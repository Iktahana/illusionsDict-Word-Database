        "examples": {
          "standard": [
            {
              "text": "春の終わりに、蝦夷上溝桜の白い花が山肌を淡く染める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "散歩中、道端に落ちた蝦夷上溝桜の小さな実を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "蝦夷上溝桜の木の下で、鳥たちが楽しそうにさえずっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "独特の香りを放つ蝦夷上溝桜の花は、ミツバチにとって貴重な蜜源だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その公園には、樹齢何十年もの蝦夷上溝桜の大木がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
