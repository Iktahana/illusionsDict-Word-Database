[
  {
    "uuid": "280b99d6-beff-58f7-923b-2da5b18686dc",
    "entry": "恵方",
    "reading": {
      "primary": "えほう",
      "alternatives": [
        "きっぽう"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "favourable direction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年の恵方は南南東だから、その方向を向いて巻き寿司を食べよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "引っ越しをするなら、恵方にある物件を探すのがいいと母が言っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "恵方を調べて、神棚をそちらに向けて置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "年内の御重宝九星売が、恵方の方へ突伏して、けたけたと堪らなそうに噴飯したれば、苦虫と呼ばれた歯磨屋が、うンふンと鼻で笑う。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてその日も夕になれば主人は肩衣を掛け豆の入りたる升を持ち、先づ恵方に向きて豆を撒き、福は内鬼は外と呼ぶ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは元日の黎明に若水汲んで含嗽し、衣を改めて芝浦、愛宕山、九段、上野、待乳山などに初日の出を拝し、帰来屠蘇雑煮餅を祝うて、更に恵方詣をなす、亀戸天神、深川八幡、日枝神社、湯島天神、神田明神などはその主なるものである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "北宋太宗の太平興国七年に、尚薬奉御王懐隠等に詔して、太平聖恵方一百巻を撰ばしめた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宗は自らこれに叙して、「朕尊居億兆之上、常以百姓為心、念五気之或乖、恐一物之失所、不尽生理、朕甚憫焉、所以親閲方書、俾令撰集、溥天之下、各保遐年、同我生民、躋於寿域、今編勒成一百巻、命曰太平聖恵方、仍令彫刻印版、※施華弟、凡爾生霊、宜知朕意」と云つてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "太平聖恵方の完本は、躋寿館に永正中の鈔本の覆写本があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此聖恵方の第一百巻に黄帝明堂鍼灸経が収めてあつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にして人あつて古版｜首行の「太平聖恵方」の五字を削り去り、単行本として市に上せた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらの方でも御用とおっしゃる」　恵方を向いた年男。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつを機に、戯作で飯が食えるように漕ぎ着けざアなるまい――まず正月早々、今年ア恵方が当ったぞ。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんじんの二人の子供のほうは、毎年、年のはじめに歳徳神の居どころを探し、今年の恵方は北だといえば、人を附けて北へ預け、南だといえば南へ送り、疲れを知らぬ奮闘をつづけていた。",
              "citation": {
                "source": "うすゆき抄",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "まろびたる娘より転がる手毬かな万才のうしろ姿も恵方道なりふりもかまはずなりて著膨れて雑踏や街の柳は枯れたれど一月十三日　二百二十日会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青竹の神々しさよえ方棚　　　　遅望　恵方というものは毎年｜干支によって異る。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方に向って高く棚を張り、葦索を飾り、松竹を立て、供物並に燈火を献じてこれを祭るのを年徳棚といい、また恵方棚ともいうと歳時記に書いてある。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その恵方棚の中で、真新しい青竹の色が神々しく作者の眼に映じた。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「古寺の簀子も青し冬かまへ」という凡兆の句は、新に仕替えられた簀子の青さを捉えたので、背景がもの寂びた古寺だけに、青竹の効果も極めて顕著であるが、恵方棚の青竹も、浄らかな燈火、供物その他に対してまた別個の趣を発揮している。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗右衛門町の一寸変った店、恵方といふのへ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑い、暑い、暑い、暑い、へえほう。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "話に夢中になっているうちに、とんでもねえほうへ来ていらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりゃはええほうがいいんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "手間を取らせねえほうがおためですぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、ホコリかぶってる」「聴かねえほうがいいぞ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "旦那は、何もしねえほうが、いいだよ。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、地獄耳というか、よく知ってるね」「ご注意しますが、絶対あんなものには係わらねえほうが、いい。",
              "citation": {
                "source": "人外魔境",
                "author": "遊魂境",
                "note": "青空文庫"
              }
            },
            {
              "text": "うんともすんともいわず、ぼろ着物はもえほうだいです。",
              "citation": {
                "source": "こわいことを知りたくて旅にでかけた男の話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶、とんび、舞い舞いせえほうらく割ったら買うてやろ　だが鳶も舞わず空は薄藍色にひろがっていた。",
              "citation": {
                "source": "大根の葉",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたけえほうの酒だぜ。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……人にきかれたらたいへんだから」「なんの話だかね……おら、気が小せえほうだから、あんまりおどかさねえでくらっせえよ」　と、こわごわそばへよった下働きの耳へ口をつけて、一言何かささやいたと思ったとたん、たちまちこの下働きは、ガタガタガタガタと、とめどもなくふるえだしました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり好きにならねえほうがいいぜ、などと思うこともあった。",
              "citation": {
                "source": "落葉の隣り",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿波の海陸二十七｜関、そこを潜って剣山の間者牢までまぎれこむのは、なるほど、できるだけ密かがいいし、弦之丞様の身になっても、足手まといがねえほうがいい。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
