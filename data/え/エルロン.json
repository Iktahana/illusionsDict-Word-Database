        "examples": {
          "standard": [
            {
              "text": "操縦桿を左に倒すと、左翼のエルロンが上がり、機体は左へとロールし始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アクロバット飛行の機体が、エルロンを細かく操作して見事な横転を繰り返している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「着陸前にエルロンの動作チェックを怠るな」と、教官から厳しい声が飛んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ラジコン飛行機の主翼を製作中、エルロンがスムーズに動くようヒンジの調整を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "両軍の両翼は、ジュナップの道とニヴェルの道との左右に延びている、そしてエルロンはピクトンに対峙し、レイユはヒルに対峙している。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルロン伯の攻撃に対してサックス・ワイマール大侯がフリシュモンとスモーアンとを維持したこと。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
