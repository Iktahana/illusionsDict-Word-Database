        "examples": {
          "standard": [
            {
              "text": "図書館で、古代エチオピアの碑文を解読するための資料を探し、エチオピア語の専門書を借りた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "言語学の講義で、エチオピア語のようなセム語派の言語が持つ独特の構造について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この本のエチオピア語の文字、初めて見た！すごく神秘的だね。」と友人が感嘆の声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "猴の称えを諸国語でざっと調べると、ヘブリウでコフ、エチオピア語でケフ、ペルシア語でケイビまたクッビ、ギリシア名ケポスまたケフォス、ラテン名ケブス、梵名カピ、誰も知る通り『旧約全書』が出来たパレスチナには猴を産せず。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
