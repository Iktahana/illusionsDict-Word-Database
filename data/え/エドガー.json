        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "EDGARシステムは、米国証券取引委員会の開示書類を検索するために使用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "初期のEDGARシステムは、大量のデータを効率的に処理するために開発された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "投資家は、EDGARで公開されている企業の財務報告書にアクセスできる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「日本人は直ぐに西洋人の真似をするのだナ」　と思いながら「エドガー、アラン、ポー」「エドガワ、ランポ」と心の中で繰り返して、何とも云えない物足りなさを感じた事を、今でもハッキリと記憶しています。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君はエドガー・アラン・ポオのデュパンを彷彿とさせるね。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の彼方のイギリスには、いま、エドガー・ウォーレスという探偵小説の流行児がある。",
              "citation": {
                "source": "ヴアン・ダインの作風",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　＊　　　＊　エドガー・アラン・ポー（Edgar Allan Poe）は、一八〇九年一月一九日、マサチューセッツ州ボストン市に生まれた。",
              "citation": {
                "source": "ポウの本質",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガーは三歳の時父母を亡ったので、ジョン・アランというヴァージニアの煙草商に養われた。",
              "citation": {
                "source": "ポウの本質",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸川乱歩という名前は、言うまでもなく、エドガー・アラン・ポーの音からとったペン・ネームである。",
              "citation": {
                "source": "日本の近代的探偵小説",
                "author": "――特に江戸川乱歩氏に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまイギリスの通俗小説の寵児、エドガー・ウォーレスのごときは、数週間も彼の新刊が出ぬと、ウォーレスは病気でもしたんじゃないかと読者があやしむということだ。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある新聞はエドガー・アラン・ポオの探偵小説「マリー・ロージェー事件」を引用して、ポオのような推理の力の発達した人間はもう出ないのかと慨歎した。",
              "citation": {
                "source": "恐ろしき贈物",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガー・アラン・ポオの小説を読むと、他人の眼を忌んで殺人を行う話がある。",
              "citation": {
                "source": "鼻に基く殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（エドガーと名づけられた男の子は八歳で夭折した。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ジョン・ハーシーや、パール・バックやアグネス・スメドレー、エドガー・スノウ、ヒュー・ディーンその他見る夢のなかに中国があらわれることのある人々の精神は、東洋にとって貴重なだけではない。",
              "citation": {
                "source": "「ヒロシマ」と「アダノの鐘」について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アジアの文学は、パール・バックやエドガー・スノウやオーエン・ラティモアなどの優秀な西欧の人間性を通じて世界文学に座をつらねる段階をぬけて来ている。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガー・ポーの知慧だな。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩中奇書といふは、エドガー・スノウの支那に関する新著のことなり。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガー・アラン・ポーの「ウィリヤム・ウィルスン」、オスカー・ワイルドの「ドーリアン・グレーの肖像画」などと共に、この種の文学としては世界的古典となっているが、それらとの比較も読者にとって興味ある題目であるだろう。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガー・キネエはそれをかう説明した。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィチ・クロポトキン　Pyotr Alkseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガー・キネェはそれをこう説明した。",
              "citation": {
                "source": "革命の研究",
                "author": "ピョートル・アレクセーヴィッチ・クロポトキン　Pyotr Alekseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　鼠は此質問を聞き流して速かに云ひ續けました、『――エドガーアセリングと共に、行きてウィリアムに面謁し、王冠を捧げたのは當然のことです。",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティガンド、国うれうカンタベリ大司教までもエドガー親王連れてウィリアムに面会し冠を差し出すのが得策と見た。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『得策だと見たのが、エドガー親王連れてウィリアムに面会し冠を差し出すことで、ウィリアムのふるまいは初めのうちおだやかだった。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説は、エドガー・アラン・ポーに始まると思われているが、中国には早くも元代に『棠蔭比事』があり、日本には三百年前の井原西鶴に『桜蔭比事』がある。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物小説というもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドガー・アラン・ポーなども興味深く読んだ。",
              "citation": {
                "source": "平次と生きた二十七年",
                "author": "――筆を折るの弁――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自注３）エドガア・スノウの本――エドガー・スノウ『中国の赤い星』。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその反対に、正直な男をあまりしつこく悪漢呼ばわりすれば、彼は、自分がまんざら悪漢でなくもないことを証明したい、旋毛曲りな欲望を起すだろう」（エドガー・ポオ）　私はもともと「正直な男」ではない。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も、また自分が属している社会をも、アルコールは肯定してしまう」　エドガー・フリーデンバーグによるこのアルコール観は、正しいのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その虚をついて、人間以外の犯人を持ちだして、アッといわせる手は、探偵小説の開祖エドガー・ポーが「モルグ街の殺人」で先例をひらいた。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見つけたのよ、エドガー。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "この封筒を渡して、あなたによろしくって」　妻の差し出した封筒をエドガー・シートンが面倒くさそうに受け取り、乱暴に指で封を切った。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしそうねえ」　エドガーが子供を両手で持ち上げて優しくキスして、片手で抱きかかえ、もう片方を妻の腰に回して答えた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
