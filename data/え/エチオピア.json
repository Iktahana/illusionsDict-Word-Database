        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "エチオピアはコーヒー発祥の地として有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "幼い頃、エチオピアの貧困問題についてのドキュメンタリーを見て衝撃を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いつかエチオピアに行って、その歴史的な遺跡をこの目で見たいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "エチオピアで同様の場合に貸し方と借り方二人の片脚を足枷で縛り合せて不自由させるという話と似ていて可笑しい。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりエチオピアへお出でになりたいからダイナマイトをくれって仰言るんですね。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ……エチオピアへでも行こうと仰言るのに度胸が御座んせんねえ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしも新張眉香子です……ですけど、貴方ホントにエチオピアへいらっしゃるおつもり？",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもない事ですから……イクラでも……わたくしモトからエチオピア贔屓ですから。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに大勢でエチオピアまでお出でが出来ますかしら。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなお話……」「そこへ今度のエチオピアの戦争なんです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のイタリーとエチオピアの戦争ってものは、元来イギリスの資本家筋が欧州の勢力の平衡を破り、エチオピアの利権を掴みたいばっかりに巧みに双方を煽動して始めさせたものですが、そいつがマンマと首尾よくイギリスの都合の宜い解決しちゃたまりません。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "便宜上エチオピアと申しましたが、実はスエズなんです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "または、エチオピア皇帝。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "エチオピアの金糸蛇の長い尾のように、何故在ったか。",
              "citation": {
                "source": "セトナ皇子（仮題）",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "問…王の眼、口等は王の命に依ってその敵手たるキタ人、エチオピア人、アッシリア人、リビア人、又はその愛する女性等に対し屡虚偽の表現をなせり。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　イタリアとエチオピアとの葛藤が永びいて、ほとんど毎日のようにムッソリニの顔が新聞に出る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　エチオピア事件でほとんど毎日毎夕の新聞に伊国首相や、エ国皇帝、それから国際聯盟の英仏代表イーデン、ラバールの肖像が出る。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エチオピアを領しつるが、希臘のアヒルレエスに滅されぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽に暮さしてやるって言えば、エチオピアにだって、連れてってやるよ」「楽な暮しなんかしたいとは思いはしないけれど、安心したいわ」「誰だって安心に暮したいさ。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一三三〇年頃仏国の旅行僧ジョルダヌス筆、『東方驚奇編』にいわく、エチオピアに竜多く、頭に紅玉を戴き、金沙中に棲み、非常の大きさに成長し、口から烟状の毒臭気を吐く、定期に相集まり翼を生じ空を飛ぶ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリニウス言う、エチオピアの長生人アトス山の住民等蝮を常食とし、虱生ぜず四百歳の寿を保つと。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴の称えを諸国語でざっと調べると、ヘブリウでコフ、エチオピア語でケフ、ペルシア語でケイビまたクッビ、ギリシア名ケポスまたケフォス、ラテン名ケブス、梵名カピ、誰も知る通り『旧約全書』が出来たパレスチナには猴を産せず。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "エチオピアに産し、その他の気候に適住し得ずというと。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六八四年パリ板サントスの『東エチオピア史』一巻七章に、カフル人は猴はもと人だったが、言えば働かさるるを嫌い猴となって言わずと説くとある。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖あの山々の向うでエチオピアの戦のあるのを誰一人口にしない。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "広く知られている通りイタリーのアフリカ植民地政策の活溌さはエチオピア問題を見ても明かであり、リビアは最近急速に戦時軍需資源の獲得地となっている。",
              "citation": {
                "source": "イタリー芸術に在る一つの問題",
                "author": "――所謂「脱出」への疑問――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エチオピアの方から来たのだそうだから、解るまいとは思うが――どけるか？",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エチオピアの王ヒダスペスは后ペルシナを娶りて十年の間子無かりしに、十年目に姫君誕生ありし由に候。",
              "citation": {
                "source": "アンドレアス・タアマイエルが遺書",
                "author": "ANDREAS THAMEYERS LETZTER BRIEF",
                "note": "青空文庫"
              }
            },
            {
              "text": "『わたくしは、それから、エチオピアではどうして果物の砂糖漬を拵へるのだか知りたくて仕方がございませんの。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで王は畢生の記憶力を絞つて、エチオピアの料理人が榲※を蜜の中へ入れて貯へる方法を叙述しようとした。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "エチオピア王は縛られながら「殺すぞ」と云つて盗人を嚇したが、バルキスは冷い朝風に身をふるはせながら、未だ見ぬ物を見るやうに、唯ほほゑむばかりであつた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "が一刻も早くエチオピアへ帰らうではないか』バルタザアルはかう云つた。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
