    "definitions": [
      {
        "index": 1,
        "gloss": "readily",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "相手の弱点を見つけ、得たり賢しとばかりに攻め立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議で自分の意見が採用され、得たり賢しとばかりに補足説明を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ライバルチームのミスを得たり賢しとばかりに利用し、逆転勝利を収めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わたくしは得たり賢しと、女の持つ媚態、女の持つ技巧を次々と繰り出させ、「あんた方、おいしいもの喰べて来たのね。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼に取っては迷惑千万な宗教問題を得たり賢しと自分に引取って面白くもない自己吹聴を並べたてる回々教徒の女の誇張した恍惚感の説明や排他的な語気は、たとえ相客が表面無礼を感ぜぬように装って居るにしても主人側から見て英国人のサロンの空気をにがにがしくするように思った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその都度、番犬が得たり賢しとその美味い麺麭菓子をぱつくりくはへては、ガツガツ言ひながら食つてしまふので、その物音に初めて我れに返つた叔母さんはいつも火掻棒で犬を打つたものだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちは得たり賢しと、勿體らしくこの歌を持ち出して、あき風ぞ吹く白河の關……。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たり賢しと、悋気深い手合がつまらんことを言い触して歩きます。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たり賢しと二人は入って来たものだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と申しますから、こちらは得たり賢しと鼻を一ぱいににやつきながら、『いかにも天気ぐらいは変るかも知れませぬて。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂というやつはこういう時に得たり賢しと立つ。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、やや怖れをなしたのは、多少心得ある者だけで、猛牛に次ぐに野牛、野あらし、野犬、まき割り、向う脛の連中が、得たり賢しと自分たちの稽古をやめて、我勝ちにと兵馬の周囲に集まって来たことです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "意地の悪い烏は可厭に軽蔑したやうな声を出して、得たり賢しと頭の上を啼いて通る。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼は得たり賢しと彼女に随って出て行った。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その奸臣が進めればこそ殿には藪原へも参られるのじゃ、ましてそなたを御殿へ昇せ殿のお側に侍らせたなら、奸臣どもは得たり賢しと殿に淫酒を進め参らせ木曽の館を忽ちにして、伏魔殿とするに相違ない。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手短に云うと、自分は暗い所へ行く気でいるんだが、実のところはやむを得ず行くんで、何か引っかかりが出来れば、得たり賢しと普通の娑婆に留まる了簡なんだろうと思われる。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩兵は得たり賢しと、『私は何時迄も何時迄も、毎日々々此處に坐つて居れば可いンだ』と繰返しました。",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私が答えようとするその途端、ツァ・ルンバは得たり賢しと「こなたは即ち日本人である」とこう一口に答えてしまった。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "折助に向って、これは内密だがねと言って話をすれば、得たり賢しとそれを吹聴する。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとて、ここで弱味を見せて、自分が引返しでもして、先方が得たり賢しと逆襲でもして来ようものなら、いったいどうするのだ、白昼、平野の中で、鉄砲玉の一斉射撃の筒を向けられたのと同じ立場ではないか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると、自分が表口へ飛びうつって、履物を突っかけてあちらから外へ飛び出すと、かえって幸いに、その怪しい奴と鉢合せをするかも知れない――得たり賢しと米友が、その通り実行を試みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私に客、ああそう」　得たり賢しと彼は立った。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "指令を受けた彼はあらかじめ事件の全貌をぐっと睨み、小首を捻ったのち、得たり賢しと部下を八方に散らしたのである。",
              "citation": {
                "source": "長屋天一坊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿引は得たり賢しと小腰を屈めながら、「もし／＼／＼／＼／＼／＼……」　とばかり息もつかずに両方から招き寄った。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お隠れになるのは」「…………」「いらっしゃいよ」　安達君は得たり賢しと、お相伴をして、そのまゝ上り込んだ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――長崎以来、雪女の女中｜弟子になっていた玉枝が、羅門へ仔細を通じたので、悪の首領たる其方は、得たり賢しと、善人の郁次郎を、誰が目にも、すべての下手人であるように仕組んで、まず第一に、雪女を殺した」「待てッ、江漢」　羅門は、かつて彼が吐いたことのない呶号で罵った。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼が室外に出て鍵をかけていったとしても、さっき煙のようにこの部屋に闖入した蠅男の一味は、えたりかしこしと帆村の留守中に再びこの部屋に押し入り、糸子に危害を加えるかもしれないのだ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに、そこに見はりをしていた海底超人の姿は見えなかったので、えたりかしこしと、すぐさま無電室にとびこんだ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
