        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "劇が始まると、役者がエプロンに出てきて挨拶した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この劇場は客席からエプロンがよく見えて、役者の表情が近くで感じられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演出家はエプロンを効果的に使って、観客との一体感を高めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
