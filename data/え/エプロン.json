          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "料理をしている間は、服が汚れないようにエプロンを着用してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのアーティストは、キャンバスに取り掛かる前に、絵の具で汚れたエプロンを身につけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "祖母はパンを焼くとき、いつもきれいなエプロンをしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ソーダの瓶と菓子｜麺麭の籠とが縞のエプロンの上で日の光を受け止めている。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大柄な肥った女で、近頃はやる何とかいう不思議な髪を結って、白いエプロンを掛けていた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏頂づらして足音も荒々しく、部屋へかえると、十七、八の、からだの細長い見なれぬ女中が、白いエプロンかけて部屋の拭き掃除をしていた。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに、食堂のなかを覗くと、奉仕の品品の饗應にあづかつてゐる大學生たちの黒い密林のなかを白いエプロンかけた給仕の少女たちが、くぐりぬけすりぬけしてひらひら舞ひ飛んでゐるのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに、食堂のなかを覗くと、奉仕の品品の饗応にあずかっている大学生たちの黒い密林のなかを白いエプロンかけた給仕の少女たちが、くぐりぬけすりぬけしてひらひら舞い飛んでいるのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいは大急ぎで書物をしまい、机を片づけ、台所に出て、白いエプロンを袂ごと胸高に締め、しばられた袂の中からようようの思いで襷をさぐりだすと、それをつむりに潜らせようとしたが、華やかなその色が、夕暗の中で痛いように眼に映った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいさんは慌て気味に襷とエプロンとを外ずしながら、茶の間に行ってラムプの芯をねじ上げた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "休業のはり札して、ぴたりと扉をとざした、何とか銀行の窓々が、觀念の眼をふさいだやうに、灰色にねむつてゐるのを、近所の女房らしいのが、白いエプロンの薄よごれた服裝で、まだ二時半前だのに、青くあせた門柱に寄り添つて、然も夕暮らしく、曇り空を仰ぐも、ものあはれ。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "振向いて見ると、一目でそれと判るような、小綺麗なエプロンを胸にかけた可愛らしい女中が、悲しそうな顔に何か訴えたいような風情を示しているのであった。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "古ぼけたエプロンの中には、たくさんのマッチを入れていました。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっ白いエプロンを掛けている。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の中には革のエプロンの仕事着のまゝで買物包みを下げた女中と踊っている者もあった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みよはその一房一房の朝露を白いエプロンで手早く拭きとつて、下の籠にいれた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉野さんは、やがて起き上り、顔をエプロンで覆ったまま部屋から出て行った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でだれでも子どもならば、鍛冶屋がどうして火をおこし、どうして鍬をうつか、仕立屋がどんなふうにミシンをまわし、どんな工合にエプロンのポケットをぬいつけるか、またせんべやのじいさんが、せんべをさしはさんだ、うちわようのものをどんな順序で火の上でひっくりかえすか細かいところまでよく知っていた。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "エプロンを貸して下さいな」「や、美人を雇いやがった。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの眠さ、あなたの笑い、あの昼日中、エプロンのかな糸のくず、みんな、そのまんまにもらってしまって、それゆえ、小説も書けないのです。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、私が荻窪の下宿にいたとき、近くの支那そばやへ、よく行ったものであるが、或る晩、私が黙って支那そばをたべていると、そこの小さい女中が、エプロンの下から、こっそり鶏卵を出して、かちと割って私のたべかけているおそばの上に、ぽとりと落してくれた。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」朗らかに笑って言って素早く母の髪をエプロンで拭いてやり、なんでもないようにその場を取りつくろってくれたのは、妹の節子である。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、エプロンの下から小さい銀のペーパーナイフをちらと覗かせてみせた。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いエプロンを掛けている。",
              "citation": {
                "source": "リイズ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と小さく叫んで、素早くエプロンをはずし、私の斜め前に膝をついた。",
              "citation": {
                "source": "女神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでわたくしは母に代ってエプロンをかけて炊事もすれば洗濯もいたします。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お秀が簡単服の前にかけたエプロンの端で額の汗を拭き／＼乞食の着物の裾を火の上へかざしてやっているうち、着物はどうやらごわ／＼に乾きかゝって来ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は給仕の服にエプロンをかけていた。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は外から見てゐた水色の洋服を著た女で、一人は島田に結うて白いエプロンをかけた十六七にしか見えない女であつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにエプロンを外すと、お太鼓の帯も妙にぺったりして、模様の金魚もなにか貧弱だ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重ちゃんはいつもエプロンの袖から白い腕をにゅっと出して、それが生々しく魅力があった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白のエプロンをかけた船のナースがシェンケでポルト酒かなにかもらってなめている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
