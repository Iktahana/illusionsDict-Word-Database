        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アルファベットの「L」は、曲線が特徴的な文字だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このコードは、A、B、C、そしてLの順で進行する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "anger はアイスランドの 〔a&ngr〕 やＬの angor などのような「憂苦」を意味する言葉と関係があるそうで、一方ではまたスウェーデンの「悔恨」を意味する 〔a&nger〕 に通ずる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでｇｒの代わりにｆｒを取ってみると英国の激怒 fury, Ｌの furia, furere に対する。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の vex はＬの uehere に関係し「運搬」の意がありサンスクリトの vah から来たとある。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらぶる神」の「アラブル」がＬに rabere = to rage に似ていることも事実である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の head はチュートン系の haubd といったような語から来ているが、音韻法則によるとＬのカプトとは別だそうである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはＬの tumuli（堆土）と同音である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＬの capillus はもとは cap（頭）の dim. だそうで caput や、ギリシアの「ケファレ」も同じものである。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　すみれ娘　日本の近代映画でも、ＰＣＬの提供するものの中には色々な点で有望な進歩の動向を示しているものがあるように思う。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のもろもろの借金を（Ｐ・Ｃ・Ｌからなるせからの払ッて下さい。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "あい度えなァ、さぞ立派なお貸元になってる事だろう」（Ｏ・Ｌ）Ｓ＝七五郎の住居の表　それは曾つての日、石松が故郷を出る時、七五郎と語ったあの場所です。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「年は若いが跡見ず三次」（Ｏ・Ｌして）Ｔ「江戸で名うての巾着切です」Ｓ＝町角　角を曲って三次やって来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｏ・Ｌして）Ｓ＝他の道――　ブラブラ鼻唄、唄って歩く三次の移動。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｏ・Ｌして）Ｓ＝通り――　横丁から鉄五郎通りへ出て来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｏ・Ｌして）　大入満員と書いた札。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次、Ｔ「昨夜、芝居が　果ててから　帰りを急ぐ仲蔵　の駕籠を……」（此のタイトル次の画面にＯ・Ｌして）　＝深夜の街　帰りを急ぐ駕籠一丁。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｏ・Ｌ）　＝元の室　大吉尚沈んで居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ　慶長十七年卯月十三日　豊前小倉の海上の　離れ島に（Ｏ・Ｌ）Ｔ　父の敵佐々木巌流と　彼を護る剣士三十余名と　決戦すＳ＝海上　数艘の小舟に分乗した、佐々木巌流の一隊。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "相合傘の下に、　いきち、おるい　その戯書の大写からＯ・Ｌして、７＝元のお類の待っていた処　お類と伊吉のラブシーンです。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）２４＝（Ｆ・Ｉ）舟宿於加田の表（夜）　入口の行燈からＯ・Ｌして２５＝内部の座敷　生島屋太郎左衛門と例の寺へ逃げ込んだ浪人乾浪之助が密談して居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｏ・Ｌ）３２＝敬四郎の家表　お兼さんが矢っ張り提灯持ってお詣りに出掛けます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）24＝（Ｆ・Ｉ）舟宿於加田の表（夜）　入口の行燈からＯ・Ｌして25＝内部の座敷　生島屋太郎左衛門と例の寺へ逃げ込んだ浪人乾浪之助が密談して居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｏ・Ｌ）32＝敬四郎の家表　お兼さんが矢っ張り提灯持ってお詣りに出掛けます。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはルクレチウス的直観能力の要素であってこれをＬと名づける。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もしこの三つの能力が測定の可能な量であると仮定すれば、ＬＳＫの三つのものを座標として、三次元の八分一空間を考え、その空間の中の種々の領域に種々の科学者を配当する事ができるであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルムホルツや、ケルヴィンやレイノルズのごときはＬＳＫいずれも多分に併有していたものの例である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファラデーや現代のラザフォードやウードのごときはＬＫ軸の面に近く位している。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルツマン、プランク、ボーア、アインシュタイン、ハイゼンベルク、ディラックらはＬＳ面に近い各点に相当する。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにＬ軸の真上に座する人はもはや科学者ではない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち彼らはわれわれにＬの要素を供給しうるのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、ボオドレエルの「人と海」といふ詩の、第一行である。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            }
          ]
        }
