    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ell (unit of length, approx. 45 inches)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の生地は、ヤードではなくエル単位で測られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このコートの裏地には、3エルもの布が必要だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これは、ボオドレエルの「人と海」といふ詩の、第一行である。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しこれを歌つてゐるのがボオドレエルだと思ふと、船の沢山ゐる港、それも余り大きくない港が見えて来たりする。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく海の出て来るボオドレエルの詩だつて、「信天翁」だと、広々として一物も見えぬ、秋も終りの海が見えて来る。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてなき浪の蕩揺に、汝はなが魂打眺む……「なーるほど…」と思ふのは、恐らくボオドレエルが私自身より意識的であることに気が付くからである。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し茲でもボオドレエルは、意識的だ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩集『悲歌』は可なりな人気を博したとはいへ、猶人々は彼女をかの浪漫派時代の女詩人達、タストやセガラやエルザ・メルクールの輩と並べて考へてゐたものだつた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同時にまたボトレエルの如き冥想の詩人でもない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "常々菊池寛氏を敬愛して「英雄」と呼んで居たのも、やはりその反性格の爲であつて、丁度あの神經質のボードレエルが、豪放で世俗的なユーゴーを崇敬して居たのと同じである。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボオドレエルが「技巧論の不可能」となすものが、茲で泌々と思ひ出されるのだと云つておかう。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にはかつて決して、ボードレエルの如き真の絶望的な悲劇詩人は生れなかったし、今後の近い未来にもまた、容易に生れそうに思われない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち例へば、ポオの翻訳に於けるボードレエルの場合であつて、これが即ち「名訳」である。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にボードレエルの訳を通じて、ポオの詩を読んでる人たちは、実にはボードレエルの詩を読んでるので、ポオを読んではないのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボードレエルは、ポオを仏蘭西人に正価で売つた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポオも、ニイチェも、ショーペンハウエルも、僕はすべて我流の仕方で、神經生理學的に讀むのであり、さうでない限り、僕に讀書の興味はないのであるが、ドストイェフスキイの場合は、僕との氣質的類似の機縁で、特にそれがはつきりして居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の讀み方によるドストイェフスキイは、心理上でポオと共通し、思想上でニイチェ、ショーペンハウエルと類縁するところの作家であつたが、友人たちの見たドストイェフスキイは、やはり白樺派の人と同じく、人道主義的に見たそれであつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーペンハウエルの哲学は、この点で僕等の心理を捉え、孤独者の為に慰安の言葉を話してくれる。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショーペンハウエルの説によれば、詩人と、哲学者と、天才とは、孤独であるように、宿命づけられて居るのであって、且つそれ故にこそ、彼等が人間中での貴族であり、最高の種類に属するのだそうである。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして尚ボードレエルの言うように、僕もまたそのように、都会の雑沓の中をうろついたり、反響もない読者を相手にして、用にも立たぬ独語などをしゃべって居る。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「孤独は天才の特権だ」といったショーペンハウエルでさえ、夜は婦などを相手にしてしゃべって居たのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはキーツにもあり、シエレーにもあり、ポオやボードレエルの中にさへも、冬の季節に関する限り、必ず抒情詩の本質的な主題になつてる。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小生、このごろボオドレエルを讀み返し、反省悔恨の強烈を學びつつあります」といふ言葉だつたので、私も之以上、愚圖愚圖してゐるのは、かへつて厭味な卑下だと思ひ、叔母を訪ねることにしました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以下はフロべエルの嘆きであるが、「私はいつも眼のまへのものを拒否したがる。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五にごく近頃、ハンブルヒのシュリックという有名な造船家が大きな独楽を船中に取付け、これを迅速に回転すると横揺れがほとんど止まるという巧みな考えを出し、小形の船で実験したら非常に好結果を得たので更に目下エルベ、ヘリゴランド間通いの千トンくらいの客船に取付けるのを製造中だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ザウエルといふ犬がゐるよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボオドレエルの『悪の華』一巻はしばしば「いき」に近い感情を言表わしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、ボオドレエル自身の説明｛９｝によれば、「ダンディズムは頽廃期における英雄主義の最後の光であって……熱がなく、憂愁にみちて、傾く日のように壮美である」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
