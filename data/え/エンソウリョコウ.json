        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのバンドは、新アルバムのプロモーションのために全国演奏旅行に出かける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ピアニストは、来月からヨーロッパ各地での演奏旅行を予定しているそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演奏旅行中、彼は各地の文化に触れることで多くのインスピレーションを得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」女流音楽家　プリマ・ドンナの Tetrazzini 夫人が演奏旅行をして、アメリカの Buffalo 市に来たことがあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」女流音楽家　プリマ・ドンナの Tetrazzini 夫人が演奏旅行をして、アメリカの Buffalo 市に来たことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツルゲーネフは彼より三つ年若いヴィアルドオ夫人が、ペテルブルグへ演奏旅行に来たとき知り合いとなった。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "近衛秀麿氏が今度それを改作する由、お蝶夫人が歌手で、ピンカートンである音楽家が京都へ演奏旅行をして、最後は、お蝶がヨーロッパへ演奏に行ってその音楽家と出会いハッピーエンドになるように改作するのだそうである。",
              "citation": {
                "source": "雨の小やみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、新聞に、巖本真理が半年ほどアメリカ、カナダの演奏旅行に出発するという記事がのっていた。",
              "citation": {
                "source": "手づくりながら",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一頃このストルキオと同じオペラカンパニーで方々演奏旅行をしたことがあります。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "終いには親族会議まで開いて私の外国行きに反対した上、私が九州へ演奏旅行に行った留守に、ホノルルから送って来た二千ドルの小切手を、三浦が独断で、三浦環は病気でホノルルへ行けない、と電報で断って小切手を送り帰してしまったのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は或る時、音楽学校から岐阜へ演奏旅行に行ったことがある。",
              "citation": {
                "source": "山の声",
                "author": "宮城道雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い長い演奏旅行を了えて、私と、私の許婚の愛子は、ピアノを叩き過ぎて尖った神経とあわただしい旅に疲れた身体とを、暫らくこの淡路島の知辺に静養して居たときの事です。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃天才兄妹として有名な、立花幾久雄さんと信子さんというのはあなたでしたか、それはいい方にお目にかかりました」「そう仰しゃられると、極りが悪くなります」「何処か演奏旅行のお帰りででも？",
              "citation": {
                "source": "天才兄妹",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "公使夫人は、ウィーンが世界の音楽の都であるという点を外交官夫人としての社交生活の中心にしていて、日本へ演奏旅行に行ったジンバリストの噂が出た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戦後はオーストリアも共和国になって、伝統的な貴族、上流人の社交界がすたれてしまったために、シーズンが終るといっしょにウィーンの有名な音楽家たちは、アメリカへ長期契約で演奏旅行をするようになった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときは、ほんとに肩身のひろい思いをいたします」　アメリカへ演奏旅行したウィーンの音楽家たちは、アメリカの聴衆は入場券を買って入った以上その分だけ自分たちが楽しませられることを要求している、と云う印象をうけて来るそうだ。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェトへはヨーロッパの音楽家の誰も演奏旅行に行かなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはウィーンをはじめ各地の演奏旅行で収入を得ながら、より高い勉強もつづけようと計画していたにちがいなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏旅行で収入を得ながらウィーンにくらすという生活と、指の練習からやりなおしをはじめなければならない三十をこした一人の日本婦人としてのウィーンでの朝夕。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏旅行は九回にわたり、姉弟の人気はいやが上にも高まるばかりであったが、この旅行のためにモーツァルトの健康は一生涯｜害なわれたことも事実である。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三歳の時シューマンの第一｜交響曲をピアノで演奏した頃から、シューマンの興味は少女クララの上に燃え始め、父ヴィークに伴われて、全欧を演奏旅行し、天才少女の名を轟かした頃はシューマンとの間に美しい愛情が芽生え、それが退引ならぬ状態にまで生長していった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ブラームスはシューマンの恩顧に酬いるためにシューマンの作品や図書の整理をし、さらにシューマンの療養費を得るために、産後のクララを助けて、遠く演奏旅行に上ったりした。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの新編曲を土産に、欧羅巴に演奏旅行をした時は、とかく反感と嘲笑とに葬られがちであったが、それはパリの小インテリの好みに逆らったのが大きな原因でもあり、ハイフェッツの野心が、無検束なせいでもあったかも知れない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一例を示せば、演奏旅行中のパデレフスキーは、船中から汽車の中にまで、愛用のスタインウェーを二台持ち込み、ほとんど毎日十二時間の猛練習を続けなければ承知しないそうだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『ローリング・ストーン』グレイル・マーカス）10　バディ・ホリーやボビー・ヴィーのグループに加わり、ロックンロールの演奏旅行に出ていた、というウワサがある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "22「イギリスの演奏旅行から帰ってきて、ボクはそれまでやっていたことをやめてしまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクは、自分で自分をコピーしている自分を発見した」23　一九六四年の五月にボブ・ディランはイギリスで演奏旅行をおこない、成功をおさめた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
