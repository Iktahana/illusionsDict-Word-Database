        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭に色とりどりのエリカの花が咲いて、とても綺麗だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "母の誕生日プレゼントに、エリカの鉢植えを選びました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この辺りには、乾燥した土地を好むエリカの仲間がたくさん自生している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "幾程もなく到り着きて、アンジエリカが家をたづね得つ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンジエリカは我を佳き兒なりと讚めき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時アンジエリカ籬の後より出でゝいふやう。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンジエリカはゆく／＼怪しき老女が上を物語りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンジエリカが家に歸り着きて、我心は纔におちゐたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど我がアンジエリカが家の廣き臥床に上りしときは、母上我枕の低きを厭ひて、肱さし伸べて枕せさせ、頼ある子ぞ、と胸に抱き寄せて眠り給ひき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔幼かりし時、母とマリウチアとに伴はれて、ネミの湖に往きしかへるさ、アンジエリカが我に物語りし事こそあれ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の春ごろ、内山敏氏が、ある雑誌にトーマス・マンの長女のエリカ・マンが、弟のクラウス・マンと共著した「生への逃亡」について、エリカ・マンの活動を紹介しておられた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内山氏の紹介によると、エリカ・マンは一九〇五年生れで、日本流にかぞえれば四十四歳になっている。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　ラインハルトの下で女優となったエリカ・マンは、やがてハンブルグでおなじ俳優であるグリュントゲンスと結婚した。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリュントゲンスは才能はあったが、あとではナチスに加って、ベルリン国立劇場支配人と立身したような性格であったため、エリカの結婚生活はながくつづかず、離婚して故郷のミュンヘンにかえった。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリカ・マンには、女性にめずらしい特長があり、疲れを知らない行動力、強靭な運動神経がある。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戦後の混乱は有名なマークの暴落をひきおこし、一方にすさまじい成りあがりを生み出しながら、中産階級は没落して、エリカ・マンさえ靴のない春から秋までをすごさねばならぬ状態におちいった。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカにわたってから、エリカ・マンが語った意味ふかい警告が、内山氏の紹介に録されている。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはエリカ・マンが「私はドイツにいるあいだ（中略）政治のことは政治家にまかせておけばよいというあやまった見解でした。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時代に育ったエリカ・マンが民主主義の精神をもち、日に日につのるナチスの暴圧に反抗を感じたのは自然であった。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリカ・マンは、はじめ小論文や諷刺物語を書いて反ナチの闘争をはじめたが、一九三三年一月一日、ミュンヘンに「胡椒小屋」（ペッパー・ミル）という政治的キャバレーをひらいて、おなじ名の諷刺劇を上演したり、娯楽と宣伝とをかねた政治的集会を催し、演劇的才能と行動性とを溌剌と発揮して活動しはじめた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また反ナチ派の勢力の下にあったバイエルン州のミュンヘンでは、この報知をきいても、ナチの悪計とは知らず、エリカ・マンの胡椒小屋は謝肉祭の大陽気で、反ナチの寸劇などに興じていた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トーマス・マン夫妻は、おりからスイスに講演旅行に出かけていてエリカとクラウスとは、もう一刻も安住すべきところでなくなったドイツを去る決心をなし、スイスの両親にそちらにとどまるようにと電報して、ただちにスイスのアローザへおもむいた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父を愛するエリカは、農婦に変装した。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　エリカ・マンの「胡椒小屋」は四年間、オランダ、スイス、オーストリヤ、チェコ、ベルギー等を巡業し、いたるところで喝采をえた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリカは、舞台のうえにいていくたびか狙撃された。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューリッヒで、「公安妨害」の口実で公演禁止されたのをはじめとして、ナチス外交官が出さきの外国でまでエリカの活動を妨害して、とうとう、それを解散させてしまったのであった。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時分に、エリカ・マンはイギリスの詩人ウイスタン・オーデンと結婚した。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリカ・マンは、一九三六年、アメリカへゆき、スペイン救済の必要と、ナチス・ドイツが、戦争の温床であることを警告した。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次大戦が勃発してから、エリカ・マンの反ナチ闘争と民主主義のためのたたかいはいっそう広汎におこなわれ、「生への逃亡」ではドイツの亡命知識人の物語を描いた。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリカ・マンはまた子供のための冒険物語「シュトッフェルの海外旅行」をも書いているそうである。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナチス・ドイツの絶滅した今日、エリカ・マンはふたたび故国のドイツの土をふんでいるであろう。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことばにつくせない犠牲をはらったドイツの民主主義のために、エリカ・マンの美しいエネルギーは、まだまだ休む暇はあたえられていないのである。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
