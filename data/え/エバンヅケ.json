        "examples": {
          "standard": [
            {
              "text": "昔の相撲には、力士の強さを描いた絵番付があったそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祭りの露店で、珍しい絵番付を見つけて思わず買ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "江戸時代の絵番付には、庶民の娯楽が色鮮やかに描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "壁には、三座の絵番付やら、素人浄瑠璃のビラなどが、辻便所ほど貼りつけてあって、そのまえに、油染みた桐の櫛箱や、鬢だらいなどをすえつけて、今、一人の客の髪を結い上げているのが、親方の仁吉らしかった。",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
