    },
    "definitions": [
      {
        "index": 1,
        "gloss": "NEC (IT and electronics corporation)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うちの会社のPC、全部NECの法人モデルにリプレースされるらしいよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "NECはかつて、PC-98シリーズで日本のパソコン市場を独占していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "衛星通信の地上局設備において、NECは世界トップクラスのシェアを誇っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一つはパーソナルコンピューターを日本に普及させるにあたって、実に大きな役割を演じたＮＥＣのドキュメントです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＥＣ内部の動きに関しては、数か月前に雑誌の仕事でかなり念入りに取材しており、資料の整理やインタヴューの録音テープを書き起こす作業もすませていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "主役に据えたＮＥＣはその後、16ビットに移ってからもＰＣ―９８００シリーズを大成功させました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＮＥＣで８ビット機の開発をリードした、もともとは半導体チップの販売担当者だった後藤富雄さんは、一九七七年の発表時点で論文を読み、それ以来これを「自分のバイブルとしてきた」というのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校三年の時、友人の兄がＮＥＣのＰＣ―８００１を持っていると耳にします。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、あえて主役を求めればＮＥＣでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文庫版の冒頭は、ＮＥＣの会社概要に関する記述です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそくインターネットでＮＥＣのホームページを開いてみました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてあなたが、日電のブランドであるＮＥＣに、どのようなイメージを抱いていたかを。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもあなたが技術畑の人間であるなら、エレクトロニクス関係の企業に籍を置いているなら、ＮＥＣブランドにはかねてからハイテックなイメージを持っていたかもしれない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしほとんどの日本人は、ＮＥＣの三文字に日電の子会社、新日本電気の家電製品のイメージを重ね合わせていたはずである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和二十年代生まれの私は、ＮＥＣと聞くと「売れない家電」と思い浮かべていたことを、今もはっきりと覚えている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは五年ほど前、私はあるオーディオ誌の編集を行っていたのだが、内外のブランド約四〇を総まとめに紹介する記事の中でも、ＮＥＣのオーディオブランド「ジャンゴ」は取り上げなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが現在、ＮＥＣブランドには、そうしたしみったれたイメージはかけらも存在しない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターと通信の融合する高度情報化社会、同社流にいえばＣ＆Ｃを目指す先鋭的なイメージを、ＮＥＣは獲得している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この両者の亀裂を埋め、ＮＥＣの三文字に「Ｃ＆Ｃ」の鮮明なイメージを定着させる原動力となったものは、何といっても同社のパーソナルコンピューター、ＰＣシリーズのラインナップであろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして翌九月十三日、秋葉原駅前に新築されたラジオ会館の七階に、これもマイクロコンピューター普及のためのサービスルームとしてＮＥＣビット・インが開設される。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "子会社の新日本電気（現在の日本電気ホームエレクトロニクス）から家電製品が売り出され、それが唯一、ＮＥＣブランドと大衆との接点となっていたが、家電への進出はけっして成功したわけではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンフレットには確かに、ＮＥＣの三文字が入っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★日本電気におけるオフィスコンピューターの開発の経緯は、『「オフコン」絶え間なき変革　シェアナンバーワンＮＥＣの挑戦』（久野英雄著、ＮＥＣ文化センター、一九九三年）に詳しい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "既存のＮＥＣアメリカとは別に設立されたＮＥＣＩＳは、まずプリンターを米国市場に問うとともに、小規模ビジネス用のマーケットをオフィスコンピューターで掘り起こす可能性の検討に着手した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "発表時点ですでに、四〇〇台以上の新型プリンターがＮＥＣＩＳを通じて米国市場にサンプル出荷されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方でＮＥＣＩＳは、オフィスコンピューターをアメリカ市場で成功させるために何をなすべきかの検討を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの年の三月から、ＮＥＣＩＳはＩＴＯＳを搭載した新機種をアストラと名付け、アメリカ市場での販売を開始した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＮＥＣＩＳによるアメリカ市場への切り込みに携わったことから、浜田は引き続いてアストラにかかわることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＥＣＩＳの製品計画、現地の販売チャネルの構築、日本からの営業支援を担当していた浜田は、繰り返しアメリカを訪れ、アストラの前にパーソナルコンピューターが立ちふさがろうとしている事実を肌で感じとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七六（昭和五十一）年九月、秋葉原駅前のラジオ会館七階に、マイクロコンピューターの普及の拠点としてＮＥＣビット・インが開設されることになったとき、渡辺は運営を依託された日本電子販売の野口重次に申し入れてＴＫ―80の販売と修理、相談のためのコーナーを作ってもらうことにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて、各地の半導体部品の販売会社の中に、ＮＥＣマイコンショップを名乗ってＴＫ―80を扱ってくれるところが数軒生まれていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
