[
  {
    "uuid": "516cee0d-ea07-5be2-ba40-8aa3aa3b3a00",
    "entry": "ＮＥＣ",
    "reading": {
      "primary": "エヌイーシー",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
