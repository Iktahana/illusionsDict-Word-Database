    },
    "definitions": [
      {
        "index": 1,
        "gloss": "memorial service",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖父の七回忌の会式は、親族だけでしめやかに行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "毎年、お寺で亡くなった方々のための会式が執り行われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先月、友人のお父様の会式があったので、お焼香を上げに行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天保以来、参詣の足が少しゆるんだとはいいながら、秋の会式についで、春の桜時はここもさすがに賑わって、団子茶屋に団扇の音が忙がしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず行者一家の者どもを引き挙げて、それをぶっ叩いて白状させるよりほかあるまいと、かれは内々でその手配りにかかっていると、あしたが池上のお会式という日の朝、多吉があわただしく駈け込んで来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七が身支度をして神田の家を出たのは朝の四ツ（午前十時）過ぎで、会式桜もまったく咲き出しそうな、うららかな小春｜日和であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "数年前、東亜同文会の発会式が、東京の万世倶楽部で挙げられて、これは私も人から聞いた話ですが、その時、近衛篤麿公が座長に推され、会の目的綱領を審議する段になって、革命派の支持者と清朝の支持者との間にはげしい議論が持ち上った。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "常丸　母様今日のお会式は面白うおぢやつたのう。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代　今日は最勝寺さまの御会式ぢやさかいに、死んだ娘と、この子の父御の供養しておぢやつた。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩五時、発会式よ」「どうぞ、御自由に」「あら。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本願寺様のお会式にも負けぬという、それは大層な評判であった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "万延元年の十月、きょうは池上の会式というので、八丁堀同心室積藤四郎がふたりの手先を連れて、早朝から本門寺｜界隈を検分に出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度｜御会式の前日なので混雑してゐる」と、云ふ意味だつたのだ。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる日は、お会式の景気を見にやらされた、その記事が自分が新聞記者としての最初の記事だらう。",
              "citation": {
                "source": "世に出る前後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "発会式は非常な景気で諸万からお遣い物などが来て盛大を極め、会合するもの三百人以上で予期以上の成功であった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "発会当時およびその後のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　　　　　「Ｓ相互扶助会」発会式　正面の一段と高いところには「天皇陛下」の写真がかかっていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "演壇には「Ｓ相互扶助会」発会式の順序と、その両側に少し離して、この会が主旨とする所の標語が貼り出されていた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "石盤書記、神秘台、読心術、交霊術、結晶凝視等々の降神会式魔術で真実を知ろうとするようなことはタブーだ。",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月もお会式の頃から寒い雨がびしょびしょ降りつづいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリンピック開会式八月一日　前日からの曇天続くウンター・デン・リンデンから競技場までの街路は、突撃隊の褐色の整列で群衆はピタリと止っている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "開会式の当日、総裁として何か一つ演説をしなければならなかつたので、平素の彼を知つてゐる人達の中には、この沈黙家がどんな挨拶をするだらうかが可なり面白い話題となつてゐた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに誘致せられて中国各地に東亜連盟運動起り、十一月二十四日南京に於ける東亜連盟中国同志会の結成となり、昭和十六年二月一日東亜連盟中国総会の発会式となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この封建ファシスト団体の多数の相互間に、対立と反目とがつきものであったのは、単に国粋会式な親分子分と繩張り仁義との結果だけではない。",
              "citation": {
                "source": "思想動員論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "発会式の時運動家の連中が幅を利かして演説した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お会式　毎年陰暦十月十三日、祖師日蓮の忌日を卜して執行の法会をお会式とはいい、宗徒は又おめいこうとて本山に参籠する。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒士町の池田の家で、当主｜瑞長が父京水の例に倣って、春の初に発会式ということをした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに今年抽斎が往って見ると、名は発会式と称しながら、趣は全く前日に異っていて、京水時代の静粛は痕だに留めなかった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳の初の発会式も、他家に較ぶれば華やかであった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦郷里に帰つた難波は、例のステッキを携へて再び上京し、年末の十二月二十七日、議会の開会式に行幸のあつた折の鹵簿を待ち伏せて、狙ひ撃ちをした。",
              "citation": {
                "source": "随筆「断片」",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "……丁度、東京の池上のお会式……あれと同じ事であります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "長四畳には帝釈様の髭題目の軸がかかっていて、お会式の万燈の花傘の、長い竹についた紙の花が丸く輪にして上の方にかかっている。",
              "citation": {
                "source": "神田附木店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は丁度竹の台に、第三回内国博覧会の開会式が催される当日だつた。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "北欧風の、色は渋いが縞の荒い男ものゝガウンを着た先生は、わたくしに並んで炉べりに雄偉な両脚の膝を立て、膝頭を両手で抱えてしばらく炉の中に燃えしきる白樺の薪の焔に見入っていました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
