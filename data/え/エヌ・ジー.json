    "definitions": [
      {
        "index": 1,
        "gloss": "no good",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「悪いけど、その日は先約があるからＮＧだわ。また今度誘って！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このレストラン、ドレスコードが厳しいからサンダル履きはＮＧだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "クライアントから「このロゴのデザインはＮＧ」と突き返され、一から練り直すことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「いくら仲が良いからって、仕事中にタメ口で話すのはマナー的にＮＧだと思うよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「ＥＸＣＨＡＮＧＥ　ＩＳ　ＮＯ　ＲＯＢＢＥＲＹ。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、その友人が、私をあわれだとみたのか、島尾氏に、こんな女が居るんだと語ったらしく、それならＶＩＫＩＮＧにおいで、ということで、私は、島尾敏雄氏なるものも、ＶＩＫＩＮＧなるものも、まったく御存知ないままに、三十枚ばかりの小説をもって、六甲へ行ったわけなのだ。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小説は、アカンとされたのだが、私が、はじめて、久坂葉子なる名前を附したもので、一週間位して、第二作、「入梅」を、島尾氏のところへ持って行き、それがＶＩＫＩＮＧにのったのだ。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、彼と共に、ＶＩＫＩＮＧの例会に出席した。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、ＶＩＫＩＮＧにのる前に、島尾氏の紹介で、若杉慧なる人に会い、彼がみせて下さいと持ってゆかれた。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ＶＩＫＩＮＧ族の方が、よっぽど愉快だと感じた。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、灰色をかいて発表して、自分には、技巧の訓練がまるでないのだということを知り、何だか自分に、おそろしくむかっ腹をたてて、ＶＩＫＩＮＧを脱退してしまった。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＶＩＫＩＮＧにも復帰し、古い原稿を整理しては発表して行った。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼の意志かあわれみで同人雑誌のＶＩＬＬＯＮか、ＶＩＫＩＮＧに印刷されるでしょう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＶＩＫＩＮＧの同人、宇野氏が、あなたを御存知だから。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿も（芝居の）ＶＩＬＬＯＮかＶＩＫＩＮＧに、富士さんは、のっけてくれるだろう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿も（芝居の）、ＶＩＬＬＯＮかＶＩＫＩＮＧに、富士さんは、のっけてくれるだろう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月三十一日　午前二時頃（昭和二七年一二月三一日作、「ＶＩＫＩＮＧ47・ＶＩＬＬＯＮ４」共同刊行号、昭和二八年三月）",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和二四年九月九日作、「ＶＩＫＩＮＧ」11号、昭和二四年一〇月）",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二度目の映畫の時にね、私が何かしくじつて――たしか私のためＮＧが出ちやつて――當時フィルムが足りないのでＮＧがやかましかつた時代でしよう、助監督から頭ごなしにダイコン！",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあもうＮＧは出せないわけだな」ディレクターは言った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のほかに、私個人としての好みに過ぎぬが、ＨＭＶとＮＧＳのレコードだけは別の棚に整理している。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＧＳの昔の袋も厚くてよかった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ・Ｗ・ＹＯＵＮＧ氏の編纂した『マウンテン・クラフト』は、いろいろな意味において私の愛読書である。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "・ヘミングウェイ＆そのさなえ（2011）『マンガ版老人と海』（ＭＡＮＧＡＢＵＮＧＯシリーズ、ホーム社発行、集英社発売）。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はこっちが出そこなったり舌をかんだりしてＮＧを出し、やっとこさ終った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼近く漸っと来り、音楽同時で、洋服屋と靴屋のかけ合ひの歌、これが大した御難で、土屋・吉岡等のうちの連中がＮＧをやたらに出す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまひには、監督ＮＧ、キャメラＮＧといふさわぎ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "outtake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「特典映像に収録されてるＮＧ集が、本編のシリアスな雰囲気とギャップがあって面白いんだよね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あーあ、せっかくのいいシーンだったのに、噛んじゃってＮＧになっちゃった。もう一回お願いします！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "撮影現場は非常に和やかで、役者がＮＧを出すたびに温かい笑いが起きていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "何回もＮＧを重ねて、ようやく監督のオッケーが出たときは、スタッフ全員から拍手が沸き起こった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
