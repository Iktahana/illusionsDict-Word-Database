[
  {
    "uuid": "71a4bc47-6623-5101-b1e5-2b309a74d421",
    "entry": "遠離",
    "reading": {
      "primary": "えんり",
      "alternatives": [
        "おんり"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "separation by a great distance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は都会の喧騒を遠離れ、静かな田舎で余生を送ることを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "故郷を遠離れて初めて、その大切さに気づくものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この岬は陸地から大きく遠離れており、まさに絶海の孤島といった風情だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それらは私の足音が遠離ればまたわけの分らぬ陰濕な會話で靜寂を領するやうに思はれた。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや遠離ってから私達はお互いに笑い合ったことです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗円　遠離一切顛倒夢想。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（シリクダ長老の偈）電は槃荼婆山の岩に墜つ我も坐らむその電を我竹叢の中にありて甘き乳糜を喫し、好く諸蘊を思念し心を遠離に専らにして、嶺を占得せん。",
              "citation": {
                "source": "風隠集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦東京を遠離してから、私の生活は一変した。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "作曲家でもあり作詞家でもあった孔子は、次第に遠離り行く都城を顧みながら、歌う。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはこの昔の友を敬する念を禁ずること能はずして、運命の我等二人を遠離けしを憾とせり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "顛倒の世界　次に、「顛倒夢想を遠離して、究竟涅槃す」ということですが、普通には、ここに「一切」という字があります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、「顛倒夢想を遠離する」ということは、そうした妄想を打破ることです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "この故に極致をみだりなりとして、實を美術の材にせむとするものは、おのづから類想を遠離りて個想に近寄らむとす。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "戲曲の作者は全く個人の主觀（能感）を遠離して、深く曲中人物の主觀に潜めり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋しゾラは天のなせる詩人なれば、おのれは空想を遠離けて批評をなし、試驗をなすとおもひつゝも、神來に逢ひ、空想を役したり。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その第一は陸の生活と遠離の感で、まるでロビンソン・クルーソーになった気持である。",
              "citation": {
                "source": "荒磯の興味",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は計らずも洋臭を遠離して、東方の国土の情調に浸つたのであつた。",
              "citation": {
                "source": "念珠集",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの仏遺教経の遠離功徳分にあるごとく「寂静無為の安楽を求めんと欲す」る比丘は「当に※閙を離れて独処に閑居し」「当に己衆他衆を捨てて空間に独処し」なくてはならない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "法華経を広める者には必ず三類の怨敵が起こって、「遠離於塔寺」「悪口罵言」「刀杖瓦石」の難に会うべしという予言は、そのままに現われつつあった。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いねにけらしも」は、親愛の大御心であるが、素朴・直接・人間的・肉体的で、後世の歌にこういう表現のないのは、総べてこういう特徴から歌人の心が遠離して行ったためである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見はこの言葉を心の奥の奥、深淵の中で、うち返しうち返してみた後に、すべての暗い雑念を遠離して、この単純なる告白の言葉を得たものと信じている。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五　一は利養の道、一は涅槃の道、斯く通達する佛陀の弟子なる比丘は、名聞を好むべからず、益々遠離に住すべし。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇五　遠離の液を飮み、又寂靜の液を（飮み）、（又）法喜の液を飮みて罪過を離れ（又）惡を離る。",
              "citation": {
                "source": "法句經",
                "author": "荻原雲來訳註",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、われわれは生滅界にありて生滅の波間に浮きつ沈みつして、三界六道の間に迷いつつあるものなれば、今よりこの生滅界を離れんと欲すれば、善因善果の規則にもとづき、これを遠離せんとする志を起こし、種々の善因を修めて真如界に向かうことをつとめねばなりませぬ。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "セルギウスは此時あらゆる現世の物を遠離ける祈祷をした。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもいたしますからごえんりょなくおおせつけてくださいまし」と申し上げました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞごえんりょなくおっしゃってください。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ王さまのおひめさまともなれば、たいして人にえんりょする必要はありませんでした。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもういちどおどったときに、王女はあやうく恋をうちあけようとしたくらいですが、考えぶかい娘でしたから、生まれた国のことや、じぶんの治める王国のこと、いつかはじぶんが上に立つはずの人民たちのことをおもって、えんりょしたのです。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いついたら、深くも考えず、ぱっぱっとやってしまったんだ」「馬鹿しちゃったね」と東一君は孫だからえんりょなしにいった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとみんなは、太郎左衛門を尊敬したりするのはふさわしくないことがわかり、えんりょなく、「太郎左衛門」とよぶようになった。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さようさ、それは――いや、まあ、ごえんりょ申しましょう。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあお菊さん菓子とらねいか鉄っさんのおごりだからえんりょはいらねいよ。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "detachment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの作家の作品は、常に現実離れした世界観で、人々の心を日常から遠離れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "感情的な混乱から遠離れ、冷静に状況を分析する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は派閥争いから遠離れ、独自の道を歩むことを決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
    ],
