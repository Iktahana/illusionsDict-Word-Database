        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「えたり！これでやっと完成だ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "難関を突破して、思わず「えたり！」と叫んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プレゼンが大成功し、心の中で「えたり！」とガッツポーズした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "まづ二人は席を得たり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもし「一週間内に東海道の大部分に降雨あるべし」との予報をなし得たりとせば、東京市民にとりては極めて漠然たる印象を与うべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すなわち男爵閣下の御肖像を彫ってくれろと言うのでしょう」「ヒヤヒヤ、それだそれだ、大いに僕の意を得たりだ、中倉さん、全く僕の像を彫ってもらいたいのです、かく申す『加と男』その人の像を。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は靉河右岸に沿い九連城以北に工事を継続しつつあり、二十八日も時々砲撃しつつあり、二十六日｜九里島対岸においてたおれたる敵の馬匹九十五頭、ほかに生馬六頭を得たり――「どうです、鴨緑江大捷の前触れだ、うれしかったねえ、あの時分は。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　海野は今この反問に張合を得たりけむ、肩を揺りて気兢いかかれり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとたび歩を急にせんか、八田は疾に渠らを通り越し得たりしならん、あるいはことさらに歩をゆるうせんか、眼界の外に渠らを送遣し得たりしならん。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが荼吉尼法は著聞集に、知定院殿が大権坊という奇験の僧によりて修したところ、夢中に狐の生尾を得たり、なんどとある通り、古くから行われていたし、稲荷と荼吉尼は狐によって混雑してしまっていた。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "李花遠きに宜しく更に繁きに宜しと楊萬里の云ひたるは、よく云ひ得たりといふべし。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "開門忽怪山為海、万畳雲濤露一峰と詩にいへるも、まことによく云ひ得たりといふべし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お露は児のために生き、児は島人の何人にも抱かれ、大河はその望むところを達して島の奥、森蔭暗き墓場に眠るを得たり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらず、あらず、彼女は犬にかまれて亡せぬ、恐ろしき報酬を得たりと答えて十蔵は哄然と笑うその笑声は街多き陸のものにあらず。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんじはまことに幸いなる報酬を得たりと思うや二郎、とわれは二郎の顔を仰ぎて問いぬ。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはこの損失を償いて余りある者を得たり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は治子の事を思い絶たんともがきぬ、ついに思い絶ち得たりと自ら欺きぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を恋うることの深きによりて、われ初めてこの深き悲哀を知り、さらに限りなきの望みと力とを得たり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで燕は得たりとできるだけしなやかな飛びぶりをしてその窓の前を二、三べんあちらこちらに飛びますと、画家はやにわに面をあげて、「この寒いのに燕が来た」　と言うや否や窓を開いて首をつき出しながら燕の飛び方に見ほれています。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕は得たりかしこしとすきを窺って例の金の板を部屋の中に投げこんでしまいました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たりやと、波と風とはますます暴れて、この艀をば弄ばんと企てたり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日清戦争に於ける戦勝の結果、国民は自信力なる精神上の偉大なる賜物を得たり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "▲日清戦争に於ける戦勝の結果、我は当然得べき遼東半島を奪取せられしも、同時に臥薪甞胆なる壮烈の意気を得たり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "我は本日漸くこれを得たり。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たりと医師は膝立直して、水薬を猪口に移し、「さあこれをお飲みなさい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と捻じれば開くにぞ、得たりと内へ忍び入りぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八蔵得たりと畳みかけて、「さあ、出して渡してくれ、否と言うが最後だ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下枝が死を宣告され、仇敵の手には死なじとて、歎き悶ゆる風情を見て、咄嗟に一の奇計を得たり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "得右衛門は得三の名を呼びて室外におびき出し、泰助は難無く室内に入りて潜むを得たり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には、晴れた空の一部分に黒い濃い雲形定規のやうな雲があつて、一寸欠け初めたばかりの月が、みえたり隠くれたり、可なり威勢よく渡れ亙つてゆくのが見られた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏の夜空の中に、電気広告の様々なのが、消えたり点つたりする下を、足を投げ出すやうな心持に、歩いてゆくことは、まるで亡命者のやうな私の心を慰める。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家がえて淋しがりやであるので関係があるやうに見えたりするだけのものだ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「物質的」に「精神的」は圧へられてゐるので、精神はスキマからチヨツピリ呟くから神秘的に見えたりするけれど、もともと東洋で精神は未だ優遇されたことはない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
