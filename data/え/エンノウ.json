    },
    "definitions": [
      {
        "index": 1,
        "gloss": "deferred payment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい車の購入費用は、特別な事情があったため延納を申請した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "税金の延納が認められれば、今月の家計が少し楽になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害に遭った場合、公共料金の支払いが延納できる制度がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "村年寄甲　新田の新吉は見えんのう。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「争えんのう、父娘だ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わしの席へ来たことがあるか」「あるはずです」「覚えんのう。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
