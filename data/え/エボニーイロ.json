        "examples": {
          "standard": [
            {
              "text": "「彼女は、エボニー色のロングコートを颯爽と着こなし、街を歩いていた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「部屋の壁をエボニー色に塗り替えたら、ぐっと落ち着いた大人の空間になった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「『この車のボディカラー、エボニー色って深みがあってすごく渋いね！』」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「エボニー色は、単なる黒ではなく、わずかに青みがかったような、奥行きのある黒だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "倉地はいとしくってならぬようにエボニー色の雲のようにまっ黒にふっくりと乱れた葉子の髪の毛をやさしくなで回した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
