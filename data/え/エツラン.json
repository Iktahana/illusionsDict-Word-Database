        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "休日は、特に目的もなくネットを閲覧して過ごすことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新の情報を得るために、日々様々なニュースサイトを閲覧している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい趣味を探して、関連するウェブページを片っ端から閲覧してみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このサイト、面白い情報がたくさん載ってるよ！」と友人に勧めるほど、熱心に閲覧した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
