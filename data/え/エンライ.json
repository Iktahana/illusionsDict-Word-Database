[
  {
    "uuid": "6c5ce396-a54b-5c92-9ab7-2f06f127a3c9",
    "entry": "遠来",
    "reading": {
      "primary": "えんらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
