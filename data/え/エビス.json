      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "peoples formerly of northern Japan with distinct language and culture (i.e. the Ainu)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歴史の授業で、日本の北方に住んでいた夷の文化について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の古い伝承には、夷にまつわる話が多く残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつては異民族を指す言葉としても使われたが、現代ではその歴史的背景が重視される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "近辺の寺々いずこも参詣人多く花屋の店頭黄なる赤き菊｜蝦夷菊堆し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇都野さんの歌はどう見ても大宮人の歌ではない、何処かしら東夷とでも云いたいような処があると私は思う。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千年来伝わった日本人の魂でさえも、打砕いて夷狄の犬に喰わせようという人も少なくない世の中である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東夷南蛮の類であり、毛唐人の仲間である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の類　衣、依、愛、哀、埃、英、娃、翳、榎、荏（これは「榎」「蝦夷」「得」等の語に用いられる）乙の類　延、要、曳、叡、江、吉、枝、兄、柄（これは「枝」「兄」「江」「笛」「※」「吉野」「消」「絶」「越」等に用いられる）　こういう仮名は、甲の類も乙の類もすべて我々が「エ」と読んでいる仮名であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に挙げたように、甲の類は榎の木の「エ」、蝦夷の「エ」、物を得るの「エ」であり、乙の類は、枝の「エ」、中大兄の「エ」、笛の「エ」、吉野の「エ」、その他にも沢山ありますが、榎の木の「エ」は甲の類の「エ」で、甲の類の字を使って、乙の類の字を使ったものはない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "千箇の焼夷弾の中で路面や広場に落ちたり河に落ちたりして無効になるものが仮りに半分だとすると五百箇所に火災が起る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼夷弾投下のために怪我をする人は何万人に一人くらいなものであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の前には、けばけばしい雜色の衣をきた、夷狄どもが多勢ゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道のひぐまも虎と同様で、東北日本の陸地の生まれたとき津軽海峡はおそらく陸でつながっていたのではないかと思われるが、それがその後の地変のために切断してそれが潮流のために広く深く掘りえぐられた、それから後にどこかからひぐまが蝦夷地に入り込んで来たのではないかと想像される。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔沃度ノニホヒフルヒ来ス〕沃度ノニホヒフルヒ来ス、　　　青貝山ノフモト谷、荒レシ河原ニヒトモトノ、　　　辛夷ハナ咲キ立チニケリ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主事　佐伯正氏群れてかゞやく辛夷花樹、　　雪しろたゝくねこやなぎ、風は明るしこの郷の、　　　　士はそゞろに吝けき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気工夫（直き時計はさま頑く、　　　憎に鍛へし瞳は強し）さはあれ攀ぢる電塔の、　　　四方に辛夷の花深き。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の気持も坦夷で、決して親切でないものではなかった。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かゝる人なりければ其｜面貌も恐ろしげに荒びて夷などの如くなりけむ、孔子も貌を以て人を取りつ之を子羽に失しぬと云ひ玉へり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉蘭花　もくれんは辛夷の類なり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の攘夷論者は西洋人を獣類の一種と思っていた。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爾の時に疾翔大力、爾迦夷に告げて曰く、諦に聴け、諦に聴け、善く之を思念せよ、我今｜汝に、梟鵄諸の悪禽、離苦解脱の道を述べん、と。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち、両翼を開張し、虔しく頸を垂れて、座を離れ、低く飛揚して、疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願ふらく、疾翔大力、疾翔大力、たゞ我等が為に、これを説きたまへ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爾の時に疾翔大力、爾迦夷に告げて曰くと、まづ疾翔大力とは、いかなるお方ぢゃか、それを話さなければならんぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爾の時に、疾翔大力、爾迦夷に告げて曰く、諦に聴け、諦に聴け、善く之を思念せよ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷、則ち両翼を開張し、虔しく頸を垂れて座を離れ、低く飛揚して疾翔大力を讃嘆すること三匝にして、徐に座に復し、拝跪して唯願ふらく、疾翔大力、疾翔大力、たゞ我等が為にこれを説き給へ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で前の座では、捨身菩薩を疾翔大力と呼びあげるわけあひ又、その願成の因縁をお話いたしたぢゃが、次に爾迦夷に告げて曰くとある。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾迦夷といふはこのとき我等と同様｜梟ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも爾迦夷｜上人と申しあげて、毎月十三日がご命日ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれの家でも、梟の限りは、十三日には楢の木の葉を取て参て、爾迦夷上人さまにさしあげるといふことをやるぢゃ、これは爾迦夷さまが楢の木にお棲ひなされたからぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この爾迦夷さまは、早くから梟の身のあさましいことをご覚悟遊ばされ、出離の道を求められたぢゃげなが、たうとうその一心の甲斐あって、疾翔大力さまにめぐりあひ、つひにその尊い教を聴聞あって、天上へ行かしゃれた。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その爾迦夷さまへのご説法ぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾の時に疾翔大力、爾迦夷に告げて曰く、諦に聴け、諦に聴け。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言えば君の顔は僕が毎晩夢のなかで大声をあげて追払うえびす三郎に似ている。",
              "citation": {
                "source": "海　断片",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "provincial (i.e. a person who lives far from the city)",
        "register": "standard",
