        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「Ｌサイズだと少し肩幅が窮屈だったから、一段大きいＬＬサイズに交換してもらったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このパーカー、ゆったりしたシルエットで着たいから、あえてＬＬを選んでみたんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「すみません、このデザインのワイシャツでＬＬの在庫はありますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近太っちゃって、ついに部屋着がＬＬサイズになっちゃったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これ、どうしたの」「いま、生田のとこへいってきたんだ」　生田は若い英語の教師で、週二回のＬＬ教室の授業を担当している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は手品師は、船客の女の一人にひよっこを握らせて置いて、また「ＧＡＬＬＡ・ＧＡＬＬＡ・ＧＡＬＬＡ」をやる。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＱＱ神父及びＬＬ氏、ＬＬ氏は日本の大学では文学史や中世思想史を講ぜられたが、本国｜仏蘭西に於ては著名な羅典語学者で、私はこの御両名から、日本に於て本当に羅典語を解する人は最上清人だらうと承つたことがある。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は真赤なＰＵＬＬ・ＯＶＥＲでスキイに出かけた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ＨＡＬＬＯＯ――　――ＨＡＬＬＯＯ――　黄昏が帰滅へ誘ふ遥かな言葉。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがＶＩＬＬＯＮ第一号に掲載されたのだ。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ＶＩＬＬＯＮの、「華々しき瞬間」、の問題にかえろう。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼の意志かあわれみで同人雑誌のＶＩＬＬＯＮか、ＶＩＫＩＮＧに印刷されるでしょう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿も（芝居の）ＶＩＬＬＯＮかＶＩＫＩＮＧに、富士さんは、のっけてくれるだろう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿も（芝居の）、ＶＩＬＬＯＮかＶＩＫＩＮＧに、富士さんは、のっけてくれるだろう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月三十一日　午前二時頃（昭和二七年一二月三一日作、「ＶＩＫＩＮＧ47・ＶＩＬＬＯＮ４」共同刊行号、昭和二八年三月）",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＥＬＬ――ＭＥＬＬは古風な英国の球ころがし遊びの名である。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンのＰＥＬＬ・ＭＥＬＬは有名なクラブ通りである。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして番頭のジョージ・依田という二世の少年や、そのほか私が顔も見知らぬ印度人たちが主人公のカパディア氏の周りに、立ったり腰かけたりして店はいつものように混雑を極めていたが、「ＨＡＬＬＯ！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
