    "definitions": [
      {
        "index": 1,
        "gloss": "prey (i.e. of a predator)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "弱肉強食の世界では、小さな動物は常に肉食獣の餌食となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "獲物を狙う鷹は、地上のウサギを餌食と定めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "危険なジャングルでは、誰もが大型捕食動物の餌食になりうる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "凍るものから、餌食を見出して来やがれ」　ぺっぺっぺっと唾を三度、庭に吐き去りかけたが、ふとそこに落ちている小石の一つを拾って手早く懐に納め、「ざまを見よ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ弾丸の餌食になるか分らない危険な仕事は、すべて日本兵がやらせられている。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車の顛覆と同時に、弾丸の餌食になった兵士が運ばれて行ったのだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乃木大将は誰のために三万人もの兵士たちを弾丸の餌食として殺してしてしまったか？",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等をシベリアへよこした者は、彼等が、×××餌食になろうが、狼に食い×××ようが、屁とも思っていやしないのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼い猫の餌食として必ず幾尾かを残して帰るように、母から云い付けられていると彼は話した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この高い魚をみんな猫の餌食に……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹ならば珍らしくない、しかも二十匹が一度に喉を鳴らし、牙をむき出して、めいめいの餌食を忙がしそうに啖っているありさまは、決して愉快な感じを与えるものではなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ妄想という怪獣の餌食となりたくないためばかりに、私はここへ逃げ出して来て、少々身体には毒な夜露に打たれるのである。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずこれならば狼の餌食になってもそれは一思に死なれるからと、路はちょうどだらだら下なり、小僧さん、調子はずれに竹の杖を肩にかついで、すたこら遁げたわ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてわけもなく餌食を平らげて湯ともいわず、ふッふッと大儀そうに呼吸を向うへ吐くわさ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち二人はフカの餌食になる価打しか無い、狂妄だったのですから……。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那風の美人、美少女、美少年が、あらゆる残忍酷烈な刑に処せられて笞打たれ、絞め殺され、焙られ、焼かれ、煮られ、引き裂かれ、又は猛獣の餌食にあたえられて行く凄愴、陰惨を極めた場面の極彩色密画であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃は鯉か鯰の餌食になりよろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "世には人生を、己が野心の餌食と心得て、くたぶれずに五十年間生きる者もある。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず口だけは体の可い事を言うて、その実はお互に餌食を待つのだ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌食がその柔かな白々とした手足を解いて、木の根の塗膳、錦手の木の葉の小皿盛となるまでは、精々、咲いた花の首尾を守護して、夢中に躍跳ねるまで、楽ませておかねばならん。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を飛ぶ仲間では、鷲、鷹、みさごぐらいなものか、餌食を掴んで容色の可いのは。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまでにして、手に入れる餌食だ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌食の無慙さ、いや、またその骨の肉汁の旨さはよ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は先刻から思う事だ、待設けの珍味も可いが、ここに目の前に転がった餌食はどうだ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう言や一体蚊も居らんが、大方その怪物が餌食にするだろう。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の妹は、兄の学資を貢ぐために、好色漢の餌食になろうとしている。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだまだこれからドレ位の生霊を、鉄の餌食に投げ出すか知れないと思いつつ……馬鹿馬鹿しいくらい荘厳な全工場の、叫喚、大叫喚を耳に慣れさせつつ……残虐を極めた空想を微笑させつつ運んで行く、私の得意の最高潮……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにも餌食がなく、食物が全く盡きてしまつた時、彼は自分の足をもいで食つた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの肉体とても婦人の病気以外には殆どあらゆる病の餌食として与へてしまつたと云つても宜い。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりとては胴慾な男め、生餌食う鷹さえ暖め鳥は許す者を。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づこれならば狼の餌食になつても其は一｜思に死なれるからと、路は丁度だら／″＼下なり、小僧さん、調子はづれに竹の杖を肩にかついで、すたこら遁げたわ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてわけもなく餌食を平らげて、湯ともいはず、ふツ／＼と太儀さうに呼吸を向ふへ吐くわさ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう四月も過ぎますねえじきに――」「そうですねえ、　桜も散りました、　タンポポだってフワフワ毛になるに間もありますまい。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
