        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "フレンチレストランで、まずはエスカルゴを頼んでみたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ガーリックバターの香りがたまらないエスカルゴに舌鼓を打った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わー、エスカルゴだ！おしゃれだね！」と友人が喜んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自宅でエスカルゴを作るために、新鮮なカタツムリを取り寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "巴里に行った人で一度はレストラン・エスカルゴの扉を排しないものはないであろう。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスカルゴとは蝸牛のことで、レストラン・エスカルゴは蝸牛料理で知られている店である。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝸牛はどれでもこれでも食べられるのではなくて、レストラン・エスカルゴ等で食べさせるのはブルゴーニュという地方で産するものである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ映画には数理的科学とビールのにおいがあり、フランス映画にはエスカルゴーやグルヌイーユの味が伴なう。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスカルゴ野の栄螺だ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十七日（火）　午後一時　放送委員会、エスカルゴ　仕事をはじめた、「道標」下巻　三。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことのあった翌日、一同連れ立って有名なエスカルゴー料理という蝸牛の料理を食べに行ったとき、その店で出したパンは実に色も白く美味なものであったので、今まで食べていたパンが有名なフランスパンなるものでないことが分った。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
