[
  {
    "uuid": "eefb0465-9c1c-5248-849e-f07e8e84bb44",
    "entry": "襟元",
    "reading": {
      "primary": "えりもと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
