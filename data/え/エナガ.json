[
  {
    "uuid": "3228a706-ee7f-5d19-bbe7-afef78c4f735",
    "entry": "柄長",
    "reading": {
      "primary": "えなが",
      "alternatives": [
        "エナガ"
      ],
      "is_heteronym": false
    },
    "grammar": {
