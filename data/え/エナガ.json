    },
    "definitions": [
      {
        "index": 1,
        "gloss": "long-tailed tit (Aegithalos caudatus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の木に、小さな体で長い尻尾を持つ柄長（えなが）がちょこんと止まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "バードウォッチング中に、林の奥で柄長が可愛らしく鳴いているのを聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「見て！あれは柄長だよ。あの特徴的な尾羽が美しいんだ」と、鳥に詳しい友人が教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "麓の里道、其石段まで、爪さきあがりの二町ばかりがほど、背戸の花、屋根の草相交り、茄子の夕日、胡瓜の風、清き流颯と走りて、処々水の隅に、柄長き柄杓を添へたるも、なか／＼の風情に候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとへ、竹槍の青光りに艶のあるのを、柄長に取って、明が続く。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高箒に手拭を被せたのを、柄長に構えて、逆上せた顔色。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び裾へ飜えるのは、柄長き薙刀の刃尖である。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "螽の飛ぶよ、と光を放ちて、小路の月に閃めきたる槍の穂先霜を浴びて、柄長く一文字に横えつつ、「来い！",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し朝倉勢に、裏切り組というのがあり、百人位の壮士を選び、各人四尺五寸、柄長く造らせたる野太刀を持ち、戦いの最中、森陰から現われて、不意に、家康の旗本へ切りかかった。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄長く椎の葉ばかりなる、小き鎌を腰にしつ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金時足柄長尾などの低い山垣が田圃越しの右手に見え、左には野原を距てて森の深い愛鷹山の墨色が仰がれた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　云い云い頭上の柄長の御幣を、姥は揉み立て揉み立てした。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "確か柄長であったと思う、何でも鳥の羽で入口に蓋のある上手な巣を作るものがある。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "是ヲ我ガ四国衆ノ、鎧毛モ切レ腐リテ、麻糸ヲ以テツヅリシヲ着シ、腰小旗ヲ横ニ、柄長柄短カノ不揃ヒナル駆ケ草鞋ノ軍勢ト見較ベンニハ、可笑キバカリ、事違ヒテ、上方勢トハ似ルベクモナシ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "新婚まもなく若い稚気のぬけなかった夫人は、恐らく恐怖にふるえながらも、人生の最も楽しく忘れ得ない夢を経験したのだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため夫人は一面において旧日本的な婦道と礼節とによって、恭しく彼に仕えながらも、半面においては彼を子供扱いにせねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、旅行者にとってはのんきそうに見えながらも、帝都の人たちはすべて懸命の努力で生きているのだという事を、この北京の客に説明してやろうかしらと、ふと思った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖簾をかけた質屋の店も、既に戸を閉めてしまったので、万象｜寂として声なく、冬の寂寞とした闇の中で、孤独の寒さにふるえながら、小さな家々が眠っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋ふかき隣は何をする人ぞ秋さびし手毎にむけや瓜茄子　芭蕉の心が傷んだものは、大宇宙の中に生存して孤独に弱々しく震えながら、葦のように生活している人間の果敢なさと悲しさだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋草には束髪の美人を聯想すなど考えながらこゝを出でたり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不折の油画にありそうな女だなど考えながら博物館の横手｜大猷院尊前と刻した石燈籠の並んだ処を通って行くと下り坂になった。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷が狭くなって、崖側を行くと、緩いながらも雪の傾斜で辷るから、ミヤマナナカマドの枝を捉えながら上る、前にも増した雪の断裂で、草鞋に踏み蹂った雪片は、山桜の葩弁のように、白く光ってあたりに飛び散る。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山の上で、朝から夕立に遇っては堪まらないと、多年山登りの経験から気がついて、呆れ顔の導者を促して路を急ぐ、岩角を上ったり、下ったり、偃松や黄花石楠花の間を転がるようにして走ったが、その間に幻影は消え消えながら、三度出た、しかし心配ほどもなく、霧は奇麗に拭われて、雨にはならなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぎたなく眠れる善作を揺り起して、炊事を命じ、自分一人寒気に慄えながら小舎の前の石峰に立た。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして弁当箱を首に巻きつけて、一杯飲んで食うことを専門に考えながら、彼の長屋へ帰って行った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、頭を抱えながら呶鳴った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は頭を抱えながら、滅茶苦茶に沢山な考えを、掻き廻していた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような他愛もない事を考えながらともかくも三年にわたる厄年を過して来た。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は、慄えながら行き合せた野の人に訊ねた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、不思議に、女は顔蒼ざめさせ体は慄えながら一種の酔心地とならざるを得なかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おら、嫌だと言ったんだけれど、みんなが無理に着せるんだよ」　四郎はお蘭の怒りに怯えながら言った。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭青年は戦慄を覚えながら押し止めました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
