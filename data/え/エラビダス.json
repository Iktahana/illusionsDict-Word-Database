[
  {
    "uuid": "5fac8736-d582-53b6-99a9-23ed98007b9d",
    "entry": "選び出す",
    "reading": {
      "primary": "えらびだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
