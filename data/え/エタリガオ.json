        "examples": {
          "standard": [
            {
              "text": "プロジェクト成功の報告で、彼は得たり顔で壇上に上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "難問を解き明かし、得意げな得たり顔で皆に解説した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "競馬で大穴を当てた友人が、得たり顔で奢ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "やがて五日｜頃の月は葉桜の繁みから薄く光って見える、その下を蝙蝠が得たり顔にひらひらとかなたこなたへ飛んでいる。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はほく／＼と得たり顔して急ぎ佐伯に告げた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まさにそうなのです」とクリヴォフ夫人は得たり顔に頷いて、他の二人に椅子を薦めてから、「私はなんとかして、心理的にだけでも犯人の決行力を鈍らしたいと思うのですわ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジナイーダが恥入ったように嘆息するのを、熊城は得たり顔に頷いた。",
              "citation": {
                "source": "聖アレキセイ寺院の惨劇",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕には、貴方が得たり顔をした、理由が判りません。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "試しに秋もたけなわの松茸の真盛りのとき、松茸の香味の絶頂に達したころ、三流どころの料理屋ならいざ知らず、もし一流二流どころの料理屋において、この季節ものをもって、得たり顔に使うとしようか、決して思うように顧客の歓心を買い得るような効果は上がらないのである。",
              "citation": {
                "source": "日本料理の要点",
                "author": "――新雇いの料理人を前にして――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
