        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ＡＰ通信が報じたニュースは、すぐに世界中に広まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は長年、ＡＰの特派員として海外を飛び回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ＡＰの記事を引用して、今日の新聞の一面を飾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "われわれにとつてはＮＡＰの夢までが苦悶の息づかひである以外の何物でもなく、才能の過信は敵であるのみである。",
              "citation": {
                "source": "浪曼的時評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二七年の末、労農芸術連盟から「前衛」が分裂し、のち「プロレタリア芸術」と合体して全日本無産者芸術連盟（ＮＡＰＦ）を結成した。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろんどん――ジブロウタ――馬耳塞――ＮＡＰＯＬＩ――ぽうと・さいど――スエズ――古倫母――シンガポウア――香港――上海――コウブ――よっくへえま！",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "小黒帽をかぶってＣＡＰＡを翻してるＤＯＮホルヘ――私――の上に太陽が焼け、下には赤い敷石が焼けて、私の感覚も、「すぺいん」を吸収して今にも引火しそうだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇子と 〔Manto'n de Manila〕 とＣＡＰＡとぼいなとカアネイションと牛と。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "カアネエション・指輪・ＣＡＰＡ・帽子・すてっきなんかが雨のようにリングへ飛ぶ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一九四八年度のソヴェト国家予算が発表されたときＡＰ通信は、「ソヴェトの新予算は、世界の平和にとって、これまでソヴェトの首脳部の声明の全部を合わせたものよりも、さらにいっそう重要な意義がある」と説明した。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨーク・タイムズ東京支局長リンゼー・パロット氏、ＡＰ東京支局長ラッセル・ブラインズ氏に対して日本人として鈴木文史朗氏が出席している、肩書はリーダーズ・ダイジェスト日本版編集長とある。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "既成ソフトのＡＰＬＩＫＡ（APplication LIbrary by Kit Assembling）シリーズには、販売管理、顧客管理、財務管理、給与計算などのさまざまなプログラムが用意された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "システム１００に用意されたＡＰＬＩＫＡのプログラムでも、頑固な中小企業の親父たちを納得させることは難しかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内版の発表に合わせて、アドバンスト・パーソナル・コンピュータ（ＡＰＣ）と名付けてアナウンスするこのマシンの売り物として、端末グループはＩＢＭの大型用端末３２７８の機能を備えている点と、ＣＰ／Ｍ―86とＭＳ―ＤＯＳの採用を強調しようとしていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでシステム１００用にコンパクトＡＰＬＩＫＡのシリーズ名で書きためられた業種業務別のさまざまなアプリケーションが利用できるほか、ＢＰＣ用に開発を進めてきたＰＲＩＳＭと名付けたグラフ作成用プログラムも、ソフトウエアのラインナップに加えられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを宿題や、数学的な謎解きやＮＵＭＢＥＲ、ＳＴＡＲＳ、ＴＲＡＰ、ＨＵＲＫＬＥ、ＳＮＡＲＫ、ＢＡＧＥＬＳといったゲームに使いたいとしましょう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は６８００ベーシックを書きましたし、現在８０８０ＡＰＬや６８００ＡＰＬを書いています。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の親方と一所に飲むけにナ」「ＣＡＰＴＡＩＮ」と真鍮札を打った扉を開くと強烈な酸類、アルカリ類、オゾン、アルコオルの異臭がムラムラと顔を撲つ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "綴りはＳＵＳＳＡＮＲＡＰです。",
              "citation": {
                "source": "不思議な島",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "漫画の題はＴＲＡＰＰＥＤ、大学スケッチ第八。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般大衆がミスカトニック大学調査隊を知っているのは、『アーカム・アドヴァタイザー』誌やＡＰ通信向けに頻繁に行った無線による報告を通じてであり、また後になってピーボディと私が書いた論文を通じてである。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "全日本無産者芸術連盟は略称をナップＮＡＰＦと云っていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時ドイツ・グラモフォン系のレコードは、シャリアピンの綴をＣＨＡでなくてＳＣＨＡＬＩＡＰＩＮにしていた関係もあったであろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
