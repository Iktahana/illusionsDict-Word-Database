        "examples": {
          "standard": [
            {
              "text": "エジプト文明の遺産は、現代の私たちを今も魅了し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供の頃、エジプト文明の特集番組を食い入るように見ていた記憶がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "世界四大文明の中でも、特にエジプト文明はミステリアスな魅力に溢れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "西暦紀元前三千年の昔にさかのぼつて、彼のエジプト文明の隆盛が歌の如く弥が上にも栄えわたつた時代、クフといふ王様の御代にかへつて……と私は云ひました。",
              "citation": {
                "source": "青白き公園",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自然についての観点が誤っていたので、病気の知識は粗末で原始的であることを、エジプト文明は示している。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来の発見によってこの感じは変化するかも知れないが、考えられたエジプト文明の独占性はその発展の全域において支持できないであろうことはますます明らかになる（他の国から言語、宗教、芸術をしばしば借りていることに示される。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
