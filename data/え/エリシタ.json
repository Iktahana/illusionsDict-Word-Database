    "definitions": [
      {
        "index": 1,
        "gloss": "usu. the drop between collar and bottom hem on kimono, yukata, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
