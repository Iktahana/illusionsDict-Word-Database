    "definitions": [
      {
        "index": 1,
        "gloss": "festival vendor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "縁日商人の威勢のいい声が、会場に響き渡っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの縁日商人のたこ焼きは、いつも行列ができている人気店だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いらっしゃい！冷たい飲み物はいかが！」縁日商人が声を張り上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "西瓜の切売をした事もある、とゞの結局が縁日商人となつて九星独判断、英語独稽古から初めて此頃では瞞着の化粧品と小間物を売つてマゴ／＼しておるが君、金を儲けるのは商人だよ。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に縁日商人位｜泡沫銭の儲かる者は無い。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな縁日商人は上等のところを一つ売れば、二三日乃至一週間は楽に喰えることが、品物のタネを洗って見ればすぐにわかる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草一帯の店の「正札無言主義」は、明らかにこの狙っている客筋が田舎者でない事を証明しているが、更に一層ハッキリと説明するものは前に述べた縁日商人の口上である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの人を一切合財相手にして、ごみだらけのアイスクリームや、冷し飴や、西瓜などを売っている縁日商人は、売れ残りの品をはやくさばいてしまおうと思って、いまだに声をからして客を呼んでいます。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁日商人も店を列べている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "持久戦争に於ては特に目前の戦況に眩惑し、縁日商人の如く戦争目的即ち講和条件を変更する事は厳に慎まねばならぬ。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「清水に聞いたのだらう――けれども、ね、如何に縁日商人だからツて」と、義雄は額の廣い、頬のこけた顏に、鋭い眼を眼鏡の裏から光らせながら、「さう馬鹿にするものぢやアないさ――お互ひに好き合つてゐるのだから。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄も知つてる通り、かの女は、亭主が十一時から十二時までに歸りさへすれば、縁日商人の職業上當り前なので、喜んで出迎へるのである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまひには一分でも二分でもいゝと、縁日商人のやうな事を云ひ出した。",
              "citation": {
                "source": "貝殼追放",
                "author": "新聞記者を憎むの記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「往来にはずっと両側に、縁日商人が並んでいる。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹割りも縁日商人が客寄せにやってることで、武道の奥儀と関係のないものだ。",
              "citation": {
                "source": "馬庭念流のこと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして又私の考へるすべてのことが、いはば一生の総じまいといふ慌ただしさで、露店の品物を片付ける縁日商人と同じやうに、あと片付けをするほかには何の余念も浮かないやうな状態なのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六、ガス燈　近ごろでは特に停電用といふのでアセチレンガスのあかり（名づけてカーバイト・ランプ）を町で売つてゐるが、これはその独得な臭気もろとも昔は往来で縁日商人の使ふものときまつてゐた。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地から蝋燭代を貰って景気を助けに出る棟梁株の縁日商人に五種あって、これを小物、三寸、転び、ぼく、引張とする。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな商店や通行人や電燈や縁日商人などのなかを、一歩ずつ黒ずんだ姿を運んでくるのが、その町の家並がだんだん背後に遠く挟ってゆくのと一しょに写し出していた。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "向う岸の人は渡し場を渡ると、そこから、かけはじめられた燈籠が、おのずから地蔵堂の前へ人を導き、沿道には早くも縁日商人連が近在から出て来て、店を張ろうという景気です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "客の多くはごく貧しい人たちで、たいていが飴売りとか、縁日商人とか、旅を渡る安旅芸人などだから、少し長く降りこめられでもすると、食う物にさえ事欠き、つい他人の物に手を出す、という者も稀ではなかった。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
