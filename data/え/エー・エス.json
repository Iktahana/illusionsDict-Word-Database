    "definitions": [
      {
        "index": 1,
        "gloss": "autonomous system",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大規模なネットワークは複数のＡＳで構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自社のＡＳは、国内外の主要なプロバイダと接続している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "インターネットの基盤を支えるのが、これらのＡＳ間のルーティング技術だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "浪という芸者が、いましたけれど、いつも男の言うこと聞きすぎて、田舎まわりの旅役者にだまされ、この土地に居られなくなり、いまはＡＳという温泉場で、温泉芸者している筈です、という答えであった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず、必ず、ＡＳという、その温泉場へ行って、浪を、ほめてあげようと思った。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとしの暑中休暇に、故郷へ帰る途中、汽車がそのＡＳという温泉場へも停車したので、私は、とっさの中に覚悟をきめ、飛鳥の如く身を躍らせて下車してしまった。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "代表者となったボブ・スタインは、妻だったアリーン・スタインとボイジャー・プレスを作った人物で、ここから引き継いだ社名は、ＮＡＳＡの惑星探査機から取ったそうです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユタ大学の大学院ではアラン・ケイの同期で、卒業後はＮＡＳＡのために飛行士訓練用のフライトシミュレーターの開発に携わっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "表だって見える最初ののろしは、日本音楽著作権協会（ＪＡＳＲＡＣ）が上げた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、保護期間の死後七〇年への延長を求める、ＪＡＳＲＡＣからの要望が盛り込まれていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "中では、そもそもの火付け役を演じたＪＡＳＲＡＣが、同小委員会の事務局の求めに応じて二〇〇四年八月三一日に提出した、三つの主張からなる要望書が、比較的良くまとまっている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際に「そらもよう」に書いた内容と重複するが、ここで再び、ＪＡＳＲＡＣの論拠に反論しておきたい。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどあの懐かしきＰＡＳＯＰＩＡがマシンの温度テスト用恒温槽で今もけなげに働いているのを発見したり、基本ソフトの開発部門にＮｅＸＴのキューブが転がっているのを見つけたりと青梅工場見学ツアーを存分に満喫しているうちに、またまた、次なる疑問がむくむくと湧いてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにそれらいくつかの統合型ソフトの選択肢の中で、Ｑｕｉｃｋ　ＢＡＳＩＣやＱｕｉｃｋ　Ｃと同じ、マイクロソフト型のキャラクター・ウインドウを用いているワークスの使用感は、ＷｉｎｄｏｗｓやＯＳ／２の操作環境の流れを汲んでいる点で点数を稼ぐだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパック、ＡＳＴを始めとするアメリカ勢も、これで日本市場になだれこんでくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間と立ち上げた『Ｉ／Ｏ』誌から別れた西、郡司、塚本は一九七七年六月、『ＡＳＣＩＩ』を創刊する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが先頭を切ってＡＭＤチップの採用に踏み切ったＡＳＴリサーチに続いて、一九九一年の十月二十一日から開催されるコムデックスでは、新たな３８６互換チップ採用の声が上がるだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　と、昨夜の食卓でナイフとフォウクの間からこういうＢＲＯＡＤＣＡＳＴをした人があった。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "この恐るべきポウト・サイドの後宮をＰＡＳＨＡのごとく一順して、私たちは港へ帰った。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "May in England ――多くの詩人と、より多くの詩の追随者たちによって、薔薇・ひばり・日光・微風・花の香・田舎みち・濃い木影なぞと古来讃美されてきた五月のろんどんだから、さぞ色彩的な生活情緒が自然に人事に高唱されていることだろうと思ったら、ＡＬＡＳ！",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "オテル・ドュ・パリとＣＡＳＩＮＯのあいだに、食卓布のように明るい灯火の小川と人々の笑い声があった。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は巴里モンマルトルのキャバレＬＡ・ＦＡＮＴＡＳＩＯを思い出した。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "この超小型コンピューターキットは、テレックス通信用の端末として開発された、テレタイプ社のテレタイプ、ＡＳＲ―33をつないではじめて動かすことができたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボード、プリンター、紙テープパンチ、紙テープリーダーを一体にまとめたＡＳＲ―33は、本来の用途以外にも、比較的小型のコンピューターシステムの入出力機器として使われていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キット程度の代物に、新品で約五五万円、中古でも三〇万円はするＡＳＲ―33をつなぐというのも、今からすれば、ずいぶんとバランスの悪い話に聞こえる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "音の大きさで悪名高かったＡＳＲ―33に組み立て終わったシステムを接続し、騒音をまき散らしながらとにかく動かしてみることに、この時期、後藤は猛烈に熱中していたのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日本に帰るや新しい雑誌作りの準備を始め、その年の六月に『ＡＳＣＩＩ』を創刊している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月付けの『ＡＳＣＩＩ』創刊号巻頭言、「編集室から」。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "長くはなるが、時代の気分を象徴的に表わしたこの一文をそのまま、ただし『ＡＳＣＩＩ』名物の誤植だけは訂正して引用したい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず近いうちに、何が何でも、ＢＡＳＩＣを使えるようにしたい」と噛み付いている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "創刊二号目の『ＡＳＣＩＩ』一九七七（昭和五十二）年八月号には、わずか二Ｋバイト（それでもＴＫ―80に標準装備されたものの四倍ではあるが）のメモリー空間に収まってしまう超小型版翻訳プログラム、タイニーベーシックの記事が紹介されている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "西和彦と名乗り、マイコン雑誌の『ＡＳＣＩＩ』をやっている者だと付け加えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ＡＳＣＩＩ』なら、渡辺もよく知っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
