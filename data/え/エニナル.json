        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古いレンガ造りの街並みは、雨に濡れると一層しっとりとして絵になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「このアングルから撮ると、廃墟でも不思議と絵になるから面白い」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雪化粧をした金閣寺は、どこを切り取っても絵になる美しさがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
