[
  {
    "uuid": "c6b2c55f-5f6a-588e-9bf7-6549d3e91114",
    "entry": "絵になる",
    "reading": {
      "primary": "えになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to make a lovely picture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "満開の桜の下で和服姿の女性が佇んでいる様子は、どこから見ても絵になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、このカフェのテラス席、海が見えて本当に絵になるね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼はただコーヒーを飲んでいるだけなのに、モデルのように絵になる男だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "実際洗いざらしの鉄道工夫の青服などは、適当な背景の前には絵になるものの一つである。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』これはすばらしい絵になるでしょう！",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのありさまは絵になるものでした。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉の濶く切れてゐる形も絵になるやうな気がした。",
              "citation": {
                "source": "中秋の頃",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方ともに絵になる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから、室内で撮った絵になる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲がフーの〈ラン、ラン、ラン〉にかわり、快晴の運動会を校舎二階から撮った絵になる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと真実の事をいふと、文展向きの絵になる景色を捜しに来たのである。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "凌雲閣はとても絵になるべきものとは思はれんのであるが、この団扇の絵は不思議に妙な処をつかまへて居る。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが絵になるとかならぬとか、そうした考えも何もなかった。",
              "citation": {
                "source": "壁の眼の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに第二番目の絵になると、皮膚の色がやや赤味がかった紫色に変じて、全体にいくらか腫れぼったく見える上に、眼のふちのまわりに暗い色が泛み漂い、唇も稍黒ずんで、全体の感じがどことなく重々しく無気味にかわっている。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども『三国志』や『水滸伝』の人物の二人立三人立などの細かい絵になると、高く揚った場合、折角の絵も分らないから、それよりも月浪とか童子格子とか、字なら龍とか嵐などがいいようである。",
              "citation": {
                "source": "凧の話",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚でも多くの写生がしてみたい、八号を幾枚、一〇号を何枚、ついでに大作も一枚、あの風景は絵になるかどうか、雨は降りはしないだろうか、女中の祝儀はいかにしたものか、といった風のことを考えることは随分やり切れないことなのだ。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "不整頓な街景が整頓した街よりも絵になることがある。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "静物画はいながらにして絵になる世界を製造し得る便利至極なものであるがために、必然な心の動きからぜひ描きたいと思う場合を除いて、ややもすると不精者の怠け細工に使用されがちである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は小説によって私自身の心に起った想像の中から絵になる要素をなるべく引出して正直に絵の形に直して皆さんへ伝える事に努力したいと思う。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし完全にどの日本の一角を切り取っても必ず絵になるという画家があったら、それは充分なる漫画家であらねばならぬ。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十三、四日頃　マルセイユは思ったよりも絵になる、実にいい町だ。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "素裸で、お蕎麦一杯を恭しく捧げて、まじめくさって突立った形は絵になるじゃないか、白蔵主のお使といったような形だね。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二の橋の日向坂はその麓を流れる新堀川の濁水とそれに架った小橋と、斜に坂を蔽う一株の榎との配合が自ら絵になるように甚だ面白く出来ている。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "フデ　　だつて、女も絵になるのは、やつとその年頃だもの。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士川通船の出るあたりに往って見たが、絵になるような場所はない。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓一つ一つが立派な絵になる。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは直ちにその装をとつて絵になる、といふ意味で、美術の「美」にかけて、あの平凡なものは矢張りそれが一番美しいといふ。",
              "citation": {
                "source": "浴衣",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは絵になる」と思ったものは、描いてみると、果して面白い。",
              "citation": {
                "source": "八幡馬と墨の研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には、色々な鳥の生態写真と、丁度それに相応した姿の絵とが沢山あるが、開いて行くうちに、はっと「これは絵になる」という気がするのは、殆んど全部生態写真の方である。",
              "citation": {
                "source": "南画を描く話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Alice in Wonderland のジョン・テニエルの挿絵になると、ここからさらにかけ離れていきます。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るかぎり、生きて動くものの姿はなにひとつなく、無限の寂寥を宿した死後の世界を想像させるだけで、絵になるような風景ではなかった。",
              "citation": {
                "source": "白雪姫",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その男になにか見覚えになる特徴はなかったか」と裁判長が夕刊売りに尋ねる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "協会の諸兄によろしく（八月十五日）　それから書き忘れましたが何か本を一冊（何か僕に「やッたらどうや」とお考えになるものがありましたら結構ですが……）　これだけ書くのに便所へ油汗かきに行く事二回、これから第三回目に参ります。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
