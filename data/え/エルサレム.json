    "definitions": [
      {
        "index": 1,
        "gloss": "Jerusalem",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "エルサレムは、多くの宗教にとって聖地とされる、歴史深い都市だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史の教科書で、エルサレムの古代遺跡について学んだのを覚えているよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「エルサレムへ行こう！」と、友人が旅行の計画を立てているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ニュースで、エルサレムの情勢が緊迫していると報じられていた。心配だな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "唯耶路撒冷を信じてゐる。",
              "citation": {
                "source": "浮浪学生の話",
                "author": "RECIT DU GOLIARD",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも耶路撒冷は遠い処だ、さうして主の君は、われわれのごとく傍にお出遊ばすのだ。",
              "citation": {
                "source": "浮浪学生の話",
                "author": "RECIT DU GOLIARD",
                "note": "青空文庫"
              }
            },
            {
              "text": "衆は耶路撒冷まで往かれまい。",
              "citation": {
                "source": "浮浪学生の話",
                "author": "RECIT DU GOLIARD",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶路撒冷が衆のとこへ来るだらう。",
              "citation": {
                "source": "浮浪学生の話",
                "author": "RECIT DU GOLIARD",
                "note": "青空文庫"
              }
            },
            {
              "text": "――耶路撒冷へ行くのです、聖地を恢復に行くのです。",
              "citation": {
                "source": "癩病やみの話",
                "author": "RECIT DU LEPREUX",
                "note": "青空文庫"
              }
            },
            {
              "text": "――耶路撒冷つて何処だい。",
              "citation": {
                "source": "癩病やみの話",
                "author": "RECIT DU LEPREUX",
                "note": "青空文庫"
              }
            },
            {
              "text": "――耶路撒冷つて、一体、何だい。",
              "citation": {
                "source": "癩病やみの話",
                "author": "RECIT DU LEPREUX",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば自分はそのエルサレムへ急ぐ巡礼だった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああエルサレム、エルサレム、予言者たちを殺し、遣されたる人々を石にて撃つ者よ、牝鶏のその雛を翼の下に集むるごとく、我なんじの子どもを集めんと為しこと幾度ぞや」という所まで読んで、思わず声を挙げて泣いたあの夜を、忘れたか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒った時には、縄切を振りまわしてエルサレムの宮の商人たちを打擲したほどの人である。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる日、私たちは愈愈あこがれのエルサレムに向い、出発いたしました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちに待った過越の祭、エルサレム宮に乗り込む、これが、あのダビデの御子の姿であったのか。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああエルサレム、エルサレム、予言者たちを殺し、遣されたる人々を石にて撃つ者よ、牝鶏のその雛を翼の下に集むるごとく、我なんじの子らを集めんと為しこと幾度ぞや、然れど、汝らは好まざりき」馬鹿なことです。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、なんだかフイルムで見たエルサレムへゆく巡礼道の情景と、そっくりではないか。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖経はエルサレムの神殿を以て神の座すところとせり、其神殿に聖所あり、至聖所あり、至聖所には祭司の長の外之に入ることを得るもの甚だ稀なりと伝ふ。",
              "citation": {
                "source": "各人心宮内の秘宮",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもその頃は、芭蕉の流れを汲むものが、奥の細道を辿るのは、エルサレムの宮殿、近代の学者たちの洋行で、奥州めぐりを済まさないと、一人前の宗匠とは言われない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルサレムと世界の最後。",
              "citation": {
                "source": "聖書の読方",
                "author": "来世を背景として読むべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔この尊者の遺体を、大理石作りの船でエルサレムよりスペインへ渡す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "千二百十二年の三月十八日、救世主のエルサレム入城を記念する棕櫚の安息日の朝の事。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてポルタ・カプチイニの方にかすかな東明の光が漏れたと思うと、救世主のエルサレム入城を記念する寺の鐘が一時に鳴り出した。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がパレスチナやエルサレムに行くことが出来たのは、一に上帝の御恵みに他なりませんて。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「では、何ですか、その人は、」と、エルサレムのことを、よく従卒から聞かされてゐたイワン・フョードロ※ッチが言つた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その、エルサレムへも行つたとおつしやるので？",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "シリヤなるエルサレムの地はイエス・キリスト終焉の地として名高く、聖地としてキリスト教徒は一生に一度は巡礼となってこの地へ参拝することを念願とした。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの時フランスの巡礼僧にペートルという者があって、親しく聖地エルサレムに至り異教徒の横暴を見、聖地荒廃の態を探ったと称し、且、エルサレムの大長老より托されたという書簡をかざし、イタリヤ、フランスの各地を巡り、「すみやかに聖地に行き、異教徒を討払い、キリストの墳墓を清むべし」と絶叫した。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう狂信家が出て聖地清掃を叫ぶというのは、天に口無し人を以って云わしむで、キリスト教徒全体がエルサレム恢復を熱望している証拠だ。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予言の不思議「流竄中のカイゼル」の著者ベンチンク夫人が、一九一四年二月エルサレムへ旅行して、船がポートセードに着くと突然甲板へ印度人の予言者が乗り込んでつかつかと夫人の前へ寄って来て、「未来を予言しますから二ポンド下さい」　と言った。",
              "citation": {
                "source": "怪談綺談",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし基督がエルサレムの何とかいふ郊外を通りかかつた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳富蘆花がエルサレム巡礼の途に上つた時、文淵堂の主人は例の通りに幾通か電報を打つたが、相手が相手だけに一向手応へがないので、態々見立てるのだといつて、神戸から門司まで蘆花君と一緒に薄汚い汽船の三等室に滑り込んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『新ジエルサレム、生命の教義』を見て分る，聖書の『エジプトは人にして神にあらず、その馬は肉にして靈にあらず』（以賽亞書三十一ノ三）とあるを解釋して、『エジプト』は人間の智慧から出た科學、『馬』はその肉的理解力の表象として、神がこの世に現はした物。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
