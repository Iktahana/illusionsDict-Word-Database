[
  {
    "uuid": "e18fca00-ac2d-579c-b2ee-dee27321e2a8",
    "entry": "遠来の客",
    "reading": {
      "primary": "えんらいのきゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
