        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "最近のAIは、人間の言葉を理解し、自然な会話ができるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "工場に導入されたAIロボットが、製品の検査を高速で行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "AIが生成したイラストは、もはや人間が描いたものと区別がつかないほどだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまりＣＭＬＱＴＰＡＩＮＳの十種である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｑ１Ｎ　　　＿＿＿＿＿＿１ＭＬ）ＱＴＰＡＩ　　　　ＱＩＳ　　　　―――――　　　　　ＱＰＡ　　　　　１ＭＬ　　　　　――――　　　　　１１１Ｉ　　　　　１ＳＮＳ　　　　　――――　　　　　　　ＭＩ　さあ、こんどはどこに第二の鍵を發見すべきであらうか。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｑ１Ｎ　　　＿＿＿＿＿＿１ＭＬ）ＱＴＰＡＩ　　　　ＱＩ０　　　　―――――　　　　　ＱＰＡ　　　　　１ＭＬ　　　　　――――　　　　　１１１Ｉ　　　　　１０Ｎ０　　　　　――――　　　　　　　ＭＩ　いよいよ第三の鍵の發見に掛る。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "２１Ｎ　　　＿＿＿＿＿＿１Ｍ５）２ＴＰＡＩ　　　　２Ｉ０　　　　―――――　　　　　２ＰＡ　　　　　１Ｍ５　　　　　――――　　　　　１１１Ｉ　　　　　１０Ｎ０　　　　　――――　　　　　　　ＭＩ　第四の鍵は、比較的樂であつたから、あとはもういいだらうと安心すると、たいへんな間違ひが起る。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｑ１Ｎ　　　＿＿＿＿＿＿１ＭＬ）ＱＴＰＡＩ　　　　ＱＩＳ　　　　―――――　　　　　ＱＰＡ　　　　　１ＭＬ　　　　　――――　　　　　１１１Ｉ　　　　　１ＳＮＳ　　　　　――――　　　　　　　ＭＩ　さあ、こんどはどこに第二の鍵を発見すべきであろうか。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｑ１Ｎ　　　＿＿＿＿＿＿１ＭＬ）ＱＴＰＡＩ　　　　ＱＩ０　　　　―――――　　　　　ＱＰＡ　　　　　１ＭＬ　　　　　――――　　　　　１１１Ｉ　　　　　１０Ｎ０　　　　　――――　　　　　　　ＭＩ　いよいよ第三の鍵の発見に掛る。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "２１Ｎ　　　＿＿＿＿＿＿１Ｍ５）２ＴＰＡＩ　　　　２Ｉ０　　　　―――――　　　　　２ＰＡ　　　　　１Ｍ５　　　　　――――　　　　　１１１Ｉ　　　　　１０Ｎ０　　　　　――――　　　　　　　ＭＩ　第四の鍵は、比較的楽であったから、あとはもういいだろうと安心すると、たいへんな間違いが起る。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ＰＯＲＴ・ＳＡＩＤは、白・黒・黄・赤の各人種によってアラビヤ風に極彩色された、二面神の象徴模型なのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "すき焼開始並びに神秘的な豚鍋よ、永久にＢＡＮＺＡＩ！",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分の先頭でＭＡＩを含み、跫音を窃取して上って来たのが、三階のこのマアセルの部屋の隣室。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも特に彼らが驚かされたのは、まっとうな企業も数多く存在しているシリコンバレーの中で、一行が彼らとキット式のコンピューターを出しはじめたばかりのＩＭＳＡＩ社のみを訪ねた点だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの年の夏には、アルテアと同じく８０８０を使ったＩＭＳＡＩ８０８０と名付けられた対抗機が登場した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発元のマイクロプロ社を設立したシーモア・ルービンスタインは、アルテアを追って生まれたＩＭＳＡＩの会社を経て、今度はでき上がったマシンで走らせるソフトウエアの会社を起こそうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七年の初頭、アメリカに戻ったルービンスタインは、コンピューターキットを売っている店でＩＭＳＡＩを買い求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンスタインはミラードに連絡をとり、ＩＭＳＡＩのマーケティング部長として働くことになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで彼は、ベーシックとは性格の異なるオペレーティングシステム（ＯＳ）と呼ばれる基本ソフトをＩＭＳＡＩに載せるために、コンサルティングを依頼していたグレン・ユーイングを通じて開発元に連絡をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩのコンサルタントをしていたグレン・ユーイングから一九七六年に連絡を受けた段階では、ＣＰ／Ｍはすでに異なった四つのシステムで使われるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーイングの用件は、ＩＭＳＡＩが「ＯＳはすぐに間に合わせる」としてすでに売りはじめていたドライブ用に、ＣＰ／Ｍを使わせてほしいという依頼だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＩＯＳの切り離しは自分でやったが、ＩＭＳＡＩのマシンへの対応は彼らに任せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "交渉にあたったＩＭＳＡＩのルービンスタインは、「二万五〇〇〇ドルで何本でもＣＰ／Ｍを使ってよい」とする条件をキルドールが呑んだことに驚かされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩをはじめとするライバル機に追われはじめると、アルテアでブームに火をつけたＭＩＴＳのエド・ロバーツは、すぐに会社に見切りをつけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩの時代もまた終わりつつあると考えたルービンスタインは、一九七八年に同社を去ってソフトウエアの会社、マイクロプロを設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンスタインがまずやったのは、自分の二週間前にＩＭＳＡＩをやめていた同社の元ソフトウエア開発部長、ロブ・バーナビーを雇うことだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアやＩＭＳＡＩの紹介とこれらにつなぐ入出力機器やシンセサイザーの解説記事を用意し、西は自分の名前では「ＴＶゲーム徹底調査」と題した連載記事を持った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにアルテアやＩＭＳＡＩ用に会場で売られている増設メモリーも、八Ｋバイトや一六Ｋバイトといった大容量のものが主役となっており、果ては一枚の増設ボードで六四Ｋバイトという度肝を抜かれるような代物まで登場していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルテアを追って登場したＩＭＳＡＩは、ゲアリー・キルドールに海軍大学院で教えを受けた、ゴードン・ユーバンクスの開発したベーシックを載せていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じくリースバックの機器のショップとして生まれた横浜のバイトショップ・ソーゴー、そしてムーンベース、コンピュータラブといった秋葉原のショップが、アルテアや続いて登場してきたＩＭＳＡＩ、ＫＩＭ―１などを並べ、雑誌類を取りそろえてマイコンショップの走りとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも雑誌の発行で多忙をきわめているはずの西は、繰り返しアメリカに出かけてはショーを覗き、古川も名前だけはよく聞いているインテルやＩＭＳＡＩなど関連の企業を訪ねていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七五年になってマイクロコンピューターを使ったキット式のシステムが一部のホビイストたちに熱狂的に支持されはじめると、大半の正統的な研究者がおもちゃ以前のシステムに興味を持たなかった中で、ラスキンはさっそくアルテア、続いてＩＭＳＡＩを買い求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
