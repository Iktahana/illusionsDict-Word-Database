    "definitions": [
      {
        "index": 1,
        "gloss": "the very picture of ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の描いた風景画はとてもリアルで、まるで絵に描いたようでした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このリゾート地の夕日は、あまりにも美しくて、まるで絵に描いたような光景でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが楽しそうに遊んでいる様子は、まさに絵に描いたような幸せな光景です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しいモデルルームは、理想的な暮らしを完璧に表現していて、絵に描いたような空間でした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "寐られません目をぱちぱちして、瞶めておりました壁の表へ、絵に描いたように、茫然、可恐しく脊の高い、お神さんの姿が顕れまして、私が夢かと思って、熟と瞶めております中、跫音もせず壁から抜け出して、枕頭へ立ちましたが、面長で険のある、鼻の高い、凄いほど好い年増なんでございますよ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に絵に描いたような「狼が来たぞ」で、情けないことおびただしい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「上の兄たちは、絵に描いたような意地悪なんかじゃなかったわ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵に描いたような美しい夜の海原だった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山がかりになっている料理屋の庭には、躑躅が咲乱れて、泉水に大きな緋鯉が絵に描いたように浮いていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光景に生気をそえるように、二人の百姓女が、絵に描いたように着物をまくりあげ、くるりと裾を端折って、膝まで水につかりながら、二本の木の竿に結びつけた破れた曳網をひっぱって池の中を歩いていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍らの椅子には、これまた絵に描いたような麗人糸子が膝に伏せた本の上にすんなりとした片手を置いて、何ごとも知らず安らかに眠っている。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから見れば、両国橋の側面は、その全体を見ることもできるし、橋の上の人の提灯も、橋の下の舟の提灯も、絵に描いたように見えるけれども、それを眺めているのではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "金持ちは、草の上に腰をおろして、たばこをすいながら、絵に描いたような、あたりの景色にうっとりと見とれたのです。",
              "citation": {
                "source": "船でついた町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルソオの頬は、絵に描いたように薔薇色に染まった。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い光の下で、それは、絵に描いたような美少女であつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ土木学を専攻しようと企てるような地味な人物だから、才気溌剌という工合にはゆかないが、一面に愚直を絵に描いたような、判り易くいえば土方の棒頭ふうな磅※たる気宇を持ち、容易に転位せぬ代りに、一旦意気に感じたらその者のためには真実水火も辞せぬというような無益な感激性に富んでいるのである。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉が極めて静かに開いて、鏡の中へ入って来たのは年のころ十八九の、絵に描いたような美しい娘である。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "島の奥まったところへ入りこむと、絵に描いたような美事な平地があって、なかほどのところを小さな川が流れ、浅い川瀬の中で、青や、赤や、紫や、色とりどりの蟹が走りまわっている。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "前髪立の美少年、曙染の振袖、精巧の袴、短いのを前半に差して、紫足袋、さながら絵に描いたようです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "声は少し皺枯れて居りましたが、まるで絵に描いたような美しい顔で」それがまた、憎くてたまらない様子です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「右の耳の後ろ、玉をのべたような首筋に、豆粒ほどの、真っ紅な痣があるんですって」「そいつは有難い、絵に描いたようなきりょうで、首筋の赤い痣だ、地獄の底へ行っても見付かりますぜ、親分」　傍で聴いて居た八五郎が夢中になって乗出します。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後から、物の影のように現われたのは、彰義隊士日下部欽之丞、二十四五の絵に描いたような美男ですが、軽傷を受けた上、幾人か斬った返り血が、乱鬢と、蒼い頬と、黒羽二重を絞った白襷に反映して、凄まじさというものはありません。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時頼門は二十九歳、絵に描いたような良い男であったということであります。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "大名の倅",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもおまけにその娘は、まるで絵に描いたようなんですからね。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れは、岡山の片田舎のくせに、江戸っ子を絵に描いたような荻舟君が、これこそ、まじりッ気なしの、江戸ッ子一本のおみつ夫人と、万事、下町ごのみに暮していたのを、私も幾度か、のぞいた記憶がある。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし木乃伊とさえ言えば、土気色をした瘠せて枯木のように乾干び切った埃及の木乃伊を連想する我らの木乃伊の概念を越えて、これはまたなんという美しい、絵に描いたように艶やかな男女一対の木乃伊であったろうか！",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま眼の前に膝を固くして、大きなからだをぶるぶる震わせているさまを見ると、その胆の小さいことも臆病なことも絵に描いたようで、どなりつけるのも可哀そうな感じさえした。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "行燈の光りをうけて、艶やかな藤尾の頬は蒼いほども冴えてみえ、理知を絵に描いたような額から眉間へのひきしまった皮膚の感じが、秀之進の記憶にある富士の一夜の情景をまざまざと思いかえさせた。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな鱗が、金と黒とで、まるで絵に描いたように、はっきりと見え、口の端には、これも絵のように、ひげが二つあった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果、いまの彼女の上半身は、絵に描いたような逆三角形をした、隆々たる筋肉の彫像だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵に描いたような人種構成の彼らが、チームとして機能しては楽園の蛇を退治するドラマの内容は、これもまた絵に描いたように、当時という時代を映していた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
