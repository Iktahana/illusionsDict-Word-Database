[
  {
    "uuid": "297436ea-d62a-54e8-9611-f704c4074a66",
    "entry": "ＳＩＣ",
    "reading": {
      "primary": "エス・アイ・シー",
      "alternatives": [
        "エスアイシー"
      ],
      "is_heteronym": false
    },
    "grammar": {
