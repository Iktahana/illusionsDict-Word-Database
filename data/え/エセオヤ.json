        "examples": {
          "standard": [
            {
              "text": "子供の進路に全く関心を示さない彼は、まさに似非親だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "育児を全て他人に任せきりなのは、似非親としか言えない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「似非親」という言葉を聞いて、自分の子育てを反省した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして、反つて相手の似非親切に研究の眼を放つた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
