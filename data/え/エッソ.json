        "examples": {
          "standard": [
            {
              "text": "裁判官の判断に納得がいかず、越訴を試みたが認められなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、正規の手続きを踏まずに越訴したことで、さらに不利な状況になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "越訴は、緊急かつ特別な事情がある場合にのみ許される行為だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "左右に居流れたは検断所の司、評定衆、問注所の司、引付衆、越訴奉行、祗候人の人々で、同じくいずれも武装していた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恐れながら申上げます」「これ／＼差越訴へは相成らぬぞ、下がれ／＼ツ」　それツと取卷く足輕の六尺棒の中に、平次は臆れた色もなく小腰を屈めたまゝ、ツ、ツ、ツと進んだのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "色若衆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
