        "examples": {
          "standard": [
            {
              "text": "決勝戦で優勝を決め、チームメンバーたちは歓喜に酔いしれ、悦に浸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、長年の夢であった個展の成功に、静かに悦に浸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "\"なんとも心地よい風だ…\"と、彼は海辺で波の音に耳を澄ませ、悦に浸った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし絶対者である仏の慈悲を感ずること、美しい偶像と音楽とのもたらす法悦に浸ることは、愛欲に駛る多くのものにも不可能ではない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
