        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも文句一つ言わず、まさに縁の下の力持ちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "チームの成功は、縁の下の力持ちである彼女の働きなしにはありえなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの縁の下の力持ちによって、社会は支えられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裏方で黙々と作業する彼は、まさに縁の下の力持ちそのものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "仲人は御縁の下の力持ち　　　　　　　　　　腰を押いたり尻を押いたり　それから四、五日経って後のこと、目明の良助が、例の通りの尻端折に頬冠り姿でノッソリと猪口兵衛の縁端に腰をかけた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "図案工なんて、ほんとうに縁の下の力持ちみたいなものですのね。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面に現れることなどは欲しない、縁の下の力持ちに甘んじて一生かかつて一つの基礎工事をコツコツやるといふやうな――」　それまで默つて二人の話を聞いてゐた三井が、その時、「確かに今迄は餘りに理窟が多かつたですからね。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この度私が楠公の馬を彫刻するとなれば、従前の関係上、必ず助力をしてくれることでありますが、しかし、その助力を蔭のものにして、私が表面に立って、美事に馬が出来たとして、後藤氏の力がそれに多分に加わっているにもかかわらず、後藤氏は全く縁の下の力持ちになってしまうわけであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "馬専門の彫刻家のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "社長の川崎は、主筆ばかりが讃められて自分は殆ど縁の下の力持ち同樣なのに業を煮やしたのだらう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかい――本当に、妾ゃ、縁の下の力持ちさ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "謹直枯淡で縁の下の力持ちの如き一生を終つた杏坪先生。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其で、わたしも、あなたを見まねで、縁の下の力持ちをやる気になりました訣です。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者をひいきすると言ふ事も、いろ／＼あるが、ぱとろんとしての誇りを衒かすことも出来ず、又、好色に泥んで縁の下の力持ちをする気にもならぬ。",
              "citation": {
                "source": "芝居見の芝居知らず",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれのような縁の下の力持ち――そうだ、おれは自分のことを縁の下の力持ちだと思うが、どうだい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな縁の下の力持ちです。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "（それから、文藝春秋社時代の芥川賞のために、文字どほり、まつたく『縁の下の力持ち』をしたのは、永井龍男である。",
              "citation": {
                "source": "思ひ出すままに",
                "author": "「文藝春秋」と菊池と",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまくいったところで縁の下の力持ち、下手をすれば博士夫人を棒に振らなければならない。",
              "citation": {
                "source": "鷺娘",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみさんには隣人のために縁の下の力持ちをして甘じているようなところがあった。",
              "citation": {
                "source": "日日の麺麭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "従弟の寛一君は今まで縁の下の力持ちを勤めていた関係上、時局の進展を与り知る権利があった。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帝国ホテルの披露会一切を背負って立つ親達は単に縁の下の力持ちを勤めるんだから気の毒だよ。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちには多年のあいだ、縁の下の力持ちばかりさせて来たが、おそらくはこんどを以て、そんな蔭の働きも、働き仕舞いと思うてよかろう。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
