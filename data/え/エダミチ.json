        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "話が枝道にそれてしまったが、本来の目的を思い出そう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の講演は、時折、興味深い枝道にそれながらも、全体としてはまとまっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ごめんごめん、話が枝道にそれちゃった。で、さっきの件だけど…」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
