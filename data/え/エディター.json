    "definitions": [
      {
        "index": 1,
        "gloss": "text editor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プログラミングのコードを書くために、高機能なテキストエディターを探しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このドキュメントは、シンプルなテキストエディターで編集しても大丈夫です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "開発者たちは、それぞれお気に入りのテキストエディターを使っています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "作った側はただ、ワードプロセッサーやエディターで文書を書いたとしか思わない。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本来はＭＳ―ＤＯＳ用のこのマシンに１メガバイトちょいのＢＴＲＯＮのＯＳ（商品名はＥＴマスター）を載せ、別売のエディターをプラスすれば日本語ワープロとお絵書きにはすぐに使える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下はＯＳの核を書き、パーソナルメディアはシステム・アプリケーションと称して標準的に持たせる文章と図形のエディターを書いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフト側では文書と図形のエディターに通信ソフトをあらかじめ持たせ、モデム、ハードディスクを標準で付けて文書作成と通信にガンガン使ってくれという仕立だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのさい、いま私たちが現にそうしているように、ネットワークから入手したデータを、ワープロやテキスト・エディター（簡易ワープロ）などの文字処理ソフトを利用して読むというやり方ですむとは思えない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワープロやエディターは書くための道具である。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、新聞のエディターとして、また政界にも活躍しようとする野心をもっていたらしい人として、利益問題に超越してなどおれないことは、無理もない話であるのだが。",
              "citation": {
                "source": "黒岩涙香のこと",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのさい、いま私たちが現にそうしているように、ネットワークから入手したデータを、ワープロやテキスト・エディター（簡易ワープロ）などの文字処理ソフトを利用して読む、というやり方ですむとは思えない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに開いているページのＵＲＬを示す欄もあるのだから、そこの文字列をコピーして電子メールに貼って渡すか、エディターやワープロで記録すればいいという判断が働いたのだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このキット式のコンピューターをアルテアと名付けたのは、『ポピュラーエレクトロニクス』のテクニカルエディター、レズリー・ソロモンの娘だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＤＰ―10にはまともな端末装置がつながっており、エディターと呼ばれる編集ソフトもそろっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初はあまり注目を集めることはなかったが、キルドールは仕事の合間を縫って手直しに努めるとともに、ＣＰ／Ｍを使ってプログラムを書くときに必要になるエディターやアセンブラー、デバッガーなどを書きためていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文書編集用のテキストエディターとして開発されたワードマスターは、印刷の機能が弱く、細かな体裁の指定ができなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "リサのインターフェイスは、ウインドウやアイコン、マウスを中心に組み上げるという方針が、見学後急遽定められ、アルト用にエディターを書いた★経験を持ち、アップルの面々にデモンストレーションを見せてくれたラリー・テスラーが引き抜かれてリサの開発チームに加わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★アルト用のエディターとしてもっとも広く使われたものは、パロアルト研究所のチャールズ・シモニーとバトラー・ランプソンによって開発されたブラヴォーだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラリー・テスラーとティム・モットはインターフェイスの改善に目標を絞って、ジプシーと名付けたエディターを書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "シモニーはパロアルト研究所在籍時、アルト用のエディターとして広く使われたブラヴォーを書いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書の記述によれば、ゲイツは三人の日本人の書いたプログラムのうち、行番号で管理する形式のエディターに不満を感じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがプログラマーたちは、その他の要素を三二Ｋバイトに押し込んでいるために、画面上の任意の文字を直接修正できるフルスクリーンのエディターを入れる余裕がなく、変更は不可能であると主張した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると次の朝、ゲイツは同じサイズに収まる〈不可能なはずの〉エディターをたずさえて現われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、問題のエディターに直接携わった鈴木仁志は、開発の経緯をより詳細に、そしてより正確に記憶している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『帝王の誕生』の記述どおり、当初エディターにはベーシックそのものが持っていた行番号単位のものに若干の味付けを施して、汎用エディターらしく見せたものを使っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このエディターを含むソフトウエアは、マスクＲＯＭに焼かれ、試作品に組み込まれて評価された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビル・ゲイツは試作機をいじくり回して真っ先にエディターに注文をつけ、作りなおしを主張した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エディターを担当していた鈴木は、厳しいメモリーの制限の中で、いかにしてスクリーンエディターを実現するかにアイディアをひねった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
