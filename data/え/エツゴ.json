        "examples": {
          "standard": [
            {
              "text": "私の祖母は、粤語、すなわち広東語を流暢に話します。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "言語学者は、広東語を含む様々な粤語方言の音韻の違いを研究しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、現代粤語の文法構造を解説した書籍を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "まあ、貴様にしたところで生きていてえつごうもいろいろあろうが、ここは一つ万障繰り合わせて俺の手にかかってくれ」「笑わせてはいかん。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "Cantonese (language)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
