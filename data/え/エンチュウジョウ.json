        "examples": {
          "standard": [
            {
              "text": "古代遺跡からは、円柱状の美しい彫刻が多数発見されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この教会の内部は、円柱状の柱が規則的に並んでいて厳かな雰囲気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "工場で使われる部品の中には、円柱状のものが多く存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その怪光線は、管内の反射鏡によって、ツツーと横に流れ、いくつかの丸い枠をとおるたびにその紫色が濃くなり、やがて最後には深い藤色の円柱状の光束になった。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "バショウの高く直立せる円柱状の茎はじつは本当の茎ではなくいわゆる偽茎であって、それは長い葉鞘が重なって出来たものである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本品は純緑色の海藻で、浅い海底の岩に着生し、三寸ないし一尺ばかりの長さがあって両岐的に多数に分枝し、その枝は円柱状で、質は羅紗のようである。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの紙を円柱状に丸め一端を心臓が拍動しているところに当て他端から聴いた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
