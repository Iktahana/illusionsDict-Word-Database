    "definitions": [
      {
        "index": 1,
        "gloss": "reserve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初対面の人ばかりだったので、遠慮してしまい、あまり積極的に話せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はいつも一歩引いて、自分の意見を主張するのを遠慮がちだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もっと遠慮なく、感じたことを率直に教えてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "谷君の方で早速遠慮を示したので、結局出掛けないことになつて、「では二階に行かうか、此処は子供が目を覚ますんで話が出来ないんだ」と牧野さんは云つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもなんとなくみんなが遠慮して、結局そこで小さい声で話すことになつてしまつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "順つて私の著者に対する大胆な評価は、凡てこの自信と無遠慮の独断から出発する。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は例の調子で、相手の氣分におかまひなく、無遠慮にずばずばと放談した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも大いに遠慮しながら発表しているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君だって遠慮しているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は久しぶりで先生のお宅へお伺いして、大隅君の縁談を報告し、ついては一つ先生に媒妁の労をとっていただきたいという事を頗る無遠慮な口調でお願いした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は出際にお客さんがありはしたし……明日立つたら……」　母が「甘い」とよく彼が言ふので、また言はれはしまいかと思つて、遠慮深さうにさう言つた時、彼はさすがに「甘い」とはいはれなかつた、却つて自分の方が「甘い」だつたのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる人にも遠慮なきこそ子供なれ。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に食事していた客の誰よりも真先に自分のところへこの菓物鉢が廻って来たので、自分は遠慮なくこのただ一つの柿を取上げた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮なさらず、思つたこと、たくさん教へてもらひたい。",
              "citation": {
                "source": "「人間キリスト記」その他",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その状は、流石に形容を遠慮しますけれど、とにかく酸鼻の極でありました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、家族の者たちに遠慮しながらも、どうしてもお酒を飮まざるを得ないやうな氣持になるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮には及びませぬて。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、みなさんも、」と兎たちに呼びかけ、「この座敷には偉いお婆さんも聖人もゐませんから、どうか、遠慮なく、どうぞ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とお爺さんは、やたらに遠慮して小さくかしこまり、朝食のお膳につく。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と生意氣な娘は、無遠慮に率直な感想を述べる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島太郎は、弟妹たちのそんな無遠慮な批評を聞いても、別に怒りもせず、ただ苦笑して、「好奇心を爆發させるのも冐險、また、好奇心を抑制するのも、やつぱり冐險、どちらも危險さ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ來て遠慮なんかするのは馬鹿げてゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなかに男振りが少し佳く生れて來たばかりに、女どもが、かへつて遠慮しておれに近寄らない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮なくべたべたと威勢よくやつてくれ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに竹刀でバシバシと、すこたんを遠慮なしに打ん殴りやがったっけ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "導火線に火を移す時は、たといどんな病気でも、一時遠慮するものだ、と。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮深い小さな聲で云つて居るのであつたが流石に昨日の大宮の車夫とはちがつて、畫の中の物體を指摘したりしないで「色」を云つたりする處がそれだけ新しい時代の子供であるのかも知れない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘の神は父の老翁に、こういう慮りから、宿は村里の誰かの家へ取ってあげますから、祭の今夜一夜だけは自分の家をば遠慮して欲しいと頼んだのであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとでも自分にだらしがないところが眼につくと、自分で不安なのだ」「何だか知らないが、欲しいものがあったら、遠慮なくいくらでもそうお云いよ」　初午の日には稲荷鮨など取寄せて、母子のような寛ぎ方で食べたりした。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから、君は旦那になったつもりで、遠慮なく愉快をすればいい」　なるほど、二人の若い芸妓たちは、よく働いた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮のない相手に向って放つその声には自分が世話をしている青年の手前勝手を詰る激しい鋭さが、発声口から聴話器を握っている自分の手に伝わるまでに響いたが、彼女の心の中は不安な脅えがやや情緒的に醗酵して寂しさの微醺のようなものになって、精神を活溌にしていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は照れるようなこともなく言葉もそう改めず、この旅でも、ただ身のまわりの世話ぐらいは少し遠慮を除けてしてあげるぐらいなものであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云って遠慮しましたら、鳥捕りは、こんどは向ふの席の、鍵をもった人に出しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
