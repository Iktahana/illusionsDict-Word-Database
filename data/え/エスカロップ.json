        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日のランチは、仔牛のエスカロップ、レモンバターソース添えにしました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "鶏肉のエスカロップを薄く叩いて、カリッと揚げると美味しいんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "パリのビストロで食べたエスカロップが忘れられない味なんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ポタージュとゼフエスカロップ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルニューグリルへ行き、コンソメ、キスのフライと犢のエスカロップを食った、犢の大きさには参った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終ると、公会堂へ、静家のオヂイに頼まれた会で行き、勝太郎の後でやり、その足でニューグランドへ、徳山と落ち合って食事、豆のポタアジュとエスカロップ、スパゲティ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "チキン・アラキング軟くてうまい、他に犢のエスカロップ、之もうまし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "京松グリルてのへ行きポタージュ、ロブスターの大きいの、卵のエスカロップ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時半、風月へ行き、コンソメ、きすとスピナチ、チキン・パテ、エスカロップビーフとスウィートポテト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ食ひたい、又任せると言ったら、ビーフのエスカロップ風のもの、相当量だったがきれいに食ひ、而も、ロールを一つ食ったから、おやぢも感心してゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやぢ在り、ポタージュ（コーンで、乙）と、犢のエスカロップと、ロール二。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィールのエスカロップ、温野菜。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
