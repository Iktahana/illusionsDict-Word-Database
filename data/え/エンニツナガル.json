[
  {
    "uuid": "85433824-4332-5724-9a9f-739098cd9db5",
    "entry": "縁につながる",
    "reading": {
      "primary": "えんにつながる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
