[
  {
    "uuid": "753fda4a-29e4-55c4-809d-cb0382cf372d",
    "entry": "厭世",
    "reading": {
      "primary": "えんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "weariness with life",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は都会の喧騒を逃れ、厭世的な気分に浸りながら山奥の別荘で独り暮らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ショーペンハウアーの著作を読み耽るうちに、彼の中に厭世観が芽生え始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若くしてすべてを手に入れた彼は、皮肉にも深い厭世の情に囚われてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の描く絵画には、どこか現実を拒絶するような厭世の色が濃く漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "厭離一切娑婆世界の厭世観は、ヘルンの多くの作品中に一貫して、その特殊な文学情操の基調となってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自殺しない厭世論者の言ふことなんか、當になるものか。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、ひどい憂鬱の厭世觀に憑かれてゐた私は、談話のあらゆる本質點に於て彼と一致し、同氣あひ引く誼みを感じた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが私は、彼の厭世觀の眞原因が、どこにあるかを判然と知り得なかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが自殺しない厭世論者の言ふことなんか、皆ウソにきまつてゐるよ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君も僕も、どうせニセモノの厭世論者さ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさへ彼が反復した最後の言葉――自殺しない厭世論者の言ふことなんか、たれが本氣にするものか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の句と同じく、或る荒寥とした、心の隅の寂しさを感じさせる句であるが、その「寂しさ」は、勿論｜厭世の寂しさではなく、また芭蕉の寂びしさともちがっている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「侘び」は決して厭世家のポエジイでなく、反対に生活を愛撫し、人生への懐かしい思慕を持ってる楽天家のポエジイである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新古今集の和歌は、亡び行く公卿階級の悲哀と、その虚無的｜厭世感の底で歔欷しているところの、艶に妖しく媚めかしいエロチシズムとを、暮春の空に匂う霞のように、不思議なデカダンスの交響楽で匂わせている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四枚、五枚の隨筆ばかり書いてゐると、とても厭世的になつてしまふのです。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその上で「人の心は飛鳥川、変るは勤めのならひぢやもの」という懐疑的な帰趨と、「わしらがやうな勤めの身で、可愛と思ふ人もなし、思うて呉れるお客もまた、広い世界にないものぢやわいな」という厭世的な結論とを掲げているのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鴫立つ澤の秋の夕ぐれ」などといふ歌をよむと、昔の厭世主義者の詩境がよくわかる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし尊氏の哲學は、キリスト教の博愛主義ではなく、もつと深刻な厭世觀を根據とする東洋の宿命哲學、即ち佛教にもとづいて居る。",
              "citation": {
                "source": "足利尊氏",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「厭世家とでも云ふんでせう。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭世家と云ふものは一種のイゴイストですから……」　聲が途切れると、またしんとなる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又決して厭世家たるの權利は無かつた。",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お栄さん僕はそんな声を聴かされると何だか哀れっぽくなって堪りません』と思わず口に出しますと『小妹は何故こんな世の中に生きているのか解らないのよ』と少女がさもさも頼なさそうに言いました、僕にはこれが大哲学者の厭世論にも優って真実らしく聞えたが、その先は詳わしく言わないでも了解りましょう。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果がビフテキ主義となろうが、馬鈴薯主義となろうが、将た厭世の徒となってこの生命を咀うが、決して頓着しない！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は鉄斎君からあなたの事はしじゅう聞いて居りますが、あなたは理想を死後の世界にもとめる厭世家であって、なぜ陶器を作って売ったり、歌の短冊を書いて売ったり、この現実に一生懸命に働いて居られるのですか。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の厭世家なら、もうこの現実には望みを断ったのだから、働いても仕様が無い筈を、あなたはせっせと働いてお出でになる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はどういふものか感傷的になつた、そして厭世的にさへなつた、私はセンチメンタリストではあつてもペシミストではない、しかし今日のやうな場合には、もし私が死ねる薬を持つてゐたならば死んだかも知れない。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "検視官は厭世自殺と認める。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の第二詩集「青猫」は、その惑溺の最中に書いた抒情詩の集編であり、したがつてあのショーペンハウエル化した小乗仏教の臭気や、性慾の悩みを訴へる厭世哲学のエロチシズムやが、集中の詩篇に芬々として居るほどである。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
