  {
    "uuid": "ea35f692-903c-59d3-8bc6-b84422a309dd",
    "entry": "エスキモー犬",
    "reading": {
      "primary": "エスキモーけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
