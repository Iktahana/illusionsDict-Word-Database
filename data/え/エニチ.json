    "definitions": [
      {
        "index": 1,
        "gloss": "sun of wisdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "仏教では、仏の知恵が世の中の闇を照らす様子を慧日に例えることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寺の山号に「慧日山」と名付けられているのは、その教えが太陽のように衆生を導くことを願ってのことだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "慧日が昇るが如く、迷いの霧が晴れて真実の姿が見えてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "煩悩の氷厚ければ、これを割る仏の慧日、光芒をいや増す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が今、再びこの世に眼を開く時、さし出ずる慧日は必ずやお前に新なるものを見せるであろう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は「本住院活法日觀信士、天明四年｜甲辰十二月十七日」、母は「靈照院｜妙慧日耀信女、文化十二年｜乙亥正月十三日」で、並に橋場長照寺に葬られた。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこには、一空和尚というえらい坊さんがいらしって、御自分の坊に、この界隈のおこども衆をおおぜい集めて、学問を教えておいでになりますから」「何という坊主だ」「慧日山金剛寺の、一空和尚でございますよ」「しからば、その坊主のもとへ、この金子を献じて参ろう。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぞわたしに、急な用事でもできたのでございますか」　若松屋惣七方のうら手、小石川上水堀の端にある金剛寺は、慧日山と号し、曹洞派の名だたる禅林だ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、わかってみると、隣の慧日山金剛寺の一空さまなのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん誰が考えても無謀な考えにちがいないが、あの人はしばらくその無謀さに気がつかない。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の恋を囁いている間に自身の芸術家の虫が、そろそろ頭をもたげて来て、次第にその虫の喜びのほうが増大して、満場の喝采が眼のまえにちらつき、はては、愛慾も興覚めた、という解釈も成立し得ると思います。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋もすえにちかいことだから、水は流れてはいない。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあざらしというけものはこんなものかとおもわれるほどの大きさで、水のうえにちょっぴり顔をだしていました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、うちの旦那にだってやっぱしわかりっこねえにちげえねえ。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、僕は、自分が今まで君の考えにちゃんと正しくついてきたことを確信したのだ。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手な神社のまた右手の一角にまっ黒い大石が乱立して湖水へつきいで、そのうえにちょっとした宿屋がある。",
              "citation": {
                "source": "河口湖",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "就いては師匠、おめえにちっと訊きてえことがあるんだが、後に来るよ」「はあ、どうぞ、お待ち申しております」　常吉はそのまま津の国屋の方へ行ってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺らおめえにちつと相談に乘つて貰えてえと思ふこと有つて來たんだつけがなよ」おつたは態と改まつた容子でなくいひ掛けた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく思い出して、行くつもりだと答えると、与次郎は、「出るまえにちょっと誘ってくれ。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴新というからにゃ、新兵衛、新九郎、新左衛門、いずれは新の字のつく名まえにちげえねえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "察するに、イの字とロの字のきちげえにちげえねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "感興の機勢で直ぐ筆を揮つたＺ・Ｋ氏は、縱長い鳥子紙の見事な出來榮えにちよつと視入つてゐたが、くる／＼器用に卷いて、では、これを、とＡさんの前に差出したかと思ふと、瞬間、手を引つ込めて、「Ａ君、これタヾかね？",
              "citation": {
                "source": "足相撲",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくマヌエラには、座間もヤンもおなじ考えにちがいない。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "このゆえにちぎれちぎれの刹那に立って、個々の断片的なる官能的経験を漁りつつ生活の倦怠より遁れんとする刹那主義者はしばらく措き、いやしくも全部生命（whole being）の本然的要求の声に傾聴して統一せる人格的生活を開拓せんとする真摯なる個人は必ず芸術とともに哲学をも要求せずにはいられない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若え時にゃ良え教育を受けたんで、その気になれぁ書物みてえにちゃんと立派にしゃべれるんだ。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "三根夫は、そのまえにちょっと足をとめた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして背中が閉まると、盃はそのうえにちゃんとのっている。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの頬杖をしている小さな石仏のうえにちらちらしていた木洩れ日も、よほど高いところから好い工合に落ちてきていたので、あんなに私を夢み心地にさせたのだったろう。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝になって、おいのりしたあとで、さて仕事に取りかかろうとすると、気づけば一足のくつはとうに仕上がり出来上がっていて、つくえにちょこなんと立てられているのです。",
              "citation": {
                "source": "小人のくつ屋さん",
                "author": "グリム兄弟",
                "note": "青空文庫"
              }
            },
            {
              "text": "火をつけたのも、おまえにちがいない。",
              "citation": {
                "source": "あほう鳥の鳴く日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、方々へ泥棒にはいったのも、おまえにちがいない。",
              "citation": {
                "source": "あほう鳥の鳴く日",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の気まぐれな明るい斑らが、草を一本一本金色に染めあげて、それでもなお足りずにそのうえにちらついたり揺らめいたりしている有様は、火のような紅蛾のはげしい羽ばたきか、それともその木かげの草むらが、一からげに月の投網に引っかかって、あちこち泳ぎまわっているところか、と疑われるばかりだった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "金剛寺坂の若松屋惣七の屋敷へ行ってみると若松屋惣七と紙魚亭主人の麦田一八郎とが、京阪へ行くまえにちょっと帰って来ていた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
