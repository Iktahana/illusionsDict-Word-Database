          "standard": [
            {
              "text": "数回の厳しい選考を経て、最終面接に残る最も優秀な候補者たちが選び抜かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "コーチは、最も才能のある選手たちを、時間をかけて注意深く選び抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "山積みの証拠の中から、探偵は決定的な手がかりを一つ、選び抜いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "選び抜くはじから、冬彦はプリントしなおした。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
