        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駅前に新しくオープンしたエステ、すごく評判がいいらしいよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は娘と二人で、たまにはエステにでも行こうかと話している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "誕生日プレゼントに、あそこのエステのギフト券をもらったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、男性でも気軽に利用できるエステが増えてきているね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
