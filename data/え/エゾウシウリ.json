        "examples": {
          "standard": [
            {
              "text": "昔は、街角で絵草紙売りが声を張り上げていたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが絵草紙売りの周りに集まって、次は何が出てくるか楽しみにしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「絵草紙はいかがですかー！」という絵草紙売りの声が、遠くまで響いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の浮世絵には、賑やかな絵草紙売りの様子が描かれていることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「先生も御承知のとおり、わっしは生得、犬猫がすきでごぜえやして……」　じっさいこのお爺さん、自分で言うとおり、犬や猫がすきで、商売は絵草紙売りなのだが、かせぎに出ることなど月に何日というくらい、毎日のように、そこらの町じゅうの捨て猫やら捨て犬をひろってきて、自分の食うものも食わずに養っているのだが。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
