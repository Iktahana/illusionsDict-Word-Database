    "definitions": [
      {
        "index": 1,
        "gloss": "to be conceited",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「うちの子、ちょっと褒められただけで、すぐに偉そうな態度をとるんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼はいつも自分が一番詳しいとばかりに偉がるから、周りは少し煙たがっている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「子供が親の気を引こうと、わざと偉そうなことを言ったりすることがある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かう云ふと何か酷く偉がるやうで、聞辛いか知らんけれど、これは心易立に、全く奥底の無いところをお話するのだ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それに彼奴、厭に偉がるのね、ドストイエフスキーが何う云つてゐるとか、ボ※リー夫人を読んだことがあるかとか、恰で此方を文学少女かなんぞのやうに考へてゐるのさ、あんなことを云ふ人に限つてドストイフスキーなんて解つてゐるもんか。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢口はもうすぐ中学へ通ふのだから僕より偉がるのだ。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "威風あたりを払うというを豪傑の理想とし、人の近づき得ざるところを偉いと做したから、偉がるものは、なるべく人を近づけぬ工夫をなし、あるいは傍若無人にして人を馬鹿にして独りで偉がった。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらばただただ人より偉いと嬉しがるために勝つかと問わば、決して偉がるばかりが目的でない、むしろ人を服従させるのが勝つの意味である。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "此人をえらくすると同時に、私がそれにおぶさつて、失敬だが、それを踏臺にしてえらがることも出來る。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云うのがえらがるのでないことは勿論である。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃元勲とか何とか、自分でもえらがる人達に、かういふ歌を詠んで遣つたよ。",
              "citation": {
                "source": "黙々静観",
                "author": "勝海舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲野さんと宗近さんは、体を斜めにえらがる人を通した。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "神、人類、祖國は本書の中心觀念である‥‥』　今讀んで見るとちとえらがるやうで、何やら嫌な臭みがあるといふ批評を下さるるかも知れぬが『高山仰止、景行行止、雖不能至、然心郷-往之』である。",
              "citation": {
                "source": "「雨の降る日は天氣が惡い」序",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来たからって、えらがるのは、沙汰の限りだ。",
              "citation": {
                "source": "世界漫遊",
                "author": "ダウィット　Jacob Julius David",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それを金があるからと云うてむやみにえらがるのは間違っている。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああしたえらがる心持に学者はなれようが、6590悪魔はとうから厭気がさしているて。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "えらがるのはただ驢馬とその亜流くらいなもので、それさえ何かある障壁にぶつかったら、もうおしまいなのである。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
