[
  {
    "uuid": "6c5acf2f-2e23-59e0-a783-1b619d006dd5",
    "entry": "閲覧室",
    "reading": {
      "primary": "えつらんしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
