[
  {
    "uuid": "71b61760-7dd9-506e-aa1b-a6da95b25465",
    "entry": "ＳＯＳ",
    "reading": {
      "primary": "エス・オー・エス",
      "alternatives": [
        "エスオーエス"
      ],
      "is_heteronym": false
    },
    "grammar": {
