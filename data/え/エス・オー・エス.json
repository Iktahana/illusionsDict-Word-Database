    "definitions": [
      {
        "index": 1,
        "gloss": "SOS (distress signal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遭難した船からSOS信号が発信され、救助隊が急行した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「誰か助けて！SOS！」 山で道に迷い、携帯電話も圏外だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "灯台守は、遠くでSOSを出す漁船の明かりを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "無事救助された彼らは、まずSOSを発信したことを感謝した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "けさ、またまた、新聞よろず案内欄で、たしかに君と思われる男の、たしかに私と思われる男へあてた、ＳＯＳを発見、おそれいって居る。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしなもので、きのうまでは大いにみずみずしい男も、お金のＳＯＳ発してからは、興味さく然、目もあてられぬのは、どうしたことであろう。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "警告の意味で、故意と声を立てて大きな欠伸を連発していたが、それでも白浪を蹴って進む林技師の雄弁丸が、どうしてもＳＯＳの長短波に感じないので、とうとう精も気魄も尽き果てたらしく、ゴリゴリと巨大なイビキを掻き始めた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハガキが二枚残つてゐたので、岔水君と多々桜君とへたよりを書く、ＳＯＳを意味しないでもない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何もかもなくなる、ＳＯＳの反響はない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しようことなしにポストまで（ＳＯＳの場合だ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、途中一杯ひつかけたが、足らないのでまた一杯、折からの空腹で、ほろりとして戻る（のん気なＳＯＳの場合だね！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "上甲板の無電室では、主任技師フィリップスが懸命にＳＯＳを放っている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＯＳは新しい信号でＣＱＤから変って間もなくだった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのＳＯＳってやつを打つことです。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからもあんまりＳＯＳを叩く機会はないでしょうから、この際大いにやりましょう」　楽天家の無電助手ブライドが、こんな冗談を言って笑った。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長もそれを聞いて、「そう度びたびＳＯＳを打つ機会があってたまるもんか」　と笑った。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、助手の Bride が鳥渡無電室を出て帰ってみると、火夫の一人が救命帯を盗みに忍んで来て、ＳＯＳを打ち続けている技師 Philips の背中から其の救命帯の紐を解きに掛っている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリップスは血の飛沫を浴びながら、振り返りもせずにＳＯＳを打電しつづけた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなくタイタニック号からは、フィリップスの打ち続けるＳＯＳが火のように放散される。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、キャリフォルニアンの無電機は、直ちにそのタイタニックのＳＯＳを感受して焦げつくような音を立て、火花を散らさん許りなのだが、この十分間に、技師エヴァンスはぐっすり眠りに落ちて、鼻先の受信機が懸命に囁くタイタニックのＳＯＳを灯を慕って、迷い込んで来た羽虫の音ぐらいにしか聞いていなかった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイタニックの必死のＳＯＳの電波が、音のない悲叫のように充満した無電室で、エヴァンスは朝まで好い気持ちに眠った。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全く、何だか様子が変ですね」見習ギブスンは心配そうに、「無線のエヴァンスを起しましょうか」　エヴァンス技師さえ眼を覚ませば、即座にＳＯＳを受信して、キャリフォルニアン号は全力を挙げてタイタニックに接近し、救助作業を開始して必ずや全人助かっていたことだろう。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時は既う、タイタニック号のフィリップスの打つＳＯＳが火のように伝わって来て、寝ているエヴァンスの傍の無電機械は間断なくその救助信号を感受して灼けつかん許りに熱している最中である。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命のＳＯＳはキャリフォルニアン号に届こうとして、遂に届かなかった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それよりも、前に述べたように、このエヴァンス技師――彼は職業柄 Sparks という綽名で通っていた快男子風の一種変った人物だった――が、もう十分間起きて無電機に向っていたら、いの一番にタイタニックのＳＯＳを把握して、何の事はなかったのである。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリップスのＳＯＳには可成り多くの船から返電があったが、皆遠過ぎて頼みにならない。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイタニックの無電技師フィリップスは、二千人の生命をＳＯＳに託して狂気のように打ち続けても、キャリフォルニアン号では肝心のエヴァンスが熟睡していて、耳の傍の機械の無言の囁きを聞く由もなかった。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後まで無電機に獅噛み付いてＳＯＳを叩き続けた、この若い無電技師の物語は今だにゴダルミング市民の誇りになっている。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "経度と緯度で的確な船の在所を知らして寄越して、直ぐＳＯＳを放電するようにと言うのである。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際カルパセア号はＳＯＳを受取ると同時に十七ノット半という驚異的な速力で突進して来たが、氷山区域へ這入ってからは止むなく徐行しなければならない。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＯＳは、返電があってから、本船の位置を確報して救助船に無駄な動きをさせずに一刻も早く誘き寄せるのが大変な仕事なのだ。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリップスとブライドに直ちに無電室を出て最後の救命艇に乗り移るように命じたが、船長が立ち去ると同時に、フィリップスは再び聴取器を掛けて又ＳＯＳを打ち始めた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はショウルで肩を包んで、子供のように歔り上げながら、ＳＯＳを打つフィリップスの指先を、泪で曇った眼で凝視め続けた。",
              "citation": {
                "source": "運命のＳＯＳ",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
