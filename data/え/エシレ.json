          "standard": [
            {
              "text": "エシレバターを使ったフィナンシェは、香りが格別で、とても美味しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ちょっと贅沢をして、エシレバターで焼いたトーストを朝食に用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "パティシエが使う高級バターといえば、エシレが有名だよね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "週末は、エシレバターと粒マスタードを使ったサンドイッチを作ろうかな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
