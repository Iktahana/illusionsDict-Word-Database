    "definitions": [
      {
        "index": 1,
        "gloss": "ceramics painting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女は午後、花瓶に繊細な花を絵付けして過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この陶芸スタジオでは、初心者向けの絵付けクラスも提供しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "その作家の独特な絵付けのスタイルは、コレクターの間で非常に人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ひとり土のみならず、絵付けに用いる鉄分も織部に用いる丹礬も、すべての材料は他所に求めてはならぬ。",
              "citation": {
                "source": "窯を築いて知り得たこと",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは中国に渡って古赤絵付けの法を得た。",
              "citation": {
                "source": "古九谷観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絵付けについて吾人の観る所を披瀝すると、古九谷の絵なるものには真に守景以上の価値として観るべきものが少なくないのである。",
              "citation": {
                "source": "古九谷観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは絵付けだけを自分でやっておりましたが、どうも他人に作らした素地に、絵だけ描いて見ましても、肝心の土の仕事が心なしの職人の作であります以上、調和のとれるはずはありません。",
              "citation": {
                "source": "陶器鑑賞について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "訳もなく他人に生地を作らせ、その上に絵付けをして先ず満足していたのである。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "生地を他人に作らせ、上絵付けを自分がするのは、合作であって自作ではない。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に陶器は絵付けが主でなくて、土の仕事が主である。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その土の仕事は無知な職人に任せて、絵付けを自分がしているなど、少なくとも作陶精神に於ては主客転倒している。",
              "citation": {
                "source": "なぜ作陶を志したか",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "美校の画学生を聘して仁清ふうの絵付けをさせてみたりされるあたりは聡明そのもののような、前山翁の所作としては合点のいかな過ぎる常識なのだ。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず仁清ふうを工人に轆轤させてと考えられ、次に絵付けとなる、と考えるにも考えられたもので美校生を招かれたという。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は仁清という大天才をなんと解していられるのかは知らないのだが、仁清ほどの特異な実在を再び造り出さんと自負する大望の翁が、一美校生を招きそれに仁清ふうの絵付けを託し、もって目的を達せんとせられたのはなんとしても認識を具えた所業と受け取ることは出来なかった。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵付けにおいてもまたそれと同じ意味を繰り返し決して不可ないと考えられるのである。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　土で出来るんじゃない、釉で出来るんじゃない、学校程度の窯業知識で出来るんじゃない、絵描き程度の画では絵付けがものをいわない。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "模様は所謂上絵付けである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉靖年製小鉢はこの意味に於て（くどい絵付けにも係わらず）、存外肩の凝らない美しさを表現していると言い得られる。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の九谷はこれら赤絵付けの特色を十分に捕え得て、弥々妙境に進んだと見るべきである。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "染付は丁寧に造られ、絵もまた精密に描けているが、呉須の方は土の仕事からが粗造であって、絵付けもまた荒っぽい、良く言えば無造作に描かれている。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ、器体と言い、絵付けと言い、いかにも楽々と出来ていて、肩の凝るところがない。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うのは、絵付けの手法が鼠志野にとっては主要な特長の一つだからだ。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、ただ器体の意匠上の工夫だとか、絵付けの妙筆だとかが、陶器の仕事の殆ど総てであると言わねばならぬことを、その作品は物語っている。",
              "citation": {
                "source": "古器観道楽",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから局外者の眼には、一見、従来の日本蒔絵でもなし、絵付けする物はすべて真鍮材の金属だし、これが何に成ってどういう用途に向くのやら分らなかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙なことに、心に浮かんだ例えは、見事な焼き物がきれいに絵付けされているが、まだ窯の中で焼き締められていない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの要素を自分の柔らかい頭に植えつけてくれた重兵衛さんに、やはり相当の感謝を捧げなければならないように思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間の岳（赤石山脈）の支峰だと晃平のいう蝙蝠岳は、西の空に聳えて、朝起きの頭へ、ずしりと重石を圧えつける。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の奴に、発破を抑えつける奴を寄越せとそう云ってくんな。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらにゃ、ダイナマイトを抑えつけるてな、芸当は打てねえんだからってな。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "発破と度胸競べなんざ、真っ平だよ」　こんな訳であって、――どんな訳があろうとも、発破を抑えつけるなんて訳に行くものではない――岩鼻火薬製造所製の桜印ダイナマイト、大ダイ六本も詰め込んだ発破は、素晴らしい威力を発揮した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光の目に見えぬ力で地上のすべての活動をそっとおさえつけてあるように見える。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は見違えるほど体など肥って来たようだがね」　事実、柚木はもとよりいい体格の青年が、ふーっと膨れるように脂肪がついて、坊ちゃんらしくなり、茶色の瞳の眼の上瞼の腫れ具合や、顎が二重に括れて来たところに艶めいたいろさえつけていた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
