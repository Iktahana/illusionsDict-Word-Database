        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「昨夜、友達と絵チャで集まって、お題を出し合って絵を描いて遊んだんだ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このイラスト、絵チャのタイムラインで見かけたよ。すごく上手だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっとしたアイデアを共有するのに、絵チャって便利だよね。みんなでワイワイ描けるし。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「え、もう完成したの？早い！私も早く絵チャで描きたいな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてね、お姉えチャン美人ねえハイチャ、だって。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なアに、月賦さえチャンチャンと拂えば、丸善の方だって少しも損はしないのだからな。",
              "citation": {
                "source": "The Affair of Two Watches",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、診療所さえチャンとやって行けて、江東辺の人のためになることなら、俺あそのためなら、おふくろなざあ、すまんけど洗濯婆さんにでもなって働きに行って貰う。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
