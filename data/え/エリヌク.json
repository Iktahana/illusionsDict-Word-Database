          "standard": [
            {
              "text": "全国の農家から選り抜かれた最高級のリンゴだけが、この贅沢なジャムの原料として使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山積みの書類の中から、今回のプロジェクトに役立ちそうな有用なデータだけを慎重に選り抜く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厳しいオーディションを勝ち抜き、選り抜かれた新人俳優たちが舞台の上で眩い光を放っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それだから色々の類似したものを取寄せて植えて置くとその中で選り抜くということが出来る。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
