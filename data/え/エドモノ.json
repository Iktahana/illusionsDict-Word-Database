    "definitions": [
      {
        "index": 1,
        "gloss": "true Tokyoite",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は生粋の江戸っ子で、いかにも江戸者らしい気っ風の良さを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔ながらの銭湯に入ると、湯加減について粋な江戸者が談笑していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まあ、そういうことを気にするのは、いかにも江戸者だな」と友人は笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「武士は食わねど高楊枝」の心が、やがて江戸者の「宵越の銭を持たぬ」誇りとなり、更にまた「蹴ころ」「不見転」を卑しむ凛乎たる意気となったのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はみな江戸者で、江の島参詣とひと目に知れるような旅拵えをしていた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしのお開帳を当て込みに、自分が心棒になって休み茶屋をはじめ、近所の娘を手伝いに頼んでいるが、主人が江戸者で客あつかいに馴れているので、なかなか繁昌するという。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸者は詰まらない贅沢を云っていけませんよ」　こんなところから口がほぐれて、半七と鳥さしとは打ち解けて話し出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "紋作はその頃二十三、冠蔵は二十八で、どっちも同じ江戸者でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風ですから、田の草を取っている在所の娘さん達とは自然と肌合いも違いましょうし、その上に両方とも江戸者同士ですから、六三郎とも調子が合って、話もだんだんに面白くなって来たんですね。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかならぬ江戸で御評判の御殿様、同じ江戸者のよしみに御助け下さらばしあわせにござります。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "素直に退かばこの隠密とても江戸者じゃ。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その男というのは江戸者じゃございませんよ」と、六助は更に説明した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「江戸者でなけりやお杉は痛がらず」という川柳がある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから草加の在の方へ行って、ひと月ばかり隠れていたんですが、江戸者が麦飯を食っちゃあいられませんから、又こっそりと江戸へ帰って来て、お時から幾らかずつの小遣いを強請って、そこらをうろ付いているうちに、田町の重兵衛に眼をつけられて、お時と情交のあることも知れてしまったんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定まりの厄介兄貴だそうです」「お房の相手の鮎川というのは、どんな奴だ」「こりゃあ江戸者じゃあありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "関戸屋という女郎屋のうす暗い四畳半の座敷に、江戸者らしい若い旅びとが、行燈のまえに生っ白い腕をまくって、おこんという年増の妓に二の腕の血を洗ってもらっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり聞こえませんでしたが、その女も女房も次郎兵衛という名を云っていたように思います」「その女は、江戸者かえ、他国者かえ」と、半七は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが怖ければ浅草へたずねて来いと……」「その女は江戸者だな」「着物から口の利き方まで確かに下町の人で、なにか水商売でもしている人じゃあないかと思います。",
              "citation": {
                "source": "半七捕物帳",
                "author": "川越次郎兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしも気になって堪まりませんから、その様子を聞きながらここへ来て、占い者に見て貰いますと、おまえさんには死霊が祟っていると云われたので、いよいよぞっとしてしまいました」「宗兵衛は江戸者かえ」「いいえ、なんでも東海道の方に長くいたそうで、大井川の話なんぞをした事があります。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸者ではいけない、なんでも親許は江戸から五里七里は離れている者でなければいけない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "向島の寮",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでわたしはお侍さんに近より、「討ち損じたは貴郎様の未熟、それでさがし出して討とうとなされても、あてなしにおさがしなされては、なんではしっこい江戸者などを、さがし出すことができましょう」　と、ささやくように言ってやりました。",
              "citation": {
                "source": "怪しの者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸者らしい侍なんだよ」「江戸者らしい侍といえば、妾もそういうお侍さんへ、酒を飲ませて酔いつぶしてやったよ」「邪魔の奴はつぶしてしまうがいいなあ。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして世話役に向って言うことには、「わしゃあ江戸者だがね、上方見物の途中なんだがね、はからずこの地へ来て皆さんの芸術を見せていただきやしたが、正直感心いたしやした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房のお松は二十三四、いわゆる小股の切れ上った女、雑種ではない正味の江戸者、張があって愛嬌があってそうして頗る人使いが旨い、若衆と一緒に床を出て、自分から火を焚いて湯を沸す、下女を労わる情からである。",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗ってくらっせえよ」　という鼻から抜ける声とともに、間伸びした鈴の音が、立場茶屋の葦簾を通して耳にはいると、江戸者らしい若い小意気な旅人が、ひとり飲みかけた茶碗を置いて振り返った。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより山とは言うべくもないが、高いところなら猫の額でも山という名をつけたがるのが万事に大袈裟な江戸者の癖で、御他聞に洩れず半ば塵埃捨場のこの小丘も、どうやら見ようによってはそうも見えるというので、一般には木槌山として通っていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一度家搜しをしようか、平次殿」　大垣伊右衞門は江戸者らしい氣さくな調子で平次を顧みます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "城の繪圖面",
                "note": "青空文庫"
              }
            },
            {
              "text": "番頭さんは江戸者だが、店中の者は皆んな同じ村の生れですよ」「さうか」　さう聽けば、力があつて、少しは武術の心得のある百姓の伜力松が、並の雇人の三倍の給料で、用心棒に雇はれても何んの不思議もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蜘蛛の巣",
                "note": "青空文庫"
              }
            },
            {
              "text": "――赤門寺のお上人は、よく店へお立寄り下さいますが、てまえどもの方の事にも、それはお悉しゅうございましてな。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "てまえどもの店で商った品かどうかはわかりませんが、たしかにこれは古島雛のまがい雛ですね」　ちらりと一瞥するや同時に、なんらのためらいもなく番頭が、一言に古島雛のまがいとホシをさしたものでしたから、当然のごとく名人のことばがさえました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いや、これでもうてまえどもの役目は終わりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念ながら、ひとりもないわい」「といたしますと、てまえどものほうでころあいの者をお見立ていたしまするが、よろしゅうござりまするか」「よいとも、よいとも。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、茶を運んで来た番頭に向い、主人の大蔵の容貌や年配を訊いてみると、「はいはい、道中でお会いなされましても、てまえどもの御主人なら、一目でお分りになるに違いございません。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
