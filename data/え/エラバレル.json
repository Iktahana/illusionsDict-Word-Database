[
  {
    "uuid": "7674b06e-3fd1-5158-8a72-dadd3633e688",
    "entry": "選ばれる",
    "reading": {
      "primary": "えらばれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be elected",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "次の市長選挙では、現職の候補者が僅差で選ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、学生会副会長に選ばれることを強く望んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "多くの応募者の中から、最終選考に残る数名が選ばれることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "此頃少し身體の工合が惡いので二三日保養のために何處か温泉にでも出掛けようといふ、その目的地に此の因縁つきの伊香保が選ばれることになつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋのをぢさんも不運に生れた一人で、こんな相談相手に選ばれるには屈竟の人間であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一等三角点にはみんな高い山の頂上が選ばれる。",
              "citation": {
                "source": "地図をながめて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし映画では第一その舞台が室内にでも戸外にでも海上にでも砂漠にでも自由に選ばれる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのテーマを表現すべき「言葉」として花と瓶とが選ばれる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく一人の娘の見送手などに選ばれるというのはブルジョア風の名誉にすぎない。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからかかる犠牲を払うからには、俺がともちゃんのハズとして選ばれるくらいのことが必要になるんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにすでに私には選ばれる資格があるのだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然自分の異母弟の一人が選ばれるものと考えていたは、一寸妙な気がした。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に又、近く來るべき戰爭に當然戰場として選ばれるだらうことを豫想しての冒險への期待だつたのではないか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "當然自分の異母弟の一人が選ばれるものと考へてゐたは、一寸妙な氣がした。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にまた、近く来るべき戦争に当然戦場として選ばれるだろうことを予想しての冒険への期待だったのではないか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "中大兄皇子は、後に第三十八代｜天智天皇とならせ給うたが、新政のために、新らしき都を選ばれる意味で、近江の志賀に都し給うた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに多くの人が順番を待って並んでいるのを見ると、もう選ばれるわけがないとあきらめていたのですが、スポールディングが聞き入れないので同じように並んでいました。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、現実世界に青空文庫が存在するなら後者が当然選ばれるだろうけれど、電脳空間というまったく新しい環境に作られた図書館であるなら、ファイル末に作業者の名前を残すというそれだけを求めて、〈「愛と崇高さ」に応える無償の行為が、巨大な知識と文化の宝庫を立派に維持できることを証明してほしいと思うのです。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋのおじさんも不運に生まれた一人で、こんな相談相手に選ばれるには屈竟の人間であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分には明治二十七年になったら、夏期学校の講師に選ばれるという考えは、その時分にはチットもなかったのです（満場大笑）。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで七匹の獣閣下は辞任して、新らたに七匹が選ばれた、然しこれまで森では自分の身を飾つたり、自分の腹を肥やすことにばかり熱中してゐるといふ、身勝手な獣ばかりが選ばれるので、森の獣達が今度選ばれた七匹も信用しなくなつてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の天才が選ばれるためには、多くの無名の芸術家が、その足下に埋草となっているのだ。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、国々から選ばれる力士も、その国で無双の強者だったのである。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「世の中には幸福な奴もゐるものぢや、彼女に選ばれる男とは一体今頃何処に生きてゐる奴だツ！",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は丁度尾谷川に臨んだ一帯の平地にあつて、樫の疎らな並樹がぐるりと其の周囲を囲んで居る奥に、一｜棟の母屋、土蔵、物置と、普請も尋常よりは堅く出来て居て、村に何か事のある時には、その祖父といふ人は必ず総代か世話人に選ばれるといふ程の名望家であつた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな理由から白色のものが選ばれることになつたか、それは知らないが、深山に隠れて静かに思惟の生活に浸つてゐるものにとつては、見馴れぬものを咎める狗の叫びと、夜明を告げる※の声とは、めつたに欠くことのできないものだつたかも知れなかつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説の題材として、最も多く犯罪が選ばれるのは、人々が犯罪に最も多くの興味を感ずるからであろう。",
              "citation": {
                "source": "「心理試験」序",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合もしそれが無かったならばこの結果は起きなかったであろうと思われるものが選ばれるのである。",
              "citation": {
                "source": "カントと現代の科学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、顔の正面から日光に照りつけられては、半丁も楽に歩けないので、時に応じて日かげの側が選ばれるのであった。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と女とのつき合いはまだまだ特殊な目で見られているのだから、どうしても、一方には責任を負わないことをそのたのしさとして求めている両性の遊びがあり、まともな結婚の対象ということになると、それらの友達の間からではなく、もっと保守な面から選ばれるという奇妙な現象が近来増して来ているように思える。",
              "citation": {
                "source": "異性の友情",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、この事務所の書記の数はいつもただ四人ときまつてゐましたから、その沢山の中で一番字がうまく詩の読めるものが、一人やつとえらばれるだけでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、近いうちには、かけっこの審判官のひとりにも、えらばれることになっている。",
              "citation": {
                "source": "かけっこ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "會議の議長にえらばれることは勿論、今日の會議の主要目的である秋の縣會の選擧に組合側として誰を候補にあげるかといふことも、彼にあつてはすでに自明の事だつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
