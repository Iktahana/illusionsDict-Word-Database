[
  {
    "uuid": "ac061a4f-38cd-56a9-ba40-b86206c2b702",
    "entry": "演奏者",
    "reading": {
      "primary": "えんそうしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
