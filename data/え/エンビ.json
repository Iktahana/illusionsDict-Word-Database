[
  {
    "uuid": "90635de9-03d2-5ccf-8da5-9594b4ec4b46",
    "entry": "艶美",
    "reading": {
      "primary": "えんび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sensuously beautiful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台に現れた踊り子の、指先まで神経の行き届いた艶美な身のこなしに、観客は思わず息を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れ時の紫に染まる空の下、ライトアップされた夜桜がこの世のものとは思えないほど艶美に浮かび上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女が纏うシルクのドレスは、その深い赤色と相まって、大人の女性特有の艶美な魅力を引き立てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼女がこれ程に深刻な魅惑力を発揮し得ようとは今までに一度も想像し得なかった程で、私は思わず心の中で……妖女……妖女……浴室の中の妖女……と叫んだほどに、烈しい熱情と、めまぐるしい艶美さとをあらわしつつ私の眼の前に蔽いかかって来たのであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生艶美な童女で暮した女だ」　友人はこれを聴いて、君助は孤独の寂しさから、少女｜病にかかつて、どの女も処女だと思ひ込むのだといつたが、君助はそれでもいゝ、結局男の望む理想の女はさうした女なのだと言ひ放つた。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨後の暁に見出すその艶美で無垢で而かも知性的なしどけなさ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇なるかな一は侠勇を尊び、一は艶美を尚びて、各自特異の旗幟を樹てたるや。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "その始めは、共に至粋の宿れるなり、啻だ一は之を侠勇に形成し、一は之を艶美（所謂粋）に形成したるの別あるのみ。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドまた香具売り兼｜幻師軽業師で歌舞乞食し行き、その妻女艶美でしばしば貴人に御目留まる賤民乾闥婆と呼ばるるあり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "華やかな艶美な微笑だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の艶美な微笑も蜜のような言葉も、今は空の空なることを知った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "縮緬の桔梗の模様の浴衣が、そのスッキリとした身体の輪廓を、艶美に描き出していた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "華やかな艶美な微笑だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の艶美な微笑も蜜のやうな言葉も、今は空の空なることを知つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "縮緬の桔梗の模様の浴衣が、そのスツキリとした身体の輪廓を、艶美に描き出してゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　錦絵のもつあの艶美な夢心地のような韻致――と申しますか、匂いと言いますか、人の魂に滲みこんでくるあの柔かな迫力は、どうも肉筆には見られないのでした。",
              "citation": {
                "source": "浮世絵画家の肉筆",
                "author": "――花は霞を透してひとしおの風情があるもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どの作のどの女を見ても、幽艶、温雅、誠実、艶美、貞淑の化身であり、所有者でありながら、そのいずれにも何かしら作者の持っていたものを隠している。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の顔かたちが豊艶なように、その肉声も艶美だ。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "又｜平常でも艶美を増す為めに是を用ゐる婦人も少なくはない。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに黒と白とのコントラストを利用して全身にその艶美を増す為めの一つの化粧法なのである。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原・奈良、及び平安の初期に亘つて行はれた仙人の内容は、艶美であつて、人間の男との邂逅を待つて居る仙女なども這入つて居たのである。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲルマンいかに仏国を仇とするも、仏国の流麗艶美の文学はこれを賞してその書籍を輸入せざることあたわざるべし。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にその咲いている花に対せば淡粧美人のごとく、実にその艶美を感得せねば措かない的のものである。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金の雨のような陽の光の中に、そういう彼女の立っている姿は、艶美というよりも妖艶であった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに先刻｜図らずも鼻子の訪問を受けて、余所ながらその談話を拝聴し、その令嬢の艶美を想像し、またその富貴、権勢を思い浮べて見ると、猫ながら安閑として椽側に寝転んでいられなくなった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の、破損はひどいが稀有に美しい木彫の観音があって、ヴィナスの艶美にも似た印象をわれわれに与える。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてただギリシア的な偉大性と艶美とのみを取りいれた。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが地獄の劫火に焚かるべき罪であろうとも、彼はその艶美な肌の魅力を斥けることができない。",
              "citation": {
                "source": "『偶像再興』序言",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査が出て行くと入れ違いに、花が保名狂乱といったような、艶美に取乱したようすで入って来ると、いきなり真名古の傍へ駆け寄って、「真名古さん真名古さん、帝国ホテルに偽の王様がいます。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "『無慙の汝、姿のみ艶美、好色の詐欺の子よ、汝此世に生れずは、或は女性に逢はずして　40逝かば却つて優ならむ、汝のために斯く願ふ、衆の目の前、冷笑と侮蔑の的にならんより。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "艶美のアレクサンドロス其時答へて彼に曰ふ――『汝の苛責皆正し、あゝヘクトール皆正し、汝の心あゝ強し、船造るべく巧妙に　60巨木つんざく人の手の揮へる手斧――揮るごとに、力いよいよ優り來る斧の如くにあゝ強し。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』垂絹長く面を掩ふ艶美の女性答へ曰ふ、『彼アイアース、すぐれたるアカイヤ軍の堅き城、こなたは英武イドメネー、＊クレーテースの衆中に　230神の如くに立ち上り、諸將士彼を取り圍む。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて地主は、えんび服をきて、シルクハットをかぶって、かた手に竹のむちを持ち、銅像の台の上にあらわれました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
