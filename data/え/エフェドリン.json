        "examples": {
          "standard": [
            {
              "text": "鼻詰まりがひどいため、医師からエフェドリンを含む点鼻薬が処方された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エフェドリンは、気管支拡張作用があるため、喘息の治療に用いられることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "注意：エフェドリンは興奮作用があるため、摂取には医師の指示が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "朝になつて未だ不安なので、エフェドリン八錠服用。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、エフェドリンに似た成分の薬だということを教えられた。",
              "citation": {
                "source": "反スタイルの記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「治療としてはアドレナリンの皮下注射、エフェドリンの内服ぐらいなもんですな」「パビナールは？",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アドレナリンとかエフェドリンなんか、あまり効かないんですよ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻がつまり弱ってると、上森がエフェドリンといふ薬を飲めばすぐ治ると言ふので取り寄せて飲む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
