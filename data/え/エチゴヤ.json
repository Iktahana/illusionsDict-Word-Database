    "definitions": [
      {
        "index": 1,
        "gloss": "Echigoya",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「このお菓子は、昔ながらの製法で作られた越後屋の銘菓だよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この辺りには、歴史のある商家「越後屋」の建物がいくつか残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この着物の柄、どことなく越後屋の屋号を思わせるね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ついでに駿河町の越後屋（そのころの三井呉服店、今の三越）をいおう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駿河町」の絵を見ると、正面に大きな富士がそびえて、前景の両側には丸に井桁に三の字を染め出した越後屋ののれんが紫色に刷られてある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝口の細君は娘を連れて、幾たびか大丸や越後屋へも足を運んだ。",
              "citation": {
                "source": "有喜世新聞の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "有り合わせのものの中からできるだけ地味な一そろいを選んでそれを着ると葉子はすぐ越後屋に車を走らせた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼すぎまで葉子は越後屋にいて注文や買い物に時を過ごした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後屋を出る時には、感興と興奮とに自分を傷めちぎった芸術家のようにへとへとに疲れきっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後屋というのが一軒、丸屋というのが一軒。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな気をつけろ」　つりさげた着物へぺったりと張りつけておいて、さっさと引き揚げていくと、すぐその足でやっていったところは軒並びのもう一軒の越後屋でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "獲物は越後屋の網と決まった。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いってみな」　その越後屋へはいると同時に、騒がしいわめき声ががやがやとまず耳を打ちました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二人連れは大塚仲町の越後屋という米屋の女房と小僧で、かの野上の屋敷の門前を通り過ぎようとする時に、暗闇のなかから一羽の蝶が飛び出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "島屋の若旦那、荒町の亀惣様、本町の藤勘様、越後屋の御総領、三浦屋の御次男、いずれも羽織｜袴の御立派な御様子で御通りになりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "島屋の若旦那、荒町の亀惣様、本町の藤勘様、越後屋の御総領、三浦屋の御次男、いずれも羽織袴の御立派な御様子で御通りになりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日病院大工棟梁越後屋新兵衛へ転陣。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "柴田絨店、米田洋服店、明治屋、海老屋、越後屋、近常、みな昔のままのところに栄えているのは喜ばしい。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後屋の店が近頃陳列風になったのは少し安っぽい。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へえ、私は深川の六間堀で、これでも越後屋重吉と云ふ小間物｜渡世でござりやす。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "時刻も彼是七つ下りぢやあるし、この雪空を見上げちや、川千鳥の声も身に滲みるやうで、今夜はどうでも日野泊りと、出かけ無けりやなら無え所だが、いくら懐は寒むさうでも、其処は越後屋重吉と云ふ道づれのある御かげ様だ。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその越後屋重吉と云ふ野郎が、先に立つて雪を踏みながら、「旦那え、今夜はどうか御一しよに願ひたうござりやす。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから早速｜草鞋を脱ぎの、行燈を下げた婢と一しよに、二階座敷へせり上つたが、まづ一風呂暖まつて、何はともあれ寒さ凌ぎと、熱燗で二三杯きめ出すと、その越後屋重吉と云ふ野郎が、始末に了へ無え機嫌上戸での、唯でせえ口のまめなやつが、大方｜饒舌る事ぢや無え。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは妙だと思つての、両掛の行李を下げた儘、梯子口から下を覗いて見ると、広い土間のまん中にや、あの越後屋重吉と云ふ木念人が、繩尻は柱に括られながら、大あぐらをかいてゐやがる。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かう皆がなぶり物にすると、あの越後屋重吉め、ちつとの間は口惜しさうに眼ばかりぱちつかせてゐやがつたが、やがて宿の若え者が、火吹竹を顋の下へやつて、ぐいと面を擡げさせると、急に巻き舌になりやがつて、「やい、やい、やい、こいつらは飛んだ奴ぢやねえかえ。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その見すぼらしい容子を見ると、おれは今更のやうにあの野郎が可哀さうにもなつて来たから、「おい、越後屋さん。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は旦那に申し上げた通り、越後屋重吉と云ふ小間物渡世で、年にきつと一二度はこの街道を上下しやすから、善かれ悪しかれいろいろな噂を知つて居りやすので、つい口から出まかせに、何でも彼でもぼんぽんと――」「おい、おい、御前は今胡麻の蠅だと云つたぢや無えか。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀さうに越後屋重吉は、あんなに横つ面を脹らした上へ、頭まで瘤だらけになりやがつた。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから比べると、あの三越の前身の越後屋の角店は大したものだった。",
              "citation": {
                "source": "日本橋附近",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは越後屋ばかりではない、あの本町通を浅草橋の方へ行く路の角には、それよりももっと大きいあの大丸の店があって、そこでも、そのオウイ、オウイをやっていたのである。",
              "citation": {
                "source": "日本橋附近",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小大丸は、銀座の越後屋と同じ道を踏むのでは無いかしら？",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
