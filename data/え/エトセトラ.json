        "examples": {
          "standard": [
            {
              "text": "「週末は部屋の掃除に洗濯、溜まった録画の消化エトセトラで、あっという間に夜だよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "披露宴の準備は、招待状の発送から引き出物の選定エトセトラ、想像以上に手間がかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼のカバンの中からは、ノートや筆記用具、謎の試供品、エトセトラが次から次へと出てきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "見物人の読者はそれを見て各自の中に居る「坊ちゃん」「赤シャツ」エトセトラを共鳴させる。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈折率、くらかけの雪、丘の幻惑、カーバイト倉庫、コバルト山地、霧とマッチ、電線工夫、マサニエロ、栗鼠と色鉛筆、オホーツク挽歌、風景とオルゴール、第四梯形、鎔岩流、冬と銀河鉄道――エトセトラ。",
              "citation": {
                "source": "惰眠洞妄語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "耶蘇は小便をしても手を洗わなかったり、酒を呑んだり、淫売と交際したり、漁師と友達だったりしたということであるが、僕も実に交遊天下にあまねく、虫の好く人間なら、その境遇と職業と主義と、人格と才能と美醜と、賢愚と貧富とエトセトラの如何を論ぜず、友達になる。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴は穿かず、古下駄も踵の方が台まで摺りへっているのを捜して穿く事、煙草は必バットに限る事、エトセトラエトセトラである。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
