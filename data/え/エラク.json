        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「昨日の会議、偉く長引いたね。もうクタクタだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この辺りは、昔は偉く静かだったらしいよ。今は随分変わったけど。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「今日の試合、うちのチーム、偉く奮闘したと思う！惜しかったけどね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「いやー、今日の仕事は偉く大変だったわ。もうヘトヘト。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「あんな奴が、段々偉くなりやがる」、ハテ面妖なとＡの方で思ふのだが、Ｂとしたら、変な話ぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　うそだわ、偉くなるわ、ほんとに偉くなるから、あたしちやあんと知つてゝよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの娘は、あまり偉くなりすぎたよ」　口惜しさと悔いがぎざぎざと胸を噛んだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉くなることなんて。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、男があんまり細かいことに気のつくのは偉くなれない性分じゃないのかい」「僕だって、根からこんな性分でもなさそうだが、自然と慣らされてしまったのだね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○偉くなろうなぞとはちっとも思わない。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、無理をして勉強せよとも、是非偉くなれとも私たちは決して言わなかった。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "へんな言いかたであるが、私は、サタンほど偉くはない。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだね、もう二三年がところ留守にしてもいいずら』『げえもねえことを……象山先生より偉くなったらどうする気だ』俺の方では佐久間象山より偉い人間は出てこようがないとしてあるんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前は偉くなろうとそんなことばかり思っているから肺病に取りつかれるんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青島さんは花田さんといっしょに会をやって、きっと偉くなるわ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、男があんまり細かいことに気のつくのは偉くなれない性分じゃないのかい」「僕だって、根からこんな性分でもなさ相だが、自然と慣らされてしまったのだね。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むぐら、むぐら、むぐらもち、お前は僕の偉くなったことを知ってるかい」　むぐらが土の中で言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は生れて来る子供のためにもあの人に偉くなって貰わねばと思い、以前よりまして声をはげまして、あの人にそう言うようになったが、あの人はちっとも偉くならない。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一事が万事、なるほど昇給に取り残されるのも無理はないと悲しくわかり、その旨あの人にきつく言うと、あの人は、そんなことまでいちいち気をつけて偉くならんといかんのか、といつにない怖い顔をして私をにらみつけた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉くなる必要もないから、幸福にお暮らしなさい。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも偉くなりません。",
              "citation": {
                "source": "「晩年」に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉くなる坊主は違ふなあ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「偉くなる坊主はァ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたはそんなことを、冗談でいふんでせうが、実はわたしはほんたうに偉くなりたいのです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兄弟子はクスリと笑つて、「そりあ偉くなるさ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたは皮肉のつもりで仰有るんでせうが、わたしはほんたうに偉くなりたいのです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「本当にわたしは偉くなりたいのです。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だからさ、お前は偉くなるよ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "生臭坊主でも偉くなれないことはないぜ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはその後何時どうしたものか失くなつたが、忠魂塔の周囲の棚が鉛で出来てゐて、それを私や私の弟は、えらく骨折つて抜取つたりしたこともあつたものだ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れだけでも日本がえらくなつたには相違ない。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両人は息子がえらくなるのがたのしみだった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年在学を延期するのも、息子がそれだけえらくなるのだと思うと、慰められないこともなかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、息子が今にえらくなるのをあてにして待っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
