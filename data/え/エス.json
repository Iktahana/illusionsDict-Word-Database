        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私の名前のイニシャルは「Ｓ」なので、このキーホルダーはぴったりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "解答用紙の「Ｓ」の欄に、正しい記号を記入してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のサインは、流れるような美しい「Ｓ」で始まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はＳ子の後から昇降口の方へ歩み寄つた、――ピヨツとＳ子は運転台の方へ走つて行つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分がＳ子に接近したことをＳ子が感じてとび逃げたものだと直ぐ次の瞬間に感じた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ子は運転台の近くに、彼は車掌台の近くに、離れて腰掛けてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君も知つてるだらうが、Ｓ子はデカタンのやうでピューリタニックなところを持つた女だし、それにあんな処で遊廓町で歌ふやうな歌を歌つちやあ困るぢやないか。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は今擲ぐらうか今擲ぐらうかと思つて拳固まで固めてゐたんだけれど、罰するのは神様の務めで人間のすることぢやないと思つたからギユーギユーいつて我慢したんだつたが……」　停留場に来るまでにＳ子の従兄に当る男が彼にこんなことを言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一君の人格が……それが分らない程君も馬鹿ぢやあるまい……」　Ｓ子の従兄は可なり昂奮してるらしかつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつて此の人は行き方がちがふんぢやないの」　Ｓ子が従兄に言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だと、……Ｓ子今何か言つたな……おまへは此の男に、妙な所で肩を持つ……」「そんなに怒らせるやうなことを言やあしないわ……」「ふん、よし……そんなら好いがな……」　従兄はＳ子の方に不満を向けた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本気な従兄の怒りを恐れる気持をゴマカすやうに、Ｓ子は雪駄の音をペツタペツタさせて、オドケてみた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その時に従兄はＳ子に何か言つたな……俺に関連させて……」　彼は電車にゆられながらさうも思つたが、決してそれは信じられなかつた、さうらしいといふことは全く不明だといふよりも不安なことであつた、のである。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「御大事になさい……」　まるで遠くへ行く人への別辞だ、――Ｓ子はさういふなり下向いた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーブの上の薬鑵の湯気をみ入つてゐる時、「電車の救助網にでもかゝつて、今怪我をして病院にゆくとすれば、Ｓ子が見舞に来るんだ……」つてな夢みたいなものを鼻の上で小踊りさせた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手に抱へられて、店屋の軒にやられた時、彼は「Ｓ子が来てやあしないか……？",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はＳ子の様子伺ひに出掛けて行つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕昨日は一寸変な気になつてゐましたから随分なことを言つたでせうが、まあ……」　道でＳ子の従兄に遇つたので、彼はさういつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは好いが君、君その指の繃帯は如何した」「一寸ナイフで切りましたから……」「Ｓ子は今内にゐませんから夕方いらつしやい……」　さう言つて二人は別れたが、彼にはその従兄の言葉が何時までも問題になつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつてね、太つたくせに顔の陰が尖るつて質の女は一度ツンとすると其の後はもう理由もなしにツンとし通すものだから……」「こいつ大した苦労性だな、気の小さい……」　夕方行くとＳ子は最も他人行儀を示した。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ活動にでも御案内しませうよ」　さういつてＳ子は彼を連れて活動に行つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、やかましいぞツ」　フイルムをみながらキヤツキヤツ笑つたり喋舌つたりする二三人連の女が二人の傍にゐた、彼は半分Ｓ子の機嫌をとるやうにその女達に怒鳴つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラ、来週はメーベルノーマンドの写真なのね、あたし今度は一人で来るわ」　予告のビラが横手の壁にあつたのをみて、Ｓ子はさういつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来週の何曜日に来るのです」「アハヽヽヽヽヽヽ」「あゝあたし彼方から廻る電車に乗りたかつたのに……」　彼が行かうとした停留場の間際まで来てＳ子はジラ半分にさう言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう「御大事になさい……」といふ挨拶をされた晩から、三週間ばかりも経つてゐるが、そして指のキズは従兄のためにはもはやトツクに癒つて好い頃だが、いまだにＳ子の所に行く時、彼は繃帯をして行く……。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の方へ「シャスタ」が、白い炎を爛々と光らして、汽車の窓から、大抵は右に見えるが、「左富士」のように、左に見えることもある、それほど川は、Ｓ字の環を繋ぎ合っている。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、同志のＳやＩなどが、「あつさりやめた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓは、私たちのグループの中で、文学的にもであるが、生活的に、全身的に、階級闘争に、もつともピッタリくつついてゐる男である。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　私は、文学の上では、兎も角、運動の上では、他の人たちを捨てても、Ｓたちと行動を共にしなければならないと思つた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "空家に籠つてこの一念（中）　Ｓや、Ｎを、文学的ルンペンなどと、たつた一ヶ月前まで位、一緒にやつて来た者で、ぬけ／＼といふ奴もあるが、そんなのは、いつでも、私が、面の皮をヒン剥いてやる。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の出した本にどんな本があるかも知らないが、リヴィエールのランボオ論とモオリヤックのイエス伝――結局彼の死の前年に出した此の二つの翻訳書だけが私の頭に残つてゐる。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレエスは百米競争では、なかったのだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百米、二百米の短距離レエスでは、もう、この選手、全然見込みがない。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
