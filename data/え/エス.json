        "examples": {
          "standard": [
            {
              "text": "コンパスを見ると、「Ｓ」が南を指しているのがわかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "地図の読み方では、「Ｓ」はSouth（南）の略です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この道はまっすぐ「Ｓ」の方向へ進むと、駅にたどり着くはずだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
