        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遠くの山々が煙霧に霞んで見えなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今朝は強い煙霧が発生し、視界が悪かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "工場地帯から立ち上る煙霧が空を覆っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "煙霧こそ距つれ、その山は地平の群山を圧して、白く美しく秀でていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿橋あたりへ来ると、窓から見える山は雨が降っているらしく、模糊として煙霧に裹まれていたが、次第にそれが深くなって冷気が肌に迫って来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "はうはうぼうぼうとした煙霧の中をあるひとの運命は白くさまよふ。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロノメートルの価は僅なものであるが、煙霧の中で船の位置を測定する事が不確実になつては、一大事を惹き起さぬとも限らぬ。",
              "citation": {
                "source": "些細なやうで重大な事",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙霧は模糊として、島の向うの合流点の明るく広い水面を去来し、濡れに濡れた高瀬舟は墨絵の中の蓑と笠との舟人に操られてすべって行く。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙霧は模糊として、島の向うの合流点の明るく広い水面を去来し、濡れに濡れた高瀬舟は墨絵の中の蓑と笠との舟人に操られて滑つて行く。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるかな地上には煙霧が匐い、夕陽はどんよりと光を失い、貯水池と川とだけが、硝子のように光っていた。",
              "citation": {
                "source": "三重宙返りの記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の中では濃い煙霧が渦巻き、開け放された窓からもあふれ出る勢いだ。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の旅その又旅の秋の風　国府津小田原は一生懸命にかけぬけてはや箱根路へかかれば何となく行脚の心の中うれしく秋の短き日は全く暮れながら谷川の音、耳を洗うて煙霧模糊の間に白露光あり。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑蔭　芝生に日光がそそいで、近くはかげろうに燃え、遠くは煙霧にかすみ、人はみどりに酔い、靴は炎熱に汗ばみ、花は蒼穹を呼吸し、自動車は薫風をつんざいて走り、自動車に犬が吠え、犬は白衣の佳人がパラソルを傾けて叱り、そのぱらそるに――やっぱり日光がそそぐ。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹海のはての遠いかなたに、ゆらゆら煙霧のようなものが揺ぎあがっているのがみえる。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほうれ、煙が鳴るだよ」　気のせいか、その煙霧がブウンと鳴っているような気がする。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、煙霧のかなたからごうごうと轟いてくるのが、「太平洋漏水孔」の渦芯の哮りか……。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「陸です、たしかに」「君の眼はどうかしてるよ」「いや、ドノバン、霧が風に吹かれてすこしうすくなったとき、みよしのすこし左のほうをごらんなさい」　このとき煙霧は風につれて、しだいしだいに動きだした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、煙霧の尾が海をはなるる切れ目の一せつなに、東の光をうけてこうごうしくかがやける水平線上の陸影！",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ところどころ煙霧の稀薄になつたところに、まるで無數の金粉を播き散らしたやうな夕映えが水蒸氣となつて煙り、日の射さない處は凝乎と不動の姿勢でゐるかと思はれるやうな雲霧もその實非常な急速力で盛に渦卷きつつ奔騰をつづけてゐるのであることが分る。",
              "citation": {
                "source": "箱根の山々",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、飛行機のすがたも、煙霧のなかにとけてしまって、やがて見えなくなった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、煙霧がなければ白根山の峰つづきが見ゆるあたりに、竜之助はいつまでか立ち尽しているが、風はそよとも吹かず、ただ高原の夜気が水のように流れているだけです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いこと煙霧に隠れて見えなかった遠い山々まで、桔梗色に顕われた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて遥か彼方、煙霧めいた層雲の上に、高い真白な峻峰が二つ並んで、その姿を現わしてくる。",
              "citation": {
                "source": "アラスカ通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りきった夕ぐれの色が煙霧のようにただよって、そこここの油障子から黄色な光線の筋が往来に倒れている。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷のふちの向方には地下の墓所から蒸発しているのか、もやもや立ち昇る煙霧の中へ青ざめた虧けた三日月が射し入っておりました。",
              "citation": {
                "source": "墓場",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "北国の風の無い朝に特有な薄い煙霧が、地平線近いところに静かにたなびいている。",
              "citation": {
                "source": "日食記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その煙霧を通して見える太陽は、真赤な月のように大きい。",
              "citation": {
                "source": "日食記",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙を流し陳ずるを千仭深き波の底、＊老いたる父の海神のかたへに神母きゝとりつ、銀波忽ちかきわけて煙霧の如く浮び出で、潜然として涙なる愛兒の前に向ひ坐し、　360玉手に彼をかい撫でて即ち彼に向ふて曰ふ、『愛兒なに故悲むや、何故心痛むるや？",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなく紫色をした空気がただよっていて、町の煙霧もそれを吹き消すことが出来ないような、遠い郊外の匂いが窓から吹いて来た。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "鏡中の美女",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
