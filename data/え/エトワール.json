        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "バレエ団のエトワールとして、彼女は輝きを放っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夜空に輝くエトワールは、旅人の道しるべとなるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今日の主役は、まさにこの新進気鋭の若手俳優、まさにエトワールだね！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私達は、エトワールと云うホテルに入った。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、私たちは、ポオの引用したエトワール紙（事実ではニューヨーク・ブラザー・ジョネーザン紙）の「死体はマリーに非ず」という議論は、恐らく、ポオが議論するために仮に設けたのではあるまいかと疑って見たくなる訳である。",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "エトワールから下る散歩道は、日曜のこととて、流行の春着の流れ下って来る河だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "エトワールで私たちは地上に出ると、もう夕闇が下りてゐて、急に灯の少くなつた市街はいやに陰慘な感じだつた。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行、大使館、市街、トロカデロ、エツフエル塔、エトワール、ルウヴル、パンテオン、アンヴァリード、リユクサンブール、クルニエ博物館、オペラ、地下鉄道（メトロ）等。",
              "citation": {
                "source": "つゆじも",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘だと思ったら、今夜十一時、銀座のキャバレー、エトワールへ来たれ。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座随一の豪華版、キャバレー・エトワールは日頃に増してお客が立てこんでいた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官隊はキャバレー・エトワールの屋外と屋内、それから痣蟹の逃げこんだ隠れ柱との三方に分れて、懸命の大捜査を始めたのだった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "消えた屍体　何のためか十日間あまり、事務所を留守にしていた青竜王は、キャバレー・エトワール事件の次の日の昼ごろ、ブラリと探偵事務所に姿を現わしたのだった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一今日はキャバレー・エトワールの事件で、青竜王のところのチンピラ小僧にうまうませしめられて、面白くないです」　といっているところへ、給仕が入ってきて、雁金検事に電話が来ていると伝えた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今日｜昼すこし前、例の事件について調べることがあって迎えのために警官をキャバレー・エトワールへ振出してみると、雇人は揃っているが、主人のオトー・ポントスが行方不明であるという。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一に、生死のほども確かでないキャバレー・エトワールの主人オトー・ポントスを探しだすこと。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真夜中、時計が丁度十二時をうつと間もなく、今は営業をやめて住む人もなく化物屋敷のようになってしまったキャバレー・エトワールの地下室の方角にギーイと、堅い物の軋るような物音が聞えた。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "エトワールの表と裏とには、制服の警官が張りこんでいるのだったけれど、この地底の小さい怪音は、彼等の耳に達するには余りに微かであった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐキャバレー・エトワールの地下に入ってパチノ墓地を検分したまえ。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "エトワールの張番がどうしたというのだろう。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座のキャバレー・エトワールへ。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはりキャバレー・エトワールの中でした。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十五日（金曜）　パリ、英米軍の包囲下にあって、全市で激戦中、エトワール、モンパルナス、サンラザール等。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里、エトワールのエハガキ。",
              "citation": {
                "source": "中條精一郎の「家信抄」まえがきおよび註",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからＢ・Ｒ、ＡＩ、ボントン、エトワール、マキシム、リドーと、この六軒でウイスキー・ソーダを一杯ずつ飲んで、それから鶴の所へ行くことにしましょう。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　蜂谷良作とつれだって、伸子はその日のうちにエトワール附近にある貸室をみに行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも空席が見つけにくいほど立てこんでいて、腕にナプキンをかけたギャルソンが軽快に陽気にその間をとびまわっていたオペラの角のカフェー・ド・ラ・ペイにしろ、ずっとはなれてエトワールに近いクポールにしろ、往来を眺めて椅子にかけているような人は、ほんの数えるしかなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子は、シャンゼリゼーとエトワールの角に立って、しばしばそのリズムに見とれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エトワールのこの光景は、グラン・ブルールの外国人たちに、あらわな戦争の惨禍を見せつけることはしない。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンシャンの競馬場をふくむブーローニュの森に通じる公園通りは、パリでよりぬきの金もちの邸宅を街すじの左右に構えさせながら、このエトワールからはじまっているのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話、エトワール２９５７――６１。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑郎はこの間初めて手紙をよこして、パリのエトワールの近くの或一寸した作家の未亡人の家に暮すようになり、フランス語がまだよくこなせないから御飯のたびに大汗の由です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "エトワール、コンコード、よく散歩したリュクサンブルグ公園、オペラやマデレーヌ寺院のある大ヴルヴァールが、激戦の巷となって居る由です、わたしのいたホテルから近いモンパルナッスも。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エトワールには、ときどきいくのよ」　その高校の生徒たちがもっとも多く利用する私鉄駅の近くに、商店街があった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
