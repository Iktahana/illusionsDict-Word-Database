        "examples": {
          "standard": [
            {
              "text": "この棚はＬ字型になっているから、部屋の角にぴったり収まるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Ｌ字型のカウンター席は、一人でも気軽に利用しやすいんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Ｌ字型に曲がるこの道は、初めて来ると迷いやすいから注意してね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "庭の端に、Ｌ字型に配置された石畳の小道を作ったんだ。なかなか良い感じ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お、このＬ字型に配置された観葉植物、おしゃれだね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｌ字型をした二つの病棟の有様も、彼にはもう慣れてゐた。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソファはＬ字型で、その内側にガラス・トップの低い楕円形のテーブルがあり、映写機はその上に載せてあった。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "家はＬ字型をしていた。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｌ字型になったカウンターの、その角のところに、ぼくの父親がいた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の内部の中心は、Ｌ字型になったカウンターだ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペイントの色は昔とはちがっているし、奥のＬ字型になった部分は、あとからその人が建て増ししたものだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きく立ちふさがる二面の壁のように、十五階建ての集合住宅がＬ字型に建っていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス戸の外は、南と西をＬ字型におさえているバルコニーとなっていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "外は玄関ホールで、こういうＬ字型のスペースの取りかたは、使いやすくていいですよ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「住みやすいですよ」「玄関の靴脱ぎの四角いスペースをホールがＬ字型に囲んで、その延長として、二階への階段が奥にあって。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の左側にＬ字型のカウンターがあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
