        "examples": {
          "standard": [
            {
              "text": "演奏会が始まる前に、プログラムで本日の演奏曲目を確認する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のコンサートの演奏曲目は、バロック音楽の傑作で構成されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演奏曲目の選定には、観客が飽きないような工夫が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼のソロリサイタルでは、珍しい現代音楽の演奏曲目が注目を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "演奏曲目はもう選んだんだね。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はバッハを初めとする古典音楽を愛するとともに、故郷カタロニアの歌調を自ら鳥の詩と称して演奏曲目に忘れない、彼が現代の十二音音楽を斥けたり、故国の独裁政権に抵抗を続けるのも、それが人性の自然に反くからであると言い、人は皆己れを人類という大木の一枚の葉と思うべきだと語っている。",
              "citation": {
                "source": "望ましい音楽",
