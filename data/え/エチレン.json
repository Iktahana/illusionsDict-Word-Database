        "examples": {
          "standard": [
            {
              "text": "バナナなどの果物は、エチレンガスによって追熟が促進される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "石油化学工場では、ナフサを熱分解してエチレンを製造している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ポリエチレンの原料となるエチレンは、世界中で大量に生産されている基礎化学品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "シェファーの方法は、ポリビニル・ホルマールの塩化エチレン溶液を使う方法である。",
              "citation": {
                "source": "雪の化石２",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると塩化エチレンは蒸発して、ポリビニルの薄膜が雪の結晶の表面に残る。",
              "citation": {
                "source": "雪の化石２",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ内容は同じだけれども、包装が違っていて、昔はハトロン紙で包んだものを、今はビニールやポリエチレンでくるむというようなことだ。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "何デモ三井化学アタリカラ樹脂原料ヲ買イ入レテ写真フィルム、ポリエチレン被膜、ポリエチレン成型品、バケツダノ、マヨネーズノチューブダノト云ッタ類ヲ製造スル会社デアルト聞イテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
