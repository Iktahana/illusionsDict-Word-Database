    "definitions": [
      {
        "index": 1,
        "gloss": "disk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "陸上選手が円盤を力強く投げ、会場の観客を大いに沸かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "天体望遠鏡で観測すると、あの惑星の周りには美しい塵の円盤が広がっているのが見えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "陶芸家は、高速で回転する円盤の上で粘土を巧みに成形していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "巌丈な鉄棒の頂上に鉄の円盤を固定したもので、人の手の力くらいでは容易に曲げ動かすことが出来ないように出来ている。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見置時計のような形をしているが、その前面の円盤には羅針盤と同じように方角を誌し、その周囲には小さい豆電灯が一列に輪をなして並んでいる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスなどの円盤の中央をたたくと、それがある整数だけのほぼ同大の扇形に割れる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にサムナー・テーンターやグラハム・ベルらの研究によって錫箔の代わりに蝋管を使うようになり、さらにベルリナーの発明などがあって今日のグラモフォーンすなわち平円盤蓄音機ができ、今ではこれが世界のすみずみまで行き渡っている。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の研究は平円盤の発明によって非常な進捗を遂げた事はいうまでもない。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋管記録の寿命はせいぜい千回ぐらいであるのに平円盤の原型の寿命はほとんど永久であると言ってもよい。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平円盤によって行なわれた声音学上の実験的研究もたくさんにあって、今でも続いて熱心な学者がこれを追究している。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が初めて平円盤蓄音機に出会ったのは、瀬戸内海通いの汽船の客室であったように記憶する。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後大学生時代に神戸と郷里との間を往復する汽船の中でいつも粗悪な平円盤レコードの音に悩まされた印象がかなり強く残っている。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "円形の要素としては蓄音機の円盤、工場の煙突や軒に現われるレコードのマーク。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば蓄音機円盤が出勤簿レジスターの円盤にオーバーラップするとか、あるいはしわくちゃのハンケチを持った手を絞り消して絞り明けると白いばらの花束を整える手に変わる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これがシャッターの回転数と蓄音機の円盤の回転数との関係を示した項式です。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう具合にシャッターの方をＡとし、円盤の方をＢとすると、ＡとＴとの積は、一定時間におけるＡのヴェロシティすなわちＶだから、それからこの項式が出てくるのです。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から覗いているくめ子は、嘗て学校で見た石膏模造の希臘彫刻の円盤投げの青年像が、その円盤をさし挟んだ右腕を人間の肉体機構の最極限の度にまでさし伸ばした、その若く引緊った美しい腕をちらりと思い泛べた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとから、もう一人、眼鏡をかけた背の低い少年が、これは両手に一つずつ円盤をさげてついて行った。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、見るものは空と海との大円盤である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になって、左舷の遥かに金華山らしいのが眺められたが、航路というものは、海岸線には添いつつも、なかなかに近くへは寄れないと思えて、おおかたは空と海とのかぎりない大円盤ばかりを周りにして進んで行くのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "内に光を孕んだ豊麗極まりない藍紫色の大円盤が、船の白塗の欄干の上になり下になりして、とてつもなく大きく高く膨れ上り、さてまたぐうんと低く沈んで行く。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "国光丸はひたすら北へ向って急ぎ、小ナポレオンのためのセント・ヘレナは、やがて灰色の影となり、煙の如き一線となり、一時間後には遂に完全に、青焔燃ゆる大円盤の彼方に没し去った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と巡査は答え、小さな金の円盤に眼を泳がせた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい機種のほとんどが、ＣＤ―ＲＯＭの再生装置付きで売られるようになり、アプリケーションも、ゲームも、電子化した本や写真集の類も、一気に虹色に光る銀色の円盤で供給されるようになったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この銀色の円盤には、電子本にしたもう一つの『本の未来』（Honmirai）が入っている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七図は、デンマーク国古青銅器時代の青銅製遺物で、馬が日の車を牽くを示すらしく、その日に充てた円盤に、黄金を被せ、美なる螺旋状飾紋あり。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると帽子は投げられた円盤のように二、三｜間先きをくるくるとまわって行きます。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、鶴村が脊中をまるくして円盤を選んだり、器用な手つきで針を差し換たりなどしてゐる姿を、縁側からぼんやり眺めてゐた。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　雲母か何かで、十六武蔵ぐらいの大きさの薄い円盤を作って、水晶の糸で釣るして、真空のうちに置いて、この円盤の面へ弧光燈の光を直角にあてると、この円盤が光に圧されて動く。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月さまは、光をうしなった、青白いえんばんみたいです。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
