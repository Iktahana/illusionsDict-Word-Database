        "examples": {
          "standard": [
            {
              "text": "昨夜、空に不思議な光を放つ円盤が浮かんでいたと多くの人が目撃証言をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "少年は宇宙人との遭遇を夢見て、夜空に輝く星々の間に円盤を探した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "SF映画では、たびたび巨大な円盤型宇宙船が登場し、地球に接近するシーンが描かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      },
