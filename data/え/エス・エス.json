        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長距離ドライブ中、ガソリンが少なくなってきたのでSSに立ち寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このSSは24時間営業なので、いつでも安心して利用できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "オイル交換をお願いしたいのですが、こちらのSSでできますか？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そうしてその筋向いのこのＳＳ旅館へ這入ると、前の会話に出た堂々たる遊廓式のまた博覧会の竜宮風の赤ニスの梯子段をトントンであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "自力にあまるならあまるで、ＳＳ頼む、弱った、助けてくれでいい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山高でフロックコートで、お従者を連れてすうと素通りで、や、ＳＳ、気の毒した、御苦労とも抜かすこつじゃねえ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四年の『国民之友』の夏期附録に載せられたＳＳＳ同人の詩の翻訳、それから続いて『しがらみ草紙』の発刊、『舞姫』の発表――一時は文壇の評論界を席巻した概があつた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災前、ＳＳＳ団という団体が某私立中学に出来ていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを米国のＫＫＫ団、又はＩＷＷ団の真似をしてＳＳＳとしたのであったが、この時まではまだ不良と名づける程の仕事もしていなかった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのＳＳＳへ不良青年がまじるようになると、いつの間にか仕事が著しい不良性を帯びて来た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に文房具にＳＳＳというのが出来たので、改めてＳＭＳと改名した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――という一つの運命的な衝動を私達の神経へ伝えて、私たちの乗り込んだＮＹＫ・ＳＳ・Ｈ丸は倫敦・横浜間の定期船だけに、ちょいと気取った威厳と荘重のうちにその推進機の廻転を開始した。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで多くの出帆がそうであるように、一つの劇的な感傷が私たちの心もちに落ちるんだが、それより、まず、どうして私たちがこの特定のＳＳ・Ｈ丸に乗船しているのか――その説明からはじめよう。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそうと、いつの間にかもう日本へ帰着したようなことを言っているが、じつは、話しのうえでは、ＳＳ・Ｈ丸はいまやっと倫敦テムズ下流のロウヤル・アルバアト埠頭を離れたばかりのところに過ぎない。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日午前九時、ＳＳ・Ｈ丸はロウヤル・アルバアト・ドックを離れてテムズ河口へ揺るぎ出た。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "船という船のなかで、この倫敦発横浜行きＮＹＫ・ＳＳ・Ｈ丸――私がそれに、何の理由もなしにほとんど運命的な約束をさえ見出しかけていると、彼女も眠れないとみえて、下の寝台で寝返りを打つのが聞えた。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる天候によごれたＳＳ・Ｈ丸の姿が何と有難く見えたことよ！",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのＳＳＳＲ、コサックと農民と労働者が美装の史書へしるした大きな黒い手のあとだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数日ののち、私たちはオスタンド・ドウヴァ間のＳＳヴィユィユ・リエイジュ号の甲板上に、近づく白堊の英吉利の断崖を見守っている自分達を発見した。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄葉した植込みの奥のもっと黄色い柱列を入って行って、旅券の後に添付されてるＳＳＳＬ居住許可証を返して来た。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂｜ＮＡＲＺＩＳＳＭＵＳ（自己恋着）はこれにして、筆者の所謂積極消極両様の変態恋愛の交叉帰一点そのものの発露と見るを得べし。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来、「ＳＳワラタ」の名はロマンティック――乗っていた人の身になれば余りロマンティックでもないが――海洋怪奇談の随一に挙げられ、詩人の夢によって幾多の詩となり、多くの作家の空想を刺激しては雄大壮麗な海洋冒険小説を生み出している。",
              "citation": {
                "source": "沈黙の水平線",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "綴りはＳＵＳＳＡＮＲＡＰです。",
              "citation": {
                "source": "不思議な島",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十二年の「國民之友」夏季附録にはＳＳＳ社中の「於母影」が出た。",
              "citation": {
                "source": "創始期の詩壇",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＳＳの陰符が人目をそばだてしめたが、これはやがて森鴎外博士の率ゐる新聲社であると云ふことが判つた。",
              "citation": {
                "source": "創始期の詩壇",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ですけれどね、きのうイー・エス・エスのときミス・ソーヤーがあなたのことをわざわざきいていらっしゃったんですもの。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一九四七年八月二十三日、日本長崎港内にて、エス・エス・ジョージ・エルホエリー号より。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時に出ると、日比谷の陶々亭へ、「エス・エス」主催の座談会、情報部の黒田軍人さん・岩田豊雄・遠藤慎悟・徳田純宏・権田保之助に僕といふ顔ぶれで、新体制の演芸といふ話、かなり言ひたいことを喋った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時、日劇へ寄って留守中ダレないやう注意して、五時、レインボーへ、東宝新雑誌「エス・エス」の菊池寛氏に芝居をきく座談会へ出席、まづい定食食ひつゝ六時半迄ゐて、本二三求め、七時十分発で修善寺へ向ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから日劇へ寄り、六時半にはレインボーへ、「エス・エス」の座談会で行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時から又山水楼で、今度は「エス・エス」の古川緑波をめぐる放談会があり、三島草道・坪内士行・伊藤松雄・川口松太郎・中野実・徳川夢声といふメムバー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エス・エス」へ、針桐小僧といふ名で一座の名古屋だよりを六枚書いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時に宿へ、秋田実、「エス・エス」のインタービューで来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
