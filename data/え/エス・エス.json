        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "The Nuremberg Trials documented the crimes committed by members of the SS.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Historical texts often discuss the SS's ideological foundation and its impact on Nazi Germany.",
              "citation": {
