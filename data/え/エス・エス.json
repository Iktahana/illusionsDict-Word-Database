        "examples": {
          "standard": [
            {
              "text": "相手チームのSSが、見事な守備でピンチを救いました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "俊足のSSは、内野ゴロでもヒットに変える力があります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわー、あのSSのプレー、すごかったな！」と観客がどよめいた。",
              "citation": {
