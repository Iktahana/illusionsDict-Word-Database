        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「よいしょ、よいしょ！」「エッサッサ！」力自慢の男たちが、丸太を運ぶ際に声を揃えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もっと力を入れて！」「エッサッサ！」重い岩を動かすために、皆で力を合わせて引っ張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この船を岸壁に引き寄せるぞ！エッサッサ！」港湾作業員たちの力強い掛け声。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「さあ、みんなで！エッサッサ！」運動会で、綱引きの応援団がリズムに合わせて叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "アラ、エッサッサア――　又もや安来ぶしだ。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」アラ、エッサッサア――十一　地主の差配の山口が、おのれの手抜かりは棚に上げて、何も彼も小作人たちの罪になすりつけてしまつた。",
              "citation": {
                "source": "菜の花月夜",
                "author": "片岡鉄兵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エッサッサ、エッサッサ」　泥鰌掬いが始まった。",
              "citation": {
                "source": "善悪両面鼠小僧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を背負つてエッサッサ／＼　ヤッコラサと着いたら汽車がでた……字の読める芸者と云ふが少女界剣花坊さくら鍋向ひの寄席は浪花節同チンタオで儲けたらしく油ぎり同何女史を訪へば大きな腹で逢ひ同　みな大正初年の市井雰囲気である。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アラ、エッサッサ、紙おくれときやがら」　凱歌のように俺は浅草の安来節を女の腹の上で歌った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の小屋ではそのころ、この「エッサッサ」の個所で客がある種の言葉（と俺も照れて伏せておくが）を合唱したものである。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
