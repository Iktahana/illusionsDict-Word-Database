[
  {
    "uuid": "6bb6515e-56f3-587e-be1f-b8e5efd19a83",
    "entry": "謁する",
    "reading": {
      "primary": "えっする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to have an audience (with)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "王に謁するため、使者は遠い国からやってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "著名な作家に謁し、サインをいただいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "神官は、神に謁することを誓い、修行に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "又別に、春日劉太保の墓に謁するの七律あり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しからずとて、強いて謁するに、夏装束と思いの外、蚊帳を身に纏うて居たと云う話がある。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大王に拝謁するために来たのです」「では、お供をいたしましょう」　武士は前に立って歩いて行ったが、水際に出ると毅を見返った。",
              "citation": {
                "source": "柳毅伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出立の前夜に源氏は院のお墓へ謁するために北山へ向かった。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "独礼とは式日に藩主に謁するに当って、単独に進むものをいう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて源吾は謁見を許されぬ職を以て終ったが、六月二十日に専六は承昭に謁することを得た。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は申告の為方なんぞは極まっていなかったが、廉あって上官に謁する時というので、着任の挨拶は正装ですることになっていた。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の八郎太が、裁許掛見習として、斉彬の近くへ出るのと、斉彬の若者好きとからで、小太郎は無役の、御目見得以下ではあったが、時々、斉彬に、拝謁することができた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ家老一同が城下から来て拝謁する。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山本の旅宿は京都の東北の吉田神社の傍で、藩主の本陣は真如堂であったから、私もあちこち往来して、また藩主にも拝謁することを得た。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで日本の使節もよいことを聞いた、小笠原流にもない礼法を学んだと喜び、いよいよ宮廷に達し拝謁するとき、使節は玉座の前でみな手を鼻に当てた。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし早く帝に拝謁することがかなわないならすみやかに浪華の地を退きたい、そして横浜にある居留民の保護に当たりたい一同の希望であると。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の舎利三千粒も、初めて聖武上皇に謁する時に捧呈せられている。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに大谷光瑞上人に謁するを得たるも、また不思議の因縁なり。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に実隆は父を懐うよりも母を慕う情が深く、父の墓所二尊院に参詣するよりも、しの坂の母の墓に謁する方が、思い出の種も多かったのである。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの記事によって斎藤と三条西家との関係を伺い知ることができるので、かかる消息が通っておればこそ、斎藤越後守も時によっては、立替えをもなし、また用脚が到着するとわざわざ使者をもって受取人派遣の督促をなし、あるいはわざわざ太刀金二百疋の折紙持参でやって来て、実隆に謁することもあったのである。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口の町では伝手を求めて領主の大内義隆に謁することが出来、領主の好奇心に答えていろいろの話をしたが、結局フェルナンデスに教義書を読ませ、日本の宗教や道徳の腐敗に対して攻撃を加えるに至った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の初めには織田信長が入京して将軍に謁し、初夏には長尾景虎が入京して、将軍に謁するのみならず参内して天盃と御剣を賜わった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠手田氏の意見では、領主松浦隆信に謁することなく、全然秘密に平戸で用を果すがよいとのことであった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "次で将軍の夫人に謁する時には、間の襖を開いて、次の間から礼をした。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "範綱と、十八公麿とは、大柱の客間をもう一間こえて、東向きのいつも、拝謁する小間まで通って平伏していた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを持って明日は、辰の口のお控え所まで参り、登城のおゆるしが出れば、即日、将軍家に拝謁することになろう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大多数の目的は若きモンテナナ国王に拝謁するためだ。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御任命のよしは承ったが、将軍家に謁するには、先例格式があって、おてがるには参らぬ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は其処で、秀吉に謁するために、賤ヶ嶽から急遽降って来た、丹羽長秀に会った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、家康に謁すると、諄々と、利害を説き、秀吉の意を諭して、大坂への入京をすすめた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
