        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大変だ、財布を家に忘れてきちゃった！偉いこっちゃ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "電車が止まった！これじゃ約束の時間に間に合わないよ、偉いこっちゃ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あれ、鍵がない！どうしよう、偉いこっちゃ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "豹吉の傍へ寄って来ると、「兄貴、えらいこっちゃ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三郎公、えらいこっちゃ、銭がない」「えっ……？",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「灸すえへんか」「すえへん、すえへん」「ほんなら好きや」「そか、好きか」　可愛さに気の遠くなる想いで、頭髪の熱っぽい匂いをかぎながらじっと君枝を抱いていると、〆団治が、「他あやん、えらいこっちゃ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何やのて、ほんまに、えらいこっちゃ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（読まんと、社会部長のところへ廻したりしたら、えらいこっちゃ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて帰ってくる）甚作　（蒼くなって、帰ってくる）えらいこっちゃ！",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お霜は粥を入れた小鉢を抱えたまま、「えらいこっちゃ、えらいこっちゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前えらいこっちゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えらいこっちゃ、えらいこっちゃ。",
              "citation": {
                "source": "南北",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共の呑気な「おかえりなさい」と云う挨拶に答えるなり、彼は息を切って、「東京はえらいこっちゃ」と云った。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁もなきよその火事でさえも一応は火事半纒を着用して、えらいこっちゃ、近い近いと走り出した。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはえらいこっちゃ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら、えらいこっちゃ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、これは――」「うむ、これはえらいこっちゃ」　一同は躍りこんだときの激しい勢いもどこへやら、云いあわせたように、その場に立ち竦んだ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うわーッ、えらいこっちゃ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うわーッ、えらいこっちゃ」「うむ、天命だな。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんまなら、こらえらいこっちゃ」　部長の顔色もサッと青褪め、すこぶる緊張した。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、えらいこっちゃ。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜びよりも、えらいこっちゃと心配になって来た。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら、えらいこっちゃ思うて、いきなり駆けだすと、木津さん、どこまでも追うて来やはるやありませんの。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、えらいこっちゃ。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "こら、えらいこっちゃ思うて、いきなり駆けだすと、木津さん、どこまで追うて来やはるやありませんの。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一枝を無造作に折りとり、年よりもまた若者たちを見おくりながら、小さい声で、「えらいこっちゃ。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やねん、あんた八百常さんかいなと云うと、向うも気が付いて、お春どん、あんた何処へ行かはるねん、この水の中を気でも違うたんか、これから先は男でも行かれへん、川の近くは家が潰れたり人が死んだりしてえらいこっちゃがなと云う。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽつ、ぽつ、と時折その前を通る人影は、槍の光を見て、遠く足を浮かして歩いて行ったり、また、高札の前に立って、「えらいこっちゃなあ」と、嘆息と共に読んで去る者もあった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕府が政権を放棄した当時に、京都で討幕府派の策謀がおこなわれて、「えらいこっちゃ」と、市中でさわぎまわらせられた京都の庶民をのぞいては、日本の庶民は喜びもせず、また悲しみもしなかったというのが事実である。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えらいこっちゃな」　時親は牛の背で世間を見物顔していた。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
