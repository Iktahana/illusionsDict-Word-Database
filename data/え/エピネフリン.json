        "examples": {
          "standard": [
            {
              "text": "アナフィラキシーショックの際には、エピネフリンの注射が必要になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エピネフリンは、ストレス反応で体内で分泌されるホルモンです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "医師は、緊急時に備えてエピネフリン製剤を処方した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "精神を集中させ、脳からノルエピネフリンの分泌が促進されることを念じながらオーラの発散を活性化させる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はいつになくノルエピネフリンの調子がいいらしい。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルファ波、オーラ、ノルエピネフリン、この三つの要素のうちどの二つを数量化して関数を作ってみても、微分すれば必ず正になる。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
