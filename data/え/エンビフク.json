        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "指揮者が聴衆に向かって深々と一礼すると、燕尾服の裾が綺麗に翻り、演奏会の幕が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、お父さん、燕尾服なんて着てまるで魔法使いみたい！」「ははは、今日は特別な晩餐会だからな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社交ダンスの競技会では、燕尾服をビシッと着こなした男性たちが、パートナーをリードして華麗に舞う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その癖腰を卸すとたんに、燕尾服の長い裾を丁寧に左右に開くことは忘れなかつたのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで燕尾服にも及ばないといって来た位です。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕尾服をつけた給仕が、銀盆に一枚の名刺を置いて、ものものしく妾達の卓子の前で、黒い尾を折りました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まであの店の部屋の古風な装飾なり、また燕尾服を着たボーイなりが、すべて前の世紀の残りものであったのが、火事で焼けたこの機会に、一足飛びに現代式に変ってしまったのだというような気がした。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺三郎なんかまるで立派な燕尾服を着て水仙の花を胸につけてまっ白なはんけちでしきりにその尖ったお口を拭いているのです。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの來歴を告げて、それから、ケルリ、ケルリ、と檻に向つて二聲叫び、右手のむちを小粹に振つた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの来歴を告げて、それから、ケルリ、ケルリ、と檻に向って二声叫び、右手のむちを小粋に振った。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽根がむらさきのような黒でお腹が白で、のどの所に赤い首巻きをしておとう様のおめしになる燕尾服の後部みたような、尾のある雀よりよほど大きな鳥が目まぐるしいほど活発に飛び回っています。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺三郎なんかまるで立派な燕尾服を着て水仙の花を胸につけてまっ白なはんけちでしきりにその尖ったお口を拭いてゐるのです。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕尾服もあれば厚い粗羅紗を着た農夫もあり、綬をかけた人もあれば、スラッと瘠せた若い軍医もありました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私から見れば黄石公――壁に脱いだ、緋の外套は……そのまま、大天狗の僧正坊……」　多津吉は銅像の腰を透かして、背後に迫って、次第に暮れかかる山の寂寞さを左右に視たが、「燕尾服の口上が、土地の新聞社という処で、相当にあしらってくれる。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――帷幕が下りると、……燕尾服の口上じゃない――薄汚い、黒の皺だらけの、わざと坊さんの法衣を着た、印度人が来て、袖を曳いて、指示をしながら、揚幕へ連れ込んで、穴段を踏んで、あの奈落……きみもよく知っていようが、別して地方劇場の奈落だよ。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は勿論、早朝から燕尾服を着て姿を消したのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――したがって日本人に最も接近させられる――であるけれども、彼等の極端なるジャズバンドの音楽でさえ、日本俗謡の八木節や安来節の類に比し、尚｜遙かに貴族感的で、どこかに＊シルクハットや燕尾服を着たところの、儀礼正しき紳士道を聯想させる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本斗」「本斗」　山高に燕尾服の、品のいい老人が、車窓に向って直立した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の岩壁には、頂上には、密集した黒と白とのロッペン鳥が幾層積を成して、規律正しき燕尾服の紳士行列を作っている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "耿として白く、また黒く、燕尾服の、　両翼を張って、ひらりと、　画面を横断して、　消える。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の静謐、　黒と白との寛洪な燕尾服の紳士、ペンギン鳥の従弟、ロッペン鳥が、その上の岩壁の突処に立っている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺と白との燕尾服で、ものおもふペンギン、なにが悲しいのか、小意気なわかい紳士のペンギン。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この往来を電車と並行して来る美事な旧式パッカードの箱自動車の中に並んでいる――燕尾服の紳士と夫人らしい夜会服、それがソックリ伯父と玉兎女史に見えたのだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　キャバレエ「オリンピア」の「支配人」佐古五郎は昨日から引続いて、仰々しく燕尾服を着込んで、鼠のように忙しく立ち廻っていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ヵ月にわたる口説き落しの努力が報いられたので、さすがの佐古も余程嬉しかったと見えて、自祝の意味もあり、多鶴子がいよいよ「オリンピア」に現れる晩、それは昨夜だったが、燕尾服を着用したのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに佐古はこともあろうに、多鶴子とおそろいの真紅の薔薇を、燕尾服の胸にぶら下げたのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く待っていると、燕尾服の胸に薔薇の花をつけた男が下品な感じの顔をぬっと出した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等室のほうからも燕尾服の連中がだんだんにやってくる。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕尾服に白襟を附けて、綬を佩びてゐる。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも主人は婆あさんを出し抜いて、一人で階段の上に迎へに出て、燕尾服を着たところを、娘に見せる積りらしい。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕尾服に白襟を附けて、綬を佩びて。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその日この男を見た町の中の人たちの中には、あの燕尾服のポケットから非常に目立ってぶら下っている白い麻のハンケチの下をちょっと覗いてみたがった連中も多かったろう。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りに私の破れ靴は黒光りの靴に変り、衣は燕尾服となり、私はシルクハツトをあみだに被り――おや／＼、きらびやかなタバンの酒注台に凭りかゝつて、盃をあげながら淑やかなマーガレツトの御機嫌をとつてゐた。",
              "citation": {
                "source": "〔モダン紳士十誡〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
