        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔のマンガでは、エテ公という言葉がよく使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動物園でエテ公がバナナを食べているのを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まったく、あいつはエテ公みたいに落ち着きがないな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "銀行泥棒上りが銀州、強盗前科が腕公、女殺しがエテ公、凡クラがボン州……モウ暫くすると君だって戒名を附けられるかも知れない。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボン州、銀州、エテ公。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この、エテ公よう」日本語でいい、女はだが笑顔をつくっていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあの人が通り合せたお蔭で助かりはしたもののこわいことだったねえ、もうもう気をつけておくれでないとほんに困りますよ」　お婆様はやがてきっとなって私を前にすえてこう仰有いました。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「口惜しいけれど、おいしいわよ」　お絹は唾液がにじんだ脣の角を手の甲でちょっと押えてこういった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君や僕が学園にいるうちは、安宅先生は決して還らないのだ」　わたくしは、少し間の悪い思いをぐっと堪えてこう訊きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話のあとへ、高谷君は付け加えてこう言った。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は往来を歩いている一人の人を捉まえてこう観察する。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　此方の船の、水夫達は、口を揃えてこう叫んだ。",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえにこそ、実に一口に言おうとて言えないくらい、さまざまに胸の摧ける思いをして、やっと今晩という今晩、またと得られない機会を捉えてこうして女の家に入り込んだのである。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "必定――ひさよし――上方の方の役者は、えてこういう眼つきをして、面で芝居をしたがる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引かえてこういう貧しい裏町に昔ながらの貧しい渡世をしている年寄を見ると同情と悲哀とに加えてまた尊敬の念を禁じ得ない。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の原子核物理学者は声をそろえてこう告白する。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでもいくぶん好奇心をそそられたと見えてこう訊き返しながら、ふと勘次は格子内の土間の灰溜りに眼をつけた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから漸と気を換えてこういった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、二成に教えてこういわした。",
              "citation": {
                "source": "珊瑚",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は虫のいいことを考えてこう決心した。",
              "citation": {
                "source": "西班牙犬の家",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "われながら大それた、外国の王様をひっつかまえてこういう無態なることをすれば、日本の国にどんなご迷惑をかけるか、それを知らねえわたしじゃアありません。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前の正岡子規が、明治三十二三年の頃、後輩の俳人に教えてこういったことがある。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "平次身の上話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ八、――存分に張り上げてみたか」　平次はガラッ八を迎えてこう訊きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは言葉を換えてこうも云えよう。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は言葉を換えてこう云わざるを得ないのである。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "または言葉を換えてこうもいえよう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも国体や皇室に触れ奉るという形を取るもので、極めて悪質なものと云わねばならぬが、所謂邪教即ち新興宗教の多くのものが、敢えてこうした形の不敬行為に及ばねばならぬということには、或る深刻な経緯があるのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "閣下はコヴェントリイ氏に、二千アングルの金で買収されていらっしゃるという事実です……その友人はなおつけ加えてこうもいうのです、あなたの召使や、奥さまや、それから私の事件に対するあなたの態度を見知っている議員たちの話で、彼はあなたがこっそり私に反対の糸を繰っていられることを知っていると。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが匈奴では蘇武をつかまえてこうさんしてけらいになれといったが、蘇武はきかなかった。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、私たちの生活上必要な一つの〔検閲で削除され不明〕だと考えてこういう生活もちゃんちゃんやって行こうと決心していて、それで大分辛棒いいのですけれど、まだまだね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "年老いた父へやさしい長い手紙を几帳面に書き送ってはいたが、あえてこうは書き得なかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "打絶えてこういうことはなかった。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　七兵衛は自分に最も手近で、そうして最もよく話をしてくれそうな見物人の一人をつかまえてこう尋ねました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "間の山の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
