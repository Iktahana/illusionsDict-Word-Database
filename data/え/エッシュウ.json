    "definitions": [
      {
        "index": 1,
        "gloss": "Esshū (the three former provinces of Echizen, Etchū and Echigo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「かつて越州と呼ばれたこの地域は、豊かな自然と歴史に彩られている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「戦国時代、越州は北陸地方の重要な拠点であった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この古文書には、越州の豪族たちの動向が詳細に記されている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「彼の子孫は、越州から離れ、遠い都で仕官したという。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "唐五行志に、乾符六年越州山陰家に豕あり、室内に入って器用を壌り、椀缶を銜んで水次に置くと至極の怪奇らしく書き居るが、豕が毎に人の所為を見てその真似をしたのであろう。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "光沢のある越州の壺に似合った冬薔薇の華やいだ向うで由吉は無造作に鮭を食べたその途端、「あッ、これは見事だ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿渋、李朝の秋草、越州、黒高麗、天龍の青磁、など、殊に一際目立って華手な、女王の品位を放つ万暦の鉢があった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "錢塘江口の明州や越州（今の浙江省會稽道紹興縣）へも、隨分日本船が出入した。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今より十二三年に、私は藤田劍峰君・長尾雨山君と同伴で、杭州から紹興（唐の越州）へ出掛けた。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に大師が歸朝の途次、浙江の越州（今の會稽道紹興縣）に立ち寄られ、越州の地方長官に經典の蒐集を依頼された時の「與越州節度使求内外經書啓」に、今見於長安城中、所寫得經論疏等凡三百餘軸、及大悲胎藏金剛界等大曼荼羅尊容、竭力涸財、※逐圖畫矣。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「與越州節度使求内外經書啓」に、元和元年四月と記してあり、また朱千乘――浙江地方の人と推すべき強い理由がある――の送別詩序（『高野大師御廣傳』上）に、元和元年春姑洗之月と記してあり、而して姑洗之月とは舊三月を指すから、此等の事實から推測すると、しかく斷定せなければならぬ。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "越州は長安を距ること三千五百里――『元和郡縣志』に據ると三千五百三十里――で約一ヶ月半の路程に當る。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に前年の遣唐大使藤原葛野麻呂の一行は、二月十日（若しくば十一日）に長安を發して、三月二十九日に越州に到着した。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大師も三四月の交に、越州附近まで歸來せらるるには、二月中旬後くもその二十日頃までに、長安を出發する必要がある。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて大師は往時と同一の驛路を、反對に杭州に下り、杭州から越州に往き、越州・明州の間に數ヶ月滯留の上、その年の八月に遣唐判官高階眞人遠成の一行に加はり、明州より出帆して、十月に歸朝されたのである。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時松平越州の名児童走卒も亦皆之を知る。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "襄も亦其小さき耳の中に越州なる名詞を※んで忘るゝ能はざりしなり。",
              "citation": {
                "source": "頼襄を論ず",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の書籍はいづれも水野越州以来久しく圧迫されてゐた江戸芸術の花が、維新の革命後、如何に目覚しく返咲きしたかを示すものである。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥居甲斐守は老中水野｜越州が天保改革の時、江戸町奉行の職に在り、一｜世の怨を買って、酷吏と称せられた人である。",
              "citation": {
                "source": "枇杷の花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「例の品でござるか、越州殿」「まあ、さようで」「ホホウ、どうしてお手に？",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホレ、上様、越州、字が書いてある？",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日某所より入手いたした茶壺、これこそは真のこけ猿に相違なしと、上様と越州と、拙者といきおいこんでその壺の紙を剥ぎ取りたるところ、なるほど虫食いのあとはげしき古図一枚、現われはしたものの、文言地図等簡略をきわめ、とても、思慮ある柳生家御先祖の真の書き物とは思われぬ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうか、越州から知らせがあったのか」　ひとりごとのような泰軒の言葉。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、いつぞやこのお美夜｜坊が、大岡どののお屋敷へお届けものをして、じきじきにお目どおりを許されたさい、これの口から越州殿にも、お願いしてあるはずじゃが……」　と、ハッと心づいたように、「ウム、そうじゃ！",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことにどうも」「一応声をかけて然るべきに、余と対談中の方へ槍を向けるとは粗忽なやつじゃ」「なにとぞ平に御容赦……お客さまへも御前からおとりなしのほどを」「越州どの、わかればもうそれでよいではござらぬか。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどどうして御前には……」「越州殿は千里見通しの神眼じゃ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "越州察するところ、こりゃ単に役人にまぎらわしき風体のものであろう。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その件に越州が首を突っこんでおるのか……ウウム！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「越州殿はお人が悪い。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、黒白の石を掴んでサラサラと盤に落とし、あるいは黒を動かし、時には白石を種々に移して、言わばでたらめで――そのあいだには、これも沈思の時の癖で、越州はしきりに爪を噛んでいるのだ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくて、伊豆屋からお油御用を取り上げて筆屋幸兵衛へ用命しようなどと、さような小事にさほどまで執着さるるはずはないと、イヤ、これは、越州一個の考えでござるが――」「私情？",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
