        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「手伝ってくれるか？」「得たりや応と！」と彼は快く引き受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な依頼にも、得たりや応とばかりに挑戦する姿勢を見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の提案に、チームの皆が得たりや応と賛同した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "で、「うるさいのね、何て真似をするの、男らしくもない」　ときめつけてやりますと、自分でも持てあぐねていた癇癪玉の投げつけ相手を直ぐ眼の前に見付けたように得たりや応と、葛岡は鎌首を擡げて来まして、「男らしくないとは何だ」　と言います。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "得たりや応という中にテンデに羽織をぬいで棺桶を担ぎ上げた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなりゃおまえさんまかせだ、橙を落とさねえようにして、はええところ伝兵衛とやらのねぐらへ案内してみな」　得たりや応とばかり、鼻高々として伝六が案内していったのは、話のその大根河岸なるさかさねこ伝兵衛のひと構えです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ざかりの日は、得たりや応と真裸の彼を目がけて真向から白熱箭を射かける。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　そうおもった彼は、得たりや応と、ノーマ号でがんばることに決めてしまったのである。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "首も廻らぬ借財の、筋の悪きを聞付けて、得たりや応と攻め掛けし、反対党の爪牙に罹り、そが煽動の出訴により、思はぬ外の監獄入り。",
              "citation": {
                "source": "誰が罪",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "値のことは我々、かゝりが違ふので、まあ岸田程のものとなればいくら高く問はれやうと、それが当り前見たやうなものゝ、たゞさうなると得たりや応とばかりヘンな岸田劉生が相当世の中に行はれてゐるらしいのは、難渋なものである。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれどもその夜は珍陀の酔に前後も不覚の体ぢやによつて、しばしがほどこそ多勢を相手に、組んづほぐれつ、揉み合うても居つたが、やがて足をふみすべらいて、思はずどうとまろんだれば、えたりやおうと侍だちは、いやが上にも折り重つて、怒り狂ふ「れぷろぼす」を高手小手に括り上げた。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
