    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Echigo (former province located in present-day Niigata Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔、越後から江戸へ運ばれた米は、その品質の高さから人気があったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このお酒は、新潟県、つまり昔でいう越後の米だけを使って造られた地酒なんだ。」と店主が説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "越後の冬は厳しい寒さと大雪で知られるが、春には一転して山々が緑に覆われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新潟県はかつて越後と呼ばれ、多くの歴史的な出来事の舞台となった地域である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "越後の豪家｜高頭仁兵衛氏が、山岳辞彙ともいうべき浩澣な原稿をかかえて、志賀先生を訪問せられたとき、横浜にいる人が、こんな紀行文を発表している、山を知っている人らしいから、訪問してみたらどうかと、注意されたそうだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬岳の又の名を越後方面では大蓮華山といっている、或人の句に「残雪や御法の不思議蓮華山」とあるからは、これも一朶の白蓮華、晶々たる冬の空に、高く翳されて咲きにおうから、名づけられたのかも知れない。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに駿河町の越後屋（そのころの三井呉服店、今の三越）をいおう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "海水旅館赤松の林をこえて、くらきおほなみはとほく光つてゐた、このさびしき越後の海岸、しばしはなにを祈るこころぞ、ひとり夕餉ををはりて、海水旅館の居間に灯を点ず。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は自分のあとを嗣がせるつもりで、子供のときから一生懸命に長唄を仕込んだが、お俊は肩揚げの下りないうちから男狂いをはじめて、母をさんざん泣かせた挙句に、深川の実家を飛び出して、上州から信州越後を旅芸者でながれ渡って、二、三年前に久し振りで江戸に帰ってくると、深川の母はもう死んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後へ行く飛脚だによって、脚が疾い。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駿河町」の絵を見ると、正面に大きな富士がそびえて、前景の両側には丸に井桁に三の字を染め出した越後屋ののれんが紫色に刷られてある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は越後獅子かと思った。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に九月二日午前七時、伏木港を発する観音丸は、乗客の便を謀りて、午後六時までに越後直江津に達し、同所を発する直江津鉄道の最終列車に間に合すべき予定なり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　魚津より三日市、浦山、船見、泊など、沿岸の諸駅を過ぎて、越中越後の境なる関という村を望むまで、陰晴すこぶる常ならず。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "加賀からも、越後からもね、おい、泊懸の参詣で、旅籠町の宿屋はみんな泊を断るというじゃあねえか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日は千曲川の船橋を渡り、妙高山、黒姫山の麓を迂回して越後国高田に出づ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）奇異の血汐　徒歩出発地は前にいう太平洋沿岸方面の常州水戸で、到着地は日本海沿岸の越後国直江津の予定。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "足跡は常陸、磐城、上野、下野、信濃、越後の六ヶ国に亘り、行程約百五十里、旅行日数二週間内外、なるべく人跡絶えたる深山を踏破して、地理歴史以外に、変った事を見聞し、変った旅行をしてみようというのである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で、房州、相模はもとより、甲州、信州、越後あたりまで――持主から山を何町歩と買ひしめて、片つ端から鎌を入れる。",
              "citation": {
                "source": "玉川の草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伏木はけだし上都の道、越後直江津まで汽船便ある港なり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　滝の白糸は越後の国｜新潟の産にして、その地特有の麗質を備えたるが上に、その手練の水芸は、ほとんど人間｜業を離れて、すこぶる驚くべきものなりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治元年の七月、越後の長岡城が西軍のために攻め落された時、根津も江戸を脱走して城方に加わっていた。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから越後へ出て、北国の方をまわって……。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし銀子の母親には、結核体質らしいところが少しもないばかりか、あの白皙人型の越後系のがっしりした、均齊のよく取れた骨格で、性格にも恪勤とか忍耐とか、どんな困難に遭遇しても撓まない強靱さがあり、家を外にして飛び歩きがちな放浪癖の父親と反対に辛抱づよく、世帯の切盛りに忠実であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母の別れ話が、またしても持ちあがり、三人ずつ手分けして、上州と越後へ引きあげることになったところで、銀子はある日また浅草の桂庵を訪れた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　銀子も言っていたのだったが、ある時｜越後の親類の織元から、子供たちに送ってくれた銘仙を仕立てて着せた時の悦びも、思い出すと涙の種であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠き越後の山に雪の光りて麥もまたひとの怒りにふるへをののくか。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、越後から来た獅子舞ひの子供達にいろいろ芸当をさせたあとで、お銭があいにくないからといふので、そのまま追つぱらつてしまつたことだとか、畑から帰るとき土橋の下で猫の仔を拾つたが、とちゆうで、猫は生物だから物を喰べるといふことをおもひ出して、またもとの土橋の下へ捨てて来たこと、などであります。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもその辺の人に「越後で偉かつた人は誰ですか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元二千六百一年四月二十九日新美南吉手毬　かすみたつながき春日をこどもらと　てまりつきつつ今日もくらしつ鉢の子　春の野にすみれつみつつ鉢の子を　わすれてぞこしあはれ鉢のこ良寛一　蔵の中　出雲崎は、越後の国の、日本海岸にある、帯のやうに細長い港町である。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあんだ、越後にだつてあるぢやないか、お爺さんやお婆さんが揺籠を揺すりながら、乳母車を押しながらうたふのと同じぢやないか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
