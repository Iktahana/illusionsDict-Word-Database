    "definitions": [
      {
        "index": 1,
        "gloss": "AI transformation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "企業が生き残るためには、ＡＸの推進が不可欠だと経営層は考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "当社では、部門ごとにＡＸプロジェクトが立ち上がり、業務効率化を目指している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ＡＸを成功させるには、最新技術の導入だけでなく、組織文化の変革も重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本からのＦＡＸやラジオ放送の情報を元に、情勢を分析しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの犯人は、電子メールとＦＡＸの二人組だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "案の定ソニーで使っているＤＥＣのミニコンピューターＶＡＸも、背負わされた荷のあまりの重さに、息も絶え絶えとなっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼らはソニーのＶＡＸのパンクに苛立って、そんなことを言い出した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがよそへいってもＶＡＸはそこでパンクしているに違いない」　こう考えてＤ博士は、彼らの提案にのった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵はＦＡＸの使いこなしに暗いから、こっちでなんだかんだ聞かれたときにはせいいっぱい意趣返しして溜飲を下げてるんだけどね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビデオの録画もＦＡＸの送信も、おまけに掃除も洗濯も、ソニーのエレクトリック・ライス・クッカーでみんなできるというのなら、ローカルな『使いやすい』ルールもけっこうだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "音声通信はもちろん、ＦＡＸ型のグラフィックス通信、テキスト通信も可能である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あったのは、ＰＣに日本語化のための部品を加えた標準化構想ＡＸだけだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体的に見れば、このＡＸは「世界の標準機を安く」という期待のうち「安く」にはさっぱり答えられず、目覚ましい勢いを発揮することなく終わった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眠らないマシン（いや、スリープ・モードだから眠るのかな）は、とりあえず留守番電話とＦＡＸを取り込んでホームコンピューターを成立させるという素晴らしいお話が次に展開されますので、皆さんまずは秋のコムデックスの速報を読んで、オレの予想が外れていたら大笑いしててね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこのマシンにはＦＡＸモデムというやつがついている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＦＡＸモデムのとなりにはなんと通常のＦＡＸマシンが鎮座ましましていて、狭い机をさらに狭くしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話に関してはこんな具合に屋上屋を重ねてその上にドームまで被せたような日々を送っているオレは、一年ほど前にオンスペック社というところがモデムとＦＡＸ、ボイスメールの機能をＰＣ用ボードにまとめたＦＡＸ―Ｏ―ＦＯＮＥという製品を出したと聞いて、指パッチンをかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはＰＣ　ＸＴまたはＡＴ上で動作し、相手の信号が音声か、ＦＡＸか、コンピューターのデーターか自動的に識別してしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手の機械は、ＦＡＸと留守番電話とワープロを統合した専用機としても登場するかもしれないが、ばらばらのインターフェイスが並び合うのはオレの趣味ではない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや自動車の急流ひきも切らないウェストミンスタア橋の方角からあれよという間に一台駈けぬけてきたＴＡＸＩが、リジェント街とチャアルス街の角にぴたりと静止すると、そこの石造建築物のまえに手荷物とともにひらりと地に下り立った男女の東洋人があった。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七〇年には一六ビットのＰＤＰ―11シリーズ、一九七七年には三二ビットのＶＡＸシリーズを発表してヒットさせたＤＥＣは、その後も急成長の勢いを落とさず、一九八一年にはついにＩＢＭに続く売上高世界第二位のコンピューターメーカーとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣの日本語化は、世界市場でＰＣ互換のラップトップを成功させた東芝の逆輸入版Ｊ―３１００や、マイクロソフトの日本法人がリーダーシップをとったＡＸと名付けられたプロジェクトによって側面から進められることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフトは今後、ＦＡＸやコピーや電話といったオフィスのさまざまな機器にＷｉｎｄｏｗｓによってインテリジェンスをプラスし、その世界をコンピューターの文化圏を超えて押し広げていく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも訊いてみるよ」「取材して記事を書いた人」「訊いておいて、ＦＡＸでも」「新しい仕事場のほうへ」「うん」　電話はそこで終わった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢沢千秋についての問い合わせに対して返事が届いたことを、日比谷はＦＡＸ通信紙に簡単に書いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして矢沢富美子からの手紙とともに、中野玲子の専用ＦＡＸ宛に送信した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙を後藤美代子のファイルに収めているとき、ＦＡＸが受信を開始した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また電話しますので、出来ればそこにいてください』　このＦＡＸ通信も、日比谷は後藤美代子のファイルに入れた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの私の裸体が、真夏の陽ざしとどこまで張り合えるかが、個人的な楽しみです』　と、玲子からＦＡＸによる連絡があった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日の夜は自宅にいます』　末尾に恵子は自分専用の電話とＦＡＸの番号を書き添えていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
