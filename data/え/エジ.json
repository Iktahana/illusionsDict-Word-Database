    },
    "definitions": [
      {
        "index": 1,
        "gloss": "gate guard (during the ritsuryō system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "都の入り口には、厳重に武装した衛士が立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜間、衛士たちは交代で門の警備にあたった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "衛士の目を掻い潜り、密かに城内へと侵入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古文書には、衛士たちの俸禄について記されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かるが故にわれは今なお牧場、森林、山岳を愛す、緑地の上、窮天の間、耳目の触るる所の者を愛す、これらはみなわが最純なる思想の錨、わが心わが霊及びわが徳性の乳母、導者、衛士たり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の分封｜太侈を論ずるに曰く、都城｜百雉を過ぐるは国の害なりとは、伝の文にも見えたるを、国家今や秦晋燕斉梁楚呉※の諸国、各｜其地を尽して之を封じたまい、諸王の都城宮室の制、広狭大小、天子の都に亜ぎ、之に賜うに甲兵衛士の盛なるを以てしたまえり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "道衍のと与に酒肆に飲ましめ、王みずから衛士の儀表堂々たるもの九人に雑わり、おのれ亦衛士の服を服し、弓矢を執りて肆中に飲む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門は京に居て龍口の衛士になつたか知らぬが、系図に龍口の小次郎とも記してあるに拠れば、其のくらゐなものにはなつたのかも知れぬ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉と従者は急いで戸の内に避けたが、最後の衛士は呉がここに涼んでいて行列の妨げをなしたのを怒ったらしく、その臥榻の足をとって倒すと、榻は石※をうがって地中にめり込んだ。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛士らはそれから他の宮殿へむかったかと思うと、その姿は消えた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると衛士は、「汝此処に立って法王の許可を待て」　と、法王の旨を伝えた。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "万之助は、懐中していた短刀の柄に幾度も手をかけたが、吉川も同時に討ちたいという気持と、相手が着ている絢爛たる近衛士官の制服の威力に圧倒されて、とうとう手が出なかった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私儀去十二月下旬より足痛相煩引込罷在候而、加藤遠江守様御医師谷村玄申聞候、依之月代仕、湯島天神下薬湯え三廻り罷越申度段奉願上候所、即刻願之通山岡衛士殿被仰渡候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その関門には衛士がいた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一人の衛士が訊いた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ帝が白い高張提灯を二つ点けた衛士を前駆にして行幸になり、四十七士の国法を犯した罪を赦し各の忠義を御褒めに成ると云ふ筋である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（of the guard ＝ beefeater）（英国皇居の）衛士。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ものの役にたつ者といふお見込みがつきましたならば、どうか、衛士となして、都へつかはしてください。",
              "citation": {
                "source": "木曾の一平",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平を衛士として、都を護らしてください。",
              "citation": {
                "source": "木曾の一平",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなく、一平はまだ年が若いにもかかはらず、軍団の兵士にとりたてられ、やがて衛士となつて京都へのぼりました。",
              "citation": {
                "source": "木曾の一平",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "江家次第の平野祭に拠ると、山人は左右の衛士だといふ風にあります。",
              "citation": {
                "source": "神楽（その二）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽家録に拠りますと、人長が手に持つ榊は、御神楽の日に、吉田山・賀茂山などから衛士が伐り出したのを、内侍所の女官に渡して置き、刻限に及んで内侍所の南階の下で、人長が女官から請ひ受ける。",
              "citation": {
                "source": "神楽（その二）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "御神楽や火を焚く衛士にあやからん　　　去来誰と誰が縁組すんで里神楽　　　　　　　其角　一は平凡で、一は奇抜です。",
              "citation": {
                "source": "俳句上の京と江戸",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝殿前で一人の衛士とすれ違う。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安朝になりましては、もはや山人をわざわざ京都まで呼ぶの手数を省いて、左右の衛士が山人の代になって、この儀式をやっております。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "また錦所経には、『江家次第』に散所衛士というのがある趣にみえているが、いまだ本書からこれを見出だすの暇がないから、これまたしばらく保留しておく。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（帝の忠誠の臣として、帝の一個の衛士として、尽くすべきことを尽くせばよい。",
              "citation": {
                "source": "赤坂城の謀略",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しずまれというのに、しずまらぬか」と御下乗の衛士のいうようなことをいって、遠くから久太夫を宥めにかかった。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に眼を定めてよく見ると内裏様もあれば、官女もあり、五人｜囃子もあり、衛士もあり、小町姫もあり、また雛道具としては箪笥、両替、膳、鏡台、ボンボリ、屏風、各形を為して種々雑多のものである事がわかる。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに残忍｜悽愴を極めたのは、山陵衛士に転向したいわゆる高台寺組に対する、彼等の復讐ぶりの徹底的なことであった――それを書いていると長い。",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその光で見ると、門の下にかかっている一方の表札は、「高台寺月心院」　他の一方のは、まだ木の香も新しい表札で、「御陵衛士屯所」とありありと読める。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十七　斎藤一の語るところによると、今晩この男が、御陵衛士隊長伊東甲子太郎を送って、ここのところを通りかかった事情は次の如くでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（腹の具合が良かろう筈がねえじゃないか、医者にもかけねえ、薬も飲まさせねえ、軟かい滋養分も食べさせない、その代りに子供の守をさせてる！",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
