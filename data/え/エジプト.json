    "definitions": [
      {
        "index": 1,
        "gloss": "Egypt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は幼い頃から、埃及のピラミッドに強い憧れを抱いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "埃及文明は、ナイル川の恵みによって栄えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の教科書で、埃及の古代遺跡について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それはこのやうな意識を確認し、かつ表彰し、そしてそれを用心ぶかく慣習のなかへ据ゑつけるのです、そのやうな假定を助けるために、古代の慣習だの、その慣習の名殘りのやうなものだのを求めたり、或ひは埃及の死者崇拜のなかにまでかかる關係の豫知を喚起したりしながら。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（年老いた「歎きの女」が若い死者を案内するところの「歎きの國」は、はつきり埃及として考へられるべきではなくして、單に死の意識の沙漠のごとき明るみのなかへのナイル地方の反映として考へられるべきでありますが。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは湊が中指に嵌めている古代｜埃及の甲虫のついている銀の指輪さえそういうときは嫌味に見えた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "路上のどんな小さな石粒も一つ一つ影を持っていて、見ていると、それがみな埃及のピラミッドのような巨大な悲しみを浮かべている。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃及、印度、支那、阿剌比亜、波斯、皆魔法の問屋たる国※だ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大森は机に向かって電報用紙に万年筆で電文をしたためているところ、客は上着を脱いでチョッキ一つになり、しきりに書類を調べているところ、煙草盆には埃及煙草の吸いがらがくしゃくしゃに突きこんである。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　その日の新聞を開いたときの匂い、初めて見る若い女性に遇うたときの匂い、吸物碗の蓋をとったときの匂い、埃及煙草の口を切ったときの匂い、親友から来た手紙の封を破ったときの匂い。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃及のカタコンブから掘出した死蝋であるのか、西蔵の洞窟から運び出した乾酪の屍体であるのか、永くいのちの息吹きを絶った一つの物質である。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無産思想を通じての有色人種と白人との国際的提携を象徴しようとして赤髪の美婦人は灰面の埃及人と腕組みして行く。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして当時の埃及人が一年を三百六十五日に分けてゐたことも亦、一つの驚異に値することである。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした事実は、古代埃及人の天体の運行に関する智識から生れたものであつて、テーベ（ナイル河の上流の古都）にある紀元前千三百年頃のヱジプト王セテイ一世の墳墓の天井には星座の図が描いてあるのを見ても判る。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いことには群星は素足でゐるが、主立つた星は古代埃及独特の独木舟に乗つてゐる。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代埃及人は、地球の裏には魔者の住んでゐる暗黒の大海があつて、太陽は東から西へと一日の行程が終ると、この地球の裏の魔海を夜間舟で渡つて、翌朝までにまた元の東に帰るのだと信じてゐたといふから察するに星も亦太陽と同様に、舟で暗黒の海を渡ると考へられたのかも知れない。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "駱駝に乗つてピラミツドの周辺を逍遥しての帰るさ立寄つたホテルの露台の籐椅子にもたれて私は埃及の空に輝く星々を心ゆくまで眺めることが出来た。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒々と屹立するピラミツドの頂点辺りに一際大きく光つてゐたのは古代埃及人が一番尊敬した天狼星でもあらうか。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヱジプトでは四年に一度天狼星が日の出と同時に現はれるので、かうした天文現象の文献が古代埃及の年代を計算する一助となつてゐるといふことである。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は埃及の星空を眺め乍ら、私の知つてゐる限りの星座の名を想ひ出して、それを探し求めた。",
              "citation": {
                "source": "星",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャネットに物心がついて母を慕う時分にはカテリイヌは埃及へ行って居た若い建築技師と結婚したものゝ間もなく病死してしまった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度はどうだ、埃及はどうだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波斯軍がアラビヤを過ぎ、いよいよ埃及の地に入った頃から、このパリスカスの様子の異常さが朋輩や部下の注意を惹きはじめた。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃及軍の捕虜共が陣中に引張られて来た時、その中のある者の話している言葉が彼の耳に入った。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリスカスは部下をやって、その捕虜が埃及人か、どうか（というのは、埃及軍の大部分は希臘人その他の傭兵だったから）を尋ねさせた。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに埃及人だという返辞である。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今までに一度も埃及に足を踏入れたこともなく、埃及人と交際をもったこともなかったのである。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗れた埃及軍を追うて、古の白壁の都メムフィスに入城した時、パリスカスの沈鬱な興奮は更に著しくなった。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も（パリスカス自身も）、今までパリスカスが埃及の歴史に通じているとも、埃及文字が読めるとも、聞いたことがなかったのである。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は埃及王プサメニトスに牛の血を飲ませて、これを殺した。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "病後の冬の寒さを避けるためにエジプト旅行に出掛けた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後にはデッキへ出てエジプトコーヒーをすすりながら、エジプトロギーをひやかしなどした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔エジプトの天文学者は地上に環を立てて北極星に面せしめて置き、環の影が丁度一直線になる日を見て春分秋分を定め、これを基として暦を定めたという事で、その時の環が今日でもアレキサンドリアの博物館に保存してある。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
