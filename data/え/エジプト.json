[
  {
    "uuid": "93a552b4-740f-57c6-bc72-01567950d14d",
    "entry": "埃及",
    "reading": {
      "primary": "エジプト",
      "alternatives": [
        "エジブト"
      ],
      "is_heteronym": false
    },
    "grammar": {
