[
  {
    "uuid": "02703a88-1f1a-5365-a235-3be8dbb32ba9",
    "entry": "蝦夷地",
    "reading": {
      "primary": "えぞち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
