    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Yezo (northern part of Meiji-era Japan, esp. Hokkaido, but also Sakhalin and the Kuril Islands)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "明治維新後、蝦夷地は北海道と改称され、開拓が進められた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "江戸時代、蝦夷地への交易は限られた商人によって行われており、その実態は謎に包まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の書物には、「蝦夷地の厳しい自然」についての記述が多く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "北海道のひぐまも虎と同様で、東北日本の陸地の生まれたとき津軽海峡はおそらく陸でつながっていたのではないかと思われるが、それがその後の地変のために切断してそれが潮流のために広く深く掘りえぐられた、それから後にどこかからひぐまが蝦夷地に入り込んで来たのではないかと想像される。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉明天皇の御代、越の国司、阿倍比羅夫出羽方面の蝦夷地を経略して齶田（今の秋田）渟代（今の能代）津軽に到り、遂に北海道に及ぶ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この信濃追分が北越の航路から蝦夷地へ流れ流れてゆくうちに、いつとなく波の響きや艪拍子の中で洗われ揉まれて、遂にはあの船唄としての追分の哀調になったのでしょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "寧親は文化元年五月連年｜蝦夷地の防備に任じたという廉を以て、四万八千石から一躍して七万石にせられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年十二月には南部家と共に永く東西蝦夷地を警衛することを命ぜられて、十万石に進み、従四位｜下に叙せられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の人民の世界にいて事を企つるは、なお、蝦夷地に行きて開拓するが如し。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府の方針が開拓に向けられてるのであるならば、まだ殆んど手をつけていない濶いこの蝦夷地に、彼らの棲む恰好の土地が無いはずはなかった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝦夷地を措いて、生きる余地はすべて塞がれた、と、そう、思いつめた彼らだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで思いはこの蝦夷地に走ったのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新政府の基礎は日毎に固まり、北海道と改めて呼ばれる蝦夷地にも開拓の歩は進められていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、蝦夷地支配の請願についても、官は盲滅法としか思われない漠然とした土地をにべも無げに指定した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "西蝦夷地を目ざすものは向う側から歩いて三日の旅、やれやれと腰をのばすところがこのサッポロ――二人の渡し守りと、数戸の土人の家があったに過ぎない。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝦夷地改め北海道の主都として、面目のために、当地に自費移住するものには家作料を百両貸しあたえた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "糧道を絶たれ、ロ人の武器におびやかされ、われらの根拠地であったクシュンコタンにいたこの堀は、事重大と見て取るや、結氷をやぶって蝦夷地に渡った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁場は宿場になり、内部に広大な土地を控えた蝦夷地の門戸になった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い昔の結びつきを信じ、国の政策である蝦夷地開拓に全身をささげようとし、そういう気持の合致が、ここに長官となり下僚として相見えたのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの古い昔の船々には、西蝦夷地のイシカリ港と喧伝されたこともあったのだが――その頃の目をもってすれば、後の従五位下の開拓判官松浦竹四郎にしても、その名著『西蝦夷日誌』に於て、「不日大阪の如き繁栄をいたさん」と謳っていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蝦夷地といえども例外には致すまい」思いだしたように邦夷がそう云った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、北辺警備の本心を蝦夷地開拓の言葉につつんでうろうろしていた開拓使庁は、漠然とこの地域の一帯をもとの伊達藩にひき渡したのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、この気持が、先年は、彼らをして蝦夷地に来る勇気をふるい起した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの心の中心に坐っているそのひとは蝦夷地にいた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上に、むろん蝦夷地の何十名かが居る。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その同じ運命が蝦夷地にいる家中のものを待っている。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん、政府も、開拓使さえも、深くは蝦夷地を知らないのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「身どもら、不運にして、先祖の地を衛るあたわず、すなわち、棄てて蝦夷地にはしる、されば、生命ある限り二度と再び立ち戻るを得ず、つつしんで永劫の袂別をもうす」　かしわ手の音がつめたく背すじを走った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲の国ロシアのカザリン女帝、不世出の英資をもって、版図を拡め日本の地をさえうかがわんとして虎視眈々、蝦夷地に向かって手を延ばさんとす。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ廃藩が断行され、旧諸藩はいずれも士族の救済に心を砕き、これまで蝦夷地ととなえられて来た北海道への開拓方諸有志の大移住が開始されたのも、これまた過ぐる三年の間のことである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の函館あたりはまだ「蝦夷地」と言いまして、開けたばかりのさみしいところでしたが、先生は六年もそのさみしいところにしんぼうして、病院や医学所を建てたり、薬草園を開いたり、松杉その他の木の苗を内地から移し植えさせたりしました。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「蝦夷地」に緬羊や牛を飼い、養蚕の業につくものができたのも、先生の監督ではじめたことなのです。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛文頃に出来た一種の蝦夷地図（函館図書館）には、今の北海道｜胆振地方と見らるべき地域に、「是より東方日の本と云」と記入してある。",
              "citation": {
                "source": "国号の由来",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "Edo-period realm of the Ainu (as opposed to the Japanese) comprising most of Hokkaido",
        "register": "standard",
