        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の鉄道模型で、SL（蒸気機関車）の走る姿を見るのが好きだったんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "観光列車でSLに乗れると聞いて、すごくワクワクしてる！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館で、古いSLの雄姿を間近で見ることができたよ。迫力満点だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、絵本で見たSLの煙突からモクモクと煙が出る様子が印象的だったな。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "・Ｍ　・ＥＲＥ　・・Ｅ　ＳＬ・ＮＥ・　すると、最初の文字はＡしかありえない。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＡＭ　ＨＥＲＥ　Ａ・Ｅ　ＳＬＡＮＥ・　つまり、この穴にわかっている名をうめると、　ＡＭ　ＨＥＲＥ　ＡＢＥ　ＳＬＡＮＥＹ　『エイブ・スレイニ参上』という意味だ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルはノートブック型にターゲットを置いた高集積度、低電力消費の３８６ＳＬの発表を、今回の社長の来日にタイミングを合わせて行なった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "３８６ＳＬ以上の32ビットを積み、画面上で「どうにかしたいのはここだ」と場所を指し示すポインティング・ディバイスが付き、Ｗｉｎｄｏｗｓがのる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方インテルにも、低消費電力版には一九九〇年十月に発表した３８６ＳＬがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十メガヘルツ版の３８６ＳＸに変えて二十五メガヘルツ版のＡＭ３８６ＳＬを採用したことで、ＶＰｉ３８６の性能は二十五パーセント上がり、電池寿命は十五パーセント長くなったという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳＬＯ――もとのクリスチャニア。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄葉した植込みの奥のもっと黄色い柱列を入って行って、旅券の後に添付されてるＳＳＳＬ居住許可証を返して来た。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＷＳＬ局の『ナショナル・バーン・ダンス』やＷＳＭ局の『グランド・オール・オプリイ』の人気は、カントリー・ミュージックのロード・ショウとプロモーションを生んだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばシカゴのＷＳＬ局で放送されていた『ナショナル・バーン・ダンス』の実況を見るために、一九三二年から一九四二年のあいだに、一〇〇万人以上の人たちが七〇万ドルちかいおかねを払ったのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年にはヴィクターでレコードをつくり、三〇年から三四年にかけて、オートリイは、ＷＳＬ局『ナショナル・バーン・ダンス』のメイン・アトラクションになって人気をたかめ、通信販売デパートのシアズ・ローバック社のレーベルで、レコードをつくった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ熊楠がここに一言するは、壮歳諸国を歴遊した頃は、逢う南中米のスペイン人ごとに余を軽視する事甚だしく、チノ・エス・エル・シウダッド・デル・ハボン（支那は日本の都）といって、日本とは支那の領地の片田舎と心得た者のみだった。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めソシャル・デモクラットとしての一体をなしてストライキを政治的反抗に導いたボルシェビキと｜エス・エルとの分裂。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーシャ、は始めヒメーラと共に仕事をやって居たが、革命が一段落ついて主脳者が皆とっつらまった時、ムーシャは労働者の力を信じ、ヒメーラはインテリゲンチャの買いかぶりエス・エルにのこる。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……北極洋冬季航路開発を遅延挫折させた、モスクワ科学アカデミー教授エス・エル・カルピンスキー博士の反革命的行為は、ただいま、午前十時、公判終結によって、次のように闡明いたしました。",
              "citation": {
                "source": "地底獣国",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
