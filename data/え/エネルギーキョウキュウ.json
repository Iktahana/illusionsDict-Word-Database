        "examples": {
          "standard": [
            {
              "text": "台風接近に備え、電力会社はエネルギー供給網の復旧体制を強化し、緊急対応チームを配置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新たな原子力発電所の建設は、安定したエネルギー供給を確保するための国家的なプロジェクトとして進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「停電しないでね！明日のプレゼン資料、全部PCに入ってるんだから！」と学生は、エネルギー供給の安定を願った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "生体は脂肪や炭水化物のような主なエネルギー供給物質だけでなく一定量のタンパク質およびある種の微量物質を必要としている。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
