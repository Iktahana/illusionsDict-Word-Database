        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのニュースを聞いて、彼はショックのエフェクトを受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この化学反応は、予期せぬエフェクトを引き起こした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "音楽のボリュームを上げると、部屋全体に響くエフェクトが生まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の言葉は、まるで魔法のようなエフェクトをもたらした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さまざまな尊き内容を持つ言葉や文字が、十分に実践的な意志を伴なわずに表現せられるときには、それのエフェクトはインテンシチーの足りないものとなって受け取られます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "床面に音楽的エフェクトあってよし。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め、市の小役人の出入りするところ、例の、銅の狭い戸から一度に、オペレッタ風に出させ、ひっこませ、手紙をよむところは、小ステージの上につみかさねて、顔々だけ燈明を加え、ドラクロア的エフェクトを出した。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そでなど、出て来るな、という予感を与えて出す、ダイナミックと正反対な、新派的エフェクト。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚のエフェクトを最大にすること。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルビンシュタインはグループのエフェクトで音を出した。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服のエフェクト、光、ひどく巧く、利用しすぎる位利用して居る。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "光と色の微妙なるエフェクトを花火の技術から感ずるものは、その人自身すでに一個のアアチストである。",
              "citation": {
                "source": "仙人掌と花火の鑑賞",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが実際上のエフェクトから云って進歩的な役割をもつか反動的な役割をもつかは、一概には決まらないが、とに角、興味は進歩や反動にあるのではない。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな風に見て、どんな風に描くか、どんな風に色を塗るか、どんなエフェクトを狙うかとかなんとか言うのは問題ではないんだ。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩松の絵、どうも見た目のエフェクトを狙うことが巧みすぎる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "平福百穂の美しい原画（菊池寛かの）があったが、それが表紙になったところみると、印刷のエフェクトひどいのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも大作を描き、いつもこういう更紗ばりのような展覧会エフェクトの多い画面です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嵐の海でサーファーが雷に打たれるシーンは、スペシャル・エフェクトでやろうとしたのですって。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
