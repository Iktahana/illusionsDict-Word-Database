    "definitions": [
      {
        "index": 1,
        "gloss": "female elevator operator",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "古い映画のワンシーン、デパートの優雅なエレガさんが客を案内していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「〇〇階へどうぞ」と、制服を着たエレガさんが笑顔でドアを開けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はかつて、高級ホテルのエレガとして働いていた経験があるらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの頃は、エレベーターガールって呼んでたわね」と、昔を懐かしむように彼女は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それまではエレガントな巴里人が指で食物を掴んだ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　エレガントといっても可いような、その立派な容貌風采、十数年の昔ではあるが、松本｜泰氏と会った時には、威圧をさえ感じたものである。",
              "citation": {
                "source": "日本探偵小説界寸評",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四角い帽子をいただいた二つの頭は、果して新しき老農夫を満足し啓蒙するだけの知識をもっていながら、彼等が余りエレガントであるために只ああやって蒼白き微笑のみで答えたのか。",
              "citation": {
                "source": "北へ行く",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に世故にたけていることも、エレガントであることもできないのである。",
              "citation": {
                "source": "十月の文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "製造コストはかさむが、ジョブズは美しいプラスチックの筺体を用意することで、誰もが触ってみたくなるようなエレガントな道具にアップル※を仕立ててみたかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがエレガントな道具を目指すジョブズは、アップル※を静かなマシンにしたいとこだわった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒル・フアルマシイだとか、エレガントだとか云ふ店は毎年輕井澤に出張してゐるので私には懷かしく、ちよつとその前を素通りしかねた。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大柱はマホガニーでありまして、華麗極まる大理石模様を、総体に現わしているところなど、エレガントと云ってもいい程でした。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスにも、エレガンス・ネグリジェといふ言葉がありまして、「身なりをかまはぬやうにみせた身だしなみ」を指すのであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "トニメレスルス・エレガンスに似ていますが、それよりもすこし長くて九十五センチぐらいありました」「それはたいへん。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒル・ファルマシイだとか、エレガントだとか云う店は毎年軽井沢に出張しているので私には懐しく、ちょっとその前を素通りしかねた。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……パリにおけるコレラによる死亡は多く、1832年にエレガントなショセ・ダンタンやモンマルトルのような高台では１万人あたり80人であり、オテル・ド・ヴィル（市庁舎）やシテ島のように低いところでは530人および520人であった（p. lxxviii）。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ逆立ちでも、フランス風の逆立ちはこんなにもエレガントなものだということを即物的に証明し、〈巴里にいる日本の女のかた〉の骨のあるところを見せ、全体主義の度胆をぬいてやろうというわけなんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしたちが二三人ずつアト・ランドムに日覆の下へ入って行くと、だれがやってもこれ以上自然にやれまいと思われるようなエレガントな身ぶりで、士官たちがいっせいに椅子から立ちあがった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は最も良心的に清潔であることが要求され、贅沢から遠く離れたエレガンスを養うように勧められる。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの本のスタイルはエレガントであり、病気についての彼の記載は正確であった。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃれやエレガンスと共にそこで学んだのであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
