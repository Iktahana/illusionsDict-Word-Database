        "examples": {
          "standard": [
            {
              "text": "夕暮れ時のエスプラネードを散歩していると、海からの心地よい風が通り抜けていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ホテルの目の前に広がるエスプラネードでは、朝早くからジョギングを楽しむ人々の姿が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地元のフェスティバル期間中、エスプラネードには色鮮やかな屋台がずらりと並び、多くの観光客で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ねえ、あそこのエスプラネードに座って、少し沈む夕日を眺めていかない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "エスプラネードを歩く。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
