    "definitions": [
      {
        "index": 1,
        "gloss": "defiled body",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "僧侶は穢身を清めるために、滝に打たれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "穢身を厭い、彼は世俗との縁を断った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "罪を犯した者は、穢身を抱えて苦しむ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その儀式は穢身を祓う意味合いを持つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "肉体の知覚がなくなると、範宴は自分の肉体のうちに、冬の月のような冴えた魂が無想の光にかがやいているのを見いだして、（ありがたや、自分のような穢身のうちにも、弥陀如来が棲みてお在す）と思った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて罪科の償いを果たして、この穢身を洗わないことには、どうも白日の下で、人なみの口もきけません。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが十一時を過ぎても、他の場所だったら、たとえしんしんとした神社の中でも、淋しい野の中でも、彼女は何かしら生々としたものを、血の通ってるものを、示してくれるだろう。",
