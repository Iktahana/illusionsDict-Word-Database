[
  {
    "uuid": "c862855e-a3b9-58af-aaa1-7ce514caa23c",
    "entry": "宴楽",
    "reading": {
      "primary": "えんらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
