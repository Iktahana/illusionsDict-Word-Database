    },
    "definitions": [
      {
        "index": 1,
        "gloss": "merrymaking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夜遅くまで宴楽の声が響き渡り、村はお祭りムードに包まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "豪華な料理と美酒に酔いしれ、人々は宴楽に興じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦乱の世に、つかの間の宴楽を楽しむ人々がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "聞いてみると、それは米相場をやる人の家で、この家の宴楽の声が米の値段のメートルだというのであった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる暴虐に飽いた身を宮殿をしのぐような六波羅の邸宅の黄金の床に横たえて、美姫を集めて宴楽にふけっております。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅泉の壮時、「挾粉白、擁黛緑、日会諸友、大張宴楽」の処が即此荘であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かくて山々は遊興と宴楽の巷と化した。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬えば道徳の説法はありがたきものなれども、宴楽の最中に突然とこれを唱うればいたずらに人の嘲りを取るに足るのみ。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、詩は田園の遊戯や祭日の宴楽から多くの主題を得たのだが、今でもそれをなつかしみ、纏綿としてはなれない。",
              "citation": {
                "source": "クリスマス",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "その行事としては、その熊を祭場に引き出し、その前にてアイヌの第一の嗜好物たる酒を供して神を祭り、結局ここに盛大なる歌舞宴楽を催すのである。",
              "citation": {
                "source": "奥羽地方のシシ踊りと鹿供養",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう酒宴に比べれば、今日荘園邸でもよおされる宴楽などは、ほんの影にしかすぎない。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　騒ぎは一瞬にして宴楽の席に水をブッ掛けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィナス窟のタンノイザーの宴楽よりも、殺生関白の荒淫よりも、吉田御殿の歓楽よりも猛烈を極めました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第一夜　初夜を盗む",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し歓楽の余燼は、その下から情火を煽って、恐れと疑いとの中にも、二人の宴楽は暁方まで続きました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第一夜　初夜を盗む",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角あの浴室の光景などは、其夜東方の丘の上の春の宮殿で催された宴楽の余興に較べたなら、殆ど記憶にも残らない程小規模のものであった事を附加えて置けば沢山です。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はすべてが懶く、熱に浮かされ、乱れた悲しい目つきを暗夜のうちに据え、宴楽の帰りのにぎやかな連中を乗せてそばを通りすぎてゆく楽しい馬車の響きとほこりとに脅かされ、意気消沈して、頭をはっきりさせるために途上の胡桃の木立ちのかおりを胸深く吸い込みながら、家に帰っていった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニュエルは気高く、パリーは聖き宴楽にふさわしく、フォアは怒号し、また君が胸衣には一つの針ありて常にわが身を刺したりき。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまごろ彼は、誰も彼の意にさからう者のない閣議にのぞんでいるか、あるいはまた、明日の狩猟のことや今晩の舞踏会のことを考えていて、宴楽は適宜の時にいつでも得られるものと安心し、自分の快楽のための仕事を他人に任せきりでいる。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かかる折こそ」とばかり、舎人たちは、宵の早くから酒を持ち込んでいるし、上達部たちは、宴楽に耽けっているし、衛府の小者などは、御門が閉まると、交る交る町へ出ては、遊んで帰った。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、五代綱吉は、臣下の柳沢吉保の招待をよろこんで、年に何回となく、その邸へ臨み、その宴楽がまた――この世をばわが世とぞおもふ――と歌った藤原道長の栄華もおろかな程なものであった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間、永野九十郎という旧家臣が、能役者の仲間に交じって、宴楽に来たのを、当主の頼房が見つけて、（武士の体面を穢すもの）　と、手討にした。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今日はまた、お客人を招いて、御宴楽の折とみえる。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴楽には、倦むことを知らないらしい。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伊予にいれば、国司の腐敗や、郡司の弱い者いじめが、目にふれて、黙っていられなくなるし、都に出れば、朝廷を栄花の巣にして、明け暮れの猟官、夜も日もない宴楽、小刀細工をして立ち廻る小人輩の讒訴だの、何だの、かだの……。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女も、上流人の宴楽に侍る白拍子という妓のひとりでしかなかったのである。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "居室をそのまま、宴楽の席とするようなことはない。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家康のとりなしで、後にようやく、信長も怒りを解いて、「ゆるしおく」　とはいったが、そのため、一時はみなどうなるかと、きょうの宴楽も仇に思われたほどだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた宴楽のあいだには、外交の詭計、私交の虚実、人物の試胆、戦不戦の打診など、善悪あらゆる機微のものも美味声色を仮りて入り交じっている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ここでなくとも、家康はあまり宴楽に興味がない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　洛陽の都会人は、宴楽が好きである。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、朝廷の宴楽台に、酒宴のあるという少し前であった。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼と玄徳との交わりは、日をおうほど親密の度を加え、朝に出るにも車を共にし、宴楽するにも、常に席を一つにしていた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝賀、礼杯の儀式もすすみ、宴楽の興、ようやくたけなわとなった頃、楽寮の伶人や、鼓手など、一列となって堂の中央にすすみ、舞楽を演じた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
