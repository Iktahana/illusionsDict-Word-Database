[
  {
    "uuid": "42859f39-5381-5638-a372-6980d2bdf0f0",
    "entry": "エッフェル塔",
    "reading": {
      "primary": "エッフェルとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
