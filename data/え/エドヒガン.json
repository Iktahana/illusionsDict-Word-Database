      {
        "index": 1,
        "gloss": "double weeping rosebud cherry (Prunus pendula)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
