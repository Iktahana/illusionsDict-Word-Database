[
  {
    "uuid": "36db21cc-a025-5c9d-902e-84db090683ce",
    "entry": "偉そう",
    "reading": {
      "primary": "えらそう",
      "alternatives": [
        "エラソー",
        "えらそー"
      ],
      "is_heteronym": false
    },
    "grammar": {
