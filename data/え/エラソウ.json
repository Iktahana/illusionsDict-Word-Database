      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "self-important",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「彼はいつも偉そうで、部下が気軽に話しかけられない雰囲気なんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あの新人、まだ何も分かってないくせに、やたら偉そうで鼻につくよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「先生がいないところで、子供たちが勝手に偉そうなことを言ってたよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "偉そうな事を言ったって、こいつは、どうせ俗物に違いないんだ。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、眼玉が出しゃばって、嘴が細くて、ちょっと見掛けは偉そうだよ。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "淋しい顔をしている人が、なんだか偉そうに見えて仕様が無い。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかに偉そうにしているが、女には、もてませんね。",
              "citation": {
                "source": "容貌",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱い男というものは、少しでも自分の得になる事に於いては、極度に恐縮し汗を流してまごつくものだが、自分の損になる場合は、人が変ったように偉そうな理窟を並べ、いよいよ自分に損が来るように努力し、人の言は一切｜容れず、ただ、ひたすら屁理窟を並べてねばるものである。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことの臆病者の丹三郎は、口ではあんな偉そうな事を言ったものの、蛸め、つづけ！",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の足下が崩れかけているのも知らずに、偉そうなことばかり喚き立てていやがる）　正勝はそう思いながらも、微笑を含んで黙りつづけた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このハドソンって獣は、さらに出しゃばるようになって、終いには、ある日、僕の目の前で親父に偉そうな口の利き方をしたんだ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか偉そうで、なるほどきびきびした男だ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とグレグソンは偉そうに胸を張って、厚い手をこすった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし名前だけはＩＢＭらしく、これぞパーソナルコンピューターとふかしをかまして「ＰＣ」と偉そうなのを付けた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉そうに大声で言うことでもないが、危機はもう一方で挑戦のための最良のチャンスでもある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからフロックコートや何か着た偉そうな男がたくさん集って、自分が存外幅のきかないようにみえたことであった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こことおっしゃりまして、お偉そうにおつむをたたきなさいましたところをみますると、知恵で白状させてみせるとおっしゃいますのでござりまするな」「さようじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとがふらふらしていらっしゃるが、日ごろ偉そうなことをおっしゃって、だんなもあのべっぴんの雪の膚を見てから、脳のかげんがちっとおかしくなったんじゃござんせんかい」「やかましいや！",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「偉そうな口をおききだが、そういうおまえはどうだい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その中で一番「偉そうな人」が風を喰らって逃げたのかな、と云ったそうである。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か偉そうなことをうっかり喋べってしまって、その議論が自分自身でも明日はすっかり変ってしまうようなことが無いとも限らない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "碌々人のいうことも聞かないで偉そうな面ばかりしてやがら、よっぽど人を馬鹿にしてやがるんだろう。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな新聞は、宮城裁判長が大変偉そうに書いているが、それは事実でないということが暫く公判をきいていると私でさえ分りました。",
              "citation": {
                "source": "共産党公判を傍聴して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか彼とか、偉そうなこと、つよそうなこと、階級的そうなことを云っても、対手の女を見ると、その男の非公式な部分、書いてない部分が露出している。",
              "citation": {
                "source": "ゴルフ・パンツははいていまい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那町｜傅家甸の新世界で、川鮑魚湯だの葱焼海参だのと呼号する偉そうできたない食を喫したのち、私たちは不可解な腕車をつらねて、喧騒と臭気と極彩色と殷賑と音響のなかを大通りキタイスカヤ街へ出た。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那に来ている日本人は皆偉そうぶって、苦力を足で蹴飛ばしている訳だから。",
              "citation": {
                "source": "苦力頭の表情",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも今日の人々は祖先を哂いながら、さも偉そうに大きな顔はしているけれど、豈図らんや自分たちもまた、やがては後世の物笑いになる数々の新らしい誤謬を犯しはじめているのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "無学で――それは彼もおなじなのだが――平民というと、見下られるものとのみこんでいた無智な仲間は、娘を売るような士族でも偉そうにあつかったので彼は得意だった。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、何々院殿という偉そうな名にはなったが――　しかし、もとの墓主だって、私は美女ときめているが、どんな人だったのか、それはわかりはしない。",
              "citation": {
                "source": "お墓のすげかえ",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にきく種々な修身談は、はじめから偉そうに、吃々と、味のない、型にはまりきったことをいうのばかりだ。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども何か僕らには偉そうに思われてしかたがなかった。",
              "citation": {
                "source": "追憶",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの狭山という男は、課長とか何とか偉そうな肩書を振りまわしているが、案外だらしのないそそっかし屋だ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へええ、貴様あとからえらそうなことを云ってやがら。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
