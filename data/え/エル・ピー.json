        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "The Liberal Party unveiled its new policy proposals ahead of the upcoming election.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "During the debate, the Liberal Party leader focused on economic growth and job creation.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Voters are weighing the Liberal Party's platform against those of other major parties.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "The Liberal Party has historically been a significant force in national politics.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Discussions about social welfare often involve the Liberal Party's stance on government spending.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
