    "definitions": [
      {
        "index": 1,
        "gloss": "LP (record)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "I just unearthed my dad's old vinyl collection; there are some incredible LPs in there!",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "My turntable is ready for a spin – I'm excited to play this rare jazz LP I found.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "There's just something special about the warm sound of an LP that digital formats can't quite replicate.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "I've been expanding my music collection, focusing on original pressings of classic rock LPs.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Oh wow, is that the original pressing of that album on LP? That's a gem!",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ミップスに背を向けて、独自に開発した64ビットのＡＬＰＨＡを一九九二年二月に発表し、これを将来構想の中核に据えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミップスの最高速版であるＲ４０００の８０ＭＩＰＳに対して、ＡＬＰＨＡは３００ＭＩＰＳはでるという触れ込みで、商売人のビル・ゲイツはさっそくＷｉｎｄｏｗｓ　ＮＴをＡＬＰＨＡに載せると言いだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題は、四月十五日に、ビートルズの新しいＬＰが発売されることだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく、このＬＰはいいね、『ヘルプ！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柾生、なにかもってきたんだろ」　と、柾生のとなりのイスにおかれたＬＰの袋を見る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＬＰが一八〇〇円として五〇枚、残りの金で、コンパクトなら二〇枚、シングルなら、えーと、会社によってちがうけど、三七〇円として、二六枚か二七枚も買える！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいなあ」　たった四枚しかＬＰをもっていない慶一は、それが五〇枚もならんでいるさまを空想した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＬＰにして、五〇枚以上じゃん！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五〇枚のＬＰというのは、圧倒的な魅力だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートルズのＬＰ買うと切符が当たる、なんてセールやってさ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志が見ている列のわきには、ジョニー・リヴァーズのＬＰと、マインドベンダーズの〈グルーヴィー・カインド・オヴ・ラヴ〉、シェールの〈バン・バン〉がおいてある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＫＷＴＳの備品だからな」　高志は、ＬＰの袋をわきの下にはさみ、領収書を大切そうにサイフにしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ、あいつには気をつけろよ」　ラヴィン・スプーンフルのＬＰジャケットを、顔のまえでヒラヒラさせながら、高志がいった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくのＬＰを、シングルみたいにあつかうことはないのに……。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一が空想した五〇枚のＬＰを、すでに超えている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シングルのほうに予算をとられるので、なかなかＬＰは買えない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワラが、これが入った『ファビュラス・ロネッツ』などという、めずらしいＬＰをもってきたときは、これで高志に一発かませる、と大喜びしたのだが。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどＬＰ買ったら、またかける」「キース・ムーンて、最高じゃん」　といって、服部は「ＣＯＭ」をテーブルに投げだした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ここには十数枚のシングルと、六枚のＥＰ、それに三枚のＬＰしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "出したばっかなのに、またすぐＬＰが出るわけない」　服部がこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十数日、地上からほかのＬＰがすべて消滅してしまったのかと思うほど、どこへいっても、こればかり聴こえてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二枚のＬＰには、四千円という値札がついている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで何んとか読めないか」「ＢＥＬＰ…………」「ＢＥＬＰはおかしいな、そんな字は無い、して見るとなんか偶然に付けた印かも知れないね」　私はそう申しました。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は新聞二三種へ目を通して、葉巻を一本つけ換えて、淡路島名物の涼風に吹かれ乍ら、いい心持でウトウトして居ると、いきなり、「ＢＥＬＰ――外に何んとか読みようは無いものでしょうか」　愛子はまだそう言って居ります。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハアと読む、ではＢＥＬＰではなくて、ＨＥＬＰではないか。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＥＬＰ、ヘルプ、助け。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨＥＬＰ、ＳＯＳ、私の頭の中には、この七つのローマ字とオタマジャクシが、妖精のように入り乱れて踊り狂いました。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやいや、困った莫迦者だて」２　エル・ピー通信社の編集長室にて。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "linear programming",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
