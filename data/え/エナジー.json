        "examples": {
          "standard": [
            {
              "text": "「よし、いくぞ！」と気合を入れ、ステージ裏でエナジーを蓄える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若いダンサーたちの爆発的なエナジーに、観客席からも熱い歓声が上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近どうもエナジー不足でさ……」と、友人は力なく笑って見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし彼の生活はエナジーの生活であつた。",
              "citation": {
                "source": "生みの力",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドストイェフスキーは實にどういふ意味に於いても「猫のやうなエナジー」を有つた人であつた。",
              "citation": {
                "source": "ドストイェフスキーに就いて",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のエナジーを喰うて生きるのやさかい、おのれの脚を喰らうて生きるタコと変りまへんがな……」と五月女君のタコ哲学の一席。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "「革命的エネルギー」という言葉があるが、それは一種のポテンシャル・エナジーで、転向・転下によって、このエネルギーがディスチャージ（？",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
