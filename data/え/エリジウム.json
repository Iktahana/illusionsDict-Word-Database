        "examples": {
          "standard": [
            {
              "text": "神話の世界におけるエリジウムは、常に春のような穏やかな気候に包まれているという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新のRPGで、最終ダンジョンの名称が「エリジウム」に設定されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「エリジウムへの道は険しいが、諦めずに進もう」と冒険者は仲間を鼓舞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「霊」が私に書けと命じ、完成せよと命ずることがらを成就してその後に、私は「エリジウムの野」（「幸福なる者たちのいる仙境」）へ降りて行くでしょう。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
