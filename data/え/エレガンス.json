        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の立ち居振る舞いには、天性のエレガンスが漂っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "そのバレエダンサーの演技は、息をのむほどのエレガンスに満ちていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "シンプルなデザインでありながら、高級感とエレガンスを兼ね備えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、なんてエレガンスなの！」と、友人は新しいドレスを見て感嘆の声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "フランスにも、エレガンス・ネグリジェといふ言葉がありまして、「身なりをかまはぬやうにみせた身だしなみ」を指すのであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "トニメレスルス・エレガンスに似ていますが、それよりもすこし長くて九十五センチぐらいありました」「それはたいへん。",
              "citation": {
                "source": "大使館の始末機関",
                "author": "――金博士シリーズ・７――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は最も良心的に清潔であることが要求され、贅沢から遠く離れたエレガンスを養うように勧められる。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしゃれやエレガンスと共にそこで学んだのであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
