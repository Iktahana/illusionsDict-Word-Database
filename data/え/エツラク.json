    "definitions": [
      {
        "index": 1,
        "gloss": "joy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "美味しいケーキを口にした瞬間の、あの至福の悦楽！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長年追い求めていた目標を達成し、彼は静かな悦楽に浸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "自然の中で深呼吸をするだけで、心が洗われるような悦楽を感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ああ、この瞬間こそが人生の悦楽だ」と彼は呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その時代には、一般世間の経済観念もきわめてルーズであり、貧しいものには貧しいなりの生活の余裕と悦楽があり、行き詰まってもどこかに抜け道があって、宵越しの金は腐ってでもいるように言われ、貧乏人の痩せ我慢が市井の美徳としてまだ残っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人の居ないところで、どこか内証に帽子を被り、鴎外博士の『青年』やハイデルベルヒを聯想しつつ、自分がその主人公である如く、空想裡の悦楽に耽りたいと考へた。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日に何千何万といふ人命を賭にして此本能に飽満の悦楽を与へるのが戦争であるとは、誰しも云ひ得まい。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる都会の文化も悦楽も青年の魂を慰めなかった。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "智子の最初の片輪に対する同情は追い追い三木雄への尊敬と変り、三木雄の暗黒世界を開拓する苦労を智子は悦楽にさえ感じて来た。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、凡て予が拠る所は僅かなれども生れて享け得たる自己の感覚と刺戟苦き神経の悦楽とにして、かの初めより情感の妙なる震慄を無みし只冷かなる思想の概念を求めて強ひて詩を作為するが如きを嫌忌す。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　私の哀しい Nostalgia がまた一絃の古琴にたまたま微かな月光の如くつかずはなれず付纏ふ時に、ある若い人達の集団はこれを唯一の楽器として、行住座臥、凡ての清新な情緒と凡ての苦い神経の悦楽とを委ねて満足してゐる。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の悦楽にたましひのふかきうめきを忍ぶにか、かつ現身を悲哀の糧と食むにか、さげすむか。",
              "citation": {
                "source": "緑の種子",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、バイト先の旦那に生まれてはじめてキャバレーに連れていかれて悦楽の夜を過ごした翌日、感動の余り「生まれてはばれてキャバレてアワワ〜」としどろもどろにホステスの手厚いもてなしの一部始終の報告に及び、以来ヤツは好感度ナンバー・ワン男と化した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟よ、われ等の肉と血潮の上に、脂切つた肉体と、それを包む華美な衣服と、荘大なる邸宅を載せて、悦楽を貪る資本家に反抗してはならぬ。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "富や悦楽は相対的なものである。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の悦楽のためにはこの船長はおれたちの生命を、いつでも鱶の前に投げてやるだろうに。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "放庵位、仕事を楽しみ、悦楽の境地においてゐる日本画家がゐるであらうか、芋銭はその楽しみ、悦楽を果して一生を終つた人であるが、放庵に於いても、仕事を楽しむといふ境地は、芋銭と等しいものがある。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊躍歓喜心悦楽し、信心踊発して十力を念ず、願わくば今日の後常に然らん事をと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と別れてしまうことに依って、異常な絢爛な人生の悦楽を、味う機会が、永久に失われてしまうようにも思われた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼に何の悦楽も与えないで、ただ、永久に満たされないもどかしさを与えるだけだった。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "何に換へても、強いといふ自信が弥が上にも私達を悦楽の雲上に遊ばせた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人と別れてしまふことに依つて、異常な絢爛な人生の悦楽を、味ふ機会が、永久に失はれてしまふやうにも思はれた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭いメスの先で一本一本神経を掘り出して行く時の触感、内臓に刀を入れるときの手ごたえに私は酔うほどの悦楽を催おし、後には解剖学実習室が私にとって、楽園となりました。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒がうまくなくなることは――酒で無理をしなくなることは、私の苦悩がなくなることであるが、それは同時に私の悦楽がなくなることでもある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きてゐる幸福、歩いてゐる悦楽。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろその業を悦楽してゐる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思ふと、大変に元気づいて、調子に一種の悦楽を帯びて来る。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も空想や幻想が頭の中に簇がり起っている場合、若しくは強烈な官能の悦楽に耽っている場合などはそれを忘れてはいるが、まったくそれ等のものを奪われるか、失うかしてしまった時の自分は必ず激しい焦躁と倦怠とに苛まれて、何処かに動き出さずにはいられなくなるのである。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯の時、台所に出て女中を手伝い、「御飯よ」と云い乍ら皆を呼んで歩くことは、決して、先のように楽しい、活動的な悦楽ではなくなってしまったのである。",
              "citation": {
                "source": "小さき家の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の繁栄は今日の没落、本条純八は暫くの間は夢｜現の境に彷徨したが、此の著しい変転は却って彼には良薬となり、俄然精神が一変し、現世の悦楽を求むる代りに、虚無融通の神仙道に、憧憬の心を運ぶようになった。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば生命水の河の詩に「路旁生命水清流、天路行人喜暫留、百菓奇花供悦楽、吾儕幸得此埔遊」と云ふが如し。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、たよりない身の上よりか、たとえつらくても、にぎやかな町の中を歩いて、いろいろなものを見たり、聞いたりするほうが、どれほど、ましであったかしれなかったからです。",
              "citation": {
                "source": "河水の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "是を以て其父母、其人を知らまく欲て、其女に誨えつらくは、赤土を床前に散らし、閇蘇紡麻を針に貫て、其衣の※に刺とをしう。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
