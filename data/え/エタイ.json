    "definitions": [
      {
        "index": 1,
        "gloss": "nature",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの神秘的な芸術家の真の「得体」を掴むのは難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人の「得体」は、見た目だけでは決して判断できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "何年も演じ続けた後、彼はついに本当の「得体」を明かした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "折々堪らないやうに双眼の切れ目から輻射状の皺を発したが、それでも更にそれらの喫殻に手を下さうとしないのは、明かに彼自身にも得体の知れぬ悶えが、彼の中を横行してゐたからである。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小村は立ち止まって、得体の知れない民屋があるのを無気味がった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それははじめ荒々しく彼をやっつけたが、遂には得体の知れない感情を呼び起こした。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴が清水の土地を思い切り、美濃の檜木の瑞雲寺へ入って馬翁という詩僧に従ったのは、勿論、娘と得体の判らぬ心理の関係にある、その境地から逃れよう為もあったが、僧でもなく俗でもない身持で、風雅に対してだけ快楽を求める生活が、俄に不安を増して来たからだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで鬱積していた得体の判らぬ心情、それがあの煙となって渦巻き上っているのだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "室子はそういう場合、得体の知れぬ屈辱感で憂鬱になる。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上得体も知れぬ虫がウジウジ出て来て、誰かの顔へは四寸程の蚰蜒が這い上ったというので大騒ぎ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十二）　何しろ、得体の判らぬ男であるが、何時まで睨み合っていても際限がないと、市郎の口も解れ初めた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、仲間でも何でもない得体の知れぬ女が、毎日同じ時刻に、誰と会うわけでもなく、一人でトグロを巻きに来ているのだ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも小沢は、何かしら得体の知れぬ予感を感じて、どきんとした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊部――今朝、渡辺橋で釣をしていた得体の知れぬ奇妙な男！",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、第一ホテルからこの劇場へ来る途中、電車の中で話しかけて来た得体の知れない中年男だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客は私と商人のパリロ氏と牧場主のラメツ氏と医師のフェリラ氏とそしてその他に全く得体の知れぬ二人連れの男女が乗っていた。",
              "citation": {
                "source": "薔薇の女",
                "author": "渡邊温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした想像の謎の中で、得体のわからぬ一つの予感が、疑いを入れない確実さで、益※はっきりと感じられた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は何と云い返そうかと、息を詰めた途端に、急に得体も知れない怯えが来た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のように一生という永い時間をかけて、世間という広い広い部屋で、筆を小刀に心身を切りこま裂いて見せ、それで真実が届くやら、届かぬやら判りもしない、得体の知れない焦立たしいなやみの種を持つものは、割の悪い運命に生れついたものである。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら此の得体の解らぬ自分の巴里滞在期を清算して白髪のほつれが額にかゝる日本の妻のもとへ思い切りよく帰れよう。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも得体の判らない家の生活に混っていると、いつまで経っても割り切れない奇数の出続ける数字を扱っているようなもどかしさから不安の気持に襲われました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、いくら解放されるからといっても、また元のあの得体の知れない倶楽部のような母の家へ帰る事はどう考えても気が乗りません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこの頃の僕は、家の者には得体の判らない人間になっていたから」　わたくしは、これを聞いては、行末、見定められぬ自分ではありますが、やっぱり、「東京へ帰ったら、あたしが何とかするわ」　と慰めてやらないわけには行きませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木崎が外科手術を連想したのも、一つにはその男たちへの得体の知れぬ憎悪からであったろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわれんでいるものを、逆に残酷に苛めたいという得体の知れぬ衝動だろうか、それとも、反撥し、嫌悪しているものに逆に惹かれるという自虐作用であろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、それがなぜか得体の知れぬ不思議な魅力であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「本当にそう言ってもいいの」「警察もへちまもあるもんか」　坂野は身上相談欄で悪徳巡査のことを読んでたので、まるで自分の細君が巡査と逃げたような錯覚を起していたせいか、ふと警察への得体の知れぬ反撥を感じていたようだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "得体の知れぬ悔恨であった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か得体の知れぬものが陽子を引き戻したのではなかろうか。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時のことを、北山はなまなましく想い出して、溜息とも叫びともつかぬ、得体の知れぬ声をうめきながら、ぶるんと首を振っていると、電車が来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな競走が続くと、もう誰もかれも得体の知れぬ魔に憑かれたように馬券の買い方が乱れて来る。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "随筆など書いて人に読んでもらおうというのはどの道何かしら「訴えたい」ところのある場合が多いであろうと思われる。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像だけでは物足りない、確かな事実を捕えたいというのが学者の願である。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
