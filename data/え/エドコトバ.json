        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "落語家は江戸言葉を巧みに操り、聴衆を笑わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父が時折使う江戸言葉は、聞いているだけで懐かしい気持ちになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "時代劇を見ていると、自然と江戸言葉のイントネーションが耳に残る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "』　矢がすりの袷に、赤の帶の竪矢の字を背中に負うた侍女が、次の間に手を支へて、キッパリと耳に快い江戸言葉で言つた。",
              "citation": {
                "source": "死刑",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "京言葉、江戸言葉の比較とも変りません。",
              "citation": {
                "source": "俳句上の京と江戸",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然淘汰優勝劣敗の原則がここにも行われて、適者優者が生存して、ここに江戸言葉というものが出来た。",
              "citation": {
                "source": "特殊部落の言語",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣を付けるつもりでも、なか／＼江戸言葉が使へません」「そんな事を氣にする奴があるものか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美女を洗ひ出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そいつは皆んな江戸言葉かい」「里言葉を使わないのが不思議なくらいでしたよ、身扮は町人風武家風、いろいろあるが、間違いもなく日本人で――」「何を言やがる」　ガラッ八の説明を聞いただけでも、その歓楽が並大抵のものではありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは純然たる江戸っ子で、じつに綺麗な江戸言葉を使っておられた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を付けるつもりでも、なかなか江戸言葉が使えません」「そんな事を気にする奴があるものか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "美女を洗い出す",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の水が戀しくつて、弟に世帶を讓つて此方へ來たといふくらゐだから」「妹二人も江戸言葉か」「へエー、小さい妹――頤に痣のあるお雪といふのが十九で。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の水が恋しくって、弟に世帯を譲ってこっちへ来たというくらいだから」「妹二人も江戸言葉か」「ヘエー、小さい妹――顎に痣のあるお雪というのが十九で。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "勉強によって、江戸の知識は仕入れることが出来るが、江戸言葉となると容易ではない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなで話をさせて、久しぶりの江戸言葉で、ばかげたようなたあいのない話をするのについ笑ったこともある。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、この女のなだらかな江戸言葉で、江戸の風物を語られることは、決して悪い思い出ではない。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
