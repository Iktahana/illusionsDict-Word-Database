        "examples": {
          "standard": [
            {
              "text": "各国は、自国のエネルギー資源の確保と、それを活用するための技術開発に力を入れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "北極圏の新たなエネルギー資源開発は、国際的な関心を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「これらの枯渇しないエネルギー資源を、賢く使っていくことが未来への責任だ。」と環境活動家は訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "水にあり余るほど恵まれている国日本で、エネルギー資源の窮乏にあえいでいるのは、何といってもいばれた話ではない。",
              "citation": {
                "source": "アメリカの沙漠",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから地熱のほんの一部でも、もし巧く利用することができれば、これまた日本の重大なエネルギー資源となる。",
              "citation": {
                "source": "温泉２",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本には、この豊富な水力電気資源のほかに、いま一つの大きいエネルギー資源があって、それはこの地熱である。",
              "citation": {
                "source": "温泉２",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
