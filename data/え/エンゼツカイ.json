        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "候補者は、支持者を集めるため、連日各地で演説会を開いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学の学園祭では、著名なジャーナリストを招いた特別演説会が開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "地域活性化を目指す市民フォーラムでは、専門家による講演と質疑応答の演説会が行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "要するにこの演説会は純粋な悪感情の表現に終ってしまった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説会　民政派の演説会には、必ず、政友会の悪口を並べる。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政友会の演説会には、反対に民政党の悪口をたゝく。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説会とは、反対派攻撃会である。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、無産政党の演説会は、たいていどの演説会でも、既成政党を攻撃はするが、その外、自分の党は何をするか、を必ず説く。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは、徹頭徹尾、攻撃に終始する既成政党の演説会に比して、よほど整い、つじつまが会っている。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、やがてアメリカの社会主義者をも立たせ、ジミーの属するリースヴィル社会党支部も演説会を開き、反対した。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○八月二十五日、北海道官有物払い下げ問題について、福地源一郎、沼間守一らが、新富座において、政談演説会をひらく。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場を演説会場に使用せし嚆矢とす。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説がすんで、聴衆は雪の夜道を三々五々かたまって家路に就き、クソミソに今夜の演説会の悪口を言っているのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのひとたちは、自分の家に立ち寄って客間に上り込み、今夜の演説会は大成功だったと、しんから嬉しそうな顔をして父に言っていました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下男たちまで、今夜の演説会はどうだったと母に聞かれ、とても面白かった、と言ってけろりとしているのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説会ほど面白くないものはない、と帰る途々、下男たちが嘆き合っていたのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とともに、その痘痕と、細君が若うして且つ美であるのをもって、処々の講堂においても、演説会においても、音に聞えた君子である。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その年も押しつまったある夜、紙芝居をすませて帰ってきますと、今里の青年会館の前に禁酒宣伝の演説会の立看板が立っていたので、どんなことを喋るのか、喋り方を見てやろうと思いながら、はいって聴きました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ東成禁酒会の宣伝隊長は谷口という顔の四角い人でしたが、私は谷口さんに頼まれて時々演説会場で禁酒宣伝の紙芝居を実演したり、東成禁酒会附属少年禁酒会長という肩書をもらって、町の子供を相手に禁酒宣伝や貯金宣伝の紙芝居を見せたりしました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何となく選挙の終った日、落選者の選挙演説会の立看板が未だに取り除かれずに立っている、あの皮肉な光景を想いだした。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二代表は毎日毎日演説会場に出席して黙々として板垣一派の演説を静聴した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳郎はゆっくりとした足どりでその坂路を登りながら、その日、午後四時から井生村楼に催される演説会の演説の腹稿をこしらえていた。",
              "citation": {
                "source": "赤い花",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "依りてある寺を借り受けて教場を開き、夜は更に昼間就学の暇なき婦女、貧家の子弟に教え、母上は習字を兄上は算術を受け持ちて妾を助け、土曜日には討論会、演説会を開きて知識の交換を謀り、旧式の教授法に反対してひたすらに進歩主義を採りぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　岸田女史｜来る　その歳有名なる岸田俊子女史（故中島信行氏夫人）漫遊し来りて、三日間わが郷に演説会を開きしに、聴衆雲の如く会場｜立錐の地だも余さざりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来東京に大阪に将た神戸に、妾は表面同志として重井と相伴い、演説会に懇親会に姿を並べつ、その交情日と共にいよいよ重なり行きぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾にも一場の演説をとの勧め否みがたく、ともかくもして責めを塞ぎ、更に婦人の設立にかかる婦人｜矯風会に臨みて再び拙き談話を試み、一同と共に撮影しおわりて、前川虎造氏の誘引により和歌の浦を見物し、翌日は田辺という所にて、またも演説会の催しあり、有志者の歓迎と厚き待遇とを受けて大いに面目を施したりき。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでキリスト教の演説会で演説者が腰を掛けて話をするのはたぶんこの講師が嚆矢であるかも知れない（満場大笑）、しかしながらもしこうすることが私の目的に適うことでございますれば、私は先例を破ってここであなたがたとゆっくり腰を掛けてお話をしてもかまわないと思います。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドコの百姓が下らぬ低級の落語に見っともない大声を出して笑うのかと、顧盻って見ると諸方の演説会で見覚えの島田沼南であった。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一　　　　　「千回もやってくれ」　第一回の「岸野小作争議演説会」が町の活動小屋で開かれた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説会は大きな反響を起した。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
