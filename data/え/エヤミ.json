        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "村全体が疫病みに襲われ、祈祷師を呼んでお祓いをする騒ぎになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えやみが流行っているそうだから、今は都へ近づくのはよしなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長引く飢饉のあと、追い打ちをかけるように疫病みが蔓延し、多くの命が失われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い記録によれば、その年の夏は例年にないほど疫病みの被害が激しかったという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "明くる年は立ちなほるべきかと思ふに、あまさへえやみうちそひて、まさるやうにあとかたなし。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴派風の表現が勢を得てから、「えやみ」（疫）だとか「すゆ」（饐ゆ）など言った辛い聯想を持った言葉が始終使われた。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴派風の表現が勢を得てから、「えやみ」（疫）だとか「すゆ」（饐ゆ）など言つた辛い聯想を持つた語が始終使はれた。",
              "citation": {
                "source": "詩語としての日本語",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼんにさえやみ市場にもあまり姿を見せなかったそうだ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹ずつ彼女の子犬もはせつけたが母親と同じくこの神秘に打たれて咆えやみ、しんとした。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "えやみや足なえ憑きものの類が、ふしぎに願をかけると癒るということだった。",
              "citation": {
                "source": "天狗",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
