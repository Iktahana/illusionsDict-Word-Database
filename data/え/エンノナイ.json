[
  {
    "uuid": "3a1407b3-47ad-5eef-aaa1-7154df9f8d15",
    "entry": "縁のない",
    "reading": {
      "primary": "えんのない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
