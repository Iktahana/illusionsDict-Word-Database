        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アルファベットの「H」は、ラテン語では「アッカ」と呼ばれます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の名前には、頭文字として「H」が使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この表では、左端の列は「H」から始まっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへＣやＤやＥやＦやＧやＨやそのほかたくさんの人物がつぎつぎに出て来て、手を変え品を変え、さまざまにＢを中傷する。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ首相が入院していた時の物々しい警戒を思い出す。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、Ｈ・Ａといふ人の戰爭の小説を讀んで、何これくらゐならば僕だつて書けると思つてゐたのだが、とんでも無いことであつた。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち私一家は、一時田舎に落ちのびて、留守は、Ｎ君とＨ君とに委せて置いた。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座の立役者Ｈの子供の初舞台の披露があるためらしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十年ほど前にはＨ博士の助手として、大湯｜間歇泉の物理的調査に来て一週間くらい滞在した。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際クラーク電池の長所を認めていわゆるＨ型のものを工夫した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、よく見るとＳも、Ｈも、Ｙも、栗島も、同様に偽札を掴まされていた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨとＳとの間に、かなり広汎な区域に亘って、森林地帯があった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＨとＳとの連絡は始終断たれていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数式で書き現わすと、この問題の分泌量Ｈがざっと H = H0 + A sin nt のような形で書き現わされその平均水準のH0」は縦中横］と振幅Ａとが各個人の各年齢で色々になる量だとする。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今いちばん適当なＨの量を仮にＫだとすると、上式をＫに等しいと置いたときにその式を満足するような時間ｔに相当する時季がその人のいちばん気持のいいときになる勘定である。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ町で乗った電車はほとんどがら明きのように空いていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の先生のＨというのが風貌魁偉で生徒からこわがられていたが、それが船暈でひどく弱って手ぬぐいで鉢巻してうんうんうなっていた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ温泉｜池畔の例年の家に落着いた。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、路傍に群がって珍らしげに見物している子供達をあとに、次のＢ村、Ｈ村へ走った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣとＨとＯだけの組み合わせで多数の有機物が出るようなものかもしれない。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＫとＨは日本語でもしばしば転化するからここではかりに同じと見て、次のような子音分類をする。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれよりもこの人に感心したのは氏が先年Ｈ子夫人と同伴で洋行したときに、パリ在住の通信員によって某紙上に報ぜられたこの夫妻の行動に関する記事を読んだときである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ夫人は、日本からわざわざ持参のホオズキを鳴らしながら、相手かまわずいっさい日本語で買い物をして歩いた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ温泉旅館の前庭の丸い芝生の植え込みをめぐって電燈入りの地口行燈がともり、それを取り巻いて踊りの輪がめぐるのである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝の新聞に宅の下手な合奏の光景が暴露されているかと思って読んでみると「……同学士をＨ町の自邸に訪えば」うんぬん、とあって、ちゃんとそのＴ氏の自宅においてＴ氏と会談したことになって記述されていたのである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはＨ高等学校の講堂だ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表紙はズット大型の黒い皮表紙なんで……ＨＯＬＹ・ＢＩＢＬＥと金文字の刻印が打込んであって、牛だか馬だかわかりませんが、頑丈な生皮の包箱に突込んであります。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その包箱の見返しの中央にＭＩＣＨＡＥＬ・ＳＨＩＲＯと読める朱墨と、黒い墨の細かい組合わせ文字の紋章みたいなものが、消え消えに残っているところを見ますと、私のカンでは多分天草一揆頃日本に渡って来て、ミカエル四郎と名乗る日本人が秘蔵してたものじゃないか知らんと……ヘエヘエ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三条河原町一　学生たちがセンター（中心）と言っている三条河原町に夜がするすると落ちて来ると、もとの京宝劇場の、進駐軍専用映画館の、「ＫＹＯＴＯ　ＴＨＥＡＴＥＲ」の電飾文字の灯りが、ピンク、ブルー、レモンイエローの三色に点滅して、河原町の夜空に瞬きはじめる。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年、四国霊場を行乞巡拝したとき、私はゆくりなくＨという老遍路さんと道づれになった。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は臆面もなくＨ老人を責めＳ夫人を責めて饒舌であり過ぎた。",
              "citation": {
                "source": "物を大切にする心",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ――氏は、散歩に出る時の外は、何もしないで、下宿の好ましい調度で品よく飾った部屋に寝ころんでいることが多かった。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "正しく風に動力を借りるオランダ低地の風車は美でもあり、経済的でもあったろうが、レムブラントの名手に油絵、またはエッチングに取り入れられたあの風車の風景も、近来は電気工業に取って代られ、引き合わないために、風車はだんだん取り毀たれ、オランダ風物の代表は、全く失われんとしているとも聞いた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
