[
  {
    "uuid": "ddbd11a7-e437-53cf-9a6e-ab6b3ea6954d",
    "entry": "愛媛県",
    "reading": {
      "primary": "えひめけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
