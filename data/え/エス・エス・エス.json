        "examples": {
          "standard": [
            {
              "text": "Getting SSS rank on that boss fight is a legendary feat; very few players have managed it.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "The pro player explained the intricate strategies needed to consistently achieve SSS rank in the competitive mode.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "Is SSS rank even possible on the hardest difficulty? It feels impossible!",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二十四年の『国民之友』の夏期附録に載せられたＳＳＳ同人の詩の翻訳、それから続いて『しがらみ草紙』の発刊、『舞姫』の発表――一時は文壇の評論界を席巻した概があつた。",
              "citation": {
                "source": "紅葉山人訪問記",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災前、ＳＳＳ団という団体が某私立中学に出来ていた。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを米国のＫＫＫ団、又はＩＷＷ団の真似をしてＳＳＳとしたのであったが、この時まではまだ不良と名づける程の仕事もしていなかった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのＳＳＳへ不良青年がまじるようになると、いつの間にか仕事が著しい不良性を帯びて来た。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に文房具にＳＳＳというのが出来たので、改めてＳＭＳと改名した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのＳＳＳＲ、コサックと農民と労働者が美装の史書へしるした大きな黒い手のあとだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄葉した植込みの奥のもっと黄色い柱列を入って行って、旅券の後に添付されてるＳＳＳＬ居住許可証を返して来た。",
              "citation": {
                "source": "モスクワの辻馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十二年の「國民之友」夏季附録にはＳＳＳ社中の「於母影」が出た。",
              "citation": {
                "source": "創始期の詩壇",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＳＳの陰符が人目をそばだてしめたが、これはやがて森鴎外博士の率ゐる新聲社であると云ふことが判つた。",
              "citation": {
                "source": "創始期の詩壇",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
