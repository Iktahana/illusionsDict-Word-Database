    "definitions": [
      {
        "index": 1,
        "gloss": "speech",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "市長候補は、中心街で開かれた集会で、力強い演説を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「我々には未来がある！」と、彼は聴衆を鼓舞する熱のこもった演説を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "平和記念式典では、生存者の代表が、戦争の悲惨さを訴える演説を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学の創立記念講演会で、著名な学者が自身の研究について興味深い演説をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ああ、いま新らしき遊戲は行はれ遠望の海さんさんたるにわれ諸君とゆびさし眺望してながく塔下に演説す。",
              "citation": {
                "source": "交歡記誌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさへ、彼等の表現の多くは、乞食壮士の大道演説に類したものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが不運にして芥川君は出席されず、歸途に驢馬同人の諸君に向つて、大いに私の論旨を演説した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口をひらけば、何か人生問題を、演説口調で大聲叱咤しさうな氣がして、どうも何氣ない話は、できぬ。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびは、まことにすまない、ゆるしてもらひたい、と堂々の演説口調で言つたので、生徒は、みんな笑つた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このたびの結婚の事に就いては少しも言わず、ひたすら世界の大勢に就き演説のような口調で、さまざま私を教え諭すのであった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "総長の演説があったが何を云っているか自分にはちっとも分らないので少々心細くなった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書の管理者などはどこでも学生には煙たがられると見えて、いつか同席したクナイペの席上における学生の卓上演説で冗談交じりにひどくこき下ろされていたが、当人は Sehrgemeiner Kerl などという尊称を捧げられても平気で一緒に騒いでいる面白い人であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一日ベルリンのフィルハーモニーで公開の弾劾演説をやって無闇な悪口を並べた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにこの演説会は純粋な悪感情の表現に終ってしまった。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年ケルヴィン卿が化学会の晩餐演説でこの事を引合に出し、レーリー卿は十二歳のときに燐で指を焼いたそうだが、自分は八十二歳のときに全く同じ火傷をしたと云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく「はにかみや」であったのでこの時の演説はよく聞き取れないくらいであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし晩年はかなり講演がうまくなり、政治演説なども相当有効にやってのけるようになった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七五年に上院で演説をさせられた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の座長の演説の中に物理学者の二つの流派、すなわち実験派と理論派との各自の偏見から来る無用の争いを誡めた一節は、そのまま現代にもあてはまるべきものである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "クェベックまでの航海中のある夜ロバート・オースチンがナンセンス科学演説をやった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ彼の座長演説をやる日に、入場券を持たずに会場へ行って門番と押し問答をやった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の演説の一部は科学者の教育問題に触れ、古典的死語に代えるべき仏独語の効能を述べている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではこの期間に彼は政治界の嵐に捲込まれ、郷里で演説をしたり、弟の立候補の声援運動を助けたりした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇九年のダーウィン百年祭はレーリー総長の司会で行われたが、その時の彼の追懐演説に現われたダーウィンの風貌は興味が深いものであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一九一一年に出た版権法修正案が大学の権利を脅かすものであったので、総長レーリーは上院で反対演説をした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーが公衆の面前に現われた最後は心霊学界の会長就任演説（一九一九）をした時であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この演説も全集に収められている。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時のタムソンの演説はさすがにレーリー一代の仕事に対する簡潔な摘要とも見られるものである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その演説の要旨の中から、少しばかり抄録してみる。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口を這入る時から、下の方で何だか恐ろしく大きな声で咆哮している人がある事に気が付いていたが、席が定まってからよく見ると、それは正面の高い壇の中壇のような処に立って何事か演説している人の声であった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中のある人は、演説のある最中に呑気相に席を立ってどこかへ出て行ったりした。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、入れ代って色々の演説があった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださえ耳の悪いのが、桟敷の不良な空気を吸って逆上して来たために、猶更聞こえが悪くなったのか、それとも云っている事が、よほど自分の頭に這入りにくい事柄であるせいか、かなり骨を折ったにもかかわらず、これらの演説がどれもよく聞き取れなかった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "談話に費やす労力　人間が談話をしたり、歌ったり、演説したりする時には、肺の中の空気を若干の圧力で押し出しているが、このために要する器械的の仕事はどれだけであるか、平たく云えば一時間しゃべるにはどれだけの労力をするかという事を測定した人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
