[
  {
    "uuid": "6c902f21-081f-5698-b467-cf79247dde99",
    "entry": "選ぶ",
    "reading": {
      "primary": "えらぶ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-バ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to choose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夕食に何を食べたい？",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい車の色をどれか選んでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "二つの仕事のオファーのうち、どちらを選ぶか決めなければならなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私が山王山を知つてから、いづれも生活の敗残者であらう、この森の中で、首縊りが二人ばかりあつた、人目を避けるに、都合がいゝとは言ひながら、不思議なことに、死ぬ人は原始的に安息な自然を選ぶ、川や海に身を投げる人と森の中で縊る人と。",
              "citation": {
                "source": "亡びゆく森",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大多數の客はバスを選ぶやうである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年大西洋航路などでは速力の増すとともに賃金も著しく上がったが、それにもかかわらず争うて快速力の船を選ぶ有様だそうである。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神的交通機関についてもやはり同様で、皆無か具足か、どちらかを選ぶことにしなければ面倒は絶えない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその要素だけを抽象し、それを主として表現するために最も有効な手段を選ぶのであろう。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば毒ガスの使用などでも適当な風向きの時を選ぶは勿論、その風向きが使用中に逆変せぬような場合を選ばなければならない。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこういう樹の種子を選ぶには播種すべき土地に応じて適当な処の産を用いねばなるまいという事を論じている人がある。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は席を選ぶために、二等車から三等車の方へ移つて行つた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道を歩く時にも、手を一つ動かす時にも、物を飲食する時にも、考えごとをする時にも、着物の柄を選ぶ時にも、常に町の空気と調和し、周囲との対比や均斉を失わないよう、デリケートな注意をせねばならない。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　劇場などで座席を選ぶ場合に、一列の椅子のどちらか一方の端の席がいいという人がある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集を好む動物があり一方にはまた孤独を楽しむ動物があるかと思うと、また一方ではある時期には群集を選ぶが他の時期、特に営巣生殖の時期には群れを離れて自分だけの領地を占領割拠し、それを結婚の予備行為とした上で歌を歌って領域占領のプロパガンダを叫び、そうして花嫁を呼び迎える鳥類もある。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、乗り換え切符を出さなくなったために乗客の選ぶコースが平常と変わり、その結果としていつもは混雑するある時刻のある線路が異常に閑散になったというような現象もあるらしく思われた。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう行きがかりで晩年自分が某研究所に入って自由に好きな研究の出来るという幸福な身分になったとき、別にわざわざ選ぶともなく自然に選んだ研究題目の一つは空中放電現象のそれであった。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際もし車掌がある一つの主義を偏執してたとえば大通りばかりを選ぶとするとそれを徹底させるためには時にはたいへんな迂路を取らねばならぬような事があるだろう。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちわざと都合の悪いほうを選ぶのである。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことから考えても、科学者が科学者として文学に貢献しうるために選ぶべき一つの最も適当なる形式はいわゆるエッセーまた随筆の類であろうと思われる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでこの二つの映画を見せて、そのいずれを選ぶかによって観客の定型を二つに分けることもできそうである。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく新聞に出るような死に方を選ぶ人の心持ちは、やはりこのはき物や上着を脱ぎそろえる心持ちの延長ではないかとも思われるのである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬を稽古する人が上達するに従ってだんだん荒い馬を選ぶようになる心理もいくらかわかったような気がする。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして評判は広告と宣伝によって高まるとすれば、書籍の生産者が売薬化粧品商と同一の手段を選ぶのは当然のことであって、これをとがめるのは無理であろう。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧の理解ある嘆美者クーシュー（Paul-Louis Couchoud）はアメリカ文化と日本文化の対蹠的なことを指摘し自分らフランス人はむしろ後者を選ぶべきではないかと言っている。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衝動の醇化ということが不可能であるをもって、この二つに一つのいずれかを選ぶほかはない。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからおまえ、本気になってこの五人の中から選ぶんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、これでも身のほどをわきまえて選ぶつもりですから……（急に戸部の前にかけ寄り、ぴったりそこにすわり頭を下げる）戸部さん、私あなたのお内儀さんになります。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに一人の若い女性があって、夫を選ぶことになりました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいずれの宗旨、教義、修業法によって自分が救われやすいかは、自分の性質によく似通った開祖や名僧知識の説きましたものを選ぶのがよろしいと思います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあなたは、そのうちでただ一つの道だけ選ぶことが出来る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "米斎君が亡くなってしまったから、今後はこれまでやった方々のうちから選ぶことにしますか、また新規な方に御願いするようになりますか、その辺はわかりません。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅茶を選ぶと、その店の少女はレコードをかけ、首をかしげて聴き惚れていた。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの異なる風習に於て我々は何れの長所を選ぶだらうか？",
              "citation": {
                "source": "家庭の痛恨",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
