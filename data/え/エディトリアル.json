          "standard": [
            {
              "text": "新聞の今日の論説（エディトリアル）は、経済政策について深く掘り下げている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この雑誌のエディトリアルは、常に読者の関心を引くテーマを選んでいます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の記事は、単なる報告ではなく、明確なエディトリアルな視点を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "同誌のエディトリアル・ディレクター、アーサー・サルスバーグは、アルテアを紹介した号の「ホームコンピューターがやってきた」と題した巻頭言で、アルテア作りを同誌が読者に提案する〈プロジェクト〉と位置づけている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
