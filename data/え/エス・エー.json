    "definitions": [
      {
        "index": 1,
        "gloss": "service area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長距離ドライブの途中、SAで休憩と食事をとることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このSAには、地元特産品を扱っているお土産物店がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが車酔いしないよう、こまめにSAで車を止めて休憩を取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高速道路のSAで、最新のバイクが展示されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "代表者となったボブ・スタインは、妻だったアリーン・スタインとボイジャー・プレスを作った人物で、ここから引き継いだ社名は、ＮＡＳＡの惑星探査機から取ったそうです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユタ大学の大学院ではアラン・ケイの同期で、卒業後はＮＡＳＡのために飛行士訓練用のフライトシミュレーターの開発に携わっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤードバーズ〈フォー・ユア・ラヴ〉、アウトサイダーズ〈タイム・ウォント・レット・ミー〉、ナシュヴィル・ティーンズ〈タバコ・ロード〉、ビーチボーイズ〈アミューズメント・パークス・ＵＳＡ〉、それに、ナンシー・シナトラやレズリー・ゴーアなんてものまである。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ＰＯＲＴ・ＳＡＩＤは、白・黒・黄・赤の各人種によってアラビヤ風に極彩色された、二面神の象徴模型なのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＡＫＵＲＡ　一七一二年に発行された、ＡＢＣのいろは歌留多みたいな“Trivia”のなかに、　Ａ――小路はぶらぶら歩きに持ってこいだし、　Ｂ――本屋の主人は天気の予言が上手だし、　Ｃ――群集は馬車がくると左右にわかれ、　Ｄ――塵埃屋には閉口だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "デンマアク街Ｘ番――上に、ＳＡＫＵＲＡと金文字が読める。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "こと食べ物に関して来たらついむきになって申訳ないが、ま、一さいの議論はあと廻しにして早速ＳＡＫＵＲＡの戸をあけるとしよう。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ・Ｈ・Ｗ――ＮＹＣ・ＵＳＡ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにでも見かけるもの――ＯＳＡＫＥという広告、と言っても、禁酒国だから酒場ではない。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "｜垂れ絹はすべて五月の朝のＳＡＶＯＹ平野の草の色だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォン・ノイマンとエッカートが協力して進めることになったＥＤＶＡＣの開発計画は、両者の発想の食い違いもあって大幅に遅れ、同方式の一号機はイギリス、ケンブリッジ大学のモーリス・Ｖ・ウィルクスによって一九四九年五月に作り上げられたＥＤＳＡＣとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次大戦後、ＮＡＳＡの前身の航空宇宙諮問委員会（ＮＡＣＡ）エイムズ研究所で風洞の研究に携わったエンゲルバートはやがて、人類の多くを進歩させるような意義のあるはでな仕事につきたいと、若者らしい野心を抱くようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五七年にスタンフォード研究所に移ったエンゲルバートは、軍やＮＡＳＡの援助を取り付けて、人間の能力を〈増大〉させるシステムの研究計画を軌道に乗せていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイの表示は、ＮＡＳＡから借りた最新のビデオプロジェクターによって、縦横二〇フィートのスクリーンに投射された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★『ザ・コンピュータ』（ソフトバンク）一九九〇年六月号、「ＫＥＹＭＡＮ ＵＳＡ　次世代のコンセプターが考えている明日」所収のアラン・ケイへのインタビュー。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも特に彼らが驚かされたのは、まっとうな企業も数多く存在しているシリコンバレーの中で、一行が彼らとキット式のコンピューターを出しはじめたばかりのＩＭＳＡＩ社のみを訪ねた点だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの年の夏には、アルテアと同じく８０８０を使ったＩＭＳＡＩ８０８０と名付けられた対抗機が登場した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の図書室にあった、開発者のモーリス・ウィルクス自身が書いたＥＤＳＡＣの本を読んでいる最中、渡部は奇妙な親近感を電子計算機に抱くようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "開発元のマイクロプロ社を設立したシーモア・ルービンスタインは、アルテアを追って生まれたＩＭＳＡＩの会社を経て、今度はでき上がったマシンで走らせるソフトウエアの会社を起こそうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七七年の初頭、アメリカに戻ったルービンスタインは、コンピューターキットを売っている店でＩＭＳＡＩを買い求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンスタインはミラードに連絡をとり、ＩＭＳＡＩのマーケティング部長として働くことになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで彼は、ベーシックとは性格の異なるオペレーティングシステム（ＯＳ）と呼ばれる基本ソフトをＩＭＳＡＩに載せるために、コンサルティングを依頼していたグレン・ユーイングを通じて開発元に連絡をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩのコンサルタントをしていたグレン・ユーイングから一九七六年に連絡を受けた段階では、ＣＰ／Ｍはすでに異なった四つのシステムで使われるようになっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユーイングの用件は、ＩＭＳＡＩが「ＯＳはすぐに間に合わせる」としてすでに売りはじめていたドライブ用に、ＣＰ／Ｍを使わせてほしいという依頼だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＩＯＳの切り離しは自分でやったが、ＩＭＳＡＩのマシンへの対応は彼らに任せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "交渉にあたったＩＭＳＡＩのルービンスタインは、「二万五〇〇〇ドルで何本でもＣＰ／Ｍを使ってよい」とする条件をキルドールが呑んだことに驚かされた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩをはじめとするライバル機に追われはじめると、アルテアでブームに火をつけたＭＩＴＳのエド・ロバーツは、すぐに会社に見切りをつけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＭＳＡＩの時代もまた終わりつつあると考えたルービンスタインは、一九七八年に同社を去ってソフトウエアの会社、マイクロプロを設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルービンスタインがまずやったのは、自分の二週間前にＩＭＳＡＩをやめていた同社の元ソフトウエア開発部長、ロブ・バーナビーを雇うことだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
