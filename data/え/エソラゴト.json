        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はいつも「いつか世界一周するんだ」と言うが、財産も計画もなく、ただの絵空事だろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、本で読んだ魔法の世界は、大人になった今でも私にとって色褪せない絵空事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「そんな都合の良い話、絵空事だよ。現実を見ろ」と、先輩は経験談を交えて諭した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "小説は絵空事と昔からきまっている。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の根本で繙いた、不思議な書物の中にある、　妾の女王の絵姿は、絵空事ではなかったか。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢えて絵空事なんぞと言う勿れ。",
              "citation": {
                "source": "妾宅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「たいていの人は絵空事だと思う。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙旅行は絵空事です。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリはあなたを愛しているでしょうが、絵空事になりますよ」「これ以上引き延ばしても無駄だ」　とベリントン大佐が冷静に言った。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯罪学の書物の挿絵を見慣れた人には、さして珍らしい姿ではないが、女の倭文子には、絵空事でない写真であるだけに、本当の惨死体を見たと同じ、胸の悪くなる様な怖さであった。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松風村雨」という二人の女の舞は、『源氏物語』にもとづいて作ったというが、それが二つの桶を棒の両方にになって、潮を汲みに行くところを舞うのは、絵空事というものである。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありもしないえそらごとの不動様に、夜も昼も睨められて、こっちの睨みが利かなくなるとは、腹が立って腹が立ってたまらない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
