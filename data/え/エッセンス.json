        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この香水は、花の持つエッセンスだけを抽出して作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼のスピーチは、長年の経験からくる知恵のエッセンスが詰まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "芸術作品のエッセンスを理解するには、作者の意図を読み取ることが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この料理の決め手は、秘伝のスパイスのエッセンスにある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "俗情のエッセンスだとでも名付けるよりほかはない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のレモン・エッセンスであったのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句とは如何なるものかという問に対して先生の云った言葉のうちに、俳句はレトリックのエッセンスであるという意味の事を云われた事がある。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春雨」「秋風」というような言葉は、日本人にとっては決して単なる気象学上の術語ではなくて、それぞれ莫大な空間と時間との間に広がる無限の事象とそれにつながる人間の肉体ならびに精神の活動の種々相を極度に圧縮し、煎じ詰めたエッセンスである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟「能」は吾人の日常生活のエッセンスである。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその一つ一つの象形文字のような夢内容は驚くべく多様な夢思想の圧縮されたエッセンスであり、またはなはだしく複雑な夢思想の網目の接合点である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、儒家は儒になずみ仏徒は仏にこだわっている間に、門外の俳人たちはこれらのどれにもすがりつかないでしかもあらゆるものを取り込み消化してそのエッセンスを固有日本人の財産にしてしまったように見える。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は万葉から元禄までのあらゆる固有文化を消化し総合して、そうして蒸留された国民思想のエッセンスを森羅万象に映写した映像の中に「物の本情」を認めたのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば吾等日本民族が、先祖代々から、子々孫々に到るまで、総がかりで完成すべく努めている綜合芸術のエッセンスであろう。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油のエッセンスにて火を灯し、草と砂糖を調じて鉱山用のドンドロを合せたなどは、ほんの人寄せの前芸に過ぎない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、陀羅尼とは、つまりあらゆる経典のエッセンスで、一字に無量の義を総べ、一切の功徳をことごとく持っているという意味です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳によって原物は殆んど全く別の姿に変わるのではあるが、その換骨奪胎に於て必ずもののエッセンスは再生され得ねばならぬ。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、ただの諸文化自身から抜け出して或る独特な新しい文化的尺度を規正するこの「文化の意識」は、もはや個々の諸文化の夫々の付属物ではなく、そういうものから発達し結実した夫々の或る代表者的エッセンスが集結し独立化し単位化したものとして、或る独立な秩序界を構成する。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "単純化は一つのエッセンス、精、法則の柱を握って、他のものをそれに依属せしむることだと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新著『循環論証の新世界観と錯覚自我説』とは氏の哲学のエッセンスで、これだけ読めば十分にかれの思想を知ることが出来る。",
              "citation": {
                "source": "錯覚自我説",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪のエッセンスを煮染めたような地元、守口、門真の風土には、ロックマニアで作家志望の感性には受け入れがたい臭みがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、世界中の距離が縮み、世界中の思想がインターナショナル的になり、世界の学問と学問との領域が益々接近しつつある今日、その各々のエッセンスを擢んで、理解し、其専門化して歪められたる方向を正しきに引き戻すのは、文学者の綜合的知識と批判を俟つの他は無い。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、私小説的なエッセンスとでも言えるものを、随所にばらまく結果ともなった。",
              "citation": {
                "source": "小説集「山吹の花」後記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者が、「文学的に」何を追い求めているかを、私は、いま、はっきりいい当てることはできないが、たしかに、それは、新しい戯曲の「生命のエッセンス」ではないかと思う。",
              "citation": {
                "source": "純粋戯曲への道",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい戯曲の「生命のエッセンス」をなかなか大胆に追ひ求めてゐるところにも、私は注目した。",
              "citation": {
                "source": "矢代静一君を推す",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、じゃこうのエッセンスならございますよ。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "エッセンスをテーブルスプーンに一杯ほど、聖ポール寺院のまんなかにぶちまいてごらんなさい、あのへんいったい、半年ほどぷんぷんしますから。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　薬屋の亭主は一オンス入りの空壜と、小型のガラスのじょうごと、「じゃこうエッセンス」と書いた壜をだして、また魔法使いのような動作をはじめた。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから細心の注意をはらいながら、壜をかたむけて、数滴――茶さじ半分――のエッセンスをステッキの綿にたらしこんだ。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿が充分にエッセンスを吸いとると、こんどはナイフの柄にエッセンスを一滴おとした。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もし精神というのがエッセンス乃至本質という意味ならば別に問題はないかも知れない。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがこの際にすでに疑問なのは、事物のエッセンス乃至本質を習慣的に精神と命名することによって、いつの間にか知らず知らずに、精神主義を混入させてはいないかということだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "）という日本主義イデオロギーのエッセンスが、如何に現下のファシズム政治理想とその政治機構とに役立てられるか、又ファシズムが照応している処の現下の資本制機構にどう役立てられるかを、今まで述べて来たとは逆のコースを取って、解明することだが、夫は省略する。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
