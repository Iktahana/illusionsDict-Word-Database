        "examples": {
          "standard": [
            {
              "text": "アリストテレス哲学におけるエネルゲイアは、単なる状態ではなく、活動そのものを指す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "種子は、その潜在能力（デュナミス）が発揮されることで、エネルゲイアとしての植物へと成長する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「形相（エイドス）は、質料（ヒュレー）にとってのエネルゲイアである」という説明は、しばしば引用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "それ故純粹の現實性純粹のエネルゲイアにおいては充實あるのみ、從つて運動は無い。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
