        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "農夫は畑に種を均一にまくために柄振を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この伝統的な農具である柄振は、何世紀にもわたって使用されてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔は、田んぼで柄振をよく見かけたものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "準之助氏は、遠くはなれたソファに腰をおろしながら、始終ニコニコしながら、満足そうに新子の教えぶりを見ていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、朝湯に行くらしい男のスタイルを見ると、頭の恰好、着物の着こなし、言葉付き、黒もじのくわえぶりに到るまで、非常に平凡化しているのは事実である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやあれは鳥渡……僕の持薬である丸薬を落したから、拾い集めて居ただけなんです」と答えたが、その答えぶりから言ってそれは明らかに偽りであることが判った。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夜のおびえぶりを見るやうだ。",
              "citation": {
                "source": "斎藤緑雨と内田不知菴",
                "author": "坪内逍遙",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にまた彼の教えぶりも負けずに退屈を極めていた。",
              "citation": {
                "source": "保吉の手帳から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の教えぶりは、――保吉は未に確信している。",
              "citation": {
                "source": "保吉の手帳から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "保吉はこの芝居のために、――この語学的天才よりもむしろ偽善者たる教えぶりのために、どのくらい粟野さんを尊敬したであろう。",
              "citation": {
                "source": "十円札",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう浪江の答えぶりによって、茅野雄は浪江が信者でないことを、ハッキリ感ずることが出来た。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ見方で安川の献身的な仕えぶりをみたならば、女神に仕える神僕か女王に仕へる奴隷のやうにも見えるであらう。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたものかと考えていると、神主はすらすらと読み続けて、その宏大なる家の構えぶりに抑揚をつける。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その答えぶりから推すと、彼女は最初からこういう料理屋めいた所へでも来るのを予期していたらしかった。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ問答ついでに、もう一つ答えてくれませんか」「ええ何なりと」　清子はあらゆる津田の質問に応ずる準備を整えている人のような答えぶりをした。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "（マタイ伝、ルカ伝の記事はイエスのお答えぶりの写生であり、マルコ伝の記事はお答えの精神を摘出したものであろう）　イエスがこれに語を次いで、汝ら人の子の、全能者の右に坐し、天の雲の中にありて来るを見ん。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　むしろ指紋をとられるのを望んでいるような、熱心な答えぶりだった。",
              "citation": {
                "source": "予謀殺人",
                "author": "A CASE OF PREMEDITATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "素子が議論していることや、秋山の答えぶりの要領よさについて、伸子は決して無関心なのではなかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君のさっきからの答えぶりなんか、全く正直だった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もどうかして、一度はそういう凄い涙の湛えぶりをしておめにかけたいものだと思いました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲目となって以来、この男の刀の構えぶりが、一層静かになってきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、痛いわね」　女は、またわざとらしい悶えぶりをする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この酒と、この肴さえあれば、尋ねる主などは、いてもいなくても差支えないという御輿の据えぶりでしたが、宿ではあらかじめ、かなりにその予備知識が吹き込んで置かれてありましたから、さのみ驚きません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "農奴の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「軍兵の覚悟」という言葉も明確だし、青竹を使っての教えぶりも要を得ている。",
              "citation": {
                "source": "薯粥",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ田植となって代掻きえぶりすり、苗もその日の朝取るのがふつうだったが、いそがしい日には、前日の日暮れに取って置くようになった。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
