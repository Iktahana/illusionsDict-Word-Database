[
  {
    "uuid": "9b47e995-bea3-514a-a06c-499815f8a10e",
    "entry": "江戸幕府",
    "reading": {
      "primary": "えどばくふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
