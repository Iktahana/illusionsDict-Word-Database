        "examples": {
          "standard": [
            {
              "text": "この駅は、幹線と枝線の乗り換え駅となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ローカル線の枝線に乗って、秘境の温泉を目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新幹線の建設に伴い、既存の枝線の一部が廃線になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "鐵路また枝線を廣げて軌道｜地下に入り、隧道を洞穴を潛行すれば、忽ち歴々たる光明の網變じて、沙塵と騷擾との中に現はる。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては人工宇宙線による原子力分解機関であって、二十四基に分れ、それが各台ともさらに多数の枝線へ変圧配給されているのであった。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五十二　無類の珍味　梅干の談話はとんだ枝線へ流れ込みたり。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
