        "examples": {
          "standard": [
            {
              "text": "「武士は元服の儀式で、幼名から烏帽子名へと改められるのが一般的だった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「昔の戸籍謄本には、本名（幼名）と烏帽子名（通称）が併記されていることがある。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「『これで君も一人前だ。これからはこの烏帽子名で呼ばれることになる。』と、師匠が弟子に告げた。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「史料によると、彼は著名な人物であったが、その烏帽子名だけが記録に残っている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は、くわ形の大かぶとだの大えぼしなどは嫌いとみえ、自分の考案で作らせた狩猟笠に似たのをこの日も用いていた。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
