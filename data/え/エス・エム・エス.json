        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友達から「今どこ？」ってSMSが来たから、駅に着いたと返信したよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "利用しているサービスのシステムメンテナンスのお知らせがSMSで届いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "携帯電話のSMS機能を使って、家族に短いメッセージを送ることがあるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "予約確認のSMSが届いたから、内容をチェックしておかないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "同時に文房具にＳＳＳというのが出来たので、改めてＳＭＳと改名した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流儀でＳＭＳは、Ｍの字を男性のあるもの、Ｓを少年の意味に使って、ＳＭＳというと或る怪しからぬ行いを仕事にする団体という意味にしたものであった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にＳＭＳ団はＭＭＭ団と改称された。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
