    "definitions": [
      {
        "index": 1,
        "gloss": "theatre",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新橋演舞場の前には、華やかな舞台を楽しみに待つ観客が列を作っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「伝統芸能を見るなら、やっぱり専用の演舞場が一番雰囲気が出るわね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "花道を備えた歴史ある演舞場では、連日熱い芝居が繰り広げられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "初めて訪れた演舞場の豪華な装飾に、子供たちは驚きを隠せなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "これは、画の話ではありませんが、先日、新橋演舞場へ文楽を見に行きました。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、演舞場で虎ちゃんが「太十」をやッたと云う新聞記事を見て、ふと前進座で光秀をやりたいとも思う。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "押詰って見えた時、海軍病院で診察してもらったが、もう十年ばかりは生きていないと仕事が片附かない、やりたい事が沢山ある、という御話だったので、御大事になさいといって別れたのですが、二月の東劇の舞台装置もなすった位だし、二月の六日の晩、私は行かなかったけれども、新橋演舞場で米斎君に逢ったという人がある。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "会場の北陽演舞場で振袖姿の千満子が師匠と連奏するのを、新郎たるべき人が鑑賞したのである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩ごはんをすましてから、兄さんと相談して演舞場へ行ってみる事にした。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "演舞場では、いま春秋座の一党が出演しているのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれが新橋演舞場！",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居見物の男女など大正一四・一二作『演劇・映画』大正一五・二、新橋演舞場初演　第一幕　京橋｜具足町の和泉屋という金物屋の奥座敷。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　或る日も晴代は静枝に頼まれて、新川筋の番頭らしい二人の客の同伴で、演舞場のレヴィユを見に行つたが、帰りは大雪になつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは演舞場へお稽古に行くときのお弁当や」「しかし芝居見物もこんなふうにしてゆくとおもしろいね」「こちらかって、幕のうちもあるし、鰻でも何でもあります。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を買おうと思えば、少しいいのは皆んな封鎖だろう」「そういったような工合だけれど、この節はあながちそうとも限らんのや」　電話が二度も演舞場からかかってきて、何やらの踊りの鼓を受け持つことになっている歌子の来ようが遅いので、一度は後と廻しにしたけれど、早く来てくれないと困るというのであった。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに比べれば新橋演舞場の方がまだ、下手なライト式ではありながら、素直に西洋風になっているだけでもいやみがなくていい。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝田君に最後に会ったのは今年の初夏、丁度ドラマ・リイグの見物日に新橋演舞場へ行った時である。",
              "citation": {
                "source": "滝田哲太郎君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ怪しいと思ったので……ところが間もなく演舞場の横から、築地河岸の人通りの少いところへくると、急にスピードを落した運転手が、帽子とマスクを取り除けながらクルリと私の方を振り向いた。",
              "citation": {
                "source": "冗談に殺す",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――河原崎座主、河原崎｜権之助は、九世団十郎が、市川｜宗家に復帰しない、養子にいっていた時の名――現今でもあのあたりは、歌舞伎座、東京劇場、新橋演舞場が鼎立している。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂昇は共楽会という南地の演舞場に開催される、第一流の群れに投じようとし、播重は自分の席の専属にしてしまおうと、心までも肉体と共に自由にしようとした。",
              "citation": {
                "source": "豊竹呂昇",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京劇場、新橋演舞場、歌舞伎座、帝国劇場と、華美をつくした劇場をもっている東京が、収支つぐなわなくなるか？",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に会ったのはたしか四五月頃でしたか、新橋演舞場の廊下で誰か後から僕の名を呼ぶのでふり返って見ても暫く誰だか分らなかった。",
              "citation": {
                "source": "夏目先生と滝田さん",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも、新橋演舞場のひどく閑散な、夜の事であつた。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○最近見て来た演舞場の舞台を例にとつて話して行くのが便利である。",
              "citation": {
                "source": "若手歌舞妓への期待",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を、暮れの浜町・春の演舞場と二度続けて見るといふ人すら――其一人は確かに私であつた――ある。",
              "citation": {
                "source": "若手歌舞妓への期待",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋駅より新橋演舞場の方へかけて、白金台町附近、高樹町、霞町、浅草観音さま本堂、本郷三丁目より切通坂へかけて、秋葉原界隈、田園調布界隈、司法省、茅場町、日本橋白木屋、高島屋の地下町の方面は次々と焼けたらしい。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新橋演舞場へ行って中井さん、アミノさんに会い、三人で又歩き、中井さんを有楽町まで送って尾張町からタクシーでかえる。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗にかみはくと仲間から呼ばれていた神楽坂演舞場へよく来ていた美男美女のカップルなど、二十余年を経た今日といえども、まざまざとそのあえかな面輪を羨ましく思い泛べることができる。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫との間を清算しようとして失踪したのだそうで、しかしこれも成功せず、数年後、東京銀座の大阪系酒場で再会した時も、やはり勢蝶との同棲は余儀なく続けられており、あきらめて私が遠ざかって多年ののち、勢蝶が新橋演舞場の美人の案内嬢と結婚したとの報せを耳にした。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝劇へ出たのをきっかけに、新橋演舞場、歌舞伎座と出るようになって、これなら東京でもできるということがわかったから、今の東京宝塚劇場を建設するようにまでなった。",
              "citation": {
                "source": "宝塚生い立ちの記",
                "author": "小林一三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の胆いりである私の友人の説明によると、金田一博士はアイヌと熊の研究にかけては日本一の権威であり、珠実嬢は花柳を五条に改名してから、近くはじめて新橋演舞場で公演するが、その出しものは金田一博士の指導により、アイヌの熊踊りである。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは演舞場の公演で唄うのであるそうだけれど、珠実嬢は踊りばかりが専門であると思っていたところ、唄もえらく大したものだ。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ重なお茶屋は大概四条通りの北、新橋方面にあつて、たゞ万亭が今と同じ所、花見小路の曲り角にあつたのを記憶するけれども、その外には女紅場（即ち祇園演舞場、都踊りをやる所）があつたぐらゐで、あの花見小路から今の東山線の電車の走つてゐるあたりは実に淋しいものであつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西貝は急きこんで、「……あの晩、演舞場を出たのが十一時ちかく。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
