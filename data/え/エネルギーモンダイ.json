        "examples": {
          "standard": [
            {
              "text": "世界は、化石燃料への依存を減らすという大きなエネルギー問題に直面している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "再生可能エネルギーの導入拡大は、エネルギー問題解決の鍵となるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エネルギー問題が地域紛争の原因になることもあるため、国際協力が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そういう新しい構想を、率先して受け入れて、水主火従という日本の電力問題、すなわちエネルギー問題の基盤を造ったのは、よほど偉い科学者がいたからであろう、と最近までぼんやり考えていた。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のエネルギー問題というような、国民の生活にとって最重要な問題について、少なくも過去においては、科学者はそう大した関心を示さなかった形になっている。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
