    "definitions": [
      {
        "index": 1,
        "gloss": "quiver (for arrows)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "弓の名手として知られたその武将は、背中の箙に二十本以上の矢を蓄えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い絵巻物には、美しい文様が施された箙を身に付けた武士たちが描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「よし、準備はいいか。」彼は箙から矢を一き抜いて、静かに弦に番えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "陸には源氏箙をたたいてどよめきけり」といふところ迄は、うつとりお耳を傾けて居られましたが、それに続けて、「あまりの面白さに、感に堪へずや思はれけん、平家のかの船の中より齢五十ばかりなる男の、黒革威の鎧著たるが、白柄の長刀杖につき、扇立たる所に立つて舞ひすましたり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は又箙を叩いてどよめきけり」と法師の節おもしろく語るのを皆まで聞かず、ついとお座をお立ちになつてしまひました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "射るところの箭、三｜箙皆尽く。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と箙の如く、麻袋を敲いて言つた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　粟生弘氏は翁の門下でも古株で相当年輩の老人であったが、或る時新米の古賀得四郎氏が稽古に行くと、大先輩の粟生氏が「箙」の切の謡を習っている。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新米の古賀氏は何の「箙」ぐらいと思っていたのに案に相違して震え上った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「箙」なぞを滅多に習うものじゃないと思った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに粟生氏が「箙」の切の或る一個所をかれこれ二三十遍も遣直させられたと思うと、老顔に浴びるように汗の滝を流しながら、精も気根も尽き果てた体で謡本の前に両手を突いて、「今日はこれ位で、どうぞ御勘弁を……」　と白旗を揚げた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣中の座興にと、信長、家康の士酒井左衛門尉忠次に夷舞を所望し、諸将｜箙を敲いて囃した。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "小姓は箙を負い半弓を取って、主のかたわらに引き添った。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年十二月二十日）箙の梅　　狸坂くらやみ坂や秋の暮　これは私がここへ移転当時の句である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この源太は二度の駆けをする勇気もないので、寒菊の無難をせめてもの幸いに、箙の梅をたずさえて今夜はそのまま帰ってくると、家には中嶋俊雄が来て待っていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どりや袍を甲斐甲斐しくも、きりりと羽織つたお月さま、愛の冷きつた世でござる、何卒箙の矢をとつて、よつぴき引いて、ひようと放ち、この世に住まふ翅無の人間どもの心中に情の種を植ゑたまへ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年十二月二十日）　　　　　二　箙の梅狸坂くらやみ坂や秋の暮　これは私がここへ移転当時の句である。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この源太は二度の駈をする勇気もないので、寒菊の無難をせめてもの幸いに、箙の梅をたずさえて今夜はそのまま帰ってくると、家には中嶋が来て待っていた。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「トローイア人を戦ひに飽かしむるまで――」の素晴しい勢で研究に没頭してゐる私にとつては、それは、箙にさしはさんだ梅花一枝の悲し気な風情でゝもあつた。",
              "citation": {
                "source": "ラガド大学参観記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に黒い塗り箙へ、二十あまり征矢をさしたのは、唯今でもはつきり覺えて居ります。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "革を卷いた弓、黒塗りの箙、鷹の羽の征矢が十七｜本、――これは皆、あの男が持つてゐたものでございませう。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古兵の戰場へ行く時は必ず一人毎に弓二張、矢は箙に三杯だけ持つて行く。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に黒い塗り箙へ、二十あまり征矢をさしたのは、ただ今でもはっきり覚えて居ります。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "革を巻いた弓、黒塗りの箙、鷹の羽の征矢が十七本、――これは皆、あの男が持っていたものでございましょう。",
              "citation": {
                "source": "藪の中",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "やさしくもあやめ卯の花さし添へし箙背負ひて弓引くや誰称名。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも刺青で肉体を飾りそのある者は鳥の羽根を附け、そのある者は髑髏を懸け、そうしてほとんど一人残らず毒矢を入れた箙を負い、手に半弓を握っている。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに花やかな弓小手、太刀を佩き短刀を差して頭に綾藺笠、腰には夏毛の行縢、背には逆顔の箙、手には覚えの弓、太く逞しい馬を曳かせて、それに介添を一人と弓持一人と的持を三人ずつ引具して、徐々と南の隅へ歩み出でたのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小森を迎えに行った侍がそのあとから、二十四差した箙を持ってついて来ました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「七十一番職人歌合せ」の絵を見ると、筆結・弦売・轆轤師・饅頭売・賽磨・甲細工・草履作・足駄作・唐紙師・箔打・鏡｜磨・玉｜磨・硯士・鞍細工・葛籠作・箙細工・枕売・仏師・経師・塗師の助手・硫黄・箒売・一服一銭・煎じ物売など、下り者と云われた諸職人・諸行商人は、多く法師姿である。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の眺望は一層の闊大を加えて北方は北アルプスの箙岳迄視界が開ける、南アルプスや槍穂高の方面は漸く霞に罩められて、鋭い輪廓もうすれて来た。",
              "citation": {
                "source": "美ヶ原",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "建武なら〈箙の梅〉というところだねなんていっていた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅に日の丸を描いた扇が、波にゆられ、浮きつ沈みつしているのを見ながら、平家は舷をたたき、源氏は箙をたたいて、この見事な弓取りを賞め讃えたのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よくぞ、射たものよ」「いや、余りにも、情をわきまえぬ」　と味方のうちにはいろいろいう者があったが、今度箙をたたいて喜んだのは源氏だけであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
