        "examples": {
          "standard": [
            {
              "text": "「FENのラジオ番組は、兵士たちに故郷の音楽を届けてくれて、本当に心の支えだった。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "冷戦時代、極東に駐留する米軍兵士向けの「FEN」は、貴重な娯楽源だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「昔、「FEN」で流れていた洋楽を聴いて、英語を勉強し始めたんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「FEN」のアーカイブ映像には、当時のアジアの軍事基地の様子が記録されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「だって、ＦＥＮは野球やっててさ、ワラが日本語の勉強だ、とか、いうからよう」　と、山崎がニヤニヤしながらこたえる。",
              "citation": {
                "source": "45回転の夏",
