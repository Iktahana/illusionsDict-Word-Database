    "definitions": [
      {
        "index": 1,
        "gloss": "Lepus brachyurus lyoni (subspecies of Japanese hare)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
