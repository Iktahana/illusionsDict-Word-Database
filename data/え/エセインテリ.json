        "examples": {
          "standard": [
            {
              "text": "彼の話は専門用語ばかりで、結局のところ似非インテリだと思った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの批評家は、いつも似非インテリぶっているのが鼻につく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "本質を理解せず、表面的な知識で語る似非インテリにはうんざりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "似非学者、似非作家、似非インテリゲンツィアの恥知らずな戦争協力にたいして、声に出せない眼をきつく働かして、それに反撥し、それを非難していた人々も、知識人の中には数が少くないのであった。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
