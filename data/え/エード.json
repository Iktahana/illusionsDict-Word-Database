        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏祭りには手作りのレモネードが出ると聞いて、楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このお店のジンジャーエードは、生姜が効いてて美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、母がよくオレンジエードを作ってくれたっけ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "バーテンダーは、様々なフルーツエードを並べて客を待つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "中にはまだ晝なのに電燈がついて、たくさんの輪轉器がばたり、ばたりとまはり、きれで頭をしばつたり、ラムプシエードをかけたりした人たちが、何か歌ふように讀んだり數へたりしながらたくさん働いて居りました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしたち二人と雛妓はオレンジエードをジョッキーで取り寄せたものを飲みながら頻りに扇風器に当った。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓｜硝子に映る電気スタンドの円いシエードが少しも動揺しないところを見ると、兄は口だけでさういつて腰を上げてまで止めに出ては来ないらしい。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "シエードの周囲に氷柱のやうなヒラヒラがついてゐる古めかしい台ランプが点つてゐるのだ。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "箒草（米大陸の孤萍ともいふべき）　　　タンブルウエード？",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワの街々にプーシュキンやオストロフスキー、グリボエードフなど文学者の記念像が立っていることは、ひろく知られている。",
              "citation": {
                "source": "行為の価値",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤枝はと見ると、オレンヂエードか何かを一杯命じたまま、ジャズと喧騒のバーの空気にも一向心を動かすようすもなく、眠そうに傍のクションに身をもたせて一言も発せず天井を薄目をあいては時々見ている。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレンヂエードに酔つてるの」　なんて女給にからかわれてもまるで気にする様子もない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人なみに青い事務セエードを頭にかけて机に倚つてはゐるものの、自分なぞする仕事が与へられず暇で困つてゐたのだ。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草、松葉町カフエードラゴン、と云うのが麗人求むなのだから、私は色々な事を空想しながら受付ける。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フルゥツパーラで、オレンジエードを飲んでその女のひとと別れると、谷村さんは、久し振りで肩で笑いながら下宿へ帰つて行きました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして私がまだ一杯のオレンヂエードを飮んでしまはないうちに、そのＴ君が元氣よくはひつて來た。",
              "citation": {
                "source": "旅の繪",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでオレンジ・エードを注文して、麦藁の管でチュウチュウ吸った。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴女みたいな方をお招きすることもありますのでネ」「だけど、このオレンジ・エード、なんだか石鹸くさいのネ。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは勿論、すこし前に食堂で彼女が飲んだオレンジ・エードに、一服盛ってあったというわけサ。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして私がまだ一杯のオレンジエードを飲んでしまわないうちに、そのＴ君が元気よくはいって来た。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドゥニャーシャ　あんたがここを発った時は、あたしまだこんなだったわ……（床からの高さを手で示す）ドゥニャーシャよ、フョードル・コゾエードフの娘よ。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこからは、サモエードがボートでベーリング海峡をわたしてくれらあ。",
              "citation": {
                "source": "少年たち",
                "author": "МАЛЬЧИКИ",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れどもまた「アーリヤ」民族を外にして、「マダガスカール」に於ても、之を発見し得可く、北亜米利加にも、之を発見し得可く、「サモア」にも之を発見し得可く、「フィン」人も之を語り、「エスキモー」も之を語り、「サモエード」人も之を語り、「ブシュマン」人も之を語る。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを後にし又向ふ＊ポリエードスとアバスとに――夢を占ふ老夫子ユウリュダマスの二人の子、其戰場に來るとき父は其夢占はず、　150ヂオメーデース猛勇に二人を屠り且つ剥ぎぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は印度王家の服を着けた太子の美しさを先程口を極めて説いたが、さて今また薄鼠色の軽そうなセルの上下、そしてそれに相応わしい灰色の深いヘルメットを持ち、婦人でも用いそうな瀟洒な鼠色のスエード革の靴を穿かれた小柄な太子の姿というものは、これもまた何とも言えぬ愛らしさのそれであった。",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの描出の模範はこれをテラメーヌ（訳者注　ラシーヌの戯曲フエードル中の人物）の物語のうちに求められる。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくオレの靴だけは踏むな、という『ブルー・スエード・シューズ』の歌詞が、象徴的だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈オレの青いスエードの靴だけは踏みつけるなよ〉」（武藤一羊・訳より）　エルヴィス・プレスリーを肯定するためのクリーヴァーの思想的な拠点は、おなじ本で次のようにのべられている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈からだ〉はつまり生命力であり、エロスであり踏みつけてはいけない、とうたわれたブルー・スエード・シューズは、生命力のシンボルだったのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "金の必要も次々に起こってくるし、六フランで買ったスエードの手袋も、朝は真っ白でも、夜会の頃にはいつも黄色に汚れていたりしてるんだろな、たまんねえ！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "オレンジエードのあついのを持って来たよ。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのとき、きみは紙しばいのじいさんに化けて、ぼくにねむり薬のはいったオレンジエードをのませただろう。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
