    "definitions": [
      {
        "index": 1,
        "gloss": "systems engineer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しいプロジェクトのために、優秀なSEを探しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は長年の経験を持つベテランSEです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "IT業界では、SEの需要が非常に高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "プロジェクトマネージャーからSEへのキャリアチェンジを考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "切り離すという意味のＳＥＶＥＲか、梃子のＬＥＶＥＲ、もしくは打ち消しのＮＥＶＥＲ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで画面の中央にでしゃばるのは、マッキントッシュＳＥ／３０だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "見りゃ、わかるだろうが」　高志は、ばかばかしそうに、横断歩道のむこうに見える「ＩＳＥＺＡＫＩ　ＣＨＯ」と書かれた、骨組だけの塔のようなものを、アゴでしゃくって示した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面には中国婦女子の顔が大きく油絵風に描いてあって、たぶんそれは誌名なのであろうが、“ＳＩＮ・ＳＥＩ・ＮＥＮ”と美国文字がつらねてあった。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "グルンドトリッグの国民高等学校・リングビイ農業学校・丁抹国立農民博物館・ＳＥＴＯ。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームズ・ウォレスとジム・エリクソンの書いた『ビル・ゲイツ　巨大ソフトウエア帝国を築いた男』（ＳＥ編集部編訳、奥野卓司監訳、翔泳社、一九九二年）も同社の歩みをじつに丹念に、しかも同社よりの史観にもとづいた『マイクロソフト』よりももう少し公平な観点から跡付けている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日本最大の計算機」を目指して大幅に機能を高めた第二号機、ＳＥＮＡＣ（仙台自動計算機、日本電気の商品名ではＮＥＡＣ―１１０２）のプロジェクトは、渡部たち工場側が研究所の協力を得て、同時並行で進めることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その直後に東北大学の通信研究所に搬入されたＳＥＮＡＣは調整に手間取ったものの、同年の十一月には動きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＳＥＮＡＣの計算能力を目の当たりにして、小林宏治はあらためて電子計算機の力を実感させられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気は本格的に電子計算機をやらなければいけない〉　小林はＳＥＮＡＣを前に、そう決意した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝送技術部に新設された電子計算機係に配属となり、ＳＥＮＡＣのプロジェクトに加わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五九（昭和三十四）年四月の入社そうそう、浜田はかつて石井がチーフを務めたＳＥＮＡＣプロジェクトの遺産と格闘することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそこに、防衛庁技術研究所から東北大学に納めたＳＥＮＡＣと同じものを作ってほしいとの申し入れがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学技術計算用のコンピューターを検討した結果、防衛庁はＳＥＮＡＣが最適であるとの判断を下した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "会計検査上の都合から、ＳＥＮＡＣは一九五八（昭和三十三）年三月に取りあえず東北大学に納入されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "★東北大学の大泉充郎らがどのような経緯で電子計算機の開発を目指し、渡部和らがいかに悪戦苦闘を続けたかは、東北大学側を情報源とした、八甫谷邦明「ＳＥＮＡＣ開発余話」（『コンピュートピア』一九七五年八月号）に詳しい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＳＥＮＡＣと同じものを作れと命じられた浜田は、工場に残されたぼろぼろの設計図を開いて頭を抱え込んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて日本電気がコンピューターに手を染めるきっかけを作った渡部和は、東北大学にＳＥＮＡＣを納めてから本業の伝送技術に戻り、その後は中央研究所で通信とコンピューター部門の管理にあたっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "１１８０　アルバラド　ＳＥ、　＃１１４、アルバカーキー、ニューメキシコ州、８７１０８。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "予はＡＮＤＥＲＳＥＮをアナアセンと呼ばず、アンデルゼンと呼ぶを恥ぢざるものなり。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は ＡＮＤＥＲＳＥＮ をアナアセンと呼ばず、アンデルゼンと呼ぶを恥ぢざるものなり。",
              "citation": {
                "source": "梅花に対する感情",
                "author": "このジャアナリズムの一篇を謹厳なる西川英次郎君に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＡＳＥＢＯＫＩＮもどこへやら、ここばかりは明るい光が窓に輝いている。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい夜の街、ＳＡＳＥＢＯも華やかに火花と輝いていますが、うごめいている人達は、なにか宿命のようなすてばちで、ただ暗い夜空をながめているようでならない。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＡＳＥＢＯは、朝鮮戦線の上り下りがまるで脈搏のようにはっきりひびいてくるのはなんとなく心細い様子である。",
              "citation": {
                "source": "エキゾチックな港街",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "内科医のところへ行くとありもせぬ病気をみつけ出されるのが怖いというので、絶対に足を踏み込まぬ男であったが、それほど気分が悪いのならジンかコニャックでも引っ掛けて、蒲団を被って寝ちまったらどうだと言ったら、グスタフは頭に響かせながら、「ＷＨＡＴ　ＮＯＮＳＥＮＳＥ！",
              "citation": {
                "source": "葛根湯",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "右側の車線のすじむこうにある高層ホテルには、ＳＥＩＫＯの英文字がブルー地に白。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
