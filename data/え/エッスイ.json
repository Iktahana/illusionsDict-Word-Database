    "definitions": [
      {
        "index": 1,
        "gloss": "overflowing (of a river)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
