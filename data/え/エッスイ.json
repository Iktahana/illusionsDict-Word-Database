        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大雨警報により、河川の越水に警戒が呼びかけられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "長雨が続き、ついに川が越水し始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "激しい濁流が堤防を越水し、町に押し寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "越水した水は、あっという間に田畑を水浸しにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「竜胆ですね」と私が云ふと、「今朝早く裏山で採つてきたのですが、色がすこし悪くつて」　さう云つてから「お部屋にお活けなさるのでしたら、もつといいのを、越水の原か、牧場まで行く道には、もうたんと咲いて居りますわ」とつけ加へた。",
              "citation": {
                "source": "挿頭花",
                "author": "津村信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "平大野球部選手越水とその仲間である。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（名刺を出す）念吉　　（油断を見せず、その名刺を受け取る）越水　　僕は、名刺を持ちませんが、そこの平大野球部の合宿所にゐる越水といふもんです。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "越水　　畑に肥料をやるのはいゝが、臭くつてやりきれない。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（越水とその仲間二人だけ手を挙げる）越水　　これだけか。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "越水　　まだあるぞ。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "越水　　別に取られるやうなもんも、置いてないからさ。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "越水　　さうぢやない。",
              "citation": {
                "source": "犬は鎖に繋ぐべからず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は人に助けられて高所に逃登り遙に駅中を眺ば、提灯炬を燈しつれ大勢の男ども手々に木鋤をかたげ、雪を越水を渉て声をあげてこゝに来る。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利義栄は前年の夏篠原長房に擁せられて兵庫に上陸し、摂津越水城に拠っていた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに丁度その頃、三人衆の親戚の青年で、三箇でキリシタンとなった武士が、越水城の青年武士と共に遊山に行った際、些細な言葉争いから仏像に不敬を加えるという事件が起った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロレンソは越水城で惟政に会い、日乗の返書を見せた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行は、親不知の嶮をこえ、越後にはいり、越水の宿まで来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……越水まで、お渡り下さるるもよし、また、主人がここへお訪ねしてもよいと申されます。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいや、主人秀吉様を、越水にお待ち願ってあるので、御都合のみを伺って、すぐ引っ返したいのです。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉の一行は、越水の街道にそう豪農らしい家に休息して、味噌漬で茶をのんでいた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけでも、お礼はこの方から申さねばならぬ」「時に、今日筑前を、越水まで迎えに来た若者は？",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一夕のことを、後の史家は「越水の会盟」といって、以後、関ヶ原戦後にまでつづいた豊臣家と上杉家との金石の盟約は、実に、この時、両者のあいだに結ばれたものだといわれている。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
