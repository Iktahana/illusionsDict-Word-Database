        "examples": {
          "standard": [
            {
              "text": "「焦らなくても大丈夫だよ。縁と月日というし、いつか良い巡り合わせがあるさ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "こればかりは努力でどうにかなるものではない。縁と月日に任せて待つのが一番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんなに願っていた再会がこんな形で叶うなんて、まさに縁と月日だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "むかしは、「縁と月日」と云ふ語ならずして、「栄曜に餅の皮むく」と云へる語なりし由也。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「縁と月日だ」「はゝあ」「気を長く待つようにと今も菊太郎さんに然う言って来た」「それじゃまだ手間がかゝりますか？",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
