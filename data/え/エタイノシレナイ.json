[
  {
    "uuid": "f6380c90-b3cd-5132-b806-c3eb18307db1",
    "entry": "得体の知れない",
    "reading": {
      "primary": "えたいのしれない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
