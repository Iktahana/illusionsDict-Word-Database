[
  {
    "uuid": "4f38f134-6e9d-541a-a3d2-297ddfabf55e",
    "entry": "榎",
    "reading": {
      "primary": "えのき",
      "alternatives": [
        "エノキ"
      ],
      "is_heteronym": false
    },
    "grammar": {
