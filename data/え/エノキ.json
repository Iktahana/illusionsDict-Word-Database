    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese hackberry (Celtis sinensis var. japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の広場に、大きな榎の木が堂々と立っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏には、榎の葉が濃い緑の陰を作り、涼を運んでくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "榎の木には、小さな鳥たちが集まってきて、賑やかだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そこにふるへ、かくれつつうかがひのぞく榎あり、いのりつつ、一心に幹をけづりしに、樹樹はつめたく去り行けり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧牛会社の前までくると日が入りかかって、川端の榎の霜枯れの色が実に美しい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の高坂橋の南詰に大きな榎樹があった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この榎樹から東の方に並んで数本の大きな椋の樹があった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、あの爺さんの庭先の手前の一本榎のところまで、この柴を脊負つて行くから、あとはお前が運んでくれよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の對岸の石垣の上には竹藪があつて、其の中から一本の大榎が聳えて居るが、其の梢の紅や黄を帶びた色彩が何とも云はれない美しい。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝の此方に畫架を据ゑて對岸の榎と赤い倉庫と薄との三角形を主題にして描き始めた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲の類　衣、依、愛、哀、埃、英、娃、翳、榎、荏（これは「榎」「蝦夷」「得」等の語に用いられる）乙の類　延、要、曳、叡、江、吉、枝、兄、柄（これは「枝」「兄」「江」「笛」「※」「吉野」「消」「絶」「越」等に用いられる）　こういう仮名は、甲の類も乙の類もすべて我々が「エ」と読んでいる仮名であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に挙げたように、甲の類は榎の木の「エ」、蝦夷の「エ」、物を得るの「エ」であり、乙の類は、枝の「エ」、中大兄の「エ」、笛の「エ」、吉野の「エ」、その他にも沢山ありますが、榎の木の「エ」は甲の類の「エ」で、甲の類の字を使って、乙の類の字を使ったものはない。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼さがりからは冬の陽の衰えた薄日も射さず、雪こそは降り出さなかったが、その気配を見せている灰色の雲の下に、骨を削ったような榎や樫の木立は、寒い凩に物凄い叫びをあげていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると暗くなった、杉、松、榎と処々見分けが出来るばかりに遠い処から幽に日の光の射すあたりでは、土の色が皆黒い。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のしかばねは、屋敷の庭の片隅にうずめられ、ひとりの風流な奉行がそこに一本の榎を植えた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "榎は根を張り枝をひろげた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "としを経て大木になり、ヨワン榎とうたわれた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "欝蒼とした欅、榎、杉、松の巨木に囲まれた万延寺裏手の墓地外れに一際目立つ「蔵元｜家先祖代々之墓」と彫った巨石が立っているのが、木の間隠れに往来から見える。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の対岸の石垣の上には竹やぶがあって、その中から一本の大榎がそびえているが、そのこずえの紅や黄を帯びた色彩がなんとも言われなく美しい。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝のこっちに画架をすえて対岸の榎と赤い倉庫とすすきとの三角形を主題にしてかき始めた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪は尽きて高い石垣、榎が空にかぶさって、浴衣に薄き日の光、二人は月夜を行く姿。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "表だけ見えて、欄干が左右へ……真中に榎の大樹があって仕切る、その二階がね、一段低くなって流に臨んで、も一つ高い座敷が裏に有りそうなんだ、夢だからね、お聞き。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト頬杖か何か、物思わしい風情で、熟とこっちを視めるらしい、手首が雪のように、ちらりと見えるのに、顔は榎に隠れたんだ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "榎はどこか、深山の崖か、遠い駅路の出入境に有る、繁った大な年｜経る樹らしい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや／＼裏庭の榎の大木の彼の葉が散込むにしては風もないがと、然う思ふと、はじめは臆病で障子を開けなかつたのが、今は薄氣味惡くなつて手を拱いて、思はず暗い天井を仰いで耳を澄ました。",
              "citation": {
                "source": "怪談女の輪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに中空を凌いで榎が一本、梢にははや三日月が白く斜に懸った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　土地の口碑、伝うる処に因れば、総曲輪のかの榎は、稗史が語る、佐々成政がその愛妾、早百合を枝に懸けて惨殺した、三百年の老樹の由。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪を掴んで釣し下げた女の顔の形をした、ぶらり火というのが、今も小雨の降る夜が更けると、樹の股に懸るというから、縁起を祝う夜商人は忌み憚って、ここへ露店を出しても、榎の下は四方を丸く明けて避ける習慣。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の商店の、夥しい、瓦斯、洋燈の灯と、露店のかんてらが薄くちらちらと黄昏の光を放って、水打った跡を、浴衣着、団扇を手にした、手拭を提げた漫歩の人通、行交い、立換って賑かな明い中に、榎の梢は蓬々としてもの寂しく、風が渡る根際に、何者かこれ店を拡げて、薄暗く控えた商人あり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすると、ここへ、痩枯れた坊主の易者が出るが、その者は、何となく、幽霊を済度しそうな、怪しい、そして頼母しい、呪文を唱える、堅固な行者のような風采を持ってるから、衆の忌む処、かえって、底の見えない、霊験ある趣を添えて、誰もその易者が榎の下に居るのを怪しまぬけれども、今夜のはそれではない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　立合の手合はもとより、世擦れて、人馴れて、この榎の下を物ともせぬ、弁舌の爽な、見るから下っ腹に毛のない姉御も驚いて目を※った。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年はおいら、おまえのきものは、一つも編んでやらないぞ。",
              "citation": {
                "source": "タネリはたしかにいちにち噛んでいたようだった",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえのきらいな、いっしょになると生き血を吸われるような人間でな、たとえばかったい坊だとか、高利貸しだとか、再犯の盗人とでもいうような者だったら、おれは喜んで、くれてやるのだ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
