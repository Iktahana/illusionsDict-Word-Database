    "definitions": [
      {
        "index": 1,
        "gloss": "those who meet must part (suggesting the transient nature of this life)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "大学の卒業式で友人たちと別れる際、会者定離という言葉が頭をよぎった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年連れ添った夫婦も、いつかは会者定離の時が来るのだと改めて感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅立つ友人に、「会者定離、また会える日を楽しみにしているよ」と声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "然しお上人さまがよう言わるる此の世のさまは、生者必滅、会者定離。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「諸行無常」だの、「会者定離」だのと聞けば、なるほどそれに違いないとうなずかれます。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "会者定離は人間の習いなれば、たれになごりか惜しき……（親鸞を見る）わたしもうよしましょうかしら。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、生者必滅、会者定離は浮世の定めでございます。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
