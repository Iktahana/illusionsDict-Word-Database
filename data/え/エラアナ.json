        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この魚は、他の種類と比べて鰓孔が目立つ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "幼生の段階では、鰓孔が外見から確認できることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ヒトの発生初期にも、一時的に鰓孔のような構造が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
