        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末に話題のSF映画を観てきたんだけど、映像がすごくて没入感が半端なかった！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔読んだSF小説を読み返してみたら、今では現実になりつつある技術があって驚いたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供が宇宙や異星人に興味を持ち始めたから、一緒にSFのアニメを見せてるんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このSFドラマ、ストーリーが斬新で毎週楽しみにしてるんだ。次回が待ちきれない！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "『銀河ヒッチハイカーズ・ガイド』というその本は、かなりしっちゃかめっちゃかのＳＦでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「銀河の知識を集成した百科事典」といえば、ＳＦファンの脳裏にはもう一つの大著が、即座に浮かぶでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "超空間をジャンプして恒星間旅行を可能にする宇宙船や、立体映像の再生装置、電子銃、電子銃が噴き出す原子流を吸収してしまう力場防御壁と、ＳＦらしい道具建てはいくつも出てきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＦの中に登場した二つの巨大な百科事典は、紙の本から電子本へと移行することで大きく変わりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "特殊撮影技術を集めた『ＳＦＸミュージアム』や、映像作家たちの仕事をさらう『映像の先駆者』シリーズの関連で、初めて渡米すると、ＭＩＴ（マサチューセッツ工科大学）の研究所、メディアラボに籍を置くというボブ・スタインという人物から連絡がありました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡庸なＳＦ物に登場するＣＡＤソフトで描き上げたような辻褄の合った未来都市など、生まれるわけはない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初代のパームトップが出た頃には、手書きなどできの悪いＳＦ映画から引っ張りだしてきた実用性のないガジェットだと言い張ろうと思えば言えたろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダグラス・アダムスのＳＦ、The Complete Hitch Hiker's Guide to the Galaxy では、電子手帳ほどの大きさの「銀河ヒッチハイカーズ・ガイド」という電子本が、重要な舞台回しを演じる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソロモンはＳＦドラマの「スタートレック」をテレビで見ている娘に、宇宙船エンタープライズに積んであるコンピューターの名前をたずねた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "応募作品のテーマには、ＳＦ小説の中で出会った「地中通信」技術を選んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＳＦ小説では、地中通信を月面での長距離通信技術と仕立てていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿の晒にもＳＦが入るので、あなたの肌襦袢のために大なる買占めをして一反サラシを買いました（！",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、ＳＦなんかでサイボーグっていうのがあるでしょう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して君は本当に自分自身がそれをやりたいと思った上でやっているのか、それともただそうやるべきものだと決まっているから何となくやっているだけなのか」　テレビの録画撮りを済ませ、世田ヶ谷の自宅の“ＳＦしてる”部屋に戻ってベッドに全身を投げ出すと突然電話のベルが鳴る。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽子は自分の部屋を“ＳＦしてる”と表現して遊びに来た友人たちに自慢していた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "録音スタジオから自宅の“ＳＦしてる”部屋に戻ると陽子は全身の力を弛緩させて絨毯に寝そべりながらＣＤでジャン・ミッシェル・ジャールの『ズールック』を聴いた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "作り物だと一目で分るメーキャップの巨人のフランケンシュタインが下手な演技でミニチュアのビルを破壊する不自然さが、むしろ最新のＳＦＸを駆使した今のスプラッタ映画より不気味だと隼人は思った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のなかで、自分ひとりでタイム・スリップしてるんだ」「アイディアとしては、面白い」「小説になるかい」「一種のＳＦだね。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
