        "examples": {
          "standard": [
            {
              "text": "「わあ、お皿からはみ出すくらい大きな海老フライだ！タルタルソースをたっぷりつけて食べよう。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "洋食屋の海老フライは、衣がサクサクで中は驚くほどプリプリしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "子供の頃、デパートの大食堂で食べる海老フライが何よりの楽しみだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "馬鈴薯のコロッケにメンチ・カツ、そして海老フライが、それぞれふたつずつもあれば、充分でしょう。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "内田百間の「冥途」を読んでると、コン／＼カーンと食事を報せる音が響いた、オルドヴル、ポタジュ、車海老フライ、鶏とヌードル、うまい、たゞこれだけで来てゐるのだからな。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
