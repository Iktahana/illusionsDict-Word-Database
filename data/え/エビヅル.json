        "examples": {
          "standard": [
            {
              "text": "「あ、エビヅル見つけた！これ、酸っぱいけど食べられるんだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "山道で見かけた蝦蔓の蔓が、隣の木に力強く巻き付いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "蝦蔓の葉の裏には白い毛が密集していて、触ると独特の感触がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "帰りに『えびづる』や『あけび』をうんと土産に採って来ます」「私は一人で居るのはいやだ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民さん、僕は一寸『アックリ』を掘ってゆくから、この『あけび』と『えびづる』を持って行って下さい」「『アックリ』てなにい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えびづる草の実で酒をつくっているんです」と歩きながら津川が云った、「色は黒いし舌ざわりもちょっと濃厚すぎるが、うまい酒です、赤髯が薬用につくらせるんですがね、そのうちにいちどためしてみましょう」　薬園を出ると、津川は北の病棟のほうへ向かった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあそういってもいいけれど、こいつはえびづる草といって、自然に生える山葡萄の実でかもしたんだ、仕込んでから十五年も経つそうで、延命長寿の薬酒だということだ」「なが生きはごめんだね」　だが半之助は、舐めるように、それを味わった。",
              "citation": {
                "source": "山彦乙女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
