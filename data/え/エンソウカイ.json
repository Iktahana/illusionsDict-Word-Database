          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "休日の夜、私たちは久しぶりにクラシックの演奏会に出かけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年末には、毎年恒例の第九の演奏会が開催される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が出演する吹奏楽の演奏会は、来週末に市民ホールで行われる予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "演奏会当日、チケットはすでに完売となっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "昨年の晩秋、ヨオゼフ・シゲティというブダペスト生れのヴァイオリンの名手が日本へやって来て、日比谷の公会堂で三度ほど演奏会をひらいたが、三度が三度ともたいへんな不人気であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷公会堂での三度目の辱かしめられた演奏会がおわった夜、馬場は銀座のある名高いビヤホオルの奥隅の鉢の木の蔭に、シゲティの赤い大きな禿頭を見つけた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓でちょっと持出されたダンテ魔術団の話と、友人と合奏のときに出たフォイヤーマンのセロ演奏会の噂とでこの夢の西洋人が説明される。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことは作曲者かあるいは指揮者を同伴して演奏会へ行っても容易に得られない無言の解説である。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔明治音楽界などの演奏会で見覚えのある楽人達の顔を認める事が出来たが、服装があまりにちがっているので不思議な気がするのであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、これが、どこかへ演奏会を聴きに行くのだと、来客は断れるし、仕事は繰合せて、そうして定刻前には何度も時計を見るであろう。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏会せんとのしらせ、　　　いでなんにはや身ふさはず、豚はも金毛となりて、　　　　はてしらず西日に駈ける。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この弊を矯めるには演奏会で受けた感動を、その後に何か主動的な方法で表現しないではおかないという習慣をつければいい。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、音楽の演奏会の批評などは、その時に聞かなかった聴衆にはナンセンスである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ音楽会と言えば、音楽学校の卒業式の演奏会が唯一の呼び物になったがこれは自分らには入場の自由が得られなかった。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶が混雑して確かな事は言われないが、たぶんそういう種類の演奏会のどれかで私は始めてケーベルさんの顔を見、ケーベルさんのピアノの独奏を聞いたように思う。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただその後に一度｜駿河台の家へ何かの演奏会の切符をもらいに行った事がある。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の音楽学校で毎月開かれる明治音楽会の演奏会へ時々先生といっしょに出かけた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり、東京の演奏会の燭光はなつかしいものだ」　千歳の胸に、かつて、邦楽革新の新進作曲家として華やかしい期待を持たれていた慶四郎と、日蔭ものになって温泉場稼ぎをしている今の慶四郎とが比較された。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕の生活的慰楽は、時々諸方の音楽会に出かける行事であるが、この音楽の演奏会といふ奴が、実にまた不愉快な気分のものである。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏会に於ける、あの一種特別の空気、妙に厳粛になつて、悪がたく神経質になつてる聴衆。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で真に音楽の解つてゐる人々は、あの演奏会に集まるハイカラの青年や淑女でなく、実は市井でハーモニカを吹いてる商店の小僧たちである。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が理窟つぽくなつてきたが、とにかくさういふわけで、私は音楽会の気分が厭ひなため、性来音楽好きでありながら、演奏会に行くことは稀れにしかない。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラヂオの放送音楽なら、イヤな演奏会に行く要もなく、家にゐて寝ころび乍ら聴いてられる。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、相手が寿子の演奏会やレコード吹き込みの話を持ち出すと、庄之助は自分から演奏料の金額を言い出して、「鐚一文かけても御免蒙りましょう」　と、一歩も譲らなかった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "演奏会の話も、レコード吹き込みの話も、そして映画出演の話も、こうして、すべて立ち消えになってしまった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十一年十一月、渋柿）　　　　　　　＊　切符をもらったので、久しぶりに上野音楽学校の演奏会を聞きに行った。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は午後、ハレの演奏会へ行って、ノーマン＝ネルダーを聴きたいのだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズが演奏会に出掛けた後、私はソファで横になり、仮眠を取ろうとした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "同居人の帰りは遅かった――あまりに長いので、行き先は演奏会だけであるまいな、と感づいた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡に残っている人は為方がないので、公園内の飲食店で催す演奏会へでも往って、夜なかまで涼みます。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の演奏は、確か三四回目の演奏会だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流社会の貴夫人達の主催にかゝる、その日の演奏会の純益は、東京にいる亡命の露人達の窮状を救うために、投ぜられる筈だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもあの人が、重病の床から、免れて再び楽壇に復帰するという記念演奏会で、大変な盛会でした。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみか、思いもかけませず喀血を致しまして、明治音楽会に一つしか御座いませぬ大切なピアノを汚しましたために、折角の演奏会が中止になりましたとの事で、ホントにどうしてお申訳を致しましょうかと、思い出しては溜息を重ねているばかりで御座います。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
