        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "交渉の場でのエスカレは避けたいと、双方の代表者がコメントした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "状況のエスカレを防ぐために、迅速な外交努力が求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "軽微な意見の相違が、そのままエスカレにつながってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "出来ることなら老女が自分を乗せかけている果しも知らぬエスカレーターから免れて、つんもりした手製の羽根蒲団のような生活の中に潜り込みたいものだと思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階から二階へ人を運ぶためにエスカレーターを運転している時がある。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどエスカレーターの最下段に押して入れてやれば、あとはひとりで、少なくも二階までは持って行ってくれるのと同じようなものである。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓越しに見えるエスカレーターには、下から下からといろいろの人形がせり上がっては天井のほうに消えて行った。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事を考えながら、自分もエスカレーターに乗ってＭ百貨店の出口に突き出されたのであった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エレベータとエスカレータの研究の為急に東京に参り候、御不便ながら研究すむうちあの請負の建物はそのまゝお使ひ願ひ候」　お父さんの村長さんは返事も出させませんでした。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来ることなら老女が自分を乗せかけている果しも知らぬエスカレーターから免れて、つんもりした手製の羽根蒲団のような生活の中に潜り込み度いものだと思った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなこと書けばフロイト流の夢判断にうるさい連中の前にそれこそ裸をさらすようなものだけど、このオレはがきの頃、ぎっしり詰まったエスカレータの人の列の中に素っ裸の自分を発見してとんでもなく恥ずかしい思いをする夢に何度かうなされたことがある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッキングされた函は、二階からエスカレーターに乗って、運河の岸壁に横付けにされている船に、そのまゝ荷役が出来る。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスカレータアで投げ上げられた群集は、大抵建物の拱廊から下を覗いた。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春雄がエスカレーターに乗ろうというので二人で並んで乗った時は、さすがに彼は幸福そうで晴々としていた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "進学校のエスカレータに運ばれていけば、当然門をくぐることになる大学の意味を問おうとする呼びかけも、松本の耳には新鮮だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その仕掛は、エスカレーター式なものでもいいし、鉱山で使う吊りバケツ式でもいいし、また吸上げポンプを動かすことにしてもいいです。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物も二階以上は使用せぬゆえ、エレベーターやエスカレーターの費用が省ける。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エスカレーターのようだ」　と清君が囁いたけれど、皆真剣だった。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻のラッシュ・アワに、こういう男女の大群集が数万の眼をもつ無言の黒い流れとなって、地下鉄のエスカレータアに運ばれ、自働的に上ったり下ったりしている光景は、緩慢で大規模な屠殺場のようだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オックスフォード広場で、勤帰りを待伏せる春婦が、ショー・ウィンドウのガラス面に自分の顔を、内部にこの商品を眺めつつぶらつき、やがて三十分もするとロンドン市中、あらゆる地下電車ステーションの昇降機とエスカレータアは黒い人間の粒々を密集させて廻転する巨大な産卵紙となる。",
              "citation": {
                "source": "ロンドン一九二九年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の迅さに、人間の足幅が追いつかず、工合わるくエスカレーターに乗りでもしたように、とかく重心がのこって、足をさらわれ勝の生活ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスカレーターに乗ってテレビ売場の四階で降りしばらくぶらぶらと歩き回っていたが、ポケット液晶テレビばかりを陳列した棚のところでふと立ち止まり、財布を取り出してまだ十分余裕があることを確かめた上でカシオのＴＶ―３６０を買うことに決めた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "九階からはエスカレーターを使って上りミラーで囲まれた踊り場でふと佇む。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限に並ぶエスカレーター。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと我に返ると隼人は録画をストップさせ、エスカレーターで九階に降りた。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何気なくテレビのスイッチをひねるとエスカレーターとイルミネーションが巨大な鏡の中に無限に繰り返されている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二列のエスカレーターのようである。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスカレーターで上がっていくのが好きだと彼女は言い、呉服売り場までエスカレーターを乗り継いだ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "支払いをして包装してもらい、店員は彼女と深町をエスカレーターまで送った。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを持ってエスカレーターで七階まで上がった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスカレーターのわきに休憩用のスペースが広く取ってあり、クッションのきいたベンチがいくつも配してあった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
