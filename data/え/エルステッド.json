          "standard": [
            {
              "text": "磁場の強さを表す単位であるエルステッドは、科学者の名前を冠しているんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "実験では、磁界の強さをエルステッド単位で測定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このコイルが発生する磁場は、約100エルステッドに達するらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かくて警察署へ引致された後キエルステッド大佐によつて對審され大佐は彼を素裸にして身體檢査を行つた。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "又エルステッドの電磁気関係の研究はシェリングのロマン派的自然哲学に負う処があるらしい。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
