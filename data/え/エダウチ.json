        "examples": {
          "standard": [
            {
              "text": "台風で傷んだ庭木の枝打ちをして、樹形を整えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "老朽化した木の枝打ち作業は、専門業者に依頼するのが安全だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この時期に枝打ちをすることで、来年の花のつきが良くなるそうだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "杣の入るべき方とばかり、わずかに荊棘の露を払うて、ありのままにしつらいたる路を登り行けば、松と楓樹の枝打ち交わしたる半腹に、見るから清らなる東屋あり。",
              "citation": {
                "source": "書記官",
                "author": "川上眉山",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花田中尉は居ないか」　枝打ち透かす日の色が赤く土間を彩っているのだが、そこに女が一人いた。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
