[
  {
    "uuid": "6d7642fc-d03c-5a4a-b578-b0449420d23c",
    "entry": "演ずる",
    "reading": {
      "primary": "えんずる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-ずる変",
