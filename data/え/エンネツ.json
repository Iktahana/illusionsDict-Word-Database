    "definitions": [
      {
        "index": 1,
        "gloss": "sweltering heat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "炎熱の砂漠を何日も旅し、やっとオアシスにたどり着いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今年の夏は記録的な炎熱で、熱中症患者が急増した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "炎熱の中での作業は危険を伴うため、休憩をこまめにとるように指示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "句の表現するものは、夏の炎熱の沈黙の中で、地球の廻転する時劫の音を、牡丹の幻覚から聴いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓の生きて働く暑さ哉「生きて働く」という言葉が、如何にも肉体的に酷烈で、炎熱の下に喘ぐような響を持っている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細民街のぼろアパアト、黄塵白日、子らの喧噪、バケツの水もたちまちぬるむ炎熱、そのアパアトに、気の毒なヘロインが、堪えがたい焦躁に、身も世もあらず、もだえ、のたうちまわっているのである。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はバンマート沖の炎熱の下を進行していた。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二六　額の禿げ上った、見すぼらしい跛が、炎熱と塵埃にむれている石畳の小路へ這入った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　洋車は、塵埃と炎熱の巷へ吸いこまれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの日、三伏の炎熱、神もまたオリンピック模様の浴衣いちまい、腕まくりのお姿でござった。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の中に、秋がこっそり隠れて、もはや来ているのであるが、人は、炎熱にだまされて、それを見破ることが出来ぬ。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりからの炎熱とともに、ただならぬ悪臭を放つようになった。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ炎熱いので甲乙は閉口しながら渓流に沿うた道を上流の方へのぼると、右側の箱根細工を売る店先に一人の男が往来を背にして腰をかけ、品物を手にして店の女主人の談話しているのを見た。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し今の塲合何も言はずに辛抱して喰つたが、印度洋の炎熱が、始終其上を燒く樣に照して居るのだから堪らない、其晝食の時、一口口にした無邪氣の少年は、忽ち其肉を海上に吐き出して、『おや／＼、どうしたんでせう、此魚は變な味になつてよ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠等が炎熱を冒して、流汗面に被り、気息｜奄々として労役せる頃、高楼の窓半ば開きて、へいげん帷を掲げて白皙の面を露し、微笑を含みて見物せり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大切な乳をかくす古手拭は、膚に合った綺麗好きで、腰のも一所に、ただ洗いただ洗いするんですから、油旱の炎熱で、銀粉のようににじむ汗に、ちらちらと紗のように靡きました。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "細民街のぼろアパアト、黄塵白日、子らの喧噪、バケツの水もたちまちぬるむ炎熱、そのアパアトに、気の毒なヘロインが、堪へがたい焦躁に、身も世もあらず、もだえ、のたうちまはつてゐるのである。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みるかぎり赤道下の炎熱に鉛のごとき鹹水は炎と燃えて、海蛇の鎌首高く、たまたまに煌めき、さてはづぶづぶと青く沈みぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八月の炎熱はかうして平原の到るところの街々に激しい流行病を仲介し、日ごとに夕焼の赤い反照を浴びせかけるのである。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎熱｜焦くが如く樹葉皆な下垂するの時、海に下りて衣を脱すれば涼気先づ来る。",
              "citation": {
                "source": "客居偶録",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ私は今、眼前に、炎熱と颱風と地震との幾世紀の後、尚熱帶植物の繁茂の下に埋め盡されもせずに其の謎の樣な存在を主張してゐる巨石の堆積を見、又一方、巨石の運搬どころか極く簡單な農耕技術さへ知らぬ・低級な現住民の存在を知つてゐるだけである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ私は今、眼前に、炎熱と颱風と地震との幾世紀の後、なお熱帯植物の繁茂の下に埋め尽されもせずにその謎のような存在を主張している巨石の堆積を見、また一方、巨石の運搬どころかごく簡単な農耕技術さえ知らぬ・低級な現住民の存在を知っているだけである。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新米の蜂須賀巡査は、炎熱の中に睡魔と戦いながら、流石にボンヤリ立っていた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は恰度あの惨劇の日と同じようにひどく暑い日だったが、喬介と雄太郎君と蜂須賀巡査の三人は、午後の二時半の灼くような炎熱に打たれながら、秋森家の横の道路を歩いていた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の末つ方、陸上の人は炎熱に堪へざらむ。",
              "citation": {
                "source": "月の東京灣",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は後には馴れて、爼橋外の撒水車の井戸のあるところに行きに帰りに寄つて、その鉄管に口をつけて、灰燼の中の炎熱に渇した咽喉をうるほすのを例とするやうになつた。",
              "citation": {
                "source": "地震の時",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもその観音といふのが、源頼義の持仏だつたさうで、頼義が安倍貞任を討つた時に、其処を通つたんだが、その時丁度炎熱が焼くがごとく、士卒が皆な渇き切つて何うにも彼うにもならなかつたんださうだ――』　不意にゴオといふ音がきこえて、鉄の欄干が向うに見え出して来た。",
              "citation": {
                "source": "水源を思ふ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご承知のごとく、昔は太陰暦でございますから、現今とはちょうどひと月おくれで、だから七月といえば、まさに炎熱のまっさいちゅうです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "われら北種は東西を通じて、おしなべて朝日を礼拝するのに、炎熱に苦しめられている南種は同じく太陽を神聖視しながらも、夕日に跪伏する。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年｜向島に水の出た時、貧民たちの窮状と、救護の現場を見せるつもりで、息のつまりそうな炎熱のなかを、暑苦しい洋服に制帽を冠った七八つの彼を引っ張って、到頭｜千住まで歩かせてしまった結果、子供はその晩から九度もの熱を出して、黒い煤のようなものを吐くようになった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑蔭　芝生に日光がそそいで、近くはかげろうに燃え、遠くは煙霧にかすみ、人はみどりに酔い、靴は炎熱に汗ばみ、花は蒼穹を呼吸し、自動車は薫風をつんざいて走り、自動車に犬が吠え、犬は白衣の佳人がパラソルを傾けて叱り、そのぱらそるに――やっぱり日光がそそぐ。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎熱に走り廻って汗をかいてるところへ傷口の血が全身に滲んで、この時はもう牛は一つの巨大な血塊に見える。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
