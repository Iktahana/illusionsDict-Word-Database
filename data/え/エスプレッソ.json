        "examples": {
          "standard": [
            {
              "text": "仕事の合間に立ち寄ったバールで、立ち飲みしながらクイっと一杯のエスプレッソを流し込むのが私の日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわっ、このエスプレッソ、すごく濃厚だね。砂糖をたっぷり入れて飲むのが本場流なのかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食後のデザートと一緒に、苦味の効いたエスプレッソを注文して口の中をさっぱりさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "エスプレッソを二杯に固ゆで卵をいくつ？",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソと固ゆで卵なのよ、いっつも。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソ・マシーンというのがあって、小さなカップにエスプレッソが二杯、同時に出来るの。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "固ゆで卵にタイミングを合わせてエスプレッソを二杯作って、食べるわけ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにも野菜やトーストを食べるんだけど、まず最初は、ほかのものは邪魔くさいからどかしておいて、エスプレッソと固ゆで卵を恵子さんは楽しむのよ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソと固ゆで卵を食べ終ってしばらくしてから、野菜とパンを食べてる。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソは二杯ずつだから、カップは四つ必要だなと、里里葉は思った。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのテーブルの上に、エスプレッソ・マシーンとドゥミタスが一客、置いてあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソ・マシーンの使用説明書を彼は読んだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒーの粉とミネラル・ウォーターを冷蔵庫から取り出し、彼は一杯のエスプレッソを作った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "香りと見た目はたいへんエスプレッソらしく、ほとんど瞬時にして、ドゥミタスのなかにエスプレッソが満ちた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "本と資料を見るともなく見ながら、彼は一杯のエスプレッソを飲んだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "キチンを出て配膳のカウンターに腰をもたせかけ、十畳のスペースごしにバルコニーのほうに視線を向け、彼はエスプレッソを飲んだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲み終わってキチンに入り、ドゥミタスを、そしてエスプレッソ・マシーンのフィルターを、彼は洗った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三杯めのエスプレッソを彼は作った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椅子とテーブルを考えごとのための場所にすればいい、などと思いながら彼はエスプレッソを飲んだ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソを飲み終え、ドゥミタスとフィルターをさきほどとおなじように洗い、彼は執筆室に入った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい仕事場のエスプレッソ・マシーンは彼女からの贈り物だ。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷はエスプレッソを注文した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソ・マシーンは調理台のいちばん端にあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソ・マシーンをセットしてから、福山は日比谷の前へ戻った。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソ・マシーンのドゥミタスにエスプレッソが満ちた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスプレッソ一杯の代金を日比谷から自分で受け取り、福山は名刺を差し出した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はエスプレッソを注文した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のエスプレッソがテーブルに届いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷さんは美代子のことを危険な人と読んだのね」　テーブルに彼のエスプレッソが届いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は校長先生がいらっしゃるそうですから、お目にかかることになると思うわ」　おたがいにエスプレッソを一杯だけで店を出た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
