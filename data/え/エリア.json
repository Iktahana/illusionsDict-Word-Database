        "examples": {
          "standard": [
            {
              "text": "このエリアはまだ開発が進んでいないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ゲームのこのエリアは敵が強いから注意しろよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "弊社は東京23区を主要なサービスエリアとしています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "避難区域は指定されたエリア以外には立ち入らないでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "やう／＼女神エジエリアの洞にたどり着きて、われ等は朝餐を食べ、岩間より湧き出づる泉の水に、葡萄酒混ぜて飮みき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "E. Pierotti,‘Customs and Traditions of Palestine,’ 1864, pp. 79―80 に、豫言者エリアスがカメルン山を通つた時、渇して瓜畑の番人に瓜一つ乞ふと是は石なりとて與へず。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリアス彼に、石と云つた瓜は石に成るぞと云つて去つた。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "北ウヱールスのデムビシャヤーのエリアン尊者の井近く尼樣の女住む。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつは通称「上の道」で、校舎裏玄関から出て、陸上グラウンドと細長い校舎にはさまれ、途中で直角に曲がり、グラウンドの短いほうの辺、野球場の一塁側ファウルエリアに沿い、一塁のわきから短い橋をわたり、本棟が建つ台地の一〇五のまえに出るものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "左翼ファウルエリアの家が、もう一歩踏みだせば、陸上グラウンドに橋頭堡を築けるが、急な斜面と金網が、その侵攻をかろうじて阻止している。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚の挿画にアルジエリア・マントを肩にした Pandus と称ふひとりの海賊が、ひとりの美女を抱き寄せ、長い頤鬚を撫でながら蠍座の星に祈つてゐた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして女房は、夜目にもあざやかな白地に｜トラムペツト・フラワーの縫取りを施した白孔雀のやうなアルジエリア・マンに包まれて、婀娜たる羽根扇を擬して、片脇には胡桃色の軽快なリイガルを抱へ、脚には七宝を鏤めた鞣皮のサンダルを結んだ。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――斯んな出来事は知らずに先へ行つたアルジエリアのマントが、櫓の上から、頻と私の新しい名前を呼んでゐるらしかつたが、広場の騒ぎと、三人の鼾きの雷鳴にさへぎられて、何うしても私の耳には、それが判別が出来なかつた。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も早くからケーテの才能を認めて、そのために一部の者からは脳軟化症だなどと悪罵された批評家エリアスは、心をこめて、この連作が「確りしたつよい健康な手で、怖ろしい真実をもぎとって来たような像である」ことを慶賀した。",
              "citation": {
                "source": "ケーテ・コルヴィッツの画業",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "クパチーノ学区の科学展にこの一〇ビット並列加減算器を出品したウォズニアックは一等を獲得し、そのあとに開かれたベイエリア科学展では、年上のライバルたちに伍して三等に食い込んだ★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚かされたのは、自由に範囲を選んでエリアごと移動できるようにした、投げ縄のアイコンで示された機能だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも航路をズッと北に取り過ぎて、晩香坡とは全然方角違いのアドミラルチー湾に深入りして雪を被った聖エリアスの岩山と、フェア・ウェザー山の中間にガッチリと船首を固定さしているのには呆れ返った。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが波かと思う紺青色の大山脈が、海抜五千｜米突の聖エリアス山脈を打ち越す勢いで、青い青い澄み切った空の下を涯てしもなく重なり合いながら押し寄せて来る。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの波の絶頂に乗上げると、岩と氷河で固めた恐ろしい恰好の聖エリアスが直ぐ鼻の先に浮き上る。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下の波の大山脈の重なりを、夜通しがかりで白泡を噛みながら昇ったり降ったり、シーソーを繰り返して翌る朝の薄明りになってみると、不思議な事に船体は、昨日の朝の通り聖エリアスとフェア・ウェザーの中間に船首を固定さしている。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長は、真向いの聖エリアスの岩山に負けない位のゴツゴツした表情で云った。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦い苦い顔をしたまま十八倍の双眼鏡を聖エリアスに向けた。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人はそのまま気拙い思いをして別れたが、それから第三日目の朝になっても、依然としてフェア・ウェザーとセント・エリアスが真正面に見えた時には、流石の俺も、ジイイーンと痺れ上るような不思議を、脳髄の中心に感じた。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、「エリアの火」を呼ぶ必要はあるまいか……永遠に燃えて居る鉄の火箸を具へて置くのだ。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、栄一はハムレツトがオツフエリアの葬列を見たより以上に――栄一はその時さう感じた――実在に対する驚異と悲哀に泣いた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アクエリアム」で熊使いが熊を使うと云う事が載っている。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎奉行宛に一通、与力同心衆一同として一通、甲必丹オルフェルト・エリアス殿並に館員御一同として一通、吉雄幸左衛門宛に一通、西善三郎へ一通、手早く認めて使者に持たせて出してやり、朝食をおわると下帯一つになって芭蕉扇で胸のあたりを煽ぎながらぐっすりと寝込んでしまった。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋の中には奉行始め出島乙名、甲必丹オルフェルト・エリアスと館員一同、与力と同心が五人ずつ、吉雄幸左衛門、西善三郎、案内を出した人は一人も洩れなく先着していて、何事が始まるのかといった顔付で思い思いのところへ控えている。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "長崎ものがたり",
                "note": "青空文庫"
              }
            },
            {
              "text": "其のお蔭でアルジエリアと云ふ国の人達が餓死した事もあつた位だ。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「メインエリア」は、図書館で言えば書架・閲覧室の部分。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもカフカが死後に評価されたのも、ジャン＝ポール・サルトルやエリアス・カネッティら著名な作家・思想家が、自らの思想や考えをカフカのテクストに読み込むことが可能であったからこそだ。",
              "citation": {
                "source": "道理の前で",
                "author": "VOR DEM GESETZ",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にはせくる敵の將、エリアーロスの頭蓋の　410もなかに石を打ち當つる、堅き甲を被れる頭二つに碎かれて敵は地上にうつぶして、生を奪へるものすごき死の運命は彼を掩ふ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ミクロメータアにうつぶせになっている治子の白いエリアシを静代が見つめている。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンデルスゾーンのエリアを、「まやかし坊主の祈祷」と呼び、シューマンのある種の歌曲を、「小娘の音楽」と見なした――しかもそれは、貴顕の方々がそれらの作品を好んでいると仰せられた時にである！",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
