        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ＮＨとしてカミングアウトするまで、彼女は長年苦しんできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はＮＨとして、性別適合手術を受けることを決意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ＮＨの友人が、性自認について深く語ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
