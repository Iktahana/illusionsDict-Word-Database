    "definitions": [
      {
        "index": 1,
        "gloss": "(male-to-female) crossdresser",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あのバーでは、毎週末ＮＨのパフォーマンスが見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はイベントのために、プロのＮＨのメイクアップアーティストに依頼した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ＮＨとして生きる人々のコミュニティは、SNS上で活発だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらにこの番組を見たＮＨＫのディレクターの話に乗って、ブラウン管のアーティスト、ナムジュン・パイクと祝田久の二本立てで、子供向けの番組も収録したとのこと。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、すぐ近くの山にＮＨＫの中継局があって、おそろしくクリアに受信できるのは、なんの因果なのだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "買物に手間どったのと、令子がヘビをこわがったために、尾根道を二キロほどいかねばならない、ＮＨＫの中継所がある山はあきらめ、手近なところですませることにした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが深いショックを感じたのは、去年の一月、二人でＮＨＫから民主的文学について対談を放送したことがあったからであった。",
              "citation": {
                "source": "譲原昌子さんについて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "譲原さんというと、わたしにはＮＨＫで会ったとき、あの人の着ていた紫っぽいちりめんの羽織を想い出す。",
              "citation": {
                "source": "譲原昌子さんについて",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべ（八月一日）ＮＨＫの街頭録音は、「政党は選挙公約の実現に努力したか」という題目であった。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうのＮＨＫは、警視庁の役人をマイクに立たせて、減刑運動をとりしまる規則はないし、減刑運動の背後にある思想も言論の自由の立場からとりしまることができない。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下院でタフト・ハートレー法に賛成した七十名の議員が落選し、上院で八名ほどの議員がおなじ理由で落選したことが、ＮＨＫの放送でも語られた。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月三日の夜、ＮＨＫの報道放送で文学博士和辻哲郎は、天皇制護持の哲学上の基礎づけを行った。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＨＫは力をつくして変らないことのために努力しつづけてきている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＨＫ（日本放送協会）では、一九四七年四月の地方長官選挙にはじまる各種の選挙に対して全国四五局のマイクを解放して前年の総選挙同様各候補者の政見発表を放送した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高野岩三郎氏が死去されたのちＮＨＫの会長となった古垣鉄郎氏は、英語もフランス語も達者であろうし、行儀がいいことが必要な時と場合の分別もあり、貴族院議員だったし、文化人であろうけれども、ＮＨＫは、新会長によって会長流民主化におかれざるを得ない。",
              "citation": {
                "source": "「委員会」のうつりかわり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入力はスイッチ、出力は発光ダイオードのランプだけのシステムを部品を集めて手作りする一方で、竹松はＮＨＫの教育テレビで放送していたミニコンピューターの講座で、ベーシックやフォートランの文法を学びはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえり、ＮＨＫで、ろく音し直しして貰う。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山と私は、この対局がすんでから、ＮＨＫの依頼で、対談を放送した。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水幾太郎によると、二三の大新聞と、ＮＨＫが共謀すれば、思うがままに世論を作り出すことができるそうだ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＨ女史とＥＨ女史だつた。",
              "citation": {
                "source": "Ｌ氏殺人事件",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和三十年九月六日　ＮＨＫ国際放送〈英語〉にて、華南、南米を除き、全世界に放送されたもの）",
              "citation": {
                "source": "日本のやきもの",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスにも、ＮＨＫと似た性格のものがあって、そこでもラジオ大学の放送をしている。",
              "citation": {
                "source": "テレビの科学番組",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一月だったか、ＮＨＫを通じて、そこから、「雪と氷」という題で、六回連続の放送を頼まれたことがある。",
              "citation": {
                "source": "テレビの科学番組",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＨＫは世界でも類の少い、ぼう大かつ強力な公共放送である。",
              "citation": {
                "source": "テレビの科学番組",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともＮＨＫの方でも、その点はよく分っているらしく、地球物理学の連続講義のような、本格的なものも放送している。",
              "citation": {
                "source": "テレビの科学番組",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＮＨＫは、なかなか人使いが巧い。",
              "citation": {
                "source": "テレビの科学番組",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にこの番組を担当している若いＮＨＫの人たちは、実によく働いてくれるのであるが、無駄な労力をひどく使わなければならない。",
              "citation": {
                "source": "テレビの科学番組",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、ＮＨＫの人がやって来て、「映画もいよいよ二本立ですねえ、ありゃ一体どうですか」などと、さも映画を侮辱したような口調なものだから、腹が立って云い返した。",
              "citation": {
                "source": "映画界・小言幸兵衛",
                "author": "―泥棒しても儲ければよいは困る※―",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠居らしく、出しゃばらないようにしていようと思ってるんですがね、先だって、ぜひぜひと云われてＮＨＫの対談に出たんですがね。",
              "citation": {
                "source": "私は隠居ではない",
                "author": "吉田茂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日の七月二十六日、朝七時四十分からはＮＨＫＴＶ『私の釣り日記』。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、ＮＨＫテレビ「ここに鐘は鳴る」へ出、生涯のおもはゆさなり。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
