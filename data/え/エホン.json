    "definitions": [
      {
        "index": 1,
        "gloss": "picture book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この絵本、挿絵がとても綺麗で、子供が飽きずに楽しんでいるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「図書館で借りてきた絵本を、親子で一緒に読み聞かせする時間が好きだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「子供の誕生日プレゼントに、昔ながらの素朴な絵本を選んだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この絵本は、文字が少なくても、絵だけでストーリーが伝わるから小さい子にも安心だね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これを飲んだらあれを買ってやるからと云ったような事で、枕元には玩具や絵本が堆くなっていた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田道灌の「富士の高根を軒端にぞ見る」という歌は、余りに言い古されているとしても、江戸から富士を切り捨てた絵本や、錦絵や、名所｜図会が、いまだかつて存在したであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "四郎は怯えも取れて、いつものようにお蘭の側に坐ってどこかで貰って来た絵本を拡げてお蘭の説明を訊くのであった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後者の実例は場末の玩具屋の店頭で見られる安絵本のポンチなどがそれである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時老人は無意味な雑鬧の中で、孫にあたる、尋常三年の清造と七つになる勉に絵本を買って与っていた。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん俗悪な木版刷りではあったが、しかし現代の子供の絵本のあくどい色刷りなどに比較して考えるとむしろ一種稚拙にひなびた風趣のあるものであったようにも思われる。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所のお婆さんが来て、勝子の絵本を見ながら講釈しているのに、象のことを鼻巻き象、猿のことを山の若い衆とかやえんとか呼んでいた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかになかなか美しい人形や小箱なども陳列してあったが、いちばん自分の注意をひいたのは児童教育のために編纂された各種の安直な絵本であった。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "残念ながらわが国の書店やデパート書籍部に並んでいるあの職人仕立ての児童用絵本などとは到底比較にも何もならないほど芸術味の豊富なデザインを示したものがいろいろあって、子供ばかりかむしろおとなの好事家を喜ばすに充分なものが多数にあった。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでながら見本としてこの絵本の第一ページの文句だけを紹介する。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが国の教育家、画家、詩人ならびに出版業者が、ともかくもこの粗末な絵本を参考のために一見して、そうしてわが国児童のために、ほんの些細の労力を貢献して、若干の火事教育の絵本を提供されることを切望する次第である。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすればこの赤露の絵本などよりは数等すぐれた、もっと科学的に有効適切で、もっと芸術的にも立派なものができるであろうと思われる。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「絵本西遊記」を読んだのもそのころであったが、これはファンタジーの世界と超自然の力への憧憬を挑発するものであった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほれ見ろやい、末ちやんこんな絵本が出て来たぞ」「それや私んだよ、力三、何処へ行つたかと思つて居たよ、おくれよ」「何、やつけえ」　と云つて力三は悪戯者らしくそれを見せびらかしながらひねくつて居る。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉は本宅の茶の間の炬燵へちょこなんと這入って、しきりに戦争の絵本かなにかに見｜耽っている。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすれば、きっと、とてもきれいな絵本ができますよ」　そこでわたしは、いく晩もいく晩も、言われたとおりにやってみました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ただのバイオリン弾き Kun en Spilmand』とか、ここに訳出した『絵のない絵本 Billedbog uden Billeder』や、『スウェーデンにて I Sverige』、『わが生涯の物語 Mit Livs Eventyr』をはじめ、彼のほとんどすべての作品はこのとき以後のものである。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "『絵のない絵本』は、一八三九年から四〇年ごろを中心にアンデルセンの創作意欲の最も盛んなときに書かれたものである。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "『絵のない絵本』はこのように小さいにもかかわらず、きわめて多彩な素材を含んでいる。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの上には、絵本やおもちゃがいっぱいありました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "カイとゲルダは、そこにすわって、動物や鳥の絵本を見ていました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ゲルダが絵本を持っていくと、今度は、カイは、そんなのは赤ん坊の見るものだ、と言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、おばあさんの言うのには、そんな子はまだここを通らないね、でも、いまにきっとくるだろう、まあ、あんまり悲しまないほうがいいよ、サクランボでも食べたり、花でも見たりしていなさい、ここの花は、どんな絵本よりもきれいなんだよ、それに、その一つ一つが、お話をすることもできるんだよ、と言いました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな絵本でも、こんなに色あざやかで、美しいものはありません。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵本だと、骸骨ばかりの、恐ろしい姿にかかれているけれども、そんなふうじゃないね。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、すてきにおもしろいお話の書いてある絵本もありました。",
              "citation": {
                "source": "家じゅうの人たちの言ったこと",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りがけにチエ子の大好きな、絵本を買って来るようなこともなくなった。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかといって女中と遊ぶでもなく、今までの通り古い絵本を繰り返して拡げたり、いろんなものをジッと見つめたり、人の顔らしいものを地べたに描いては消したりして遊んだ。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに一体それさえほんとうに見ているのかただ眼がそっちへ向いてるように見えるのか少しもわからないのでしょう。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "素顔の雪に化粧して、皓歯に紅を濃く含み、神々しく気高いまで、お珊はここに、黛さえほんのりと描いている。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
