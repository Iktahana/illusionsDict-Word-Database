        "examples": {
          "standard": [
            {
              "text": "学校の先生が、エホバの学生に対する配慮について話していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "エホバの集会所は、街のあちこちに見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「最近、エホバの人たちがうちに来て、パンフレットを置いていったの。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
