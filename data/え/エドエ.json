        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "博物館で、見事な江戸絵のコレクションを鑑賞した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "葛飾北斎や歌川広重といった絵師たちは、数々の傑作たる江戸絵を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの古い掛け軸は、まさに江戸絵の趣があっていいね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これですよ」　半七老人は万延版の江戸絵図をひろげて見せてくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その事を話し出すと、それ、案の定、天井睨みの上睡りで、ト先ず空惚けて、漸と気が付いた顔色で、「はあ、あの江戸絵かね、十六、七年、やがて二昔、久しいもんでさ、あったっけかな。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れたろうよ、な、な、お前も、あの、江戸絵さ、蔵の中にあったっけか。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と幾度も一人で合点み、「ええ、織さん、いや、どうも、あの江戸絵ですがな、近所合壁、親類中の評判で、平吉が許へ行ったら、大黒柱より江戸絵を見い、という騒ぎで、来るほどに、集るほどに、丁と片時も落着いていた験はがあせん。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして東京みやげの「江戸絵」を染めたアニリン色素のなまなましい彩色がまだ柔らかい網膜を残忍にただらせていたころの事である。",
              "citation": {
                "source": "青衣童女像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母さんに貰った仲の町の江戸絵を、葛籠から出して頬杖を支いて見るようなもんだと思って。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきり、沈黙やぶれて、煤けたる江戸絵の壁に禁軍の紅帽あかり、はちはちと火の粉飛びちり、しづまりぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "横町は新五番町の一部で、普通の江戸絵図には現われていないほどの狭い路で、俗にいう三町目谷の坂下から東へ入るのである。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸絵といった、江戸絵の小路と、他町までも申しましたよ。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八方、諸国、流転の末が、一頃、黒姫山の山家在の荒寺に、堂守坊主で居りました時、千箇寺まいり、一人旅の中年の美麗な婦人――町内の江戸絵の中と……先ず申して宜しい。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が落ちると急に冷えて来て、春のまだ浅い夕暮れの寒さは、江戸絵を貼った壁の破れから水のように流れ込んで来た。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもただの江戸絵ではない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンは『あなたは今の東京を、廣重の描いた江戸絵のようなところだと誤解して居る』と申していました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸絵を貼った屏風をうしろにして、若い旅人が白い腕をまくっていると、若い遊女が紅さした口に水をふくんで、これを三栖紙にひたして男の腕を拭いています。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "千｜代紙や江戸絵をお土産にもらつて、明る日、村へかへつてきました。",
              "citation": {
                "source": "桜さく島",
                "author": "見知らぬ世界",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はある日美しい浮世絵（私たちは江戸絵と言った）の美人の張ってある屏風に向けて熱心に可笑しな真似をしていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が買ってくれた江戸絵の美しい木版画を丹念に写したりしたものです。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は幼い時から、母から江戸絵の美人画を与えられたせいか、人物画が好きでした。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一山のスケッチ帳　人物画は、江戸絵、錦絵のあった、東京方面にはよいお手本もありましたが、京都には花鳥の画家が多く、ほとんど美人画を見る機会がありませんでした。",
              "citation": {
                "source": "画筆に生きる五十年",
                "author": "――皇太后陛下御下命画に二十一年間の精進をこめて上納――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで同じ町内に吉野屋勘兵衛――通称よしかんという絵草紙屋がありましたので、私は母にねだって江戸絵や押絵に使う白描を買ってもらい、江戸絵を真似てかいたり、白描に色をつけては悦んでいました。",
              "citation": {
                "source": "あのころ",
                "author": "――幼ものがたり――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また並び床といって、三十軒も床屋があって、鬢盥を控えてやっているのは、江戸絵にある通りです。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "之等の句中には、いま昔を超越した、女らしさがあって、初版の上品な江戸絵を見る如きなつかしさ、美しさ古めかしさを覚えるのである。",
              "citation": {
                "source": "桜花を詠める句",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと馬場下とは高田の馬場の下にあるという意味なのだから、江戸絵図で見ても、朱引内か朱引外か分らない辺鄙な隅の方にあったに違ないのである。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ不正確なる江戸絵図は上野の如く桜咲く処には自由に桜の花を描き柳原の如く柳ある処には柳の糸を添え得るのみならず、また飛鳥山より遠く日光筑波の山々を見ることを得れば直にこれを雲の彼方に描示すが如く、臨機応変に全く相反せる製図の方式態度を併用して興味｜津々よく平易にその要領を会得せしめている。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点よりして不正確なる江戸絵図は正確なる東京の新地図よりも遥に直感的また印象的の方法に出でたものと見ねばならぬ。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の裁判制度は東京地図の煩雑なるが如く大岡越前守の眼力は江戸絵図の如し。",
              "citation": {
                "source": "日和下駄",
                "author": "一名　東京散策記",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の方はたいてい外套を着てるが、女の方になるてえと、手前がありだけのものをほうり出しても、まだ足りないくれえどえらい衣裳だぜ！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
