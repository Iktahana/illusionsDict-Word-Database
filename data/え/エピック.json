        "examples": {
          "standard": [
            {
              "text": "その冒険は、まさに現代のエピックと言えるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、長年にわたる努力の末、ついにエピックな目標を達成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「指輪物語」は、ファンタジー文学におけるエピックの代表例だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "かうした心境に住む室生君が、西洋風のリリックやエピックなど書くとすれば、それこそ却つて不自然に感じられる。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画「大地」はドラマでもなく、エピックでもなく、またリュリックでもない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日我が国の軍隊等で、少許のことを「じゃっかん」と言い、物乾場のことを「ぶっかんじょう」と言い、滑稽にまで無理に漢語を使用するのは、発音に於けるエピックな響を悦ぶのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "95　95―136 他のエピックよりの※入なるべし、此の場合にふさはしからず。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本と日本の家庭の一つの典型のエピック。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
