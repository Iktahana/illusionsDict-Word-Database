[
  {
    "uuid": "680371d6-2896-54bf-a547-e4f28769b6c4",
    "entry": "越中",
    "reading": {
      "primary": "えっちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
