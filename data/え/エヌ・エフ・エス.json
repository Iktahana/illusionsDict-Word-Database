        "examples": {
          "standard": [
            {
              "text": "複数台のサーバー間でファイルを共有するためにＮＦＳを設定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ＮＦＳのマウントオプションを調整して、パフォーマンスを改善する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古いシステムでは、ＮＦＳのバージョン互換性の問題に注意が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ウインドウ環境には、マサチューセッツ工科大学のＸ　Ｗｉｎｄｏｗ、マシンを結び合う信号路にはゼロックスのイーサネット、ネットワーク上でファイルを共有する仕組みにはサン・マイクロシステムズ社（アントニオ猪木の兄弟であるこの会社については、後で書く）のＮＦＳ（ネットワーク・ファイル・システム）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした試みの中から、サンはビル・ジョイの書いたネットワーク上でファイルを共有するためのＮＦＳ（ネットワーク・ファイル・システム）を標準に押し上げ、マサチューセッツ工科大学開発のＸ　Ｗｉｎｄｏｗがウインドウ環境の標準となれば、自らが開発したＮｅＷＳに加えてこれを採用する姿勢を打ちだした。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
