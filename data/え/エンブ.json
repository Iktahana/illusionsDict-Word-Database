    "definitions": [
      {
        "index": 1,
        "gloss": "waltz",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "宮廷の広間では、煌びやかな衣装を纏った貴族たちが優雅な円舞に興じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、まるで蝶が舞っているみたい！」と、少女は円舞の美しさに目を輝かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "三拍子の調べに合わせて、二人は呼吸を合わせながら華麗な円舞を披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台の最後を飾るのは、全出演者による息の合った円舞だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "すると闘牛士の大きな帽子が見事にそれを受けとめて、その鍵で中の潜んでいる扉を開くと、暗い場所から嵐のように闘牛が広々とした円舞場に踊り出るのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の旅程――　１　横浜外交官の無線電信の費用見つもり処、グランドホテル・ド・ヨコハマに設計された硝子張りの円舞場でスパルタの女と根岸の外人ティームとの間で弓術試合が行われた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "曠原紳士、村の娘たち、牧者、葡萄園農夫等　円舞。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてしろつめくさのいちめんに咲いた野原のまん中の心持、円舞終る。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（壇を下る　拍子、歓声、オーケストラ、〔数文字空白〕を奏する　円舞はじまる。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は黄ばみかかった落葉樹の下で、この菌の胡粉を塗ったような白い揃いの着付で、肩もすれずれに円舞を踊っているのを見たことがあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが妻よ、円舞曲の幻の後に続く狂騒章だ――と想像して、楽の音の嵐だけを聴いておいでよ。",
              "citation": {
                "source": "歌へる日まで",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり面白さうなので私も折々遅ればせに出かけては石灯籠の台に登つたりして、七重八重の見物人の上から凝つと円舞者連の姿を視守つてゐた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり面白そうなので私も折々遅ればせに出かけては石燈籠の台に登ったりして、七重八重の見物人の上からじっと円舞者連の姿を見守っていた。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、松原の向方から響いて来る波の音が実にも堂々たる円舞楽になつて彼等を覆つてゐる！",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "空をとぶ大きな鳥のたのしそうに悠々とした円舞を見あげて、あんな風にして自分たちも自由に空をとんでみたいとあこがれる人類の感情を、ギリシア人が、若々しい人類の歴史の若年期を生きつつ、自分たちの社会の伝説にとりいれたことはいかにも面白い。",
              "citation": {
                "source": "なぜ、それはそうであったか",
                "author": "――歴史・伝記について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして田野に円舞して、笑いさざめき歌を歌う生命の活気もなければ、専念に思考を練って穿ちに穿って行く強度も無く、表情が、力の欠乏に生気を失って居ると全く同様の状態が内奥の魂にまで食い入って居ります。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貪婪な嘴を突き立てて四面を一渡り円舞し、急に首を丸め爪で嘴をとぎながら扇子のように拡げた翼をとじて直下の姿勢をとった。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "円舞はたゆたひながら、だんだん彼の身ぢかへ接近して来た。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "テントの方から労働者音楽団が活溌な円舞曲を奏し出すといっしょに、　ソラ、右へ、右へ、　一　二　三　四！",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓の音につれて、老若男女が夜更けまで踊り楽しみ、その円舞の中央に明るく焚火が燃え続けるのである。",
              "citation": {
                "source": "広場のベンチ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "奏楽（中欧作曲家の円舞曲）　ルナアト・パリヤアニ中尉は、その晩、自分の部屋に帰ると、早速、ブレンネル地方の軍用地図をひろげ、条約で仮に決定されたアルプスの分水線に赤い線を書き入れ、コンパスで、重要な地点間の距離を測り、明日の集合地たるメンデル・パスまでの自動車道を選びました。",
              "citation": {
                "source": "けむり（ラヂオ物語）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼんやりと浮かび出てゐる薄ら赤い明りから人群の大部分はむしろはみ出しており、外側からは無論見えない樽太鼓を中に、村の衆は男女を問はず広い花笠に紅色の襷をかけて、唄ともつかぬ盆唄を祈祷のやうに呟きながら、単調な円舞を踊つてゐた。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "円舞をとりまいてゐる観衆の円陣を、さらに二人は遠くから黙々と一廻りした。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間ではグラン・ロン（訳注　大円舞）の最中。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから暫くして後、彼女は父親が大円舞に加わって踊っているのを見た。",
              "citation": {
                "source": "頸の上のアンナ",
                "author": "АННА　НА　ШЕЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処かの一と組がレコードの円舞曲をかけてゐる。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはスナップ写真で、エルザがいつも酒場でよく踊る円舞のあとで、彼女を撮ったものだった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "円舞曲（舞踏会）第二楽章。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の快楽――詠唱曲、メヌエット、円舞曲、および、行進曲。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "管絃楽の曲目には、エグモントの序曲、ワルトトイフェルの円舞曲、タンホイゼルのローマ巡礼、ニコライの陽気な女房の序曲、アタリーの宗教行進曲、および、北極星といふ幻想曲、などが含まれていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "管絃楽は、ベートーヴェンの序曲を几帳面に演奏し、それから円舞曲を猛然と演奏した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘たちが調子の狂った楽器の上でたたきちらすものは、幾つかの円舞曲とポルカ曲、バグダッドの太守の序曲、若きアンリーの狩の序曲、モーツァルトの二、三の奏鳴曲など、いつも同じものばかりで、またいつも音が間違っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "即興曲の中わけても「幻想即興曲」の甘美さ、円舞曲のうち「華麗円舞曲」の雄麗さ、「円舞曲｜嬰ハ短調」の幽婉さ、二十四曲の練習曲、四曲のスケルツォ、三曲のソナタ、四つの譚歌、哀れ深き夜曲の数々、二十四の前奏曲、十数曲のポロネーズ、夥しきマズルカ、――数え来るとショパンの作品は際限もない。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "えんぶだごんの価値でも説く事か、天女に対して、三銭也を口にする。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
