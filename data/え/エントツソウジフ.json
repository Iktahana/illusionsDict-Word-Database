        "examples": {
          "standard": [
            {
              "text": "「お父さんはね、ロンドンで一番腕のいい煙突掃除夫だったんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "煙突掃除夫の少年たちは、狭い煙道を通るために、いつも煤で顔を汚していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "煤まみれの作業着を着た煙突掃除夫が、梯子を立てて手際よく作業を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "〔無題〕今、煙突掃除夫の手、地獄の底を掻きまはした手、やけになりきつた手、痛快を死に賭けて悔いない手、その母が見たら泣きませう。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "別荘ではむろん煖炉など焚いていないので、煙突掃除夫が来ている筈はない。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に長いことしゃべったのがインテリ煙突掃除夫だ。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
