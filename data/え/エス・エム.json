          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あのライブパフォーマンス、演出がSMで、会場全体が熱狂の渦に包まれたよ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このアート作品、SMな視覚表現が特徴的で、見る人の心を揺さぶるね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "友人との会話で、昔の特撮番組のあのシーンがSMだったよね、と盛り上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "同時に文房具にＳＳＳというのが出来たので、改めてＳＭＳと改名した。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流儀でＳＭＳは、Ｍの字を男性のあるもの、Ｓを少年の意味に使って、ＳＭＳというと或る怪しからぬ行いを仕事にする団体という意味にしたものであった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にＳＭＳ団はＭＭＭ団と改称された。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方三菱電機は沖電気と組んでＣＯＳＭＯＳシリーズを、日本電気は東芝と組んでＡＣＯＳシリーズを、それぞれＩＢＭ非互換で開発することとなった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでシステム１００用にコンパクトＡＰＬＩＫＡのシリーズ名で書きためられた業種業務別のさまざまなアプリケーションが利用できるほか、ＢＰＣ用に開発を進めてきたＰＲＩＳＭと名付けたグラフ作成用プログラムも、ソフトウエアのラインナップに加えられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "前年、松本はＭＢＣ―１００と並行してＳＭＣ―70と名付けられるソニーのＣＰ／Ｍマシンの追い込みにもかかっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "予定を大幅に遅らせて一九八二（昭和五十七）年五月、まずアメリカ市場向けにＳＭＣ―70を発表した時点で、ソニーはマイクロコンピューターを８０８６に切り替える増設モジュールを提供すると予告し、ＣＰ／Ｍ―86に加えてＭＳ―ＤＯＳのサポートを約束せざるをえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソニーのＳＭＣ―70は、開発をほぼ完了した段階でＰＣの発表という衝撃波に見舞われた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ビットから一六ビットへの転換の隙間に足を取られて、ＳＭＣ―70は商業的には失敗に終わったが、松本はこのマシンの開発にあたって新しい技術的な経験を積んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＭＣ―70に関しても、直線的なイメージを生かしてすっきりとコンパクトにまとめた筺体のデザインが固められたあとで、松本は限られたスペースに高解像度のカラーグラフィックスを表示する基板を押し込むことを求められた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本はこのＡＳＩＣをパーソナルコンピューターでいち早く利用することによって回路の大半をＬＳＩに押し込み、ＳＭＣ―70の極端な小型化の要求に応えることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＭＣ―70の開発作業はソニーの厚木工場で進められたが、松本は同じ神奈川県内の中原区、武蔵中原にある富士通のＡＳＩＣ部隊に通っては、ＳＭＣ―70用の論理設計を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターで初めてＡＳＩＣを使いはじめたのはシャープのＭＺ―80Ｂだったが、松本もＳＭＣ―70でほぼ同じ時期に、専用のＬＳＩを起こすことを体験していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂｜ＮＡＲＺＩＳＳＭＵＳ（自己恋着）はこれにして、筆者の所謂積極消極両様の変態恋愛の交叉帰一点そのものの発露と見るを得べし。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二五年には、テネシー州ナッシュヴィルで、保険会社がラジオ局をひとつつくり、ＷＳＭ（「万人の生活を守る」という意味のスローガンの頭文字）と名づけ、一〇月に開局した。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイアル６５０をさがせばＷＳＭ局の『グランド・オール・オプリイ』が土曜日には必ずあったし、バーン・ダンスのかたちで、多くの局が、カントリー・ミュージックをながしていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＷＳＬ局の『ナショナル・バーン・ダンス』やＷＳＭ局の『グランド・オール・オプリイ』の人気は、カントリー・ミュージックのロード・ショウとプロモーションを生んだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＤＲの放送があるときには、ＷＳＭ局の『グランド・オール・オプリイ』も、さすがにお休みした。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "先頃、エイ・エス・エム・ハッチンスンと云う作家が（男です。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
