        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末に友達と待ち合わせで、駅前のSM（ショッピングモール）でぶらぶらしてたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "新しい服が欲しくて、近所のSMに買い物に行ってきたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供たちが遊べるキッズスペースがあるから、よく家族でSMに行ってるよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夕食を食べに、このSMにあるレストラン街に来たんだ。選択肢が多くて迷っちゃうね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
