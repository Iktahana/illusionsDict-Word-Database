        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "展望台から見下ろす宮島の夕景は、まさに絵にも描けない美しさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「龍宮城って、こんな風に絵にも描けないほど豪華な場所だったのかな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自然が作り出したその氷の造形美は、筆舌に尽くしがたく、絵にも描けないほどだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いま三鷹の施療ベッドにいるが、絵にも描けないような惨状なんでね」　と、しょんぼりした。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "急にあたりの水色まで赤くなったと思われる、絵にも描けない美しいみごとな赤ダイ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに反して城太郎の顔つきは絵にも描けないほど物凄かった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "水の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては、敵の謀略」　費耀のおどろきは絵にも描けないほどである。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いかに後醍醐の豪気といえ、暗夜、皇都脱出の挙に出ようなどとは、夢想もしていなかったことだから、その狼狽ぶりたるや、絵にも描けない。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
