          "standard": [
            {
              "text": "数学の授業で、楕円や放物線といった円錐曲線の性質を学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "惑星の軌道は、太陽を焦点とする円錐曲線の一部として記述される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この設計図には、複雑な円錐曲線を用いた構造が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "カジョリ（Cajori）の数学史にはこの人のことにつき、代数方程式を円錐曲線の交わりによりて解くことを、一種の方法として成り立たせるために最も功労のあった一人は、コラッサン（Chorassan）の詩人オマール・カイヤム（約一〇四五―一一二三）であった。",
              "citation": {
                "source": "芸術と数学及び科学",
                "author": "三上義夫",
                "note": "青空文庫"
              }
            }
          ]
        }
