        "examples": {
          "standard": [
            {
              "text": "絶体絶命のピンチに、彼は思わず叫んだ。「エリエリレマサバクタニ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人生で一番辛かった時、本当に神に見捨てられたような気持ちになった。まさに、エリエリレマサバクタニ、という気分だったよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "（演劇のセリフとして）「なぜ、なぜ私を見捨てられたのですか…！エリエリレマサバクタニ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "もう何もかも信じられない。完全に孤立無援だ。エリエリレマサバクタニ…。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
