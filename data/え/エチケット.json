    "definitions": [
      {
        "index": 1,
        "gloss": "politeness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初対面の方には、まず笑顔で挨拶するのが、円滑なコミュニケーションのための第一歩でしょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「電車の中では、静かに過ごしましょう。周りの乗客へのエチケットですよ。」とアナウンスが流れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、相手が誰であろうと常に礼儀正しく接しており、その洗練されたエチケットは周囲から尊敬されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "レストランで、ナイフとフォークの使い方が分からず戸惑っていると、店員さんがさりげなくエチケットを教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "この女達はいわばお互いのエチケットに夢中で、権右衛門の浪花節は碌にきかなかった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "社交上のエチケットだとか、または、趣味の向上だなんて事のために無理に芸術の「勉強」をしやしないのだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、家名だとか、エチケットだとか、そういう無意義な重荷を打ち壊す、強い意志を育ててくれる、何らの機会も環境も、私たちには与えられていなかったの。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の後ろに身長の高い紳士が、エチケットの本のように、淑やかに立っていた。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔、とにかく、カフェにある種の義理人情や、エチケットの存在していたのを知っている女給さんである。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと大使の奥様は私を余興の歌うたい扱いをしているんですから、欧米の社交界の慣例によって、プリマドンナをお客様に紹介する、エチケットも知ってか知らずか、お構いなしで、大統領はもちろんのこと、お客様に紹介しないで、私に歌をうたって頂戴とおっしゃるのです。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら形式打破を標榜し、徳義無視を標榜しても、社会生活には多少とも一種のエチケットが必要だから、痛手を与えた相手の前へ、のこのこ出て行きかねるという意味合いもあろうというものだ。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代日本人の庶民的風格といふものなどは実に愛すべく親しむべきものであるに拘はらず、欧羅巴や支那のやうな老大国では、その階級に相応しいエチケットがあつて、どうも具合のわるいことが多いといふ話も聞く。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんゴルフのエチケットなぞここでは無意味なばかりか、スコアの勘定も無意味である。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　航空会社と読売新聞と航空旅行そのものにあくまでエチケットをつくす志。",
              "citation": {
                "source": "新春・日本の空を飛ぶ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この国のもつとも豊かでもつとも愉しかつた大正年間にわれわれは上も下もなく知らずしらずの間に西洋のエチケットを習ひおぼえたのであつたらう。",
              "citation": {
                "source": "入浴",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただそれを表現しないエチケットなのである。",
              "citation": {
                "source": "入浴",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスでも、やはりエチケットがあるのだから、有名なレストランだからと言って、わけもなく怖れることはない。",
              "citation": {
                "source": "すき焼きと鴨料理――洋食雑感――",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれもアプレゲールのえげつないダンスゆえ、遊里のホールたるここでは、せめてエチケットとしてダンスだけは上品なものばかりを踊ってほしいのだと原さんが言った。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、これも先代ゆずりの座敷におけるエチケットだったのかもしれないが、いかにも春團治らしい色の濃くながれている話ではないか。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし当局者の言が新聞に出たところでは、躾という言葉は使いたくない、エチケットという意味だ、というようなことになっていた。",
              "citation": {
                "source": "六三制を活かす道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代青年のエチケットつて、あんな形式的なもんぢやないわ。",
              "citation": {
                "source": "悪態の心理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "関心や興味は大体伝習的に教育されているものであって、関心や興味にはいつも宗派的なエチケットがあるものだ。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "このエチケットを無視して関心を拡大するには特別な自信を必要とする。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、エチケットとしてぼくは彼の蒐集に一応の羨望は示しておいたけれどね。",
              "citation": {
                "source": "はやい秋",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕立舟ならともかくも、乗合舟は他人の迷惑になることがあるので、大衆のエチケットだけは覚えておかないと笑われる。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、川奈ホテルの朝の食堂ではよくキャプテン・エチケットのお愛想をこぼしている大倉喜七郎翁の姿をお見かけするが、あるとき私が翁の耳元へそっと『いったい毎日、ご自分のお部屋では、何をいちばん好むおかずとして召上ってますか』と訊いたところ、翁もまた声を低め『てへ、へ、へ。",
              "citation": {
                "source": "舌のすさび",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣り近所への、エチケットだというのである。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬を飼うには、飼うためのエチケットがあり、蓄音機を鳴らすには、そのための儀礼がある。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は成長していきたいということです」この最後の一行は、ホミの本心というよりは、先生に対するエチケットと言ったほうが正確だった。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　ヴィレの註によれば、〔honneste＝distingue'〕, de bon ton; habile＝capable. エチケットも心得ているがそれがただの形式でなく誠実味があり、学問の素養もあるが実際の仕事もできる人。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウージェーヌ、そう、彼はパリジェンヌの様々なエチケットを全然知らなかったのだ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理人も亦、芸術家なのだから、芸術家に対するエチケットを心得るべきである。",
              "citation": {
                "source": "駄パンその他",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "マ氏の水洟さえ、親友嘉治さんへの友情とエチケットになっている程だから。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
