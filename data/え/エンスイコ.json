        "examples": {
          "standard": [
            {
              "text": "世界には海水の数倍の塩分濃度を持つ塩水湖が存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その地域特有の動植物は、塩水湖の厳しい環境に適応している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "死海は有名な塩水湖の一つで、誰もが水に浮くことができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼等はとうに加特力僧どもがウクライナの地へ侵入して、哥薩克の民を加特力に改宗させつつあることも、二日にわたり、＊塩水湖附近で韃靼の軍勢が干戈を交へたことも口にしなかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩水湖　黒海沿岸の湖で、水に多量の塩分を含むところから、この名がある。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            }
          ]
        }
