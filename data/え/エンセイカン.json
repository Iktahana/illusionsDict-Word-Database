[
  {
    "uuid": "3a4e138f-c94c-516e-996f-c7bc16df8dd2",
    "entry": "厭世観",
    "reading": {
      "primary": "えんせいかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
