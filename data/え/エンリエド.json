        "examples": {
          "standard": [
            {
              "text": "戦乱の世を生きた人々は、厭離穢土の思想に深い共感を覚えたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の人生観は、この世の苦しみから抜け出したいという厭離穢土の念に根差している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの求道者が、厭離穢土欣求浄土の教えを心の拠り所とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此土即寂光土か厭離穢土欣求淨土か。",
              "citation": {
                "source": "三太郎の日記　第三",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
