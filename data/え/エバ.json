        "examples": {
          "standard": [
            {
              "text": "「この羽織、柄がとても華やかでいいね！」「ありがとう。これは絵羽っていう、全体に模様がついた仕立てなんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い着物についていた絵羽の羽織を、母が大切に保管していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この振袖、絵羽の染めが美しいね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
