          "standard": [
            {
              "text": "ピアノの発表会で、彼女は「エリーゼのために」を美しく演奏した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "カフェのBGMで「エリーゼのために」が流れていて、なんだか落ち着いた気分になった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "子供の頃、よく「エリーゼのために」を口ずさんでいたのを思い出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「この『エリーゼのために』にしましょうか」と云いながら、また別の楽譜をとりだして彼に示しては、「これはまだ弾けません」とわざわざ断ったりする。",
              "citation": {
                "source": "永遠のみどり",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この『エリーゼのために』にしませうか」と云ひながら、また別の楽譜をとりだして彼に示しては、「これはまだ弾けません」とわざわざ断つたりする。",
