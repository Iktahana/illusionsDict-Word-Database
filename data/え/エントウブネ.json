        "examples": {
          "standard": [
            {
              "text": "物語では、遠島船に乗せられた主人公の悲しい別れが描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "歴史書には、罪人を遠島へ運んだ遠島船の記録が残されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "港には、これから遠島船が出発するのか、多くの見送りの人々が集まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「その飼主は一貫文の科料、猿公は世間をさわがしたという罪で遠島、永代橋から遠島船に乗せられて八丈島へ送られました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで三甚は思いも寄らない手柄をしたのですが、自身番へひかれて行った時に、金蔵はたいそう口惜しがって、どうでおれは遠島船を腰に着けている人間だから、遅かれ早かれ御用の声を聞くのは覚悟の上だが、いざお縄にかかるという時には、江戸で一、二といういい顔の御用聞きの手に渡る筈だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "――遠島船の船印だ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やア、遠島船だ」「畜生、縁起でもねえ」「寄るんじゃねえ、寄るんじゃねえ」「平吉めら、どこに眼のくり玉をくっつけていやがる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹船の禁物は第一は遠島船。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠島船にあうと鰹の群来が沖へ流れるといって、たいへんに嫌う。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、船を寄せてみろ」　波のりぶねというぐあいにぼんやりと漂っている遠島船の腹へこちらの舳を突っかける。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭の喜三次、「じゃあ、おれが行く」　と、立ちかかったところへ、平吉が遠島船の棚縁から青い顔を出した。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうもなにも……」「よし、いま行く」　すぐつづいて、繩上の丑松、「おれも行こう」　こうなると怖いもの見たさで、船には楫取の和次郎をひとり残してわれもわれもとゾロゾロと遠島船へ乗りうつる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠島船はいうまでもなく囚人をつんで行く船だから特別なつくりになっている。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "与力と御船手が立ちあいの上で、送り帳と人間を照しあわせて間違いがないとなると、艀舟に乗せて品川沖の遠島船へまで送りとどける。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こいつア、すこし理屈にあわねえようだ」　と言って、真顔になり、「……遠島船のホマチといって、島流人の親兄弟にたのまれて、米味噌やら金子やら、御船手役人の眼を盗んでそっと島々の囚人におくりとどけ、また御法度の文づかいをして双方から莫大な礼をとる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでいろいろかんがえて見ると、遠島船にはむかしから弱い尻がある。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "遠島船",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の十蔵は、出先で捕まり、遠島送りになったが、途中、夜に乗じて、遠島船から海へとびこみ、江戸へ舞いもどって以来、自暴自棄な野性の生活力を逞うしている男だった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
