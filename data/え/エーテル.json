        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "実験室でエーテルの独特な匂いがした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古いSF小説には、宇宙空間を満たすエーテルという概念が出てくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昔の手術では麻酔薬としてエーテルが使われたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "有機化学の授業で、エーテル結合について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "氏の考案は光がエーテルの波動だという事を基礎としたもので、理論上実に巧妙なものである。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも始めはエーテルの弾性的の波であると考えられたのが、後には電磁気波でなければならぬと考えられることになった。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後にはエーテルと称する仮想物質の弾性波と考えられ、マクスウェルに到ってはこれをエーテル中の電磁的｜歪みの波状｜伝播と考えられるに到った。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また現今の相対原理ではエーテルの存在を無意味にしてしまったようである。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その近頃に発表した論文によると、この薬剤に酸素を混じて試験用の動物に吸入させてみたが一時間ほどごく安静に魔睡し、睡りからさめる時も速やかに醒め切って、エーテルやクロロホルムのようにさめ際の悪いようなことがなかったそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「無有入於無間」を「個体性のないものは連続的物質中に侵入する」と訳しているが、これは、何となく古典物理学のエーテルを云っているようで面白い。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上田から長野へ電線で送られた唱歌が長野局から電波で放送され、それがエーテルを伝わってもとの上田の発源地へ帰って来ているのである。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮に包まれているその姿は、今エーテルのように風景に拡がってゆく虚無に対しては、何の力でもないように眺められた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アインシュタインはそこで余儀なく絶対空間とエーテルの殻を砕いたまでである。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の空間は真の空虚であってエーテルのごときものでない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、水のおもては、まるでエーテルのようにきらめいて、大きな広い波となってうねりました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、貴子という女の体には、一種ふしぎな体温と体臭があり、エーテルのように章三を眠らせる作用を持っているのだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "エーテルを吸わせると彼は生き返り、それからさっさと健康を回復して、間もなく友人たちのあいだへ戻った、――彼らには彼の生き返ったいっさいの事情は病気の再発の懸念がなくなるまで知らされなかったが。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "光の波動を伝えていたエーテルも、今はきれいさっぱり消え去った。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "エーテルのように常に我等を取り巻く災厄の種に、ノホホンと警戒心を欠いていたオレが悪いと言えば悪い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り、全身麻酔にはクロヽフォルムとエーテルの混合液が使用されますが、私はそれをクロヽフォルムだけにしたならば、ヒステリックな患者はことによると手術中に死ぬかも知れぬと思いました。",
              "citation": {
                "source": "痴人の復讐",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず兎を、家兎固定器に仰向けにしばりつけてエーテル麻酔をかける。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原始状態はまたしばしば、たとえば日本の神話におけるごとく、原始エーテルという言語で言い表わされる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "『天と地とが未だ互いに分れていなかった昔にはただ原始エーテルがあったのみで、それはあたかも卵子のような混合物であった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "（注二）　エーテル。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "上層の純粋な天の気、後に宇宙エーテルとして、火、空気、土、水の外の第五の元素とされたもの。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、地を天（空気）と水から分ち、精微な空気（エーテル）を粗鬆な（普通の）空気から取り分けた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "（注二）陸と海、地と蒼穹とは分たれ、輝くエーテルと重き空気は分たれぬ。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気はそのエーテルより重きことはなお水の土よりも軽きがごとし、神はこれを雷電の座と定めければ、このときより多くの人の心はそのために安からず恐れ悩めり。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄めるエーテル、そは明るき遠方に重量なくまた地にあるごとき限界を知らず昇りたり――エーテルに今は星も輝き初めぬ。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神々は生のすべてのいかなる部分にも過ち犯すことなからんために、エーテルの中に光り浮ぶ。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくはまた地の土の中にエーテルの取り残されし一片の火花ありしか、この土を水に柔らげて神々の姿と容をプロメテウスの堅き手に作り上げしときに。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "原始の渾沌が次第に一定の形をもつようになった、太陽は巨大な灼熱された鉄塊であり、その他の星もやはり灼熱していた――それはエーテルとの摩擦のためであったというのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
