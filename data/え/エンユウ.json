[
  {
    "uuid": "01c3ed63-eac9-5e24-92a9-fd70cb085f65",
    "entry": "宴遊",
    "reading": {
      "primary": "えんゆう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drinking party hall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新年の幕開けは、盛大な宴遊で祝われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "仲間たちと、久しぶりに酒を酌み交わして宴遊した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭園では毎夜、月を愛でる宴遊が催されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "酒宴遊舞をなすものあり。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "此より日々招宴遊宴等がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝亀元年河内｜由義宮の行幸に「博多川に臨みて、以て宴遊す。",
              "citation": {
                "source": "和歌の発生と諸芸術との関係",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国のうたげと似て、宴遊を頌し、宮殿・園林を讃する何層倍も大じかけである方面は、有識の官吏に響いた。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯言ふべきは、離宮行幸が、全く支那の宮廷生活を模した宴遊であつた事だ。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴遊の中、日がへりの旅にも、行つた先で宴歌を作るのは、其行事が外国の写しだけに、歌詞も支那を学んで、小屋をさへ造らぬにかゝはらず、宴歌がやはり歌はれる事になつたのだ。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも其間にやはり、古い意義を存して、天子外出の時の方法としての警蹕・反閇の形を、少しく大きくして、新室ほかひのない宴遊をしたものと考へられぬでもない。",
              "citation": {
                "source": "叙景詩の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、どうして其等の相聞歌が散逸せなかつたか、即興以外には纔かに宴遊の余興に於て、だが、はつ／＼好事の漢風移植者たる大伴旅人・家持一味の人々の文芸意識を持つての遊戯が見える位に過ぎない時代に、悲しみを叙して、繰りかへし贈答することがあつたとは思はれぬ。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此分離の原因の表面に出たものを「宴遊即事」にあると見てゐる。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ、支那宮廷の宴遊の方式と共に、厳り立てた園池・帝徳頌讃の文辞が入りこんで来たのだ。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "朗詠が、異様に、長目な音脚意識と、華やかで憑しい音調とを刺戟して、和漢混淆文の発生を促した様な事情が、短歌の側でも見られるのである、宮廷・豪家の生活に、神事の「解忌」として行はれた直会の肆宴以外にも、外国式の宴遊の儀が加へられて来た。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏歌の場合に限らず、かうした宴遊の酒間・水辺にも、即事の唱和があり、歌垣系統の勝負争ひもあつたらしい。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした宴遊の場に於てくり返された労苦が積りつもつて、短歌成立前から兆して居た創作動機を、故意に促す文学態度が確立した訣である。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良の古詞憧憬は、儀礼・宴遊の詞章を神聖視した為で、本縁あるもの、豪家に伝来久しいもの、歴史背景を思はせるものなどの散佚したのを、採録して置かうとしたのに違ひない。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方宴遊の場合に詩文を相闘し、鑑賞し合ふのに、国語を以て出来ぬまだるこさと、教養不足とから、自然宴遊詩から宴遊歌に移つたのであらう。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、一時衰へた短歌は其衰へさせた人々によつて、復活せられて、文学遊戯の対象となり、宴遊を種とした小説や、更に進んでは、上官への哀訴を寄せた告白文などにさへなつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "其叙景の歌とても、宴遊の即景に祝言を託する様なものか、人の意表に出る様な誇張や、言ひ廻しで、興趣の嵐を起して、当座の人の心を捲き込んで行くと言ふ風なものであつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の生時は、其宴遊の歌の、在来の型を破つた新しさ、放胆らしい其調子によつて、騒がれてゐたものであらう。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌合せは整理せられて、宴遊の形をとつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌垣の歌の、古詞何々｜振を繰り返す様になつて行く一方に、風雅な遊戯・宴遊の方便に用ゐられた側が、次第に、文学態度の意識を生じて来た。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が、後鳥羽院になつてから、ずつとくだけて、宴遊の形を持ち出した。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴遊歌の発達して出来た叙景詩の素地も、其外に古くからあつた。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "叙事脈の賦・伝奇小説・情史・擬自伝体艶史の影響が、新叙事詩を作り出した様に、稍遅れて、漢詩の観察法・発想法が、宴遊・覊旅の歌の上に移されて来た。",
              "citation": {
                "source": "女房文学から隠者文学へ",
                "author": "後期王朝文学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐風藻で見ても、宴遊・賀筵の詩が十中七八を占めてゐる。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此意味で、万葉巻八・十なども、宴遊の即事や、当時諷誦の古歌などから出来てゐる、と見る事が出来ると思ふ。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮廷・豪家の宴遊の崩れなる肆宴には、旧来の習慣として、男女｜方人を分けての唱和があつた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく厳冬の極つて、春廻る夜の行事に限られたのであらうが、飛鳥朝から、次第に其回数を増し、宴遊を以て宮廷の文化行事の一つと考へる様になつて、宴遊・行幸・賀筵が行はれた。",
              "citation": {
                "source": "万葉集研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
