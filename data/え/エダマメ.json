        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ビールのお供に、茹でたての枝豆は欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "スーパーで旬の枝豆を買い、夕食のおかずに追加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あー、一杯やりたいな。とりあえず枝豆頼む！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "「僕は学校へ往ってしまえばそれでよいけど、民さんは跡でどうなるだろうか」　不図そう思って、そっと民子の方を見ると、お増が枝豆をあさってる後に、民子はうつむいて膝の上に襷をこねくりつつ沈黙している。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お亀の家は浜町河岸に近い路地の奥で、入口の八百屋にも薄や枝豆がたくさん積んであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "おみちは餅の三いろ、あんのと枝豆をすってくるんだのと汁のとを拵えてしまって膳の支度もして待っていた。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておみちはそのわずかの畑に玉蜀黍や枝豆やささげも植えたけれども大抵は嘉吉を出してやってから実家へ手伝いに行った。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰って、厩の前から入って行きますと、お爺さんはたった一人、いろりに火を焚いて枝豆をゆでていましたので、亮二は急いでその向う側に座って、さっきのことをみんな話しました。",
              "citation": {
                "source": "祭の晩",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋が肥え枝豆がおいしくなるにつれて、月も清く明らかになる。",
              "citation": {
                "source": "草と虫とそして",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二社あたりへ客の寄るのは、夏も極暑の節｜一盛で、やがて初冬にもなれば、上の社の森の中で狐が鳴こうという場所柄の、さびれさ加減思うべしで、建廻した茶屋｜休息所、その節は、ビール聞し召せ枝豆も候だのが、ただ葦簀の屋根と柱のみ、破の見える床の上へ、二ひら三ひら、申訳だけの緋の毛布を敷いてある。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ、南瓜も飛び出せ、牛蒡も踊り出せ、枝豆、隠元、ささぎ豆、なた豆、落花生に胡麻の種、莢がはぢけた、赤ちやけた、化猫、雉猫、かま鼬、粟が尻尾を黄に垂れた。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに泡だったコップのビール、枝豆の緑、はためく白いテントの反射光だ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京都のモスリン会社の別荘で」とＭ君が枝豆をつまむ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "附近ではビールと枝豆がしきりに繁昌していた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋※の靡く様子から、枝豆の実る処、ちと稗蒔染みた考えで、深山大沢でない処は卑怯だけれど、鯨より小鮒です、白鷺、鶉、鷭、鶺鴒、皆な我々と知己のようで、閑古鳥よりは可懐い。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは枝豆を焦がしながら燒いて居るのであつた。",
              "citation": {
                "source": "彌彦山",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉蜀黍や西瓜や枝豆の殻が散らかっているなかを野良犬がうろうろさまよっていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの店にも枝豆がたくさん積んであるので、やがて十三夜の近づくのが知られた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし織田になっても武田になっても、氏元ほどの誅求はやるまいと皆が高をくくっているので、今川氏の盛衰を思うよりも、畔に植えた枝豆の出来栄えを気にしていた。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鮮やかな色の傍には掛茶屋めいた家があって、縁台の上に枝豆の殻を干したまま積んであった。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝豆なんかをそんなところにさらしておくなよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに泡だつコップのビール、枝豆の緑、はためく白いテントの反射光だ。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とＭ君が枝豆をつかむ。",
              "citation": {
                "source": "日本ライン",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の野菜はたくさんあるが、そのうちでも代表的なのは瓜と枝豆であろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青々した枝豆の塩ゆでも悪くない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうお終いものの枝豆なども持って来た。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所には、青い枝豆の束が、差し込んで来る日に炙られたまま、竈の傍においてあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかずは枝豆と罐詰の牛肉が少々とだった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄は肉にカイベツのあしらひを、北海道の涼しい夜風と同樣、初めての如く珍らしく思つたと同時に、香の物代りに出てゐたカイベツ並に枝豆の糠味噌漬けを甘いと感じた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はこのカイベツと枝豆の漬け物とを味はつて、それらを渠の北海道生活に於ける最初の知己であるかの如く思つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "奧から林檎をむいて持つて來たのが、義雄には昨夜の枝豆につづいてうまかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
