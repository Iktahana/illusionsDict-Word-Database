    "definitions": [
      {
        "index": 1,
        "gloss": "edamame (green soybeans)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
