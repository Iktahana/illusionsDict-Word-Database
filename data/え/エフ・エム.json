        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "I usually listen to the local FM station during my morning commute for the news and traffic updates.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "The concert was broadcast live on FM radio, so fans everywhere could tune in.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "She fiddles with the radio dial, trying to find a clear FM signal in the mountains.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "松田優作の霊前にぬかずいて役者馬鹿ＦＭ　ＴＯＷＮＳの大成を祈る　一九八九年十一月六日の夜、松田優作が死んだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通が出しているＦＭ　ＴＯＷＮＳというパーソナルコンピューターの新機種発表会に、危うく遅れかけたからだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのオレに、ＦＭ　ＴＯＷＮＳはデビュー当時の松田優作を彷彿とさせる走りを求めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてオレが東京駅から地下鉄の大手町駅まで走り、九段下で降りてまたホテル・グランドパレスまで駆けたのも、ＦＭ　ＴＯＷＮＳという名の原石がどう化けたのか、この目で確かめたかったからである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デビュー当時の松田優作は笑いものにしていたが、オレはＦＭ　ＴＯＷＮＳを馬鹿にしてはいない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＦＭ　ＴＯＷＮＳも、独自のＯＳに加えてＭＳ―ＤＯＳを使える準備も整え、「文字処理、数字処理もいけます」と謳ってはいる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＦＭ　ＴＯＷＮＳにおいて富士通がやりたかったことの味噌は、「コンピューターの手を借りて自らの思うところをより鮮やかに表現する」という、新しい世界の開拓だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十一月七日、息せき切って駆け込んだ新製品発表会は、この電子紙芝居によるＦＭ　ＴＯＷＮＳの表現力を表に立ててスタートを切ったばかりだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "息を切らせて走ってきたせいか、発表を聞きながらついうとうとと眠り込んでしまったオレは、タキシードで決めた関澤専務がＦＭ　ＴＯＷＮＳを駆使して大観衆を前にプレゼンテーションを決める夢を見た。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢判断にも一家言を持つこのオレが分析すれば、ＦＭ　ＴＯＷＮＳという可能性を秘めた原石にオレはもう一化けを期待しているということなのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "デビュー間もないＦＭ　ＴＯＷＮＳをいじくり回し、ＴＯＷＮＳ　ＧＥＡＲの目指すものに納得したオレは、となりで電源を入れっぱなしにしておいたマッキントッシュに目をやったとたん、富士通の新しいマシンが使いこなしの流儀を決めるウインドウ環境を持っていないことに気づいた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＭＳ―ＤＯＳをサポートするＦＭ　ＴＯＷＮＳは、ＭＳ―ＤＯＳにかさ上げしてマッキントッシュ型のウインドウ環境を提供する試みは採用するだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＭ　ＴＯＷＮＳもやがて、マイクロソフトのＷｉｎｄｏｗｓに関しては載せてくる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、自らのアプリケーションに一貫した個性を与える独自の環境を欠いてデビューした事実は、ＦＭ　ＴＯＷＮＳの役者人生をどう左右するだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしろ松田優作を失ったこの世でオレが望むのは、ＦＭ　ＴＯＷＮＳのもう一化けである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮沢りえが若さを謳うテレビＣＭをなんべん見せられるより、オレには関澤専務のパフォーマンスを一度見るほうが、表現の道具としてのＦＭ　ＴＯＷＮＳの可能性がよく分かる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで前者を取ったのが富士通のＦＭＲ―ＣＡＲＤで、後者を選んだのが日電のＰＣ―９８ＨＡ（みんな、覚えてるか？",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＭ　ＴＯＷＮＳがマクロマインドの技術によってマルチメディア取り扱いの基盤としてパワー・アップすれば、うちのマシンも涙を流して喜ぶであろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下電器のマシンが富士通のＦＭＲ互換であることを考えれば、健全な好奇心を持つものはこっちでも動くのではないかと考える。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松下のＰａｎａｃｏｍ　Ｍと富士通のＦＭＲは互換なのだから、こいつ向けにＯＳだけ売ってくれないのかとお願いしてみたが、これも予定していないとのことであった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このステレオだって、ＦＭを受信できる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、問題は、ＦＭの世界では、まだ新大陸が発見されていないことだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＭでは、百年昔、二百年昔、もっと昔の音楽が、最新のヒット曲のような顔をして、のさばりかえっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ティーネイジャーは、ＦＭになど、まったく注意を払わない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球かなにかの実況中継らしいので、ＦＭにするが、これも室内楽のようなものが流れている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にこの帯が破れてその部分から球状の遊星ＣＦＭ等また衛星Ｄｇｈｋができる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通はすでにこの年の四月、漢字ＲＯＭをオプションで追加できる初めての漢字パーソナルコンピューター、ＦＭ８を発表していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＦＭ８を追うために短期間での開発を余儀なくされたＰＣ―８８０１も、漢字ＲＯＭを標準で持つところまでは踏み切れなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通のＦＭ―11は、ベンチマークで唯一ＰＣ―９８０１と肩を並べる高速のマシンだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが八ビットからのプログラムの継承に関して、ＦＭ―11はＰＣ―９８０１のようなシンプルな解決策を提供できてはいなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
