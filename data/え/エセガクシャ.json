        "examples": {
          "standard": [
            {
              "text": "データを都合よく解釈するだけの彼は、似非学者に過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の論文は引用ばかりで、独自の研究がないため似非学者だと揶揄された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "専門家を装って誤情報を広める似非学者が後を絶たない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "似非学者、似非作家、似非インテリゲンツィアの恥知らずな戦争協力にたいして、声に出せない眼をきつく働かして、それに反撥し、それを非難していた人々も、知識人の中には数が少くないのであった。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
