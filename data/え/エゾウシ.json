[
  {
    "uuid": "4e2c0a6f-cb8a-5635-91dd-4c0f17989a08",
    "entry": "絵草紙",
    "reading": {
      "primary": "えぞうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
