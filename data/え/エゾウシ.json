      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "ezōshi (Edo-period illustrated story book)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "江戸時代の庶民は、絵草紙を読んで楽しんでいたんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古書店で、珍しい題材の絵草紙を見つけたんだ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この絵草紙は、当時の人々の生活を知る上で貴重な資料だよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、この絵柄、すごく面白い！」と子供が絵草紙を広げて歓声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そのころは既に広重の出世作、『東海道五十三次』（保永堂板）は完成され、葛飾北斎の『富嶽三十六景』が、絵草紙屋の店頭に人目を驚かしていたのであるが、その地図にある定火消屋敷で、広重が生れ、西の丸のお膝下で、名城と名山の感化を受けていたのだと思うと、晩年に富士三十六景の集作があったのも、偶然でない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも明治年代に出来た俗な絵草紙である。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょろひょろの小僧は、叩きつけられたように、向う側の絵草紙屋の軒前へ駆込んだんです。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「恨み重なるチャンチャン坊主」が、至る所の絵草紙店に漫画化されて描かれていた。",
              "citation": {
                "source": "日清戦争異聞（原田重吉の夢）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は「猫のお湯屋」の絵草紙を見たことがあって、「あれがもし、日本の女たちの入る風呂の習慣としたら、同性たちと一緒に話したり慰め合ったりしながら湯に入れて、こんな便利な風呂の入り方はない」と羨ましそうにいった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、袖を斜めに、ちょっと隠れた状に、一帆の方へ蛇目傘ながら細りした背を見せて、そこの絵草紙屋の店を覗めた。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸漿屋の店から灯が点れて、絵草紙屋、小間物｜店の、夜の錦に、紅を織り込む賑となった。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、粘土細工、積木細工、絵草紙、メンコ、びいどろのおはじき、花火、河豚の提灯、奥州斎川孫太郎虫、扇子、暦、らんちゅう、花緒、風鈴……さまざまな色彩とさまざまな形がアセチリン瓦斯やランプの光の中にごちゃごちゃと、しかし一種の秩序を保って並んでいる風景は、田舎で育ってきた私にはまるで夢の世界です。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この情景は昔の絵草紙などに書いてある。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあお前は先からの知己か、紋床に居て近所だから絵草紙屋と懇意になったというんじゃあないのかね。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目が日本橋の人形町で、柳屋といってね、……」十二「もうその時分は、大旦那がお亡くなんなすったあとで、御新姐さんと今のお嬢さんとお二人、小体に絵草紙屋をしておいでなすった。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すると姓は何とおっしゃるんで、柳屋は、何でしょう絵草紙屋をなすった時の屋号でしょう。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女世帯の絵草紙屋を棄てて、華族の女を媽にしたというので、酷くこの深川ッ児に軽蔑されるよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはその頃絵草紙屋にあっただまし物である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃絵草紙屋に吊るしてあった、錦絵の源氏の君のような顔をしている男である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "林之助がまだここにいる頃に粗相で一カ所破いたので、なにか切貼りをするものはないかと、彼は近所の絵草紙屋へ行って探した末に、鬼の念仏の一枚絵を買って来て貼り付けた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者、蔭間、力士、その他の芸人、占者、祈祷師、絵草紙、薬種、化粧品の行商人等の中にこの種の商売人が居たのであるが、今ではずっとこの範囲が広まっている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚五厘の絵草紙を子供が破りましても、大切にして長く持てば貴い物になると教えました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "売店の軒先に昔ながらの絵草紙が展げてあるのを子供達が恍惚として見あげてゐるさまを屡々瞥見した。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "西郷星　かの西南｜戦役は、わたしの幼い頃のことで何んにも知らないが、絵草紙屋の店にいろいろの戦争絵のあったのを記憶している。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの商店のうちでも、絵草紙屋――これが最も東京の歳晩を彩るもので、東京に育った私たちに取っては生涯忘れ得ない思い出の一つである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵草紙屋は歳の暮れにかぎられた商売ではないが、どうしても歳の暮れに無くてはならない商売である事を知らなければならない。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "錦絵の板元では正月を当て込みにいろいろの新版を刷り出して、小売りの絵草紙屋の店先を美しく飾るのが習いで、一枚絵もある、二枚つづきもある、三枚つづきもある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにいろいろの双六も絵草紙屋の店先にかけられる。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵草紙屋では歌がるたも売る、十六むさしも売る、福笑いも売る、正月の室内の遊び道具はほとんどみなここに備わっていると云うわけであるから、子供のある人にかぎらず、歳晩年始の贈り物を求めるために絵草紙屋の前に立つ人は、朝から晩まで絶え間がなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは子供の時に、麹町から神田、日本橋、京橋、それからそれへと絵草紙屋を見てあるいて、とうとう芝まで行ったことがあった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳の市を観ないでも、餅搗きや煤掃きの音を聞かないでも、ふところ手をして絵草紙屋の前に立ちさえすれば、春の来るらしい気分は十分に味わうことが出来たのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲売りが、菓子などとともに、「おうむせきえぞうしばんづけ」と、呼び売りして歩く習慣だった。",
              "citation": {
                "source": "あの顔",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
