        "examples": {
          "standard": [
            {
              "text": "この現象の「得体のが知れない」原因を、専門家たちも解明できずにいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人間関係は時に「得体のが知れない」もので、相手の本心を見抜くのは難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女の過去は謎に包まれており、「得体のが知れない」部分が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
