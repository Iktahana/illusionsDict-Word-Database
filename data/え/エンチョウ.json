  {
    "uuid": "4dd3715d-5569-5bcf-a169-7147d622ed3c",
    "entry": "延長",
    "reading": {
      "primary": "えんちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
