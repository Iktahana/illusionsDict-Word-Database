        "examples": {
          "standard": [
            {
              "text": "手指の消毒用に常備しているエタノールが切れてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インフルエンザ対策として、ドアノブをエタノールで拭くのは効果的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "燃料電池の新たな研究で、エタノールの効率的な分解方法が鍵となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "リン脂質はトリグリセリドの１つの脂肪酸がコリン−リン酸またはエタノール−リン酸で置き換えられたものと考えることができるであろう。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてステッテン(24)は重窒素で標識したコリンおよびエタノールアミンを使って実験を行った。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "コリンの重要な性質はメチル基にだけ存在し、ステッテン(24)が示したようにこの分子の他の部分はアミノエタノールまたはグリシンから作ることができるようであった。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に彼らはエタノールを被験者に少しづつ与えるとエネルギー原になることを発見した（20）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
