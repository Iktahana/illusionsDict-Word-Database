    },
    "definitions": [
      {
        "index": 1,
        "gloss": "school trip",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「明日の遠足、お弁当に唐揚げいっぱい入れてね！」と娘が嬉しそうにリュックを詰め直している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小学校最後の遠足が雨で中止になり、代わりに体育館でレジャーシートを広げておやつを食べた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "遠足のしおりを何度も読み返しながら、集合場所までの電車賃を小銭入れに用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "自分よりは一つ年上の甥のＲと二人で高知から室戸岬まで往復四、五日の遠足をした。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乘り込んだ汽車は何處かの女學校の遠足で滿員であつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠足にしては唯一人といふのも可笑しかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車は小學校の遠足のかへりで一杯であつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとまた反対に向うへ行く人々の中には写真機を下げて遠足にでも行くような呑気そうな様子の人もあった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一｜中隊ぐらいで、鉄橋の上を行く汽車よりはもっとゆるく、小学校の遠足の列よりはも少し早く、たぶんは中隊長らしい人を先頭にだんだん橋を渡って行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西田幾多郎先生をお誘いして貴船へ遠足してアマゴでも食べようということになった。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根は二十年も昔水産関係の用向きで小田原へ行ったついでに半日の暇を盗んで小涌谷まで行ったのと、去年の春長尾峠まで足を使わない遠足会の仲間入りをした外にはほとんど馴染のない土地である。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは学校の遠足会で多摩川べりへ行ったことがあった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　遠足に疲れた生徒が、泉のほとりに群がって休息しているように、兵士が、全くだれてしまった態度で、雪の上に群がっていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一中隊ぐらゐで、鉄橋の上を行く汽車よりはもっとゆるく、小学校の遠足の列よりはも少し早く、たぶんは中隊長らしい人を先頭にだんだん橋を渡って行きました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はかつてこういうことがある、家弟をつれて多摩川のほうへ遠足したときに、一二里行き、また半里行きて家並があり、また家並に離れ、また家並に出て、人や動物に接し、また草木ばかりになる、この変化のあるのでところどころに生活を点綴している趣味のおもしろいことを感じて話したことがあった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗り込んだ汽車はどこかの女学校の遠足で満員であった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠足にしてはただ一人というのもおかしかった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車は小学校の遠足のかえりでいっぱいであった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「くいし（山名）へ行くにはどっちですか」「神社」「アツマコート」「小女山道」「昼飯」「牛を追う翁」「みかん」「いこいつつ水の流れをながめおれば、せきれい鳴いて日暮れんとす」など、とり止めもない遠足の途中のいたずら書きらしいものもある。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働に疲れ種々の患難に包まれて意気銷沈した時には或は小さな歌謡を口吟む、談笑する音楽を聴く観劇や小遠足にも出ることが大へん効果あるように食事も又一の心身回復剤である。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「遠足の試験だい。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこである日、先生につれられて、丘の上へ遠足にきたとき、小学生のひとりが、にれの木かげの銅像を指さして、「先生、この人が、ペテロじゃないでしょうか。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなく、あしたは春の遠足という日に、久助君はじしゃくをさがすため、茶だんすの引き出しをみなひっぱり出して、いろんなガラクタのなかをかきまわしていた。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の頃、遠足に行つたり何かして、金木の近くの幾つかの部落を見た事はあつたが、それは現在の私に、なつかしい思ひ出として色濃く残つてはゐないのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小学校二、三年の時、遠足で金木から三里半ばかり離れた西海岸の高山といふところへ行つて、はじめて海を見た時の興奮を話した。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」嫂は、私のさつきの高山へ遠足してみじめな姿で帰つた話をふと思ひ出したらしく、笑ひながらさう言つて、陽子もお婿さんも、どつと笑つたら、兄は振りかへつて、「え？",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて、やっぱり、小学生が遠足に出かける時みたいな、はしゃいだ調子の文章になってしまったが、仕事が楽しいという時期は一生に、そう度々あるわけでもないらしいから、こんな浮わついた文章も、記念として、消さずにそのまま残して置こう。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠足した人が經驗する足の痛みも同じことである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの式や遠足の時と云ふと軍服を着けて來て、日清日露役の從軍記章と、功六級の金鵄勳章と、勳七等の青色桐葉章を得意氣にぶら下げた動物學の先生の稚氣、それ等は寧ろ氣持の好い先生達の愛嬌だつた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学園の遠足以外には田舎に出たことはなく、田舎の夜とては一層に不勝手なわたくしには、東京であれほど弾んだつもりの安宅先生説得の意気込みも、いつか、相撲の手だとて人から聞きました肩透しとやら叩き込みとやらを受けました形で、たゞしょんぼりと力抜けがするだけでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生を訪ふた、翌日でした、使者が手紙を持て來て今から生徒十｜數名を連れて遠足にゆくが君も仲間に加はらんかといふ誘引です。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の子にはたのしい遠足でした。",
              "citation": {
                "source": "岡の家",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日には舟を漕ぎに行くか、そうでないときは遠足をする。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "long walk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
