[
  {
    "uuid": "02cfec2a-1f0a-5d80-b8a3-e87ebe81b4f9",
    "entry": "遠足",
    "reading": {
      "primary": "えんそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
