[
  {
    "uuid": "3d5c9862-362a-5fbb-9bd0-6fb97a253469",
    "entry": "選び",
    "reading": {
      "primary": "えらび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
