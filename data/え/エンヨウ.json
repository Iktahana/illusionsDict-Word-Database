        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "炎陽の下、子どもたちは元気いっぱいに水遊びを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "照りつける炎陽が、アスファルトを熱くする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "炎陽に焼かれた大地は、ひび割れていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「このものどもの言うことが、なにも聞えんようにしてくれ」　けれども、あやしげな顔は、なおも、しゃべりつづけました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮い漁師は白白と明けた朝の光が眼に入らないような風で、じっと人びとの顔を見ていたが、「女房が帰って来て、ここまで来ると見えんようになった、探してくれ」と悲しそうに云った。",
              "citation": {
                "source": "月光の下",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたも間違えんようしっかり考えなはれや」と相手をいたわるような春風駘蕩の口を利いたりした。",
              "citation": {
                "source": "勝負師",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に、本当のことがいえんようじゃ、男として恥じゃないか。",
              "citation": {
                "source": "島原心中",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙がポロポロ出て物が見えんようになります」「ふうむ。",
              "citation": {
                "source": "眼を開く",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯も食えんようになりよった。",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の事早くも御領主様へ聞えましたから太左衞門｜罷出でて、立派な申開きが相立ち、原丹治｜父子の悪事、おかめの不届の次第が分りましたが、鹽原の家は焼失致し、それなりに済みまして、太左衞門は鹽原角右衞門の位牌を引取り、線香の煙の絶えんように致しました。",
              "citation": {
                "source": "鹽原多助一代記",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時から三時までの間に両方でそこまで行って待ち合わすことにして互いに電話を切ろうとすると、女は念を押すように、「もしもし、あんたはん違えんようにおしやす」　いくらか嗄れたような女の地声で繰り返していう。",
              "citation": {
                "source": "黒髪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "……手がふるえんように気をつけること。",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝助はべつな意味で歌どころではないらしく、しきりに伸びあがっては孝吉や千鶴子の姿を探していたが、「孝吉も、千鶴子も、見えんようだが」　と、うわずったような顔で山内たちのほうへ振返った。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼だが、素人衆とは見えんようだが」　女はやにわに突っ立った。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御嬢さんと云えば今日は御那美さんが見えんようだが――どうかされたかな、隠居さん」「どこぞへ出ましたかな、久一、御前の方へ行きはせんかな」「いいや、見えません」「また独り散歩かな、ハハハハ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、なんたらいう立派な絵かきが、貧乏しとる頃、ある宿屋に泊つて宿賃が払えんようになつた。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今迄此眼鏡がキチンと目に合っていたんだけれども」「見えませんかな」「一寸も見えんようになってしもうた」　乃公は可笑しくなったが、我慢して聞いていた。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冨美子が枕元についていたら「おや、目が見えんようになった」と仰云った由。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなぐらいな事で何で死んだりするかいな、光ちゃん、光ちゃん」いうて力つけたげても、もう眼エ見えんようにどろんとなった瞳上げて、「姉ちゃんあて堪忍してくれるわなあ。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嚇かそうとしとるんじゃよ」「吉田親分は、見えんようじゃないか」「後で来るとか、いいよった」　新之助は、金五郎の弟分ということで、今日は「飛鳥」の亭主ではなく、正客として、金五郎とならんでいた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの梅丸には、ドテラ婆の組が来ちょるが、角助は見えんようにあるのう？",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪が飛んで、親父は片眼はまるきり見えんようになったらしいけんど、片方が大丈夫じゃけ――眼は一つありゃええ、なんて、元気でいうとるらしい。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はっ……」「それに奉行もまだ見えんようではないか」「おそらくは、まだご存知なく、当寺より走らせた使いによって、仰天しておらるるものと思われまする」「使いはやってあるのだな」「追ッつけお見えになるでございましょう。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洩れなく、揃いましてございますが」「ひとり、あれが見えんようだが」「お。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の一部｜始終から一族の健在を聞いて、玄徳のよろこびは何にたとえんようもなかった。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
