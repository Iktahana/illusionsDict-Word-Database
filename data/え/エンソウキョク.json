        "examples": {
          "standard": [
            {
              "text": "彼女のリサイタルでは、ショパンの美しいバラードが最後の演奏曲だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "アンコールで何を演奏曲にするか、聴衆の反応を見て決めることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の発表会で、私はベートーヴェンのソナタを演奏曲として選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "演奏曲目はもう選んだんだね。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあの演奏曲を当てろと言われたら、正解を言えたはずだ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はバッハを初めとする古典音楽を愛するとともに、故郷カタロニアの歌調を自ら鳥の詩と称して演奏曲目に忘れない、彼が現代の十二音音楽を斥けたり、故国の独裁政権に抵抗を続けるのも、それが人性の自然に反くからであると言い、人は皆己れを人類という大木の一枚の葉と思うべきだと語っている。",
              "citation": {
                "source": "望ましい音楽",
                "author": "信時潔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
