        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "卒業式で着た海老茶色の袴は、ハイカラな雰囲気で友人たちにも好評だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父の書斎にある古い革張りの椅子は、使い込まれて深い海老茶色をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "街路樹の葉が落ち、歩道が落ち着いた海老茶色の絨毯で覆われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "銘仙の袷に金紗の羽織を着、兎の毛で縁をとつたオールドローズの繻子の肩掛に寒々とくるまり、海老茶の袴を胸高く穿いてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女生の海老茶袴が目立って見える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高阪橋を越す時東を見ると、女学生が大勢立っていると思ったが、それは海老茶色の葦を干してあるのであった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹とは何人ぞ、君驚く勿れ、藝者でも女郎でもない、海老茶式部でも島田の令孃でもない、美人でもない、醜婦でもない、たゞの女である、湯原の温泉宿中西屋の女中である！",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き鞭を以て示して曰く、変更の議罷成らぬ、御身等、我が処女を何と思ふ、海老茶ではないのだと。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れが診斷した通り中葉以上の患部の稍粗雜な海老茶色の表面には、咯啖樣の色をした粟粒がうざ／＼する程現はれ出た。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの海老茶袴は、最もよくこれ等の弱点を曝露して居るものといわねばならぬ。",
              "citation": {
                "source": "白い下地",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その好きな帽子といふのはパナマ帽でもなくタスカンでもなく、あの海老茶色のリボンを巻いた、一高の夏帽子だつたのだ。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく私は、あの海老茶色のリボンを考へ、その書生帽子を思ふだけでも、ふしぎになつかしい独逸の戯曲、アルト・ハイデルベルヒを聯想して、夏の青葉にそよいでくる海の郷愁を感じたりした。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その海老茶色のリボンでさへも、地面の泥にまみれ、私の下駄に踏みつけられてゐた。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老茶と緋縮緬の交換だな。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人のやうに背のひよろ高いのもあれば、海老茶色の毛糸の長い羽織の紐を総角のやうに胸に結んでゐるのもあつた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためもあって、先生はいくらか丈夫になり、女学校へ通う時分は前橋まで四里往復ほどの道を海老茶袴で自転車に乗って通ったりしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ出口で海老茶袴の二、三と逢ったが、着こなしがいかにも野暮くさく、面相がいくらか内地とは違うなぐらいで、それも軽く擦れ違ってしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "木柵、木柵、木柵、　海老茶だ、あ、すかんぽだ、あ、お襁褓だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが少々渋ったのは桃色のスカートの、鼠色の華奢な眼鏡の、海老茶帽子の、そうした夫人同伴のＢ重役Ｈ会社員Ｋ工学博士あたりであった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼女はいつか道ですれ違つた、海老茶色のリボンを前髮につけた眼の大きい、黒い編上げの靴をはいた快活さうな少女のことを考へた。",
              "citation": {
                "source": "珠",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き鞭をもって示して曰く、変更の議｜罷成らぬ、御身等、我が処女を何と思う、海老茶ではないのだと。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は何心なく裏口の前の障子をあけて見ると、四人の雪駄が四足ちゃんと並べてある、うえ二人のが海老茶の鼻緒で、した二人のが濃紅の鼻緒である、予はこれを見て一種云うべからざる感を禁じ得なかった。",
              "citation": {
                "source": "浅草詣",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "海老茶の疎い絞りの帶を締めて、萠黄メリンスの前垂をして居る。",
              "citation": {
                "source": "菜の花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "予て用意したれば、海老茶の紋縮緬の※の傍に七宝焼の小判形の大手炉を置きて、蒔絵の吸物膳をさへ据ゑたるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房は、短い海老茶袴のやうなものゝ上に、男のものでもありさうな毛糸のジヤケトを着て、ぷか／＼と煙草を喫してゐる。",
              "citation": {
                "source": "お蝶の訪れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "其頃は女子の教育は盛になつて庇髪と海老茶の袴とが段々眼につくやうになつてゐた。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　私は、前日海老茶ビロウドの表紙のついた最も小型なヨハン・ゲーテのバースデイ・ブツクを買つた。",
              "citation": {
                "source": "日本橋",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして肘の抜けた僕の海老茶のジヤケツをつくろつて着用し、また霜解けの道なので長靴ばかりを素足に穿いてゐた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　百合子は赤いバンドで胴を括つた海老茶の水着の上から胸をさすつたり、肩をすぼめたりして、「厭な音ちやん、ひとが話しかけてゐるのに返事もしないで、妾の顔ばかり見てゐるわ。",
              "citation": {
                "source": "まぼろし",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か――」　海老茶の水着をきた娘が悲鳴をあげた。",
              "citation": {
                "source": "熱い砂の上",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四五年来の女子教育の勃興、女子大学の設立、庇髪、海老茶袴、男と並んで歩くのをはにかむようなものは一人も無くなった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が子供の頃には海老茶色が流行つた。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい洋服で、それもスコッチの毛の摩れてなくなった鳶色の古背広、上にはおったインバネスも羊羹色に黄ばんで、右の手には犬の頭のすぐ取れる安ステッキをつき、柄にない海老茶色の風呂敷包みをかかえながら、左の手はポッケットに入れている。",
              "citation": {
                "source": "少女病",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
