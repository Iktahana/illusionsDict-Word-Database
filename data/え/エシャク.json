    "definitions": [
      {
        "index": 1,
        "gloss": "slight bow (as a greeting or sign of gratitude)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "廊下で上司とすれ違い、軽く会釈をして通り過ぎた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "店員さんが荷物を持ってくれたので、「ありがとう」と会釈で返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初対面の人には、まず笑顔で会釈をするようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "隣の席の人が何か落としたようだったので、拾って渡すと、小さな会釈をしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "いつになく少しはにかんだような笑顔を見せて軽く会釈しながらいそいそ奥へはいった。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま来客でもあって応接していると、肝心な話の途中でもなんでも一向｜会釈なしにいきなり飛込んで来て直ちに忙わしく旋回運動を始めるのであるが、時には失礼にも来客の頭に顔に衝突し、そうしてせっかく接待のために出してある茶や菓子の上に箔の雪を降らせる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから女主人は丁寧に爺いさんの麻の手袋に会釈した。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥の大｜卓子の支配人が彼女にかるく会釈をかえした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御信心だね」と、半七も笑って会釈すると、小娘も笑って挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免くださいまし」　半七は何げなく挨拶すると、女は黙って鷹揚に会釈した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは半七ですよ」「親分さんですか」と、男は会釈した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、あなたも御見物ですか」　わたしの方から声をかけると、老人も笑って会釈した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ごめんください」　半七は丁寧に会釈して進み出て、正面の行者の顔をみあげた時、そのそばに一人の若い女が控えているのを更に見いだした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "式部も会釈して、その箱をうけ取って、まず行者のまえに押し直すと、行者は幣束を取り直してその箱のうえを一度払った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は会釈して又ひと膝すすみ出ると、行者の衣にはなにかの香が焚き籠めてあるらしく、蘭奢とでもいいそうな一種の匂いが彼の鼻にしみた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "やって来た旨を述べても、たゞ会釈したのみだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言つきは慇懃ながら、取附き端のない会釈をする。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見覚えある板塀のあたりに来て、日のややくれかかる時、老夫はわれを抱き下して、溝のふちに立たせ、ほくほく打えみつつ、慇懃に会釈したり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "田端で停車した時、園は立上つて、其の夕靄にぽつと包まれた、雨の中なる町の方に向つて、一寸会釈した。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大噐氏にちょっと会釈するや否や、若僧は落付いた、しかしテキパキした態度で、かの提灯を持って土間へ下り、蓑笠するや否や忽ち戸外へ出て、物静かに戸を引寄せ、そして飛ぶが如くに行ってしまった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "真正面から受ける「有心」の付け句がだいじであれば軽い「会釈」や「にげ句」はさらに必要である。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相互の矛盾欠点が眼に立ち、赤裸々の男女が鼻突き合せて、遠慮会釈もなく、ザックバランに、二人が本当にこれから先きの長い生涯を一緒に暮し得らるるや否やを吟味するのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主は、笠ながら会釈して、「貴殿は大高源吾どの？",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……手を曳かれたり、三人つれたり、箱屋と並んで通るのだの、薄彩色した陽炎が朧に顕れた風情の連中が、行違ったり、出会ったり、大勢の会釈するのが、間の隔った時分から――西河岸の露店の裸火を、ほんのりと背後にして軒燈明の寝静まった色の巷に引返す、――この三人の目に明かに見えたのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十九　巡査は掌を向うへ扱いて、手袋を外して、片手に絞って、更めて会釈する。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩の位に、大客を恐れない品格が備わって、取乱した人とは思われなかった、が、清葉も改めて会釈をする時、それは誰にするのやら分らないことを悟った。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の影ならず、血だらけの抜刀を提げた、半裸体の大漢が、途惑した幟の絵に似て、店頭へすっくと立つと、会釈も無く、持った白刃を取直して、切尖で、ずぶりとそこにあった林檎を突刺し、敵将の首を挙げたるごとく、ずい、と掲げて、風車でも廻す気か、肌につけた小児の上で、くるりくるりとかざして見せたが、「あはは。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたくしは警部の前に会釈して坐りました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "異教徒席の中からせいの高い肥ったフロックの人が出て卓子の前に立ち一寸｜会釈してそれからきぱきぱした口調で斯う述べました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」老人は会釈して壇を下り拍手は天幕もひるがえるようでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭司次長は軽く会釈しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那服で祭壇に立ってはじめて私の顔を見て一寸かすかに会釈しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちついて祭壇に立ってそれから叮寧にさっきのマットン博士に会釈しました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は会釈して壇を下り拍手もかなり起りました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "consideration",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女はいつも他人に会釈する心を持っているから、みんなに慕われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公共の場では、周囲への会釈を忘れないように心がけたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "相手の気持ちを会釈しながら行動することが、良好な人間関係を築く鍵だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
