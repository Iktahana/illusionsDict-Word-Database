[
  {
    "uuid": "b085a5e5-53a8-5065-afcc-af840340d1d9",
    "entry": "得手勝手",
    "reading": {
      "primary": "えてかって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
