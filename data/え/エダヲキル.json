        "examples": {
          "standard": [
            {
              "text": "庭師が、伸びすぎた庭木の枝を剪る（えだ を きる）作業をしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "果樹の収穫量を増やすために、適切な時期に枝を剪る必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この桜、もっと綺麗に咲かせるには、どう枝を剪ったらいいかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "譬えば大樹を伐るに、先ず附枝を剪るが如し、親藩既に滅びなば、朝廷孤立し、奸臣志を得んには、社稷危からん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "欅は枝を剪るとのびが止まるらしい。",
              "citation": {
                "source": "五葉の松",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            }
          ]
        }
