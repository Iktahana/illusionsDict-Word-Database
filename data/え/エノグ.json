    "definitions": [
      {
        "index": 1,
        "gloss": "paint",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供たちがアトリエで、色とりどりの絵の具を使って絵を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この絵の具は発色がとても良くて、キャンバスの上で鮮やかに広がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "筆につけた絵の具をパレットの上で混ぜ合わせ、理想の色を作り出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水彩絵の具は、水で薄めて使うと淡く優しい表現ができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "絵の具も画架も揃ひ、まづまづ龍は描いたが、まだ点睛がないといふのが昨今の状勢である。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な事には巻物の初めの方に朽ち残った絵の色彩は眼のさめるほど美しく保存されているのに、後の方になるほど絵の具の色は溷濁して、次第に鈍い灰色を帯びている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじゃ野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてがただ紙の表面へたんねんに墨と絵の具をすりつけ盛り上げたものとしか感じられない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲胄堂の婦人像のあはれに絵の具のあせたるが、遥けき大空の雲に映りて、虹より鮮明に、優しく読むものゝ目に映りて、其の人恰も活けるが如し。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画工さんは立処にコバルトの絵の具を溶いたし、博士は紫の蝶を追つて、小屋うらの間道を裏の林に入つたので。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "図画の先生に頼んで東京の飯田とかいううちから道具や絵の具を取り寄せてもらって、先生から借りたお手本を一生懸命に模写した。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと使った絵の具箱やパレットや画架なども、数年前国の家を引き払う時に、もうこんなものはいるまいと言って、自分の知らぬ間に、母がくず屋にやってしまったくらいである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後都へ出て洋画の展覧会を見たりする時には、どうかすると中学時代の事を思い出し、同時にあの絵の具の特有な臭気と当時かきながら口癖に鼻声で歌ったある唱歌とを思い出した、そうして再びこの享楽にふけりたいという欲望がかなり強く刺激されるのであった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでさっそく絵の具や筆や必要品を取りそろえて小さなスケッチ板へ生まれて始めてのダップレナチュールを試みる事になった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しいパレットに押し出した絵の具のなまなましい光とにおいは強烈に昔の記憶を呼び起こさせた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い筆の先に粘い絵の具をこねるときの特殊な触感もさらに強く二十余年前の印象を盛り返して、その当時の自分の室から庭の光景や、ほとんど忘れかかった人々の顔をまのあたりに見るような気がした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉛筆でザット下図をかいてみたがなかなか似そうもなかった、しかしかまわず絵の具を付けているうちにまもなくともかくも人の顔らしいものができた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目を細くしてよく見きわめをつけてから一筆ごとに新しく絵の具を交ぜては置いて行くのだそうである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は六尺もある筆の先へちょっと絵の具をくっつけて、鳥でも刺すようにして一点くっつけてはまたながめて考え込むというのである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは小さな板へかいた習作であったがなるほど濃厚な絵の具をベタベタときたならしいように盛り付けたものであった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分ののっぺりした絵と比べて見るとこのほうが比較にならぬほどいきいきしていてまっ黒な絵の具の底に熱い血が通っていそうな気がした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下図はとうとうあまりよく似ないままで絵の具をつけ始めた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子のごくごくいい日にはいいかげんに交ぜる絵の具の色や調子がおもしろいようにうまくはまって行く。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具のほうですっかり合点してよろしくやってくれるのを、自分はただそこまで運んでくっつけてやっているだけのような気がする。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具と筆が勝手気ままに絵をかいて行くのを自分はあっけに取られて見ているような気がするのである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してぐあいの悪い日は絵の具も筆も、申し合わせて反逆を企て自分を悩ますように見える。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある場所につける一点の絵の具が濃すぎても薄すぎても顔がいびつに見えた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜顔色の美しい女客の顔を電燈の光でしみじみ見ていると頬や額の明るい所がどうしてもまだかわかぬ生の絵の具をべっとり盛り上げたような気がしてしかたがなかった、そしてその光った所が顔の運動につれていろいろに変わるのを見とれているうちに、相手の話の筋道を取りはずしそうになる事が一度ならずあった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "餡入りの餅のほかにいろいろの形をした素焼きの型に詰め込んだ米の粉のペーストをやはり槲の葉にのせて、それをふかしたのの上にくちなしを溶かした黄絵の具で染めたものである。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてが岩絵の具でかいた絵のように明るく美しい色彩をしている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥色をした浅草紙を型にたたきつけ布海苔で堅めた表面へ胡粉を塗り絵の具をつけた至って粗末な仮面である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　画かきはにわかにまじめになって、赤だの白だのぐちゃぐちゃついた汚ない絵の具｜箱をかついで、さっさと林の中にはいりました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "画かきは絵の具ばこをカタンとおろしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵の具箱へスケッチ板を一枚入れて、それと座ぶとん代わりの古い布切れとを風呂敷で包み隠したのをかかえて市内電車で巣鴨まで行った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
