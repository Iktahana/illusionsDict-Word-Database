        "examples": {
          "standard": [
            {
              "text": "最新のカメラはＡＦ性能が格段に向上し、動く被写体でもピントが合いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暗い場所での撮影はＡＦが迷いやすく、マニュアルフォーカスに切り替えることも多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このレンズは高速ＡＦに対応しているので、スポーツ写真に最適だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "即ちＡＦＬ、ＣＩＯの二大労働組合がタフト・ハートレー法撤廃のため一生懸命になって千五百万の組合員に運動し投票所へのかりだしに努めたことに対し、それに適当するだけの数の見本がくばられていなかったのではないだろうか」と。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ケティは、何処にいるね」ダネックがちょっと意気込んだ声で折竹に訊いたが、相手の様子をみるといきなり言い紛わせ、「いやね、大氷河のしたのＡＦ点の傾斜を測りたいんだ。",
              "citation": {
                "source": "人外魔境",
                "author": "天母峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＤＡＦの馬鹿野郎！",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＤＡＦ・ＤＡＦ・ＤＡＦの馬鹿、ＤＡＦの馬鹿……」と。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＤＡＦ・ＤＡＦ・ＤＡＦ・バカ……」　畑の方からまつしぐらに、激しい嵐の一とうねりが、この径を遠い向うの街へ目指して駈け抜けるとき、駄夫もそれに送られてピョコピョコと数歩急ぐのである。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえ――ＤＡＦの馬鹿野郎！",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベートーヴェンの四番目（作品一八の四）の四重奏曲とハープ四重奏曲と作品一三一番の四重奏曲が入っているが、ビクターのカタログに残っているハープ四重奏曲（ＡＦ三一六―八）が一番良いだろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
