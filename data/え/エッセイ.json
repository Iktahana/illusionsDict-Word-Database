        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "週末は、お気に入りのエッセイを読み返して過ごす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の書くエッセイは、ユーモアがあって読みやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このエッセイコンテストのために、新しい作品を書こうと思う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "何気ない日常の出来事が、彼女のエッセイでは魅力的な物語になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "然るに氏のエッセイはとみると、時にダダツ子みたいに感じられる時がある。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者がかつて評論した、有名なヘルンのエッセイ『ある女の日記』も、校本に拠るところがあるとは言いながら、実はその愛妻節子夫人を、半面のモデルにしたものと言われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら鳥や虫の生活の方が、人間よりも不幸であるとは思えないから』と、あるエッセイの中で書いてるヘルンは、日本人の民族化した仏教情操であるところの、あの『物のあわれ』の抒情的ペーソスを知ってたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文壇でいふ「隨筆」とは、西洋のエッセイとは全く別種の物であつて、主として季節の推移に於ける自然の情趣や、日常生活に於ける身邊の述懷などを敍するもので、その文學の本質する精神は、全く俳句のそれと共通してゐる。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の世界にある文學は、詩とエッセイの外に何物もない。",
              "citation": {
                "source": "詩に告別した室生犀星君へ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、「東京をおもう」というエッセイの最後の章がそれだ。",
              "citation": {
                "source": "東京文壇に与う",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学は文学者にとって運命でなければならぬ――と北原武夫氏が言っているのは、いい言葉で、北原氏はエッセイを書くと読ませるものを書くが、しかし、「天使」という北原氏の小説は終りまで読めなかった。",
              "citation": {
                "source": "文学的饒舌",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アランや正宗白鳥のエッセイがいつ読んでも飽きないのは、そのステイルのためがあると思っている。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、支那のエッセイストたちの作品を愛読している。",
              "citation": {
                "source": "庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アフォリズムとは、だれも知る如くエッセイの一層簡潔に、一層また含蓄深くエキスされた文学（小品エッセイ）である。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ彼はそのエッセイにも、ニイチェの標題をそのままイミテートして「文芸的な、あまりに文芸的な」と書いた。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「詩」という一つの観念は、古代より近代に至るまで、西洋のあらゆる文学史を一貫し、小説も戯曲もエッセイも、すべてがこの母音の上に詩神を立脚している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十四章　詩と小説　吾人が文学と称するものの中には、詩、＊評論（章尾の註参照）、随筆、エッセイ、戯曲、小説等の種類がある。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹について　阿部次郎のエッセイの中に、小さい蟹が自分のうちの台所で、横っ飛びに飛んだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」を保田与重郎が送ってくれ、わがひととは、私のことだときめて再読、そのほか、ダヴィンチ、ミケランジェロの評伝、おのおの一冊、ミケランジェロは再読、生田長江のエッセイ集。",
              "citation": {
                "source": "碧眼托鉢",
                "author": "――馬をさへ眺むる雪の朝かな――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、目次を一見して、若い時分の汗顔もののエッセイだけは、どうしても削って貰わねばならぬと思う。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、ジイドの『地の糧』だの、チェスタアトンの楽天的エッセイなどが、何と弱々しい声々で彼を説得しようとしたことだろう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学論文や報告書などをバサバサ拾い読んだり飛ばし読んだりする程度ならいいが、それによって小説やエッセイや哲学や歴史の本を読もうなどという気分にはとてもなれない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、私は、こないだ君のエッセイみたいなものを、偶然の機会に拝見し、その勿体ぶりに、甚だおどろくと共に、君は外国文学者（この言葉も頗る奇妙なもので、外国人のライターかとも聞えるね）のくせに、バイブルというものを、まるでいい加減に読んでいるらしいのに、本当に、ひやりとした。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、君たちのこの頃のエッセイほど、みじめな貧しいものはないとも思っている。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿なエッセイばかり書きやがって、この頃、君も、またあのイヒヒヒヒの先生も、あまり語学の勉強をしていないようじゃないか。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニイチェだかのエッセイの中にも、子供を生ませたいと思う女、という言葉がございましたわ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "産業という実際問題から出発したエッセイだから、坊間風をなすあの「随筆」というもののカテゴリーでは片づかない。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――チャールス・ラムは『エリヤのエッセイズ』で、「既婚者の言動についての或る独身者の嘆き」というものを説いている。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "はためにみれば、そもそも文学をはずれて繁栄している中間小説と、私小説がひとしお煮つまって一種のエッセイ風の作品となっている尾崎一雄の文学とを同列に語ることさえ、謂わば荒っぽいセンスである。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの書かれたエッセイをなにとぞ送ってください。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は先日トルストイの性欲に関するエッセイを読みました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
