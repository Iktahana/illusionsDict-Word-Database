        "examples": {
          "standard": [
            {
              "text": "この映画のポストプロダクションでは、エディティングに特に時間がかかったそうです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "原稿のエディティングが終わり次第、印刷に進みます。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は、新人作家の小説エディティングを担当している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "いかによい役者やロケーションを使いいかに上手なカメラマンを使っても監督の腕が鈍くて材料のエディティングが拙ならば、一編の作品として見た映画はいわゆる興味索然たるものであるに相違ない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろないわゆるモンタージュやエディティングの必然性が観客の頭へはそれほどに響いて来ない。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから撮影してつけ加える最後の部分をのぞいて、全篇のエディティングは完成している。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
