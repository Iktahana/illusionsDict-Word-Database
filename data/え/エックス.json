        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この暗号の鍵はＸだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "署名の欄にＸ印をしてください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "問題文のＸに適切な語句を入れなさい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "Ｘ光線の治療をする音が聞えてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人情と義理と利害をＸＹＺの座標とする空間に描きだされた複雑極まりない曲面の集合の一つの切り口が見える。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　何かというとすぐに「ＸＹＺの座標」を持ちだすのが彼の一つの癖である。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今唇の前後の方向の位置をＸで表わし、唇の開きをＹで表わすとるると、イエアオウと順に発音する場合にＸＹで表わされる直角坐標図の上の曲線はざっと半円形のようなものになる。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次にＸＹの面に垂直なＺ軸の方向に時間を取る。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にこういう空間曲線を作る事は厄介であるから、その代りにこの曲線をＸＺ面とＹＺ面に投射したものと二つを画いて調べる外はないのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなような考えから、私はいつぞや先ずこのＸＺ面の射影、すなわち唇の出方のいろいろと変る方だけを二、三十首の歌について画いてみた事がある。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中が妙に騒々しくて、青いＸ事件があるかと思うと黒いＹ事件、黄色いＺ事件などが続出する。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ君とＺ君だけは自分の大浴場説に賛成した。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電波や熱や光やＸ線やγ線や、人間を離れて見れば全く同じ物で波の長さという事の外には本質的の差異を認めない。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らない答をＸと名づけて、そしてそれを知っているような顔をして取扱って、それと知っているものとの関係式を書く。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからこのＸを定めるという方法だ」と云って聞かせた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "津田君の画はまだ要するにＸである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉類の中の結核　獣肉中に結核の有無を見るには従来ただこれを切開して吟味するより外に手段はなかったが、近頃ある人がＸ光線で透して見てすぐに病所の有無を知る事を発見した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月八日『東京朝日新聞』）　　　　　　　　　十五　　　　　　奇妙な病気　始終Ｘ光線を使っている人は往々不思議な恐ろしい病気に罹るそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屍体とＸ光線　生きている人体の腹部をＸ光線で照らし写真を撮っても胃や腸を識別する事が出来ぬが、死後間もなく写して見ると明らかにこれらの臓腑の所在がわかる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年一月二十七日『東京朝日新聞』）　　　　　　　　　六十二　　　　　　迅速なるＸ線写真　従来Ｘ線で人体の内部などを写真するに当って一つの欠点は照射時間の長い事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに近頃ローゼンタールは特別な感応コイルを発明し、これによってＸ線を生ずれば喉頭の写真をわずか二秒間で撮る事が出来るという事を発表した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年三月二十日『東京朝日新聞』）　　　　　　　　　六十八　　　　　　真珠の採取にＸ光線の応用　世界中の真珠産地で年々に採る母貝の数は夥しいものであるが、その中で真珠を含んでいるのは比較的に少ない、それで母貝の多数はつまり無駄に殺されてしまう事になる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが今から七年前にジュボアという人がＸ線で真珠貝の写真を撮り珠を験する事を考え出したが、なにしろ沢山な貝の写真を撮るのはかなりに手数でもあり費用もかかるところから、実業社会の注意を惹くに至らなかった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十一年五月二十日『東京朝日新聞』）　　　　　　　　　八十二　　　　　　学者の犠牲　英国のホールエドワードという学者はＸ線のために左の手全体と右の手の指とを失った。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その所説に拠れば、疑問の死体をＸ線で透して撮影すれば、もし本当の死産なれば体内の機関は一つも写らぬが、少しでも空気を呼吸したものなれば胃だけが現れる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中野重治の「鉄の話その一」には、Ｘの掲げるスローガンを具体的な主要なテーマとしてたくみに、えん曲に生かしている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ――という女の人の私室である。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうわけで私はアインシュタインの出現が少しもニュートンの仕事の偉大さを傷つけないと同様に、アインシュタインの後にきたるべきＸやＹのために彼の仕事の立派さがそこなわれるべきものでないと思っている。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば電子波回折の実験がＸ光線回折の実験の行なわれたころにすでに行なわれたというような事も、それ自身において必ずしも不可能でなかったと思われるから、もしもそうであったとしたら、その後の物理学界の動きはよほど実際とは違ったものになったのではないかと想像されるのである。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年三百六十五日間における日々の甲某百貨店の第Ｘ売り場における売り上げ高と日々の雨量との関係いかんということが問題になったとする。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この尊い地球を捨てるなんて」「あとちょうど一年たてば、地球はエックス彗星と衝突して、めちゃめちゃに壊れることが分っているのです」「はあ、なるほど、彗星との衝突ですか」とフルハタはうなずいたが、「それで地球から移民の必要があるんですね。",
              "citation": {
                "source": "千年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し其道具立の一つ／＼から順々に歸納的に結論したら、却つて「悄然」と正反對な或るエックスを得るかも知れない。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから駿河台の岡島先生のところへ行って、二人の身体をエックス光線でみてもらいますから、すぐ自動車を用意してください」　俊夫君の言葉がいかにもハキハキしていたので、木村さんは何も言わずにおばさんを近所の自動車屋へ走らせました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
