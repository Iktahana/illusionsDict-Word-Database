        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "長旅の疲れを癒す、温かいエッセンを求めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "山小屋で、採れたての野菜を使った素朴なエッセンをいただいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "家族で囲む食卓のエッセンは、何よりもご馳走だ！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "俗情のエッセンスだとでも名付けるよりほかはない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のレモン・エッセンスであったのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句とは如何なるものかという問に対して先生の云った言葉のうちに、俳句はレトリックのエッセンスであるという意味の事を云われた事がある。",
              "citation": {
                "source": "夏目先生の俳句と漢詩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春雨」「秋風」というような言葉は、日本人にとっては決して単なる気象学上の術語ではなくて、それぞれ莫大な空間と時間との間に広がる無限の事象とそれにつながる人間の肉体ならびに精神の活動の種々相を極度に圧縮し、煎じ詰めたエッセンスである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畢竟「能」は吾人の日常生活のエッセンスである。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその一つ一つの象形文字のような夢内容は驚くべく多様な夢思想の圧縮されたエッセンスであり、またはなはだしく複雑な夢思想の網目の接合点である。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、儒家は儒になずみ仏徒は仏にこだわっている間に、門外の俳人たちはこれらのどれにもすがりつかないでしかもあらゆるものを取り込み消化してそのエッセンスを固有日本人の財産にしてしまったように見える。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は万葉から元禄までのあらゆる固有文化を消化し総合して、そうして蒸留された国民思想のエッセンスを森羅万象に映写した映像の中に「物の本情」を認めたのである。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば吾等日本民族が、先祖代々から、子々孫々に到るまで、総がかりで完成すべく努めている綜合芸術のエッセンスであろう。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "醤油のエッセンスにて火を灯し、草と砂糖を調じて鉱山用のドンドロを合せたなどは、ほんの人寄せの前芸に過ぎない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し現在の状態では共産的精神は周囲がさうでない場合にその実行が結局不可能で自滅せねばならない、かく完全なプランの下でも駄目なものだ――この一つのプルーフを得る丈けで私は満足するものでこの将来がどうであるかといふことはエッセンシャルなことゝは思つてゐないものであります。",
              "citation": {
                "source": "農場開放顛末",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、陀羅尼とは、つまりあらゆる経典のエッセンスで、一字に無量の義を総べ、一切の功徳をことごとく持っているという意味です。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "翻訳によって原物は殆んど全く別の姿に変わるのではあるが、その換骨奪胎に於て必ずもののエッセンスは再生され得ねばならぬ。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、ただの諸文化自身から抜け出して或る独特な新しい文化的尺度を規正するこの「文化の意識」は、もはや個々の諸文化の夫々の付属物ではなく、そういうものから発達し結実した夫々の或る代表者的エッセンスが集結し独立化し単位化したものとして、或る独立な秩序界を構成する。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "単純化は一つのエッセンス、精、法則の柱を握って、他のものをそれに依属せしむることだと思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新著『循環論証の新世界観と錯覚自我説』とは氏の哲学のエッセンスで、これだけ読めば十分にかれの思想を知ることが出来る。",
              "citation": {
                "source": "錯覚自我説",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪のエッセンスを煮染めたような地元、守口、門真の風土には、ロックマニアで作家志望の感性には受け入れがたい臭みがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いまや潜航艇「｜鷹の城」の艇長――故テオバルト・フォン・エッセン男の追憶が、その夫人ウルリーケの口から述べられようとしている。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつかの日、私はテオバルト・フォン・エッセンという一人の男を知っておりました。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、決戦派の首領、男爵フォン・エッセンには耐らなかったのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、マリア・テレジヤ騎士団の集会でおこなった演説を最後に、フォン・エッセンは二度と怒号しようとはしなかった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですけど、貴方の幻だけはかたく胸に抱きしめて――あの気高くも運命はかなき海賊、いいえ、男爵海軍少佐テオバルト・フォン・エッセンは、死にさえも打ち捷って、このような熱い接吻で私の唇を燃やすではございませんか。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、耳｜朶へ……貴方……」　フォン・エッセン艇長とウルリーケとを結びつけた、かくもかたい愛着の絆を前にしては、現在の夫、八住衡吉などは、むろん影すらもないのだった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、「｜鷹の城」の怪奇「私はこの際、フォン・エッセン艇長の最期を明らかにして、坊間流布されておりますところの、謬説を打破したいと考えます。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが光栄至極にも、われわれはフォン・エッセンの指揮下にある、潜航艇に乗り込んでしまった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、故フォン・エッセン男爵の霊の上に、安らかな眠りあらんことを……」　　　　　　三、濃緑の海底へ　艇長フォン・エッセン男の死体が消失した、しかも蒼海の底で、密閉した装甲の中で――この千古の疑惑は、再び新しい魅力を具えて一同のうえにひろがった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「儂は、王立カリンティアン快走艇倶楽部員の一人として、かつてフォン・エッセン男爵に面接の栄を得たものでありますが、儂ですらも、これまではさまざまな浮説に惑わされ、艇長の死を容易に信ずることができなかったのでした。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、今や雲散霧消したことは、なにより墺太利海軍建設以来最初の英雄であるところの、フォン・エッセン閣下のため祝福さるべきであろうと信じます。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
