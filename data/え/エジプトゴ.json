        "examples": {
          "standard": [
            {
              "text": "彼は大学でエジプト語を専攻し、今はエジプト学の研究者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ヒエログリフは古代エジプト語の象形文字の一つです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "エジプト語の響きは、私にとってとても異国情緒がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこを、コウノトリが、長い赤い足で歩きまわっては、エジプト語でぺちゃくちゃと、おしゃべりをしていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "コウノトリは、おかあさんから、エジプト語をおそわっていたのでした。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "エジプト語にはかなりの数の身体の名前があるだけでなく、抽象的なアイデアのイラストとして使っている。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、エジプト語の終了を確かめるには多くの困難がある。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
