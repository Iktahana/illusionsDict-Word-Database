        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "敵の動向を探るため、エリント部隊が前線に配置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最近の軍事作戦では、エリントによる情報収集が不可欠となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エリント衛星が、敵国の通信傍受に成功したと報告があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あれなる平野の大軍は英將ウエリントンの一隊。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ナポレオンとウエリントンも一緒に居る筈ですね。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世人が往々誤解するように横隊戦術に比し戦場に於て必ずしも徹底的に優越なものでなかったし（一八一五年ワーテルローでナポレオンはウエリントンの横隊戦術に敗れた）、決して仏国が好んで採用したものでもない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリュッヘルは三軍団の兵力（八万一千）をもって、リーニー川の線に陣地を占領し、英将ウエリントンの来援を頼んでナポレオンと決戦せんと企図していた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてこの藤枝真太郎がウエリントンたりブリューヘルたることを忘れていたんだよ」　林田のことをナポレオンに祭り上げた藤枝は俄然自身をウォータールーの将軍に擬している。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに就いては既に英吉利の有名な科學者ウエリントンも書いてゐる。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウファ映画「会議が踊る」の中で、メテルニッヒがウエリントンの会話などを盗み聴くあれがそうである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はウエリントンより偉大な戰士であつた。",
              "citation": {
                "source": "劒の教義",
                "author": "エム・ケー・ガンヂー",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレラがこのように発生していなかった周囲の通り、すなわちウエリントン・ストリート、オールド・キング・ストリート、ヒューズズ・フィールヅ、を調査して、水の変化していなかったことが判った。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの人格思想は、伊藤公爵大隈伯爵等と對照すれば、より多く東洋的なりと雖も、若し強ひて歐洲に其の比倫を求めば、英國のウエリントン其の人を擧げざるべからず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "出でては元帥たり入つては宰相たる所、我が山縣公爵とウエリントンと東西の好一對なるべく、其の政治思想の保守的に傾けること亦二人甚だ相遠からず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯だウエリントンは殆ど政治家たるの一能力だも備へざりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウエリントンは毫も公衆の感情に頓着せざると共に、又公衆に好愛せらるべき、傾向を其の天分に發見せざりき、彼れの態度は冷靜なりき、乾燥なりき、生硬なりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れの人格思想は、伊藤公爵大隈伯爵等と対照すれば、より多く東洋的なりと雖も、若し強ひて欧洲に其の比倫を求めば、英国のウエリントン其の人を挙げざるべからず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "出でては元帥たり入つては宰相たる所、我が山県公爵とウエリントンと東西の好一対なるべく、其の政治思想の保守的に傾けること亦二人甚だ相遠からず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウエリントンは毫も公衆の感情に頓着せざると共に、又公衆に好愛せらるべき、傾向を其の天分に発見せざりき、彼れの態度は冷静なりき、乾燥なりき、生硬なりき。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんでもない法螺吹きどもは、その年の十一月の中頃、ボロ船に乗ってなんということもなくシドニーを出て行ったが、翌年の三月の末、新西蘭（英国の自治領）のウエリントン港に帰ってきて、こんどは南緯八十度〇五分まで行ってきたと発表した。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "指南丸の日本人がウエリントン港で架空の宣言をしてから、十五年の歳月が流れた。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くでよく聽えるのはメルボルン（三キロ）、マニラ（五十キロ）、ニユージーランド・ウエリントン（五キロ半）等で、今この原稿を書きながらマニラの素敵な女聲の二部合唱を聽いてゐる。",
              "citation": {
                "source": "ラヂオ閑話",
                "author": "成澤玲川",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですが、やはり獄中で偶※ウエリントンという偉人の伝記を読んで、その人が戦々兢々負債を恐れるという一節に、私はひどく胸を打たれました。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その、ウエリントンである、ナポレオンをやぶったウエリントンが」。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はウエリントンの名前をわすれていたのである。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウエリントンは万雷のごとき熱情をこめた拍手をもって彼を迎える大英国の民衆に向って言った。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウエリントンは偶々ナポレオンを相手とするワーテルローの戦場において彼の真髄を発揮したが、およそ高遠なる理想を行わんとする場所は人生の到るところにある、吾輩は諸君に向って何ものかになれなぞというケチなことは申さぬ、学生たるべき諸君は先ずおのれの心を屈して学問を修得すべきである。",
              "citation": {
                "source": "早稲田大学",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりもさらにブラックなものとして、デューク・エリントンやカウント・ベイシー。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイ・チャールズ、さらにはデューク・エリントンまで、若い白人のアイドルだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
