[
  {
    "uuid": "52a860a9-07a8-5601-a26b-c68a14ce67bf",
    "entry": "穢多",
    "reading": {
      "primary": "えた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
