        "examples": {
          "standard": [
            {
              "text": "仏教の世界観において、我々人間が住むこの世界は閻浮提と呼ばれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「閻浮提の衆生は、煩悩に苛まれながらも懸命に生きているのだ」と僧侶が説いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い経典には、須弥山の南方に位置する閻浮提の様子が詳しく記述されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "広大な宇宙の中でも、閻浮提という小さな世界で縁あって出会えた奇跡を噛みしめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "日に閻浮提洲を三度｜匝って疲れず王の念うままになって毎もその意に称うという（『正法念処経』二、『法集経』一）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十日にして閻浮提のあらゆる経論を誦し、皆ことごとく通達す〉。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大薩遮尼乾子受記経』巻三にも、転輪聖王の馬宝は、〈色白く彼、一日三遍閻浮提を行ず、疲労想なし〉とあり、古インド人白馬を尊べるを知るべし。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし『仏説観弥勒菩薩｜下生経』に、この閻浮提洲、弥勒の世となって、危険な物や穢い物ことごとく消え失せ、人心均平、言辞一類となり、地は自然に香米を生じ、衣食一切の患苦なしとあるに、無数の宝を蔵めた四大倉庫自然に現出すると、守蔵人、王に白す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後は※利天に生まれ天上で終ってこの閻浮提洲の富貴人に生まれる。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "七日立つとその子自分の福力もてこの閻浮提洲の二十また二十五歳ばかりに成長する。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "噫、冬枯や、法師めくかの行列を見てあれば、たとしへもなく静かなる夕の空に二列、瑠璃の御空の金砂子、星輝ける神前に進み近づく夕づとめ、ゆくてを照らす星辰は壇に捧ぐる御明の大燭台の心にして、火こそみえけれ、其｜棹の閻浮提金ぞ隠れたる。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "噫、冬枯や、法師めくかの行列を見てあれば、たとしへもなく静かなる夕の空に二列、瑠璃の御空の金砂子、星輝ける神前に進み近づく夕づとめ、ゆくてを照らす星辰は壇に捧ぐる御明の大燭台の心にして、火こそみえけれ、其棹の閻浮提金ぞ隠れたる。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "噫、冬枯や、法師めくかの行列を見てあれば、たとしへもなく靜かなる夕の空に二列、瑠璃の御空の金砂子、星輝ける神前に進み近づく夕づとめ、ゆくてを照らす星辰は壇に捧ぐる御明の大燭臺の心にして、火こそみえけれ、其｜棹の閻浮提金ぞ隱れたる。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に日蓮聖人の「前代未聞の大｜闘諍一｜閻浮提に起るべし」は私の軍事研究に不動の目標を与えたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "釈迦の予言によれば、釈迦滅後、五百歳ずつを一区画として、正法千年、像法千年を経て第五の末法の五百年に、「我が法の中に於て、闘諍言訟して白法隠没せん（大集経）」時ひとり大白法たる法華経を留めて「閻浮提に広宣流布して断絶せしむることなし（法華経薬王品）」と録されてある。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蓮は自らをもって仏説に予言されている本化の上行菩薩たることを期し、「閻浮提第一の聖人」と自ら宣した。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妙法比丘尼御返事」には、日蓮は南閻浮提日本国と申す国の者なり。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "「閻浮提の内に湖あり、その中に金輪際より生い出でたる水晶の山あり、天女の住む所なり」というのはこの島のことであろうか。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第七巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南閻浮提金銅十六丈の廬遮那仏を焼き滅した平家に味方する者が、ここにおる、召し捕れ」　と三声叫んだのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第六巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
