        "examples": {
          "standard": [
            {
              "text": "北米の広大な森で、堂々としたエルクの群れを見た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「わあ、あんなに大きい！ あれはエルクかな？」と友人が興奮して言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "今度は松居松葉作詞、ウエルクマイステル作曲の「釈迦」、主役は私と清水金太郎、そして私どもが養成した歌劇部員が初出演しました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それを改造したのが独逸のリュベッカーとドーラゲルエルクです。",
              "citation": {
                "source": "水中の怪人",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少シ憎体ニ見エルクライニ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
