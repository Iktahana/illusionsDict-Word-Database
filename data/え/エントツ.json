        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「おじいちゃん、あの赤い屋根の家から煙突の煙が出ているよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "サンタクロースが煙突から入るという話を、子供たちは真剣な表情で聞いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い銭湯の煙突が、夕焼け空にまっすぐ突き刺さっている光景が好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工場地帯の巨大な煙突からは、白い蒸気が絶え間なく吐き出されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋の煙突から吹き出る真赤な焔が黒い樹に映えて遠い森の上に青い月が出ている絵も欲しかったが、何となく静かなこの「森の絵」にきめた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘が淵紡績の煙突草後に聳え、右に白きは大学のボートハウスなるべし、端艇を乗り出す者二、三。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱田の八剣森陰より伏し拝みてセメント会社の煙突に白湾子と焼芋かじりながらこのあたりを徘徊せし当時を思い浮べては宮川行の夜船の寒さ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突の脇へ子供を負った婆さんとおばさんとが欄干にもたれて立って、伝馬の船底から山を見ている顔が淋しそうな。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突の下で立ちながらめしを食っている男がある。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の宵　　　　　　青いソフトに降る雪は　　　　　　過ぎしその手か囁きか　　白秋ホテルの屋根に降る雪は過ぎしその手か、囁きか　　　　ふかふか煙突｜煙吐いて、　　赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにしづかに酒のんでいとしおもひにそそらるる……　　ホテルの屋根に降る雪は　　過ぎしその手か、囁きかふかふか煙突煙吐いて赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "十幾階の角形の建築物や、工場の煙突の上に、白蝶の翼をひろげたように、雪の粉を吹いて、遠くはこんもりと黒く茂った森、柔かい緑の絨氈を畝ねらせる水成岩の丘陵、幾筋かの厚襟をかき合せたカスケード高原の上に、裳裾を引くこと長く、神々しくそそり立つ姿であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "進行中の汽車道から三町位はなれた工場の高い煙突の煙が大體東へ靡いて居るのに、すぐ近くの工場の低い煙突の煙が南へ流れて居るのに氣がついた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此れから行先にまだいくらも同じやうな煙突の一對があるだらうからもう少し詳しく觀察してやらうと思つて注意してゐたが、たうとう見付からずに澁川へ着いてしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突なども倒れかゝつたまゝになつて何となく荒れ果てた眺である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの曲つた煙突をかくといゝんだがなあ」などゝいふ者もあつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "内では天井に大煙突の抜けているストーヴでどんどん薪をくべていました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで例えば煙突の振動の問題でも、従来の理論的取扱い方に不満を感じて色々の点から改良を試みた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外に煙突の煙からは煤に混じて金属の微粒も出る、火山の噴出物もまた色々の塵を供給する。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "炭の活け方には色々あるが、要するに炭を並べて真中に縦穴を作り穴の下の方に横穴を作れば全体が丁度ストーヴの煙突と同じ作用をして空気の流通を促し炭の燃えるのを助ける訳になる。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が審理の結果、同会社の煙突から出る煤煙は十分な設備によって清められたものであって、そんなに害毒を生ずるような悪い煙でないという事になり、この訴訟は却下になったそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の趣味としては、もつと空氣の明るく近代的で、工場や、煙突やが林立し、一方に生産的市場が活動しつつ、一方に赤瓦の洋風家屋などの散見する情趣、即ち大都會の郊外にみる近代的生活の空氣がすきなのだ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "灼熱した塵埃の空に幾百筋も赫く爛れ込んでいる煙突の煙。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし鉱山の煙突から採れる銅やビスマスや黄金は役に立つのである。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い粘土で塗りかためられた煙突からは、紫色の煙が薄く、かすかに立のぼりはじめたばかりだ。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製煉所の銅煙は、禿げ山の山腹の太短かい二本の煙突から低く街に這いおりて、靄のように長屋を襲った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、醤油を煮ている釜の傍の大きな煉瓦の煙突の下に来た。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を煙突につけると、煉瓦は中を通る煙の熱で温くなっていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は煙突の方に向いて両手で顔を蔽うて泣いた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔白金環の天末を〕白金環の天末を、　　　　　みなかみ遠くめぐらしつ、大煙突はひさびさに、　　　くろきけむりをあげにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "比叡山――それを背景にして、紡績工場の煙突が煙を立登らせていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時どき烟を吐く煙突があって、田野はその辺りから展けていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、この息子が錠をおすと、トランクは息子を乗せたなり、ヒューッ、と、えんとつの中をつきぬけて、高く高く雲の上までとびあがってしまったのです。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
