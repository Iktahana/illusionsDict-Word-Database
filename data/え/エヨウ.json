        "examples": {
          "standard": [
            {
              "text": "「その着物の絵様は、今の季節にぴったりの繊細なデザインだね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い屏風に描かれた絵様が、部屋の雰囲気をぐっと格調高くしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工芸品の表面に刻まれた独特の絵様には、家紋に由来する意味が込められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
