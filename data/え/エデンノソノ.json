[
  {
    "uuid": "6b0387a4-6267-54fc-8972-6c18570811b4",
    "entry": "エデンの園",
    "reading": {
      "primary": "エデンのその",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
