    "definitions": [
      {
        "index": 1,
        "gloss": "free agent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "The star player is set to become a free agent next season, and several teams are already vying for his signature.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "After years with the same company, she decided to become a free agent in the job market, looking for new opportunities.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "The trade deadline passed, but the team still has cap space to sign a few key free agents in the offseason.",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "日本からのＦＡＸやラジオ放送の情報を元に、情勢を分析しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＡＱのページでは、プロジェクトの成果物に対して何か出来るかが、以下のように明示されていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの犯人は、電子メールとＦＡＸの二人組だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵はＦＡＸの使いこなしに暗いから、こっちでなんだかんだ聞かれたときにはせいいっぱい意趣返しして溜飲を下げてるんだけどね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビデオの録画もＦＡＸの送信も、おまけに掃除も洗濯も、ソニーのエレクトリック・ライス・クッカーでみんなできるというのなら、ローカルな『使いやすい』ルールもけっこうだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "音声通信はもちろん、ＦＡＸ型のグラフィックス通信、テキスト通信も可能である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二階にＦＡＣＯＭ１００がおいてあって、ちょうど窓際でＦＡＣＯＭ１２８の設計について議論をしていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間、『いま、ＦＡＣＯＭ１２８の設計に関して持ち出さねばいけないものは何か』と考えたんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眠らないマシン（いや、スリープ・モードだから眠るのかな）は、とりあえず留守番電話とＦＡＸを取り込んでホームコンピューターを成立させるという素晴らしいお話が次に展開されますので、皆さんまずは秋のコムデックスの速報を読んで、オレの予想が外れていたら大笑いしててね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこのマシンにはＦＡＸモデムというやつがついている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがＦＡＸモデムのとなりにはなんと通常のＦＡＸマシンが鎮座ましましていて、狭い机をさらに狭くしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話に関してはこんな具合に屋上屋を重ねてその上にドームまで被せたような日々を送っているオレは、一年ほど前にオンスペック社というところがモデムとＦＡＸ、ボイスメールの機能をＰＣ用ボードにまとめたＦＡＸ―Ｏ―ＦＯＮＥという製品を出したと聞いて、指パッチンをかました。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはＰＣ　ＸＴまたはＡＴ上で動作し、相手の信号が音声か、ＦＡＸか、コンピューターのデーターか自動的に識別してしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手の機械は、ＦＡＸと留守番電話とワープロを統合した専用機としても登場するかもしれないが、ばらばらのインターフェイスが並び合うのはオレの趣味ではない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は巴里モンマルトルのキャバレＬＡ・ＦＡＮＴＡＳＩＯを思い出した。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフトは今後、ＦＡＸやコピーや電話といったオフィスのさまざまな機器にＷｉｎｄｏｗｓによってインテリジェンスをプラスし、その世界をコンピューターの文化圏を超えて押し広げていく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "２年後に彼らはこれらが体内でアラキドン酸から合成されることを示し、必須脂肪酸（ＥＦＡ）欠乏の少なくともあるものはプロスタグランジン　ホルモンの不十分な合成によることを示唆した（124）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "多価不飽和脂肪酸　以前のセクションで述べたように多価不飽和脂肪酸（ＰＵＦＡ）は、 C-20 に鎖を延ばし、種々のホルモン活性を持っているプロスタグランジンを作ることが示された。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物の不飽和脂肪が動物の飽和脂肪に比べて、人間でもラットでも、血清コレステロールレベルを下げることが最初に見つかったときに、これまで知られている必須脂肪酸（ＥＦＡ）すなわちリノール酸および多分リノレン酸が多いためと考えられた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "大腸で繊維が発酵すると短鎖脂肪酸（ＳＣＦＡ）量を増加させ、これが抗ガン作用を持つ可能性が示唆された（161）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも訊いてみるよ」「取材して記事を書いた人」「訊いておいて、ＦＡＸでも」「新しい仕事場のほうへ」「うん」　電話はそこで終わった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢沢千秋についての問い合わせに対して返事が届いたことを、日比谷はＦＡＸ通信紙に簡単に書いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして矢沢富美子からの手紙とともに、中野玲子の専用ＦＡＸ宛に送信した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙を後藤美代子のファイルに収めているとき、ＦＡＸが受信を開始した。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また電話しますので、出来ればそこにいてください』　このＦＡＸ通信も、日比谷は後藤美代子のファイルに入れた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまの私の裸体が、真夏の陽ざしとどこまで張り合えるかが、個人的な楽しみです』　と、玲子からＦＡＸによる連絡があった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
