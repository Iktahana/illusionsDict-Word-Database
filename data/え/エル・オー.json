        "examples": {
          "standard": [
            {
              "text": "「すみません、もうお食事のＬＯを過ぎてしまいましたので、お飲み物だけの提供となります。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「えっ、もう２２時？ 急いでデザートを注文しないとＬＯに間に合わないよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "居酒屋で昔話に花を咲かせていたら、店員さんにＬＯの時間だと告げられ、名残惜しく店を後にした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "マッキントッシュは淀み、ＭＳ―ＤＯＳは周回遅れでたらたらとマックを追いかけ、ＵＮＩＸの土俵ではＯＰＥＮ　ＬＯＯＫとＭｏｔｉｆ（共にＵＮＩＸをマックに化けさせる厚化粧の流儀）が水入りの勝負を続けている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文献に出てゐるたくさんの謎々の問題は、イギリスの２ＬＯ放送局から放送されたものを集めてあり、虫喰ひ算と覆面算はたつた四題にすぎませんが、他の百ばかりの問題は、數學と科學と工學の各部門に亘り、なかなか面白いものばかりで、氏の解説も頗る平易です。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文献に出ているたくさんの謎々の問題は、イギリスの２ＬＯ放送局から放送されたものを集めてあり、虫喰い算と覆面算はたった四題にすぎませんが、他の百ばかりの問題は、数学と科学と工学の各部門に亘り、なかなか面白いものばかりで、氏の解説も頗る平易です。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳＬＯ――もとのクリスチャニア。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "――God damn!　ＬＯ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "God damn it !　じゃこっぷの中途から救われてガルシア・モレノに甲板した僕と鞄が、ＬＯ！",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　　　　　３　ランキャスタシャアのＰＯＬＯの名手として知られているナックス・タウンセンド大佐は、女を擽るために赤毛の口髭を短く刈り込んで、ＲをＵのように発音していた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "新探偵雑誌ＬＯＯＫに、江戸川さんと共に追悼文を書く。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ＨＡＬＬＯＯ――　――ＨＡＬＬＯＯ――　黄昏が帰滅へ誘ふ遥かな言葉。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがＶＩＬＬＯＮ第一号に掲載されたのだ。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ＶＩＬＬＯＮの、「華々しき瞬間」、の問題にかえろう。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼の意志かあわれみで同人雑誌のＶＩＬＬＯＮか、ＶＩＫＩＮＧに印刷されるでしょう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿も（芝居の）ＶＩＬＬＯＮかＶＩＫＩＮＧに、富士さんは、のっけてくれるだろう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿も（芝居の）、ＶＩＬＬＯＮかＶＩＫＩＮＧに、富士さんは、のっけてくれるだろう。",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月三十一日　午前二時頃（昭和二七年一二月三一日作、「ＶＩＫＩＮＧ47・ＶＩＬＬＯＮ４」共同刊行号、昭和二八年三月）",
              "citation": {
                "source": "幾度目かの最期",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わきの映画館の軒蛇腹に橙色の焔の糸が、柔かい字体で、ＧＬＯＲＩＡ・ＰＡＬＡＳＴと輝やいている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして番頭のジョージ・依田という二世の少年や、そのほか私が顔も見知らぬ印度人たちが主人公のカパディア氏の周りに、立ったり腰かけたりして店はいつものように混雑を極めていたが、「ＨＡＬＬＯ！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "合言葉のひとつであったＬＯＶＥは、最大限の愛を持った人間こそもっとも美しい人間だ、という考え方から出てきたものなのだが、結局はフィーリングとジェスチャと性的な自由さにとどまり、それらをのりこえたアクションにはならなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "責任、義務、期待などすべてからはなれきったところで各自が自分をフルに表現すれば理想の世界ができあがるという、一足とびの観念世界だけのためにしかＬＯＶＥは存在しなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "このときのヒッピーたちにとって、信念はすでにＬＯＶＥでも Do your own thing でもなく、「ムーヴメントはそれぞれの頭と手のなかにある。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三つの言葉は、　ＩとＬＯＶＥとＹＯＵだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
