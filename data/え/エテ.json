    "definitions": [
      {
        "index": 1,
        "gloss": "forte",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はプログラミングが得手なので、システム開発のリーダーを任せられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は細かい作業は苦手だが、人前で話すことは得手だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「え、こんな複雑な計算、君の得手じゃないのかい？」と先輩に言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は料理が得手で、いつも美味しい手料理を振る舞ってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "気の毒にみえた奴が、忽ち自分の不得手なことを始めたからだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "得手勝手な考えごとなどしているから、人の言うことも耳へ這入らないのだ……」　という様な随分痛い小言を云った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "各人、随分得手勝手な、無責任極まる与太を飛ばしましたが、結果に於ては出来上ったシナリオが想像以上に明るく面白く、ギャグなぞも案外垢抜けのした奴がありました。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はフランス語はいちばん不得手だがしかしごくゆっくり話してくれればだいたいの事だけはわかるつもりだと言ったら、それで結構だと言ってぽつぽつ話しだしたが、その話の内容は実に予想のほかのものであった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この得手勝手な男はその前に立ち止った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物の目から見ればやはり人間は得手勝手なものに見えるであろう。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "碎いて言へば、夜逃は得手でも、朝旅の出來ない野郎である。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶なら油揚も攫おうが、人間の手に持ったままを引手繰る段は、お互に得手でない。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれもどれも、碌でなしが、得手に帆じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一知の幸運の獲得手段はドコまでも陰性で消極的であった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄は、謂わば立派な人格者なのであって、胸には高潔の理想の火が燃えて、愛情も深く、そこに何の駈引も打算も無いのであるから、どうも物語を虚構する事に於いては不得手なのである。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼈四郎の父はそれまで不得手ながら金銭上の事に関ってまでいろいろ面倒を見てやったのだがついにその甲斐もなかった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、僕等の年代の人間には、はっきりは触れられんが……」　旧詩人の社長は、よく通りかかりの旅客が、寄航したその場だけ、得手勝手なことを頼み、あとはそれなりになってしまう交際に慣れているので、私が娘を連れて、こちらに来た用向きを話し出すと、始めは気のない顔つきをしていたが、だんだん乗り出して来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、嘘の不得手な純真なお子です。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞんざいというと非難するように聞えるが、そうではない、シネクネと身体にシナを付けて、語音に礼儀の潤いを持たせて、奥様らしく気取って挨拶するようなことはこの細君の大の不得手で、褒めて云えば真率なのである。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日以後も昨日以前同樣の取扱方を吾が身に加へて居て、而して明日からは往日と異なつた結果を得ようといふ其樣な得手勝手な注文は成り立つ道理が無い。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも僕は、こんなわかり切ったような概念論は、不得手なのだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙というもの、実にまどろこしく、ぼくには不得手。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』ヴェル氏、仰天して、ころげるようにして廊下へ飛び出し、命からがら逃げかえったそうで、僕は、どうも、人のざんげを聞くことが得手じゃないのです。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不得手なのは攀木に駈競。",
              "citation": {
                "source": "刑余の叔父",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから自分としては、どこまでも一人の単純な青年を老嬢の無理から切り離そう、その侠気のようなものだけで心が奮い立って来たような気が致しますのは、やっぱり女は甘くて得手勝手なものなのでございましょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事でも順序を立てて考へることは不得手であるのを、博士が論理で責めるから、半分夢中で受答をしてゐる中に、いつでも十六｜六指のやうに詰められてしまふ。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも不得手だ」「まあ何にも出來ないの。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "また秀吉三楽に向って曰く、「御身は智仁勇の三徳ある、良将なり、されど小身なり、我一徳もなし、しかし天下を取るが得手なり」と。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　前川は、美和子らしい得手勝手な金額に微苦笑しなら、「どうぞ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こんなところから得たものか、作文は学校においても比較的得手であったように記憶している。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか別にきらいのものもなかった代わり、また格別得手というものもなかったが、その中で地理だけは中学時代から、特別に興味を持っていた。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧米人の得手勝手で、いかなる文明開化も建築宏壮にして国亡びて後までも伝わるべきものなきは真の開化国にあらずなどいうは、大いに笑うべし。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "５向ふに、水車が、見えてゐます、　　苔むした、小屋の傍、ではもう、此処からお帰りなさい、お帰りなさい　　僕は一人で、行けます、行けます、僕は、何を云つてるのでせう　　いいえ、僕とて文明人らしくもつと、他の話も、すれば出来た　　いいえ、やつぱり、出来ません出来ません。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといふのが世態で何しろ神経生存だけになつてゐて、まづまあ金ピカ流儀を覚えて「嗤はれないやうに嗤はれないやうに」か、又一方「我等は若きプロレタリアだツ」になるほか差当つて帰趨を知らないからである。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
