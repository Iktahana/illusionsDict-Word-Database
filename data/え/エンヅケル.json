        "examples": {
          "standard": [
            {
              "text": "親は娘を良家の子息に縁付けようと奔走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は親が子供の相手を探し、縁付けることが多かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "姉を縁付けるために、叔母が何度も見合い話を持ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自分の子供を無理に縁付けるつもりはないと言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「あれが片付かんと、妹二人を縁付ける訳に行かんからのう」「そうですねえ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つには村でも最も古い家柄であるだけに、娘をよそへ縁付けるなどというといろいろ面倒な慣例もある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "日下部太郎はつい先頃、高畠子爵の二十六になった長女を、伊勢の豪家へ縁付ける媒酌をした。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
