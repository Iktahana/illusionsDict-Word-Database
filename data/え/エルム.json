        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公園の大きなエルムの木の下にベンチを置き、読書をしながら午後のひとときを過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "街路樹のエルムが秋風に揺れ、黄色く色づいた葉が歩道を静かに埋め尽くしていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この家具はエルム材で作られており、力強い木目と温かみのある質感が特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「エルムの街灯」というタイトルの小説を読み終えた後、外の並木道を散歩したくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "いつでも見落すことのできないのは、北二条と大通りとの交叉点にただ一本立つエルムの大樹だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルムは立っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が輪まはしに駈けめぐる小路のあたりにはやはらかなクローバーが白い花をつけ、エルムのやさしい梢は彼女の頭の上に押しひろがって、ゆたかな影を与へて居た。",
              "citation": {
                "source": "雛鳥の夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉巻の煙、エルムの若葉の香、多くの窓々が五月の夕暮に向って開かれている。",
              "citation": {
                "source": "わが五月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草臥れたんで電車に乘りエルム街の停車場で降り家の方へ歸つて來るところを捕まつたのです。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "息もつまりそうにうっそうと茂ったエルムの梢を、そよりとも動かす微風もなくて、静かに横わった湖水から、彼岸の山にかけて、むっとした息のような霞が掛って居る。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウェデン詩歌の元祖スチェルンエルム Stjernhjelm はこの時に出ました。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千七百年代から、ローマン主義時代までのスウェデンでは、フランスのクラッシク文學をまねた典雅な擬古典主義文學が隆盛で、スチェルンエルム以後の詩人は言葉の清醇と作詩の自由とを妨げられました。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルムの巨木がその邸の上にひろびろと枝をひろげ、その根かたには泉があって、甘い柔かい水がごぼごぼと湧きだして、小さな樽形の井戸からあふれ、きらきら光りながら草地のなかを通って、近くの小川に注いでいた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに、イカバッドはあの大きなエルムの木の下の泉のほとりや、あるいは、黄昏のなかをぶらぶら散歩しながら、娘を口説くのだった。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丘の上に建っており、まわりには南蛮さいかちやエルムが高々としげっていた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞエルムなるべしと思って、顧みて聞くと、「にれの樹です」という。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラークの胸像のように、エルムという樹名も追放されていたのであろうか？",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルムもまたアメリカから渡った街路樹とばかり私は思いこんでいた。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉を布いてそそりたつ巨木はすべてエルムであった。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみれば、道立図書館まえの大街路樹、おばけのような柳とエルムも、土地生えぬきのものだったのだ。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "楡なぞという木を見たこともない開拓民たちは、サッポロ・チャシナイ・クッチャンなどと耳馴れぬアイヌ地名を覚えるのと同じ気安さで、アメリカの教師が教えたエルムという樹名に親しんでいったことであろう。",
              "citation": {
                "source": "望郷",
                "author": "――北海道初行脚――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてエルムの学園などという言葉が、戦前まではよく使われたものであった。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内地の若い人たち、特に女学生の人たちの間に、このエルムの樹はなかなか人気があったようである。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでこういう美しいエルムの樹の花はどんなだろうかという質問を時々うけることがある。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどエルムの花盛りというものは、一寸旅行者には見られない。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エルムの樹に花なんか咲きゃしませんよ」というのが、大多数の人の返事であろう。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしエルムにも立派に花盛りがあるのである。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時に、冬の間はすっかり葉が落ちたエルムの梢が、まだ枯枝のまま暗い空に交錯してのび出ている。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがエルムの花なのである。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮に冷たい風の吹く中を、オーバの襟を立てながら、鼠色の空に交錯する枯枝を仰いで「またエルムの花盛りになったね」と冗談を言う友人もあった。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木屑のような花ながら、エルムにとっては、それが青春なのである。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう先生方は、エルムの花のような青春を送っていれば、それで世間は安心している、というよりも、その方が評判がよいと言った方がよいであろう。",
              "citation": {
                "source": "楡の花",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木はその頃の立木を残したもので、亭々とした樫だの柏だのエルムなどが、家々の屋根をおおって聳え立っている。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたりは、針葉樹は全然ないところで、街路樹も庭木も、みなエルムとか、樫とか、柏とかいう、闊葉樹ばかりである。",
              "citation": {
                "source": "北国の春",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
