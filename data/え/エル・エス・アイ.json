[
  {
    "uuid": "e48db779-c592-546b-8d7e-91a6a36c8b0f",
    "entry": "ＬＳＩ",
    "reading": {
      "primary": "エル・エス・アイ",
      "alternatives": [
        "エルエスアイ"
      ],
      "is_heteronym": false
    },
    "grammar": {
