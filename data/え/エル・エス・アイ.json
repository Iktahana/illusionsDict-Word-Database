      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "large scale integrated circuit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「この新型ゲーム機には、専用設計された最新鋭のＬＳＩが搭載されているんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「基板上のＬＳＩがかなりの熱を持っていて、冷却ファンがフル回転しているよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "半導体技術の進歩により、かつては巨大だった計算機が、一個のＬＳＩに収まるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「設計図をＬＳＩとして焼き付ける工程には、非常に高い精度が要求されるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "つまりこうだ、もし私の読み通り、これがあのご婦人と昔親密にしていた者からのメッセージだとすれば、この両端にＥがあり、中に三文字ある組み合わせは、ＥＬＳＩＥ、『エルシィ』という名前をまさに指しているのかもしれぬ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＥＬＳＩＥ　・ＲＥ・ＡＲＥ　ＴＯ　ＭＥＥＴ　ＴＨＹ　ＧＯ・　ここにＰとＤを加えて、伝言は完成です。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命児はそれまでコンピューターとは縁のなかった集積回路部門、ＩＣやＬＳＩといった電気回路用の部品を取り扱うセクションから誕生した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして半導体メーカーに、新製品用ＬＳＩの設計を依頼し、設計が終わって原版にあたるマスクが作られると、ともかく想定した個数分のＬＳＩを、輪転機を回すように作りきってしまうのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビジコン社は、それまでの常識からすれば半完成品のＬＳＩ、つまりは完全に印刷が終わっておらず、白い頁の残ったままのＬＳＩを利用することを考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある機能を備えた電卓向けに開発されたＬＳＩには、その機能を実現するために必要な回路がきわめてコンパクトに作り付けられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを裏返せば、ある一種類のＬＳＩは、他の機能を備えた電卓の部品としては使えない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも三種類の機能の異なった電卓を作るとすれば、三種類のＬＳＩを用意する必要があり、そのたびごとに膨大な回路の設計作業を行うことになる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対し、半完成品でそこにソフトウエアを追加してはじめて機能するＬＳＩを大量に作っておく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この半完成品ＬＳＩ、いわばできそこないＬＳＩに、付け加えたい機能を実現するソフトウエアを加えてやれば、それ用のＬＳＩに化ける。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもこうしたできそこないＬＳＩが作れれば、ソフトの種類だけ化ける可能性を持ったものを一挙に作り上げてしまう超輪転機方式が可能になる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビジコン社は、従来の常識からは考えられないできそこないＬＳＩの開発を、当時はまだほんの小さかった半導体メーカー、インテル社に依頼した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "できそこないＬＳＩの開発を担当していたビジコン社のスタッフ四名は、基本的な構想を固めてアメリカに渡り、インテル側の担当者と設計図の作成に着手した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビジコンではあくまで、電卓用ＬＳＩでプログラム可能なもの、言い換えればソフトウエア追加によって異なった機能を持つものを望んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電卓にしかならないＬＳＩではなく、電卓にもなるＬＳＩを目指したのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ＬＳＩの技術も存在し、プログラムをたくわえておいて実行するという方式もコンピューターでは行われていたことから、小島は特許の取得を断念することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその後、ＩＣの集積度は飛躍的に高まり、ゲートと呼ばれる基本単位となる回路の数が一〇〇〇を超えるものに関しては、ＬＳＩ（大規模集積回路）という別の名前が用意されるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＬＳＩにコンピューターの中央処理装置の機能を収めたといっても、その力はあまりに貧弱。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、目の前にあるちっぽけなＬＳＩにコンピューターの中央処理装置が収まっているといわれても、どうしても首をひねりたくなる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターとＬＳＩ一個とは、どう考えても結びつくように思えない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに一個のＬＳＩに押し込められたマイクロコンピューターは、原版にあたるマスクができればあとは写真を焼き付けるように一括して大量に作ることができる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "電卓用のＬＳＩを担当しているスタッフに相談してみると、比較的簡単に発光ダイオードの簡単な出力装置が付けられそうだということで、入力装置も簡単なテンキーのようなものでいってはという。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＫ―80の記憶装置には、値段の安く電力を食わないＭＯＳ型のＬＳＩを使うことになったが、これがまったく静電気に弱い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、普段ＬＳＩに縁のない技術者に、どうすれば安全に組み立ててもらえるだろうか――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかでも笑い出したのは、ＭＯＳ型ＬＳＩの取り扱い注意である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
