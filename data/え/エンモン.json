        "examples": {
          "standard": [
            {
              "text": "古代の壺には、繊細な円文様が描かれていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この着物の帯には、吉祥の意味を持つ円文が織り込まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館で見た古いコインには、中央に美しい円文が刻まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "八千円文庫ですら今八百の単位を戦いとったのである。",
              "citation": {
                "source": "国会図書館の窓から",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "希くば、この十二社で、基本図書、教養文庫の一万円文庫の計画を立てて戴き、図書館協会の組織と組み合わせて大いなる威力だと思っている。",
              "citation": {
                "source": "国会図書館の窓から",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事態、私も怪訝に堪えんもんで、早急とはなしに、本郷方面へ、同僚の筋を手繰って捜りを入れると、葛木晋三と云う医学士はいかにもあるじゃね、そしてです、それは医科に勤めておらるるが、内科、外科、乃至婦人科、何でもないのじゃ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこんとこ、何とかうまい具合にして貰えんもんかと思いやす。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうほのかな話でなく、ひとつわれわれにも納得のゆくような証拠を示してもらえんもんだろうか。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「東京に行ったわ」「ふウン」時次郎は、ちょっと、張りあい抜けした表情を浮かべたが、「実は、長崎の高島炭坑で沈没炭引きあげの相談をうけてなあ、わし一人の手に負えんもんじゃけ、オヤジの力を借りようと思うて来た。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
