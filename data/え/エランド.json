        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "アフリカのサバンナをドライブ中、広大な草原を悠々と歩くエランドの群れに遭遇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エランドは、カモシカ科の動物の中でも特に体が大きく、その優雅な姿は見る者を魅了する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雄のエランドは、太い角を持ち、縄張り争いの際には迫力ある姿を見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "安政五年の出版で、蘭書フーフエランドの寫本を原稿として鉛活字で印刷したといふ意味が述べてあり、練造氏の幼時の記憶によれば「又活字も診察室の戸棚に澤山あつたものでした。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は再び船に乗り込んで、ある曇った日に（海は黒く揺れていた）北へ向かって、ゼエランド島の渚づたいに、ヘルジンゲエルへと進んで行った。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "堆書狂で名高かったのは、十九世紀初葉のオランダの貴族ウェストリーネン・ヴァン・ティエランドであるが、此男が豪い蔵書家で、且つ蔵書を人に見せたがらない奇人だった。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の友は快諾して、招待の日を待っていたがティエランドは遂に違約して了った。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "又一説によると、二人の友は条件を具備した風体で蔵書拝見と出掛けたところがティエランドはそれでは満足出来ず、更に彼等二人に大きな袋を穿かせて、手足の自由を奪って置いて、袋から首だけを出させたままで、書庫に案内したが唯書架と書架との間をピョンピョン飛んで過させただけだった、とも伝えられている。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "堆書狂でティエランドを凌ぎ、英国のリチャード・ヒーバーにも勝る程の豪傑はフランスのブーラールである。",
              "citation": {
                "source": "愛書癖",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
