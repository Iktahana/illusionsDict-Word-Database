        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "時計の精巧なメカニズムにおいて、エスケープは時間の精度を保つための重要な部品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "アンティーク時計の修理では、このエスケープ部分の調整が最も神経を使う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この古い時計、カチカチって音はするけど、進まなかったんだ。エスケープが噛んでるのかも。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エスケープの設計が、時計の動力伝達効率や精度に大きく影響する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
