        "examples": {
          "standard": [
            {
              "text": "「足元が暗いので、出口まで私がエスコートしますね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国賓の来日に合わせ、白バイが車列を厳重にエスコートしながら進んでいった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「パーティーの会場では、パートナーをスマートにエスコートするのがマナーだよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "豪華客船の甲板で、紳士が淑女をエスコートして夕食に向かう姿が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "外泊のときは、さすがの高志も、兄らしく令子をエスコートして帰り、いっしょに寮にもどってくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女共学も結構、男が女をエスコートする風習の移入も結構。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その八　安吾愛妻物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｇ中尉は「これは少々ツー・メニイだ」といって、入口の所へ行き、前から命令を受けていた米国兵一人のほかに比島兵一人に新たに命令を出し、都合二人の兵隊がエスコートすることになった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、夜卓の上に投げ出しておいた、かなり多額の磅紙幣と、巴里のナショナル・エスコートで振出した旅行信用状の入った札入などは、手もふれたようすがなかった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "金はニューヨークのナショナル・バンク、パリーのエスコート・ナショナル、ローマのローマ銀行、その他合計十六の銀行へ払い込み、赤線の小切手で全額を仕払うことになっていた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとりでは心細いとピアイラグが言うので、エスコートのようについて来たのですよ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵夫人はエスコート係に自分の手を陽気にキスさせた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
