        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "逃げ出そうとした万引き犯の襟首を掴み、「待て、どこへ行くんだ」と店主が鋭く一喝した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「こらっ、勝手におやつをつまみ食いしたのは誰だ！」と父が弟の襟首を掴んで居間に連れ戻した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "泥酔した男たちが喧嘩を始め、相手の襟首を掴んで激しく前後に揺さぶっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "崖から転落しそうになった仲間を、間一髪で襟首を掴んで力任せに引き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "走り寄って来た警官は、咄嗟の間にこの場の成行を察すると、手を伸して真名古の襟首を掴む。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中久太夫は徒士の御先手で駕籠脇についていたが、あまりの煩しさに、ついとり逆上せ「三両、三両」と叫びながら、駕籠脇に迫ってきた才槌頭の襟首を掴むなり「おのれ」といって、ぬかるみへ取って投げた。",
              "citation": {
                "source": "ボニン島物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
