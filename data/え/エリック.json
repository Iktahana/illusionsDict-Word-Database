        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "教育学の論文を執筆するにあたり、まずはERICのデータベースで最新の先行研究を検索することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "教授から「その理論の出典はERICで見つけられるはずだ」と具体的なアドバイスをいただいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外の教育現場での実践事例を収集するため、ERICに登録されている膨大な紀要を読み込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "……王の射手エーナール・タンバルスケルヴェはエリック伯をねらって矢を送ると、伯の頭上をかすめて舵柄にぐざと立つ。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリックの兵は急いで捕えようとしたが、王は用心深く盾を頭にかざして落ち入ったので捕える事ができなかった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリック・エリオット、映画技術と芸術（岸松雄訳）。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上が画工エリックの物語で、同雑誌記者の附記する所によれば、彼の画工の筆に成った恐しき婦人の絵姿は此のほど全く出来したが、何さま一種云われぬ物凄い恐しい顔である、婦人の如き、其の図を一目見るや忽ちに魘えて顫えて、其後一週間ほどは病床に倒れたという。",
              "citation": {
                "source": "画工と幽霊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "著作権切れの書籍を電子化して公開するプロジェクトを進めるエリック・エルドレッド等は、同法が合衆国憲法に違反するとの訴えを起こした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面に、Ｅ・Ｈ・エリックが映しだされる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ・Ｈ・エリックが、ザ・ビートルズ、と叫んだのだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリック・バードンが叫び、アラン・プライスのオルガンが突っこんでくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　＊　其後、英国のゴムシャムで出来た人造人間、倫敦の流行児となったエリックという人造人間、米国ではウェンスレー博士のこしらえたテレボックスという名の人造人間など、あとからあとへと現れ、テレボックスの如きは同じ姿をした弟たちが、幾度も製造され、それぞれ役立っているという。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて四号には、ニュージャージー州ルーズベルトに住むハイスクールの三年生、エリック・ミューラーの書いたタイニーベーシックのソースリストが掲載された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、私は東五十六丁目の――番地エリック方へ陣取って、鞄をあずけ、一週間分の間代を前金で払い、鍵を受取って、木元の跡を追いかけた。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、その夜はエリック方に寝て、翌日からの活動になった。",
              "citation": {
                "source": "ニュー・ヨーク　『青春の自画像』より",
                "author": "前田河広一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "保羅は、時々、先生のところへやって来ては、沈鬱な、典雅なようすで、エリック・サティやダリウス・ミヨオやオーリックなどを弾いていた。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "充電するにはブルースが必要だ」と、エリック・クラプトンは、言った。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（エリック・クラプトン）　最初の楽器はピアノだったのです。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（エリック・クラプトン）　聞いている人たちからのフィードバックは重要な演奏メンバーのひとりと言える。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（エリック・クラプトン）　ジャズは、内省にむかいすぎている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
