        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔は、FDにOSやアプリケーションをインストールしていたんだよ。今思うと信じられないね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "あの頃のFDは容量が小さかったから、大きなファイルは複数枚に分けないといけなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "引っ越しの整理をしていたら、懐かしいFDがたくさん出てきた。もう読み込めるドライブがないけど。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館で、当時のコンピュータと一緒に展示されているFDを見たよ。貴重な展示品だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "トルーマンは、ＦＤＲのニュー・ディールを継続することにした。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＶＡ、社会保障法と、これまでのアメリカの伝統の枠内ぎりぎりのところでＦＤＲは改革をこころみ、ラジオをとおして、親密な感じで国民に語りかけ、前進していった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＤＲの放送があるときには、ＷＳＭ局の『グランド・オール・オプリイ』も、さすがにお休みした。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＦＤＲは再選され、一九四一年、日本がハワイのパール・ハーバーを奇襲した。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大統領は三選をめざして選挙に出ることはできないことになっていたのだが、ＦＤＲは、このルールを破って、大統領になった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "本の表題“Japan Day by Day”――エッチ・エー・ガーフィールド夫人とロリン・エフ・ディーランド氏とから個々に云って来られた――は、事実ありのままを示している。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
