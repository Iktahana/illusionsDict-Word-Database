[
  {
    "uuid": "e1a410a8-0f19-5fa1-8f23-5eb692da2f7d",
    "entry": "演説口調",
    "reading": {
      "primary": "えんぜつくちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
