          "standard": [
            {
              "text": "夏休みの最終日、溜め込んでいた絵日記を一気に描き上げるのは子供たちの定番の苦行だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お母さん見て！今日の絵日記、カブトムシが上手に描けたよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父が遺した戦時中の絵日記には、当時の厳しい暮らしが淡々としたタッチで描かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "絵日記に三六度なんて書いたことなかったもの」　ワラは足もとの袋をゴソゴソやって、なにかさがしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の為めには、古い新しい写生帖が懐かしい絵日記となつて居る。",
              "citation": {
                "source": "写生帖の思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の絵日記の一番古いのは十三位の幼い頃から始まつてゐる。",
              "citation": {
                "source": "写生帖の思ひ出",
                "author": "上村松園",
                "note": "青空文庫"
              }
            }
          ]
