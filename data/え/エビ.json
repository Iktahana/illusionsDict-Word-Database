      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "evidence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「事件の核心に迫るエビを、我々はついに掴んだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このプロジェクトの成功を裏付けるエビは、まだ不足している。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「担当者から、エビの提出を急いでもらいたい。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「裁判では、被告に不利なエビが次々と提出された。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "幹太郎が這入って行くと、領事館からついてきた、帽子にエビ茶の鉢巻のついた若い巡査は、二人が、ちょっと顔を見合して室外に出た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲、ケーキ、イチゴミルク、エビフライ、オムレツ……。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "フズーズボンチとちがうわい」　と、次郎は叱りつけたが、ふと、ためいきをついて、「――しかし、珈琲も美味かったぜ」「わいはあんなにがいもンより、エビフライの方がええ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの家はどう云う理由か、エビス・ビールを看板にしているが、私はずっと前に、矢張りその界隈にあるハムブルグ酒場で、大変美味しいピルゼンのビールを飲んだことがあった。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はエビス・ビールが我慢出来なかったので、酒台のところに立って火酒を飲んだ。",
              "citation": {
                "source": "ああ華族様だよ　と私は嘘を吐くのであった",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の妻のエビルは頗る多情で、部落の誰彼と何時も浮名を流しては夫を悲しませていた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルは浮気者だったので、（斯ういう時に「けれども」という接続詞を使いたがるのは温帯人の論理に過ぎない）又、大の嫉妬家でもあった。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が路の真中を歩かずに左側を歩くと、其の左側の家々の娘共はエビルの疑を受けた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、ギラ・コシサンの妻エビルは、此の恋喧嘩を、人妻といわず、娘といわず、女でない女を除いたあらゆる村の女に向って仕掛けた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルは腕も脚も飽く迄太く、膂力に秀でた女だったのである。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルの多情は衆人周知の事実だったにも拘わらず、彼女の数々の情事は、結果から見て、正しいと言われなければならない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際エビルは、彼女の現実の情事は常に正義であり、夫の想像された情事は常に不正であると固く信じていた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルの慧眼が夫の顔色の変化を認めない訳がない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去十年間無敵を誇った女丈夫エビルが最も大事な恋喧嘩に惨敗を喫したのである。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "リメイによって救われるかも知れぬとの予感が実現しようとしているのは有難かったが、何しろ無敵のエビルが敗れるなどという大変事を前にして、一体この事柄をどう考えていいのか、又、此の事件が己が身にどう影響して来るのか、大いに惶れ惑わざるを得なかったのである。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、エビルはかすり傷だらけの身体に一糸もまとわず、髪の毛を剃られたサムソンの如くに悄然と、前を抑えながら家に戻った。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かに踊の群に近付き椰子樹の陰から覗いて見たが、踊る人々の中にも見物の中にも妻のエビルの姿は見えない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は誰か判らないが、女がエビルであることだけは間違いない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大嫉妬家のエビルに向って嫉妬するなどとは到底考えられぬことだし、怒りなどという感情はいじけた此の男の中から疾うに磨滅し去っていて今は少しの痕跡さえ見られない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分長い間経って二人が我に返った時、リメイは（エビルを負かす程の強い女だったにも拘わらず）さめざめと泣きながら、彼が来なくなってからの久しい間に、如何に操を立てるのが苦しかったかを、かき口説いた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前の壮烈な恋喧嘩の結果を見れば、優しく強いリメイがついている限り、幾らエビルが攻寄せて来ても恐れることはない。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、エビルは、夫がまだカヤンガルで舞踊台の出来上りを待っているとのみ思って、日夜数人の未婚の青年を集めて痴情に耽っていた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルは忽ちカアーッと逆上した。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が言伝えに残る・前にも後にも此の島唯一人の自殺者だが、今エビルは此の男に倣おうとした。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にエビルは肥って腹が出ているので、登り易くする為に椰子の幹に刻んだ切痕を五段も攀じ上ると、早くも呼吸が切れて来た。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "口惜しさにエビルは大声を出して村人を呼んだ。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰ももうエビルの叫喚には慣れて了って、又始まったと昼寝の枕から首も上げないのであろう。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エビルは今迄の叫喚をピタリと止め、多少きまり悪げな笑いを浮べてノソノソ下りて来た。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下にいた数人の村人の中に、エビルがギラ・コシサンの妻になる以前に大変｜懇ろであった一人の中年男がいた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りて来たエビルは此の男の顔を見ると、自分でも訳が分らずにニコリとした。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            }
          ]
        }
