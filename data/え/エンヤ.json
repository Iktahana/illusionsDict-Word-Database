        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の艷冶な笑顔は、多くの人々を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "舞台女優は、その艷冶な身のこなしで観客の視線を釘付けにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼の描く人物画は、独特の艷冶な雰囲気を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "おなじ半を口に啣へて、うつむいて見せた圖は、永洗の口繪の艷冶の態を眞似て、大に非なるものであつたが、これは期せずして年方の插繪の清楚であつた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙さえあれば、彼はこっそり瑠璃光丸の目を盗んで、大講堂の内陣に彳みながら、観世音や弥勒菩薩の艷冶な尊容に、夢見るような瞳を凝らしつゝ、茫然と物思いに耽って居た。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどわれいかでこの翁を忘れえんや。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれこのえんやらえ」というのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで人夫たちは、終いの文句の「えんやらえ」だけで材木を曳き上げてみましたけれど、どうも調子が悪くて直ぐ疲労てしまいます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はじめは倹約えんやらえ」と。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　自分は疲れてはゐるし、第一眠くてならなかツたから、遠慮をしないで、早速老人の肩へ兩手を掛けると、老人はえんやらツと立起ツて、ぽツくりぽツくり歩き出した。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "慨然として席を立ち、剣を按じて右に趨きて曰く、諸君｜乞うらくは勉めよ、昔｜漢高は十たび戦って九たび敗れぬれど終に天下を有したり、今事を挙げてより連に勝を得たるに、小挫して輙ち帰らば、更に能く北面して人に事えんや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王｜悦んで曰く、敵必ず兵を分ちて之を護らん、其の兵分れて勢弱きに乗じなば、如何で能く支えんや、と朱栄、劉江等を遣りて、軽騎を率いて、餉道を截らしめ、又｜游騎をして樵採を妨げ擾さしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲痛何ぞ能く堪えんや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうちょっと、そろそろ行って貰えんやろか」　と、頼んでも、「わたいはひとの二倍、三倍稼がんならん身体だっさかい、ゆっくり走ってられまへんねん」　辛抱してくれと、言って振り向いた眼の凄みに物を言わせて、他吉はきかなんだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "玲瓏たり燦爛たり、相模灘、もう一息だぞ、えんやらえんや。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実一念、十方玲瓏、喞筒の水はりうりうたり、れいろうたり、さんらんたり、えんやらえんや、えんやらえんや、消防整列、一心一向、消えて失くなれ不尽の山、やあれ、やあれ、えんやらな。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮気な沙魚めにや逃げられる、漕いでも漕いでも波の上、えんやらほいほい、えんやらほい、急いで上らにや子が喚く、えんやらほいほい、えんやらほい。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生はふつうの人のはいれない、離宮や御えんや、宮内省の一部なども開放されたので、人々はそれらの中へもおしおしになってにげこみました。",
              "citation": {
                "source": "大震火災記",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうちょっとそろそろ行って貰えんやろか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の指図によって、消防隊の人々が一方のセメント柱に手をかけて、えんやえんやと引張った。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ、もっと皆さんこっちへ来て手を貸して下さい」　更に人数を殖やして、えんやえんやと引張った。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、えんやえんや」　うんと力を合わせて引張ったので、セメント柱はごろごろと台の上から下に転がり落ちた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、だんだん見えんやうになつて行きよる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも去年から見りやずツと見えんやうになつたがのう。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
