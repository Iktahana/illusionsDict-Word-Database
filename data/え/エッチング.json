        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この銅版画は、緻密なエッチング技術によって描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ガラスに文字をエッチング（彫刻）して、オリジナルのグラスを作ってみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "科学の授業で、金属板に酸でエッチングする実験をしたよ。薬品を扱うのはちょっと怖かったけど、面白かった！",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "美術館で見たエッチング作品の数々は、光と影の表現が素晴らしかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "正しく風に動力を借りるオランダ低地の風車は美でもあり、経済的でもあったろうが、レムブラントの名手に油絵、またはエッチングに取り入れられたあの風車の風景も、近来は電気工業に取って代られ、引き合わないために、風車はだんだん取り毀たれ、オランダ風物の代表は、全く失われんとしているとも聞いた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "オリーブ色の壁に彩色画が七八点エッチングが三十点ほど懸け並べられてあった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事は実際上、良人や子供の理解なしにはなりたたないから、好都合な事情で運べば、よい妻、いい母さん、そして手芸であれ、エッチングであれ何か一つの仕事をもった女主人として、描かれる一家団欒の画面は非常にこまやかで活溌な生気に溢れていることも想像し得るのです。",
              "citation": {
                "source": "現実の道",
                "author": "――女も仕事をもて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどメイフェアの家は一つひとつが古いエッチングのように重く錆びている。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは、画家がエッチングの絵を描き、写真家が写真に撮るような、風光明媚で古風な趣で溢れています。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　私の書斎には今マールブルクの町を描いた小さいエッチングが懸っている。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黒と黄の入り乱れた色彩は、そのディムな感じからも、まるきり、黄色紙にされたエッチングを見るような気がした。",
              "citation": {
                "source": "結婚問題に就て考慮する迄",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋にもエッチングのみやる人と、彩描のかたわら或る内容をエッチングで表す人との二種があるように。",
              "citation": {
                "source": "想像と装飾の美",
                "author": "それを持つ特殊の個性によって生かさるべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には水彩もやってみたくなればグワッシュもやりたくなる、あるいはエッチングをやるのも面白いだろうし、木版を彫ってもいい、あるいは素描パステル、何でも好きなことをやれば気持が直る。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで仕上った絵は、実物の風景とは、左右が反対になっています、丁度エッチングの場合と同じ事であります。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度エッチングの場合と同じ事であります。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "――つい云ふのを忘れてゐたが、插繪はみんなエッチングである。",
              "citation": {
                "source": "詩集「窓」",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は絵筆の代りにエッチングの針を持つことの方が多くなった。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肖像画の注文は途絶え、しばらくは風景画を描いたり、エッチングを彫ったりしていなければならなかった。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャガールのは 250F で彼のサインのついたエッチングのすり一枚ついて居る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前には日を正面に受ける為に、横に派出された小尾根も谷も、唯だ一様に穏かな雪の斜面を見せて、凸凹などは少しもなく極めて平滑なようであるが、日が西に傾くに連れて、横尾根の日蔭になった半面と谷とが、濃藍色の太い竪縞を山の肌に織り出し、而も明暗の境界線がレムブラントのエッチングのように鋭い。",
              "citation": {
                "source": "望岳都東京",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は電灯で照された彼の室を見廻して、その壁を隙間なく飾っている風雅なエッチングや水彩画などについて、しばらく彼と話し合った。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "年齢はいくつなのか、まだ子供子供し、束の間の盛りを見せる脆い花といった、ものやさしさで、線の細いエッチングか素描でも見ているような清楚な印象を受けた。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "レンブラントのエッチングの絵はがきは届きましたか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "十数葉のエッチングだそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "エッチングとリトーグラフィーで主に制作しているのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても一枚ほしい人には、自作の『エッチング』（ＪＥ一九―二一）を挙げよう、ただし、大して面白いものではない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "台座の背面の高い位置に、文字をエッチングした小さな銅板が埋め込んであった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
