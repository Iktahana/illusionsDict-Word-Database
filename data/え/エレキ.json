        "examples": {
          "standard": [
            {
              "text": "ライブ会場では、バンドメンバーが越歴（エレキ）の激しいサウンドを響かせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は昔、越歴（エレキ）の腕前を披露していたらしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この曲のソロ、越歴（エレキ）で弾くと最高なんだ！」と、ギター初心者の友人が興奮して言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "中古の越歴（エレキ）ギターを衝動買いしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
