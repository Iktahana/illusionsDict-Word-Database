          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「お昼はコンビニのエッグサンドで済ませちゃおう。あれ、卵たっぷりで好きなんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、卵切らしてた！」「大丈夫、冷蔵庫の奥にパックのエッグがまだ残ってるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "パンケーキの生地をふっくらさせるために、新鮮なエッグを贅沢に3つも使っちゃった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この店へは比較的英米客が寄り付くので献立表にもクラブ・サンドウィッチとか、ハムエッグスとかいう通俗な英語名前の食品が並べてあった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手製のパンにハムエッグとコーヒーが出ました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートミルとフライエッグスと一、二杯の珈琲。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "フライ・エッグを入れた箱を提げて、出前持の女は事務室の親爺とぱったり出逢った。",
              "citation": {
                "source": "街の断片",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "オートミール、ハムエッグス、ベーコン、紅茶、さすがに閉口してしまって、いまだにハムエッグスとベーコンを見ると胸がつかえそうになる時がある。",
              "citation": {
                "source": "朝御飯",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の朝食と云うのは、日本の味噌汁みたいに、三百六十五日ハムエッグスがつきものなのだろうか。",
              "citation": {
                "source": "朝御飯",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「豆スープとハムエッグスと黒｜麺麭と、珈琲にウイスキーを入れて持って来い」　女は何も喰べずに、男の様子をまじまじと見ていた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつこのカフェー・ユートピアの二階へ上り込んだのか……どうして今、眼の前に並んでいる四種の料理……「豆スープ」と「黒｜麺麭」と「ハムエッグス」と「珈琲」を誂えたのか……一つも頭の中に残っていなかった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと一緒に俄かに空腹を感じて来たので、そこにあった黒｜麺麭を左手に掴み、右手で肉叉を使ってハムエッグスを掬いながら、野獣のように噛じり、頬張り、且つ呑み込んだ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺が今喰った……その四皿の料理はスープとハムエッグスと黒｜麺麭と珈琲だったナ……ウイスキー入りの……」「ハイ……貴方が御註文なすったんです」　ボーイは叱られるのを待っているような顔をした。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は立ち上って出て行きがけに、念のため私が自分で註文した食事が、黒｜麺麭とスープとハムエッグスと、ウイスキーを入れた珈琲の四皿に相違なかったかどうかをボーイに問い確かめてみると、ボーイはその通りですとハッキリ答えた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……のみならずその卓子に腰をかけていた志村浩太郎氏が、その妻ののぶ子から紫のハンカチを受け取る直前に、その卓子の上に並べていた四皿の料理は、今夜疑問の女から紫のハンカチを受け取る前に並べていた四皿の料理と、そっくりそのままの……黒麺麭と、スープと、ハムエッグスとウイスキー入りの珈琲ではなかったか。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポリッジとベイコンエッグス、ライプドオリーブ、それに紅茶とパンと、十年一日、判で捺したような朝食を済ましてから、伊東は松林に囲まれた家を出た。",
              "citation": {
                "source": "暴風雨に終わった一日",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "バタートーストにスープに、ハムエッグスに、コーヒーに葡萄酒、どれもふつうの量の三倍から四倍もあった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの五人の少年が、どこかへ姿を消しました」「なんだと」　さすがにＸ号も顔色をかえて、スープの中へハムエッグスをぽたりと落とした。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまだそんなお料理がありますか」お登和嬢「ハイ、今のようにブラウンソースで和えた肉を焼いたパンの上へ塗って今のような玉子の湯煮半熟を載せて出しますとメンチトースボウチドエッグスというものになります。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "白髪のプロフェッサー、ハムエッグを作って居る。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食の場合ですと、トースト十セント、ハムエッグ三十セント、それにコーヒー二十セント、これで充分です。",
              "citation": {
                "source": "アメリカの牛豚",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "缶詰は朝がハムエッグス（といっても、缶をあけると目玉卵が出て来るのではない。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ結構」というと、大きな卵を三個割ってスクランブルド・エッグスをつくり、トーストと缶詰の桃とでサパーの準備をしてくれた。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝飯にはベーコン・エッグスが出た。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
