        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「そのRPGの世界では、エルフは森の中に隠れ里を作り、数百年という長い寿命を生きるとされている。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「わあ、耳が尖ってる！本物のエルフに会えるなんて、まるでおとぎ話の世界みたい！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ファンタジー小説の中のエルフは弓の名手として描かれることが多く、驚異的な視力で遠くの敵を射抜く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その映画に登場するエルフの王女は、透き通るような肌と銀色の長い髪を持ち、この世のものとは思えない美しさだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "お化けは居ないがヘクセンやエルフェンは居そうな気がした。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルフルトのドミニカン僧より始め、中世最大の神秘家と云われた汎神論神学者）の云う霊性の方に近いのかもしれませんわ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ファウストが、疲れ果てて、不安らしく、草花の咲いた野に横はつてゐると、何處からともなく、身は細けれど胸廣きエルフの群は救はれむ人ある方へ急ぐなり。",
              "citation": {
                "source": "手紙",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォルリの名族の出、十三世紀の後半の人にてグエルフィ黨に屬す九一―九三【ポーと山と海とレーノの間】ローマニア。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "北欧羅巴の「エルフ」説話は、即ち之なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「雨のごと散る春の花人皆の頭の上に閃き落ち、田畑の緑なる恵青人草に4615かゞやきて見ゆる時、身は細けれど胸広きエルフの群は救はれむ人ある方へ急ぐなり。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの優しいエルフの流義でこの場でも働いてくれ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてあれを神聖な光の中へ返して遣つて、エルフの義務の中の一番美しい義務を尽せ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ごろ太っているエルフィーモフが、きょうは一層肥えふとって、息づかいもくるしそうにしている。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルフィーモフのかみさんの裾が、きょうはまた何とふくらんでいることだろう。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルフィーモフの腹のまわりから十ヤールの羅紗地があらわれた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは五年前、エルフルトでカタル性の熱病に、あの高熱の胸の病にかかって以来、一度も声をひそめぬ警告である。",
              "citation": {
                "source": "悩みのひととき",
                "author": "SCHWERE STUNDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラハ、ウィーン、ハイデルベルク、ケルン、エルフルトの大学の創立は14世紀に起きた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "1237年にエルフルトで100人以上の子供たちに踊りと凶暴の発作が起きこの場合も多くが死亡し生存者には永続性の震えが残った。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "中心となる部分が集められるまで病気はほとんど無くマグデブルク、エルフルト、ポズナン、ベルリンに作られた病院にはほとんど患者が居なかった。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
