        "examples": {
          "standard": [
            {
              "text": "若くして亡くなった天才音楽家は、白玉楼中の人となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさか彼が白玉楼中の人となるなんて…」と、友は悲しみに暮れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "惜しまれながらも、偉大な画家は白玉楼中の人となり、多くの傑作を残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "曽て漢詩の大家何某先生｜白玉楼中の人となるや葬礼に際して俄に文学博士の学位を授られたる事あり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの世には悩みも恨みもこれあるまじく、父の手を執りて由利どのを追い、共に白玉楼中の人となるが、いまはの際の喜びに御座候。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
