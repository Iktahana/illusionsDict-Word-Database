    "definitions": [
      {
        "index": 1,
        "gloss": "bald head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四十を越えた禿げ頭の男からおかっぱの女の子までまじっている。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「気障言うないこの禿げ頭ッ！",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕は全くの旅客でこの土地には縁もゆかりもない身だから、知る顔もなければ見覚えの禿げ頭もない。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボースンは、いよいよあわてて、いよいよ急にその禿げ頭をなでて、頼むのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで支配人の禿げ頭がキラキラと光っているところがうつってでもいれば、もっと胸がスーッとすくだろうに。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は何か書きものをやっているようだが、私の方からは、彼の禿げ頭と、痩せた肩が見えるだけです。",
              "citation": {
                "source": "無駄骨",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟子の僧は、時々気の毒そうな顔をして、内供の禿げ頭を見下しながら、こんな事を云った。",
              "citation": {
                "source": "鼻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "内供は、誦しかけた経文をやめて、禿げ頭を傾けながら、時々こう呟く事があった。",
              "citation": {
                "source": "鼻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "又もし禿げ頭だつたとすれば、恐らくは塗つても利かないであらう。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その感じから暗澹たる色彩を奪ったのは、ほとんど美しいとでも形容したい、光滑々たる先生の禿げ頭で、これまた後頭部のあたりに、種々たる胡麻塩の髪の毛が、わずかに残喘を保っていたが、大部分は博物の教科書に画が出ている駝鳥の卵なるものと相違はない。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うとまた、両手で禿げ頭を抑えながら、机の上へ顔を伏せて、いかにも面目なさそうに行きづまってしまう。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがて家畜のような眼の中に、あの何かを哀願するような表情が、際どくちくりと閃いたと思うと、急に例の紫の襟飾へ手をやって、二三度｜禿げ頭を下げながら、「いや、これは私が悪い。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと先生の禿げ頭も、下げる度に見事な赤銅色の光沢を帯びて、いよいよ駝鳥の卵らしい。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の中に映っている客の姿が、こちらへは僅に横顔しか見せていないにも関らず、あの駝鳥の卵のような、禿げ頭の恰好と云い、あの古色蒼然としたモオニング・コオトの容子と云い、最後にあの永遠に紫な襟飾の色合いと云い、我毛利先生だと云う事は、一目ですぐに知れたからである。",
              "citation": {
                "source": "毛利先生",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食前の閑つぶしに読んでいた小説を、太鼓腹の上に伏せて、片手で美事な禿げ頭をツルリと撫で上げながら、大きな欠伸を一つした。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、伯母さんも似合わないというし、シューラも似合わないって云うもんだから」「ばかなナースチャ、おかっぱにしないのなんか禿げ頭の爺さんか豚だけよ――ごらん、わたしだってよく似合ってるじゃないの」　ナースチャは、感嘆して、紫苑色のリザ・セミョンノヴナのすらりとしたスウェーター姿を眺めた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――人の好い禿げ頭の総代役はかう常談などもつけ加へた。",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処へ雛でも売つたらと父へ勧めてくれましたのは丸佐と云ふ骨董屋の、……もう故人になりましたが、禿げ頭の主人でございます。",
              "citation": {
                "source": "雛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この丸佐の禿げ頭位、可笑しかつたものはございません。",
              "citation": {
                "source": "雛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな手を差し出して、禿げ頭にそっと触れてみました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "巳之助は思い出したように、禿げ頭を掌で撫でてみました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして帽子を脱いで机の上に置くと、ボリボリと禿げ頭を掻いた。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしのにらんだところによると、宇宙のどこかに、兇悪な宇宙の猛獣とでもいうべき奴がひそんでいて、みんなそれに喰われてしまうんだどおもうよ」　禿げ頭のスミス老人が杖をふりまわしながら、花束を持った四、五人の老婦人を相手にしゃべっている。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あんな禿げ頭の年寄ではありません。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれっ、どうかしたよ、この受付は」　と、正太は怪訝な顔をしているとき、奥から人波をかきわけながらぜいぜい息を切らせてかけつけた一人の禿げ頭の老人があった。",
              "citation": {
                "source": "人造人間エフ氏",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一読、赤銅いろの禿げ頭した背の低い小肥りした憎気のない老武士が髣髴としてくるではないか。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀燭台に身を背けて、夜食をベラベラ食べているのは、大原の住職法印良忠で、法衣はつけず白衣ばかりの丸腰、禿げ頭を光からせていた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿げ頭は面喰ったように慌てて頭をさげ、ジロジロと見あげ見おろしていたが、気がついたように頓狂な声をだした。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大海人は、よくかげ口をきかれる例の神鳴り声を、小黒の禿げ頭のてつぺんへ浴びせかけると、ゆらりと地上へおり立つた。",
              "citation": {
                "source": "春泥",
                "author": "『白鳳』第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いひとはほんのわずかで、全体に禿げ頭や皺や白髪のほうが目だち、ひとくちにいえば非常にクラシックなパァティだった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
