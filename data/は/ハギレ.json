    "definitions": [
      {
        "index": 1,
        "gloss": "feel when biting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれら魂が稀薄なために、夢が浅いので歯切れが好いばかりだ。",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――彼等が歯切れの好いことは彼等の人格と無関係だ。",
              "citation": {
                "source": "Me Voila",
                "author": "―― a Cobayashi",
                "note": "青空文庫"
              }
            },
            {
              "text": "象牙のような滑らかさがあって、生餅より、よっぽど歯切れがよかった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉のよくわからないせいもあろうがいったいに前のスターンバークの「モロッコ」などに比べて歯切れが悪くてアクセントの弱い作品のように思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ、ポウェルという男とゲーブルという男との接触から生じるいかにもきびきびした歯切れのいい意気といったようなものが全編を引きしめていて観客を退屈させない。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下一つ隔てた向ひの部屋に、これもくすぶり込んでゐるらしい一人の客が、十二時近くなると毎晩下から沢庵漬を取りよせて酒を飲むのだつたが、いかにも歯切れのよささうなばり／＼といふ音と、生ぬるいらしい酒をずるつと啜り込む音とが堪らなく気持がよかつたのだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "照枝は東京の子供たちの歯切れの良い言葉がいかにも利溌な子供らしく聴えて以来、お腹の子供はぜひ東京育ちにするのだと夢をえがき、銭勘定も目立ってけちくさくなった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも東京生れの、言葉使いの歯切れよい、分に過ぎた女房であったが、千恵造は兄の命ずるまゝに従った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが何故かかの女を歯切れの悪い忿懣の情へ駆り立てた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎座の事務所に電話をかけたら、女のひとが出て、或いは有名な女優かも知れない、媚びたところも無く自然の、歯切れのよい言葉で、ていねいに教えてくれた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もさっそく四人の大学生の間に割込んで、先生の御高説を拝聴したのであるが、このたびの論説はなかなか歯切れがよろしく、山椒魚の講義などに較べて、段違いの出来栄えのようであったから、私は先生から催促されるまでも無く、自発的に懐中から手帖を出して速記をはじめた。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、いろいろとまた、別の話もしたが、来客は、私の思想の歯切れの悪さに、たいへん失望した様子でそろそろ帰り仕度をはじめた。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "食物には、筍は孟宗のシユンは過ぎて淡竹｜真竹の歯切れのよい品種が私たちを迎へる。",
              "citation": {
                "source": "初夏に座す",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪のでん公と比べものにならぬほど歯切れの良い土地者が暖簾をくぐると、どぎまぎした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪のでん公と比べものにならぬほど歯切れの良い土地者が暖簾をくゞると、どぎまぎした。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに女は歯切れの良い東京弁と来ている。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章会で四方太氏が自分の文章を読み上げる少しさびのある音声にも、関西なまりのある口調にも忘れ難い特色があったが、その読み方も実にきちんとした歯切れのいい読み方であった。",
              "citation": {
                "source": "俳諧瑣談",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて電話を入れた人間に、海外からすぐに返事をくれたことへの驚きに加え、歯切れの良い萩野さんの語り口調は、受話器を置いた後も耳に残りました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "塚本さん、インプレスの柱となる雑誌の創刊にあたっては、そこのところを是非、歯切れの良い大きな声で聞かせていただけないだろうか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、やをら立ちあがると、オツに歯切れの好いやうな調子で、頤をしやくつて、「おい、君、借りとくぜ。",
              "citation": {
                "source": "城ヶ島の春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "お医者の世界観は、原始二元論ともいうべきもので、世の中の有様をすべて善玉悪玉の合戦と見て、なかなか歯切れがよかった。",
              "citation": {
                "source": "満願",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｎは、生意気な中学生らしくして歯切れよく笑つた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保田氏は、往来に出ると、さういふ意味のことを、もつと歯切れのいゝ言葉で、だがいかにも何らかの弁明らしくティミッドな調子で、突然ポンと云つた。",
              "citation": {
                "source": "足袋のこと",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛子は一所をまたたきもしないで見つめながら、「えゝ」　と歯切れ悪く答えるのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きりっ　と歯切れのいい音を立てて弾筒が少し回転した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一に歯切れよく、と。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉はこういう男で、誰に会っても旧知の友のように胸襟を開いて歯切れの好い江戸ッ子弁でサックリと竹を割ったように話すから、誰でも快く感じて一見百年の友に接するような心持がした。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらには、テレビの戦争回顧番組で見た、帝国陸軍落下傘部隊の雄姿を伝える日映の日本ニュースでも、歯切れの悪いヴァージョンではあるが、おなじ音楽を聴き、呆然とすることになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、はぎれのいゝ聲を掛けて、水上さんが、格子へ立つた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物をいわれてもはぎれのいい少し高調子の丸みのある声で答え、たたみのけばなんかむしらない人、いろいろな向面に趣味をもって音楽も少しは出来文学の話相手も出来る人、髪でもなんでもさっぱりしていやみのないめずらしい形に結って思いっきり何でもはっきりした娘がすき。",
              "citation": {
                "source": "妙な子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
