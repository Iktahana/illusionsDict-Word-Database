          "literary": [
            {
              "text": "しかもソイツが結局、吾輩タッタ一人の死物狂い的白熱戦になって来たんだから遣り切れない。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身の戦いのごときは、人間同士の戦いのごときは、この巨大な白熱戦の中に消え失せてしまった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん、橋本さんのところ、相変らず白熱戦でございますって」　と富士子さんが取り繕った。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして白熱戦の一瞬がすぎると、だれしも命は惜しく、八ぽうへワッと飛びのく。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
