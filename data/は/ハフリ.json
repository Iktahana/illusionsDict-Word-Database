    "definitions": [
      {
        "index": 1,
        "gloss": "junior Shinto priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汝等祝福されてあるべきなり、其の他はすべて分解しければ。",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あげよ我等の日章旗人みな愁眉をひらくの時わが戰勝を決定してよろしく萬歳を祝ふべし。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは僕にとって、嘆くべきことか祝福すべきことか解らない。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らぬ人が見たら祝いの酒宴とも見えるだろう。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の祝宴か磯辺の水楼に紅燈山形につるして絃歌湧き、沖に上ぐる花火夕闇の空に声なし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の初節句、結婚の披露、還暦の祝い、そういう機会はすべて村のバッカスにささげられる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "久々で国にいるから祝の御萩を食いに帰れとの事であった。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時一人の家来があはたゞしく王の前に参り「たゞ今二人の蘭人がこれに見えて、王に戦勝の祝の品を持つて来たと申して居ます。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キツトその蘭人があれから先づ己の国に帰つて又日本に来る途中で自分の戦勝を聞き、取り敢へず祝の品を持つて来たのだらうと思つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はめいめい先年の絶大な恩を受けたこと、及びこの度の戦勝の祝をくどくどしく申し述べた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "異人種から戦勝の祝のことばを述べられる。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭人はやがて紫の布に包んだ祝の品を恭しく差し出した。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お祝言の時などの島臺の、れいの蓬莱山、尉姥の身邊に鶴と一緒に侍つて、鶴は千年、龜は萬年とか言はれて目出度がられてゐるのは、どうやらこの石龜のやうで、すつぽん、たいまいなどのゐる島臺はあまり見かけられない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神主の祝詞が「聞こし召せと、かしこみ、かしこみ」と途切れ途切れに聞える時には、素朴な板葺のかけ茶屋の前を通って、はや小御岳神社へと詣でるころであった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうして、一日楽しく明治節を祝つた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈凌ぎに飲食することは、前祝いのようで都合が悪かった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征を祝す、の征旗も、旗を取り込んで、てつぺんに葉を少し残した旗竿だけが、淋しく軒先きに立つてゐる。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年になると着なれぬ硬直な羽織はかまを着せられて親類縁者を歴訪させられ、そして彼には全く意味の分らない祝詞の文句をくり返し暗誦させられた事も一つの原因であるらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、かれらが人間から軽侮される生活そのものが、実は人間にとって意外な祝福をもたらす所以になるのである。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の三歳、五歳の祝ひ着は今の芝居のうちかけで見るやうな花蝶総縫ひのちりめんに下着を赤のゑぼしちりめんといふので重ねてありました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は手をその方へ掲げて、彼等を祝福した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで常陸風土記によると一応はこうも事祝いでやった、「人民集賀、飲食富豊、代々無絶、日々弥栄、千秋万歳、遊楽不窮」と。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの大家プランクはこの論文を見て驚いてこの無名の青年に手紙を寄せ、その非凡な着想の成効を祝福した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の説だというのに拠れば、社会の祝福が単に制度をどうしてみたところでそれで永久的に得られるものではない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは何もかも他の言うなりになって、霜月｜半に祝儀をしたけれど、民子の心持がほんとうの承知でないから、向うでもいくらかいや気になり、民子は身持になったが、六月でおりてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで祝詞のことです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ますと、その中に祝詞があったことがわかります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『貞観式』には祝詞はなかったのですから、『延喜式』を作る時に、『弘仁式』にあった祝詞をその中に収めたのではないかと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の片隅には彼が元服祝に貰った鳶色の革函が載っており、これに銭と大事な書類がしまってあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴虫はふり出てなく声のうつくしければ、物ねたみされて齢ひの短かきなめりと点頭かる。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
