    "definitions": [
      {
        "index": 1,
        "gloss": "negative heliotropism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
