    "definitions": [
      {
        "index": 1,
        "gloss": "peeling off (e.g. of paint)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鼻翼の所はおしろいが剥落ちてゐて、一寸突いたらビリビリと破けさうな感じがする。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどなるほど、味噌は巧く板に馴染んでいるから剥落もせず、よい工合に少し焦げて、人の※意を催させる香気を発する。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "反古張りの襖も剥落し尽していた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう風に自分の村の信仰がだんだん剥落して来たので、尼は生活の必要上、かのすすき原を遠く横切って、専ら隣り村の方へ托鉢に出るようになった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐門の剥落した朱の腰羽目に、墨でゴシック風の十字架の落書がしてあった。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノは今目のあたりに見れば、鍵盤の象牙も光沢を失ひ、蓋の漆も剥落してゐた。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに良いと思ふ釉藥を流しかけても、その媒溶劑が適度でなかつたり、又｜胎土が釉藥に親和しなかつたり、火度が適度でなかつたり、窯中に於て器の置き場所が惡かつたりすると、釉と土とが相反撥したり、はぢけたり、釉が剥落したり、完全な釉の發色がない。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旋条がかなり磨滅し、撃鉄や安全環はニッケルが剥落して黒い生地を露し、握りの処のエボナイトの浮彫も、手擦れで磨滅してしまっている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　猪熊のばばに別れると、次郎は、重い心をいだきながら、立本寺の門の石段を、一つずつ数えるように上がって、そのところどころ剥落した朱塗りの丸柱の下へ来て、疲れたように腰をおろした。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "峯々の胡粉の桜剥落に傾く渓の雨の朝かな　これも塩原の朝の小景。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗の乾かぬうちに、シャツと洋服とオーバーを着て、ちょっとの用達しと散歩をして帰るのであるが、途中で湯冷めがして、全身の皮が一枚｜剥落してしまったくらいの寒さを感じたものであった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも眼膜剥落は、法水の推測とは全然異なる経路に於いて、起されたのではないだろうか？",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画舫に身を托してこの水路を進めば、俗塵は剥落して詩趣が湧く。",
              "citation": {
                "source": "北支点描",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "模写で見て居たのと異つて剥落を極めて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて画家よ、彩料にはわが好むパステルを用ひたまへ、剥落と褪色とは恐らく此像の女の運命なるべければ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛はあちこち剥落してゐます。",
              "citation": {
                "source": "匈奴の森など",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "上塗りの壁土は殆んど剥落して、中塗りの赤土や繩が露出し、屋根瓦も満足でなく、ひょろ長い雑草が生えて風にそよいでいる。",
              "citation": {
                "source": "蔵の二階",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも太閤の桃山御殿の一部を移したものとかで、壯麗なる蒔繪の天井や柱が年を經て剥落してゐる。",
              "citation": {
                "source": "湖光島影",
                "author": "琵琶湖めぐり",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでにも何度かこの壁画を見にきたが、いつも金堂のなかが暗い上に、もう何処もかも痛いたしいほど剥落しているので、殆ど何も分からず、ただ「かべのゑのほとけのくにもあれにけるかも」などという歌がおのずから口ずさまれてくるばかりだった。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一層そのひどい剥落のあとをまざまざと見せてはいるが、そこに浮かび出てきた色調の美しいといったらない。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで少年たちは、自分たちの現に見て来た事実が信ぜられないのを、自分たちの信用が剥落したかの如く残念がり、その宣伝を有効ならしめようとあせりつつ、榊新田の陣屋跡までやって来て、陣屋の中をのぞき込みました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、改築したばかりの小学校舎の壁が剥落して彼の辞職の主因をつくってしまった。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "古染付を手にせられた人々は何れもその器の縁又は角々等に虫の喰つた痕のやうに、上釉が剥落して居る事に気がつかれるであらう。",
              "citation": {
                "source": "「明の古染付」観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが又いつの間にか物に触れてポリと剥落するのである。",
              "citation": {
                "source": "「明の古染付」観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し日本で※造する偽物其他の染付などには、態々この剥落の虫食ひをつくる可く苦心を払ふ者さへある。",
              "citation": {
                "source": "「明の古染付」観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁は暗く、柱は煤け、大きな板戸を彩色つた古画の絵具も剥落ちて居た。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "色彩剥落し畫布半破れたれど珍しければ奉納者の名を見るに、「干葉縣下長柄郡□□□□大字五井、片岡□□米國サンフランシスコ在留せんまつ」とあり。",
              "citation": {
                "source": "荷風戰後日歴　第一",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡すと、女の人数だけずらりと並んだ鏡台と鏡台との間からはわづかに漆喰の剥落ちた壁が現れてゐて其面には後から後からと、重つて書き添へられたいたづら書のさま／″＼。",
              "citation": {
                "source": "勲章",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの顔はくらくして地面をばかりみる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、殆ど同時に、私の意識はすうつと拭はれるやうに總身から消え去つて、血潮の赤が限りなく遠くに霞んだかと思ふと、私はくらくらと倒れかかつた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
