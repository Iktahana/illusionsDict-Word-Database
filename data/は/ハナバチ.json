        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭の植物に蜜を吸いにやってくる花蜂は、見ているだけで心が和む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "花蜂が飛び回る音は、夏の午後をさらにのどかに感じさせる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "農家では、受粉のためにたくさんの花蜂が飼育されていると聞いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ゆふやみの花と花とのあひだにこなをまきちらす花蜂のやうにあなたのみづみづしいこゑにぬれまみれて、ねむり心地にあるいてゆくのです。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかの　てっぺんぺんにある　まるはなばちの　すから　かっぱらってきた　ものでした。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と　まるはなばちの　おんなのこが　しゃべります。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるはなばちは　すっきゃない。",
              "citation": {
                "source": "おねずみおばさんのはなし",
                "author": "THE TALE OF MRS. TITTLEMOUSE",
                "note": "青空文庫"
              }
            }
          ]
        }
