    "definitions": [
      {
        "index": 1,
        "gloss": "to fit (e.g. a pane into a frame)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし入れ歯は吐き出して捨てるわけに行かないから引っ込ませてはめ込む。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味で現実の断片を、そのまま舞台にはめ込むのは芸術上の大錯誤である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は決心さえすればどんな境遇にでも自分をはめ込む事ぐらいできる女だ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上は死に対して最上の態度を取る為めに、お前たちに最大の愛を遺すために、私を加減なしに理解する為めに、私は母上を病魔から救う為めに、自分に迫る運命を男らしく肩に担い上げるために、お前たちは不思議な運命から自分を解放するために、身にふさわない境遇の中に自分をはめ込むために、闘った。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人ユーザーにとって、処理速度を高めたマシンの本体だけを買ってきて従来のシステムにはめ込むことができれば、新しい機種への移行の敷居はずいぶん低くなる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたいてい赤貝の類の貝殼を刳り拔き、その周圍ばかりを殘して前腕にはめ込むでのでありまして、石器時代の墓場から出る人骨に、この貝輪がそのまゝ腕骨にはまつてゐるのをたび／＼發見されました。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私共が、その貝輪をとつて前腕にはめようとすると容易にはまりませんが、これは今日でも南洋あたりにあるように、うまく氣合でもつて手にはめ込む專門家があつたかと思はれます。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の一番デリケートな部分を停車中にさせるやうにはめ込む）　スミ「そいで、あんた、どうすんの？",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろはにはその屋内装飾――つまり客間用に――その壁面へ持つていつて数多くの大きな鏡をはめ込むと共に、柱々には、一々細長い、ゴツゴツ紫檀わくのついた、小形のいはゆる「姿見」を懸け連ねてあつた。",
              "citation": {
                "source": "「いろは」の五色ガラスについて",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、懷中煙草入はこの蓋の下にあつたと言つたな」「へエ、――二人掛りで引つ張り出すのが精一杯でしたよ」「そいつを一人ではめ込む工夫があるんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "彌惣の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "その珠をことんとはめ込むように石が彫ってあった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、懐中煙草入はこの蓋の下にあったと言ったな」「ヘエ、――二人掛りで引っ張り出すのが精いっぱいでしたよ」「そいつを一人ではめ込む工夫があるんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "弥惣の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、翌日は早速町の飾り屋へ行って、レコードをはめ込む鉄板のワクを作らせました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "音盤の詭計",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の両側には、徒渉場にさしかかろうという場所に、深い縦溝を掘った石柱があり、大水の時には水が道路を洗い流すのを防ぐ可く、これ等の溝に板をはめ込む。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし丹尾の風貌を、うまくそこにはめ込むことが出来なかった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏返された画面、おそらく向こう側に書きなぐってある額面か、あるいは壁から取りはずされてそのままはめ込むのが忘られた姿鏡のようでもあった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の眼鏡のように、ふたつのレンズがあるサングラスではなく、フレームの溝にシールドをはめ込むタイプのサングラス。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が頻用したのは詩を音楽にはめ込む方法だった。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロレンコは「人生は無数の妙にからんだゆがんだもので合わさっていて」、「それを理論的組立ての四角い中にはめこむことは困難である」と話し、ゴーリキイもそれはそう考えた。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はその中に、生きた、困難な、気儘で柔軟なロシア語をどうしてもはめこむことが出来なかった。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はその中に、生きた、困難な、気儘で柔軟なロシア語をどうしてもはめこむことが出来なかった」と。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "組織の決定的な部分に古い官僚をはめこむことに成功している。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "象徴詩はもと実体がないのであるから、読む者が自由に好きなものを空想してはめこむが宜しい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな工合で、僕がまあ代りに行くことになって、顎骨の脱臼をはめこむ仕方をいろいろ教わって、作男に案内されて出かけました。",
              "citation": {
                "source": "舞踏病",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、顎の骨をはめこむことは何でもないが、ひどい危険が伴う、うっかりしてると指を食い切られる、とそう先生におどかされたものですから、僕は途々心配でたまらなくなりました。",
              "citation": {
                "source": "舞踏病",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう話してしまえば笑い話ですが、その時は実際、外れたの骨をはめこむことしか教わっていなかったものですからね。",
              "citation": {
                "source": "舞踏病",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（前と同じやうな姿勢で挑みかゝらうとする）校長　　（軽く、それを受けとめて、腰をひねりながら）かうやつて、相手のキヽ腕をとつたら、この膝をずらして、相手の腰へ十分こつちの腰をはめこむ。",
              "citation": {
                "source": "道遠からん　四幕",
                "author": "――または　海女の女王はかうして選ばれた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその複雑性は、直観をはめこむ知識の框が一層複雑になるというに過ぎぬ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの本性の弱さからして、われわれは一つの場合を想像しわれわれをそのなかにはめこむ。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが支店長代理は、活溌な、ただ精神上活動的な人間にしばしばあることだが、この手工じみた仕事に夢中になってしまい、ついに手すりの一部は実際引上げられ、今度はその小さな柱をまた適当な穴にはめこむことが問題であった。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
