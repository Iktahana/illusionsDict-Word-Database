[
  {
    "uuid": "d67b5c9d-e001-56bf-aa73-37ab96412117",
    "entry": "恥をさらす",
    "reading": {
      "primary": "はじをさらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-サ行"
      ],
