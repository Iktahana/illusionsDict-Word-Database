[
  {
    "uuid": "8914e014-83ab-59a5-994b-d39149175e5f",
    "entry": "敗退",
    "reading": {
      "primary": "はいたい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being defeated",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほどなく、きゃんきゃん悲鳴を挙げて敗退した。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ここで敗退しては、色男としての名誉にかかわる。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけで手も足も出ないまま三―〇のストレートで敗退した。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇奮猛烈の軍隊の氣は黒み、薄弱にして敗退せんとする軍隊の氣は白けるといふが如きことは、今遽に某の書の某の章に出づといふことを擧ぐる能はずと雖も、蓋し何人も記憶して居ることであらう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその刀折れ矢尽きて現社会から敗退して行った翁の末路を見てホッとした連中が「それ見ろ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘中三河守は、大聖院へひき上げたが、大元方面へ退いた味方の軍の形勢を見て、折あらば敵を横撃せんと、機会を覘っていたが、大元竜ヶ馬場方面も脆く敗退した為、大元と大聖院との間の竜ヶ馬場と称する山上へ登り、此処を最後の戦場として父子主従たった三人になる迄吉川軍と決戦して遂に倒れてしまった。",
              "citation": {
                "source": "厳島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長直ちに使をやって誡めようとしたが時既に遅く、両軍敗退の最中であった。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "於平壌行長敗退之事　日本軍襲撃の報を、朝鮮の政府が明第十三代の皇帝｜神宗に逸早くも告げた事は前に述べたが如くである。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時九州には、先に建武の中興に忠死した菊池武時の子武敏があり、少弐貞経を誅し、勢威を振つてゐたので、尊氏を迎へ撃つて、博多の東方なる多々良浜で激戦したが、時利あらず、敗退したため尊氏の勢力は、九州一円を風靡し、九州の将士争うて之に属した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇猛果敢な軍隊の気は黒み、薄弱にして敗退しようとする軍隊の気は白けるというようなことは、いま急に某の書の某の章に出ていると挙げられないけれどさぞかし何人も記憶していることだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、僕の敗退の巻らしい。",
              "citation": {
                "source": "名士訪問記",
                "author": "――佐野昌一氏訪問記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月五日には独軍は早くもソンムの強行渡河に成功、仏国の抵抗意志は急速に低下して到るところ敗退、六月十四日独軍パリに入城、六月二十五日休戦成立した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "普軍は戦力全く消耗して対応の策なく遂に敗退しブリュッヘルは危うく捕虜とならんとして僅かに逃るる事が出来た。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、道徳の敗退も一所に来てゐる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘘で塗り固めた権力と表面の統一のもとに国内生活は恐ろしい破綻を孕み、戦局は一刻一刻と敗退の途を辿りながら昭和二十年の夏が来たのであった。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　それならば一九四九年という年は、福田恆存の概括にしたがって「知識階級の敗退」の年であったのだろうか。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が間も無く彼女は敗退して、私の方へ帰って来た。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "パートナーは無く、一人が三つしくじれば敗退するのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四五年八月が来てその土地の憲兵隊が敗退してひきあげるとき彼等は郁達夫に日本語がわかり、彼等の侵略行動の目撃者、戦犯の証人であるということを恐怖した。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーズヴェルト当選予測を示して、調査の正確さで進出したギャラップ博士の世論調査所が、つづく大戦中、半官的な米国世論調査所と発展し、この一九四八年の大統領選挙でデューイとともに敗退した。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ人民が、理不尽な暴力で導きこまれた肉体と精神との殺戮が、旧支配力の敗退によって終りを告げ、ようやく自分たち人間としての意識をとりもどし、やっとわが声でものをいうことができる世の中になったことをよろこばない者がどこにあろう。",
              "citation": {
                "source": "歌声よ、おこれ",
                "author": "――新日本文学会の由来――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が欧洲大戦に本気に参加せず、東部戦線に於ける露国の敗退を救うべく、英国から再三の慫慂を受けたのにも応じなかったのは、偏えに背後の米国を警戒して不足勝ちな石油を蓄積したいためと伝えられておりますが、このために日本民族の実力が欧米各国から如何に軽視される立場に陥って来ましたことか。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機万能の現代では、航空機の前に未踏地はなし――とまでいわれるのに、なぜ悪魔の尿溜だけには敗退したか？",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機万能の現代では、航空機の前に未踏地はなし――とまでいわれるのに、なぜ｜悪魔の尿溜だけには敗退したか？",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "互に妨害し合いまた進出し合っているらしいが、或る処で偶然聞いた重慶からの放送には、盛んに日本軍敗退のデマが飛ばされ損害其他詳しい説明までなされていた。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "北フランスでどんどんと追いはらわれてゆくナチス軍の敗退の足どりがしるされた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗退と決定したあとに、衰亡の途が黒い口をあけて待っていたのである。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、第一岬要塞の戦闘がすんで、アカグマ国軍が敗退したとき要塞の上高く掲げられた敵軍の旗と同じマークのものであった。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この時の衰耄に近づいた子分は、今国越えをせなければならぬ親分の心の寂寥――謂はゞ人世に「敗退」といふことのあるを思ひもせなかつた壮年無頼の漢子の、未だ深く意識せぬ憂愁を、象徴すると謂つた役であつた。",
              "citation": {
                "source": "実川延若讃",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "京弥は言うまでもないこと、妹菊路のろうばいはいたいたしい位でした。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
