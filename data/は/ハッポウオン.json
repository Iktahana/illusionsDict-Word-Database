          "literary": [
            {
              "text": "こうして我々は船長室に突進したが、戸を押し開けたとき、なかから発砲音が聞こえてきた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "再びくぐもったマスケット銃の発砲音が起こり、深い叫び声が聞こえた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時パンパンという発砲音が聞こえ、銃弾がパッパッと家屋の木材に当たった。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
