    "definitions": [
      {
        "index": 1,
        "gloss": "hedgehog (any mammal of family Erinaceidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
