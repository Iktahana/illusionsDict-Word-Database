    "definitions": [
      {
        "index": 1,
        "gloss": "to rebound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あそごの水の跳ね返る処よ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の跳ね返るような歩調は、決して衰えなかったが、私から百｜碼ばかりも先んじて行った彼は、ふと立ち止まった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　虐げられたる女性全体の、反抗の化身であるように、夫人の態度は、跳ね返る竹の如き鋭さを持っていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　虐げられたる女性全体の、反抗の化身であるやうに、夫人の態度は、跳ね返る竹の如き鋭さを持つてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "墜落する物音、唸り声、石に衝って跳ね返る弾丸の律動と一緒に、戸が白い粉を噴きながら、見る間に穴を開けていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時彼の眼は跳ね返るやうに外れ彼の心は急に暗くなつた。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "紐をゆるめて跳ね返るまでには、半分は本気で半分は笑談のような無言の争闘がしばらく続いたが、起きあがってみると、ぐったりとした吭笛のところは、手でさわったり唾を呑みこんだりするたびに、腫物のような軽い痛みを感じた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は獲得する生活が好きだね」　と彼はピンピン跳ね返る鯛を始末しながら言った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面と同一の高さにある階下の床は歩くたびに釘のとれた床板が跳ね返る。",
              "citation": {
                "source": "飢ゑ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "円鈕を前に押しながら、開く戸に身を任せて、音なき両足を寄木の床に落した時、釘舌のかちゃりと跳ね返る音がする。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾丸の跳ね返る恐れは少しもなかった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "がたがた馬車が、跳ね返る小馬に牽かれて駆けて往く。",
              "citation": {
                "source": "糸くず",
                "author": "LA FICELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう雪が薄くなっていれば人の跫音にも均衡は破れて、木はひどい勢で跳ね返る。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖徒に向って鞭を加えたる非の恐しきは、鞭てるものの身に跳ね返る罰なきに、自らとその非を悔いたればなり。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "屈竟の手懸りに、砕けよとばかり尾を啣えながら左右にふると、尾のみは前歯の間に残って胴体は古新聞で張った壁に当って、揚板の上に跳ね返る。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "立上がって戸口の方へ探り寄ろうとすると、床板の釘が抜けていたものか、それとも、陥穽の仕掛になっていたものか、足の下の板が一枚、パッと跳ね返ると、「あッ」　新三郎の身体は、数十尺の下へ、支えるものもなく落ちて行きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "立上がつて戸口の方へ探り寄らうとすると、床板の釘が拔けて居たものか、それとも、陷穽の仕掛になつてゐたものか、足の下の板が一枚、パツと跳ね返ると、「あツ」　新三郎の身體は、數十尺の下へ、支へるものもなく落ちて行きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "復讐鬼の姿",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がいつも東京に在って思いを関西の空に馳せる時、第一に念頭に浮かぶのは蘆屋の家のことであるのは云う迄もないが、何処か頭の隅の方に、折々は此処の店の様子や、親爺の風貌や、彼の庖丁の下で威勢よく跳ね返る明石鯛や車海老のピチピチした姿も浮かんだ。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "降る雨は歩道から跳ね返る雨といっしょになって、ミヨコの短いスカートの裾のすぐ下あたりまで、常に届いていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車のかたわらを歩いていくとき、車体から跳ね返る雨は彼女のミニ・スカートの腰から半袖シャツの袖口まで、存分に濡らした。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "若気の至りとか、後で跳ね返るとか。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "光って木がはねかえる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牙にあたればはねかえる。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "残った枝の強くはねかえる勢いで、となりの枝も強く揺れて、髑髏はからからからからと続けて高く笑った。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかしそれに応えるものとては並び建つ校舎からはねかえる反響のほかになんにもなかった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが目が近いのでいっぺんにつかまってしまう事を思うと、ふいとおかしくなってしまって、冷たい壁に私の嗤いがはねかえる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが目が近いのでいっぺんにつかまってしまう事を思うと、ふいとおかしくなって、冷い壁にカラカラと私の笑いがはねかえる。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の足で踏みつけた草の茎や葉は、見るまにぴんとはねかえる。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁にあたってはねかえるのがある。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さむいけれど、空気は、音のはねかえるほど澄んで、さえきっていました。",
              "citation": {
                "source": "戦争はぼくをおとなにした",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
