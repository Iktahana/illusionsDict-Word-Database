          "literary": [
            {
              "text": "それを間もなく照り出した日の光りに透かしてみると、半乾きのハンカチの繊維が皆、真白に輝いて見えた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥の半乾きになった道を、近藤と、土方とが、結城兵二三を連れて、防禦陣地の選定に廻った。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝古河を立つて、北千住で汽車を下り、途中浸水の迹を見ながら来たと云ふお話、急に二三枚畳を半乾きの床上に竝べてこの良客を迎へた。",
              "citation": {
                "source": "臨終の田中正造",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            }
          ]
