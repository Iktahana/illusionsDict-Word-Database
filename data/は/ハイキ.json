[
  {
    "uuid": "7ba112e6-7793-53d8-a1c8-18af7521207d",
    "entry": "廃棄",
    "reading": {
      "primary": "はいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
