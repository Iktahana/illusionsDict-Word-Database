    },
    "definitions": [
      {
        "index": 1,
        "gloss": "disposal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "詩は公衆から顧みられず、文壇は詩を犬小舎の隅に廃棄してしまつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、プロレタリアートと戦争　　　　　　一　プロレタリアートは、社会主義の勝利による階級社会の廃棄がなければ、戦争は到底なくならないということを理解する。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステッキなど持って歩くと、犬のほうで威嚇の武器と勘ちがいして、反抗心を起すようなことがあってはならぬから、ステッキは永遠に廃棄することにした。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスがその「宣言」にいっているように、従来現存していたところの人々間の美しい精神的交渉は、漸次に廃棄されて、精神を除外した単なる物的交渉によっておきかえられるに至った。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの象徴派の詩人にして、欧洲に於ける自由詩の開祖と目されるヴェルハーレンすらが、後には自由詩を廃棄して、最も形式的なる押韻詩の作家になったのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればかかる社会に於て、古典韻文の如き形式主義の文学が、流行の外に廃棄されるのは当然である、特に就中、叙事詩の如き貴族趣味に属するものは、時代の来る先鋒に於て死刑にされる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、吾人のあまりに日本人的なレアリズムやデモクラシイやを、断然として廃棄してしまうのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の考を徹底させれば、俺の従来の作品の凡てを廃棄しなければならなくなるのではないか。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切は、幸福への意志の廃棄と共に、始まるのだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "造り物と小道具　これは能の舞台面に用いる家とか舟とか、樹木とか、又は演出を補助する糸車、鏡、桶、釣竿、なぞいうものであるが、これも初めはかなり写実的なもので種類も沢山あったのを、次第に単純化されたり、廃棄されたりして来た形跡がある。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂には廃棄せられて、毀れてしまう。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一六八五年にルイ十四世によってナント勅令が廃棄され、新教が禁止されると、多くの新教徒がアメリカの植民地に移住した。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "古人の書画等に対してもまたそうであり、故紙や書物の断片の将に廃棄するところを救い、これを新装し再生するようなことは助長であり、心無く埃まみれに放置し、鼠や虫の害に遭わせたり，濡らしたり焼け焦げを作ったりするようなことは剋殺である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内には自分がまさに言わんとする事どもを少なからず説かれおり、ために大きな番狂わせを吃い、何とも致し方なくて、折角成り懸かった原稿を廃棄し、更に谷本君の文中に見ぬ事のみを論ずるとして再度材料蒐集より掛かったに因る。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、自然的条件が、文学の変遷を決定する唯一の原因であるとするならば、原因は殆んど変らないのに結果だけが目まぐるしく変つてゐるといふことになり、因果の原理は廃棄されねばならぬことになる。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "日英同盟廃棄数年後になっても日本人は英国が日英同盟の好誼を忘れた事を批難し、つい最近まで第一次欧州大戦に於ける日本の協力を思い出させようとしているのに対し、あるドイツ人が「日本は離婚した女に未練を持っている有様だ」と冷笑した事があった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジイドの「芸術的な無道徳主義は」、「ニイチェの『危険な生き方』とドストイェフスキーの英雄的な道徳廃棄論との巧緻な結合であり、しかも以上の二人の天才の倫理的熱情を全く欠いているジイドは」単に「感覚の玄人」として、世界観の飛躍を試みたに過なかった。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「労働者階級は単に出来合の国家機関を占領して、それを自分自身の目的のために運転することは出来ぬ」（マルクス）プロレタリアートは自身の新しい国家機関を組織するためには、旧い国家権力を解体し、粉砕し、それを全く廃棄しなければならぬ。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が現実の国民生活安定の代用品として勧められている所以が之であり、又之が国民生活安定という設題自身の廃棄になると私かに考えられている所以でもある。",
              "citation": {
                "source": "挙国一致体制と国民生活",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際前にも一度そんな話があったけれど、条件が折合わないで廃棄されたんだ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "びつしよりぬれてゆくところがない・風の建物の入口が見つからない　どうやら霽れてくれさうな草の花　春雨の放送塔が高い・移りきて無花果も芽ぶいてきた（惣三居）廃棄工場（発電所）、そこにはデカダン的で男性的なものがあつた、なか／＼句にならない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "己はいつもなるべくそれと方向を殊にしている策を認容するのであるが、こん度はためしにどれをも廃棄して、「きょうは僕は内で本を読むのだ」と云って見た。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に日本が彼の日英同盟を廃棄し、新嘉坡と濠洲海軍の脅威を覚悟しつつ日仏の秘密協商の成立に焦慮しているのは何のためでもない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者が学問をもって畢生の業と覚悟したるうえは、自身に政治の思想はもとより養うべきも、政壇青雲の志は断じて廃棄せざるべからず。",
              "citation": {
                "source": "学問の独立",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはいまだ西洋の事情につきその一斑をも知らざる者にても、ひたすら旧物を廃棄してただ新をこれ求むるもののごとし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私はこれがために婦人の持っている優しい慈善心を抑制し、かつその慈善行為を廃棄せよというのではありません。",
              "citation": {
                "source": "食糧騒動について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけをみて、ぼくはくるりと引っ返し、競争を廃棄しました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄が耕二の間の障子を開けると、「負けちやつた」と耕二はいきなりそれだけ言つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとジョバンニはいきなりさっきカムパネルラといっしょだったマルソ〔に〕会ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　油断をしているうちに、達二はいきなり山男に足を捉まいて倒されました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
