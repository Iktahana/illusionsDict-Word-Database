        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吐き気がついてからえづきをした。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐き気をもよおして来た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、苦しい息の下から一ことそう言うのさえやっとで、何か冗談を言おうと思っても、すぐ吐きそうになり、黙って這うようにして衣服を取りまとめ、スズメに手伝わせて、どうやら身なりを整え、絶えず吐き気とたたかいながら、つまずき、よろめき、日本橋の待合「さくら」を出た。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端にげっと吐き気を催した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "警部によれば、ものすごく汚いらしく、顔じゅう汚れきっているのだが、それでもその吐き気のする醜さを隠せていないという。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男がうちの女中に見せる態度といったら、好き勝手でなれなれしく、吐き気がするほどです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしも二〇年刑事やってますが、さすがにあれには吐き気がしましたよ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山杖を目にした私は、悪寒と吐き気に襲われた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時俺たちは極度の貧乏をしてゐたのだが、彼女は不経済にも喰べた物を片つ端しから盛んに吐きだした、そして吐き気が二ヶ月もつゞいたのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠ざかりながら人の声とも獣の声とも知れぬ音響がかすかに耳に残って、胸の所にさし込んで来る痛みを吐き気のように感じた次の瞬間には、葉子は昏々として熱も光も声もない物すさまじい暗黒の中にまっさかさまに浸って行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋本、あいつをとめろ、舎監のとこへいく気だ」　ここで舎監がくるようなことになったら、絶対に助からないと、慶一は吐き気を感じた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐き気が起こるからな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた吐き気を催し、ぐったりとしていた。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐き気に耐えてＹＳ―11で繰り返しジャストシステムを訪ねた間宮は、浮川初子と福良伴昭の傑出したプログラマーとしての能力に鮮烈な印象を受け続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前に出された美味な御馳走に咽喉が鳴っても、一口二口食べるともう吐き気をもよおして来てコーヒーと水ばかりを飲んだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢代はこの気流に打たれると、いつも吐き気をもよおして横を向き急いでその前を横切るのである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊庭の猛々しい態度に吐き気が来た。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慣れない内は、その臭気を嗅ぐと、誰でもすぐに、吐き気を催した。",
              "citation": {
                "source": "虱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い吐き気も来ないようですから」Ｓさんは母に答えながら、満足そうに手を洗っていた。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御息女のお小やすみの部屋に、わしが案内をして取らせましょう」　江戸で、物産問屋としては、兎に角、指を折られるまでに、立身をしている身で、自分から淫ずら事の手引きをしようとする、この三郎兵衛の態度に、雪之丞は堪えがたいいまわしさを覚えて、ほとんど吐き気すら感じて来るのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨が挽かれるような苦しみ、恐ろしい吐き気、生まれる時か死ぬ時よりもつよい精神の恐怖。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の前には女と男が一本づゝくれた二本の酒があるのだが、私はもはや吐き気を催して実際は酒の匂ひもかぎたくなかつた。",
              "citation": {
                "source": "いづこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議に思って、自分がまず肉の一切を箸につまんで口に入れた途端、胸腑に悪臭が渦まき起こり、むっと吐き気を催したとある。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムカムカッと吐き気を催すわよ。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の前には女と男が一本ずつくれた二本の酒があるのだが、私はもはや吐き気を催して実際は酒の匂いもかぎたくなかった。",
              "citation": {
                "source": "いずこへ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中の寒気にふるえ、絶え間なく流れでる洟汁と、こみあげる吐き気に苦しんだ。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都へついた私は、まったく船酔いに似て、寒気と吐き気に苦悶し、半死半生のていであった。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "胃へ流れこむまゝにすると、忽ち吐き気を催し、終日吐き気に苦しんで、思考する時間もなく、仕事に注意を集中し持続するということが全く不可能となるのであった。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "口がきけないのに」「うん、たしかに、口はきけないね」と、学生さんは答えました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とはきけなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
