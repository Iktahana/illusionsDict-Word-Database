        "examples": {
          "standard": [
            {
              "text": "悪霊に取り憑かれたという話を聞き、有名な祓い師に助けを求めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その祓い師は、古くからの伝統的な方法で悪霊を祓う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画に登場する祓い師は、常に冷静沈着で頼りになる存在だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "富士男は草をはらいはらいして、なかをのぞいてみると、そこにうす暗い洞穴の入り口を見た。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、火がきえてるのも、ススはらいします。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            }
          ]
        }
