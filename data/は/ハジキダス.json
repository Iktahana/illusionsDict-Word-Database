    "definitions": [
      {
        "index": 1,
        "gloss": "to flick out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "巨大都市に仕組まれた底なしのスプレッド・シートがはじき出すものは、足し引きゼロの収支勘定だけだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いなしかその爪音は、人の涙をはじき出すように哀れに顫えていた。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにもつよい近代武器の鋼鉄バネが当ったらあやまたず命につきささる鋭い決然とした弾丸をはじき出すような音である。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎やん、　夜、床が体をはじき出すように苦しく、おきたりねたりかがんだりさまざま九月二十八日　木曜　思ったより早くよくならない。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかに、「日本は欧州人をはじき出す」という意味の言葉があり、自分は面白いと思った。",
              "citation": {
                "source": "モスクワ印象記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湿りけをぱちぱちとはじきだすのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは他人には、ぼくをはじきだす幸福な壁のほかは、なにひとつ見たくはなかったのだ。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの半六はだめな男だ」斎宮はふところ紙で眼を拭き口のまわりを拭いた、「おまえさんは殻に傷のついた卵を孵そうとしている、ばかなめんどりのようなものだ、半六なんぞは巣からはじきだすがいい」　それから、なんの用だ、と云わんばかりな表情で、功兵衛を見た。",
              "citation": {
                "source": "醜聞",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
