    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crushing (into pieces)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私の恋人は破砕器へ石を入れることを仕事にしていました。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに明治年間ある知事の時代に、たぶん机の上の学問しか知らないいわゆる技師の建言によってであろう、この礁が汽船の出入りの邪魔になると言ってダイナマイトで破砕されてしまった。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲の音やガス容器の爆発の音などとは全くちがった種類の音で、しいて似よった音をさがせば、「はっぱ」すなわちダイナマイトで岩山を破砕する音がそれである。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども想像的鬼神の輸入あると共に一方に於ては、万葉時代に行はれたる単純なる、「自然力」に対する恐怖を、其心外無法の斧を以て破砕したり。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、既成政治家の張り廻らした奸悪な組織や習慣を一つ一つ破砕して行くことは、子路に、今まで知らなかった一種の生甲斐を感じさせる。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭蓋骨が少し破砕されたのであるが、べつにさし迫った危険もなかった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれどもこの小児的の感念は遠からずして破砕せられたり、余は基督教会は善人のみの巣窟にあらざるを悟らざるを得ざるに至れり、余は教会内においても気を許すべからざるを知るに至れり、しかのみならず余の最も秘蔵の意見も、高潔の思想も、勇壮の行績も、余をして基督教会に嫌悪せしむるに至れり。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の歯は物を咬み咬み之を破砕して物の分子の間に君の唾液を混入して嚥下と消化を容易にするだろう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂気は散る気・凝る気・悖る気・暴ぶる気・沈む気・浮く気等あらゆる悪気が入り乱れ膨らみ、時と境の二圏の輪郭を破砕して発生するものであるが、その気は一切の悪気の最たるものであるから、甚だ稀ではあるが伝染・感染の作用をする場合がある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一貫の趣旨、もとは不可解でも難解でも無いものを、何となく仏教徒の開悟一番の古則公案のように取り上げて来た俗な傾向や、幽旨玄味で測り知り難いものでもあるかのような観方を破砕したことは、真に全氏の正義である。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　小宮山明敏氏の公式の破砕　私の批判者のうちで、最も愛嬌に富んだものゝ一人は小宮山明敏氏である。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその刹那に氏の脆弱な公式は粉微塵に破砕してしまつたのである。",
              "citation": {
                "source": "諸家の芸術価値理論の批判",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この破砕に当って疑いもなく猛烈な火山噴出が起りその結果として、当時太陽は既に消燼していてもそれにかかわらず、砕けた破片は一時灼熱状態に達するであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても破砕された遊星は隕石塵のように静かに太陽に落下するので、そのために太陽の物理的状態に著しい変化を生じるようなことはないであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの光景を破砕して幾多の俳句と為さば為し得べきも、一部の光景はその地全体の特色を帯びざるが故に、世人は承知せざるなり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "純一はこう思うと同時に、この娘を或る破砕し易い物、こわれ物、危殆なる物として、これに保護を加えなくてはならないように感じた。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、結婚と生児の制限率に関する研究をやつてゐるんだが確かに博士論文位の価値はあるものだよ、純正社会主義の実現を基礎づけあらゆる反対を根本的に破砕するものなんだ。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｘ号よ、おまえの野望もこれで完全に破砕されたぞ。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい私の恋愛論を破砕する人があろうとも、それは私の恋愛の価値とは没交渉なことである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、この店の前、歩道と車道とに跨って、道路修理のため、細かく破砕した小砂利が積んであった。",
              "citation": {
                "source": "庶民生活",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "個人の破砕、このことは世界観にとっては、危機となったのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この欧州大戦後、すなわち一九一八年以後、機関銃の音が耳の底に残っている人が成年になり老年となって、戦いの苦しみを知らない少年が青年となってきた一九三三年頃の文化は、破砕され傷ついた個人と、もっと巨大になったまた傷つきもした集団機構との新しい絶えざる闘いの連続であったのである。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "破砕せる巨大なる個人の記録である。",
              "citation": {
                "source": "レンズとフィルム",
                "author": "――それも一つの性格である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し彼らに強大な機械力があるとすれば、われわれが用ふべきものは、その機械力を破砕するに足る霊妙な智能の働きぢやありませんか？",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの近傍において地質の急に変革したところもある、すなわちその北方｜犀川筋の地方はおもに破砕した翠増岩石から成り立っていて、そしてその南方木曾川の谷は数マイルの間おもに大口火性石の谷側に連なるのを見るし、また、河底は一面に大きな塊の丸石でおおわれていると言ってある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂は幸いに外形無事だが、中の半丈六薬師如来ならびに両脇侍菩薩の木像は須弥壇から投げ出されて、勿体なくも無残に破砕している。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲鳴、叱呼、絶叫、怒罵と、衝突、破砕、弾ける響、災の吼る音。",
              "citation": {
                "source": "越後獅子",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはさいかちの木の下にいてそれを見ていました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はさいきん、少しからだの調子を悪くして、神妙にしばらく酒から遠ざかっていたのであるが、ふと、それも馬鹿らしくなって、家の者に言いつけ、お酒をお燗させ、小さい盃でチビチビ二合くらい飲んでみた。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝はさいしよの光が東の山の峰の上から、さつと流れ、木や家や墓石にやはらかく触れました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
