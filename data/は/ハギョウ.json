[
  {
    "uuid": "512c1fa6-9ff0-5465-bf6d-b8ed97f86402",
    "entry": "は行",
    "reading": {
      "primary": "はぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
