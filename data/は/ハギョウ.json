      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the \"ha\" column of the Japanese syllabary table (ha, hi, fu, he, ho)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ、いま新らしき遊戲は行はれ遠望の海さんさんたるにわれ諸君とゆびさし眺望してながく塔下に演説す。",
              "citation": {
                "source": "交歡記誌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅上萩原朔太郎けぶれる空に麥ながれ、麥ながれ、うれひをのせて汽車は行く。",
              "citation": {
                "source": "旅上",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たづきも知らに、わが喰むむぎの蒼さより、あはれはるばる、み空をながれ汽車は行く。",
              "citation": {
                "source": "旅上",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰しも全然固定観念を抱かないわけには行かぬ。",
              "citation": {
                "source": "宮沢賢治の世界",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れて行くところまでは行ってみる」口を曲げて苦しそうに笑った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば、世界は行為を滅却したのだ。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウソついて日大に行つてるとて実は行つてなかつたのが母に知れる。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それやあ、おまへは自分を標準にするからのことだけれど、耕二はさうは行かん。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　即ち彼は行為の前の義務――認識――の上で実に目覚ましい詩人なのだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だつて此の人は行き方がちがふんぢやないの」　Ｓ子が従兄に言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがどんなに悲しむべきことであるかは、知る人ぞ知る、とても悲し過ぎて、今茲で簡単にその証明をするわけには行かぬ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ幸ひにネタが少ないから仕事が少ないとばかりは行かないので、ネタがないことがまたネタともなるので、尤もその場合扱ひ馴れないネタには一寸まごつくのであるが、ジイドの時代はまことにさうしたまごつきの時代であつた。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "巷に秋の夕日散り鋪道に車馬は行き交へどもわが人生は有りや無しや。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なぐれ』『たため』『しめろ』雜然たる叫聲の中、殺氣は既に滿ち渡つて、氣早の若者は行成横合から飛び出して、思ひ切り芳の天窓を擲つた、續いて何處よりともなく、拳の雨は彼の頭上に降り注いだのである。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校ではわりに成績のよかった自分が、学校ではいつもびりに近かった亀さんを尊敬しない訳には行かなかった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう、さう、」と狸は、自分でも何を言つてゐるのか、わからなくなり、「まつたく世の中は、これでなかなか複雜なものだからねえ、そんなに一概には行かないよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前にも忠告して置きますがね、あの山へだけは行つちやいけないぜ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに、うまくは行きませぬて。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川楊の大木が、嵐にも洪水にも抵抗し抜いて、力も何も尽き果てたというように、ぐったりと根こそぎに、岸から川の中へ打ち倒れているのを、橋代りにして渡ったが、向う岸に着くまでには、三度ばかり冷たい水の徒渉をしないわけには行かなかった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "がそれは必ずしも、好きであるからではない、位置が南に偏り過ぎて、雪が早く融けるし、氷河は小ッぽけな塊に過ぎないし、富士山のように、新火山岩で、砂礫や岩石が崩れ易いので、高山植物は稀薄であるし、「好き」になるところまでは行かないが、それでも、最も多く心を惹かれる山である。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「井戸から水が出ない」　と借家人が云ふと、「お天陽様のやる事は、家主が責任を負ふ訳には行かない」　と、この家主の老人は、舌さへ動かし惜しみつゝ答へる。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ俺は行こうってんだ」　樫の盆見たいな顔を持った、セコンドメイトは、私と並んで、少し後れようと試みながら歩いていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、家族のものは、泣きながら食卓の前に坐らされている、腹の空いた子供のような気持を、抱かない訳には行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族の者とても、取調べを受けない訳には行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんな調子だと、善良な人民を監獄に入れて、罪人共を外に出さなけりゃ、取締りの法がつかない」と、「天神様」たちは思わない訳には行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、都合によると、こりゃ危いかも知れねえぞ）　だが、彼はそこでへまを踏むわけには行かなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年も、殆んど毎日のように、導火線に火を移す彼等であっても、その合図を待つ時には緊張しない訳には行かなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは「死」を売り物にする訳には行かなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "春秋の筆法が今は行はれないのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "颱風災害防止研究機関の設立は喜ぶべき事であるが、もしも設立者の要求に科学的な理解が伴っていないとすると研究を引受ける方の学者達は後日大変な迷惑をすることになりはしないかという取越苦労を感じないわけには行かないようである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
