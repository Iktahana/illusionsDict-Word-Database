        "examples": {
          "standard": [
            {
              "text": "夕食に、パリパリに揚がった「春巻き」を注文した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「春巻き」の具材には、野菜やお肉がたっぷり入っていて栄養満点だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "熱々の「春巻き」を口に入れると、中の餡がとろりと溶け出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
