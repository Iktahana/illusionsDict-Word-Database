    "definitions": [
      {
        "index": 1,
        "gloss": "to start",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その夜我々は新しく始める同人雑誌の相談で、同人二十人ばかりで其処へ集つてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨今後その中の若干なり未知の人なりが点睛を示し始める時、詩壇ははじめて面白くなるのであらうと私は思つてゐる。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでＢは文学談を始めるとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝負事でも始めるか酒でも飲むしか仕方はない。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて再び、ＡはＢを気の毒がりさへし始めるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかオイ……」と突然三田村はその重さうな頭をハネ上げて続きを始めるのだつた、「俺がついててやるから安心しいろい」「うん、うん」と私は相変らず吊り込まれて承知するのだつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（書き始める）女　まあ奇麗な字を書くわねえ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（男、手帖に何か書き始める。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、大臣になつてゐる自分の幼な友達だつた男の逸話を祖母は始めるのであつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その、呑気さうな言葉付が彼女には歯痒かつたが、その社長が、自分を可なり大事な者に考へてゐたことがその口振で分ると、彼女は急に、先刻解雇者の名前をみた時から忘れてゐた、それは若い女らしい、それを頭に浮べれば乳房のくらげのやうに伸縮し始める、その理想を再生させることが出来た。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのポルチエーが自分を小蔭へ引っぱって行って何かしら談判を始める。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は枕元の火鉢の傍で縫いかけの子供の春着を膝へのせたまま、向うの唐紙の更紗模様をボンヤリ見詰めて何か考えていたが、思い出したように、針を動かし始める。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてお父さんが目を覚まして、咳払ひや煙草盆の音を立て始めると、急に家中活気を呈して来ます。",
              "citation": {
                "source": "家族",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は甲斐の自然が、人文の上に輝き始める回春期である、甲斐の文芸復興は、恐らくその洪大なる自然の上に打ち建てられるであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから土地の案内に精しい輿水象次氏が一行に加わって、泥道を歩き始める。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、彼が、痛いのは腰だ、と思っていたのに、川上の捲上線に伝って登り始めるのと、カッキリ同時に、その腰の痛みが上の方に上って来るのを覚えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く手廻しをすればよいのに、元日になってから慌てて書き始める、そうして肩を痛くし胃を悪くして溜息をしているのが、傍から見ると全く変った道楽としか思われないのであった。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いに永生きをして八十くらいになったら、その時にそろそろマルクス、エンゲルスの研究でも始めるだろうと皆でうわさをすることである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなバスケットや信玄袋の中から取り出した殘りものゝ鹽煎餅やサンドウイッチを片付けて居た生徒達の一人が、さういふものゝ包紙を細かく引き裂いては窓から飛ばせ始めると、風下の窓から手を出して其れを取らうとするものが幾人も出て來た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯空で考へるだけでは題目は中々出て來ないが、何か一つつゝき始めると其の途中に無數の目當てが出來過ぎて困る位である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が其處へ來る前から、中學の一年か二年位と見える子供が唯一人材木の上に腰をかけて居たが、私が描き始めると傍へ來て大人しく見て居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると鉄の浮いていた小管内の水銀面が下がって弁の細い孔が露出し、ここから瓦斯が侵入して稀薄の度を減じ、管が光り始める。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めに電流がこのコイルを通ってこれを熱すると、その中にあるマグネシアの線が熱して導体になり光り始める。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもそのままでは電気は通らぬが、始めにこの管を傾けて水銀を管の一端から他端へ流し、電極の間に橋をかけると電流が通じ始める。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大きいどんぐり、ちいちゃいどんぐり、みいんな利口などんぐりちゃん」と出たらめの唱歌のようなものを歌って飛び飛びしながらまた拾い始める。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "初夏五月の頃、富士の嶺の雪が溶け始めるのに人間の形に穴があく部分がある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新喜楽のまえの女将の生きていた時分に、この女将と彼女と、もう一人新橋のひさごあたりが一つ席に落合って、雑談でも始めると、この社会人の耳には典型的と思われる、機知と飛躍に富んだ会話が展開された。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると作楽井は独り感に入ったように首を振って「御主人は、よく知ってらっしゃるが、考えてみれば自分なぞは――」　と言って、身の上話を始めるのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分の動きにつれて肯定と否定の両頭は直ぐ噛み合いを始める。",
              "citation": {
                "source": "時代色",
                "author": "――歪んだポーズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が、うすら冷たくそのうえを上走り始める。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
