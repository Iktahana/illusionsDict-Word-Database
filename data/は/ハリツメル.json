        "examples": {
          "standard": [
            {
              "text": "寒波で湖面が厚い氷に張り詰めて、スケートができるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "屋根瓦が綺麗に張り詰められ、新しい家の外観が完成した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の朝、窓ガラスには美しい霜の模様が張り詰めていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
