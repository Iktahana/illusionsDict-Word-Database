        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人目をつつむ苦しさに、鳴りを沈めた琴の絃、じつと哀しく張り詰める。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこの山の神様がこれではいけないというのでいつも氷を張り詰めることにしたのである。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の修覆と言つても塗替へるとなると大變であるから豫ての計畫通り壁土のやうな色をした洋紙で一面に張り詰める事を思ひ立つた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "期待の永さと、短い間にひどく緊張して気をはりつめるせいで面会はくたびれた。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙がこの部屋一ツになつたやうな緊張が、部屋いつぱい、はりつめる。",
              "citation": {
                "source": "散る日本",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
