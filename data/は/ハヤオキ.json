        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは私にしては、余程早起きなのであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　或る日の朝、珍らしく早起きして床を片づけてゐる所へ、思ひがけなく芥川君が跳び込んできた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四、五日たってから、ある朝奮発して早起きして、電車が通い始めると絵具箱を提げて出かけた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――堯はいつになく早起きをした午前にうっとりとした。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときＫ君も早起きしたのか、同じくやって来ました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の裏戸が明いて早起きのおかみさんが掃除を始める、その箒の音がこれに和する。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起きの西山は朝寝の柿江をとうとう起してしまったらしい。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は早起きして表戸の野に新聞紙を拾いに出ると、東にあった二個の太陽を見出した。",
              "citation": {
                "source": "北海道に就いての印象",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　早起きの女中がざぶ／＼、さら／＼と、早、その木の葉をはく。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけだから、いつもより早起きをしてすぐに湯に浸って帰ってくると、隣座敷では今ようよう起きたらしかった。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しは頭脳がはっきりし、悲しみも剥れて行ったが、請地ではもう早起きの父が起きている時分だなぞと考えてみたりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も母も宵寝の早起きだったのて、台所ではもう焚きたての飯の匂いがしており、七輪にかかった鍋の蓋の隙間から、懐かしい味噌汁の甘い煙も噴き出していた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを早起きして来た動物の番人が一生懸命で止めています。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓司が「また、一人、君のお仲間が来た」と言うと、花田は苦り切りながら、「あいつも早起きの乞食の一人だ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新百瀬の啓司は朝飯を食べますと、早起きの鷺撃ちの疲れが出て一睡する癖があります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十四日　第七信（ベルリンにて）ママ、今日は早起きをしたの、五時にね。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頬白鳥　ものぐさ百姓がある朝、めづらしく早起きして、畑で種蒔きをしてゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "明後日放送があるんですって、だから明日は八時までに練習所へ、顔を出さなきゃいけないんですって……練習所は、荏原の方だから、早起きしなければいけないんですってね……」　美沢の噂をするのなら、せめて（お姉さんによろしくといっていたわ）とか、（お姉さんに会いたいといっていたわ）とか、あっていいはずである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、呼びかけて、「貴女は、お若いのに早起きですな。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達も、休み中なるべく早起きの習慣をつけたいと思っていますから……」準之助氏は、新子をうながすように、小径を先に立って歩きながら、「じゃ、朝食前に、小太郎に読み方と算術を教えて下さい。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "早起きして顔を洗った自分の頭もせいせいして、勇ましい心は公園の球投げ、樋川の夜ぶりと駆けめぐった。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　街では早起きの連中がちょうど窓から顔を出し始める頃で、我々の馬車はサリィ州の町並みを抜けていった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れもしない、あの三月四日のこと、私は普段よりも少しばかり早起きすると、折しもまだシャーロック・ホームズは朝食中だった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人の子供のうち、上と下の兄弟は寢坊だが中の姉妹は早起きである。",
              "citation": {
                "source": "たべものの木",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "久保町の豆腐屋定助が商売柄だけに早起きをして、豆腐の碓を挽いていると、まだ薄暗い店先から一人の女が転げるように駈け込んで来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "節季師走じゃありませんか」「そんなに早起きをしているなら知っているのかえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やれ有難やと喜んで、再び奉納小屋の方へ引っ返そうと致しますと、この頃は夜の明けるのが早くなったのと、開帳中は特に早起きをいたしますので、寺中ではもう雨戸を繰るような音がきこえます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "みっかめの　りすたちは　はやおきして　つりに　でかけました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はおれがめずらしくはやおきをして、といってもかれこれひるちかかったが、朝昼けんたいのめしをくっている時だった、みしりみしりと階段の音がして留守番のばあやが、「ムッシュウ・じゅあん、お客さんですよ」　といい、よちよち一枚の名刺を眼のまえにさしだした。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ム、ウム……ム、ウム」　と、ふかい吐息をもらして台所の土間に腰をおろしたまま、もはやおきあがる気力もなく、左近将監は刀を杖に、じーっとさしうつむいておりました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
