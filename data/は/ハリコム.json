          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "招待状に、装飾用のリボンを貼り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "写真アルバムに、旅行で撮った写真を一枚一枚貼り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い地図の破れた部分に、補修用の紙を貼り込んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "食事、味噌汁・納豆うまいこと、十一時に出るので、それ迄に、旅中の新聞雑誌の切抜きをスクラップブックに貼り込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう直き簾をはりこむぜ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそく私がはりこむことに致します」　呼吸というものは、こう、いきたいものである。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
