[
  {
    "uuid": "10ff6e9d-cd0d-5f1a-b9ee-994265a62d6e",
    "entry": "犯罪捜査",
    "reading": {
      "primary": "はんざいそうさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
