[
  {
    "uuid": "cef99f0f-3efa-540c-9d0c-a02054137d6e",
    "entry": "払う",
    "reading": {
      "primary": "はらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
      ],
