    "definitions": [
      {
        "index": 1,
        "gloss": "shaving (usu. concrete, paintwork, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さういふ軽蔑のされ方ならその叔母のみならず毎度のことで、そんなことで腹が立つのでもなかつたが、何がなし癪に障つて、トラックの上にゐて顔に当る朝風は自分の一切合切をみる／＼削り減らしてしまふやうに感じられる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ巨大な堆石が、現在見当らないのは、何分にも、氷河が小さく、谷の削り方も浅くて、「剥ぎ取り」が、深く利かないためであろう。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上は大空で、否、大空の中に、粗削りの石の塊が挟まれていて、その塊を土台として、蒲鉾形の蓆小舎が出来ている。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを錬え直して造った新しい鋭利なメスで、数千年来人間の脳の中にへばり付いていたいわゆる常識的な時空の観念を悉皆削り取った。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥から着物を出して、荒削りの槙柱に縄で括りつけたロココ式の半姿見へ小初は向った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の端削りて道路開かれ、源叔父が家の前には今の車道でき、朝夕二度に汽船の笛鳴りつ、昔は網だに干さぬ荒磯はたちまち今の様と変わりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿糸の結び玉や、毛髪や動物の毛らしいものや、ボール紙のかけらや、鉛筆の削り屑、マッチ箱の破片、こんなものは容易に認められるが、中にはどうしても来歴の分らない不思議な物件の断片があった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その削り立った峰の頂にはみな一つ宛小石が載っかっていた。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "香は天つ風の烈しく吹くにも圧されず、色は白璧を削りたればとてかくはあらじと思はるゝまで潔きが中に猶｜温かげなるおもむきさへあり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもて通りが少し広くなって、私の家の庭も半分ほど削り取られて道路にされてしまいました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして画かきはじぶんの右足の靴をぬいでその中に鉛筆を削りはじめました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二一課　橋は流れて水は流れず　私たち鰹節をナイフで削るときには、鰹節を確と握り押えてナイフの方を動かして削ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、鰹節削りの鉋が出来て鰹節を削るときには、今度は鰹節の方を動かします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を削るのには必ず鰹節を握り押えて削るもの、すなわち「水は流れて橋は流れず」の一方ばかりの考え方に凝り固まっている人は、折角鰹節削りの鉋箱が出来ても、どこまでも鰹節の方を動かしてはならぬものとして、鉋箱を逆にして鰹節に宛てがうでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして残された切ない心だけが、わたくしを削り虐みます。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど引潮の海の色は、煙の中に藍を湛えて、或は十畳、二十畳、五畳、三畳、真砂の床に絶えては連なる、平らな岩の、天地の奇しき手に、鉄槌のあとの見ゆるあり、削りかけの鑪の目の立ったるあり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "船乗りの青年はポケツトから小さなナイフを出してその窓の羊歯の葉の形をした氷をガリガリ削り落しました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "削り取られた分の窓ガラスはつめたくて実によく透とほり向ふでは山脈の雪が耿々とひかり、その上の鉄いろをしたつめたい空にはまるでたつたいまみがきをかけたやうな青い月がすきつとかゝつてゐました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかものは又窓の氷を削りました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に自殺をするものが　　二本も注意深く鉛筆を削り　　そんなあやしんで近寄るものを　　霧の中でしらしら笑ってゐるか。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠の霜は針の山、熱海はたちまち八寒地獄、日金がおろして来ましたので、烈しい陽気の変りよう、今日が危い、とまた誰いうとなく、湯殿の話、辻の風説、会うものごとに申し伝えて、時計の針が一つ一つ生命を削りますようで、皆、下衣の襟を開けるほど、胸が苦しゅうござりましたわ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと削りませんからッて、私強情を張りましたら、それでは、きっと誰にも見せるなよ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まくり手には、鉄の如意かと思う、……しかも握太にして、丈一尺ばかりの木棍を、異様に削りまわした――憚なく申すことを許さるるならば、髣髴として、陽形なるを構えている。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　美少年はものをも言はで、直ちに鋸の刃を返して、さら／＼と削り落すに、粉はばら／＼とあたりに散り、ぢ、ぢ、と蝉の鳴きやむ音して、焼砂に煮え込みたり。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　あきなひに出づる時、継母の心なく嘗て炭を挽きしまゝなる鋸を持たせしなれば、さは雪の色づくを、少年は然りとも知らで、削り落し払ふまゝに、雪の量は掌に小さくなりぬ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四幕の朝鮮王妃王子らが捕虜となる件りは、朝鮮公使の抗議に遭い、半途よりその一幕を削りて、更に「義経腰越状」を加う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹節を削りつゝ、それを贈つてくれた友の心を感じる、桂子さん、ありがたう。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "およぐひとおよぐひとのからだはななめにのびる、二本の手はながくそろへてひきのばされる、およぐひとの心臓はくらげのやうにすきとほる、およぐひとの瞳はつりがねのひびきをききつつ、およぐひとのたましひは水のうへの月をみる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の顏は一段と蒼ざめて、瞳はつり上つて急に生氣を失つてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま人間に生を受けて、しかも別嬪に生れたものを、一生にたった一度、生命とはつりがえの、色も恋も知らせねえで、盲鳥を占めるように野郎の懐へ捻込んで、いや、貞女になれ、賢母になれ、良妻になれ、と云ったって、手品の種を通わせやしめえし、そう、うまく行くものか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
