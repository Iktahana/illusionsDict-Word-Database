    "definitions": [
      {
        "index": 1,
        "gloss": "to fit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "想ふに「場末の新開町」といふ言葉は今の東京市の殆んど全部に當嵌まる言葉である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この最後の疑問はしかしおそらく現在の我国の物質的のみならず精神的文化の種々の方面に当て嵌まるものかもしれない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは「嘘」とは事変るが、アインシュタインの相対性原理がまだ十分に承認されなかった頃、この所論に対する色々な学者の十人十色の態度を分類してみると、この『徒然草』第百九十四段の中の「嘘に対する人々の態度の種々相」とかなりまでぴったり当て嵌まるのは実に面白いと思う。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手甲見たような、腕へだけ嵌まる毛糸で編んだ、萌黄の手袋を嵌めて、赤い襯衣を着て、例の目を光らしていたのさ。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上この青年には病的と思えるほど敏感に、女ごころの委曲に喰い入って、それにぴったり当嵌まる処置や捌きをつけてくるのには一種のもの憎ささえ感じた。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのどれに当て嵌めて見ても、姉の美佐子の行動は当て嵌まるのだった。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけても最近作「鏡地獄」は、江戸川氏でなければ書けないもので、怪奇の美という此四文字が、ピッタリ宛て嵌まるように思われました。",
              "citation": {
                "source": "探偵文壇鳥瞰",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南信濃、殊に私の住んでゐる諏訪地方などには、この詞が尤もよく当て嵌まるのである。",
              "citation": {
                "source": "諏訪湖畔冬の生活",
                "author": "島木赤彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで釣寄せて置いて……ほんありがた山の蜀魂、一声漏らそうとは嬉しいぞえ嬉しいぞえ」　と妙な身振りをして、「それなら、実は此方も疾からその気ありだから、それ白痴が出来合｜靴を買うのじゃないが、しッくり嵌まるというもンだ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵌まると云えば、邪魔の入らない内だ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ベンカウ』とは矢張私達の田舍で使ふ言葉で、まあ生意氣と言つたら近いかも知れませんが、すつかり意味の宛嵌まる東京言葉は一寸思ひ當りません。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば前に結果したことによって、吾々の求めているものは「存在する」であったが、この存在を広く解釈すればそれは正にそのままこの「実体」に当て嵌まるからである。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "空間はかくして事実上――直観という定義に当て嵌まるばかりではなく――直観として検証されるのでなければならぬ。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし空間であるものと空間でないものとの対立が、今人々が想像しているように、実在と通路との対立に当て嵌まるとすれば、かかる実在・通路の対立は――恰も形式・内容の対立に於て見たように――対立概念使用上の誤謬を犯していると云わねばならぬであろう。",
              "citation": {
                "source": "性格としての空間",
                "author": "――理論の輪郭――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法則にあて嵌まるか嵌まらないかで、芸術作品の価値を決定しようとする。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もこうした典型にあて嵌まる軍人式評論、つまり軍事的に玄人であるが故に社会的に素人である処の評論家が、今日では往々無批判な通行券を有ち勝ちだ。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の破壊にも等しい懺悔――彼は懺悔という言葉の意味が果してこういう場合に宛嵌まるかどうかとは思ったが――その結果が自分に及ぼす影響の恐ろしさを思うと、猶更躊躇しない訳にいかなかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらのことは歴史の場合にも當て嵌まるのである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら歴史的知識をひたすら生への有用性の見地からのみ見るところの、かくの如き歴史的プラグマチズムに對しては、一般にプラグマチズムに向ひ人々の繰り返へしてゐる非難、即ち知識は生にとつて有用だから眞であるのでなく、却て眞であるから生にとつても有用なのである、といふ非難が當て嵌まるであらう。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば子規が評した言葉は、言水にも確に当て嵌まるが、言水の特色を云ひ尽すには、余りに広すぎる憾みはないか。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "男女の抱擁を「釦が釦の孔に嵌まるやうに一緒になつた」と叙してある如き其の一つである。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌は如何といふ場合にも当て嵌まるが、こんな風に取つても差支ないであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "女のやうでもあるが、羽左衛門なら男でも当て嵌まる。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "「適者生存」は彼等には正に当嵌まる言葉である。",
              "citation": {
                "source": "続西方の人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロクロ島の、階段上の出入り口を閉めて、そのまま海底に沈降すると、その直下に、丁度クロクロ島が、そのままぴったり嵌まるだけの穴が開いているのだ。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは客體の基體をなす實在者が「物」と稱せられる場合にのみならず「人」と名づけられる場合にも等しく當嵌まる（二）。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことはそのまま客觀的時間にも當嵌まる。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "穂尖は短いけれども、咽喉までも通るかと思われるほど深く嵌まる。",
              "citation": {
                "source": "闘牛",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庇を貸して母屋を取られたという諺は、エジプトほど適切に当て嵌まる国は見出せない。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来彼はモデルを虐待するので有名だったが、製作に打ち嵌まるといかなるモデルも一草一木と同じようにしか思えない芸術家的心事は容易に同情される。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
