[
  {
    "uuid": "056baa94-cd14-5006-843c-8e52d2f8bbc9",
    "entry": "恥をかく",
    "reading": {
      "primary": "はじをかく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
