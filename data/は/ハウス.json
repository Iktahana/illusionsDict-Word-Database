        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを左へ曲るとウンテルデンリンデンですぐ右側の角がツォイクハウス、次が番兵屯所、その次が大学である。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘が淵紡績の煙突草後に聳え、右に白きは大学のボートハウスなるべし、端艇を乗り出す者二、三。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川放水路の水量を調節する近代科学的｜閘門の上を通って土手を数町川下へさがると右にクラブハウスがあり左にリンクが展開している。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九五年にはトリニティ・ハウス（海事協会）の学術顧問に聘せられた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えているとバーリントンハウスの玄関や、シャンセリゼーやクーアフュルステンダムなどの幻が聯想の糸に引かれて次ぎ次ぎに浮かんで来る。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前日から、小湊のチョップ・ハウスの断髪女を中心にした三つの殺人事件が本牧横町の街を騒がしていた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　神戸――Ａオリエンタル・ハウスの踊子が私を占う。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから私は彼女を連れて、白首女の蝟集する裏町へ行って、チョップ・ハウスのサルーンで、一夜そこの踊子たちの仲間入を彼女にさせました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンのカウフハウスでは穀類や生魚を売っていた、ロンドンの三越のような家では犬や猿や小鳥の生きたのを売っていた。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウンター・デン・リンデンを歩いている女と、タウエンチーン街を歩いている男と、ホワイトハウスの玄関をはぎ合わせたりするような事はそもそも宵の口のことであって、もっともっと美しい深い内容的のモンタージュはいかなる連句のいかなる所にも見いだされるであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのビイルディングの軒端には「フラワー・ハウス」と云う電飾文字が明滅していた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "北マラアストランド二十四番街、宏壯な五階建てのアパアトメント・ハウス、その三階の八室全部を領するシイドウ男爵家、程なくソオルが、そこの玄關に案内を乞ふと、暫くして戻つて來た若い小間使は、男爵が書齋で面會する旨を傳へた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、警察自動車は街燈の光りも見え分かぬ、雪の深い通をのろくさい速度で走つてゐたが、やつとのことで、シイドウ男爵の住ふアパアトメント・ハウスの廣大な入口に辿り着いた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに依ると、男爵は四時少し前に事務所を引き揚げアパアトメント・ハウスの入口で自動車を降りたが、それがお抱へ運轉手の眼に殘る生きた主人の最後の姿で、溜間からすぐ昇降機で三階へ昇ると、自分で鍵をあけて住居の中へはいつて行くのを昇降機のボオイも見屆けてゐたといふのだつた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖水の向う縁の在所を示すように間を置いてクラブハウス、鱒孵化場などの灯が点々と蛍のようです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の家は、暫らく前に死んだ或る海軍大将の家で、アドミラルハウスと呼ばれて居る。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食後、使が来て、負傷者等がミッション・ハウスへ運ばれて来ている旨を告げた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにハウス・ツー・レットとかいた紙が、剥がれている。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「クラブ・ハウスから、一番遠いコースにいたんだよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「杉山は、キャディに訊いても、ハウスの人に訊いても、今日はお見えにならないと云ったって、帰って参りましたのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「リツプ・バン・ヰンクル・ハウス。",
              "citation": {
                "source": "エハガキの激賞文",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最近までコクソン・ウッドハウスの店にいらっしゃいましたか？",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺たちは俺たちの古巣の向いの、カムデンハウスに居るのだ」「しかしどうしてこんな処に来たのだ？",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ウェストハウス＆マーバンクの外商ですから、フェンチャーチ街でいちばん大きなクラレット輸入業者になります。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ郵便でフェンチャーチ街のウェストハウス＆マーバンクから手紙が届き、その知らせの内容は、人相書があらゆる点でうちの社員のジェイムズ・ウィンディバンクと一致。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはドレイパ・ガーデンズのコクソン＆ウッドハウスの店に職を持っていたんですけれど、この春先にご存じだと思いますけれどベネズエラ公債でやっちまいまして、どっと傾いてしまったんです。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "『最近までコクソン＆ウッドハウスにお勤めで？",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "インドの虎狩人の直話をワルハウス筆して曰く、コイムバトール地方を永い間侵して人多く殺した一虎を平らげんとて懸賞したが、誰も討ちおおせなんだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある秋の日の黄昏近くのころ、私はロンドンのＤ――コーヒー・ハウスの大きな弓形張出し窓のところに腰を下していた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "独立したソフトハウスによって書かれたスーパーカードは、こうしたいくつかの問題を乗り越えようと狙った製品です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
