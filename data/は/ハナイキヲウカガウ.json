    "definitions": [
      {
        "index": 1,
        "gloss": "to sound out a person's feelings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
