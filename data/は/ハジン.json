        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四時、六十人のサモア人と、十九人の欧羅巴人との前で、スティヴンスンの身体は埋められた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事にも不器用で、癡重といふやうな処のある欧羅巴人を凌いで、軽捷に立ち働いて得意がるやうな心も起る。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇八年板ごむの「歴史としての民俗學」第一章などを見ると、今日開明に誇る歐羅巴人の多くの祖先も都々逸御順で、老は棄てられ壯きは殘る風俗で澄して居たらしい。",
              "citation": {
                "source": "棄老傳説に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども彼が師｜巴人に受くるところ多からざりしは、成功の晩年にありしを見て知るべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや長じて東都に遊び、巴人の門に入りて俳諧を学ぶ。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "大地に堅く足をつけてかゝつた歐羅巴人が近代に根を張つたことの決して偶然でないことを想ひ見る。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "歐羅巴人の見地よりする古代印度の研究者として名高く、吾國から巴里に遊んだ學者達をはじめ多くの日本の留學生を愛した佛蘭西大學のシル※ン・レヰイ老教授のことは知る人は知る。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "後部の舞踏甲板は、欧羅巴人によって黄金の威力を実示された被征服民族の商隊で一ぱいだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴をはいてるのが欧羅巴人で、跣足で歩いてるのが印度人。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "亜剌比亜人の penis は欧羅巴人のよりも短い。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに黒人のは欧羅巴人のよりも更に長く、且つ黒人のは膨脹律が少なくて duration が長い。",
              "citation": {
                "source": "リチヤアド・バアトン訳「一千一夜物語」に就いて",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともあれ、東洋的な、種々の所謂思想丈けならば、既に実際に証拠立てられてゐる如く、稍優秀な頭脳を有つた丈けの欧羅巴人の誰彼によつてゞも、容易く理解され、そしてもてはやされることすらも出来るであらう。",
              "citation": {
                "source": "ニイチエ雑観",
                "author": "超人の如く潔き没落を憧憬するニイチエの日本精神に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋諸国に来たる欧羅巴人は、支那・日本の語にも通じて、著述などするものあり。",
              "citation": {
                "source": "学校の説",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは現在の欧羅巴人の考のみでなく、昔の欧羅巴人も矢張り然う思つた。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　現在の欧羅巴人もこの古代の詩人と同じ望を、器械の発明に嘱して居りました。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "英人カルカツプは今日の有様を歎息して『欧羅巴人は政治上の民権を得たが、経済上の食客で、地面なく家もなし』と言うて居る。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども彼が師｜巴人に受くる所多からざりしは、成功の晩年にありしを見て知るべし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは色の白い毛の赤い欧羅巴人とか云う奴らだ。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い肌、青い眼、黄金色の髪、紛れもないそれは欧羅巴人で、他ならぬそれはジョン少年であった。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧羅巴人の子供だそうで」「それでは俺達の敵ではないか」オンコッコは顔をしかめ、「いったいどこから捕らえて来たのだ？",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "亞細亞列國の人種相異なるや、日本人種と歐羅巴人種の相異なると毫も異ならず。",
              "citation": {
                "source": "世界の日本乎、亞細亞の日本乎",
                "author": "竹越三叉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余程前のことでございますが此緑地へ親子三人の欧羅巴人が参りました。",
              "citation": {
                "source": "沙漠の歌",
                "author": "スタンレー探検日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑地に住んでいる土人達は最初こそ三人の欧羅巴人を恐れたり憎んだり致しましたが、善良の性質だと知ってからは喜んでその周囲に集まりました。",
              "citation": {
                "source": "沙漠の歌",
                "author": "スタンレー探検日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛装を凝らした貴婦人を連れた欧羅巴人も歩いている。",
              "citation": {
                "source": "死の航海",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしカシュガルの王が――私は非常に進歩してゐる王だと思ふが――歐羅巴人に復讐しようと思つたら、このやうな不和の林檎を吾々に送るのが最も有効で、それ以上にその目的に添ふ方法はありますまいね。",
              "citation": {
                "source": "若い僧侶の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "大村の生れで、父はレオ落合小左衛門、母はクラヽ、貧乏な武士で、両親共に殉教者であつたといふが、彼は少年時代から有馬の神学校で育ち、欧羅巴人と同じぐらゐラテン語を達者に話した。",
              "citation": {
                "source": "わが血を追ふ人々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "３．印度歐羅巴人種は源は同一種族であり同一言語を使用してゐた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この亜細亜人種とか、欧羅巴人種とか、亜非利加人種とかいうものは、御互いに古い時から分れたもので、比較的遠い親類でありますが、馬来人種などと言われるものは、右の区別に比べると、亜細亜人種とは比較的新しい時代に分れた人種と云ってよかろうと思います。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楊貴妃はじんぜうなるやせ容の人の如く想はるれど、天宝遺事に貴妃素有肉体、至夏苦熱、常有肺渇、毎日含一玉魚児於口中、蓋藉其凉津沃肺也と。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三平　スープか……双葉　（野菜を、マナイタの上で揃えながら）サツマイモのはじん所、お父さん掘ったんですか？",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
