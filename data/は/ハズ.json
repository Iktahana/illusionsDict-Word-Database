[
  {
    "uuid": "2eaaa6f7-ec46-5a19-85e4-48e214861d70",
    "entry": "筈",
    "reading": {
      "primary": "はず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "助動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "should (be)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宗教に入つて、尠くも朝と夕方に、帰依する気持があれば、謙譲は持続しやすく、さうであれば、詩的恍惚もミツチリと感じられ、漸次に味の深いものが、生れるやうになる筈だと思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、信義に乏しい現今は、芸術家達が、恐らく甚だしい孤独に逐ひ込められてゐる筈である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "書きたいことはないけれど、あの人が嫌ではないしするから書かうといつて書く手紙に、受取つた人が感動する筈はないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "云へば平凡なこととなるけれど、あれやこれやの作品が、その読む人の人格といふ点で関連し合ひ、ひいては文学一般の了得が、その人なりに満足され、つまり、競技に勝つだけでなく、そのフォルムも自分にとつて決定的である筈のものが最後的に探索されねばならないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の余剰価値ともあるべき筈の芸術が浅墓なことであるくらゐならば、頼みもしないにそんなものを作らなくてもよいのだし、作るとすれば図々しいことである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち我々は書いてみたくなつたのであつて、一定の目的のために、書かうとしたのではなかつた筈である。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学に、親しんでゐるといふ、まことに文学者にとつて当然のことさへ出来てゐるならば、決して起らない筈の問題が、数々の問題の過半を占めてゐるといふやうなこともあるものであると、今更思ふ人も少くなくて欲しいことである。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶんたくさん書くことを用意していた筈なのに、異様にこわばって、書けなくなった。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、面白い筈だが、という抗弁は成り立つわけは無い。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん皆にわかってもらいたくて出来るだけ、ていねいに書いた筈である。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一文にとりかかるため、私は、三夜、熟考した筈である。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかつて私たちの敬愛の的であった田舎｜親爺の大政治家レニンも、常に後輩に対し、「勉強せよ、勉強せよ、そして勉強せよ」と教えていた筈であります。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "博識の人が、おのれの知識を機会ある毎に、のこりなく開陳するというのは、極めて自然の事で、少しも怪しむに及ばぬ筈であるが、世の中は、おかしなもので、自己の知っている事の十分の一以上を発表すると、その発表者を物知りぶるといって非難する。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ以上の佳日は無い筈である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「瀬川さんだったら、大隅君にも不服は無い筈です。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「長女の婿は三、四年前に北支で戦死、家族はいま小坂の家に住んでいる筈だ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか友右衛門だつた筈です。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日中に、文芸春秋社から「新ハムレット」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つづいて筑摩書房から「千代女」が、高梨書店から「信天翁」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひそかに読書もしている筈であります。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書を一度、情熱を以て精読した人なら、誰でも知っている筈のものを、ことごとしく取扱っているだけであった。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしか友右衛門だった筈です。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は大井広介とは、遊んだ事もあまり無いし、今日まで二人の間には、何の恩怨も無かった筈だが、どういうわけか、このような難題を吹きかける。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "叫び（生活）そのものは遮断されたまゝになつて、叫びの表現方法が向上して行くのであるから、外的になる筈である。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが振返つて考へてみれば、さういふことが流行してゐる今だとて、さういふことを口にしてゐる人は、現実感を以て云つてゐる筈はない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「併しまあ好い……」彼はこんなに考へ悩むのは自分の神経で、実際にはまだ教師達が給士一件を知つてゐる筈のものではないだらうと思つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら善意といふものが在つて然る後神が在るのではなく、神といふ一切の根源が在る「在り様」こそ善意である筈だからである。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、帰する所は、あの路この路を径た上での善意の国である筈だからだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "では今は魂のことの方が先になつたのだから、以前の機敏は右にか左にかともかく変化をうけた筈です。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人が驚けば、その驚きはひきつゞき何かを想はす筈だが、そして描写の労を採らせるに然るべき動機はそのひきつゞいた想ひであるべきなのだが。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
