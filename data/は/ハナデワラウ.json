        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "年内の御重宝九星売が、恵方の方へ突伏して、けたけたと堪らなそうに噴飯したれば、苦虫と呼ばれた歯磨屋が、うンふンと鼻で笑う。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶子はおかしいほど機嫌とって、「英語たらいうもんむつかしおまっしゃろな」女学生は鼻で笑うのだった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふ、ふん」と鼻で笑うのは智識がおであった。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし酔うと、酷薄無慙な気持になる桂子は、そんな私の心づかいなど鼻で笑う。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
