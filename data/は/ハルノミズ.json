    "definitions": [
      {
        "index": 1,
        "gloss": "lakes and torrents of spring (overflowing with water)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "橋なくて日暮れんとする春の水　こうした春の郊外野景を描くことで、蕪村は特殊の画才と詩情とを有している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とその○□△を楽書の余白へ、鉛筆を真直に取ってすらすらと春の水の靡くさまに走らした仮名は、かくれもなく、散策子に読得られた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の水をさかのぼる笑へば金歯が見える春風　三月十九日花ぐもりだ、身心倦怠。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二年二月　　鶯の歌なやましき鶯のうたのしらべよ……ゆく春の水の上、靄の廂合、凋れたる官能の、あるは、青みに、夜をこめて霊の音をのみぞ啼く。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ橋なくて日暮れんとする春の水罌粟の花まがきすべくもあらぬかなのごときは古文より来たるもの、春の水｜背戸に田つくらんとぞ思ふ白蓮を剪らんとぞ思ふ僧のさま　この「とぞ思ふ」というは和歌より取り来たりしものなり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "・霜晴れほのかに匂ふは水仙　　　或る夜の感懐・死にたいときに死ぬるがよろしい水仙匂ふ・寝るとしてもう春の水を腹いつぱい・月夜雨ふるその音は春　二月十八日　春ぐもり、雨。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、作者の腹に入って見ると、「その前夜」に描かれている恋愛の本質を「春の水」のマリヤの気まぐれな恋愛と比べて見た場合、どちらが社会的な価値において高いという、はっきりした選択と主張はされていない。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "連歌の発句にもすき返せ草も花咲く小田の原　　　　　紹巴山川のめぐり田かへす裾輪かな　　　　同濁りけり山田やかへす春の水　　　　　同など田をかへすといふ事は既にいへり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白鳥の花振り別けし春の水。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の水船に十人の桜人皷打つなり月昇る時　嵯峨の渡月橋辺の昔の光景でも想像しながらこの歌を読めば完全に鑑賞出来ようといふものである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "天竺の流沙に行くや春の水浪華の街を西す南す　昔の大阪、水の大阪、その大阪の春の情調を表現しようといふ試みであらうが、それが見事に成功し、既にクラシツクとして我が民族のもつ宝物の一つになつてゐる歌。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪を流れる春の水の心持は流沙へ流れ込む水のそれに似てゐるやうに私は思ふといふわけなのであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "後朝や春の村人まだ覚めぬ水を渡りぬ河下の橋　川上の女の家を尋ねてのあした、村人さへまだ起きぬ早朝、朝靄のほのかに立ち昇る静かな春の水を見ては幸福感に浸りつつ河下の橋を渡つて家路に急ぐ心持であらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "君乗せし黄の大馬とわが驢馬と並べて春の水見る夕　春宵一刻千金とまでは進まぬその一歩手前の夕暮の気持を象徴的に詠出したものであらうか。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になってから文房堂へ行き帰りに『ドン底』と『春の水』を買って来て、「春の水」の方をすっかりよんでしまう。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩は斜に流れを裂いて、淙々とたぎる春の水に千年の苔を洗わせていた。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴一羽高歩みして春の水　　あふひ　鶴の沢山すむという南国阿久根の里でもよし、ひろやかな、木深い幽苑を想像してもよい。",
              "citation": {
                "source": "女流俳句を味読す",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ橋なくて日暮れんとする春の水罌粟の花まがきすべくもあらぬかなの如きは古文より来る者、春の水｜背戸に田つくらんとぞ思ふ白蓮を剪らんとぞ思ふ僧のさま　この「とぞ思ふ」といふは和歌より取り来りし者なり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒いまでに蒼い水の色、早春の水としては当然である。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ちょろちょろ雪解の春の水　○少し凍って居る洗濯もの　○鳩、ふくらんで雌のまわりを廻る、鳩のきれいな形　グルッククーグルックー　○『文芸春秋』の四月特別号　文芸春秋議会、始め下らぬガヤガヤと思い、あとで一寸よみなおし、感じるものがあって身体があつくなった。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の上から春の水がどんどん渦巻いて流れ下りて来る。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "マーシャルの弐島で六千人全滅〔欄外に〕　田圃道を行ったら草はまだ黄色く枯れているのに、水はとくとくと春の水の音を立ててせせらいでいて印象ふかかった。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の水は、ゆるくめぐるカナールグランデの、水楼に暮らした幾日の、水の香につつまれて、ふと眼をさます暁方も、または、アヴェ・マリヤの鐘の音に、静かに暮れてゆく夕方も、今、眼を閉じて想えば、涙の滲むほど、なつかしくはあるが。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日はぽかり／＼春の水はのたり／＼、堤外は一面の紫雲英で、空には雲雀、田には蛙が鳴いて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬の候、卵から艀った鮭の子は、生まれたあたりで越年して、温かい春の水を迎えるのであるが、四月上旬になると、長さ一寸五分ほどに育つ。",
              "citation": {
                "source": "魔味洗心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然と凹む二畳ばかりの岩のなかに春の水がいつともなく、たまって静かに山桜の影を※している。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂川は二間に足らぬ小橋の下を流れて、浜の方へ春の水をそそぐ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
