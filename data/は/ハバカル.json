    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to hesitate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と、女は何故か憚るやうにあわてて扉を締めて、置いた火鉢を抱へ直すとけむつぽい顏を横に曲げながら、私の側に近寄つて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れ憚る者がいないのが嬉しかった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからお徳までが磯には憚る風がある。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然私の耳は憚るやうに「パパパパ……」と云ふ行夫の聲を捕へて、ぎよつと正氣に返つた。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と憚る所あるらしく、声もこの時なお低い。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小児も憚るか楽書の痕も無く、朦朧として暗夜にも白い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何も貝類を川に棄つるに、世間を憚る事は無いように思われる……ですね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さるからに御老職、諸役人いづれも方某が言に背かざるやう御約束ありたく候」と憚る處も無く申上ぐれば、御年役聞し召し、「道理の言條なり」とてすなはち一同に誓文を徴せらる。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、人通りは少し、日向の眞中を憚る處もなく、何しろ、御院殿の方へ眞直だ、とのん氣に歩行き出す。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝太郎がその挙動を、鋭い目で角の屑屋の物置みたような二階の格子窓に、世を憚る監視中の顔をあてて、匍匐になって見ていた、窃盗、万引、詐偽もその時｜二十までに数を知らず、ちょうど先月までくらい込んでいた、巣鴨が十たび目だという凄い女、渾名を白魚のお兼といって、日向では消えそうな華奢姿。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、またこの折には、あちらでも、こちらでも、ひそひそ話が泡沫に成って湧いたから、さまでに憚るでもなかったので、はっきりと聞えたのである。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は表二階の空を眺めて、その足で直に裏窓を覗くのを不斷から憚るのである。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――日和癖で、何時ぱら／＼と來ようも知れないから、案内者の同伴も、私も、各自蝙蝠傘……いはゆる洋傘とは名のれないのを――色の黒いのに、日もさゝないし、誰に憚るともなく、すぼめて杖につき、足駄で泥濘をこねてゐる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――飜つて思ふに、自から忌み憚るやうに、人の手から遠ざけて、渠等を保護する、心あつた古人の苦肉の計であらうも知れない。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、君の細君は、……（云いつつ憚る。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間とても年が経てば、ないがしろにする約束を、一呼吸早く私が破るに、何に憚る事がある！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳の方は、まだしかし人ぎきも憚るが、洋傘の方は大威張で持たずに済んだ。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "深張の涼傘の影ながら、なお面影は透き、色香は仄めく……心地すれば、誰憚るともなく自然から俯目に俯向く。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　お千は、世を忍び、人目を憚る女であった。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路の長屋の赤い燈に、珍しく、大入道やら、五分刈やら、中にも小皿で禿なる影法師が動いて、ひそひそと声の漏れるのが、目を忍び、音を憚る出入りには、宗吉のために、むしろ僥倖だったのである。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おたかは娘たちがそろって銭湯に行くのも憚る気持がした。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、私は髭もすでに立派に生えたし、これからは誰に憚るところもなく、一人前の大人として世を渡って行くことが出来るのだ。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "いふを憚ることだつたので。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と憚るところ無く白しける。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し確証の無いことを深刻に論ずるのは感心出来無いことだ、憚るべきことだ、田原藤太を強ひて、何方へ賭けようかと考へた博奕打にするには当らない。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "休題、南町の桐楊塾は、監督が祖母さんで、同窓が嬢たちで、更に憚る処が無いから、天下泰平、家内安全、鳳凰は舞い次第、英吉は遊び放題。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早瀬の事はまだまだ、それどころじゃないですが、」と直ぐにまた眉を顰めて、談じつけるような調子に変って、「酒井さん、早瀬は、ありゃ罪人だね、我々はその名を口にするさえ憚るべき悪漢ですね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お妙は格子戸を出るまでは、仔細らしく人目を忍んだようだけれども、こうなるとあえて人聞きを憚るごとき、低い声ではなかったのが、ここで急に密りして、「あの、貴下、父様に叱られて、内証の……奥さん、」「ええ！",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空がさっぱりと晴々した心持だから、誰に憚る処も無い。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠等の無頼なる幾度も此擧動を繰返すに憚る者ならねど、衆は其乞ふが隨意に若干の物品を投じて、其惡戲を演ぜざらむことを謝するを以て、蛇食の藝は暫時休憩を呟きぬ。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
