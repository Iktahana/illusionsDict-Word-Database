[
  {
    "uuid": "319711c0-d94c-5712-a1f8-7e8882aa9022",
    "entry": "憚る",
    "reading": {
      "primary": "はばかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
