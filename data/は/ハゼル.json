        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黒い煙と、パチパチという材木の爆ぜる音。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けたたましく自動車の鳴り爆ぜる音、咽喉太の唸り笛さへ、凝り霜の夜凝りに冴えて、はた、ましぐらに何処へか駈け去り去りぬ。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "けたたましく自動車の鳴り爆ぜる音、咽喉太の唸り笛さへ凝り霜の夜凝りに冴えて、はた、ましぐらに何処へか駈け去りぬ。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "苞ぐるみ巧くそれを※ぎとったところで、どうせ長もちはしないに極っているが、手のひらのなかで苞の爆ぜるのを感じるのは、ちょっとくすぐったいもので、蟋蟀のように刺だらけの脛で、肌を蹴飛ばしたりしないのが気持がいい。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "独軍の塹壕で矢庭に小銃の爆ぜる音がしたが、弾丸は外つ方へ逸れてしまつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと、その煙の向うにけたたましく何か爆ぜる音がして、金粉のような火粉がばらばらと疎らに空へ舞い上りました。",
              "citation": {
                "source": "疑惑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、あの時に較べて今の方が爆ぜるような気力でおしもを視ているのが、自分ながら不思議なことであった。",
              "citation": {
                "source": "女心拾遺",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯林停車｜場（晶子）ああ重苦しく、赤｜黒く、高く、濶く、奥深い穹窿の、神秘な人工の威圧と、沸沸と迸る銀｜白の蒸気と、濛濛と渦巻く煤煙と、爆ぜる火と、哮える鉄と、人間の動悸、汗の香、および靴音とに、絶えず窒息り、絶えず戦慄する伯林の厳かなる大停車｜場。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時頃から滿と健はもう目を覚して、互いの床の中から出す手や足を引張り合つたり、爆ぜるやうな呼び声を立てたりして居た。",
              "citation": {
                "source": "帰つてから",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生むことは、現にわたしの内から爆ぜる唯だ一つの真実創造、もう是非の隙も無い。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "阿片が燻る……発動機が爆ぜる……楽が裂ける……三つの路わが出でんとする城の鉄の門に斯くこそ記るされたれ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯林停車場ああ重苦しく、赤｜黒く、高く、濶く、奥深い穹窿の、神秘な人工の威圧と、沸沸と迸る銀白の蒸気と、爆ぜる火と、哮える鉄と、人間の動悸、汗の香、および靴音とに、絶えず窒息り、絶えず戦慄する伯林の厳かなる大停車｜場。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは陰にこもった鈍い響きであったが、やがて爆ぜるような轟きに変って、窓のガラスがびりびり鳴るほどの烈しさになった。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう村人の声もしない、爆ぜる音ばかりが続き、凝乎としては熱風で息が窒まりそうだった。",
              "citation": {
                "source": "野に臥す者",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "セエラはこの夢から覚めまいと思って、一生懸命眼をつぶっていましたが、ぱちぱちと火の爆ぜる音を聞くと、眼をあけずにはいられませんでした。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の上がる処には何だか貝殻を吹き鳴らすやうな音と、ぱち／＼と爆ぜる音があつた。",
              "citation": {
                "source": "父の死",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」炎の中に　それは物の爆ぜる音でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "安堵にうち震え、救いの場まで連れ戻してくれた最後の一灯が爆ぜるのを見つめながら。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の爆ぜる音だけが、静かさを破った。",
              "citation": {
                "source": "桜島",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう云う字を書くか存じませんが、多分あれを炒る時に爆ぜるからハゼと申すのでしょうか。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その時、後方で、豆がはぜるような発射の音がした。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、一郎は、足もとでパチパチ塩のはぜるような、音をききました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずうっとずうっと遠くで騎兵の演習らしいパチパチパチパチ塩のはぜるやうな鉄砲の音が聞えました。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずうっとずうっと遠くで騎兵の演習らしいパチパチパチパチ塩のはぜるような鉄砲の音が聞えました。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、一郎は、足もとでパチパチ塩のはぜるやうな、音をきゝました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、云う準之助氏の声も、次に、豆のはぜるような音を立てて襲って来た雹雨の音に、かき消された。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　パンパンとはぜるようにまくしたてられて、ぼうぜんと目を丸めている可賀をあとに、伝六、名人二つの御用駕籠は、時を移さず神田鍛冶町へはせ向かいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はぜるような雷声が、主水之介の頭上へ落ちかかりました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三鞭酒のキルクのはぜる音。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前方には、陣地で燃く篝火のチラチラ光る焔が見え、パチパチ木のはぜる音が聞え始めた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
