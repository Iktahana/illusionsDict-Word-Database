    "definitions": [
      {
        "index": 1,
        "gloss": "underside of a bird's wing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
