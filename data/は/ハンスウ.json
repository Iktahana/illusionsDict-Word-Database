[
  {
    "uuid": "269e7ca4-10fa-51fb-a600-80298f2cfaeb",
    "entry": "半数",
    "reading": {
      "primary": "はんすう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "half the number",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は始業時間にもう十五分なのに、教師達がまだ半数しか出席してゐないのに先づ腹を立てた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして半数の労働者がプロレタリアの指導を去って彼等の追随者になっている。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに村の半数は出していないらしい。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビアなどとなると、だいぶこの置換が困難な問題となるが、しかしたとえば喉音のあるものは半数だけｋかｇ、残り半数をｈで代用するというような試験的便法を取って第一歩を進める事もできる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後記　茲に収めたのは、『山羊の歌』以後に発表したものの過半数である。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スナイダーは、自分のバンド（尤もその半数は、みんなビジテリアンだったのです、）を、そっくりつれてやはり一昨日、ここへ着いたのだそうです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその話題によほどの確実性と普遍性がなければ、多くはある一角、または半数、三分の一くらゐなところで、いつも立ち消えになつてしまふ。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十人くらいの名前を呼んだのだが、出席者は約その半数である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸にして七年前、遷居の際に、途中で一つの本箱を壊わし、その半数の書籍を紛失したが、ちょうどこのノオトも、その時に共に紛失してしまったのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、これも半数以上此集には削除して了つた、これがそもそもの「雀の卵」編纂の動機となつたものである。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも半数は階下の開き戸から表へ飛び出してしまった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "各地方の大酋長にして、此の五つの称号の全部、もしくは過半数を（人望により、或いは功績により）得たる者、推されて王位に即くなり。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍は、背文字のない雑誌形のものが過半数で、そこには貸本屋のそれのやうに一々自筆で、題名が記されてあつた。",
              "citation": {
                "source": "余話（秘められた箱）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "半数十頭を回向院の庭へ揃えた時はあたかも九時であった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、町奴の側には少なからぬ手負いが出来たが、白柄組にも殆ど過半数の手負いを見出した。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め一番坑から続々出坑して、あと半数ほどに残されていた坑夫達の間には、ひとたび海水浸入の事実が知れ渡ると、もうそこには統制もなにもなかった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "過半数のものは諦めていたが、それでも銘々、うぬぼれは持っていた。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴衆の過半数は、あっとばかりにおどろいて立ち上りました。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち、その半数を抜いて払って半数は無手の居捕り、左右にパッと分れながら、じりじりと詰めよりました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十本ほどの扇子のほとんど半数に、同じその絵その文字が見えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮生は、半数は直接ジュウタンに腰をおろし、のこりは、低い部分におりる階段や、上にならべられた折り畳みイスに坐り、ざわめいている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、半数が高志のコレクションで、のこりの多くも、ワラと慶一のものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "多いところは一町内の過半数が飲食店と云ってもいい位である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも学生と違って、直接復興事業に携わっているのが半数以上と想像される。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この報道を受け取った新聞通信社の約半数は、この報道内容の常識逸脱ぶりを指摘して、報道者ドレゴの精神状態が正しいかどうかにつき疑問を持ち、報道をさしひかえた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さまが、「牛についていってごらん」と、おっしゃったので、僕は「四足獣、草食獣、複数の胃で、はんすうする」と、いった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "露伴先生は、富士登山の著述の中で急ぐ勿れと言っていますが、学問は一歩一歩と着実に、牛のはんすう消化のように繰り返し繰り返し味わって学ぶべきものと、ここでは稽古という語を使って述べています。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "反芻（はんすう）動物におけるコバルトの特別な役割が明らかになったのは、もっと後のことであった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
