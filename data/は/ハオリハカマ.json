    "definitions": [
      {
        "index": 1,
        "gloss": "haori and hakama (Japanese male formal attire)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "羽織袴を忘れずに、帽子はなるべくアミダに冠らないやうにして、六ヶ敷い顔をして、理想を前例に照して持つてゐれば、近所知己の評判は良いのでありませう。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日が来ると羽織袴の、揃つて粗雑な顔をした運動員達が道場の内や外を迂路ついてゐるのが見られた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の姿を見ると目出度いと言って急いで羽織袴で恭しく出迎えるような商家の主人もあった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）大きな門前　羽織袴の徳兵衛刀箱を持って門内へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこへ画架を立てた――その時、この峠を導いて、羽織袴で、阪へ掛かると股立を取つた観湖楼、和井内ホテルの御主人が、「あ、然やうで。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "観湖楼の羽織袴は、特に私たちの為ではない、折から地方の顕官の巡遊があつた、その送迎の次手である。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座席に腰かけている人はパナマ帽に羽織袴の中年紳士で、ペダルを踏んでいるのは十八九歳ぐらいの女中さんである。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ四十恰好の眼の鋭い、腕ッ節の強そうな刑事然たる人が羽織袴で面会に来て某名士氏の次の間にヒレ伏した。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概洋服でなければ羽織袴を着た人たちのなかで芥川君の着流しの姿が目に立った。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸事で宗山の留を刺したほどの豪い方々、是非に一日、山田で謡が聞かして欲しい、と羽織袴、フロックで押寄せたろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この看板の前にのみ、洋服が一人、羽織袴が一人、真中に、白襟、空色｜紋着の、廂髪で痩せこけた女が一人｜交って、都合三人の木戸番が、自若として控えて、一言も言わず。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見ると、板戸に凭れていた羽織袴が、「やあ！",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "店のあきないを仕舞って緋の毛氈を敷き詰め、そこに町の年寄連が集って羽織袴で冗談を言いながら将棊をさしている。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下に跫音、ばたばたと早く刻んで、羽織袴の、宝の市の世話人一人、真先に、すっすっすっと来る、当浪屋の女房さん、仲居まじりに、奴が続いて、迎いの人数。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……というのは羽織袴です――弁持も私も、銀行は同一取引の資産家だから、出掛けに、捨利で一着に及んだ礼服を、返りがけに質屋の店さきで、腰を掛けながら引剥ぐと、江戸川べりの冬空に――いいかね――青山から、歩行で一度中の橋手前の銀行へ寄ったんだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉六はそれでも、紋付の羽織袴の姿をして、万事わたくしを補佐します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織袴をつけて兄の代理に宴席の上座に坐っているのを料理店の窓横を通りがゝりに覗きますと、眉の濃いがっしりした眼鼻立ちの美男子ですが、彼はいつも立上って何か行動的な生活に自分をなずませて置きたいような青年でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕ですか、僕は』と言ひ澱んだ男は年の頃二十七八、面長な顏は淺黒く、鼻下に濃き八｜字髭あり、人々の洋服なるに引違へて羽織袴といふ衣裝、今は都下で最も有力なる某新聞の經濟部主任記者たり、次の總選擧には某黨より推れて議員候補者たるべき人物、兒玉進五とて小介川文學士は既に人々に紹介したのである。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、僕はなんの手伝いをするわけでもなく、羽織袴でただうろうろしているばかりであったが、それでもいい加減に疲れてしまった。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの小僧のすこし先をあるいていた羽織袴の侍が、旋風のやんだ時にはもう見えなくなっていたということであるが、その一刹那、小僧は眼をとじて地に伏していたのであるから、そのあいだに侍は通り過ぎてしまったのかも知れない。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ宣教師の正装をしたジョリーさんを先に立てた和洋人の黒服が四五人ばかり、銀色の十字架を胸に佩びてゾロゾロと乗込んで来たので、居住居を崩していた羽織袴連中は、今更のように眼を聳てて坐り直した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の背後には昨夜から父の最後の喘ぎを一心に凝視して御座った羽織袴の頭山さんが、キチント椅子に腰かけて、両手を膝に置いて御座るので、醜体を演じてはならぬと一生懸命に唇を噛んでいたがトテモ我慢し切れなかった。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其背後の半間の間には羽織袴でキチンと坐つた老人の四つ切りの写真が額に入つて立つて居る……」　この題材は、もし自然派系の作家が扱ったならば、どんなに皮肉に描き出しただろう。",
              "citation": {
                "source": "志賀直哉氏の作品",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私の身體に目をつけながら、『それに第一、遠方から來るといふのにそんな小ぎたない風態をして來る奴があるものか、君の細君も細君だ、僕は最初の日、羽織袴で出迎へて呉れた臺長の手前、ほんとに顏から火が出たよ、其處へもつて來ていきなり歸るなんか言ひ出すもんだからあんな騷ぎになつたのだよ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織袴で杖を持とうという柄だもの、かわって謂ってくれねえから困るよな。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーバアの紳士、道行を着た年配者、羽織袴のは、外套を脱いで小脇に挟んでいる。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――橋がかりの際の、私の居まわりにも、羽織袴だの、洋服だので、合図をかわしていました。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘次はそれでも羽織袴で位牌を持つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "總代等はそれでも羽織袴の姿であるが一人でも滿足に袴の紐を結んだのはない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら、いっそ、羽織袴でせにゃなるまい。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
