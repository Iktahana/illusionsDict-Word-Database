[
  {
    "uuid": "bb1a2f7b-97a1-50ff-8acb-d63301f80817",
    "entry": "話し込む",
    "reading": {
      "primary": "はなしこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
