[
  {
    "uuid": "c0d94c76-41d2-513c-9299-ec2ac013f24c",
    "entry": "外す",
    "reading": {
      "primary": "はずす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
