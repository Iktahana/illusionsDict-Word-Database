    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to remove",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しばらくかけていて外すと、眼の前に蜘蛛の糸でもあるような気がして、思わず眼の上を指先でこすってみた。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "存外すいて居る車に乘込んだが、すぐあとから小團體がやつて來て完全に車内の空間を充填してしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども実際は科学者が科学の領域を踏み外す危険を防止するためには、時にこれらの反省的考察が却って必要なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように、特に違った地方の言語を用いたものは、全体として除外すべきものと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう風にして見て行くと、例外すなわち右に述べたような仮名の区別を乱した例は非常に少なくなるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "見られて雪枝てれて視線外す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、そこへ列車が通りかゝると、綿を踏んだように線路はドカンと落ちこみ、必然脚を踏み外すのであった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道や朝鮮台湾は除外するとしても、たとえば南海道九州の自然と東北地方の自然とを一つに見て論ずることは、問題の種類によっては決して妥当であろうとは思われない。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを迂濶に口外すれば宇三郎ばかりでなく、第一にわが身の上が危ういから、藤吉は忌々しいながらも我慢するよりほかはない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、それはいっさいの秘密の行法で、うっかり口外すると一年｜経たねえうちに命がなくなると嚇かされているので、誰もはっきりと云うものがねえそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "またシラブルの終わりのｎは除外することにする。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうたくさんであると言っても存外すぐにはやめてくれない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "連句に限らずすべての詩歌、ただし近ごろの先端的とか称する奇妙な不規則な詩形の化け物はひとまず除外するとして、普通の古典的の意味においてのすべての詩歌は、皆共通な音楽的要素をもっている。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう歩行中でも彼の思索に探り入る習慣は立派な鍛錬となって、決してわきの刺戟によって思索の軌道を踏み外すようなことはなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と呟くのを機會に、跨いだ敷居の腰を外すと、窓に肱を、横ざまに、胸を投掛けて居直つた。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下晴れて、財布の紐を外すやら、胴巻を解くやらして、賭博をはじめますと、お船頭が黙ってはおりませぬ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、こいつ案外すばしこいとこがある。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は挨拶しようと思つて近寄つて行つたが、その老人は私に気づかず、そして何思つたか眼鏡を外すと、すつと奥へひつこんでしまつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一家が寝鎮まった十二時頃を見計って杉扉の鍵を開けたが、想像の通り、器械イジリに慣れている一知にとって、旧式の鍵を外すくらいは何でもない事であった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし……何の用ですか……」「オホホホホホホホホホ」　私は表の扉の閂を外すと又二階に上って、あたたかい夜具にもぐり込んだ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（勿論この場合の考察では詩想の概念的觀念を除外する）此等の要素の集つて構成されたものが、我等の所謂「旋律」である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも西洋に於ては――日本はこの際、特殊の事情によって例外する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更、これを引離すことは、勢い立った若武者を戦場から引上げさすことであり、恋人との同棲から捩ぎ外すことだった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女はむす子が一緒だったらどんなに楽しかろうと思って見るのだが、客を疎外するように取られる懸念から口に出しては云わなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを突然に、郎等だにあらば打殺してましものをと言ふのは、余りに従兄弟同士として貴人の前に口外するには太甚しいことである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦、旦那様、あの、何が、あの、あのあの、」　　　　　矢車草　　　　　　　十　お源のその慌しさ、駈けて来た呼吸づかいと、早口の急込に真赤になりながら、直ぐに台所から居間を突切って、取次ぎに出る手廻しの、襷を外すのが膚を脱ぐような身悶えで、「真砂町の、」「や、先生か。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷をしゃんと、前垂がけ、褄を取るのは知らない風に、庭下駄を引掛けて、二ツ三ツ飛石を伝うて、カチリと外すと、戸を押してずッと入る先生の背中を一ツ、黙言で、はたと打った。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "榊を外す、それを受取る。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくらい念の入った長虫ですから、買手が来て、蛇屋が貯えたその大瓶の圧蓋を外すと、何ですとさ。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内より枢外す音して、門の戸の開いたるは、跫音もせざりしが、姉上の早や二階を下りて来たまいたるなり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
