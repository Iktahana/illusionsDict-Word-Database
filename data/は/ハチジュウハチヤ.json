    "definitions": [
      {
        "index": 1,
        "gloss": "eighty-eighth day from the beginning of spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、八十八夜。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの低い声で、「きょうは八十八夜」そうひとこと呟いたかと思うともう、てれくさくてかなわんとでもいうようにむっくり立ちあがって両肩をぶるっと大きくゆすった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜を記念しようという、なんの意味もない決心を笑いながら固めて、二人、浅草へ呑みに出かけることになったのであるが、その夜、私はいっそく飛びに馬場へ離れがたない親狎の念を抱くにいたった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜だから連れていってあげましょう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "れいの低い聲で、「けふは八十八夜。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜を記念しようといふ、なんの意味もない決心を笑ひながら固めて、二人、淺草へ呑みに出かけることになつたのであるが、その夜、私はいつそく飛びに馬場へ離れがたない親狎の念を抱くにいたつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜だから連れていつてあげませう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せツせツせ夏もちかづく八十八夜野にも山にも新緑の風に藤波さわぐ時　私は、たまらない気持になつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春も八十八夜となつて草木のやはらかな緑が四方を飾るやうになるとみじめな姿で顧みられなかつた畑のへりの茶の木のめぐりも赤い襷の女共が笑ひ興じて俄かに賑かになる。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜過ぎである。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日記の上のところを見たら八十八夜とある。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "青鱚脚立釣佐藤垢石　青鱚釣は例年八十八夜即ち五月上旬には釣れはじまる。",
              "citation": {
                "source": "青鱚脚立釣",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "またハスを栽え付くるには、その前年の蓮根を掘らずに置いて春の八十八夜の前後十日すなわち八十八夜を中にして凡二十日位の間にこの掘らずに種に残して置いた蓮根を掘り来ってこれを栽え付けるのですが、その蓮根を横に泥中に入れ少しく後方に曳いて置くのです。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十八夜頃は殊に明瞭であるという。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月初旬の八十八夜前後には、季節の変り目を知らせる雷雨が赤城方面に発生して、雹などを降らすことがある。",
              "citation": {
                "source": "山と村",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処かしこと聞きたずねても行方が知れぬから、もしや八丈島にでも居はせぬかと、八十八夜の八丈島の上り船をあてにして、首も細るほど待っているのだろうに」　丑蔵がいうと福松は首を振って、「いや、そうではあるまい。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なんでも八十八夜のすぐあとのことでした」「総領の甚之助が死んだのはいつだっけな」「……五月の二十日。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "……蝮蛇がひとを咬むのは八十八夜から十月の中ごろまで。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "蠑※",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お七夜、お十夜、八十八夜、百夜通いは深草の少将で――」「馬鹿野郎」「へッ、うっかり智恵も出せねえ」　柏餅で腹一杯になると、ガラッ八はもうこんな調子でした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、八十八夜も二百十日も、節分から勘定するのが定法だから――」「節分は？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつは今年の暦だ」「不自由な暦だね」「節分から百四十四日目は、八十八夜から五十六日目じゃないか、八十八夜は何日だい？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だからあっしが八十八夜と言ったじゃありませんか」　ガラッ八の鼻は少しばかり蠢きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――無駄を刈って、八十八夜を捜しな」「三月の七日」「お品さん、算盤を頼みますよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというもの、小金馬は八十八夜も待たずして、「安宅丸」のカッパの吉蔵のように、「五井へ行こう、五井へ行こう」という。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年（二十八年）は八十八夜（五月二日）には、すでに胴体の一部が現われていて、代馬より二十日以上も早い。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が昨年見たところでは、八十八夜にはすでに、苗代に若い緑が芽生えている所もあったから、昔よりは種まきの時期も、だいぶ早くなっているのであろう。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗鞍岳（蓮華）の種蒔爺さん――北城村森上より　出現時期は無論、代馬などより早く、昨年は八十八夜（五月二日）には、もう一部分ではあるが出ていた。",
              "citation": {
                "source": "残雪の幻像",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
