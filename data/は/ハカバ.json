        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポオの無韻詩「大鴉」の表現効果は、あのねえばあ・もうあとか、れのああとかいふ言葉の、寂しく遠い、墓場の中から吹いて来る風のやうな、うら悲しくも気味の悪い音韻の繰返す反響にある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "線香と花｜估るゝ事しきりに小僧幾度か箒引きずって墓場を出つ入りつ。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が急いで急坂を上るのは、私の身心から発散する墓場の雰囲気が恐ろしかつたのだと、私は考へた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はようやく少し落着いて人々と共に墓場を辞した。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とても取り返すことの出来ない生」を取り返さうとして、墓場の下から身を起さうとして無益に焦心する、悲しいたましひのすすりなきのやうなものが、彼の不思議の芸術の一面であつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが、産卵を終つた彼等の墓場だつたのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓場を発いて屍体を嗜む変質者のやうな惨忍なよろこびを俺は味はつた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にでも、スパイは、小うるさく、僕の背後につき纒って、墓場にまでやって来るだろう。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷の奧には墓場もあるだらう、人生悠久の流が此處でも泡立ぬまでの渦を卷ゐて居るのである。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その墓場からはやはりいろいろの草花が咲き出ている。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い家のなかは墓場のように森と沈んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうもお詣りに見えました」　手桶に水と樒とを入れて、半七は墓場へ行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして帰りぎわに墓場の方へそっと廻ってみると、一人の男がきのうの墓のまえに拝んでいる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "１６＝墓場　伝六探し廻る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "16＝墓場　伝六探し廻る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが、産卵を終わった彼らの墓場だったのだ。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓場を発いて屍体を嗜む変質者のような残忍なよろこびを俺は味わった。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島に生れてこの島に死し、死してはあの、そら今風が鳴っている山陰の静かな墓場に眠る人々の仲間入りして、この島の土となりたいばかり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お露は児のために生き、児は島人の何人にも抱かれ、大河はその望むところを達して島の奥、森蔭暗き墓場に眠るを得たり。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲く花に人の集まる処を廻ったり殊更に淋しい墓場などを尋ね歩いたりする。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲のおおぜいの乗客はたった今墓場から出て来たような表情であるのに、この二人だけは実に生き生きとしてさも愉快そうに応答している。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおさ、己も墓場の方で、銀平｜様の合図を待ってましたが、別に嬢様の出て来る姿を見附けませんで、「もうもう尋飽倦まして、夜も更けますし、旦那方の御智慧を借りようと存じましてひとまず帰りました。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い狭い石室の中は、墓場のように鎮り返っていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "友吉に案内させて、半七らは更に墓場を見まわると、そこらの大樹の下に二、三カ所、新らしく掘り返したような跡が見いだされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "四人がこれまでに盗んだ金や、右から左に処分することの出来ないような金目の品々が、寺の何処にか隠してあるに相違ないというので、二人は人目に付かないように忍び込んで、墓場や床下を掘ってみたり、須弥壇を掻き廻してみたり、心あたりの場所を一々探していたが、それがどうも見付からない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の医師に診てもらうために出て来て私のうちで数日滞在してから、任地近くの海岸へしばらく療養に行っていたが、どうもはかばかしくないので、学校を休職して郷里の浜べに二年余り暮らした。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕一の方から来ている子供では一年生の生徒が二人ありましたけれどもそれはもう午前中に帰ってしまっていましたし耕一はかばんと傘を持ってひとりみちを川上の方へ帰って行きました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為め取り出すときに一枚切手が剥げて居て函の中に落ちてあり、も一枚はかばんへうつすとき剥げた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　夫人の想出話に対して新吉の返事がはかばかしくないので、夫人は急にこんなことを言い出した。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
