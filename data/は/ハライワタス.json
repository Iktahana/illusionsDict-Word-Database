        "examples": {
          "standard": [
            {
              "text": "彼は下請け業者に、仕事の報酬を払い渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "銀行の支店で、多額の現金を払い渡す手続きを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "給料は、毎月25日に社員の口座に払い渡される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "初日の評判を後にして、その日いっぱいの上り高のしめくくりをしたお角は、払い渡すべきものは即座に払い渡し、大入袋の割振りまできびきびとやっつけて、残った金を両替にすると、それを恭しく紙に包んで男衆を呼びました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その仕事の多寡を計算して、労銀を払い渡すという時になると、与八はいない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
