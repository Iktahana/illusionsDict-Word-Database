    "definitions": [
      {
        "index": 1,
        "gloss": "(an actor) conveying qualities of a character without gestures or speech",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてそれがそれほど誇張されない身ぶりの運動のモンタージュによって、あらゆる悲痛の腹芸を演ずるからおもしろいのである。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが所謂腹芸という奴で、こうして名優の心の底の変化は腹の底から鼻の頭へ表現されて、自由自在に見物に感動を与える事、恰も無線電信のそれの如くであります……。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗も田舎役者ではあるが相当なもので、その後も謀反の嫌疑をかけられたとき、いつも秀吉との腹芸を、相当にやっている。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもながら、捕物名人と、名宰相とのやりとりは、まこと玄々妙々の腹芸ですが、しかし、ありようしだいを打ち割ってみれば、不思議でもない、不審でもない、名人のいったその、御前のあのなる「あの」は、伊豆守の浪人取り締まり政策を利用しようというのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩の前で、あれ程、シラを切っていた腹芸には感服した。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に深夜の腹芸によって、不眠の夜の御機嫌を伺い奉る位のものではないかと私は考えている。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、その腹芸を怪訝に思い、とにかく、騾を引いてきてお乗んなさいとばかりにすると、「君、ちょっとあの男を呼んで来てくれんかね」　と云うのだ。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……例の衝立を使はずに若君に寄り添うたまゝ、思ひのまゝに愁歎を見せるなど、大腹芸とや言はん。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう今では、伝説の領分に入つて、益、ねうちの上つて行かう、として居る団十郎の腹芸とか言ふものと、明らかに反踵的な位置を固執して居る人とか、聞いて居ましたが、なる程、団十郎門流並びに、其感化を受けた役者たちの、無内容を充実らしく見せかける、此頃の腹芸といふものとは、大分違うたはちきれ相な含蓄でした。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう聞いて見れば、技巧よりは、腹芸で見せよう、と言ふ風な容子が見えます。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "立役の腹芸は、形ばかりでも、ある点迄内容あり相に見せることは出来ますが、女形の腹芸と言ふのは、類型のない事故、ほんたうの技巧から出たのでない此人には、見習うてよい先蹤がないのです。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくもまあ、空しい腹芸を標榜する人を並べて、二人きりの場面を委ねる心に、博士がなられたものだ、と思ひました。",
              "citation": {
                "source": "芝居に出た名残星月夜",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "両々ゆづらず、神謀鬼策、蛇の道は蛇、火花をちらす両雄の腹芸といふところだが、話が出来すぎてゐるやうだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "議会の答弁や腹芸なぞと云われているものが大がいそうだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを芝居道の上でいえば、逝くなった団十郎の芝居は腹芸が多く、動きが少ないから、当時大向うに受けなかったという話であるが、それと同じであろう。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩成期の仕事とされるこの備前焼は、腹芸そのものが、秀れた美を生む源泉となるのである。",
              "citation": {
                "source": "備前焼",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この腹芸をすっかり失っている今の陶芸作家には、二、三を除いては、的確な陶器思考などあるはずもなく、わからず屋同士が、他愛もなく、その日暮しにおのずと酔生夢死を待つばかりという体たらくである。",
              "citation": {
                "source": "備前焼",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "肚がないから腹芸が出来るはずがないとなる。",
              "citation": {
                "source": "愛陶語録",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹芸が出来ないために、猪口才で行こうとする。",
              "citation": {
                "source": "愛陶語録",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両役者同志の腹芸なのである。",
              "citation": {
                "source": "今昔茶話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれがだいこんの腹芸なのさ」　珠子さんが合槌をうつ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく議事堂や警視庁の建築をながめたあとで、眼を返してお濠と土手とをながめるならば、刺激的な芸のあとに無言の腹芸を見るような、もしくは巧言令色の人に接したあとで無為に化する人に逢ったような、深い喜びを感ずるであろう。",
              "citation": {
                "source": "城",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両々ゆずらず、神謀鬼策、蛇の道は蛇、火花をちらす両雄の腹芸というところだが、話が出来すぎているようだ。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のジャナリストたちは「腹芸」を演じすぎます。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は共産主義ないし共産党の基本線にそって編集されている雑誌が、表向きはそうでないようなフリをして見せたり、「共産革命政府」と言えばハッキリするところを「人民民主政府」と言ったふうのまぎらわしい言葉を使ったりする理由が、「腹芸」やマキァヴェリズム以外のものとしては、私にはわからないのです。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が腹芸なら、君だって腹芸じゃなかったかねえ？",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋風の大ざっぱな、直観的な、そして腹芸的表現ですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
