        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あの飾り気なく見える「萩焼」といえども、今は全くこの弊に捉われている。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの萩焼の如きも全く同じであって、茶の病でぬきさしならないのである。",
              "citation": {
                "source": "北九州の窯",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のような窯場は顧る人もない無名のものでありますが、これに対し長門の国には「萩焼」と呼ぶ名高いものがあります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうことがよく解ったら、今の萩焼とても、ずっとよくなるでありましょう。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
