        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何という塩っぱい、鼻を刺すような匂だろう。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻を刺す移り香を楽しみでもするように直人は、しっかりと女の枕に顔をよせて、にやにやと笑っていたのである。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端、鼻を刺すやうな激しい臭みが、籠の目を洩れて、そこらにぷんぷんと散らばつて往つた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻を刺す石炭酸の臭気が、何処となく底冷のする空気に混じて、家々の軒下には夥しく石灰が撒きかけてある。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻を刺す石炭酸の臭氣が、何處となく底冷えのする空氣に混じて、家々の軒下には夥しく石灰が撒きかけてある。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端、鼻を刺すやうな激しい臭みが、籠の目を洩れて、そこらにぷんぷんと散ばつて往つた。",
              "citation": {
                "source": "春菜",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "棺の蓋を明けると燒いた牛肉の匂ひに頗る似て一層重厚な強烈に鼻を刺す惡臭が室内に充滿し觀者をして殆ど嘔吐を催さしめた。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "プンと鼻を刺す生臭い匂い。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プンと鼻を刺すは血の匂いだ。",
              "citation": {
                "source": "北斎と幽霊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "濛々と立ち上る黄色い煙り、プンと鼻を刺す煙硝の匂い、誰か爆弾を投げたと見える。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいて、顔の上にかがみ込んで見ると、酒気と濡れた羅紗から発散する鋭い臭いとが交り合って、ツンと鼻を刺す。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻を刺すような地酒を、それも一合に限って舐めるようにちびちびやっている。",
              "citation": {
                "source": "留さんとその女",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着てしまったものを今更脱いだっておんなじ事さ」庭では別段気がつくほどではなかったのだが、締め切ってあった洋室の中には一と晩じゅう澱んでいた葉巻の匂いと大蒜の匂いとが、むっと鼻を刺すばかりに交っていた。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
