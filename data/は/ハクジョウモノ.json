        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酒井は耳にも掛けないで、「済まん事さ、俺も他人でないお前を、薄情者にはしたくないから、居処を教えてやろう。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「薄情者｜奴が横顔さえも惜んだのか。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方はそんなに未練がお有り遊ばしても、元この女は貴方を棄てて、余所へ嫁に入つて了つたやうな、実に畜生にも劣つた薄情者なのでは御座いませんか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女三　そう云えば、初めからそんな薄情者のような気がしたわねえ。",
              "citation": {
                "source": "世評（一幕二場）",
                "author": "A morality",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か一瞬悲しい声のざわめきをあげて、後に姿を消した家から、「薄情者ッ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかキセキはあらわれないものか何とかどうにか出来ないものか私が働いている金はどこへ逃げて行くのだろうそして結局は薄情者になりボロカス女になり死ぬまでカフエーだの女中だのボロカス女になり果てる私は働き死にしなければならないのだろうか！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかキセキは現はれないものか何とかどうにか出来ないものか私が働らいてゐる金はどこへ逃げて行くのかそして結局は薄情者になりボロカス女になり死ぬまでカフエーだの女中だの女工だのボロカス女で私は働き死にしなければならないのか！",
              "citation": {
                "source": "蒼馬を見たり",
                "author": "蒼馬を見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう（畜生、徳子、薄情者）　と、罵りつつ、それでいて、恋しさに、眠れぬ眼を、見えぬ昼間の家の方へ向けて（そこにいるなら、徳子、おれが、こんなになっているのを見せてやろうか）　と、いうような呪、愚痴。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が「お春さん――益満は、そんな、薄情者じゃない。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中は、広いんだから、旅にでも出てしまって――）　そう、時々は、考えもするが、益満と、庄吉との、愛欲の夜を思い出すと――頭の中で（誰が、あんな薄情者に――）　と、思っても、肌が、血が、愛着の味を忘れないでいた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな薄情者だから、田舍のあんないゝ子供さんたちのことだつて、見てやれないんぢやないか。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "姐さんは我利々々の凄腕の冷めたくって薄情者の男だましの天才なのよと色々と内幕をあばいてきかせる。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうお前は薄情者か！",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たゆ」は実は薄情者の癖に、一見人懐こく、少しも人見知りをしない。",
              "citation": {
                "source": "打出の小槌",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンデン　あなたは實際私をそんな薄情者だと思つていらつしやるの？",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は薄情者ではない、わたしが匿してゐると同じ心の向きを持つてゐる。",
              "citation": {
                "source": "神のない子",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "筒井は男を怨むとか薄情者であるとかいう観念を持たず、ただ健やかであれと思うほかは淡い気持であった。",
              "citation": {
                "source": "津の国人",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだ者のことを惡く言つちや濟みませんが、あの男は、腹の底からの薄情者でしたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘の守袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "造酒助は薄情者らしいから、肝を潰して家の中へ引返し、女房のお余野にそっと言ったかも知れない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は口惜しいから、甲子松に喰ってかかると、お嬢さんがすっかり喜んで、家中は、薄情者揃いだけれど、お前一人が頼もしい、そこを見込んで一生のお願いがある。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもう私が彼の前に出て行つても「戀人」だの「いとしい人」だのといふ甘い言葉で呼びかけることはなく、私にかける一番よい言葉と云へば「癪にさはる人形」とか、「意地惡の妖精」とか、「薄情者」、「とりかへ子」等であつた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は口惜しいから、甲子松に喰つてかゝると、お孃さんがすつかり喜んで、家中は、薄情者揃ひだけれど、お前一人が頼もしい、そこを見込んで一生のお願ひがある。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなたは薄情者よ、あたしはそのことをどんなに有難く思っているかしれないのに。",
              "citation": {
                "source": "葦は見ていた",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、薄情者、革命党、無法者、虐殺人！",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はいつからそんな薄情者になったのよ」「だからさ。",
              "citation": {
                "source": "桜の森の満開の下",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この浮気男め、薄情者め。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄情者めが、よくもそうしゃあしゃあした面ばかりが揃ったものだ」と、年景はまるで、この不愉快な事件が、すべて他人のせいであるように罵って、「出て行けっ」と、部屋を揺るがすような声でわめいた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、お粂の嵐粂吉が、この甲府の柳町の小屋を打ってまだ日の浅いうちに、先生が安価な折花攀柳をやったのは、あらそい難い事実であると見えまして、「寄ってゆかない、この人は」「薄情者」「素どおりはひどい」　などと、この昼なか、多少人前というものもあろうに、容赦なく袂をつかんで、格子の前を離しません。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
