[
  {
    "uuid": "b2d9d1a0-99dc-55b4-9457-4ed3a8486322",
    "entry": "拝謁",
    "reading": {
      "primary": "はいえつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
