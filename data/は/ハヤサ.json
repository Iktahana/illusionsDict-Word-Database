[
  {
    "uuid": "f53fc98f-e4d3-5d95-92c9-25ff48766c49",
    "entry": "速さ",
    "reading": {
      "primary": "はやさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
