    "definitions": [
      {
        "index": 1,
        "gloss": "to do",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たづきも知らに、わが喰むむぎの蒼さより、あはれはるばる、み空をながれ汽車は行く。",
              "citation": {
                "source": "旅上",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ　いのちの孤獨、われより出でて徘徊し、歩道に種を蒔きてゆく、種を蒔くひと、みづを撒くひと、光るしやつぽのひと、そのこども、しぬびあるきのたそがれに、眼もおよばぬ東京の、いはんかたなきはるけさおぼえ、ぎたる彈く、ぎたる彈く。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔ゆがみつゝ月は出で〕宮沢賢治ゆがみつゝ月は出でうすぐもは淡くにほへり汽車のおとはかなく恋ごゝろ風のふくらしペンのさやうしなはれ山の稜白くひかれり汽車の音はるけくなみだゆゑ松いとくろしかれ草はさやぎてわが手帳たゞほのかなり",
              "citation": {
                "source": "〔ゆがみつゝ月は出で〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭日〔二〕宮沢賢治アナロナビクナビ睡たく桐咲きて峡に瘧のやまひつたはるナビクナビアリナリ赤き幡もちて草の峠を越ゆる母たちナリトナリアナロ御堂のうすあかり毘沙門像に味噌たてまつるアナロナビクナビ踏まるゝ天の邪鬼四方につゝどり鳴きどよむなり",
              "citation": {
                "source": "祭日〔二〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶は雪のふる都會の夜にしづかな建築の家根を這ひまはるさびしい青猫の影の影記憶は分身のやうなものだ。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等と交はることは、私にとつてちがつた宇宙への觀察だつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、織田君の哀しさを、私はたいていの人よりも、はるかに深く感知していたつもりであった。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はるかに紫禁城を眺めている横顔の写真。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁さんを迎えに、はるばる北京からやって来たのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに気乗りがしないのなら、なぜ、はるばる北京からやって来たのだ、と開き直って聞き糺したかったが、私も意気地の無い男である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　良子は、さう云ひながらあじとお祖母さんとをかはるがはるに見てゐる小僧の顔を、ヂツとみてゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉と眉との間に皺を寄せたり伸ばしたりしながら、竿のあちらの端とこちらの端をかはるがはるに見てゐた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "水鳥や舟に菜を洗ふ女あり　と共に、蕪村の好んで描く水彩画風の景趣であって、薄氷のはる冬の朝の侘しさがよく現れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村はこの外にも、君あしたに去りぬ夕べの心｜千々に何ぞはるかなる君を思ふて岡の辺に行つ遊ぶ岡の辺なんぞかく悲しき　という句で始まる十数行の長詩を作ってる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなれば追はるる如く歳暮の忙がしき街を憂ひ迷ひて晝もなほ酒場の椅子に醉はむとするぞ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りて書物を投げすてひとり校庭の草に寢ころび居しがなにものの哀傷ぞはるかに彼の青きを飛び去り天日直射して　熱く帽子の庇に照りぬ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡しきものに逢ひけるよ、と思ふまもなく、つかつかと歩みよりて、なつかしげに物言はるるに、こはけれど遁れゆくべきにあらず。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか知らねど萩原朔太郎なにか知らねど泣きたさにわれはゆくゆく汽車の窓はるばるときやべつ畑に日は光り風見ぐるまきりやきりりとめぐる日にわれはゆくゆく汽車の窓なにか知らねど泣きたさに",
              "citation": {
                "source": "なにか知らねど",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雲の国に徂徠する天人の生活を夢想しながら、なおはるかな南の地平線をながめた時に私の目は予想しなかったある物にぶつかった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それははるかなはるかな太平洋の上におおっている積雲の堤であった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年の長い歳月を費し、しかも大敗の憂目を見ること三度、やうやうにして首里よりはるか遠くの石垣島を占領したあの苦しみも忘れてしまふ程であつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と興覺めた事を言ひ、また、お婆さんも、「いのちにかかはるものではないでせうね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "辨天樣の池畔などで、ぐつたり寢そべつて甲羅を干してゐるのは、あれは、いしがめとでもいふのであらうか、繪本には時々、浦島さんが、あの石龜の脊に乘つて小手をかざし、はるか龍宮を眺めてゐる繪があるやうだが、あんな龜は、海へ這入つたとたんに鹹水にむせて頓死するだらう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもまた、見渡す限り、ただ薄みどり色の茫洋乎たる大空洞の片隅に、幽かな黒一點をとどめてゐるものが、たとひそれは嘘にしても月の影法師だと云はれて見ると、鯛の大群や火事だと思つて眺めるよりは、風流人の浦島にとつて、はるかに趣きがあり、郷愁をそそるに足るものがあつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりや、陸上からはるばるたづねて來た珍客ですもの、それにあなたは、私の恩人ですからね、お出迎へするのは當り前ですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　眼を擧げて見ると、はるか上方に、魚の天蓋がのどかに浮び漂つてゐるのが、青く霞んで見える。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
