    "definitions": [
      {
        "index": 1,
        "gloss": "spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春風ですよろこびやがれ凡俗！",
              "citation": {
                "source": "春の日の怒",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはこれら彼の作品が、大正十三年頃、つまり「春と修羅」が出た頃に認められなかつたといふことは、むしろ不思議である。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は彼の詩集、「春と修羅」を十年来愛読してゐますが、自分が無名のために、此の地方で印刷された驚くべき詩集を、皆さんにお知らせする術を持ちませんでした。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああふるさとの永日に少女子どものなつかしさたとしへもなきなつかしさやさしく指を眼にあててももいろの秋の夕日をすかしみるわが身の春は土にうもれて空しく草木の根をひたせる涙。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "まひる利根川のほとりを歩めば、二人歩めばしばなくつぐみ、つぐみの鳴くに感じたるわが友のしんじつは尚深けれども、いまもわが身の身うちよりもえいづる、永日の嘆きはいやさらにときがたし、まことに故郷の春はさびしく、ここらへて山際の雪消ゆるを見ず。",
              "citation": {
                "source": "利根川の岸邊より",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "機会宮沢賢治恋のはじめのおとなひはかの青春に来りけりおなじき第二神来は蒼き上着にありにけりその第三は諸人の栄誉のなかに来りけりいまおゝその四愛憐は何たるぼろの中に来しぞも",
              "citation": {
                "source": "機会",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔なべてはしけく　よそほひて〕宮沢賢治なべてはしけく　　よそほひて暁惑ふ　　　　　　改札をならび出づると　　ふりかへる人なきホーム　　　陸の橋歳に一夜の　　　　旅了へしをとめうなゐの　　ひとむれに黒きけむりを　　　そら高く職場は待てり　　　春の雨",
              "citation": {
                "source": "〔なべてはしけく　よそほひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春愁」は傑作でさへあります。",
              "citation": {
                "source": "書信",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造は今春大学を終へた。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　翌年の春になつて暖かくなると、忠魂塔の下に遊びに行つたものださうだ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後三十年、思へば「私の青春は嵐に過ぎなかつた、時々其処此処に陽の光のちらついた」、詩さながらではなかつたか。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "春晝――敍情小曲――萩原朔太郎うぐひすは金屬をもてつくられしそは畔の暗きに鳴き菫は病鬱の醫者のやうに野に遠く手に劇藥の鞄をさげて訪づれくる。",
              "citation": {
                "source": "春晝",
                "author": "――敍情小曲――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、当時の彼の詩は、青春の感情の奔蹤を極めたものであつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私共は、既にかうした青春時代の花やかな、とはいへいくぶん狂気じみた創造の夢を過去に微笑して観ることさへもできる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の一つの影は、逞ましく肉づいた青春の情慾と健康と、及びその放蹤無恥な感情の乱酔を語つた、世にも水水しい情熱の詩篇であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて大久保の新居に移った時は、春の麗らかな日であって、裏の竹藪で鶯がしきりに鳴いてた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある晩秋の日に、庭の桜が返り咲きをしたのを見て、『春のように暖かいから、桜思いました。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は佐藤春夫、室生犀星、北原白秋、千家元麿、高村光太郎、日夏耿之介、佐藤惣之助等の諸君の詩を、たいてい忠實に讀破してゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（文壇で我々の自由詩が解る人は、室生犀星、佐藤春夫の詩人小説家を除いて、實に芥川龍之介一人あるのみだつた）概ねの場合に於て、彼の詩の批判は正しかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの點から、自分は彼を室生君や佐藤春夫君――その人たちは疑ひもなく詩人である。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に月々の「文藝春秋」に出すアフォリズム風の文字（侏儒の言葉）は、機智のために機智を弄する弄筆者流の惡皮肉で、憎惡的にさへ不滿を感ぜずに居られなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にその「文藝春秋」に連載された「侏儒の言葉」や、私の所謂印象的散文風な短文やを見ると、いかに彼の文學本質が、詩人といふに遙かに別種の氣質に屬するかを感じさせる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣菫氏の詩は、その初期の物（暮笛集・ゆく春）ほどよく、純粹なリリシズムが盛られて居るのに、自選詩集には、却つてその詩情を稀薄にした後期の敍事詩風の作が多く入れられてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、妹さえ丈夫でございましたならば、私も、少し気楽だったのですけれども、妹は、私に似ないで、たいへん美しく、髪も長く、とてもよくできる、可愛い子でございましたが、からだが弱く、その城下まちへ赴任して、二年目の春、私二十、妹十八で、妹は、死にました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青春というものは、ずいぶん大事なものなのよ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの早春に、私はこの甘酒屋で異様な男を見た。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春と夏と秋と冬と一年に四回ずつ発行のこと。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年の春であったか、私は山田勇吉君の訪問を受けた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は、昨年の春、同じ学部の若い教授と意見の衝突があって、忍ぶべからざる侮辱を受けたとかの理由を以て大学の講壇から去り、いまは牛込の御自宅で、それこそ晴耕雨読とでもいうべき悠々自適の生活をなさっているのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
