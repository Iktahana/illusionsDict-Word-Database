[
  {
    "uuid": "916b853f-b213-53db-83a9-9866af062294",
    "entry": "波磔",
    "reading": {
      "primary": "はたく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
