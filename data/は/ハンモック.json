        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――しかしやがてイスポリの燈台を離れて、エルアルズのコーカサスの山脈が静かに黒海に映るころになって、トレビゾンドの赤土のプラットホームに女実業家達が下車すると夜は神秘に地球はハンモックのなかで眠りだすのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻は労働者のように終日こつこつと働いて食うし、蜘蛛は資本家のように、暑い夏の日を、梢から枝へとハンモックを釣って、その上に寝ていて食っている。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が、ただ一つ残されたハンモックを天井に釣りはじめた時、その隣で寝ていた魚崎や大辻が眼をさました。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦長に対してどう御返事をしたのだ」　杉田はハンモックの中にもぐりこんだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僚友たちも、それをみると、やや安堵して自分のハンモックにかえっていった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "非番の水兵たちは、梁につりわたしたハンモックの中に、ぐっすり眠っていた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、優しくも五弦琴を掻き鳴らす者もあり、各自にいろいろな娯楽に興じたり、ハンモックの中で悠閑な眠りを貪ることも出来た。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "玩具箱がひつくりかへつてゐたし、ハンモックも吊つたなりだつた。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣太郎は、ハンモックの中へ、帽子や土産物を投げいれて、臺所に二本並んでゐるビールを座敷へ持つて來て、一人で栓をぬいてごくごく飮んだ。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋はハンモックのやうに揺れた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が舟へ飛び乘ると、屋根つきの細長い船はしばらくハンモックのやうに左右にゆれ動いた。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "清少年と※代さんは、ハンモックの中で眠られぬ一夜をすごしたが、明くれば二月二日、今日こそは、いよいよ『鬼の島』碧海島の秘密がわかるのだ！",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも、ハンモックに揺られて、よく寝ていたものだから、やめにしたんだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは鳥のように高い空をとぶこともできるし、ハンモックもないのに空中で昼寝をすることができますわ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁に添ってハンモックが釣るされてあったが、そこには、人間が寝ていずに、和蘭あたりの船長でも着そうな、洋服が丸めて置いてあった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに幾本かの麻縄を結び、その端に、ハンモックを取付けた。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、はやく、ハンモックへ乗りたまえ」　老博士は、僕等を促した。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、一刻もはやく、ハンモックに乗りたまえ」「…………」僕等は、もう拒むことも出来ず、ハンモックに乗った。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "試しに、あの風船に乗って見ようか」「よかろ」二人は、ハンモックを離れて、畳のように海面に拡がった風船に這い上った。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはハンモックじゃないですか」「そう。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ軍人のベッドはハンモックでたくさんだ」　そういうと、少佐はハンモックをかついで三階へあがっていった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンモックだったのか」　源一はアメリカ軍人の簡易生活におどろきながら、少佐のハンモック吊りを手つだった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "対角線にハンモックを吊った。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少佐は三階へハンモックをもちこんで、はすかいにつった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど事もなき艦橋の上の夜、韓海の夏暑くしてハンモックの夢結び難き夜は、ともすれば痛恨｜潮のごとくみなぎり来たりて、丈夫の胸裂けんとせしこと幾たびぞ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど解きても融け難き一塊の恨みは深く深く胸底に残りて、彼が夜々ハンモックの上に、北洋艦隊の殲滅とわが討死の夢に伴なうものは、雪白の肩掛をまとえる病めるある人の面影なりき。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
