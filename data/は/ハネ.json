    "definitions": [
      {
        "index": 1,
        "gloss": "feather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "造花造りの羽振のよさは、あゝ、滑稽なこつた滑稽なこつた。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織袴を忘れずに、帽子はなるべくアミダに冠らないやうにして、六ヶ敷い顔をして、理想を前例に照して持つてゐれば、近所知己の評判は良いのでありませう。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "銘仙の袷に金紗の羽織を着、兎の毛で縁をとつたオールドローズの繻子の肩掛に寒々とくるまり、海老茶の袴を胸高く穿いてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかしねえ」と、その傍にゐた会社員風の男が睡さうに云つた、「音羽屋のを見てからは見られませんよ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いやいや、大して違ひはありますまい」と語尾を上げて、爺々ィが云つた、「音羽屋の方が所作はうまいかしれないが、ハリマ屋の方はスゴミがあるツ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな田舍臭い百姓歌の主人公が、灯ともし頃に羽織をきて、新宿の宿場を漂泊して居るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　羽左衛門の私生活なども書いてみたい。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」けれども、私は、男女川の小説も、羽左衛門の物語も、一生涯、書く事は無いだろう。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶん痩せ細っているようであったけれども身丈は尋常であったし、着ている背広服も黒サアジのふつうのものであったが、そのうえに羽織っている外套がだいいち怪しかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚は、大仰な言いかたをすれば、鶯の羽のような汚い青さで、まったく光沢がなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の部屋の窓を夜どおし明けはなして盗賊の来襲を待ち、ひとつ彼に殺させてやろうと思っているのであるが、窓からこっそり忍びこむ者は、蛾と羽蟻とかぶとむし、それから百万の蚊軍。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは学生服をきちんと着て、そのうえに、ぶくぶくした黄色いレンコオトを羽織っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前日、新宿の百貨店へ行って結納のおきまりの品々一式を買い求め、帰りに本屋へ立寄って礼法全書を覗いて、結納の礼式、口上などを調べて、さて、当日は袴をはき、紋附羽織と白｜足袋は風呂敷に包んで持って家を出た。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小坂家の玄関に於いて颯っと羽織を着換え、紺足袋をすらりと脱ぎ捨て白足袋をきちんと履いて水際立ったお使者振りを示そうという魂胆であったが、これは完全に失敗した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私はわけのわからぬ言葉を発して、携帯の風呂敷包を下駄箱の上に置き、素早くほどいて紋附羽織を取出し、着て来た黒い羽織と着換えたところまでは、まずまず大過なかったのであるが、それからが、いけなかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮分別の深い結納のお使者は、ひどく酔いました、これは、ひどく酔いました、と言いながら、紋附羽織と白足袋をまた風呂敷に包んで持って、どうやら無事に、会津藩士の邸宅から脱れ出ることが出来たのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　においが有るか無いか、立ちどまって、ちょっと静かにしていたら、においより先に、あぶの羽音が聞えて来た。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜜蜂の羽音かも知れない。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤黒い顔に鉄縁の眼鏡を掛け、紋付羽織が好きで何時もその広い胸ははたけられてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日が来ると羽織袴の、揃つて粗雑な顔をした運動員達が道場の内や外を迂路ついてゐるのが見られた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の笑といふ笑は哄笑であり、その度に鳩尾の上辺りに垂れてゐる白の、幅広く厚くもある旧式の羽織紐が、トロントロンと揺れた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬には、羽織を脱いでそれを折りたゝんで「兜」にして冠る遊びがあつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と幸福との間に一羽の鷲が――不幸なこつた不幸な！",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山麓の小家の周囲を、夏の羽蟻が飛んでるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この表現効果の主要点は、羽蟻という小動物。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち読者は、羽蟻という言葉によって、そうした高原地方の、夏の日中の印象を与えられてしまうのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし羽蟻は絵に描けない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こうした刈入時の田舎の自然と、収穫に忙しい労働の人生とが、屋根の上に飛びあがった一羽の鶏の主観の影に、茫洋として意味深く展開されているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永日和讚萩原朔太郎ひとのいのりはみなみをむき、むぎはいつしん、うをはいつしん、われはしんじつ、そらにうかびて、ゆびとゆびと哀しみつれ、たましひはねもごろにほとけをしたふ。",
              "citation": {
                "source": "永日和讚",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
