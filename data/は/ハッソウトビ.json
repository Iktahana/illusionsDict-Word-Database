    "definitions": [
      {
        "index": 1,
        "gloss": "leap up from the initial charge in order to surprise the opponent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
