        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに歯向かうには真実で歯向かうほかはない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間じゅうの人に歯向かうんだわ。",
              "citation": {
                "source": "大ヴォローヂャと小ヴォローヂャ",
                "author": "ВОЛОДЯ　БОЛЬШОЙ　И　ВОЛОДЯ　МАЛЕНЬКИЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かっとなったり、いきり立ったり、やけくそで抵抗したが、武装警官に歯向かうのは論外だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカ犬婦連の大軍に歯向かうことの意味を思い知らせてやるのです！",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "能因　　それはむかうの勝手だが、こゝへ押掛けて來られては甚だ迷惑。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けむりのやうにはびこる憂欝、はりねずみのやうに舞ふ苦悶、まつかに焼けただれたたましひ、わたしはむかうの岡のうへから、やみつかれた年寄の馬をつれてこようとしてゐる。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ひとりごとのやうにさういつて、男はむかうへいつてしまひました。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳生一刀流にはむかう気なら、かかってこい」　なんかと、駕籠かきと長屋の人々と、ワイワイいう騒ぎだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと彼はむかうに見おぼえのある紅殼色のバンガロウを見る。",
              "citation": {
                "source": "ルウベンスの僞畫",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人はむかうの離れにゐるらしい。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十面相に、はむかうやつは、だれでも、こういうめにあうのだということを、はっきり知らせてやるのだ。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
