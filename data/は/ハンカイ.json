[
  {
    "uuid": "69fd7b30-21d7-53d2-a6cf-ffeea7388087",
    "entry": "半解",
    "reading": {
      "primary": "はんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
