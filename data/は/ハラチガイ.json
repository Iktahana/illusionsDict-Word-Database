    "definitions": [
      {
        "index": 1,
        "gloss": "half- (sibling by a different mother)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
