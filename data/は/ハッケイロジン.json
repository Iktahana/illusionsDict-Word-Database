    "definitions": [
      {
        "index": 1,
        "gloss": "White Russian emigre",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
