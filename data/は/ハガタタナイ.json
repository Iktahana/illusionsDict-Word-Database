[
  {
    "uuid": "aa561728-14a2-5430-beef-011723cc9993",
    "entry": "歯が立たない",
    "reading": {
      "primary": "はがたたない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
