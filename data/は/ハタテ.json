        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私たちはいまにだんだん深い処へさえ来れば、兵隊たちはたてがみにとりついて泳ぎ出すだろうと思って待っていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはいまにだんだん深い処へさへ来れば、兵隊たちはたてがみにとりついて泳ぎ出すだらうと思って待ってゐました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「風のない時はたての棒、風の強い時は横の棒、その他はみみずなどの形。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの松原は松露があると、宿で聞いて、……客はたて込む、女中は忙しいし、……一人で出て来たが覚束ない。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠目に濁る蒼海の色こそあかれ、黒潮の水脈のはたての水けぶり、はた、とどろ撃つ毒の砲弾、清しき喇叭、薄暮の朱のおびえの戦に疲れくるめく衰ぞああ音を搾る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "国土のはたてに我は来りけり薄紫の馬鈴薯の花「これはどうだい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しげらへる森のはたてに。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒涼たる焼石の原から、柔かい緑の丘へ、二頭の馬はたてがみで高原の涼風を切る。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "で僕は肩にかけてゐる望遠鏡を取りだして、見定めようと試みたのだが、切りに駆け回つてゐる最中で騎手の顔はたてがみにかくれて、その上ハンチングを眼深かにかむつてゐるのでたれとも判別し難いのであつた。",
              "citation": {
                "source": "娘とドリアン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はたてつくようになり、自分の権利を主張し、そしてついにある舞踏会へぜひとも行きたいと言い出す。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝燒雲、空のはたてに低く細くたなびきて、かすけき色に染まりたる、野に出でて見よ、滴る露の中に瓜の花と蜂の群とが無數に喜び躍つてゐる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "夏のよろこび",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹はたてども飯ばかり喰いぬ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「母の初七日の時もね、わたしはたて続けにビールを何杯飲みましたろう。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "功名はたてておきたいもので、これが普通の与力同心ならば、ごく内密にといったそのことばのてまえ、容易に披見は許されないはずですが、右門の才腕がものをいいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら敬公だっても、そのくらいなてがらはたてるだろうよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう音はたてないでね。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "身動迂き旅人の雲のはたてに消ゆる時。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨きあげた足の踵は、鶯張りの縁側を歩いても音はたてまいと思はれるやうなたをやめで……。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて声だけはたてなくなったが、彼女ははふり落ちる涙を、何時までたってもとどめ得なかった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あ　鸚鵡の口に戸はたてられず。",
              "citation": {
                "source": "藤村いろは歌留多",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "露骨に笑い声はたてないが若い女房は皆笑っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "常夏",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくこのまま聞いていたく薫は思うのであったが、音はたてずにいても、薫のにおいに驚いて宿直の侍風の武骨らしい男などが外へ出て来た。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶はたてるごとに、それぞれ個性を備え、水と熱に対する特別の親和力を持ち、世々相伝の追憶を伴ない、それ独特の話しぶりがある。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたてつづけに三四杯飲む。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の宿は、空襲後に建てたバラックらしく、五部屋位のものだつたが、案外客はたてこんでゐて、壁隣りは賑やかに笑ひさゞめいてゐる。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大晦日迄はたてこんでゐた醉月も、元日には客といつては三田一人で、三番の野呂も休暇を利用して東京にゐる妻子のところへ行つてしまつた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　蟒はたて續けにコツプ酒をあふりながら、支店長を尻目にかけて、口から出まかせの毒口をきいてゐた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶の花はたてゝもにても手向かな軒端もや扇たるきと御影堂角二つあるのをいかに蝸牛元日や何にたとへむ朝ぼらけというもあった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
