        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腹が減ると饑えは充分感じるのだが、うっかり喰べる気はしなかった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山越しをするには腹が減るといけないと思って、食い物をたくさん買い込んで来たのですが、そうも食えないもので……。",
              "citation": {
                "source": "木曽の旅人",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きているから腹が減るのは止むを得ないという連中ばかりが、元来持って行き処のない尻を俺の処へ持って来るんだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら××したつて、貴方達の腹が減る位だよ。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が減ると、かれは立つて行つて、七輪に火を起した。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が減るという現象が心に起ればこそ飯が旨いという現象が次いで起るので、必ずしも料理が上等だから旨かったとばかりは断言できにくいのであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日十五六時間も働いて、日の長いのに三度の飯は腹が減るのは無理もなかった。",
              "citation": {
                "source": "苦力頭の表情",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きとると腹が減る！",
              "citation": {
                "source": "とも喰い",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸所放浪しているうちに、或日、或時、或村へ差しかかると、しきりに腹が減る。",
              "citation": {
                "source": "文芸の哲学的基礎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "タンタラスは腹が減る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さぞ腹が減ることと同情したが、何の風情もない。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "点検が済んだら、すべからく寝て鋭気を養うべしだ」言いつつ菓子皿に残れるカステーラの一片を頬ばり「むむ、少し……甲板に出ておると……腹が減るには驚く。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が減るとなにかにつけて猜疑心が強くなり、社長クラスや高等官クラスまでが炊事場へ押しかけ、飯上げ当番の手元に注視していて、「君は、君の食器と誰々の食器に飯を押しつけて盛った。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分の前だが、巣鴨から神田迄驅けて來ると、隨分腹が減るぜ」　八五郎が寒天に大汗を掻いて飛込んだのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "若樣の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "――くたびれたか」「疲れたわけぢやありませんが、下手人の見當でも付かなきや、腹が減るばかりで」「下手人はわかつて居るのだよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "晒し場は招く",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は粗朶置場へ寝る、またどこかの納屋の中で……腹が減るとごったく屋の裏口を覗き廻る、それから墓場へ、そこにも飯や菓子が供えられてあるから。",
              "citation": {
                "source": "お繁",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかい、秋の夜は腹が減るもんだからなあ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生きていれば、腹が減るものと、いま気がつくなんざ、滑稽だな。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はらがへるどころか、じっとしてたら、死んでしまうんだからね。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
