    "definitions": [
      {
        "index": 1,
        "gloss": "hand-to-hand combat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
