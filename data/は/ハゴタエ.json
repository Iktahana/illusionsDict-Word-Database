        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが今の巻煙草では灰皿を叩いても手ごたえが弱く、紙の吸口を噛んでみても歯ごたえがない。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人は一見乾燥なように見える抽象的系統の中に花鳥風月の美しさとは、少し種類のちがった、もう少し歯ごたえのある美しさを、把握しないまでも少なくも瞥見する事ができるだろうと思う。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を判然して出直して、切物か、刃物の歯ごたえのあるようにして、私に断然、（女と切れない。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも思煩った所で、彼方の女に何の歯ごたえがなくとも仕方がないと諦めて居た。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌があれていると、味がわからなくて、ただ量、或いは、歯ごたえ、それだけが問題になるのだ。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "数は一つ減りましたが、問題の質は格段にむつかしくなりましたから、十分歯ごたえがあると思います。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯ごたえがありすぎる！",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、もう第十二階選士になられたのですから、これくらいの歯ごたえがないとお気の毒に存じまして、かくの通り……。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ歯ごたえがございますよ。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブロイラーのたよりない柔らかさとは遠く、歯ごたえがあり味が深い。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもタケシに、理科的な素養がなければ、おそらくはこうした歯ごたえのある本は、途中で投げ出していたのかもしれない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方で機能はタイニーベーシックとしては多めに盛り込み、バグを見つけだすための仕掛けも充実させて、経験者にも歯ごたえのあるものとするよう努めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄貴、上方には美い女がいるなあ、随分美い女がいるけれど、歯ごたえのある女はいねえようだ、口へ入れると溶けそうな女ばかりで、食って旨そうな奴は見当らねえや」　まだ宿へ着かない先に、町の中でがんりきがこんなことを言いながら、町を通る京女の姿を見廻しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "がんりきの奴、その時分とは、こっちの歯ごたえが少し違うものだから、やきもきしている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、歯ごたえが強く、中間の肉に優るものがある。",
              "citation": {
                "source": "塩鮭・塩鱒の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうすることによって中身はエキス抜きにならないから、噛むと魚の好味が出て、歯ごたえもあり、至極美味い。",
              "citation": {
                "source": "道は次第に狭し",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴちぴちはねている生き物を自分の手でしっかり押さえつけて、頭がらガリガリとかじるのにくらべては、歯ごたえがなかった。",
              "citation": {
                "source": "白いくま",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蟹は、一般には、越前蟹と呼ばれているが、肉は白い大理石のような色をしていて、きめのこまかい締った肉の歯ごたえが、誰にも喜ばれている。",
              "citation": {
                "source": "母性愛の蟹",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを手助けにして、歯ごたえのあるごちそうを噛み砕き、精神的に咀嚼してみせようとしていたのだ。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂肪と歯ごたえのある肉との甘い匂いが、室の中にたちこめている。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川は、全く下り坂で、旗本も腰が抜けてしまった、関東の武士も今は怖るるところはない、ただ新徴組の一手と――それに東北の質樸な国侍に歯ごたえがある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待て、待て、ちと歯ごたえのある勝負がしてみたいわ」　かの壮士は竜之助の気勢を見てかえって喜んだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "壬生と島原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその葉はまだ稚すぎたと見えて、歯ごたえがほとんどなく、それほど旨くはなかった。",
              "citation": {
                "source": "庭の眺め",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯ごたえもなければ、香りも、味も、そっけもない、泡沫の固まりのようなものだ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを煮ると、白味が焦げついても、黄味のしんはジャリリ、と冷たい歯ごたえ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが通称フンドシで、タラバガニのそのフンドシは普通のカニとちがって、ゆでるとカマボコみたいな歯ごたえの、うまい身がはいっている。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎の前へ投げられた一片の肉ほどな歯ごたえも任原には感じまい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
