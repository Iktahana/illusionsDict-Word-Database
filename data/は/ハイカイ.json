[
  {
    "uuid": "06081d96-9bec-5a1b-be2a-98640bb0481f",
    "entry": "俳諧",
    "reading": {
      "primary": "はいかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
