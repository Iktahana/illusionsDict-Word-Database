    "definitions": [
      {
        "index": 1,
        "gloss": "carrying in (esp. heavy objects, artwork, furniture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "既に食物搬入は済んだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室への機材搬入の費用は、思わぬところから転がり込んできました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ明日は收納日といふ日の前日、村の耕作者組合では、全組合員の荷をトラツクに積んでＮ町の收納所に搬入した。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷は、搬入場に、各個人別にまとめて積んだ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼等は昨日の搬入場へ來て、自分達の荷を調べ、提出順をきめるのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃搬入場にやつて來るるものはしかし彼等だけではなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四間に十二間の收納所の建物は、ほぼ中央で、黒いカーテンに仕切られ、こつち側が事務所や搬入場で、向う側は鑑定所に荷造場だつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "搬入場の入口から吹き込む風は冷たく、コンクリートの床は冷えて、腰から下は冷え切つてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所は搬入場の入口を入つたつきあたりだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分達の荷は全部運び出され、代りに明日收納される荷が運び込まれてゐる廣い搬入場に、百姓達はふるへながら立つてゐた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会の搬入締切日がだんだん近づいて来るし、決定的な構図が頭に浮かんで来ない。",
              "citation": {
                "source": "健康と仕事",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "あずま琴などとも言ってね、その名前だけでも軽蔑してつけられている琴のようですが、宮中の御遊の時に図書の役人に楽器の搬入を命ぜられるのにも、ほかの国は知りませんがここではまず大和琴が真先に言われます。",
              "citation": {
                "source": "源氏物語",
                "author": "常夏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の早朝、新宿郵便局に郵便番号自動読み取り機が搬入され、これに抗議するデモ隊は夜になっても局を取り巻いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その直後に東北大学の通信研究所に搬入されたＳＥＮＡＣは調整に手間取ったものの、同年の十一月には動きはじめた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「みづゑ」大正十二年一月）鑑査の日　会場へ搬入された夥しい絵が、女達の手によって十枚位ずつ、われわれの前に運ばれて来る、そしていいのは予選の部に入る、何としても見込みのないのは落ちてしまうのだ。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年の二科帝展等の出品搬入数を見ても驚くべき数を示している。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶菓は精養軒で出して貰い、折詰の料理と豊富な酒類はよそから搬入された。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐世保軍港で、得態の知れぬ兵器を搬入したことがあったが、あれに違いない。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の小品に相当に佳いものがあったので、彼女も文展に出品する気になって、他の大幅のものと一緒にそれを搬入したが、鑑査員の認めるところとならずに落選した。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の小品に相当に佳いものがあつたので、彼女も文展に出品する気になつて、他の大幅のものと一緒にそれを搬入したが、鑑査員の認めるところとならずに落選した。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八年六月、大日本印刷株式会社市ヶ谷工場にトラックで搬入された累々たる苦心の原稿が、やがて校正刷になって返って来る。",
              "citation": {
                "source": "『広辞苑』後記",
                "author": "新村出",
                "note": "青空文庫"
              }
            },
            {
              "text": "膝まであるフェルトの防寒長靴をはいて、裏から羊毛がもじゃもじゃよれたれ下っている短皮外套をきた五人の若くない労働者が搬入の仕事をやっていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "搬入もすまして――ひとつは、その疲れがあったのかもしれませんわ」　二人は、磯崎恭介の横わっている寝台を見下しながら、小声で話すのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにして頂くし、入選のこともわかりましたし……」　恭介が死ぬ一日二日前に、自分で搬入した静物がサロン・ドオトンヌに入選した。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "所はこれ東西大陸の中心、完全なる天文台は、敢て経費の支出を俟たず、地球上に存在せる、あらゆる材料を搬入して、立所に出来て仕舞った、また同盟会議所のごときは、優に一億万人を収容するに足るべき大殿堂であるが、ここには各国から簡派したる、各階級の議員が、充満しておるのである。",
              "citation": {
                "source": "太陽系統の滅亡",
                "author": "木村小舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "コレ即チ清教徒ガ新世界上陸ノ基点ニシテ、世界殖民ノ歴史ニ異彩ヲ放テルぷりまうすノ事業モまた茲ニ始ル」　駒井甚三郎は直参失脚の後に於て、その爵位財産の一切を返還してしまったが、蔵書だけは、ほとんどその全部をこの船に搬入して来ています。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ糧道の遮断が無意味だというか」と、急きこんで更に――「つい後の月にも、毛利家の糧船二百余艘が魚住の岸に寄って、三木へそれを搬入せんとしたのを断乎追いしりぞけ、そのほかの道でも、密輸の糧米をたえず抑えている。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とにかく不破氏が帰って来てから、その所存をただしてみよう」「とにかく荷物を搬入した方がいいね。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
