    "definitions": [
      {
        "index": 1,
        "gloss": "the eight gods who preside over the lucky/unlucky directions of the traditional calendar for each year (in Onmyōdō)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また八将神と申すものがある。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その王子が八将神であるというがごときは、だれありて信ずるものはなかろう。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "八将神のほかに人の最も恐るるものは金神である。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "このゆえに、牛頭天皇南海よりかえりたまうとき、八将神を遣わして討ち平げたまう。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、八将神と申すものが暦中に掲げてある。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "年を越すとは昨冬の雷鳴が、その方面に聞こえたということと思うが、近世の暦の八将神のものものしい名前なども、やはりこういう民間の古い習わしから、出ていたことが考えられるのである。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
