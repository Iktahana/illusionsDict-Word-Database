        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "杜の杉にはふくろふの滑らかさ、昆布の黒びかり、しづかにしづかに溶け込んで行く。",
              "citation": {
                "source": "ラジュウムの雁",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざえもんは　くろいあたまをくうらりくらり、　とんびとうざえもんは　あぶら一｜升でとうろりとろり、　そのくらやみはふくろうの　いさみにいさむもののふが　みみずをつかむときなるぞ　ねとりを襲うときなるぞ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはまっ黒な土があたたかにしめり湯気はふくふく春のよろこびを吐いていました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窪地はふくふくした苔に覆われ、所々やさしいかたくりの花が咲いていました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやにまじめくさった彼女の頬はふくれていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざゑもんは　くろいあたまをくうらりくらり、　とんびとうざゑもんは　あぶら一升でとうろりとろり、　そのくらやみはふくろふの　いさみにいさむものゝふが　みゝずをつかむときなるぞ　ねとりを襲ふときなるぞ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥はみんな興をさまして、一人｜去り二人｜去り今はふくろうだけになりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の書体はふくよかで美しかつた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ったら、青砥はふくれて、「夢のお告げなんて、あてになるものじゃありません。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」吉弥はふくれッ面をした。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と私はふくれた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつと綱をみつめてゐると綱の細い輪郭はふくれしだいに太く見えだした。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いけないよ、活動だなんて――」と私はふくれ顔でさへぎつた。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうかも一度……」　小僧はふくれつ面をして、口の内でぶつくさ呟きながら、やけに火を磨つた。",
              "citation": {
                "source": "西大寺の伎藝天女",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "青ざおとした落し眉に、妖しき色香がこぼれんばかりにあふれ散って、肉はふくらみ、目はとろみ、だが只の女ではない。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生、ガブガブ飲むったら、ありゃしない」――給仕はふくれかえっていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお礼にはこれを差し上げます」　少年はふくろを解いて、見ごとな毛裘をとり出した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃になると、そこらの木の実はそれぞれ黄金色に、また渥丹色に熟み爛れ、草の実はふくらみきつた莢からおのづと爆ぜ割れて、そのはずみにぴちぴちとかすかな音を立てて広い外界へと飛び出してゐる。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はふくれてゐて青く、水にふやけた瓜のやうな感じであつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身の血が頭にのぼり、こめかみはふくれあがり、眼に入る事物は幾重にも折り重つて躍つてゐるやうだつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "将校はふくれつ面をしたが、それでも言葉はかへさなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　王様はふくれ面をして呟いた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アダムスがその男にどうしたのだときくと、男衆はふくれ面をしていつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度二人が電車に乗った頃千世子はふくふくの布団にくるまりながら自分で自分をねかしつける子守唄をうたって居た。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の女の声は陽気で、第一第三の女はふくみ声でゆっくりと口をきく人。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小父貴にでもそれを云われたらともかく一応はふくれるにちがいない娘さんたちが、それと同じ本質のことを、アナトール・フランスの言葉というようなものを引用したらしく文学のように話されれば、何かちがった瞬きようをしてきくという心は、読者の何という可憐さであろう。",
              "citation": {
                "source": "今日の読者の性格",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧正月まへ・こゝろたのしくてそこらで餅をつく音も・更けてひとり焼く餅の音たててはふくれる・みぞれする草屋根のしたしさは　霜晴れの、むくむくと土をむぐらもち　ふるつくふうふういつまでうたふ　　　改作　ほつと夕日のとゞくところで赤い草の実　二月朔日　晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "草青く寝ころぶによし　ここまでは会社のうちで金盞花・あゝさつきさつきの風はふくけれど・まがれば菜の花ひよいとバスに乗つて・寝ころべば旅人らしくてきんぽうげ　四月二十五日　晴、日本の春、南国の春。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
