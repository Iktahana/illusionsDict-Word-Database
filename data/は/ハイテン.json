        "examples": {
          "standard": [
            {
              "text": "試験の配点を確認し、重点的に勉強する箇所を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "論文の各項目には、公平に配点されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この問題は難易度が高いので、配点も大きくなっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「なんだ、ズロースはいてんのか」　ワンピースの外から、それと分るそのゴム紐を、俺は手さぐりで探して、外からちょいと引っ張って、ぱちんとやって、「どこかへ行ってきたのか」「うちへ、ちょっと……」　クララは言葉をにごしたが、「うち？",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
