    "definitions": [
      {
        "index": 1,
        "gloss": "to bow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その崇拝する芭蕉の庵を、初めて親しく訪ねた日は、おそらく感激無量であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我らは風流使者にあらず、しかも天縁尽きずして、ここに名山を拝するの栄を得、名山が天を讃する如くにして、人間は名山を讃す、また可ならずや。",
              "citation": {
                "source": "山を讃する文",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰青色した緻密の熔岩と砂礫と互層をしているところを、筋違いに岩脈がほとばしって、白衣の道者たちが大沢で祈ったのと同じように、この岩脈を十二薬師の体現と信じて、崇拝するという話である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　三三九頁を見ると、　フェレチ王国の人々は朝起きた時に一番先に眼に触れたものを、その一日中崇拝するという事が書いてある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新輸入の思想の初物を崇拝する現代の多数の人達とこの昔の王国の人とどこか似たところがあるような気がする。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良はビイクトリア・ブリテッシュ・スクールの学生が、花園のなかのジャックソンの銅像に礼拝する姿を見るのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その木挽の与吉は、朝から晩まで、同じことをして木を挽いて居る、黙って大鋸を以て巨材の許に跪いて、そして仰いで礼拝する如く、上から挽きおろし、挽きおろす。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の物語を聞き、此像を拝するにそゞろに落涙せり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　世界の屋根　この映画で自分のもっとも美しいと思った場面はおおぜいの白衣の回教徒がラマダンの断食月に寺院の広場に集まって礼拝する光景である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等といふは、元来はわれわれ梟や鵄などに対して申さるゝのぢゃが、ご本意は梟にあるのぢゃ、あとのご文の罪相を拝するに、みなわれわれのことぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等というは、元来はわれわれ梟や鵄などに対して申さるるのじゃが、ご本意は梟にあるのじゃ、あとのご文の罪相を拝するに、みなわれわれのことじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に神と良心を無視し、黄金と肉慾を崇拝する者は地上の強者也。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校の教員はすべからく焼塩か何にかで三度のめしを食い、以て教場に於ては国家の干城たる軍人を崇拝すべく七歳より十三四歳までの児童に教訓せよと時代は命令しているのである。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同座具を延べて三拝する。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（釈尊の説法が終ると教団の人々は立ちて三拝する。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小間）その三（あたり少しく鳴り響き、目連は釈尊の姿が眼に入るや、直にその前に来て正しく立ち三拝する。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜、一夜は、あの小魚のいのちをぽちりぽちりわしの骨の髄に噛み込んで生き伸びたい――」　徳永が嘆願する様子は、アラブ族が落日に対して拝するように心もち顔を天井に向け、狛犬のように蹲り、哀訴の声を呪文のように唱えた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "岐阜県××町、――里見稲子、二十七、と宿帳に控えたが、あえて誌すまでもない、岐阜の病院の里見といえば、家族雇人一同神のごとくに崇拝する、かつて当家の主人が、難病を治した名医、且つ近頃三由屋が、株式で伊勢の津に設立した、銀行の株主であるから。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（わななきながら八方を礼拝す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "禰宜、仕丁、同じく背ける方を礼拝す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に英邁勇敢なるルーズヴエルト氏が大統領に就任せし時以来、一部国民の精神は著しく其感化を受けしものゝ如く、表面に黄金を崇拝する事に変りはなけれど、其精神に於ては英雄崇拝を以て本義と為し或者は尚武練胆の気風を皷吹し、或者は米国魂に加ふるに日本魂の精萃をすら吸収し伝播せんと企てつゝあるが如し。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻で、閣翁を突くがごとくにして、銅像に一拝すると、「えへん。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一と三の烏、同時に跪いて天を拝す。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "内藤家の藩地は日向の延岡であるが、その帰国の途中、高野山その他の仏寺を遍歴参拝することは苦しからずということであった。",
              "citation": {
                "source": "かたき討雑感",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲原有明は僕の崇拝する唯一の詩人。",
              "citation": {
                "source": "蒲原有明に帰れ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　とにかく、こんな前提は、いよいよとなると葉子の心から一掃されて、葉子にはただ崇拝する文学者麻川荘之介氏と同宿するという突然な事実ばかりが歴然と現前して来るのであった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて信仰は地上にあつたでうすはいすらええるの野にござつて惡しき大天狗小天狗を退治なされた。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいすの綿や、毛類や、蒲団などが燃ゆる音であった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは長戸検事のところへ電話をかけるから……」　蜂矢はいすの背をとびこえて、電話機のところへとんでいった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、総監はいすからたちあがって、スミスにかたい握手をもとめ、そして声をひくくしてささやくようにいった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
