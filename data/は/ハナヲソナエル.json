        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は広瀬川の水を汲んで、夏の日に霊前の花を供えるのであろう。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仏に後夜の勤行の閼伽の花を供える時、下級の尼の年若なのを呼んで、この紅梅の枝を折らせると、恨みを言うように花がこぼれ、香もこの時に強く立った。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかして手に入れたかった――きっと花を供えるという約束をしたのだから。",
              "citation": {
                "source": "碧眼",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "内供は、仏前に香花を供えるような恭しい手つきで、鼻を抑えながら、こう呟いた。",
              "citation": {
                "source": "鼻",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私の女房がほんとうにその気持で母の写真に食べ物や花を供えることを喜んでいる心や習慣があるなら、私自身は自分でそんなことをする気持がなくとも、女房のヤリたいことをやらせて悪いことはなかろうさ。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その四　人形の家",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
