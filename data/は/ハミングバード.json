          "standard": [
            {
              "text": "ハミングバードは、その素早い羽ばたきで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "庭に飛んできたハミングバードが、花の蜜を吸っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ハミングバードの飛行は、まるで空中に静止しているかのようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一番ちっちゃいのはハミングバードで、一番大きくて美しいのは極楽鳥です。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギブスンのハミングバード。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千曲川」「うわあ」「ギターを出すから、ちょっと待ってくれ」　受話器をまたベッドに置き、ハミングバードをケースから出した。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
