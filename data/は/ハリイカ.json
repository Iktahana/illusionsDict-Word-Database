          "literary": [
            {
              "text": "低くてなだらかな山々が広く長く根を張っている姿も、やはりいかにも落着いたのんびりした感じを与える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "となればやはりいかざあなるまいと駆け付けてみると、なんと師匠、いきなり今度は社内のスタッフにレッド・ペーパーを突き付けるではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし口の輪廓はやはりいかにも優しく、顎の形はいかにも柔らかだった。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            }
          ]
        }
