    "definitions": [
      {
        "index": 1,
        "gloss": "show (of power, ability, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「全くだ」とＡも思ふ、「しかしま、お手柔らかに」と、表情以て友達甲斐を発揮する。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "発破と度胸競べなんざ、真っ平だよ」　こんな訳であって、――どんな訳があろうとも、発破を抑えつけるなんて訳に行くものではない――岩鼻火薬製造所製の桜印ダイナマイト、大ダイ六本も詰め込んだ発破は、素晴らしい威力を発揮した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに諭さなくとも早百合姫は、道に志ある身となって、しかし、これは逆に塵中へ引返し、舞いの天才を発揮して京町の名だたる白拍子となりました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう点から見て最も多くの芸術としての文学の特徴を発揮しているものはこの種の詩歌でなければならない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなければ、作者の個性発揮も充分でない、情調化も充分でない。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にいたずら好きの天分をも発揮して、ガス管内に空気を押し込み、先生の祈祷が始まると燈火が自然に消えるという趣向を案出し実行した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂屋の主人は意外な機会に変った英雄主義を発揮して見せた訳である。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主役のすみれ娘はオリジナルな愛嬌と頭脳の持主らしく随所に一種の俳諧を発揮しているようである。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてだんだんその作品に親しんで行くうちに、同君の天品が最もよく発揮し得られるのは正しくこの方面であると信ずるようになったのである。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような種々な美点は勿論津田君の人格と天品とから自然に生れるものであろうが、しかし同君は全く無意識にこれを発揮しているのではないと思われる。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは横田はヤンキーの女達が過去スペインの愛犬に恋慕したように、無謀な愛情ときわどい婦人社会の教養をうけて裸体で近東風な機械体操や、スパルタ風の腕力を発揮したり、恐らくあの毛むくじゃらの胸を、つき出して、サロンを物好きな流行女の号令によって、自由自在に這い廻っていることだろう。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "作家としての独歩の面目は、到るところに発揮されて、当時の海戦と艦上生活の有様をヴィヴィットに伝え得るものがある。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の固有の線の美しさが発揮されている。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、一寸でもその、まどろみの邪魔をすると、父は、火がついたような狂暴性を発揮する。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "工人達には、こういう時こそ、彼等の偉力を発揮するのに、好都合な条件がひとりでに備わってくる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "劣勢の場合には尻をまくって逃げだすが、優勢だと、図に乗って徹底的な惨虐性を発揮してくる。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりが互に一種の面目を重んじて、一種の男らしい精神を発揮して来る。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "互に時勢の差、境遇の差に連れ得意の方面の其の特長を発揮して居るものゝ、其中に大をなして居る者は必ず張良、陳平の徒が多く、水火を踏んで辞せず、剣戟の林に入つて退かざる者は、寧ろ第三流第四流に居る処の樊※、鯨布の徒である。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの考えを基にしてルクレチウスは、精神は肉体の死とともに死滅するものであるという彼の信条を「説明」するためにおよそ二十八箇条をあげて彼の雄弁を発揮するのである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも割れ目の空隙が厚くなるほど、これを充填した血液の水分は蒸発し、有機物は次第に分解変化して効力を失うであろうから、やはり目に見えない程度の分子的な割れ目に対して最も効力を発揮するであろうと考えられる。",
              "citation": {
                "source": "鐘に釁る",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この天成の妙機を捨てる代わりに、これを活用してその長所を発揮するような、そういう「科学の分派」を設立することは不可能であろうか。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし極端な自然科学的唯物論者におくめんなき所見を言わせれば、人間にとってなんらかの見地から有益であるものならば、それがその固有の功利的価値を最上に発揮されるような環境に置かれた場合には常に美である、と考えられるであろう。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる種類の電気照明は積雪飛雪の街頭にその最大能率を発揮する。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して先生が自分の仕事を横取りしたといって泣き言を言うような弟子が一本立ちになって立派な独創力を発揮する場合はわりに少ないようである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャーナリズムが恐るべき性能を充分に発揮するのはこの点であろうと思われる。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学は全く受動的に非科学の奴僕となっているためにその能力を発揮することができず、そのために無能視されてしかられてばかりいるのではないかという気もする。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだとすると、男も鉄漿黒々とつけていた日本の昔は今よりももっと人間のこの特権を充分に発揮していたことになるかもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うれしい事は、うれしくないことの続いたあとに来てはじめてうれしさを充分に発揮する。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの態度を、はっきりきめていただきたい。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の世界観をはっきり持っていなくても、それでも生きて居れる人は、論外である。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
