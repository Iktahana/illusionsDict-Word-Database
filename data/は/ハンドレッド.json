          "literary": [
            {
              "text": "スリー・ハンドレッドでいいんですね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹で穀六十ポンド、またハンドレッド・ウェートの豆を備えたもあるという（ウッドの『動物図譜』一）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "一疋で穀六十ポンド、また豆ハンドレッド・エートを蓄うるものありとは仰山な。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語では百日ってハンドレッド・デイっていうよ」「ハンドレッド・デイズだよ。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "△△が昨日も来てハンドレッドばかり置いて行ってくれるし、何ならちっと御用立てしましょうかね。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドレッド・ベスト・ホームソングスというような厚い四角い譜ももって来た。",
              "citation": {
                "source": "きのうときょう",
                "author": "――音楽が家庭にもたらすもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "米人がハンドレッド・ペルセント米人といえるに対し、他邦民は大分反感を抱いている。",
              "citation": {
                "source": "民族優勢説の危険",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもあなたは、われわれのおとなしいデイヴィ、或はワン・ハンドレッドより荒い馬に乗って、馬術の腕をためして見る機会がなかったからいいのよ。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もしもある者かがホップに何らかの薬品または成分を入れてその色または香りを変えたら、その罪を犯したものが罪を犯した地区または場所の治安判事の前で１人の証人の宣誓により有罪となったら、ハンドレッドウェイト（112ポンド）について５ポンドの罰金を払わなければならない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が練習した歌の中には「巡礼の合唱」、アリオン集中の若干、「オールド・ハンドレッド」〔讃美歌の一〕、「すべての名誉を兵士に捧ぐ」その他があった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
