        "examples": {
          "standard": [
            {
              "text": "商店街のお惣菜屋さんは、好きなおかずを量り売りで買えるので重宝する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "無駄を省くため、洗剤やシャンプーの量り売りを利用する人が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "海外の市場では、スパイスやナッツが大きな袋に入って量り売りされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「まあ、お近婆さん、徳ちゃんと兵ちゃんは、顔色が変っているじゃないか」　私の母は、その残飯を量り売りしながら、あんまり、ひどそうなので、注意したことがあった。",
              "citation": {
                "source": "あまり者",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどお葬式に悲哀を添えるために雇われる人々のように、彼らはその涙を、その悲嘆をさえ、切り売りし、量り売りする。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが　はかりうりを　してくれません。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
