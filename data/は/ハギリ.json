    "definitions": [
      {
        "index": 1,
        "gloss": "gnashing the teeth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
