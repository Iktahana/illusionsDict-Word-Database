[
  {
    "uuid": "dd1577b8-ad10-5bfe-a94f-371267aca9d8",
    "entry": "排出",
    "reading": {
      "primary": "はいしゅつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
