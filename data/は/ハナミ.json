[
  {
    "uuid": "b554f47a-068c-5f07-a3f2-ae9b60417f20",
    "entry": "花見",
    "reading": {
      "primary": "はなみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
