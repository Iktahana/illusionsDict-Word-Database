    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cherry blossom viewing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "行く春や白き花見ゆ垣の隙　この句もまた、蕪村らしく明るい青春性に富んでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用をすました帰りにぶらぶら竹の台を歩きながら全く予期しなかったお花見をした。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花を見ながらふと気の付いたことは、若いときから上野の花を何度見たかしれない訳であるが、本当に桜の花を見て楽しむ意味での花見をすることが出来るようになったのはほんの近年のことらしい、ということである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人にこだわりながら花見をして帰ると頭が疲れてがっかりしたものである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ俺は、あの桜の樹の下で酒宴をひらいてゐる村人たちと同じ権利で、花見の酒が呑めさうな気がする。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の遊楽の中でもいわゆる花見遊山はある意味では庭園の拡張である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな勤倹な四民も年に一度のお花見には特定の「濫費デー」を設けた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは三月なかばの花見｜日和といううららかな日で、ぶらぶら歩いている二人のひたいには薄い汗がにじんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ俺は、あの桜の樹の下で酒宴をひらいている村人たちと同じ権利で、花見の酒が呑めそうな気がする。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天気がよくて暖かくてなんだか東京の花見時分の心持ちでした。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、たとえて言わば、花見に行って、この花のわかるのはおれ一人だと言って群集をののしるようなものでおかしい。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで日本人ならば、丁度花見とか月見とかいふ処を、蛙どもは雲見をやります。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで日本人ならば、ちょうど花見とか月見とか言う処を、蛙どもは雲見をやります。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちの花見酒で酔い潰れ、こっちのお祝い酒で奢り潰されてなあ」「太平楽なにも程がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、不断は千本格子を境にして、やけな奥女中の花見ぐらい陽気な処へ、巡査と見ると騒動が豪い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこのくらいな間だったが――山の根に演芸館、花見座の旗を、今日はわけて、山鳥のごとく飜した、町の角の芸妓屋の前に、先刻の囃子屋台が、大な虫籠のごとくに、紅白の幕のまま、寂寞として据って、踊子の影もない。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四海波靜にして俥の上の花見のつもり。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親合點の母親承知で、向島へ花見の歸りが夜櫻見物と成つて、おいらんが、初會惚れ、と云ふ寸法に成るのであるが、耕地二十石の百姓の次男では然うは行かない。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月　舳に肌ぬぎの亂れ姿、歌妓がさす手ひく手に、おくりの絃の流れつゝ、花見船漕ぎつるゝ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、腰の矢立はここのも同じだが、紺の鯉口に、仲仕とかのするような広い前掛を捲いて、お花見｜手拭のように新しいのを頸に掛けた処なぞは、お国がら、まことに大どかなものだったよ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四辺を※す）ちょいとお花見をして行きましょうよ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三年（庚寅）　一八九〇○一月、団十郎は京都花見小路の祇園館に乗込み、大阪の鴈治郎、福助らと合同して開演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その春から上野の中堂が大修繕の工事に取りかかりましたので、お花見差止めというわけでもありませんでしたが、大抵は遠慮して上野のお花見には出ませんでした。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、花見小路に最近出来た「京都プルニエ」で食事を済ませて、勘定を払おうとすると、財布がないことに気がついた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年は三里塚へお花見に行くなんて、時ちゃんたち言っていたけれど、あの雨だろう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま私の心は涙をもてぬぐはれ閉ぢこめたる窓のほとりに力なくすすりなくああこのひとつのまづしき心はなにものの生命をもとめなにものの影をみつめて泣いてゐるのかただいちめんに酢えくされたる美しい世界のはてで遠く花見の憂鬱なる横笛のひびきをきく。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂鬱なる花見憂鬱なる櫻が遠くからにほひはじめた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま私の心は涙でぬぐはれ閉ぢこめたる窓のほとりに力なくすすり泣くああこのひとつのまづしき心は　なにものの生命をもとめなにものの影をみつめて泣いてゐるのかただいちめんに酢えくされたる美しい世界のはてで遠く花見の憂鬱なる横笛のひびきをきく。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しどけなき、なれが頸は虹にしてちからなき、嬰児ごとき腕して絃うたあはせはやきふし、なれの踊れば、海原はなみだぐましき金にして夕陽をたたへ沖つ瀬は、いよとほく、かしこしづかにうるほへる空になん、汝の息絶ゆるとわれはながめぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の奥の綾むしろは暖く、結燈台の油｜坏に油はなみなみとしている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
