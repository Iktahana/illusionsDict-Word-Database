  {
    "uuid": "7404b374-de46-5eb6-a2ef-16340bc7e472",
    "entry": "配流",
    "reading": {
      "primary": "はいる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
