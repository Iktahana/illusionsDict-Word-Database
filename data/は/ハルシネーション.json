        "examples": {
          "standard": [
            {
              "text": "AIが生成した画像に、時々ハルシネーションが見られることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最新のAIモデルは、ハルシネーションの発生を抑制するよう設計されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医療分野では、幻覚症状をハルシネーションと呼ぶ場合がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "始めて気のついた時はハルシネーションのようにはっきり見えたが、その後はただぼんやり、しかしそれが画像の顔だという事がわかるくらいに現われたり消えたりした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくこれは生理的ではなくて、病理的に神経の異常から起こるハルシネーションの類だろうが、それにしても妙なものである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりではない、葉子の五官は非常に敏捷になって、おまけにイリュウジョンやハルシネーションを絶えず見たり聞いたりするようになってしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
