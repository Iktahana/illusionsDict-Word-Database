    "definitions": [
      {
        "index": 1,
        "gloss": "any duck with white specula (bright patches on the wings)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "緋の鳥冠の小さな鶏は二羽白い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、染め羽白羽のとがり矢は、中には物々しい鏑の音さえ交えて、またひとしきり飛んで来る。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "五、六羽白い色のも見える。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、中に一｜羽白いのがまじっています。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　手をのばして、抜き取ってみると、なるほど、妻羽白の矢羽の下に、ほそい、書状らしいものが、結びつけてあった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピラピラピラ羽白の細矢がとんでくる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、一本の羽白の矢が、ヒュッ――と鏃に陽の光を切って、うつつな、かれの姿を狙ってとんだ。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "剣山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま、奥で一ぱい飲みながら考えていたところさ」　中老の男はじろじろ私を見るので主人は正直に私の身元を紹介した。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と石井翁はじろじろ河田翁の様子を見ながら聞いた。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では、まことに申しにくうございますが、この御相談はお断わり申しとう存じます」　女の眼はじろりと光った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "母はじろり自分を見たばかり一言も言わず、大きな声で「お光、お銚子が出来たよ」と二階の上口を向いて呼んだ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査はじろりと四辺を見た。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくろうはじろじろ室の中を見まわしながら、　「たった六日だったな。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坊主はじろりと顔を見た。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓子はじろじろホールの中を見廻していたが、何思ったか急に、「あたしお相手しますわ」　と、小郷に言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか科白を喋ってから引き下るということにしなければ、恰好がつかないし、今更引っ込みもつかない」「じゃ、何を喋りに来たんや」「結論を先に言おう」　と小沢はじろりと一同を見廻して、「――喧嘩というものが、いかにくだらぬものであるかということを、君たちに納得させたいんだ」「大きにお世話や。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、巡査はじろりと見ただけで、通り過ぎた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "えぞせんにゅう、えぞおおあかげら、くまげら、しめ、赤ばら、えぞやまどり、しまえなが、のびたき、かけす、きびたき、るりびたき、しぎ、うみがらす、つつどり、きんくろはじろ、かるがも、こおりがも、おおせぐろかもめ、おいらんかもめ、うみしぎ、ちどり、うのとり。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　イワンはじろりとマカールの顔を見て答へました。",
              "citation": {
                "source": "ざんげ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、それは母さんの、形見の櫛、そればっかりは、どうぞ」　伊右衛門はじろりと見た。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの」と、かの女はじろりとした目を義雄に向け、「いつかの女の人はどうなりました？",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十九、三十、……）　豹一はじろりと部屋の中を見廻した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、失礼でございますが、私から、ちょっとお話をあげたいと思いますが」　松山はじろりと定七を見た。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはまはじろり悪口いう方を見たがだれだかわからなかった。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯さえ蒼白い顔は藍のように変わってしまって、ただ黙ってうつむいていると、やがて吉五郎はじろりと見かえって、「若けえ人に飛んだお下物を見せたが、おめえはあの女を知っているかえ。",
              "citation": {
                "source": "子供役者の死",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "和尚はじろりと尻目に甚斎の左手を見た。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督はじろりそれを見ながら、無遠慮に唾をはいた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　わたくしが思い切ってこう言いますと、じいやはじろりと横目で睨んだばかりで、しばらく黙っていましたが、やがてしずかに言い出しました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉五郎はじろりと見返ったが、やはり黙っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お政はじろりとその様子をみて、何を思ッてか、高く笑ッたばかりで、再び娘を詰らなかッた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
