          "literary": [
            {
              "text": "処で、其次が半自治と云ふ奴だ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々の自治寮は、即ちこの半自治の状態に有るのだ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "半自治とは、換言すれば、規則が有つたり無かつたりと云ふ状態なのだ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "我自治は、半自治なりさ。",
              "citation": {
                "source": "俺の記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            }
          ]
        }
