    "definitions": [
      {
        "index": 1,
        "gloss": "to crawl into",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蛇が餅の皿の中へニョロニョロ這い込む。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は早く妻に店番を譲って寝床へ這い込む。",
              "citation": {
                "source": "白い路",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は背中にモゾモゾと這い込む蟻を磨り潰そうともしないまま静かに眼を閉じてみた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おおかた野良犬でも這い込むのだろう。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は土竜のように這い込むと、まだ三間とは進まないうちに、道は塞がって行く手をさえぎられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "露路口は這い込む人の身体で膨れ上った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "草むらに這い込む苦力が、そこでもかしこでも兵卒の発砲にのめり、倒れた。",
              "citation": {
                "source": "シベリヤに近く",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だって交番に這い込むのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、皆が這い込む筈の寝台は、すぐ右側の隣りだった。",
              "citation": {
                "source": "春",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいよ、窓からはいるから……」　ラエーフスキイは窓から這い込むと、サモイレンコに近よってその手を掴んだ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "………他の獣の窩へ這い込む、蟻塚をやたらに荒らす、蝸牛を殻ごと噛みくだく。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふたたび橇の疾駆、酔払ったニカノールの寄態な声、風、眼に口に毛皮外套の襞という襞に這い込む執念ぶかい雪……。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥へ這い込むようにして、しばらく押入れ中ごそごそ言わせていたが、やがて、発見け出した竜手様を、汚なそうに、怖ろしそうに、指さきに挾んで、腰を伸ばした。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "悲願百両",
                "note": "青空文庫"
              }
            },
            {
              "text": "念のため提灯を差し込んで、離屋の縁の下を覗いて見ましたが、床下には巨大な土台をめぐらし、人間は愚か、小犬の這い込む隙間もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "密室",
                "note": "青空文庫"
              }
            },
            {
              "text": "高蔵人登場　お春には固く口止めして、それとなく邸の内外を堅め、蟻の這い込む隙間も無いようにしましたが、何んの役にも立ちません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第三夜　お化け若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の絶間を見すまして、橋桁の下の闇へ這い込むと、「三ちゃん待って居たよ」　半面美人のお若が待って居て、「…………」　不機嫌な私に構わず、「今日は貰いがどっさりあったから、天プラを買って来たよ、お上り」　お若は私の身体へ凭れるように、鼻の先へ美味しそうな竹の皮を開くのでした。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも、見当位はつくだろうと思うが」「――」「お嬢さんの手紙と思い込まなきゃ、二本差の立派な若侍が、犬潜りから這い込むような、恥曝しなことはしなかったでしょう」　平次は件の手紙を畳の上に置いて、なおも詰め寄るのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "恋患い",
                "note": "青空文庫"
              }
            },
            {
              "text": "上り框から這い込むように、まだ朝の膳も片付かない茶の間を覗きながら八五郎は途方もないことを訊くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鬼の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、皆が丸くなって「じゃんけん」をする、負けた一人が、本堂傍の梁へ吊るした古俵の中へゴソゴソと這い込むと、庭で枯木へ火をつけた一人が真剣な声を張りあげて、「火事だぞーッ、火事あおっぱじまったぞー！",
              "citation": {
                "source": "三郎爺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から、三芳も這い込む。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて女の児がつれ去られ　泣きつかれた男の児は　そのあとへ這い込む　九歳のしなやかな　日やけ色の手脚をまるめて　名もなつかしい　｜おじいさん椅子は　おだやかに　大きく黄ばんだ朽葉色　気持の和むなきじゃくりと　ミシンの音は夢にとけ入り　時計はチクタクを刻む　となりの子供は　みんな出払った　休日の宵。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると、最初のよりも余程深い音色のする鐘が鳴り、我々は手を洗い、茶室へ這い込むという、同じ形式をくりかえした。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オオ、やっぱりそうだったか」　博士は唸るように云うと、ベッドから降りて、今度はその下の僅かの隙間に這い込むと、自動車の修繕でもするように、仰向きになって、ベッドの裏側を調べていたが、突然、恐ろしい声で呶鳴り出した。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの鉄管を駈け抜けるたびに、次に這い込む鉄管を、用心深く選択しなければならなかった。",
              "citation": {
                "source": "人間豹",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人も遅れず同じ穴から這い込む。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいちょい野菜泥棒にも這い込むがいい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがそのストーブの下にはいこむと、すっかりからだがかくれてしまうんだ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンプの下に何か見るべきものがあると、わたしたちはみんなしゃがんで、ほとんどポンプの下へはいこむくらいでした。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小林少年はそういって、丈吉君といっしょに、また、さっきのかくれ場所へはいこむのでした。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりまえの家でしたら、庭のほうの縁がわの下から、床下へはいこむという手もありますけれど、このお座敷の縁がわの下には、厚い板が打ちつけてございますからね。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
