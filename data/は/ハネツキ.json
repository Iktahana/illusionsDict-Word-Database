        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "話はそれたが三河様というのは、風ふくな、ナア吹くな、三河様の屋根で、銀羽根ひろって……と羽根つきながら風が出てくると呪いに唄う大川端の下邸跡である。",
              "citation": {
                "source": "牢屋の原",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "この広い店、中央の羽根つき場になる個所はずっと天井が高く、明りとりになっていて廻りだけにぐるりと二階がある。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今のように自動車が通るではなし、往来はそれはのんきなもの、お正月は往来が羽根つき場所だったのです。",
              "citation": {
                "source": "私の思い出",
                "author": "柳原白蓮",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽根つきは、昨夜も座敷の中でやりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "坐り羽根つきという新しい名をつけて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥が靴にはねつき靴は水を蹴る。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
