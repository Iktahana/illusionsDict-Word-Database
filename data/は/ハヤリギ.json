          "standard": [],
          "literary": [
            {
              "text": "逸り気を斥け驕り昂る心を捨て、静寂の中で省察を誠実に行い、我々と聖人との関係を思えば、人誰か古聖が大慈の父母の様で、我々が不幸の児の様に思わないであろうか、聖賢の恩恵は我々をスッポリと包み我々を援助し、我々の愚かな者は聖賢に背き聖賢を疎外する。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今のようなことを聞けば、あなたはよけいに、卑怯者といわれたくないと思い、死んでも帰ると仰っしゃるかも知れませんが、そんな逸り気はやめて下さいませ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい首尾を作るにも、男の逸り気を撓め、女の待ち汐を見、そこの櫓楫の取り方は媒ち役の腕というもの。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のこの逸り気を誘き出しに来た敵の水軍であったとは、如何せん、後で分ったことだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――味方の全軍が、わずか一城に懸って、日を過すうちに、神戸、一色の敵軍が、退路を断って、包囲して来たら何と召さるか」　飯尾｜隠岐、下方左近｜将監などの老練の将は、藤吉郎の策を若い逸り気として、叱るが如く云った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬしこそ、とかく逸り気だから気をつけろ」　見張りの蛮兵が、報告に来た。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、困るのは、彼らのそうした逸り気だった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、直義に劣らない逸り気の将校はほかにも多い。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "音の程らひの搖曳に、憧れごゝち、夢に入るをきけば昔の戀がたり、「細谷川の丸木橋、ふみかへしては、かへしては、あの山みるにおもひだす、わかき心のはやりぎに森の女神のシュリンクス追ひしその日の雄誥を。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
