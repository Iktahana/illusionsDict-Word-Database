    "definitions": [
      {
        "index": 1,
        "gloss": "hack",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "------------------------------------------------------------------　ハックニー馬［※１］のしっぽのような、巫戯けた楊の並木と陶製の白い空との下を、みじめな旅のガドルフは、力いっぱい、朝からつづけて歩いておりました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "------------------------------------------------------------------●入力者注※１　ハックニー＝馬の種類。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一列馬をひく騎馬従卒のむれ、この偶然の馬はハックニーたてがみは火のやうにゆれる。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に無茶先生は、谷川のふちに生えていた細い草の葉を取って、二人の鼻の穴へソッと突込みますと、二人共一時に、「ハックションハックション」　と嚔をしながら眼をさまして、起き上りました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十八「大きな、ハックサメをすると煙草を落した。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さん、婆さんハックッシヨと云へば、お靴の中でも雀がハックッシヨ、お帽子の中でもハァハァハックッシヨ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハックッシヨ、／＼、ハァハァハックッシヨ、ハックッシヨ、／＼、ハァハァハックッシヨ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど詩人ハックレンデルが当世の奴隷といいしごとく、はかなきは舞姫の身の上なり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず噎せ返って、「ハックシン」　と大きなくしゃみを一つして、フッと眼を開いてみると、どうでしょう。",
              "citation": {
                "source": "白椿",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『朝野僉載』には大酔して崖辺で睡った人の上へ虎が来て嗅ぐと虎鬚がその人の鼻孔に入りハックションと遣った声に驚きその虎が崖から落ちて人に得られたとある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "故ハックスレーが説いた通り、ギリシア人スペイン人とも髪も眼瞳も黒くメラノクロイと称する白人中の一類に属するから、その美女の標準も大抵同一なるべく、したがってヘレナの乳は小さかったから小觴のモデルにしたらしい。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘキスン……ヘッキスン……」「ハックシン……フィックシイン。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ですが、こういうハックスレイを御存じですか。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、「竹取物語」、「西遊記」、「アラビアン・ナイト」、スチブンソンの「宝島」、アミーチスの「クオレ」、マロオの「家なき少女」、トウエンの「ハックルベリー・フィンの冒険」「トム・ソーヤの冒険」、「ロビンソン・クルーソー」、「不思議の国巡廻記」等。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハ、ハックショイ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これからそうするよ、ハックショ！",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この書もまた、一つの告白文学にちがいないのだが、ここには人生の荊棘に血を流し呻く声のかわりに、ハックルベリーの実の饗宴に充ち足り、想いをガンジスの悠久な流れにはせる、自信にみちた独白がある。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "訳者の言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは其学識を衒ひて、ミル、スペンサー、ベンダム、ハックスレー、何でも御座れと並べ立てゝ傲然たること猶今の井上博士が仏人、独逸人、魯人、以太利人、西班牙人の名を並べて下界の無学者を笑ひ給ふが如くなりき。",
              "citation": {
                "source": "明治文学史",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下に名高い大辻……うわッ……ハーハックション！",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月五日　オルダス・ハックスリーの『ジョコンダの微笑』短篇集をよむ。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（彼に自覚されていず、またその愛読者に理解されていない事実）　○ハックスリーのこういう短篇にしろローレンスにしろイギリスの中流的偽善には立腹しつづけている。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "集会をハックネーからおっぱらい。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、私は彼等を、プリムロウズ、ペリウィンクル、スウィート・ファーン、ダンデライアン、ブルー・アイ、クロウヴァ、ハックルベリ、カウスリップ、スクォッシュ・ブロッサム、ミルク・ウィード、プランティン、それからバタカップという風に呼んでおこうと思う。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼は、ペリウィンクル、ダンデライアン、ハックルベリ、スクォッシュ・ブロッサム、ミルク・ウィード、その他、彼の半分か三分の一くらいな年の子供達に対しては、まるでお祖父様のような気がしていた。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
