    "definitions": [
      {
        "index": 1,
        "gloss": "white sand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "右には未だ青き稲田を距てて白砂青松の中に白堊の高楼｜蜑の塩屋に交じり、その上に一抹の海青く汽船の往復する見ゆ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁舟江心に向かいてこぎ出せば欸乃風に漂うて白砂の上に黒き鳥の群れ居るなどは『十六夜日記』そのままなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえて西の空｜麗しく晴れて白砂青松に日の光鮮やかなる、これは水彩画にも譬うべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お松が自分をおぶって、囲炉裏端へ上った時に母とお松の母は、生薑の赤漬と白砂糖で茶を飲んで居った。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は、パン屑のまじった白砂糖を捨てずに皿に取っておくようになった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして馬の顔の毛や、革具や、目かくしに白砂糖を振りまいたようにまぶれついた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の口ひげから眉にまで、白砂糖のような霜がまぶれついていた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草がくれの艫に、月見草の咲いた、苫掛船が、つい手の屆くばかりの處、白砂に上つて居て、やがて蟋蟀の閨と思はるゝのが、數百一群の赤蜻蛉の、羅の羽をすいと伸し、すつと舞ふにつれて、サ、サ、サと音が聞こえて、うつゝに蘆間の漣へ動いて行くやうである。",
              "citation": {
                "source": "十和田の夏霧",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の光を白砂にたよつて、子の口の夕べの宿に着いたのである。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "底は一面の白砂に水紋落ちて綾をなし、両岸は緑野低く春草煙り、森林遠くこれを囲みたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕頸に淡いくびれがあり、指の附根の甲に白砂を耳掻きで掬った痕のような四つの小さい窪みのできる乙女の手は、いま水晶を溶したような水の流れを遮る――水は潺湲の音を立て、流勢が勝って手に逆うとき水はまた淙々と響く。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半ば戸袋へするりと開けると、雪ならぬ夜の白砂、広庭一面、薄雲の影を宿して、屋根を越した月の影が、廂をこぼれて、竹垣に葉かげ大きく、咲きかけるか、今、開くと、朝の色は何々ぞ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆の中より、水際立って、美しく水浅葱に朝露置いた大輪の花一輪、白砂の清き浜に、台や開くと、裳を捌いて衝と下り立った、洋装したる一人の婦人。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長閑さはしかし野にも山にも増って、あらゆる白砂の俤は、暖い霧に似ている。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯馴松は一樹、一本、薄い枝に、濃い梢に、一ツずつ、翠、淡紅色、絵のような、旅館、別荘の窓灯を掛連ね、松露が恋に身を焦す、紅提灯ちらほらと、家と家との間を透く、白砂に影を落して、日暮の打水のまだ乾かぬ茶屋の葭簀も青薄、婦の姿もほのめいて、穂に出て招く風情あり。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝の間を白砂のきれいな坂が畝つて拔けて、その丘の上に小學校がある。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　――道をかえて、たとえば、宿の座敷から湖の向うにほんのりと、薄い霧に包まれた、白砂の小松山の方に向ったのである。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそぐだらくにつかれきつて白砂の上にながながとあふむきに倒れてゐよう。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　健康とそれから金銭の条件さえ許せば、私も銀座のまんなかにアパアト住いをして、毎日、毎日、とりかえしのつかないことを言い、とりかえしのつかないことを行うべきでもあろうと、いま、白砂青松の地にいて、籐椅子にねそべっているわが身を抓っている始末である。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "白砂に這い、ひろがれる千本松原、または紅葉に見えかくれする清姫滝、そのような絵はがきよりも浅草仲店の絵はがきを好むのだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、真鯛、鰹、真那鰹、その金銀の魚類のみでは、満足をしませなんだが、続いて、三抱え一対の枝珊瑚を、夜の渚に差置きますると、山の端出づる月の光に、真紫に輝きまするを夢のように抱きました時、あれの父親は白砂に領伏し、波の裙を吸いました。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "半島の岩礁はメトロポール、白砂はクラッカー・クリーム。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白砂の上にお嬢様のルビー入りの胸留が落ちていますよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白砂から山にかゝって、果樹畑は暮れ染めにけり。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は渺々たる伊勢の海を眼界の外に霞ませて桑名へ至る石船の白帆は風を孕んで、壮大な三角洲の白砂と水とに照り明って、かげって、通り過ぎる、低く、また、ひろびろと相隔たった両岸の松と楊と竹藪と、そうして走る自転車の輪の光。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "翠嶂山と呼ぶこのあたり、何かわびしい岩礁と白砂との間に高瀬舟の幾つかが水にゆれ、波に漂って、舷々相摩するところ、誰がつけたかその名も香木峡という。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、実に驚いたのは、宏大な三角洲の白砂のかがやきであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛堂の敷地には亭々たる赤松の五、六がちょうどその前廂の斜に位置して、そのあたりと、日光と影と、白砂と落松葉と、幽寂ないい風致を保っていた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "那珂川の白砂では博多織を漂白すんだぞ畜生……。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の那珂川の水は透明清冽で博多織糸の漂白場であったが、ずっと上流まで博多湾から汐がさして、葦原と白砂の洲が到る処に帯のように続いていた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
