        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――けれどもなまじっか人並以上の暮しをしていた悲しさで今更他人の台所を這いずる気にもなれず……」「……そういうんでは、あなたが今云った朝鮮行きもどんなものかな……一つ大決心がいるね」　一太に会話の大部分は不得要領であった。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、婦は這いずるようについて出て来た。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡紅色の胎内……、そこを這いずる無数の青｜蚯蚓。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥が擦りあらされ、おが屑の山がおしひろげられ、木材は巨大な虫が這いずるようにずるずると小屋に運ばれて行った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢島は、いつもションボリ坐っている妻、壁に手を当てゝ這いずるように動く女、またある時は彼の肩にすがって、単なる物体の重さだけとなってポソポソとずり進む動物について考える。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が恐らく全身のエネルギーを使いきった証拠には、漸く岸へ這いあがると、這いあがったなりの腹這いの恰好のまま、だらしなくのびてしまって這いずることもできなかった。",
              "citation": {
                "source": "禅僧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑いの原因は、こちら側のホームを這いずるように歩いて行く、一人の乞食のような汚れた風態の老婆にあるらしい様子だった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
