    "definitions": [
      {
        "index": 1,
        "gloss": "the first time in the year that one wears an awase kimono",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四月はじめの大空は蒼々と晴れて、町には初袷の男や女が賑わしく往来していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "初袷　袷着て吾が女房の何とやら、綿入れの重きを脱ぎすてて初袷に着代えた当座、洵や古き妻にも眼の注がるるものである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "遮莫、物に執着するはかれらの最も潔しとせぬところ、さればぞ初袷の二日三日を一年の栄えとして、さて遂には裸一貫の気安い夏をも送るのである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾儕は爾く青簾を愛する、その初袷に赴いた心はやがて青簾にも同じ好愛を恣にするのである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄無地の道行半合羽、青羅紗の柄袋、浅黄甲斐絹の手甲脚半、霰小紋の初袷を裾短かに着て、袴は穿かず、鉄扇を手に持つばかり。",
              "citation": {
                "source": "死剣と生縄",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶三は大島の初袷に節糸の羽織を重ね、電車を待つ振で時間通りに四辻の乗換場に彳み三田行と書いた電車の留まる度、そこから降来る人をば一人一人一生懸命に見張っていた。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親のお豊は長吉が初袷の薄着をしたまゝ、千束町近辺の出水の混雑を見にと夕方から夜おそくまで、泥水の中を歩き※つた為めに、其の夜から風邪をひいて忽ち腸窒扶斯になつたのだと云ふ医者の説明をそのまゝ語つて、泣きながら釣台の後について行つた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親のお豊は長吉が初袷の薄着をしたまま、千束町近辺の出水の混雑を見にと夕方から夜おそくまで、泥水の中を歩き廻ったために、その夜から風邪をひいて忽ち腸窒扶斯になったのだという医者の説明をそのまま語って、泣きながら釣台の後について行った。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏も初袷きる頃には身一つのさびしさ堪えがたき事ありしが、今年もまたわけもなく心淋しく三味線ひく気も出ぬほどなり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之三大正八年歳次己未",
                "note": "青空文庫"
              }
            },
            {
              "text": "随って初袷の好時節も若葉の初鰹のと申す贅沢も出来ず閉居の体。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白地の単衣を黒いのに着かへて夕風をしのぎ、いよいよ初袷になるころの夏から秋への推移ほど快いものはあるまい。",
              "citation": {
                "source": "われらが四季感",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷の中に初袷というものを認めるならば、蚊帳の中に初蚊帳があってもいいわけである。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀河一　初袷を着、風も秋めくと、毎日のように、江戸のどこかしらで、笛太鼓の音の聞えない日はない。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か仔細の有りそうな、もとは良家の青年らしく、折角染めた木綿の初袷を、色もあろうに鼠色に染めたと、若い身空で仏門に入ったあじきなさを歎じていると、後の附句ではすぐにこれをあの時代の、歌比丘尼の身すぎの哀れさに引移したのである。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ独身で、九条村の百姓家に間借りをしている医書生で、夏は唐人扇子をパチつかせ、冬はぼろ隠しの十徳を着て、飄々乎としている源内が、仕立ておろしの初袷をつけて、いつになくこざっぱりしていたのは、季題はずれのように衆目をひいた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
