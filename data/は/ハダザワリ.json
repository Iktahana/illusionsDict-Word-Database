[
  {
    "uuid": "b7171353-2ba5-5263-bfe9-5b0a0a0e34f2",
    "entry": "肌触り",
    "reading": {
      "primary": "はだざわり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
