        "examples": {
          "standard": [
            {
              "text": "彼はついに転職することを「腹を決めた」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度「腹を決めた」ら、もう後戻りはしない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大きな決断を前に、彼は静かに「腹を決めて」いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そういう時に、自力で起ちあがる腹を決めるのが、夙くから世間へ放り出されて、苦しんで来た彼女の強味で、諦めもよかったが、転身にも敏捷であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今になって、どっちか腹を決める羽目になった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
