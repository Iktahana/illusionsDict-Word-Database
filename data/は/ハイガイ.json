[
  {
    "uuid": "77a915ef-133b-5e38-9614-8134468ea976",
    "entry": "排外",
    "reading": {
      "primary": "はいがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
