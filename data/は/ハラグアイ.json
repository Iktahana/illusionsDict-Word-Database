    "definitions": [
      {
        "index": 1,
        "gloss": "condition of one's stomach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腹具合が惡いと云つたお鳥は、一番大きさうな藥屋でヘルプを買つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎今夜は嘔吐やや烈しかりしために腹具合悪く、食慾なけれど、無下にことわるも如何にて、煎餅より外に何もないか、といへば、今日貰ふたる日光｜羊羹ありといふ。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月の十一日は、私はすこし腹具合を惡くしてゐたので、旅疲れのしたからだを一日休めることにした。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "御蔭で今日は腹具合が悪くつて不可ない」「又神経だ」「神経ぢやない本当だよ。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "就職問題など一にかかって、支配者の腹具合にあると云うべきだろう。",
              "citation": {
                "source": "学生の技能と勤労大衆",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき課長がいつもの時間に見廻ってきて、Ａに「もう腹具合はよくなりましたか」と心から心配そうに尋ねたものです。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿から学校までは、五町あまりのものでありましたが、大変谷村さんには腹具合のいゝ散歩で、その学校までの道筋には、麻雀荘だの、安カフエー、古本屋、魚屋、床屋、玉突場なぞ何か安直な肩の張らない店が、煤けて並んでいました。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御蔭で今日は腹具合が悪くって不可ない」「又神経だ」「神経じゃない本当だよ。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "足だとか手だとか、腹だとかいってみても、腹具合以上の感じ以外に何を知っているといえるだろう。",
              "citation": {
                "source": "過剰の意識",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに同席の支那の友人某君に「それはチブスに危險ですからお止めなさい」と言はれて、急に腹具合が惡く、それから一週間ばかり今日發病するか、明日參るかと心配したことである。",
              "citation": {
                "source": "異國さかな雜談",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は「いや今日は少し腹具合が惡いので、洵に失禮をします」と辯解して其の後の皿は食べず、早く食卓を離れて直ちに街の料理屋へ走つたことであつた。",
              "citation": {
                "source": "異國さかな雜談",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御飯の量は、みずからの腹具合に相談して、盛ったらよい。",
              "citation": {
                "source": "てんぷらの茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "というは、腹具合が悪くて、飯を一度食わなかったから。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞見の方は腹具合を悪くして、寛斎の介抱などを受けていたために、神奈川を立つのが二、三日おくれた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二日ほど前あたりから彼は腹具合を悪くして、わざわざ中津川の景蔵と香蔵とが誘いに寄ってくれた日には、寝床の中にいた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日散歩したるが故にや今朝腹具合よろしからず。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "両三日腹具合大に好し。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之一大正六年丁巳九月起筆",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃腹具合思はしからず。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            },
            {
              "text": "余病後六年汁粉を口にせざりしが、この頃の腹具合なれば気遣ふにも及ばじとて、二椀を更へたたり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹具合よろしからず。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅雨中腹具合例によつてよろしからず。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "にんじん――母さんの腹具合によってだよ。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度腹具合も北山だらう、一杯身につけようぢやないか」　平次は斯んな事を言つて、ヒヨイと顎をしやくりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど腹具合も北山だろう、一杯身につけようじゃないか」　平次はこんな事を言って、ヒョイと顎をしゃくりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪を引いた上に、腹具合まで悪くなったので、翌日は終日床についていたが、骨董屋達が古い陶器を見せにやって来て、私は私の蒐集を大いに増大させた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの時私は腹具合が惡くて便所へ行つてゐたのですよ」「誤魔化したつて駄目だよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "一番札",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいか、大変、腹具合はいい。",
              "citation": {
                "source": "うどんのお化け",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、本当のことを言えば、毎食毎に、メニュウを全部平げていた日には、腹具合は兎も角として、倦き倦きしちまう。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹具合悪いからハネて、サムボアで、上等ウイのキャメオを少々のみ、トースト、オムレツといふところで、帰宿。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
