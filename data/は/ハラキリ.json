    "definitions": [
      {
        "index": 1,
        "gloss": "harakiri",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まかり間違えば腹切り道具のこの事件に対して、彼がこんなに冷淡に構えているのを、半七は不思議に思いながら、もう一度この男の顔を見直した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも静かなり、ただ、腹切りし苦しさに肩衣をはねのけし瀬尾、その青き松の震慄。",
              "citation": {
                "source": "庭園の雨",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "まかり間違えば、やはり腹切り仕事である。",
              "citation": {
                "source": "鐘ヶ淵",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな様方も御覧の通り、六段目の幕があきまして、腹切りまでは滞りなく済みましたが、若旦那の勘平が刀を腹へ突っ込んで、手負いの台詞になってから、何だか様子がおかしくなったのでございます。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうその頃には、わたしに「熊谷陣屋」や「勘平の腹切り」を見せてくれた印板屋の定さんはどこへか立去ってしまった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに触れるが否や、大騒動が勃発するという死点、この危機に今や日本は面しておりますが、かかるときには、日本民族本来の無の精神は直ちに実行を見出し、外国人が常に日本人に対して抱くところの、かの腹切りとなって、生命を無にして後悔することもないのであります。",
              "citation": {
                "source": "我等と日本",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、今まで梶の横で誰とも話さなかったむっつりした一人の婦人が不意に梶に向って、「日本人はどうして腹切りをするのです」　と訊ねた。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "梶の横に通訳のようにいた友人は、「日本人の腹切りは見栄でやるのか責任を感じてやるのかと、この婦人が訊ねるんですよ」　と梶に説明した。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人のやる腹切りのようなわけだ。",
              "citation": {
                "source": "襟",
                "author": "オシップ・ディモフ　Ossip Dymoff",
                "note": "青空文庫"
              }
            },
            {
              "text": "……帰り来ぬ間に腹切りたく……脇差しお貸しくださりませ」「生きて甲斐なき浮世でござるよ」　足音の主もしみじみといった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌は私の腹切り道具。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北条の腹切り窟の石塔を、今のうちに撮影しておかうなどと、殊勝な心掛をおこした。",
              "citation": {
                "source": "ハビアン説法",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "……殿さまの恐縮もさることながら、駕籠について行った用人、氷見役一同、ことによったら腹切りもの。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "氷献上",
                "note": "青空文庫"
              }
            },
            {
              "text": "……存じてもおろうが、紀州侯は、諸事ご厳格な方であらせられるから、このようなことがお耳に入ったら、お忿怒もさぞかし、とても、二人や三人の腹切りではあいすむまい。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "御代参の乗物",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽く行って閉門、悪くすると腹切り。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "御代参の乗物",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、腹切りと覚悟をきめてしまったのか。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "研屋五兵衞の遺書が表沙汰になると、御腰物方が三人、腹切り道具になるが――」　笹野新三郎が暗い顏をするのも無理のないことでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "買つた遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となつては何分遲い」　清左衞門は寛げた肌をかき合せると、屏風を引き寄せて、腹切り道具を隱し、火桶の側に二人をさし招いて話し出しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ間違ったら腹切り道具だから。",
              "citation": {
                "source": "女記者の役割",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりすると腹切り道具ですから、小堀平治も全く気が気じゃありません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第五夜　悪魔の反魂香",
                "note": "青空文庫"
              }
            },
            {
              "text": "研屋五兵衛の遺書が表沙汰になると、御腰物方が三人、腹切り道具になるが――」　笹野新三郎が暗い顔をするのも無理のないことでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "御腰物方御役人にしても、これが表沙汰になっては腹切り道具だ」「…………」　石川良右衛門は、奇怪至極なことを語り進みます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "買った遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となってはなにぶん遅い」　清左衛門は寛げた肌をかき合せると、屏風を引寄せて腹切り道具を隠し、火桶の側に二人をさし招いて話し出しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "傀儡名臣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つ間違へば、御奉行｜朝倉石見守樣は申すに及ばず、御老中方に取つても腹切り道具だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金色の處女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一つ間違えば、御奉行｜朝倉石見守様は申すに及ばず、御老中方にとっても腹切り道具だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金色の処女",
                "note": "青空文庫"
              }
            },
            {
              "text": "金座銀座の頭は、今日の日本銀行総裁のような非常に見識があったもので、勘定奉行と雖ども、滅多に指を差すわけに行かず、若し調べた上で、不正の貯蓄が見当らないとなると、これは腹切り道具です。",
              "citation": {
                "source": "黄金を浴びる女",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙にお絹が天狗に浚われたのだから、幸いにしてお絹は帰って来たからいいようなものの、もし帰らなければ、所詮自分の腹切り勝負だと思いました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "駒井能登守の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し彼の友人が腹切りをすることがあれば、彼は首斬りの役を頼まれるかも知れない。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "金を持つてゐる町人の住家より、貧乏な武士の屋敷の方が遙かに戸締りの嚴重だつたのは、萬一筋違ひの怨みや、押込みなどに入り込まれて、辱しめを受けるやうなことがあれば、輕くて追放、重ければ腹切りもので、それに備へて、世間の人の想像もつかぬ、嚴重な注意を拂つたものです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "飛ぶ女",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「仲人は腹切り仕事だという。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
