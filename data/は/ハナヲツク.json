[
  {
    "uuid": "5f8c4c43-c94b-58c5-a12c-12eaba0d5cfd",
    "entry": "鼻をつく",
    "reading": {
      "primary": "はなをつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
