    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to assail the nostrils (smell)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鼻をつく闇に隠れて俺をからかうその高慢な鼻が気にくわぬ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん防腐の手当なぞをしてある訳でもないから、この陽気で忽ちに腐りはじめて、その臭気は鼻をつくという始末。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして昔の懐かしいかおりまでが僕の鼻をつく。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "むせるような臭気が鼻をつくと、順平には、この妓がと、嘘のように思われた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも木村が毎日米国という香いを鼻をつくばかり身の回りに漂わせて、葉子を訪れて来るので、葉子はうっかり寝床を離れる事もできなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時のようにぷんと鼻をつくものは、あのとき職人のいったように長いこともう住み手がなかったとみえて、あき家特有の湿気をふくんだかびのにおいです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "むっと臭気が鼻をつく。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻をつく硝煙、真赤な火焔、ひっきりなしの爆音、それに呼応して天空高くとび上る大水柱！",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にもホスゲン瓦斯の堆肥に似た臭が鼻をつくかと心配されたが、四分たち、五分たっても、なんの変った臭もして来ず呼吸はふだんと変りなくたいへん楽であった。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る朝、鼻をつくやけあとの匂いとまだ低く立ちこめている煙の間に、思いがけず鴎外の大理石胸像がのこっていた。",
              "citation": {
                "source": "田端の汽車そのほか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムンと若い女の体臭が鼻をつく。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "家々の屋根や日覆が、日没前の爛れたような光線を激しく反射する往来は、未練する跡もなく撒き散して行った水でドロドロになって、泥から上るムッとしたいきれが、汗じみた人の香と混って、堪らなく鼻をつく。",
              "citation": {
                "source": "樹蔭雑記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うす化粧のにおいが、汗にまじって、むんと鼻をつく。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "近世の読経は陰気くさくもあり、宗旨の匂ひが紛々として鼻をつくが、平安朝のそれは全く感じが違ひ、著しく音楽的に響いたものの様で、されば艶にとあらはされ、心よくなめらかに響いてくる読経の声を聞くなど君の帰らぬ夜もまたをかしといふ心であらうか。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの傾き落ちた墓石と、映り繁った樹木を見ると、いやな臭いが鼻をつくような心持になる。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも鮮明に、おいらん臭いにほひがむつと鼻をつく程十分描き出されて居る。",
              "citation": {
                "source": "貝殼追放",
                "author": "泉鏡花先生と里見※さん",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒倉のうちつゞく濱端の一地點に建てられた二階家の欄干に近々と浪が寄せて、潮の香の鼻をつく座敷で、夜の更ける迄酒を飮んだ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　もう酒の香が鼻をつくやうに相好を崩して應じた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の焼けただれた皮膚の臭気が硫気にまじって私の鼻をつく。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の全身は悉く腐爛し、口も眼も鼻も癩患者のようにただれ、彼より発する堪え難い悪臭が恐ろしく鼻をつく。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から南風がさっとふきこんだ、炎々たる火光と黒煙のあいだに父は非常な迅速さをもって帳簿箱に油を注いでいる、石油の臭いは窒息するばかりにはげしく鼻をつく、そうしてすさまじい勢いをもって煙を一ぱいにみなぎらす、焔の舌は見る見る床板をなめ、テーブルをなめ、壁を伝うて天井を這わんとしつつある。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻をつく木の香がそこの廊下には満ちている。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカデミスムとコンマアシヤリズムとの交叉点は、幸にして悪臭鼻をつくものがある。",
              "citation": {
                "source": "暫く黙せしめよ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつかの横町を曲り、珍しく二階建ての映画館のやうな建物の狭い階段を登りきると、むつと鼻をつく臭ひは、内地の銭湯のそれとあまり変らない。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫黄の匂いが鼻をつく。",
              "citation": {
                "source": "山と雪の日記",
                "author": "板倉勝宣",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃っぽい上に、なんだか鼻をつくような酸っぱい匂いがする。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれに代って、ひどく鼻をつくのが消毒剤のクレゾール石鹸液の芳香だった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくぶん調子を和らげるために、一度前の選集に入れたものを少し加へてみたが、それでも、全体を纏めて読み返してみると、一種十八世紀的臭味が鼻をつくのである。",
              "citation": {
                "source": "「時・処・人」まへがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "野菜の「すえ」た臭いと、屋根の梁の鶏の巣から来る臭いが入りまじって気味悪く鼻をつく。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
