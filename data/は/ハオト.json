[
  {
    "uuid": "2b01c001-8e78-5683-b3e1-69a7345a611a",
    "entry": "羽音",
    "reading": {
      "primary": "はおと",
      "alternatives": [
        "はねおと"
      ],
      "is_heteronym": false
    },
    "grammar": {
