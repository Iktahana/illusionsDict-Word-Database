        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "花の宴にこのことのあるのを珍しい光栄だと人々は見ていた。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "左大臣が来て、花の宴のおもしろかったことなどを源氏に話していた。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤花の宴も続いて同じ日に行なわれることになっているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "花宴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また院の御代の最後の桜花の宴の日の父帝、艶な東宮時代の御兄陛下のお姿が思われ、源氏の詩をお吟じになったことも恋しく思い出された。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は二条の院の庭の桜を見ても、故院の花の宴の日のことが思われ、当時の中宮が思われた。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春鶯囀」が舞われている時、昔の桜花の宴の日のことを院の帝はお思い出しになって、「もうあんなおもしろいことは見られないと思う」　と源氏へ仰せられたが、源氏はそのお言葉から青春時代の恋愛｜三昧を忍んで物哀れな気分になった。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の宴　　　　一　それから年のこよみが四たび変わって、仁平二年の春が来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "関白忠通卿が桂の里の山荘でも、三月のなかばに花の宴が催された。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の宴のあくる日で、ゆうべから酔いこけた賓客たちも日の高い頃にだんだん退散して、あるじの軽いしわぶきも遠い亭まできこえるほどに、広い別荘のうちもひっそりと静まっていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは花の宴もたけなわなるきのうの夕方の出来事で、玉藻が川端に立って散り浮く花をながめていると、そこへ主人の弟の左大臣頼長が来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に関白殿の花の宴のゆうべに、彼は自分と玉藻との語らいをぬすみ聴いていたらしく、それを白状せよと迫って土器をしい付けた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "近い頃にも関白殿の花の宴に、玉藻のからだから不思議の光りを放って暗い夜を照らしたという噂もある。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にこのあいだの花の宴にも、自分は彼と玉藻との密会を遠目に見ている。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "関白殿の花の宴の夜に、おのれひねり潰してくれようと思うていたが、あいにくの嵐に邪魔されて、そのままに助けて置いたをありがたいとも思わずに、女にむかって人もなげなる広言を吐き散らしたそうな。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光りは花の宴のゆうべに、玉藻の身から輝いたのと同じように見えた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきの夜、関白殿が花の宴のみぎりに、身の内より怪しき光りを放って嵐の闇を照らした者があるとか承る。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この春の花の宴のゆうべにも、このような怪しい空の色を見たよ」　彼の予言は外れなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは花の宴の夕にみせられた不思議とちっとも変わらなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の宴一　それから年のこよみが四たび変わって、仁平二年の春が来た。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるこうろうのはなのえんめぐるさかずきかげさして　じぶんの美声に聞きほれているかのようにマスノは目をつぶって歌った。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
