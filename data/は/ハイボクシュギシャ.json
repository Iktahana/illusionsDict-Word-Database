        "examples": {
          "standard": [
            {
              "text": "彼は根っからの敗北主義者で、困難に直面するとすぐに白旗を上げてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲から「敗北主義者」と蔑まれても、彼は無謀な特攻に反対し続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "リーダーが敗北主義者では、メンバーたちが全力を尽くそうという気になるはずがない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼奴は個人主義者で、敗北主義者で、そして裏切者だ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨斷家は甚だしばしば敗北主義者、知性の敗北主義者である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "独断家は甚だしばしば敗北主義者、知性の敗北主義者である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えれば考えるほど、朝倉先生が敗北主義者になったような気がして腹がたって来た。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
