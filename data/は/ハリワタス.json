    "definitions": [
      {
        "index": 1,
        "gloss": "to string along (of rope, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "キャンプサイトに洗濯物を干すため、木と木の間にロープを張り渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大勢の人が集まる会場に、装飾の旗をたくさん張り渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "危険な場所には、立ち入り禁止のテープが何重にも張り渡されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それには颱風の事実を捕える観測網を出来るだけ広く密に張り渡すのが第一着の仕事である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（僕はあのフイルムの動いてゐるうちに、僕の持つてゐたステツキの柄へかすかに糸を張り渡す一匹の蜘蛛を発見した。",
              "citation": {
                "source": "野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、日傘をかざすもの、平張を空に張り渡すもの、あるいはまた仰々しく桟敷を路に連ねるもの――まるで目の下の池のまわりは時ならない加茂の祭でも渡りそうな景色でございます。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "スロープの頂上から下まで、強い糸をまっすぐに張り渡す。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の年縄はただ張り渡すばかりだが、初山掛けに用いるものだけは、下げて行かれるように取手がつけてある。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
