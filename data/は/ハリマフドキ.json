    "definitions": [
      {
        "index": 1,
        "gloss": "Harima Fudoki (description of the culture, climate, etc. of Harima province; 715 CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
