[
  {
    "uuid": "a483e240-81e8-5bc3-83b7-7424dc3daeb9",
    "entry": "鼻水",
    "reading": {
      "primary": "はなみず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
