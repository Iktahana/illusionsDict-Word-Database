        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さういふ軽蔑のされ方ならその叔母のみならず毎度のことで、そんなことで腹が立つのでもなかつたが、何がなし癪に障つて、トラックの上にゐて顔に当る朝風は自分の一切合切をみる／＼削り減らしてしまふやうに感じられる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は腹が立つてならなかつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「病室の奴等は……」と思ふとその饒舌の声々に腹が立つたが、その入院してる一人々々の顔を憶ひ出すと、何にも云へぬ気がした。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その點だけでも、彼は僕にとつての益友だが、あんまり腕白小僧の我武者羅が強い時には、さすがに僕も腹が立つて、時々子供同士のやうな喧嘩をする。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを書きながら、腹が立つて仕樣が無い。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒をする、そのことが、本当に、彼には、腹が立つものゝようだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁助は、従弟が皆に笑われたり、働きが鈍かったりすると、妙に腹が立つらしく、殊更京一をがみがみ叱りつけた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やけに腹が立つわい」「腹が立つのう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいたいことは山ほどあるのだが、書生さん相手では、婆やのいうことなどは上の空に聞き流されるのだから腹が立つばかりだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して無上に腹が立つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹が立つまいことか、御察しなされませ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし腹が立つといえば、いわゆる婚約期間中にも随分腹の立つことが多かった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうです」　小沢は腹が立つというより、むしろ情けなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹吉はあっけに取られた、腹が立つというより、むしろ噴きだしたかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは無性に腹が立つので、まるで彼の顔にぶっつける様な調子で、「あの女はあなたを嫌いだって言ってましたよ。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は最初どうしても信じられなかつた、そして腹が立つてきた、そして悲痛のおもひがこみあげてきた。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はプチブル婆、プチブル爺に対して腹が立つた、そして乞食の負惜を体験した。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はムキになつて腹が立つた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉作であることがわかると、松吉は腹が立つて来ました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな日暮には、いつも温かにおつとりした良寛さんの心が、情ない程いらいらして、ふとしたことにも腹が立つたりした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいふ風で村に、はいつてゆくのは、まことにふてぶてしい奴だと、勘又さんはもう腹が立つて来た。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "武助さんは、自分の思つてゐることを、一言いつてやれなかつたので、腹が立つてゐたのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の不明とはいいながら相当腹が立つわけさ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから、あとから、腹が立つ。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもいいけれど、何ぞというと食い潰しって云われるなあ腹が立つよ。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶かされるナア腹が立つよ、ひとが心配しているのに。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何がはらがたつんだ。",
              "citation": {
                "source": "はちとくま",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
