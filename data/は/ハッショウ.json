[
  {
    "uuid": "acef34ae-3b42-5f66-a8ee-1ae47210685a",
    "entry": "発祥",
    "reading": {
      "primary": "はっしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "origin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここはおそらく明治時代における文明開化の発祥地で、またその中心地帯であったらしく、均平の少年期には、すでに道路に煉瓦の鋪装が出来ており、馬車がレールの上を走っていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "サロンは、諸外国に於いて文芸の発祥地だったではないか、などと言って私に食ってかかる半可通が、私のいうサロンなのだ。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸外国の文芸の発祥地と言われているサロンと、日本のサロンとは、どんな根本的な差異があるか。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義の本質は、それは人によっていろいろに言えるだろうが、私は、「人間は人間に服従しない」あるいは、「人間は人間を征服出来ない、つまり、家来にすることが出来ない」それが民主主義の発祥の思想だと考えている。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "富山や京都は全く別系統であって、富山が八犬の発祥地であるほかには本筋には何の連鎖もない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議にもこの中坂は文豪馬琴の史蹟であると共にまた、明治の文学史に一エポックを作った硯友社の発祥地でもある。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三河は、人も知る十八松平、葵宗家の発祥地、御領主様は智慧者でござる。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏高力、鬼作左、どへんなしの天野三郎兵衛と、語呂面白く舂引唄に作って唄いはやしたと今に古老の伝うるところですが、いずれにしてもこの一国は、江戸徳川にとって容易ならぬ由緒の土地であると共に、わが退屈男早乙女主水之介たち、譜代直参の旗本八万騎一統にとってもまた、祖先｜発祥功名歴代忘れてならぬ土地です。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、これが文学の発祥地盤だと私は思う。",
              "citation": {
                "source": "スフィンクス（覚書）",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら新しい宗教の発祥地として運命づけられていなければならないこのサイマ湖！",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそものれんの発祥した庶民の暮しは、同じ荒っぽさに一きわむき出されているのだが、そういう生活の中では、一山いくらと札の立っている瀬戸物のなかからより出して来る茶碗が実にひどいものになっているという今日の情のこわい肌ざわりしかないのである。",
              "citation": {
                "source": "生活のなかにある美について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間性を意志的に有にせんとする意欲から発祥している、「義理人情という秩序」に対して意志的に無になろうとするならば、その人は先ず第一に芸術家であることを廃業しなければならないであろう。",
              "citation": {
                "source": "「迷いの末は」",
                "author": "――横光氏の「厨房日記」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒューマニズムの発祥点が、現代の社会の特徴によって雑階級的にあること、それぞれの性格的な持物を否定せぬままに前進しようとし、また、せざるを得ない客観的事情もあり、現代ヒューマニズムがプロレタリア・リアリズムと出発を異にするといわれていることも、一応肯けなくはない。",
              "citation": {
                "source": "十月の文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "文相安倍能成は二月十一日、日本の建国記念日とされている日に、大和民族の優秀性を意味し天皇制の伝説の発祥である建国神話の再認識を求めた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本映画の発祥が明治三十年、神田錦町の錦輝館の活動写真にあることも、今では映画史の第一頁に、例の「すこぶる非常」で売った活弁元祖の駒田好洋の名と共に必ず記されることになった。",
              "citation": {
                "source": "神田界隈",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは先住民族のバリサイ人が棲んでいた理由で、パリの名称の起りをなすとともにまたパリ発祥の地でもある。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから見ると源氏物語が平安朝に出たなんか当然なんで、仏像にしても奈良朝の天平八年に菩提とか仏哲などという印度人が日本へ来て、イラン文化というようなヨーロッパ文化の発祥みたいなものを仏像として日本に入れてしまっているよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで大阪で発祥した処の浄るりを東京人が語ると、本当の浄るりとは聞えない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ日本は発祥の地ではあり得ない事は遺憾であるが、それはまだ新らしき日本が絵画芸術のみならずあらゆる文化が今急速に新らしく組み立てられつつ動いて行く工事場の混乱を示している最中である。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが新らしき日本へ新らしき花を発祥させるには根のない木を植えてはいけない。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが巴里の羨やましい処で仏像を洗い落したような尖端は発祥しない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこが、人類発祥の地だという。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、景色もよく気候もよい青島のこととて、此処に文化施設を盛んにすることによって、私のイメージは案外実際的なものとなり、新たな文化の発祥地の一つとなるかも知れない。",
              "citation": {
                "source": "北京・青島・村落",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、組踊り自身が、玉城重朝や、此人を伴うて、村をどりの発祥地たる儀来河内へ還つて了ふ、といふ心細さが、早、目睫の間に迫つてゐる。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは（一）古代エジプト王朝発祥の地としてメムフィスの名で長い間知られ、次に、エジプト王朝没落後（二）バビロンの名でローマ帝政時代の遺跡を留め、初期キリスト教の流布に貢献するところが多かった。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがパラティーノの山の北の端で、ローマ民族の伝説的発祥の地として昔から神聖視され、また帝国時代の初期には歴代の皇帝が宮殿を営んだ所として有名である。",
              "citation": {
                "source": "パラティーノ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
