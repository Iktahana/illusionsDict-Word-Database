    },
    "definitions": [
      {
        "index": 1,
        "gloss": "criminality",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "獣のような本能、鳥のような虚栄心、犯罪性、残虐性、破壊性、耽溺性などいうのが下等の部類に属するのだそうである。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神的に悪い境遇に育ったもの、生れ付きヒネクレたもの、又は、良心欠乏、無智なぞいう先天的の犯罪性を帯びたものも、静かな地方を嫌って東京に出て来る。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら秘密をつくり、秘密の帷のうちで吾と自ら吾肉体に邪悪の針を打ち込んで、快哉を叫ばんとする如き犯罪性に憧れてゐるのだらう。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知のとおり、身体に何等かの肉体的異常を持つものは、男でも女でも幼い時分から一種のひがみを持ち、だんだん犯罪性を増して行くもので、極端になると、殺人狂になり了ります。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も同じ不具者でも、殺人狂にまでなったものは、たとい嫉妬によって人を殺し、邪推であったとわかっても、オセロのように後悔しないのですが、それ程強い犯罪性のないものには、多少の悔恨の念は残って居る筈です。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犯罪性質が、彼をひとりおかなければならぬものなのであらうか。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自分の一つおいて隣りの監房に移してはならぬ獨房の男、自分に近づけてはならぬ犯罪性質を持つた男、といへば、自分と同一の罪名の下に收容されてゐる者以外にはないのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その犯罪性質が、彼をひとりおかなければならぬものなのであろうか。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自分の一つおいて隣りの監房に移してはならぬ独房の男、自分に近づけてはならぬ犯罪性質を持った男、といえば、自分と同一の罪名の下に収容されている者以外にはないのである。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間を殺すことを平気でやれるように、日夜教育し実践させた戦争の犯罪性が、まざまざと反映している上に、おどろくような権力への屈従癖が惨劇の発端をなしていることである。",
              "citation": {
                "source": "目をあいて見る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、社会主義の社会の住民として「攻撃を受けて自分自身を守り通した小さい人々」の人間価値を評価し、彼ほど衷心から戦争の犯罪性を指摘するなら、人民階級の独裁ということと、金と権力をひっくるめて独占するということとの間にあるちがいについても学ぼうとするだろう。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし興業者にこういう拒絶を可能にさせる一つの圧力があったわけで、この圧力こそ今日でもまだ日本人民に戦争の犯罪性を自覚させまいとしている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私どもが基本的人権についていう場合には第一、戦争の犯罪性ののこりとして、それで「殺す」ということについての人間感覚がにぶっているということ。",
              "citation": {
                "source": "浦和充子の事件に関して",
                "author": "――参議院法務委員会での証人としての発言――",
                "note": "青空文庫"
              }
            },
            {
              "text": "下山事件がおこると早速「非常事態宣言」の用意があると首相が声明し、それをのせたのは読売新聞であり、他新聞は、自殺説・他殺説それぞれの客観的根拠を語っているが、読売の記事は一貫して犯罪性を濃く表現し、しかもそれを何のよりどころもないのに共産党、組合と結びつけている傾向が露骨である。",
              "citation": {
                "source": "「推理小説」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『読売新聞』は一貫して犯罪性を強調し、この裏に共産党ありと、あすにも犯人があがりそうに不安な雰囲気をかきたててきたが、今日の『読売』をみると一役すんだのだろう、国鉄中闘委員会左派十四名免職をトップに、あとは野球、囲碁へと注意を流している。",
              "citation": {
                "source": "犯人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに、おどろくべく深い人間精神虐殺の犯罪性の一つがひそんでいる。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり高い顳※骨と、薄い眉とは犯罪性をあらわし、狭く尖った鼻の頭と、稍角張った大きな顎は敗け惜しみの強い性格をあらわしているが、小さな分厚い唇はどちらかといえば考えの浅い、お人好しの性格を見せている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つく／″＼彼の言行を見るに、悪事にかけては中々抜目のない男で、それに犯罪性のあるものゝ通有性として、甚だ気が変り易い。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めのようだと鴨田を陥れようとしているのは誰かという問題となり、後のようだと鴨田は自ら嫌疑をうけようとするもので、そこには容易ならぬ犯罪性を発見することになって、帆村は鴨田の性格を知るために、室内を隅から隅まで見廻して、何か怪しい物はないかと探し求めた。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は信ちやんの天来の犯罪性にぞつこん迷つてしまつたのさ。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から沼田英吉は、相手の男のうちに、一種の犯罪性を嗅ぎつけてるのだった。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "高倉玄蔵の、露わな胸元の黒い毛、太い指先、少し縮れ加減の耳朶、口元の一寸したたるみ、そして何よりも、じっと見据えたように、いやに執拗な意図と困惑の色とが籠ってること……などから彼は、誰にでもあるくらいの犯罪性を、大袈裟に抽出して、それで相手の男を批判した。",
              "citation": {
                "source": "電車停留場",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひろい意味でいえばあらゆる悲劇が犯罪性をもっている。",
              "citation": {
                "source": "探偵小説の芸術性",
                "author": "――文学のメカニズム――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふものを見たいためにあの人の犯罪性をかぎだしたわけでもないのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、回り道をした枝分かれのある操作によって死の毒の一部が生命の必需品に入り込み、これが入り込むのを可能にした人たちに犯罪性を付け加えることができない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に酒を止す気で瓢箪供養をしたのなら、たった一升だけ貧乏徳利に剣菱を残しておくはずはない、――夜中に急に飲みたくなれば、お滝を酒屋まで一と走りさせて、まずい酒でも何でも買わせるだろう」　平次の推理は、事件を次第に怪奇な――が犯罪性のないものにして行きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "瓢箪供養",
                "note": "青空文庫"
              }
            },
            {
              "text": "無職の父兄の子弟も亦そうだ（悪い意味に於ける無職というのは社会的定位を占めないことで、即ち社会では可能的な犯罪性を意味して来つつある）。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりそれは、明るみをきらう反社会的な本能をはげますことで、これが不節制、厚顔無恥、増大する犯罪性となって現われてきたのである。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、あの出来事には犯罪性というものは全く無いように思われます。",
              "citation": {
                "source": "阿部定という女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
