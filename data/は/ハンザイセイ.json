[
  {
    "uuid": "5ad9f5ed-2783-560f-9b9e-082060cfc2b0",
    "entry": "犯罪性",
    "reading": {
      "primary": "はんざいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
