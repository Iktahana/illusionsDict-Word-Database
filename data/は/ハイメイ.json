[
  {
    "uuid": "e84e4886-0727-5546-9091-9d250569594c",
    "entry": "俳名",
    "reading": {
      "primary": "はいめい",
      "alternatives": [
        "はいみょう"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pseudonym of a haiku poet",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "やゝ年下だけれど心置かれぬ友だちに、――ようから、本名俳名も――谷活東といふのが居た。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが庵に同居し俳道の弟子にする秋雄と俳名する人物もその一人である。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四季の里は俳名｜馬好と号した常に馬を楽んだ風狂の伯楽が初めて営んだものだそうであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや年下だけれど心置かれぬ友だちに、――ようから、本名俳名も――谷活東というのが居た。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "源、何、何とか云ったな、その戒名、いや俳名よ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ちねえ、お前なんざあ俳名よりその戒名の方をつけるが可いぜ、おいらが一番下駄の火葬というのを遣って、先きへ引導を渡してやろう。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで僕は、その傘雨といふ俳名を知らなかつた。",
              "citation": {
                "source": "「尾花」を読みて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二年の夏頃、大阪の書肆文淵堂の主人で、俳名春草といふ金尾種次郎氏が、その頃大阪で『造士新聞』といふ文藝新聞を編輯發行してゐた私の友人平尾不孤氏を通じて、私の詩集を發行させてくれといつて來ました。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に今晩も狂言作者で名高い河竹其水（黙阿弥の俳名）さん、戯作で売り出しの鈍亭魯文先生なぞがお見えになって居ります。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に燕枝は非常な好劇家で、常に団十郎の家にも出入りし、団十郎の俳名団洲に模して、みずから談洲楼と号していた。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村｜歿後に出版せられたる書を見るに、蕪村画名の生前において世に伝わらざりしは俳名の高かりしがために圧せられたるならんと言えり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによれば彼が生存せし間は俳名の画名を圧したらんかとも思わるれど、その歿後今日に至るまでは画名かえって俳名を圧したること疑うべからざる事実なり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は俳名再び画名を圧せんとす。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に伝わった俳名｜三升、白猿の外に、夜雨庵、二九亭、寿海老人と号した人で、葺屋町の芝居茶屋｜丸屋三右衛門の子、五世団十郎の孫である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六代西村東清信士は過去帳一本に「幼名五郎作｜自義公拜領、十五歳｜初御目見得、依願西村家相續｜被仰付、眞志屋號拜領、高三百石被下置、俳名春局」と註してある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又「俳名春局」と註してあるのを見れば、東清が俳諧をしたことが知られる。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去帳一本に「實は東國屋伊兵衞弟、俳名｜東之」と註してある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙山という名は、アンポンタンにも新しいものではない、まさかに子供でも、錦絵の智識から羽左衛門かとか尾上梅幸とかよぶようなこともしなかったから、曙山とは、沢村田之助の俳名だと知っていた。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕末頃のくさ草紙には、俳優田之助が人気があったからか、小意気な水茶屋の女なぞに環菊のお田之とかなんとか書いてあったほどだから、俳名の曙山も目からくる文字の上でのおなじみだった。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その女の人が、なんで田之助の俳名と関係があるのかがわからなかった。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "――姓は細木、名は藤次郎、俳名は香以、俗称は山城河岸の津藤と云つた男である。",
              "citation": {
                "source": "孤独地獄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村没後に出版せられたる書を見るに、蕪村画名の生前において世に伝はらざりしは俳名の高かりしがために圧せられたるならんと言へり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによれば彼が生存せし間は俳名の画名を圧したらんかとも思はるれど、その没後今日に至るまでは画名かへつて俳名を圧したること疑ふべからざる事実なり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬月師の門下に加わって、俳名をもつようになってからも、冬亭のところへ句作をもって行って、批評をきいていた。",
              "citation": {
                "source": "西林図",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻をおさいといひ、俳名を翠仙といふ、夫婦ともに俳諧を能し文雅を好り。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
