        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月あかりのために、石ころや、笹の葉や、棒杙や、掃き溜めまで白く光っていた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は掃き溜めをあさる痩せ犬のように、鼻さきが鋭敏になって、あくまで耽溺の目的物を追っていたのである。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような状況下では、全帝国における惰気倦怠の掃き溜め、このロンドンに私が居着くのは当然のことだった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧は見えかくれにそのあとに従いて行って、自分は木の実を千切ったり、掃き溜めを漁ったりして喰べて行った。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "納豆を喰うと掃き溜めの腐ったにおいがして、何とも云われずうれしい。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "過ぎ去つた快樂は現在の自分を滿足させるに足りないのに、矢ツ張り、こんなところにこびり付いてゐるのは、宿無し犬が掃き溜めの汚物に飢ゑをつなぐと同樣、ここに自分の苦痛の必然な餌じきを求めてゐるのだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだものなんか、掃き溜めへはふり投げて置いてもいい位のものだ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は目に見えて痩せて行きながら、掃き溜めの魚の骨などをあさつてゐた。",
              "citation": {
                "source": "貝殼",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝塚といふのは、前にも申したとほり、昔の人が海岸だとか、あるひは湖邊だとかに棲んでゐて、平常食つてゐた貝殼やその他の不用物をすてた掃き溜めの跡であります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすが京都で育っただけに、肌の白さ美しさ、眼鼻立ちから姿から何んとも云えず※たけて見え、こんな山家へ持って来れば、正に掃き溜めに鶴である。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間の隅へ掃き溜められて灰をかけた血の中へ指を突っ込んだ藤吉は、その指先を懐紙へ押して見ながら「うん、一昨日の子の刻だな。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "のの字の刀痕",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、そこには、手拭を頭にのせた母が、散らかつた薪屑を箒で掃き溜めているではないか。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "野良犬が掃き溜めを漁るように言って貰いたくねえ」「大層なことを言うぜ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "懐ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "野良犬が掃き溜めを漁るやう言つて貰ひたくねえ」「大層なことを言ふぜ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "懷ろ鏡",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝塚即ち石器時代人民の掃き溜めより宗教上の物を發見すとは如何にも誠しからず聞こゆべしと雖も、一定の時日を經たる後、或は一定の祭祀を終りたる後は、偶像の利益｜功力を失ふと云ふが如き考へは存し得べき事にして、尊崇すべき物品が食餘の汚物と共に同一所に捨てられしとするも敢て怪むべきには非ざるなり。",
              "citation": {
                "source": "コロボックル風俗考",
                "author": "坪井正五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独で、孤立して、世界の片隅の掃き溜めで忘れられて……　一度、例の割れた鏡を見つめて果樹園の木々の間に遊ぶ陽光を見ようと試みた。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "プティー・バンキエ街の角の所に、腰の曲がった婆さんが、街灯の光を頼りに掃き溜めの中をかき回していた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに私も、しょげてしまって、その犬の子を弟から奪い取って裏のはきだめに捨てました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『東京がなんだ、参議がどうだ、東京は人間のはきだめよ。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "はきだめを覗いちゃなら無えとか、落ちたものを拾っちゃなら無えとか云うんなら、数え切れ無え程あるんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室も寮も、ゆがめられた性慾の、はきだめみたいな気さえして、自分の完璧に近いお道化も、そこでは何の役にも立ちませんでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理の食べ残しは、はきだめに捨てるばかりである。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひねこびた色気の、はきだめという感じである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、はきだめの瓜の花一輪を、強く、大事に、育てて行こうと思いました。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけで、こんな台所へ、身分のあるわれわれが来たのも、まあはきだめにつるがおりたというものだ。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "質屋のことをいや、だんなはまたごきげんが悪くなるかもしれねえが、床屋と質屋と銭湯と、こいつア江戸のうわさのはきだめなんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の嵐の中に、塵労のはきだめのような現実社会へ、かようにして無抵抗のままで、押しやられた子供たちはどうなるであろう？",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○この街にいろいろな人が集ってくる飢えによる堕落の人々萎縮した顔　病める肉体の渦下層階級のはきだめ天皇陛下は狂っておいでになるそうだ患っているもののみの東京！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "足元はどうかというとみかんの皮や南京豆のから、あらゆる不潔物ではきだめのごとくみだれている。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなきたないはきだめによくがまんができるものだ」と光一は思った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
