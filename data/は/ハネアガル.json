    "definitions": [
      {
        "index": 1,
        "gloss": "to jump up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二日後に射った二度目からは、跳ね上がるほどの発熱はなくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆は遠くから飾りのついた短剣が、歩くたびに尻に当って、跳ね上がるのを見ていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "消え行く怪物　甲斐博士が、恐しそうに身を後に引くのと、怪物の死骸がぴょんと跳ね上がるのとが同時であった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "山女魚が、低い宙を飛ぶ羽虫を追って、水面から跳ね上がるのは毎日見ている。",
              "citation": {
                "source": "莢豌豆の虫",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女らは、煮立ったフライ油のねっとりとした雫のように、草のなかから跳ね上がる。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、跳ね上がる。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、間もなく、髪の毛の最初のひと束が、ぴんと空中に跳ね上がる、まっすぐに、自由に。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌が身を切るたびに心臓が跳ね上がる。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "尖った、焔に似た巨大な舌の形になって、なめずっては跳ね上がる。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからと言って必ず跳ね上がるとは限らない。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、跳ね上がるかもしれない。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴を扱えるだけのロープは用意してある」　おそらく、俺がほんの少しロープの張りを強めるだけで、奴は痛がって跳ね上がるだろう。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その影に驚いたトビウオの群れが、跳ね上がるのが見えた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "価格が跳ね上がるさまはあたかも果物が絶滅したドードー鳥になったかのようだった。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は黒光り、はねあがる。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しゅ、戻れったら、しゅ、」雪童子がはねあがるようにして叱りましたら、いままで雪にくっきり落ちていた雪童子の影法師は、ぎらっと白いひかりに変り、狼どもは耳をたてて一さんに戻ってきました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の声の時はねあがる。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いるかは水からはねあがるそのふざけた黒の円錐形ひれは静止した手のやうに見える。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しゆ、戻れつたら、しゆ、」雪童子がはねあがるやうにして叱りましたら、いままで雪にくつきり落ちてゐた雪童子の影法師は、ぎらつと白いひかりに変り、狼どもは耳をたてて一さんに戻つてきました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、あたしが高くはねあがると、そのたびに、ツバメさんたら、巣の中から頭を出して、『どうなの？",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなに高くはねあがるのは、まりが、そうしたいと、あこがれていたからかもしれません。",
              "citation": {
                "source": "いいなずけ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ雨が残っているような雨雲が空いちめんに流れている晩で、暗いうえに雨水を含んだ地べたがじくじくしていて、はねあがるようで早くは歩けなかった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "独法師のお島は、草履や下駄にはねあがる砂埃のなかを、人なつかしいような可憐しい心持で、ぱっぱと蓮葉に足を運んでいた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず、沖の方から、黒い方な波のうねりが段々こっちにせまって来ると思う間もなく、グーンと空高くはねあがる。",
              "citation": {
                "source": "冬の海",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり石材の値が、高くはねあがる見込みだと一般に思わせて、大儲けをしようというわけだよ。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車の排気の影響だと、もっとひどくて、三十フィート先を一台の自動車が通ると、今まで二百個くらいだったのが、一挙に十万個にはねあがる。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、なあに、こっちのことで……ただね、ただ殿様にゃア女性のにおいがするから、それでその、あんまり女の子が寄りつかねえんじゃねえかと――はははは、これああっしの勘ですがね」　ギラリと凄い光が、豆太郎の眼尻から弥生の横顔へはねあがる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお妹さんだとばかり思っていました……陶磁を見るのは、案外に疲れるものですな……どうです、むこうで、お茶でも……」テラスに吹く風　池の面をとざす青々とした杉苔のあいだで、ときどき大きな鯉がはねあがる。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、はねあがるしぶきは、高い絶壁をおおい、熱帯の強い日光があたって、絶壁の肩に、七色の虹をかけている。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると突然に、橇の後部が轍の中へらしくめりこんで、梶棒がかじりついているハルもろとも空中へはねあがるのが見えた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
        }
