        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひとつ、ここはうんとハッスルしてもらって、ことマイクロ・コンピュータ技術資料に関する限り、世界中のエンジニアが、日本語を知らなければ遅れをとるというぐらいに、がんばってほしいものである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は亡母の命日だったけど僕は何となく亡母もよろこんでくれている様に思えて子供になってハッスルしました。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんながハッスルしたのです。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
