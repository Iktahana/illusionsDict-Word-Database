        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "童話にあらわれていた味は、生活的な成長から諷刺に転じて、小熊さんの鋭い反応性と或る正義感と芸術的野望とは、諷刺詩を領野として活躍しはじめた。",
              "citation": {
                "source": "旭川から",
                "author": "――小熊秀雄氏の印象――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイデルバーガー博士と協同して免疫した動物の特異抗体の化学反応性について実験を行った(66)。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "正常の体内におけるタンパク質の化学反応性はアミノ基に限られていない。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "グルタミン酸はもっとも反応性のあるだけでなく動物タンパク質にもっとも多いアミノ酸である。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "３日後に尿は自然の色および反応性に戻った。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの尿から融点と反応性がホモゲンチジン酸に一致する酸成分を抽出した。",
              "citation": {
                "source": "アルカプトン尿の発現",
                "author": "THE INCIDENCE OF ALKAPTONURIA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
