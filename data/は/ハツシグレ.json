    "definitions": [
      {
        "index": 1,
        "gloss": "the first rain to fall between the late autumn and the early winter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夕ぐれ、ばら／＼と降つた、初時雨だらうか、まだ時雨が本質的でなかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "番組は「鶴亀」、「初時雨」、「喜撰」で、末に好として勝三郎と仙八とが「狸囃」を演じた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "初時雨と云うのだろう。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "初時雨あるべき空を見上げつゝ十一月八日　草樹会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初時雨その時｜世塵無かりけり十一月七日　句謡会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初時雨しかと心にとめにけり水餅の混雑しをる壺の中一月二十九日　「玉藻五句集（第八十一回）」。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「初時雨猿も小蓑をほしげなり」という句については其角が「猿蓑」の序でこういうことを言っています。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊賀の山中で樹上にいる猿を見た時におりふし初時雨が降ってきた、その初時雨の淋しさが腸に沁みこむように覚えられた時自分の情を猿に移して猿も蓑をほしげだと言ったその心持に俳諧の生命はあるというのであります。",
              "citation": {
                "source": "俳句とはどんなものか",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お寒うございます」というのと大した相違はないが、その初時雨の降った時の景色を言い合って挨拶を交したのである。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初時雨の降っている時、町なら町を歩いている。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし時雨の趣を解するような人が、初時雨を愛でて柚味噌を焼いているというほど、殊更な趣向とも解したくない。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
