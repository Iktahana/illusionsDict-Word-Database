        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ポルトガル奥さんは、まったく話がうまいんだよ」と、みんなは言いました。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "何に話がうまいって、どうして話どころでなかった、積っても見ろ、姪子｜甥子の心意気を汲んでみろ、其餅のまずかろう筈があるめい、山百合は花のある時が一番味がえいのだそうだ、利助は、次手があるからって、百合餅の重箱と鎌とを持っておれを広福寺の裏まで送ってくれた。",
              "citation": {
                "source": "姪子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このひとは君、なかなか話がうまいよ。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「話がうまいから。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がうまいのは、明けっ放しで、機智のあるせいらしく、それにブチこわしなあけすけの程度にも、妙に程の良いところがあって、相手の好寄心と好意とを、手いっぱいに引出す力を持っていそうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーアは手話がうまい。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "話がうまいのは、明けつ放しで、機智のあるせゐらしく、それにブチこはしなあけすけの程度にも、妙に程の良いところがあつて、相手の好奇心と好意とを、手一杯に引出す力を持つてゐさうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
