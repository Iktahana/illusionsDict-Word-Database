    },
    "definitions": [
      {
        "index": 1,
        "gloss": "transportation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ水中電話器から発する連続性の搬送音だけが、かすかに受話器に入って来ている。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の塔が竣成して間もなく、専門家が長い間の研究と実験を経て完成されたチャイムの鐘が十二個イギリスから搬送されて来たのである。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイクは更にメッセージを送ってきて、十四体の大型標本のキャンプへの搬送が完璧な成功裡に終わったと言った。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四個のＶＦＯはそれぞれ映像搬送と音声搬送の機能を果たす二個一組の全部で七組に分れ、各々がダイプレクサーを仲介して結びついている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "更にその下はＪを独立変数とする二つの関数が、ＲＥＡＤ／ＤＡＴＡ文で順番に並べられた映像搬送周波数と音声搬送周波数の値をそれぞれ取るようになっている。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の山の麓から北方に拡がるサンホセの盆地から、米機の眼を盗み、兵達が搬送して来た籾をバンカに連ね、既に朝の籾｜搗きが始まったのであろう。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしツゲガラオ飛行場から飛び立つ米機のため、昼間は籾の搬送は出来ぬ。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャリングクロス病院まですぐ搬送してくれ」二　神経で胃が弱るたちじゃないジェームズ・チェイス氏こと、前ニューヨーク・チャンティクリア新聞記者、現モーニング・テレフォン新聞記者は、ハーリ通りの角で煙草に火をつけた。",
              "citation": {
                "source": "死の川",
                "author": "THE RIVER OF DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ははんそうか、さてはだれかその用人の身内の者がお手討ちの恨みを晴らすために、あんな左の目のない生首をこしらえて、味なまねしやがったんだなと思いましたからね、すぐにおやじへきいたんでがすよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "と泣きつかれて見りゃ、ははんそうかね、で見過していられるかい？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘレナ　かくはんそう？",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、このまま仙太を追放しといて仇も打たなけりゃ、他の親分衆に挨拶も出来なくなるし、せっかくの仏瀧一家の名跡も絶え、渡世の看板もこれですたれる、どうしたもんでしょう、くらやみの、と泣き付かれて見りゃ、ははんそうかねで見過して居れるかい？",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
