  {
    "uuid": "17365d7c-38f0-5285-ba8b-a0515117ec8f",
    "entry": "搬送",
    "reading": {
      "primary": "はんそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
