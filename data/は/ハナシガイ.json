[
  {
    "uuid": "33dee33d-0118-5739-b500-80a29a607f5d",
    "entry": "放し飼い",
    "reading": {
      "primary": "はなしがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
