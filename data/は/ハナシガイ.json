    },
    "definitions": [
      {
        "index": 1,
        "gloss": "worth in speaking (to someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、そのつき合いに対しても、一葉は一面に男の人たちはよろずにおおらかで、話し甲斐もありと見ゆれど「それもさるものにて、いさゝかやましきことそはぬにしもあらず」という気持をもっている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら尚の事、話し甲斐があるんだ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この有様を見てポルトガル人たちは非常に感動し、世界を廻っていろいろ珍らしいことを見たが、今日見たことほど話し甲斐のあるものはない、と云った。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が亡くなってから、当然あとのはなしがいろいろ出た。",
              "citation": {
                "source": "寒橋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十面相や部下のものには、よくなれているので、はなしがいにしてあるのです。",
              "citation": {
                "source": "奇面城の秘密",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう他から結婚のはなしがいろいろ持込まれるのであった。",
              "citation": {
                "source": "日本名婦伝",
                "author": "太閤夫人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
