          "literary": [
            {
              "text": "博士は、博識多才、一代に超絶す。",
              "citation": {
                "source": "南洲留魂祠",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな博識多才の名士だって、君、九年も戸を出なかったら、京都の事情にも暗くなりますね。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五巻の不木全集に知られるとおり、博識多才、病いを養いつつも、専門の研究をつづけ、その余力を探偵文学と犯罪科学の研究にそそぎ、「新青年」の発展に寄与するところ多かったことは、今更書き記すまでもあるまい。",
              "citation": {
                "source": "三十六年前",
                "author": "森下雨村",
                "note": "青空文庫"
              }
            }
          ]
        }
