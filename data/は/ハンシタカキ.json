        "examples": {
          "standard": [
            {
              "text": "彼は長年、版下書きとして多くの作品を手掛けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "版下書きの技術は、印刷物の品質を左右する重要な要素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "デジタル化が進んだ現代でも、熟練の版下書きの需要は高い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一見、書家の書体であり、版下書きの書体である。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは坊間ざらに見る、僅かに数銭を投げうてば、たちどころに揮毫するところの版下書きの書ではないか。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大著成るに及んで、最後の大切な表紙の題書を坊間の版下書きの書をもって満足するとはなにごとである。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、『名器鑑』のような大著の上になんとしても考えもなく低級な版下書きの書を用いしや。",
              "citation": {
                "source": "高橋箒庵氏の書道観",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
