        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国が箱庭的であるからか音楽まで箱庭的である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物ぐるほしけれど箱庭に作りたる石一つ水の面にそと取落せば、さゞ波すこし分れて、これにぞ月のかげ漂ひぬ。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ひ換へれば、氏の作品の多くは優れたるものと雖も、何処となく名匠の手になつた箱庭を見るやうな感じがする。",
              "citation": {
                "source": "現代作家に対する批判と要求",
                "author": "――全人間的な体現を――（その一、芥川龍之介氏）",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱庭は言葉どおりに庭園のミニアチュアである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石垣のある土手を右に、左にいつも見る目より、裾も近ければ頂もずっと高い、かぶさる程なる山を見つつ、胴ぶくれに広くなった、湖のような中へ、他所の別荘の刎橋が、流の半、岸近な洲へ掛けたのが、満潮で板も除けてあった、箱庭の電信ばしらかと思うよう、杭がすくすくと針金ばかり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所で、小さな兒が、おもちやに小庭にこしらへた、箱庭のやうな築山がある。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に水竿を控え、彼方此方に佇んで当惑する船夫の姿は、河面に蓋をした広い一面板に撒き散した箱庭の人形のように見えた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈籠やら、いくつにも分岐した敷石の道やら、瓢箪なりの――この形は、西洋人なら、何かに似ていると言って、婦人の前には口にさえ出さぬという――池やら、低い松や柳の枝ぶりを造って刈り込んであるのやら例の箱庭式はこせついて厭なものだが、掃除のよく行き届いていたのは、これも気持ちのいいことの一つだ。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬱蒼たる熱帯林や渺茫たる南太平洋の眺望をもつ斯うした土地に、自分の力で一つ一つ生活の礎石を築いて行くのは、スティヴンスンにとって、子供の時の箱庭遊に似た純粋な歓びであった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の上に椰子と蛸樹と家々とを程良くあしらつた小さな箱庭のやうな。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の上に椰子と蛸樹と家々とを程良くあしらった小さな箱庭のような。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "朶石からは画の他に漢詩作法と篆刻と築城講話と、そして国手から半弓と碁と笛と釣りと箱庭作法とを習つた。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は前にも増して弱虫で、疳癪持ちの青白い子供で、幻灯にも馬にも飽きて、箱庭などをつくつた。",
              "citation": {
                "source": "肉桂樹",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――望遠鏡を、あべこべにして見ると風景は、実際の距離の二倍に遠くなつて、さながら箱庭のやうに小さく映る――独りになつた時のこの頃の彼の心境は、そのやうに熱がなく、まつたく箱庭の泥で拵へた豆人形になつてゐた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隨つて東京の近郊は、箱庭的の風景なくして、所謂大陸的也。",
              "citation": {
                "source": "東京の近郊",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "山寺を箱庭的といふ者もあらむ。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱庭的といふとも、これくらゐ面白き箱庭的の處が他にあるかと云ふ者もあらむ。",
              "citation": {
                "source": "遊羽雜感",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "検疫官の官舎の白い壁も、そのほうに向かって走って行くモーター・ボートも見る見る遠ざかって小さな箱庭のようになった時、葉子は船長室でのきょうの思い出し笑いをしながら、手欄を離れて心あてに事務長を目で尋ねた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱庭の人形のやうな女は私の方をキョトンと眺めてゐます。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い松と薄い紅葉がぐあいよく枝をかわし合って、箱庭の趣がある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論敵は取り逃したのは云ふまでもなく、漸く身を起した時には、もうその電車も発車の後で、遥かの河下の森蔭に近い停車場で、田圃道を駈けて来る乗客を待つてゐるのが、箱庭の景色ほどに見えた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓なりの入江の中腹で彼等は、箱庭のやうな景色を眺めた。",
              "citation": {
                "source": "Ｆ村での春",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その箱庭の人形のやうな女は私の方をキヨトンと眺めてゐます。",
              "citation": {
                "source": "晩春の健康",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱庭作りのやうに器用な幽斎は、何の雑作もなく、「かならずと契りし君が来まさぬに　　　強ひて待つ夜の過ぎ行くは憂し」と、有り合はせの楢と橡と桐と樒と柿と椎と松と杉と柚と桑とを詠み込んで見せたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正十一（一九二二）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も箱庭の中にて俳句をものせんとならばそれにても好し。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかり、宗匠の俳句は箱庭的なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
