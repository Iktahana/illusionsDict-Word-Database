        "examples": {
          "standard": [
            {
              "text": "この素材の反射率は非常に高く、太陽光を効率的に跳ね返す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "屋根に白いペンキを塗ると、反射率が上がり、室温の上昇を抑える効果がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "反射率の高い鏡は、光をより多く宇宙空間に反射させる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "からだを、空気と同じ反射率、屈折率をもたせることにあった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際風雨に対する耐久力とか、太陽光線の反射率とかいう点では、アルミニウム・ドープは非常に優秀な性能があるので、何とかこの儘で電気的性質の改良が出来ればよいのであるが、当座のところは仕方がないのであった。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
