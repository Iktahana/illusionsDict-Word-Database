    "definitions": [
      {
        "index": 1,
        "gloss": "City of Flowers (nickname for various cities, esp. Paris and Florence)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その夜、花の都、ネオンの森とやらの、その樹樹のまわりを、くぐり抜け、すり抜け、むなしくぐるぐる駈けずりまわった。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "）媛神　花の都の花の舞台、咲いて乱れた花の中に、花の白拍子を舞っている……巫女　座頭俳優が所作事で、道成寺とか、……申すのでござります。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――焼け残った幸福な花の都の京都の人々にお願いします。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の事と云ふものは、座敷で道中雙六をして、花の都に到達する如きものではない。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『応仁記』等に依って見ると、如何に被害が甚大であったかを詳細に列挙して、「計らざりき、万歳期せし花の都、今何ぞ狐狼の臥床とならんとは」と結んで居る。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の事と云うものは、座敷で道中双六をして花の都に到達するようなものではない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲きてとく散るは憂けれど行く春は花の都を立ちかへり見よまた御運の開けることがきっとございましょう。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相は出て行く気がしないで、飽かなくに雁の常世を立ち別れ花の都に道やまどはん　と言って悲しんでいた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "花は櫻、櫻は日本、日本の中にても東京附近、げに／＼花の都なる哉。",
              "citation": {
                "source": "小利根川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の都變じて塵の都となる。",
              "citation": {
                "source": "千川の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "匙を投げかけた記者　東京はこんな風に、大人の享楽主義の天国であるように、少年少女の花の都である。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも述べた通り、花の都の生存競争は生き馬の眼を抜く程激烈なものであった。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「須田町は花の都の親知らず」　と云うが、今ではその親知らずが東京中に拡がって、とても女子供や老人と構ってはいられない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父の義明がこのたびの上洛について、可愛い孫娘にも一度は都の手振りをみせて置きたいという慈愛から、遠い旅をさせて一緒に連れて来たが、なるほど花の都にもあれほどの美女は少ない。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花の都も」と歌いすすむと、見る見る涙が女の頬を伝いまして、落魄た袖にかかりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "壮麗を極めた花の都の中にぎっしりと立ち並んでいる家々は各々の美しく高い甍をお互に競争し合っている。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の都をあとはるばると。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、すくなくとも、今日の社会、東洋第一の花の都には、地上にも空中にも、おそるべき病菌が充満している。",
              "citation": {
                "source": "死刑の前",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "時人謡ひて曰く「咲きつゞく花の都をふりすてて、風ふく原の末ぞあやふき」と、然り真に「風ふく原の末ぞ」あやふかりき。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫も花の都の電車が通つてる所なら、まだしもだが、日向の延岡とは何の事だ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも花の都の電車が通ってる所なら、まだしもだが、日向の延岡とは何の事だ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリは決して人の言ふやうな花の都ではない。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "舊きは廢れ街衢、また新しく榮ゆべき花の都の片成りに成りも果てざる土の塊、塵に塗るる草原の、その眞中に畏しき大電働機の響こそ日も夜もわかね、絶間なく。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロセチ白耳義旅中の吟『ルバイヤット』より其一泥沙坡とよ、巴比崙よ、花の都に住みぬとも、よしやまた酌む杯は甘しとて、苦しとて、絶間あらせず、命の酒うちしたみ、命の葉もぞ散りゆかむ、一葉一葉に。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹としては、まだ見ぬ花の都を見飽きるほど見て帰れるし、それは、れっきとした後ろだてがあって、体面が保てて、生活が安定するのだから、ほんとうにこの辺で納まるのが何よりという里心にもなったのでしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は日本見物をしたいと云ふ考で早速用意にとりかゝり、花の都の東京さして東海道を真一文字に東の方へとんで行ったが、地図で見ると小指でつぶせるが狭いやうでも広い所、とう／＼道をふみちがへて東京へ行く筈であったのが、わらぶきの家のならんで居る田舎の奥の山又山の所へまで来てしまった。",
              "citation": {
                "source": "鶴と鶯",
                "author": "槇村浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて女は蒼めた顔を仰げて、　　ふるさとやはるばるここにきみゐでら　　はなのみやこもちかくなるらん「故郷や」の「や」には力を入れました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
