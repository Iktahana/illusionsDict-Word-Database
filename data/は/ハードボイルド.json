        "examples": {
          "standard": [
            {
              "text": "彼は感情を表に出さない、まさにハードボイルドな男だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この映画の主人公は、都会の闇を生きるハードボイルドな探偵だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のファッションスタイルは、どこかハードボイルドな雰囲気を漂わせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私は人呼んで「ハードボイルド」な男だと言っていいと思うんだが、その部屋の壁に掛かっているのを見たら気分が悪くなったよ。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
