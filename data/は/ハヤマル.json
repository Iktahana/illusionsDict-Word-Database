    "definitions": [
      {
        "index": 1,
        "gloss": "to be brought forward (e.g. by three hours)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宰牛この事早まるべからず、男を生むか女を生むかを見定めた上、果して男を生んだら殺したまえと諫め、王その言に随い大臣をして后を監視せしむ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　会話の速度が早まるにしたがい、私は一そう切口上だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると「いや早まるな。",
              "citation": {
                "source": "勇子",
                "author": "一つの追憶",
                "note": "青空文庫"
              }
            },
            {
              "text": "それさえ解れば千人力……」「ま……ま……まあ早まるな。",
              "citation": {
                "source": "超人鬚野博士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が忙くので足が早まる。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車の速力の早まるにつれて、まさ子の顔から微笑の翳が消えていつた。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に早まる太鼓の音。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ここで調子が、にわかに早まる。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨　（その手を抑さえて）早まるな、主君と家来ではない。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、早まるな、それほど皆なに知れて居る短刀で人を殺す馬鹿はない。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "路地の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、早まるな、それほど皆んなに知れている短刀で人を殺す馬鹿はない、おまけに、殺して二た刻（四時間）も経つのに、その目印の刃物を抜かずにおくということがあるものか」「ヘエ」「これを見るがよい、これは誰のだ」　死体の側から拾い上げたのは、金唐革の洒落た懐煙草入が一つ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早まるってどういう点でですか？",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブスマン　待ちなさい、ドミン、早まるんじゃありません。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかる、わかる、そしてテンポ（内容に近づく）が早まる。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この通り手をついてあやまる」「もうよせよ」「ところで今度は僕が君の為に一つ運動する」「僕は今貰っても仕方がない」「おっと、早まるなよ」「それじゃ何だい？",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬間、流石の法医学者も、勇敢なその助手も、動悸の早まるのをどうすることも出来なかった。",
              "citation": {
                "source": "悪魔の紋章",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートリスは心臓が早まるのを感じた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "明らかに無関係だし、名前を出せば経営醜聞が早まるだけだし、一番避けたかったからだ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に背を向ければ、悲劇が早まるだけだし、何としても一番避けたい。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが偽らぬボクの気持だけど……」「はやまるのは身の破滅よ」「はやまるわけじゃないよ。",
              "citation": {
                "source": "握った手",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いやはやまるっきり分りませぬかな？",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思うて心ははやまるのだ。",
              "citation": {
                "source": "愛の詩集",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても遁れぬことなれば、今にても庄大夫尋まゐり候へば、わが息にかゝらぬよふに、臍の下をあさく皮をたち切り、我命此通り也と申、一々咄し、ゑぐりし事もはなし、其上にて自害いたすべし、と心を定め、門の戸叩き候へば、直に臍の下きり出、其訳申べし、とおもふ内、はや戸叩きしが、先づ、はやまるまじ。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫉妬で、そんな考へにはやまるな。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやまるなよ、いちじの哀れさに負けるな。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は女を突き放し、「私は道場の平手幹太郎だ、はやまるな」と、叫んでとびさがった。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、味方の五百余艘が、父孫堅の龍首船をまん中にして、江上に船陣を布き、「孫策、はやまるな」　と、小舟をとばして伝令して来たので、孫策もうしろへ退いて、父の船陣の内へ加わった。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやまるなっ――」　続いて後ろのほうに聞える。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
