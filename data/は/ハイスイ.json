    },
    "definitions": [
      {
        "index": 1,
        "gloss": "water supply",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "配水管ではなかろうね？",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "配水、排水設備　　　　　　　　　　七〇〇円？",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は吹きつけられず、配水管もまったく機能しなかった。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが家の井戸なども、名水の一つださうだが、配水裝置をしたために、あたら水の味を惡くしたと、ポンプ屋に笑はれた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前住んでいた大阪郊外の家は電力で井戸水をタンクに入れ、そこから家々にパイプで配水する仕掛けになっていたが、このスイッチがどうかして故障を起すと、誰か梯子を登ってスイッチ・ボード迄行かなくてはならぬ。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
