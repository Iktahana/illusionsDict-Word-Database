    "definitions": [
      {
        "index": 1,
        "gloss": "rebellious spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
