    "definitions": [
      {
        "index": 1,
        "gloss": "buying club (e.g. fruit-of-the-month)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
