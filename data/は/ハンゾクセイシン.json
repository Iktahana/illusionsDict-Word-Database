        "examples": {
          "standard": [
            {
              "text": "その若き詩人には、既存の枠に囚われない反俗精神があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の音楽は、反俗精神に満ちている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "反俗精神こそが、新しい文化を生み出す原動力となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "信吉の意に適っているのは、野放図、破天荒、横紙破り、常規を逸したもの、破目を外したもの、尻尾を出すこと――いわゆる反俗精神の裏づけあるものに限られていた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの友愛は、ラ・ボエシの自由の精神、反俗精神がもとで結ばれたと言えるであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからモンテーニュは、ラ・ボエシの自主独立の反俗精神を、別の方法で宣布しようとする。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
