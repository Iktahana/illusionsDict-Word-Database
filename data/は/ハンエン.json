[
  {
    "uuid": "1d0c7811-82c7-5542-8515-2fbc104fb184",
    "entry": "半円",
    "reading": {
      "primary": "はんえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
