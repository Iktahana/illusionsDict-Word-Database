[
  {
    "uuid": "9a7909f7-e2bd-51cd-9a69-b4484b540b19",
    "entry": "鼻薬",
    "reading": {
      "primary": "はなぐすり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
