[
  {
    "uuid": "b31558f3-6c51-5b67-a977-54d0654d5ace",
    "entry": "反する",
    "reading": {
      "primary": "はんする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
