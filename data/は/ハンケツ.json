[
  {
    "uuid": "2e232e26-cc0e-54f9-9e7c-ce751ba33fd0",
    "entry": "判決",
    "reading": {
      "primary": "はんけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
