        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "突然、茂みの中からウサギが勢いよく跳ね出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "閉じ込めていた感情が、我慢できずに一気に跳ね出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の才能は、若くして周囲の期待を大きく超えて跳ね出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "両手を後へ引いて飛込みの姿勢になるときが二で、跳ね出す刹那が三の、すべてで三挙動である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな魚でも七彩の虹をもつ、金銀の閃光をもつ、そして水の青冥を截つて、初めて明るい気層へ跳ね出すのであるから、魚が驚いて、怒つて、反抗して、鰭をひらき、腮をふくらし出来るだけ跳躍を試る。",
              "citation": {
                "source": "夏と魚",
                "author": "佐藤惣之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "金をひいて守りをかためるか、歩をついて様子を見ればおだやかであるが、桂をはねだすと乱戦模様になる。",
              "citation": {
                "source": "桂馬の幻想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
