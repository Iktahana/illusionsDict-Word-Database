[
  {
    "uuid": "810d0103-10fd-5633-8160-68c4bd94332d",
    "entry": "働かす",
    "reading": {
      "primary": "はたらかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
