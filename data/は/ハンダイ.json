[
  {
    "uuid": "73778ee3-6a51-5854-935b-31894a5100aa",
    "entry": "飯台",
    "reading": {
      "primary": "はんだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(Japanese-style) dining table",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外のもっと年のいった、経験の多い兄哥連は、晩酌を一本やったら、おだを上げたりして、まだ土間の飯台から立ち上がらないのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時としては飯台思案外史とも称していた。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、その後何度も顔を見ても、気焔咄を恐る恐る傍聞しているだけで、益々都々逸や川柳に精しいのを感服したが、『読売』の投書欄でお馴染の中坂｜乃至飯台思案外史をこの五分刈の巨頭君に結びつけて考える事は出来なかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "思案外史はその頃中坂から一丁半ばかり、富士見町の裁判所の横手の、今は暁星中学校の構内に囲込まれた処に住んでいたから、中坂というは少し無理だが、馬琴がしばしば飯台｜蓑笠漁隠と称した如くに飯台を戴く因縁は持っていたのだ。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっと目を据えて見ると、土の上にじかにおかれた細長い飯台に向いあって、漁夫、馬橇引、百姓などとりまぜて七八人が腰をおろしていた。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "めったにそんなところに来たことのない帳場が、飯台にズラリとならんで飯を食っている漁夫たちのところへやって来た。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（船頭、下船頭は帳場と一緒に事務所で、お膳つきで飯を食うことになっていて、ここにはいなかった）食事がおわりかけたころ、飯台の端の方に坐っていた山本が、突然立上って口を切った。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側に背を向け、小さな御飯台に片肱をかけ、頭をまげ、私は一心に墨を磨った。",
              "citation": {
                "source": "雲母片",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ここ」　私は、七歳で、真白い紙の端に墨の拇印をつけながら、抓んで半紙を御飯台の上に展げた。",
              "citation": {
                "source": "雲母片",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど辛かったのだろうと思ったからさ」「この鰺はもう食べませんか」「ああ」　飯台が小さいためか、魚が非常に大きく見えた。",
              "citation": {
                "source": "清貧の書",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが飯台をはった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飯台に向うと父親はけろっとしていた。",
              "citation": {
                "source": "前夜",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は、飯台を急いで片づけながら涙声を上げた。",
              "citation": {
                "source": "前夜",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾り気の無いＡの字は掘立小屋の入り口、奥に見えるは板敷か、茣蓙か、囲炉裏か、飯台か。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉は飯台をだして平一郎に朝食をすすめた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の希望が日を逐うて潮の如く高まると共に、上飯台の連中や幹部連の凄惨な顔色は弥々深くなる。",
              "citation": {
                "source": "監獄部屋",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）　山の幹部連中は前の晩から十何里｜距った汽車の着く町迄｜出迎に出かけて居る、留守は上飯台の連中が、取片付けに吾々を追廻し乍らも、口では夫れとなく、裏切りをすれば生命は無いぞと脅すのを忘れなかった。",
              "citation": {
                "source": "監獄部屋",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方吾々下飯台の方は、幾月にも斯様なお手柔なこきつかわれ方に遭遇さないので、却て拍子抜がして、変てこだが遉に嬉しさは顔や科に隠されぬ。",
              "citation": {
                "source": "監獄部屋",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千人と一ト口に言うが、大したものだ、要所要所に上飯台の連中を配置し、寸分も足掻きを効かせまいと行届いた手配だ。",
              "citation": {
                "source": "監獄部屋",
                "author": "羽志主水",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹婿は昼間の疲で、飯台に凭れたまま眠ってるし、鷲尾はいつものように台所へいって水枕をつくると、子供たちの傍にいって横になったが、とても寝つけそうでなかった。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯台の上に赭い童顔を載せ、いっぱし女といちゃついているところを見せつけられたから、我慢がならなかった。",
              "citation": {
                "source": "蕎麦の花の頃",
                "author": "李孝石",
                "note": "青空文庫"
              }
            },
            {
              "text": "後について行くと、大きな部屋の真中に細長い飯台を据え、ギヤマンのコップやら匙やら賑かなほどに並べたて、小麦粉の切餅を大皿に山盛りに積みあげてある。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "今し方工場から帰つたばかりの嘉吉は、いつもの癖で仕事着のまゝ円い飯台の一方に場広くあぐらに据わつて、もうがつ／＼やらかしてゐた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔城下で金銀の御用細工を申附かつてゐた時分から此の家の台所の飾りである大きな円飯台の周囲が久しぶりに明るく賑やかに見えてゐた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は大勢の職人や弟子達がゐて此の飯台で二替りにも食事をしたものだとは老母がよく飯時に繰り返す一つ話であつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "一家が城下を引払つて今日の境遇になつてから、何よりも老母に今昔の感を深うさせるものは食事時に飯台の周囲の寂しいことであつた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのおもひたちの、決して無理でも、ないものねだりでもたかつたことは、紫の事務服、白いエプロンをかけた売店の女たちの、甘栗のふくろをさげたり、水菓子のはんだいをかゝへたりして桟敷の間をまご／＼するのとゝもに、わたしは、呼出しのたッつけのかげにかくれた白ちりめんの兵児帯。",
              "citation": {
                "source": "角力",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれごらんなさい、あれはまだ新しい盃とはんだい――まあ、こちらの方から、女の帯が流れて来ますよう」　盃とはんだいと言っていた間はまだいいが、女の帯と言われて、一座がゾッとしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
