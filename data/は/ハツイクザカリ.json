    "definitions": [
      {
        "index": 1,
        "gloss": "period of rapid growth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
