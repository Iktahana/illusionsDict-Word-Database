        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "畑を荒らす動物から守るため、周囲に電気柵を張り巡らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "警察は犯人を逃がさないよう、街中に厳重な警戒線を張り巡らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "インターネットは世界中に情報網を張り巡らし、瞬時に情報を共有できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "住む家は、いくらでも生えているびんろう樹などを切ってきて、その木を柱にし、葉をあんで柱の間にはりめぐらすと家ができる。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "権力の液汁を一滴でも多く同族のなかに吸収しようとして、特権階級の人々がその結婚や知人関係をとおして毛細管をはりめぐらす手腕は、日本でもフランスでも同じことなのであった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要に応じては鉄条網をはりめぐらすこともある。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほそびきを、縦横に、はりめぐらすんだ。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
