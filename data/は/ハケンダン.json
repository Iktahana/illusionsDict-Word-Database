        "examples": {
          "standard": [
            {
              "text": "この国際会議には、世界各国から外交官の派遣団が参加している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オリンピックに出場する選手たちは、国の代表として派遣団を組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "貿易交渉のため、政府の派遣団が相手国を訪問した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり、城には専属の消防隊があって、お祭りには派遣団を送ってきて、その人たちといろいろのことが話し合いされました。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋や鋳物屋が派遣団の使節として送られるのを見たことはない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
