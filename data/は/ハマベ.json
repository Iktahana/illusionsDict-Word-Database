        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "生徒が浜辺に大勢居る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒き浜辺にマルガレエテが歩み寄するヴェールを風に千々にされながら。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に朝日夕日は一万三千五百五回ずつ平和な浜辺の平均水準線に近い波打際を照らすのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜石の港へはいると、何とも知れない悪臭が港内の空気に滲み渡っていて、浜辺に近づくほどそれが猛烈になる。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＫ君の死体が浜辺に打ちあげられてあった、その前日は、まちがいもなく満月ではありませんか。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の浪が浜辺へ引き摺りあげました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "また沖へ引き去られ、また浜辺へ叩きつけられました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は浜辺へ出るのに、いつもこの店の前から土堤を下りて行くから熊さんとは毎日のように顔を合せる。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺に焚火をしているのが見える。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "惻然として浜辺へと堤を下りた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんよりと吉野紙に包まれたような空の光も、浜辺のような白い砂地のかがやきも、見るもののすべての上に灰色の悲しみが水の滲みるように拡がって行った。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺へ出て遠い沖の彼方に土堤のように連なる積雲を眺めながら、あの雲の下をどこまでも南へ南へ乗出して行くといつかはニューギニアか濠洲へ着くのかしらと思ってお伽噺的な空想に耽ったりしたものである。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方内海に面した浜辺に出て、静かな江の水に映じた夕陽の名残の消えるともなく消えてゆくのを眺めていると急に家が恋しくなって困ることがあった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の海水浴場のように浜辺の人目が多かったら、こんな間違いはめったに起らなかったであろうと思われる。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして暫くの間、浜辺に近い遠浅の春のようにあたたかい陽がのろりのろり淀んだ海面に練られている穏かな平凡の中に、万事を忘れるようにしました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺は煮えて賑かに、町は寂しい樹蔭の細道、たらたら坂を下りて来た、前途は石垣から折曲る、しばらくここに窪んだ処、ちょうどその寺の苔蒸した青黒い段の下、小溝があって、しぼまぬ月草、紺青の空が漏れ透くかと、露もはらはらとこぼれ咲いて、藪は自然の寺の垣。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　＊　　　　　＊　　　　　＊　　　　　＊　あと白浪の寄せては返す、渚長く、身はただ、黄なる雲を蹈むかと、裳も空に浜辺を引かれて、どれだけ来たか、海の音のただ轟々と聞ゆるあたり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十五　さて半時ばかりの後、散策子の姿は、一人、彼処から鳩の舞うのを見た、浜辺の藍色の西洋館の傍なる、砂山の上に顕れた。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と謂い棄てつ、おもむろに歩を移して浜辺に到れば、一碧千里｜烟帆山に映じて縹渺画のごとし。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく一二時間先に、文太郎君とその恋人とが江の島に着いているとすれば、まず人目の少い片瀬から七里ヶ浜の砂浜辺りで、肩すり寄せて語らい合っているかも知れないと思われたからです。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺にいる人からも必ず、松林の縁の街道を走る自動車の姿は一目で見える筈だし、そうすれば、幌なしの座席に相乗りしたアメリカの活動役者の恋人同士のように颯爽たる男女の様子は、この上なく羨ましい光景として見送られるに相違ないのです。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、起き抜けに、Ｂの細君はＡに案内を頼んで、浜辺へ散歩に出た。",
              "citation": {
                "source": "花嫁の訂正",
                "author": "――夫婦哲学――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、何時迄待っても、夕方になってやがて浜辺や松林の景色が物悲しく茜色に染まって、日が暮れかけても、幸子は帰らなかった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日、甲午、晴、亥剋、由比浜辺焼亡す、南風烈しきの間、若宮大路数町に及ぶ、其中間の人家皆以て災す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の所有する珠貨は、玳瑁が浜辺で一度に産みつける卵の数ほど多い。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の世のお礼やら、あの世のお頼みやら、仏様にお燈明なとあかあかあげて、親子夫婦が訣れのお念仏唱えさせて頂きましょう』源右衛門『よいところへ気が付いた』（二人で仏壇の扉を開け、礼拝の支度）　　　　　舞台半転（源右衛門宅の裏の浜辺。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その宿は庭からすぐ海に出られるので、客の眼をぬすんでは、砂の白いその浜辺に出て語りました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "童話の月大きな黄色の月、童話の中の月、おお、浜辺へ出て、手をあげて呼ぶのは誰だ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも強雨の霧しぶきの中の浜辺で、あちこちと奔走している黒い人影までが、つぎつぎと吹き飛ばされそうに撓んでいる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜辺は昆布が散らかってる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
