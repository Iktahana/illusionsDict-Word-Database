[
  {
    "uuid": "2c6685b4-901a-525a-b0c6-dab6b1c87261",
    "entry": "覇権",
    "reading": {
      "primary": "はけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
