    "definitions": [
      {
        "index": 1,
        "gloss": "hegemony",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "満州に覇権を打ち立てようとした企ては、日中戦争から太平洋戦争に続く、十五年戦争へと日本を導いていきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れてきた帝国主義国家、ドイツ、イタリア、日本は、ファシズムを国家の機軸に据えて、先を行く帝国主義諸国の覇権を脅かしながら勢力の拡大を試みた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らの挑戦を受けた側は、自らの覇権に対する脅威を、文明と自由と個人の尊厳の危機に重ね合わせてとらえた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "朕は即ち勇と力とだけが並外れて強かつたが為めに、覇権を握ることが出来たではないか。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからいくばくもなく紅葉が多年の牙城たる『読売』を棄てて『二六』に移った時は、一葉落ちて天下の秋を知るで、硯友社の覇権がそろそろ徐々傾き出した。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなれば、お互に実力を発揮して堂々と覇権を争うほかはありませんな。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジヨア階級が、その覇権へむかつて進出したときの進行曲として、政治的文学をもつたこと、そしてブルジヨア革命のまつ最中には、歴史的に見れば一時文学の衰頽期を現出したこと等が、それを語つてゐる。",
              "citation": {
                "source": "政治的価値と芸術的価値",
                "author": "マルクス主義文学理論の再吟味",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は信ず、本年の文壇に於て覇権を握るものは此二氏に在ることを。",
              "citation": {
                "source": "舞姫",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、文学における小説の覇権はいつまでつづくだろうか？",
              "citation": {
                "source": "文芸は進化するか、その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "として、Ｈ機関庫に前科者の覇権を握っていると言う、なかなかやかましい代物です。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝翫はその隆々たる人気を背負って、明治の世界に乗込んで、やはり一方の座頭株と認められていたのであるが、明治十年以後――いわゆる新富町の全盛期になると、東京劇壇の覇権はいつか団菊左の手に移って、かれは自然その次位に置かれることになってしまった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞伎劇は影薄く、新派劇ひとり驕って、わが劇界の覇権は前から後へ移り変わるかと見られた時に、あくる三十七年の二月には、かの日露戦争の幕が開かれた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……文壇の覇権手に唾して取るべしなぞと意気込んでね……いやはや、陋態を極めて居たんだ。",
              "citation": {
                "source": "予が半生の懺悔",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ巧みにつけ入って、ドイツ民族の優秀なことや、将来の世界覇権の夢想や、生産の復興を描き出したヒトラー運動は、地主や軍人の古手、急に零落した保守的な中流人の心をつかんで、しだいに勢力をえ、せっかくドイツ帝政の崩壊後にできたワイマール憲法を逆転させる力となったのである。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『くにのあゆみ』が、従来のように東洋における覇権の争奪者としての日本を描き出す態度をすてて、平静に、われらが生国日本における民族生活の推移と、諸外国との関係を扱っているのは当然である。",
              "citation": {
                "source": "『くにのあゆみ』について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方に米国で催された国際オリンピック競技では、さしもに列国が歯を立て得なかった水上の強豪、米国の覇権を、名もない日本の小｜河童連の手でタタキ落させ、何の苦もなく世界の水上王国の栄冠を奪い取らせるなぞ、胸の空くような痛快な波紋を高々と、近代史上に蹴上げている。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して覇権一度、相門を去るや、平氏が空前の成功は、平家幾十の※袴子をして、富の快楽に沈酔せしむると同時に、又藤原氏六百年の太平の齎せる、門閥の流弊をも、蹈襲せしめたり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして植物の栄養分に乏しい状態が再び訪れると、前の日のグイ松たちは、もうその覇権を名もなきみずごけどもにゆずって、この土地からその姿を消して行くのである。",
              "citation": {
                "source": "ツンドラへの旅",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後まもなく、アレマニ族の新らしいはなはだ恐るべき侵入が世界の覇権奪取の脅威を与え、アウレリアンは三度の大規模な血腥い戦闘を行った後、ようやくにしてこの破壊的集団を撃破し、イタリアをその蹂躪から救ったのである９）。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども新興の意気は実に凄じいもので、期年ならずして天下の覇権を握ると各自堅く信じて疑はなかつたのだ。",
              "citation": {
                "source": "野球界奇怪事　早慶紛爭囘顧録",
                "author": "吉岡信敬",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃に至つては向陵の健児は如何に頑張つても、最早覇権は其手から奪はれて仕舞つた。",
              "citation": {
                "source": "野球界奇怪事　早慶紛爭囘顧録",
                "author": "吉岡信敬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼等の覇権争奪の争闘を遠い将来へ、何マイルも何マイルも苦しい橇曳きの骨折りをとげた後へ、のばすことになつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "この組の先犬であり認められた首領としてのスピッツは、自分の覇権がこの奇妙な南国犬におびやかされていることを感じた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにバックはもののわかつた犬であつた、そして彼を危険なものにしたのは、赤いスウェーターの男の棍棒が、彼の覇権獲得の欲求から、盲目的な勇気と軽はずみをたたきおとした事実であつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　覇権を勝ち得たもの「え？",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイヴとソルレクスは覇権の移動に無関心だつた。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意地が通されないくらいなら美術家たるはおろか、何一ツしでかすものかと、今度はけんか腰になッて、人を後ろへ向かそうッて、たれが向くか、ざまを見ろと今から思えばおかしいがほんとにそう独語を言いながら画き続けた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雉、雉、雉ぐるま、雉はけんけん、鳩ぽつぽ、啼いてお山を今朝越えた。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした二つのものが相接触すればいつかはけんかになる事が当然すぎるほど当然な帰結である。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと今ごろはけんか腰になってみんなと談判でもしていらっしゃるでしょうよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
