        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北米の南方ではわがタイフーンの代わりにその親類のハリケーンを享有しているからますます心強いわけである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリケーンと言いたいくらいの凄い西風が、地響き立てて吹きまくる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると棘のような雹と雨が鋭く激しい音を上げ、ハリケーンが叫び暴風が轟々と恐怖のロールを鳴らし、天の果てから果てまで揺るがした。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今はハリケーンの季節だ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリケーンの季節にハリケーンが来ていなければ、一年で最高の時期なんだ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリケーンが来ている時は、何日も前から空にその兆候が見える。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、今はハリケーンは来ていない。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五四年にそのあたりを襲ったハリケーンによって、大きく損害をこうむったその灯台は、沿岸警備隊の判断で現役を退くことになった。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリケーンのシーズンを、あの島でやりすごせるはずがありません。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し大きなハリケーンが来れば、猛り狂う波の下に、あの島は一時的に沈んでしまうはずです。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アランの出発の日から起算して七か月後には、ハリケーンのシーズンでした。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「シカゴ」を見る、大仕掛の火事、スペクタクルとしては「ハリケーン」に劣るが、面白かった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
