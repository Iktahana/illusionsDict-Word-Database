        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何れも前髮を垂らした、日本なら潰し島田とか云ふ風な玄人特有の髮に結ひ上げて模樣のある黒繻子かなんかの上着に、半ズボンをはき、足には刺繍のある支那靴。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一その筒の傍に立って、花火の打上げを担当している二人の技手からが、洋服に、スエター、半ズボンというハイカラな服装である。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャンパーに、半ズボンという軽装です。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして狐が角パンを三つ持って半ズボンをはいてやって来ました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白や茶いろや、狐の子どもらがチョッキだけを着たり半ズボンだけはいたり、たくさんたくさんこっちを見てはやしているのです。",
              "citation": {
                "source": "茨海小学校",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛は薄いが、顔立ちはこぢんまりと綺麗にまとまつて、半ズボンの下にむきだしにしてゐる足は、女の子のやうに白かつた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉は私のはいている小さな半ズボンをたくし上げた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は真昼の太陽の射し込む窓の硝子戸に凭りかかって、半ズボンと靴下との間に生えている脛毛を、ながめてばかりいた。",
              "citation": {
                "source": "可哀相な姉",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の髪は美しい金色で半ズボンの下から見える脛がすなおに細かった。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この役を引受けたのが百瀬の新家の息子の啓司で、ネクタイ無しの半ズボンで下駄を穿き、二連銃を擬して森のような大木の梢に向って頻りに発砲しています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らくすると、半ズボンの写真館の男といっしょに、降りて来た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、〆団治はついぞ着ぬ洋服を着たのは良いとして、まだまだ寒さが去らぬのに、異様な半ズボンでぶるぶる震えていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷町で五十銭の半ズボン、松屋町の飴屋で飴五十銭。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと上ったところで、半ズボンの両脚を前へつるつるつるである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ついぞ着ぬ洋服を着たのは良いとして、〆団治はまだまだ冬だというのに、異様な半ズボンでぶるぶる震えていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人とも背は二フィートで、三角の上反り帽をかぶり、股のところまで下っている真紅のチョッキを着、鹿皮の半ズボンをはき、赤い毛の靴下と、大きな銀の締め金のついた重い靴とをはき、青貝の大きなボタンのついた長い上着を着ている。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装はぴったりと体にあった燕の尾のような裾のついた黒い上衣（その一つのポケットからとても長い白ハンケチがぶら下っていた）と、黒いカシミアの半ズボンと、黒い靴下と、黒繻子を蝶結びにした大きな房のついた切株のような舞踏靴とであった。",
              "citation": {
                "source": "鐘塔の悪魔",
                "author": "THE DIVIL IN THE BELFRY",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと上つたところで、半ズボンの両脚を前へつる／＼／＼である。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬二は寝衣をかなぐりすてると、金釦のついた半ズボンの服――それはこの東京ビルの給仕としての制服だった――を素早く着こんだ。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いズボンを穿いてゐるのが苦しくてならない、つひに今日よりゴルフパンツを引張り出して半ズボンの姿になる。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しくて敵はんと朝から云つてゐたが、やがて晝飯の時にサロンへ出て來た彼の姿は俄然半ズボンになつてをつた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその半ズボンの形が少しをかしい。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「到頭半ズボンをどこかで手に入れて來たね」と云へば、彼は天井を向いて「わはつはつ」と笑ふ。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の好みによって造った軽い帽子を冠り、半ズボンを穿き、長い毛糸の靴下を見せ、輝いた顔付の青年等と連立って多勢娘達の集る文学会に招かれて行き、プログラムを開ける音がそこにもここにも耳に快く聞えるところに腰掛けて、若い女学生達の口唇から英語の暗誦や唱歌を聞いた時には、殆んど何もかも忘れていた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃いの半ズボンで写真まで取ったこともある。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がエリザ式の半ズボンに絹の靴下を膝頭で結んだ右足を左りの上へ乗せて鵞ペンの先を紙の上へ突いたまま首を少し傾けて考えているところを想像して見た。",
              "citation": {
                "source": "倫敦塔",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜日ごとにゴルフとまでは行かないプチブルらしくベビー・ゴルフというものへ、半ズボンはいて行くＯ氏のお伴をしなければ、不和を生じるという場合、どうしてＫ子はＯ氏との恋愛をよろこび、共に発育して行く人間らしい楽しみを感じることが出来ましょう。",
              "citation": {
                "source": "ゴルフ・パンツははいていまい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は半ズボンと共に郊外の散歩。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い上衣に短い半ズボンを穿いて脛をあらわした仏蘭西風の子供の風俗は、国の方で見るものとは似てもつかないようなものばかりだ。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
