    "definitions": [
      {
        "index": 1,
        "gloss": "fighting with one's back to the wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
