          "literary": [
            {
              "text": "」「また御早うに……。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い胸あてをした人がジョバンニのうしろを通りながら、「よう、虫めがね君、お早う。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋のアザミの造花のおかれた卓子に、ミサコと対して女記者は巨木のような脚をくむと、すぱりすぱりと朝日の紙巻タバコの煙を吐きだしながら、「お早うございます。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あら、お早う、いつおかえり？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、「六さん、お早う」と声をかけましたが、子供は私の顔を見てニヤリ笑ったまま、草ぼうきで落ち葉を掃き、言葉を出しませんでした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大層お早うごぜえましたね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早うございます」「やあ、お早う」と、裏庭の縁側で朝顔の鉢をながめていた半七は見かえった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっこいしょ、どっこいしょ」　お早うを言いにあがって来た信子は「まあ、温かね」と言いながら、蒲団を手｜摺りにかけた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早う仕度しやんし」と言って煙管の詰まったのを気にしていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」信子が訊くと、「行くのやと言うて、今夜は早うからおやすみや」と母が言った。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄念は起さずに早うここを退かっしゃい、助けられたが不思議なくらい、嬢様別してのお情じゃわ、生命冥加な、お若いの、きっと修行をさっしゃりませ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い胸あてをした人がジョバンニのうしろを通りながら、「よう、虫めがね君、お早う」と言いますと、近くの四、五人の人たちが声もたてずこっちも向かずに冷たくわらいました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると虔十の兄さんが、「平二さん、お早うがす。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お早うございます。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「樺の木さん、お早う、そちらに居られるのは土神ですね。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清夫は笑って、「いや、つぐみ、お早う。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清夫は笑って、「いや、ふくろふ、お早う。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　清夫は笑って、「いや、よしきり、お早う。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前もものの命をとったことは、五百や千では利くまいに、早うざんげさっしゃれ。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お早う、于※大寺の壁画の中の子供さんたち。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと一郎が「先生お早うございます。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いましたのでみんなもついて、「先生お早うございます。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一郎が思わず下にいる嘉助へ叫ぼうとしていますと、早くも三郎はどてをぐるっとまわって、どんどん正門をはいって来ると、「お早う。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは返事をしないのではなくて、みんなは先生にはいつでも「お早うございます。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というように習っていたのですが、お互いに「お早う。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」なんて言ったことがなかったのに三郎にそう言われても、一郎や嘉助はあんまりにわかで、また勢いがいいのでとうとう臆してしまって一郎も嘉助も口の中でお早うというかわりに、もにゃもにゃっと言ってしまったのでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の進むにつれて最早気味悪き音はやんで動揺はようやく始まりて早や胸悪きをじっと腹をしめて専ら小説に気を取られるように勉むればよう／＼に胸静まり、さきの葡萄酒の酔心。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンカツに巡り会わない日本人はようやくその代用品を見つけて、衣を着た肉の揚物に対する執着を充たすだけで我慢しなければならぬ。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日足の短さ、日はようやく傾きそめる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん、まアどうしたんでしょう」　僕の詞に励まされて母はようやく涙を拭き、「政夫、堪忍してくれ……民子は死んでしまった……私が殺した様なものだ……」「そりゃいつです。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
