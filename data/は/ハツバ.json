    "definitions": [
      {
        "index": 1,
        "gloss": "start (of a horse race)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
