          "literary": [
            {
              "text": "殊に原本は十五、六行の蠅頭細字で認めた一年一冊およそ百余｜張の半紙本である。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻は百｜零三｜頁の半紙本で、頁数は森｜枳園の朱書する所である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十七｜頁の半紙本で、首に「森氏」、「伊沢家書」の二印がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
