    "definitions": [
      {
        "index": 1,
        "gloss": "Mother's Day (2nd Sunday of May)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何故母の日記に、自分が左様な醜い好奇と、自分にとつては小説的どころではないが或る意味で小説的な誘惑を強ひられるか？",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よう丈夫で歸つたのう」といふと、母の日に燒けた頬にはみるみる大粒の涙がつたはつた。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はなつかしい祖母の日。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡母第四十九回忌、御幸山大権現祭日、地久節、母の日週間。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "憲法記念祭、子供の日、母の日。",
              "citation": {
                "source": "鬼畜の言葉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその腰かけの背に両手をかけて漸との事で上半身を支えていたが、その両手に急に力がなくなって……　　　菜穂子の追記　此処で、母の日記は中絶している。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　その次ぎに又Ｏ村の家に残して置いたものの整理に一人で来たとき、私ははじめてその母の日記を読んだ。",
              "citation": {
                "source": "楡の家",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は五月の第二日曜で、『母の日』だと云ふので、うちではみんなあんなにして、今日の土曜を『母の日』に繰上げて、わたしをいたはつてくれる。",
              "citation": {
                "source": "母の日",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日は、五月の第二土曜日で、ほんたうは明日の第二日曜が『母の日』です。",
              "citation": {
                "source": "母の日",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の日といふのは、僕たち子供が、赤ん坊の時から面倒を見て育てていただいたお母様に、いや世界中のお母様方に、心からお礼を云つてお祝ひをしてあげる、一年に一日しかない目出度い日です。",
              "citation": {
                "source": "母の日",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその腰かけの背に両手をかけて漸っとの事で上半身を支えていたが、その両手に急に力がなくなって……菜穂子の追記　此処で、母の日記は中絶している。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその話を聞いてほほえんだのでしたが、近頃｜成尋阿闍梨の母の日記のことを佐佐木信綱大人の書かれたのに、その母性愛のことの記されてあるのを読んで動かされました。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ふ母の日に、涙が浮んでゐましたので、私はとう／＼、ほんとに泣いてしまひました。",
              "citation": {
                "source": "時男さんのこと",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の孫を手一つで育てゝゐる祖母の日頃の苦勞を思ふと、雪子は何といふ不心得な不孝な女だらうと、一圖に憎々しくなつた。",
              "citation": {
                "source": "孫だち",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛一郎は、最近、母の日記を読み、死んだ妻にたいする父の美しい追憶を守るために、母が思いを残した手紙の束を、とりかえそうと決心したものらしい。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界に例のない“母の日記”といえようか。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏隣り　“母の日”だといふ。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい母の日とは、何をする日か、意味するのか、考へると、分らない。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の日は、理窟ではありません、社會教化日であります、かういふ設定日でもおかなければ、女性は母の使命を忘れ、子は母親を生理的分身とみるだけで、相互、母性愛の本來を、また感謝を、忘れさうです。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑの母の日であります。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の日はなく、母の日だけといふのも、へんなもので、なぜいツそ“親の日”とでもいはないのか。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄のキリレンコが日本語が巧いのは当然として、カタリナも日本へ来てから短時日のわりには相当にこなすが、一番分りにくくて滑稽なのは老母の日本語で、これには妙子も少からず悩まされること。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の日ごろの信心がの。",
              "citation": {
                "source": "私本太平記",
                "author": "千早帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
