[
  {
    "uuid": "2f8384bd-d0f8-5cef-9860-4a4c8a7bb1d9",
    "entry": "蔓延る",
    "reading": {
      "primary": "はびこる",
      "alternatives": [],
      "is_heteronym": false
    },
