    "definitions": [
      {
        "index": 1,
        "gloss": "to begin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "尚黙りつゞけるとしても、Ａは兎も角女給なり、従つて酒場の空気なりと交流が始まる。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といふ声がして、女の啜り泣が始まる）（男、ドアの所まで行つて隣室の中をみる）男　もう仕度は出来てゐたのか。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さうした小言の言ひ合ひがまた始まるのであつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジイドの活動の始まるのは、その下り坂がもう殆んど下り切つたといふ時であつた。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冬近し」という切迫した語調に始まるこの句の影には、芭蕉に対する無限の思慕と哀悼の情が含まれており、同時にまた芭蕉庵の物寂びた風情が、よく景象的に描き尽されている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村はこの外にも、君あしたに去りぬ夕べの心｜千々に何ぞはるかなる君を思ふて岡の辺に行つ遊ぶ岡の辺なんぞかく悲しき　という句で始まる十数行の長詩を作ってる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした輪廻の道程がもう一歩進んで堕落と廃頽の極に達し俳句が再び「宗匠」と「床屋」の占有物となる時代が来ると、そこではじめて次の輪廻の第一歩が始まるのではないかという気もする。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同座敷の片側へ一列にならんで順々拝が始まる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スチクレスタードの野の戦の始まる前に、王は部下の将卒の団欒の中で、フィン・アルネソンのひざを枕にしてうたた寝をする。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しい天気であったのが、戦が始まると空と太陽が赤くなって、戦の終わるころには夜のように暗くなったと伝えられている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "森林帯の尽きるところから、大雪渓が始まるが、この雪渓の長々しい傾斜は、さすがに白馬岳あたりの比ではない。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもしその唄が時の巴里の物足りなく思っている感情の欠陥へこつりと嵌まり込めばたちまち巴里じゅうの口から口へ移されて三日目の晩にはもうアンピールあたりの一流の俗謡の唄い手がいろいろな替唄までこしらえて唄い流行らしてくれるし譜本は飛ぶように売れ始まる。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「趣味」はまず体験として「味わう」ことに始まる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者の仕事は、それに終るのではなくて、実はそれから始まるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の成立するのは、云わば個々の能知者が所知者の中に入り込む時に始まる。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時にいたずら好きの天分をも発揮して、ガス管内に空気を押し込み、先生の祈祷が始まると燈火が自然に消えるという趣向を案出し実行した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日が来るとこれらの機械的鳥獣の自由な活動が始まるであろう。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争のないうちは吾々は文明人であるが、戦争が始まるとたちまちにして吾々は野蛮人になり、獣になり鳥になり魚になり、また昆虫になるのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になると上野に絵の展覧会が始まる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大戦」と、ルパートのいわゆる「戦いはこれから始まるのだ」のその「戦い」との間に、この楽しい球技の戦いが挿入されている。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはただ今日から二人の生涯が始まると予期していたばかりです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その始まる生涯と仰ゃるのは。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の精神のあらゆる飛躍は私の血のなかに始まるのです。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこからルーマニアの士官と、スペイン女のあの意気で猥雑なタンゴが始まると、人々は腰を高く振って、歓声をあげるのでした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "出兵が始まると同時に、アメリカは、汽船に二杯、偽札を浦潮へ積みこんできた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにトーキーが始まるというので後学のために出かける。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この流れが始まると、陸地の表面では上層の空気が他処へ流出するために圧が海上の同じ高さの点より低くなる。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新星の今後の変化を研究すべき天文学者の仕事はこれから始まるので、学者達は毎晩曇った空を眺めては晴間を待ち明かしている事であろう。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんから、そろそろこの小雀の身の上に悲劇がはじまる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、その翌日から、お爺さんの大竹藪探索がはじまるわけである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
