[
  {
    "uuid": "896238ed-5346-5754-b502-70ec97f62d91",
    "entry": "藩札",
    "reading": {
      "primary": "はんさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
