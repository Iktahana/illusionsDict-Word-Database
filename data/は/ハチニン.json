        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隣りはタカヂアスターゼの兄さんか弟の家で、子供が八人くらゐゐて、ひどく賑かだつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "同行八人の寝室も、食堂も、ここで兼ねるのである。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍聴席には、その両親の子供たちが、ハッキリ数へることは出来なかつたが、七八人、或は十人もゐたかもしれなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ぬ恋に憧れたあちこちの若い河神たちが、八人と集って来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "消ゆるかに見えて、また立つ漣……」　岳麓にできた八つの湖、その一つ一つを見まもる八人の河神の若い瞳。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔二、〕活版所ジョバンニが学校の門を出るとき、同じ組の七八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその十字になった町かどや店の前に女たちが〔〕七八人ぐらゐづつ集って橋の方を見ながら何かひそひそ談してゐるのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの七、八人ひとりも起きてるものは無かった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "加入者の数は全人口に割り当てると二十八人に一人となる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗客の数は一等五百六十三人、二等四百六十一人、三等千百三十八人、試運転の平均速度二十六浬三である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この正月の休暇に八人会で旅をしますが、旅の間に一本書こうかとの話があります。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "八人の酔ッ払いがどんな与太を飛ばすだろうかと思うと今から旅が楽しみです。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あるとも、代貸元をつとめる人が二十八人、是を唱えて清水の二十八人衆。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の二十八人の中に次郎長程もえれえのが五六人居るからね」　「お前さん仲々詳しいね。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝代官屋敷の夜――　竹垣三郎兵衛の屋敷に乱入した次郎長を始め清水一家の猛者八人。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帰り途に下谷の御成道へさしかかると、刀屋の横町に七、八人の男が仔細らしく立っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかにも七、八人の男がその中間を取りまいて、何か大きい声で罵っているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、二人の巡警は、棺車を守る七八人の屈強な男の敵じゃなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年間、一日もここから出ない者十八人。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山なしが、山へ来とるげ……」　部落の子供達が四五人、或は七八人も、手籠を一つずつさげて、山へそう云うものを取りに行っている時、トシエは、見さげるような顔をして、彼女の家の山へは這入らせまいとした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう話が、たった八人の彼等を、おびやかすのだった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、軍曹から初年兵の後藤にいたるまで、自分たちはたゞ、自分たち八人だけだという感じを深くした。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は、ビンから喇叭のみにして、八人の口から口にまわった。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品とおきみとは、七八人の子供達と縄飛びをしていた。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く人が二十八人にならなければやめるそうだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十八人に四人足りなかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、活版所　ジョバンニが学校の門を出るとき、同じ組の七八人は家へ帰らずカムパネルラをまん中にして校庭の隅の桜の木のところに集まっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその十字になった町かどや店の前に女たちが七八人ぐらいずつ集って橋の方を見ながら何かひそひそ談しているのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然も猶これは真直に真四角に切たもので、およそ恁る角の材木を得ようというには、杣が八人五日あまりも懸らねばならぬと聞く。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
