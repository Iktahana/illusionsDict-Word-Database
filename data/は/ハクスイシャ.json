    "definitions": [
      {
        "index": 1,
        "gloss": "Hakusuisha (publisher)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
