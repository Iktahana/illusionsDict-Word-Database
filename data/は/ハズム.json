    "definitions": [
      {
        "index": 1,
        "gloss": "to spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "旅慣れない私はこころの弾む思いがあった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の着代えをしようとしてがんじょう一方な木製の寝台の側に立っていると、戸外でカロラインと気軽く話し合うファニーの弾むような声が聞こえた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいくらか胸が弾むようなのを紛らすために、庭の天井を見上げた。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「川を溯るときは、人間をだんだん孤独にして行きますが、川を下って行くと、人間は連を欲し、複数を欲して来るものです」　若い学者は内心の弾む心をこういう言葉で娘に話した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなればそれに張り合う生の弦とて弾む道理はありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "調子の弾む程余計にアイリスは我慢がならなかった。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、京吉が土曜日すら清潔だと勘でかぎつけていたように、春隆――この乗竹侯爵の次男坊も、背中へ廻した手の感触で、この女はまだ一度も体を濡らしたことはないと、改めて直感すると、「今夜こそこの女をどこかへ連れて行って……」　という想いに心も弾むのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうにか澄んでゆくやうでも、事に触れては弾む。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻君は桃いろのスカートで、歩くときには、その健康そうな円いお腰がくるりくるりと弾む。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "応接室へ、煽風器をかけて、冷たいものを差し上げて……」自ら弾む口調で、命じると、浴衣ではわるいと思い、さっき脱いだ黒い上布に着かえ、応接室へ急いだ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　まんまと馬車のうちにとっつかまえて、そのとき私の胸は喜びに弾むあまり動脈瘤がひどいことにならないかとひやひやものでした。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "出したばかりの本への好意的な書評を読んで、一瞬わき上がってきた弾むような気持ちが、取り逃がした風船のようにすぐに消えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が絶えず、わく／＼して、息は抑えても／＼弾むのであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡花の「高野聖」の頓智や芥川の「河童」の機智を愛し、里見※の弾むような文体に惹かれ、十和田操を期待していた。",
              "citation": {
                "source": "忘れがたみ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後戦地へ赴いた彼に妻が思い出を書いてやると、「帰って来たら又幾羽でも鵯鳥を獲って差上げます」と何かまだ弾む気持をつたえるような返事であった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸が絶えず、わく／＼して、息は抑へても／＼弾むのであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "バクー名所の一つである九世紀頃のアラビア人の防壁を見物して、磨滅した荒い石段々を弾む足どりでイラ草の茎を片手にもって降りて来たら、わきの共同便所の前から十一二歳の少年の一団がやって来る。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "体育室からは、フットボールの弾む音がする。",
              "citation": {
                "source": "ソヴェト同盟の三月八日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあの椅子が少し弾むようになったときにあのくいついたところがはなれる。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "消極の極で暮して来た、否暮させられて来た、日本婦人に対して、生きて弾む生命を持って居るこちらの婦人の価値は、種々な形成に於て或時は余りに過重され、又或時には余りに価値以下に観られて居ると思います。",
              "citation": {
                "source": "Ｃ先生への手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼もまた弾む心で殆ど妻の透視しているものを信じてもいいとおもえたのだが……。",
              "citation": {
                "source": "苦しく美しき夏",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朝、態度がけしからんと云って、一青年の頬桁を張り飛ばした教官は、何かまだ弾む気持を持てあましているようであった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その朝、態度がけしからんと云つて、一青年の頬桁を張り飛ばした教官は、何かまだ弾む気持を持てあましてゐるやうであつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな籠を頭に載せた娘達は田畦の方へやって来ると、手を振り振り弾むような声で叫ぶ。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やったで」　一九八二（昭和五十七）年四月、深夜の電話を伊勢崎の自宅で受けた松本吉彦は、時差など頭の隅にも置いていない西和彦の、弾むような声に耳をはじかれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おたくは何か、別の仕事をやってらっしゃいませんか」　何の気なしにそう水を向けてみると、耳元の受話器で「日本語もやっているんです」と弾むような高い声が砕け散って輝いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーという会社にみなぎっていた弾むような柔軟性や、プロジェクトのパートナーとなった笹渕のＧＵＩに対する確信、そしてリサを貫く精神の斬新さに打たれた間宮は、開発作業をになうことになったジャストシステムの三人の熱意に触れて、再びあおられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "球はとんと弾むが早いか、一筋の赤を引きずりながら、ころころ廊下へ出ようとする、――と思うと誰か一人、ちょうどそこへ来かかったのが、静かにそれを拾い上げた。",
              "citation": {
                "source": "母",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "リズムに乗った弾むような快感が一層強まるのを矢代は覚えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間話がはずむ……夜半になると、焚火は、とろとろと消えかかる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
