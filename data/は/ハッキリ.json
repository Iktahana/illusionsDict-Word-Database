    "definitions": [
      {
        "index": 1,
        "gloss": "clearly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこの態度を、はっきりきめていただきたい。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の世界観をはっきり持っていなくても、それでも生きて居れる人は、論外である。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり向き直って、おのれのヴァニティと対談してみるがいい。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、いちどは、はっきり、合せ鏡して見とどけて置く必要は、ある。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり言ったっていいんじゃないかしら。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腎臓結核という、わるい病気でございまして、気のついたときには、両方の腎臓が、もう虫食われてしまっていたのだそうで、医者も、百日以内、とはっきり父に言いました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は、はっと、むねを突かれ、顔の血の気が無くなったのを自分ではっきり意識いたしました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、はっきり間違って居りました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、病気になってから、それが、はっきりわかって来たの。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい音楽学校にはいっているのかどうか、それさえはっきりしていないのです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは僕がはっきり予言して置いていい。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "額はあくまでもせまく皺が横に二筋はっきりきざまれていて、もう、なっちゃいない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々の事を、はっきりと教えてくれるので、私も私の疑念を放棄せざるを得なかった。",
              "citation": {
                "source": "六月十九日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきり覚えていません。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の火焔が、金木から、はっきり見えました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた左の如き恋愛句において、こうした蕪村の青春的センチメントが、一層はっきりと特異に感じられるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなども具体的内容は覚えていないが、この記事で窺われた当時の根岸子規庵の気分と云ったようなものだけははっきり思い出すことが出来る。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事なしかもかなり六かしい事柄の核心を平明にはっきり呑込ませる術を心得ているようであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局先生自身がその学問の奥底まではっきり突きとめて自分のものにしてしまっているせいだろうと思われた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいではっきりそれを覚えているのかもしれない。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき先生自身がひどく吃驚した顔を今でもはっきり想い出すことが出来る。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ恥ずかしかった事だけはっきり想い出すのである。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の事は覚えていないがただ一事はっきり覚えているのは、この子が自分にときどき梟をやろうとか時鳥をやろうとかまた鷹をやろうとかいう申し出しをしたことである。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中折帽に着流しでゴム靴をはいて、そしてひどく考え込んだような風でゆっくり歩いて来る姿をはっきり覚えているように思うのであるが、しかし、これはよくある覚えちがいであるかもしれない。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしただ一度ある小春日のわが家の門前で起った些細な出来事だけがはっきり印象に残っている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体にその頃の消印ははっきりしていたが、近頃のは捺し方がぞんざいで不明なのが多いような気がする。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の五歳の頃から五年ほどの間熊本｜鎮台に赴任したきり一度も帰らなかった父の留守の淋しさ、おそらくその当時は自覚しなかった淋しさが、不思議にもこの燈下の寒竹の記憶と共に、はっきりした意識となって甦って来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻からはっきりと、物体のつかめる現実の世界となった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死んだのかい」「死んだらしい」「どうしたんだい」「やけに呷ったらしいんだ」「フーム」「………………」「で、水葬はいつかい」「一運に一度訊いて見よう」「酒が、わるかったんだね」「ウム、どうもはっきり分らねえ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし作者によってその顔が非常にはっきり出て来るのと、そうでないのとがある。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
