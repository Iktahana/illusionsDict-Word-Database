    "definitions": [
      {
        "index": 1,
        "gloss": "to brush off",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "敵の片腕　島原城之介力をこめ、ピューッと鉄杖を横へ振ったが、払い落とすことはできなかった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく振って埃りをすっかり払い落とすと、それを肩にひっかけて、彼は階段を降りて表へ出た。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はぷんぷん腹を立てながらも、さすがに寂しさを払い落とすことができなかった。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの勇気ある行為によって不健全なイメージを払い落とすための一歩としたのではなかろうか。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "石屑の乱れがある一つの払い落とすことのできぬ印象を我々に与え、ガソリンの臭いがどんどんきつくなってきた。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし音楽は魔法の小枝をもっていて、いかなる錠前をも払い落とす。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星基地はここからすぐのところにあります」　あなたはおもむろに立ち上がり、服についた土を払い落とす。",
              "citation": {
                "source": "人生は擬似体験ゲーム",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥への手紙にも書いている――「今の時代にとって必要なのは、けちな狡い卑怯な乞食根性を人間の魂から払い落とすような剛毅な精神の人々である」と。",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭きを出して、裾を、特に脚絆の黄色い埃をはらいおとすのであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな足のほうからはいのぼってくるカニを、はらいおとすのに、大さわぎをしました。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいてが、潜航艇にしがみついてしまっては、手も足もない機械ですから、はらいおとすことも、どうすることもできません。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
