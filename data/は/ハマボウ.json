        "examples": {
          "standard": [
            {
              "text": "夏の海岸の風景に、浜朴の鮮やかな黄色い花が彩りを添えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "浜朴は、塩分に強く、海岸線に群生する落葉低木だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「あんなに鮮やかな黄色い花、ハマボウっていうんだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ハマボウフウの生えている砂地や、ツクシ、タンポポの丘の辺から、陽炎の立つ柔らかな日の光の下で種々の香りが蒸し出される。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間に微風に乗じて、わずかに香気を送ってくるものが蔓荊で、土地ではこれをハマボウと呼んでいた。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "※瑰の紅　南部日本のハマボウに対立して、北に進めば則ちハマナスの花がある。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
