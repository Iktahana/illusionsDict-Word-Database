    "definitions": [
      {
        "index": 1,
        "gloss": "bai ze (mythical Chinese animal able to understand human speech, having the body of a lion and eight eyes)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小十郎は夏なら菩提樹の皮でこさえたけらを着てはむばきをはき生蕃の使うような山刀とポルトガル伝来というような大きな重い鉄砲をもってたくましい黄いろな犬をつれてなめとこ山からしどけ沢から三つ又からサッカイの山からマミ穴森から白沢からまるで縦横にあるいた。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年の春はやく山の木がまだ一本も青くならないころ小十郎は犬を連れて白沢をずうっとのぼった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎はまっ白な堅雪の上を白沢の方へのぼって行った。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎は白沢の岸を溯って行った。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白沢から峯を一つ越えたとこに一疋の大きなやつが棲んでいたのを夏のうちにたずねておいたのだ。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝永六年板『子孫大黒柱』四に『博物志』に『白沢図』という書を引いて黄金の精を石糖といえり、その状豚のごとし、これは人家にあって白鼠を妻とす云々。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しかすると、菊池君は何時か私の生れた村の、アノ白沢屋とか云ふ木賃宿の縁側に、胡坐をかいて居た事がなかつたらうかと考へたが、これも甚だ不正確なので、ハテ、何処だつたかと、気が少し苛々して来て、東京ぢやなかつたらうかと、無理な方へ飛ぶ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで文化二年以来津軽家の漸く栄え行くのに平ならず、寧親の入国の時、途に要撃しようとして、出羽国秋田領｜白沢宿まで出向いた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "関良輔は、人々が、十分に集ったのを見ると「白沢の関より届にも及ばずして、参覲交代の道を変更したる段につき、上より咎めあるべきはずを、沙汰の無き、これ一つ。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "白沢の駅で大銃を放とうと企てたのが、真正の大作か、渡し舟のが、当の本人か、どうも、出没自由にて、稀代の曲者と心得ます。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやや大規模な崩壊利用といたしましては上伊那郡西春近村の白沢部落かと記憶しておりますが、あそこでは、その地方一帯は赤土の段丘地でありますが、その上に一個所だけ、あそこの裏山の崩壊で押出された広い石礫地区ができております。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州側には大刀寧岳と剣ヶ倉、白沢山。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴峠を上って白沢に下りる道の傍に新しい小学校があって、庭の八重桜は未だ花をつけていた。",
              "citation": {
                "source": "秩父のおもいで",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白沢のとある人家の高い杉の木を縫うて、白い藤の花が梢近くまで咲き続いていた美しさには、思わず足を止めて見恍れた。",
              "citation": {
                "source": "秩父のおもいで",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平ヶ岳に登るには初冬の頃がよいと思う、白沢の水量も減じていようし、熊笹や雑木の勢いが夏期のように旺盛ではないし、人夫も比較的に閑暇であるから便利だというのである、余分の日子と防寒具の用意をして初冬に登るべきである。",
              "citation": {
                "source": "平ヶ岳登攀記",
                "author": "高頭仁兵衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫からは上越の国境山脈を辿り、露営四泊にして二十七日午後三時大白沢山の一角に達し、猫又川を下りて貉沢から至仏山に上り、ヘエヅル沢を下って二十九日に柳淀に帰着したのである。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂駒ヶ岳は『上野国志』に拠れば、「駒子山の東越後界にあり、越後にては白沢岳と云」とあって、陸地測量部発行五万分一図（藤原図幅）の白沢山或は大白沢山に相当しているようであるが、戸倉村の書上では景鶴山の一名を駒ヶ岳というのである。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の東方の白沢岳とあるものは平ヶ岳に、其北微西に在る大平山というのは兎岳に、共に相当しているらしい。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は高頭君の登られた白沢口よりも困難が多いかと思われる。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白沢山　平ヶ岳から南に延びた尾根上の一隆起であるが、取り立てて言う可き程の峰ではない。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白沢山の登りに懸るあたりからそろそろ陣竹や矮少な木本の藪が始まるけれども、僅ばかりの登りであるから直に三角点に達する。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白沢山から二時間余を費して大白沢山との鞍部に近き峰の突端に達した。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大白沢山の北に在る草原も池も目の下に瞰られた。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予定ではこれから大白沢山を経て景鶴山に登り、然る後尾瀬ヶ原に下る計画であったが、山頂まで白檜の森林に掩れた藪の深い様子を眺めては、到底縦走を続ける勇気もなく、近い大白沢山もススケ峰も一瞥を与えたのみで、鞍部から猫又川へ下ってしまった。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地図を見ると大白沢山の三角点の東南方に長い懸崖の符号が記入してある。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫の話では、此懸崖の下の小沢に沿うて大白沢山へ登れるそうである。",
              "citation": {
                "source": "利根川水源地の山々",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、やっと足をはずしたが、法師はくたくたとなったので、水を吹っかけなどして、やっと蘇生させた。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて女中はくたくたにもみ通されて一口も言葉を出さなくなつた。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事の後片づけを済ますと、妹はくたくたに疲れて二階へ昇って来る。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事の後片づけを済ますと、妹はくたくたに疲れて二階へ昇つて来る。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
