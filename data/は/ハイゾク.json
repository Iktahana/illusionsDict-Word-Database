    "definitions": [
      {
        "index": 1,
        "gloss": "assignment (of a person to somewhere)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分は、あの雷の如き蛮声を張り上げる配属将校をさえ、実に容易に噴き出させる事が出来たのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十一年兵として近衛歩兵第一聯隊に配属された私は、極度の過労と、慣れない空気のために見る見る弱り果てて、とうとう第一期の検閲直前に肺炎で入院した。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一ベンガル先発隊に配属したることあり。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「きさまは南町ご番所配属の自身番という自身番を残らず改めろ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　前にもいう通り、従軍新聞記者に対する待遇や規定がハッキリしていないので、その配属部隊の待遇がまちまちで、非常に優遇するのもあれば、邪魔物扱いにするのもある。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京日日新聞社からは黒田甲子郎君がすでに従軍願いを出して、第一軍配属と決定しているので、わたしは東京通信社の名をもって許可を受けました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "配属部隊の方でも怪しみませんでした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとには留守部隊がのこっていたが、これには臨時に、三｜箇中隊の高射砲隊が配属されていた。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "配属将校は軍事学を講義すべきものではなく、また多くの人はそんな力は持っていない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "入社後、後藤は半導体の生産設備を整備する部隊に配属されるのだが、ここで担当したのが、渡辺と組んで進めることになったＩＣテスターの開発業務だったのである。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "新人類の加入　一九七七（昭和五十二）年四月、後藤富雄がアメリカに出発する直前に入社し、マイコン販売部に配属された新人は、ある種の新人類だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その永尾が渡辺の率いるマイコン販売部、実体を正確に表現すれば、パーソナルコンピュータ開発部兼マイコン販売部に配属されたのが一九七九（昭和五十四）年二月一日。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシは建設部に、ヨーコは肉処理部に配属された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで配属先の第一志望には、「通信」と書いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが具体的な配属先を示されたとたん、後藤は気持ちが落ち込んでいくのを抑えられなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業部内での配属を最終的に決める面接で「回路図が読めるか」と聞かれ、物理や化学出身の新卒者の大半が「読めない」と答える中で、「なんとか読めます」と答えてしまったことを、後藤はそのとき、後悔した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "配属されたセクションでやっていた、アナログ方式のコンピューターで潜水艦の航跡をシミュレートする仕事は、いかにも斬新で面白そうに見えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "教授の世話で日本電気への入社が決まり、配属を決めるための面接では「デジタルコンピューターが伸びそうなので、ぜひやらせてほしい」と答えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "配属先は希望どおり、コンピューターの専門セクションとして二年前に作られたばかりの電子機器工業部となった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "配属された部署に置いてあった電動計算機を使っても、精度の高いフィルターの設計には数か月を要した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時期、浜田は設立間もない専門セクションの電子機器工業部に配属された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "配属を決める際の面接には、玉川事業部の事業部長を務めていた小林宏治があたった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが正式の配属先を決めるに先だって、半年ほどもかけて新人に各部署を体験させる研修期間中に伝送工場を覗いてみると、ここで扱っている技術にも興味が湧いてきた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最終的に配属先が決まる直前、小林宏治にもう一度「伝送でどうだ」と聞かれた際には、「お任せします」と答えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "配属された伝送技術課では、のちに会長となる大内淳義が、音声をパルスに載せて送る技術に取り組んでいた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝送技術部に新設された電子計算機係に配属となり、ＳＥＮＡＣのプロジェクトに加わった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めての配属先は、中央研究所の電子計算機研究室だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小林のもとに、超小型分野の新機種開発担当技術課長として浜田俊三が配属された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は修士出の多くが研究所にまわされていたが、「物作りがやりたいので研究所には行きたくない」と配属前の面接で訴え、オンラインで中央のコンピューターと結んで使う銀行の端末装置作りの仕事についた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸坂の配属されたデータ通信の端末装置担当セクションで、先輩の浜田は当時新しいタイプの技術に取り組み、その可能性に確信を持つにいたっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
