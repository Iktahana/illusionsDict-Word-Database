[
  {
    "uuid": "c8100fdd-75d3-5981-bdd3-411d1cd9ccb5",
    "entry": "俳画",
    "reading": {
      "primary": "はいが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "briefly drawn picture",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "午過ぎから帰るつもりでいたが案外気分がいいし天気もいいから白木屋の俳画展覧会を見に行ったらもうすんでいた。",
              "citation": {
                "source": "病中記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳画の庭、幽かな庭。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼をして力を俳画に伸ばさしめば日本画の上に一生面を開き得たるべく、応挙輩をして名をほしいままにせしめざりしものを、彼はそれをも得なさざりき。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（筆力等の技術はその書及び俳画を見て想像するに足る）蕪村は南宗より入りて南宗を脱せんと工夫せしがごとし。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の画を称する者多く俳画をいう。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳画は蕪村の書きはじめしものにして一種摸すべからざるの雅致を存す。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども俳画は字のごときもののみ、ついに画にあらず、画を知らざるものこれをもって画となす、取らざるなり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横自在にして法度にかかわらず、しかも俗気なきこと俳画に同じ。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "へと／＼に酔つた画家が、肩肱を張つて、俳画めいたものをかいたあとで、氷川も小さいものを二つ三つ書かされた。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはゆる俳画などといふ麁画に俳句の賛を書くのは、山水などの場合と違ふて、面白き者が多い。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "（八月二十四日）百五○略画俳画などと言つて筆数の少い画を画くのは、むしろ日本画の長所といふてもよい位であるが、その略画といふのは複雑した画を簡単に画いて見せるのを本領と思ふて居る人が多い。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうぼうで演説をしたりして気焔をあげていたが、そのうち笈を負うて上京し、紅葉山人などと交友し、俳画で以て名をあげた。",
              "citation": {
                "source": "三人の師",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸先生の俳画に対して、皆多少は驚いたのである。",
              "citation": {
                "source": "俳画展覧会を観て",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより寧ろ、頭のどこかに俳画と云ふものと、値段の安いと云ふ事とを結びつけるものが、予め存在したと云つた方が適当である。",
              "citation": {
                "source": "俳画展覧会を観て",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、上人の俳画は勿論祖師でも何でもないから、更に紙衣なんぞは着てゐない。",
              "citation": {
                "source": "俳画展覧会を観て",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "（筆力等の技術はその書及び俳画を見て想像するに足る）蕪村は南宗より入りて南宗を脱せんと工夫せしが如し。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の画を称する者多く俳画をいふ。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳画は蕪村の書きはじめし者にして一種摸すべからざるの雅致を存す。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかれども俳画は字の如き者のみ、終に画に非ず、画を知らざる者これを以て画となす、取らざるなり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横自在にして法度にかかはらず、しかも俗気なきこと俳画に同じ。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "又単に所謂俳画なるものでもない。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その張交に石摺だの、俳画だの、扇の骨を抜いたものなどが見えた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "通されたのは奥の六畳、型のごとく明窓浄几、側には俳書らしいのを入れた本箱、前の炉には釜がチンチンたぎって、俳画の細物の一軸が後ろにあるといった道具立てで、主人の鶯谷は茶色の頭巾を深々と冠り、被布を羽織ったまま、口をもぐもぐさせて二人を迎えます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次には夜半堂の筆法で、軽妙に近い俳画が描かれて、上に一茶調の俳句が題してある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "画帳へ俳画と句とを書かうと云ふ。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "画にするならば正に俳画の世界である。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓢箪の蔓に見越すや雲の嶺　　　　范孚　俳画に描くとすれば、窓に垂れた瓢箪の蔓を比較的大きく画いて、その向うに雲の峯の白く聳えているところを現すのであろうか。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "画にすれば俳画よりも漫画に近いものであろう。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に俳画になり得べき趣である。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣ごしや菊より出て長咄し　　　　旦藁　俳画的小景である。",
              "citation": {
                "source": "古句を観る",
                "author": "柴田宵曲",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
