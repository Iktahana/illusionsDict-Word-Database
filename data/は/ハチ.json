        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（一九三三・八・一四）",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三三・一〇・八）",
              "citation": {
                "source": "いちぢくの葉",
                "author": "〔夏の午前よ〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三六、一、二八）",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五、第六、第七、第八行。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、二、三、四行に於ても、第五、六、七、八行に於ても、海は猶深さよりも広さを感じさせたが、茲に於て海は深く、ふてぶてしくも狂暴である。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一九三六、八、二――",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が高森を知つたのは七八年前のことであるが、彼はその前から詩を書いて、日夏耿之介主宰の游牧記等に発表してゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―一九一四、五、八―",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―一九一四、八、十四―",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一九一四、八、八――",
              "citation": {
                "source": "岩魚",
                "author": "――哀しきわがエレナにささぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一九一四、八、吾妻ニテ――",
              "citation": {
                "source": "山頂",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此の新生児を抱いて、七転八倒してみるだけのことである。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり七転八倒の文章であるから以下簡単に此の一文を要約してみる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルスリーヌ・デボルド―※ルモオルは千七百八十六年七月の二十日にドゥエ（Douai）に生れ、千八百五十九年七月二十三日巴里で死んだ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく月収僅か八十｜法で以てフェイドオ劇場といふのに招かれ、赤貧洗ふが如き生活をした。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三六・八・一五）",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三五・二・一八）",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリスタン・コルビエールは、千八百四十五年、七月十九日、午前八時、モルレーに於て汽船会社の社長の息子として生れ、千八百七十五年、三月一日午後十時同所で死んでゐるから三十年に足らぬ生涯であつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "プリプリしながら、だがその晩は七時にはお湯屋に行き、目覚時計を四時に掛けて八時には床に這入つた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その庭といふのはその後数回築き直されたにも拘らず、その忠魂塔の台石となつた石だけは殆んどその位置を変へず、そしてその忠魂塔も、私が後に出郷してからも、帰省した時には見掛けたやうに思ふが、七八年前帰省した頃から、それは姿を消した。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論暗くなつたればとて、他人様にまで八ッ当りを始められる程の自分なら何を書かう程のことでもないけれど、暗くなると却て明るい真似をしてみたり急に他人本位になつたりしなければならない上に、それでゐて結局人からもさういふ時はやつぱり此奴暗いと見て取られてしまふからには、なんとも馬鹿化た話なんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の肥つた女達は、私のや私の前の男のネクタイを見ながら、「まあ勉強しますわねえ、八十銭であんな物まで附けるのですものねえ……ええェ」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十七日パパカラ可愛イ子ニ、ソレカラ皆ノ人ニヨロシク。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "小泉八雲　小サイ可愛イママサマ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼津　八月十八日小泉八雲　この情緒纏綿たる手紙は、新婚当時の手紙ではない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、不便が嬉しくはちつともない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、君、僕はちかく勘当されるかも知れないのだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとはちよつと失敗した。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんだ、」小坂氏はちょっとまごついて、「何を言うのです。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
