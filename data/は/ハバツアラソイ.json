        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "政党内の派閥争いが激化し、党首のリーダーシップが問われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史を振り返ると、多くの組織で派閥争いが起きてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "些細なことから派閥争いが始まり、組織全体に悪影響を及ぼした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし、今度のことは、おそらく陸軍内部の派閥争いに直接の原因があるだろう。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれなんかも、陸軍の派閥争いの一つの犠牲だよ。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の事件にしたって、おそらく青年将校が主動者になっていると思うが、それも、もとをただせは巨頭連の派閥争いが原因さ。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍の派閥争いもそれには関係があった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと休みしたら、どうだ、俺と一緒に仕事をしないか」「軍の派閥争いからは手をひいたほうがいい……？",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "派閥争い、功名争いで、トコトンまで戦争をやるにきまってる。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
