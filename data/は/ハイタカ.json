    "definitions": [
      {
        "index": 1,
        "gloss": "Eurasian sparrowhawk (Accipiter nisus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
