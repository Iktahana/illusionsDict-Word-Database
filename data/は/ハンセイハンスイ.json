    "definitions": [
      {
        "index": 1,
        "gloss": "half awake and half asleep",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
