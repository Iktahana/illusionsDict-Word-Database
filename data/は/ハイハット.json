        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ハイハットをしっかり踏みこまず、オープン気味でガシャガシャさせるのも、切れが悪くて好きじゃない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "開き気味のハイハットと、それにバスドラムとウッド・ベースのイントロが入ってきた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じぶんはイントロのあいだ、くわえタバコでハイハットの位置をなおし、ゆったりとスティックをかまえ、八分四拍のおかずで、曲に入っていく。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キース・ムーンはさ、ハイハット使わないんだぜ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラディックのスネアと、ジルジャンの一八か二〇インチ、それにハイハットぐらいは買おうと思ってさ」　服部は、慶一の嫌みには気づかなかったように、すましていう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて亜理沙が暗闇の中で緑色に光るスティックを振り回しながらハイハットシンバルとスネアドラムを交互に叩き、しばらくすると赤いスポットライトが亜理沙を包み込んだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
