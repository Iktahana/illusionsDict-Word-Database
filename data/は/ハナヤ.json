        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "造花作りは花屋を恨む、さて、花は造花程口がきけない。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、それは花屋の前であつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられてゐて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられていて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近辺の寺々いずこも参詣人多く花屋の店頭黄なる赤き菊｜蝦夷菊堆し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の店の氾濫、カード屋のカード字も独逸風のややっこしい装飾文字が太く賑やかに刷られて居るのも、他の国のとは自然違う感じです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花買いに四目の花屋に行く。",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に最後に、漸く一軒の花屋によつて氏の宅を教へられた。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその花屋の曰く。",
              "citation": {
                "source": "蒲原有明氏の近況を聞いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "首や手が自分で動かせるやうになつた時、私は見舞にくる母に外國の繪葉書を買つて來て貰つて眺めたり、武井さんに頼んで草花の鉢や切り花などを病院の近くの草花屋から買つて來て貰つた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼い女児二人は縁側へいろいろなお花を並べて花屋さんごっこをする事もある。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の店先に立って色様々の美しい花を見ているうちにこんな事を考えた。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思ったので、つい花屋を通り過ぎてしまった。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "門をくぐると左側に花屋があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆前で参詣が多いとみえて、花屋の小さい店先には足も踏み立てられないほどに樒の葉が青く積まれてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとの花屋へ帰って来て、死んだ師匠は生きているうち、墓まいりに時々来たことがあるかと、半七はお婆さんに訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋の前には梅と福寿草をあしらった植木鉢が並んでいた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の門、植木屋の庭、花屋の店など、坂下を挟みて町の入口にはあたれど、のぼるに従いて、ただ畑ばかりとなれり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポインセチアはこれまで花屋で見かけた事はあるが、名はそれまでは知らなかった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アカチーン街の語学の先生の誕生日に、何か花でも贈り物にしたいと思って、アポステル・パウルス・キルヘの前のけちな花屋へ寄って、あれかこれかと物色した末に買ったのがこの花であった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時に江戸川の大曲の花屋へ寄って求めたのがやはりベコニアであった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオンの店をだされたアンナが町の花屋の屋台の花をぼんやりながめる。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋のおばさんが花束をさしだす。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　つるばらと団扇とリベラリスト　鉢植えのつるばらがはやると見えて至るところの花屋の店に出ている。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんご存じないでしょうが、寺町の清華寺の隣りに、トモヤという小さい花屋がありました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花屋から屑花を払いさげてもらって、こうして売りに出てから、もう三日も経っているのであるから花はいい加減にしおれていた。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼ごろ用があって花屋へ行って見たらすべての花は水々していた。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "準備が整って予定の時刻が迫ると、見物人らは一定の距離に画した非常線の外まで退去を命ぜられたので、自分らも花屋敷の鉄檻の裏手の焼け跡へ行って、合図のラッパの鳴るのを待っていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードは浅草の盛り場の光景を描いた「音画」らしい、コルネット、クラリネットのジンタ音楽に交じって花屋敷を案内する声が陽気にきこえていた。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸川畔の花屋でベコニアの鉢を求めてお見舞いに行ったときは、もう面会を許されなかった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
