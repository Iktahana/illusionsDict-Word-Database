    "definitions": [
      {
        "index": 1,
        "gloss": "judges and prosecutors",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
