[
  {
    "uuid": "84371646-581b-5148-9af1-b98b9ff5e6fa",
    "entry": "林",
    "reading": {
      "primary": "はやし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
