  {
    "uuid": "5face286-eb62-51ed-9b3e-4d1f3cb53a2b",
    "entry": "ハヤシ",
    "reading": {
      "primary": "ハヤシ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hash (e.g. hashed meat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オサムラヒニ　バケル　トキハ　マゲヲ　ツケテ、ヒゲヲ　ハヤシテ、カタナヲ　オコシニ　サシテネ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケレドモ、タイヘンナ　コトニ、コゾウサンガ　ピント　ヒゲヲ　ハヤシテ　ヰマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "葱とチーズを壺焼にしたスープ・ア・ロニオンとか、牛舌のハヤシライスだとか、莢隠元のベリグレット・ソースのサラダとか、彼がふだん好んだものを註文したので鼈四郎は慥え易かった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入獄するチョット前からハヤシかけていた髭は、暇に任せてネジったりヒッパったり散々に虐待するものだから、たださえ薄い少ないのが可哀相に切れたり抜けたり少しも発達せぬ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはワキ師がハヤシ方に成つても善からう。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし出来るならばシテも遣る、ワキも遣る、ハヤシ方も遣る、狂言も遣る、さういふやうな人もあつて差支ないであらう。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂水之水能早敷八師（巻十二・三〇二五）で、ハヤシのハとハシキヤシのハに続けたたぐいである。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "地帯一帯を蔽う、くぬぎ林は、ハヤシの如くしずまりかえっているし、はき溜を置いてあるでなし、ドブ板があるでなし、リーヤ・カーが置きっ放しになっているではなし、ましてやネオンサインも看板もない。",
              "citation": {
                "source": "第四次元の男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者でも、道具方でも、ハヤシ方でも、選り好みはしないよ。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "全部がそのまま言葉にしては、単調すぎて異様であるが、至極単純な句とハヤシ言葉の合成したものかも知れない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間まで食堂にゐるつもりで、ゆつくり献立表とにらめつくらをし、その挙句、ハヤシ・ライス一皿を註文して、アイス・ウォターをがぶがぶ飲んだ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この時、遠くから風にのって流れて来る秋祭りのハヤシの笛と太鼓の浮き立つような音。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金吾　この奥の村でそろそろ祭りだから、ハヤシの稽古だ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（ハヤシが高調にかかる）……お父さん！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｅ　その静けさの底から、はじめは、それと聞きわけられぬほど微かに、次第にハッキりと浮き立って流れてくる祭りのハヤシの音。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（なお調戯いたげにしたが追分のハヤシを唄い終り、出てくる時次郎、おきぬを見て、這う這う行ってしまう）おきぬ　（酔漢のうしろから）何をいってやがるのだい。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "日新亭のハヤシライスが食べたいってよく泣いたのは誰だっけね。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は子供の頃、ハヤシライス位｜旨いものは知らなかった。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は自分はスープを、私にはハヤシライスを誂えた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "田原屋のハヤシライスとオムライスとって貰って食ひ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜食八時頃、食堂へ下りて、オムレツ・ハヤシライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食大阪屋のホワイトシチュウとハヤシライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事は大阪屋ハヤシライスとホワイトシチュウ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "間に、大阪屋のシチュウとハヤシライスを食ひ、六時頃から「われらが猫騒動」の稽古。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って大阪屋のポタージュとハヤシライスを食って、おね／＼してるともう夜の「芝居」が開く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所でソーダ水と大阪屋のハヤシライスを食ひ、理髪しに行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪屋のハヤシライスとトースト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って入浴し、大阪屋のハヤシライスと毛利の肉まん。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻迄二三カット、食堂でハヤシライスをパクつくと、又始まる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻雀クラブへ、やり乍ら、ハヤシライス一、ちらし一、しるこ一、ざうに一、皆おどろく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
