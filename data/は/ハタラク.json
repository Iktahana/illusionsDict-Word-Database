[
  {
    "uuid": "bc7facb2-827e-5395-9d60-ee242366e8f9",
    "entry": "働く",
    "reading": {
      "primary": "はたらく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
