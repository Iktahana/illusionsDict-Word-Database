[
  {
    "uuid": "4229d4b4-9c89-5bd5-bff6-0f86bc7bbbbc",
    "entry": "波動",
    "reading": {
      "primary": "はどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wave motion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腰に括ってある紫の風呂敷が、揺れると、強烈な色彩の波動が、流水の震動と一つになって、寂しい谷が、ぱっとなる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の考案は光がエーテルの波動だという事を基礎としたもので、理論上実に巧妙なものである。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に前述の発生器で生じた波動を空中に伝える物は、アンテナと称えて高い柱に張った針金である。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしアインシュタインは古い昔のガリレーをほじくって相対性原理を掘りだし、ブローイーは塵に埋もれたハミルトンにはたきと磨きをかけて波動力学を作りあげた。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュートンが光の微粒子説を主張したという事がどれだけ波動説の承認を妨げたかは人の知る所である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュートンは物体から微粒子が飛んで来るのが光だと考えたが、ハイゲンスが出て来て波動説を称えこれが承認されるに幾多の年月がかかった。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその地質的変動によって生じた地震の波が如何なる波動であったかというような事はむしろ第二義以下の問題と見られる傾向がある。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにレーリーの「光学」と「光の波動論」が出ることになった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後日彼は、あるアメリカの農夫が『百科全書』を買ってＡからＺまで通読しているという噂をして「私の波動論をどう片付けるか見ものだ」と云った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　運慶が木材の中にある仁王を掘り出したと云われるならば、ブローリーやシュレディンガーは世界中の物理学者の頭の中から波動力学を掘り出したということも出来るであろう。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も映画で見られるほどの運動は老人の膝に認められないが、微細な波動がないとは云われないのである。",
              "citation": {
                "source": "鴉と唱歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとはもう聞えないくらいの低い物言いで隣りの主人からは安心に似たようなしずかな波動がだんだんはっきりなった月あかりのなかを流れて来た。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "より深い暗黒が、いつも絶えない波動で刻々と周囲に迫って来る。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代物理学に新紀元を画した相対的原理にしても、素量力学や波動力学にしても、直観なしの推理や解析だけで組み立てられると考える事がどうしてできよう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年に至って原子は電子とプロトーンによって置き換えられ、ごくごく最近に波動力学の出現によってこれら物質的素量に関する観念に始めて目立った変化をきたしつつある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代の相対性理論にしても、量子力学にしても、波動力学にしても基礎に横たわるものはほとんど哲学的、あるいは質的なる物理的考察である。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいことには、また一方で、自然界に存する実際のすべての波動はやはり「虚成分」をもっていて、これが減衰を支配し、ある意味ではまた拡散をも意味する。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、もしや、拡散も波動も概括するような一つの大きな体系があって、その両極端の場合が不減衰波動と純粋な拡散とであって、その中間にいろいろなものが可能でありはしないかという空想が起こり得られる。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまた、ある特別な科学国の「国語」の読める人にとっては、アインシュタインの相対性原理の論文でも、ブロイーの波動力学の論文でも、それを読んで一種無上の美しさを感じる人があるのをとがめるわけにはゆかないであろうと思う。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュートンの光学が波動説の普及を妨げたとか、ラプラスの権威が熱の機械論の発達に邪魔になったとかという事はよく耳にする事である。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "振動週期の短い主要動の始めの部分に次いでやって来る緩慢な波動が明らかにからだに感ぜられるのでも、この地震があまり小さなものではないと思われた。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつもこうした混雑の週期的な波動の「峰」を避けて「谷」を求める事にしている。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてこの肺病の一労働青年は日本じゅうの人気男となり、その波動はまたおそらく世界じゅうの新聞に伝わったのであろう。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば近代物理学の領域を風靡した「波動力学」のごときもその最初の骨組みはフランスの一貴族学者ド・ブローリーがすっかり組み立ててしまった。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでアルベール自身の頭の中に経過しつつある不安な警戒の念が彼の絶えず移動する目のくばりに現われて、それが直ちに観客の頭に同じような感情の波動を伝えるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこれらの構成要素はそのモンタージュのリズムによってあるいは急にあるいはゆるやかなる波動を描いて行く、すなわち音楽的進行を生ずるのである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに悚然とした状に、一度すぼめた袖を、はらはらと翼のごとく搏いたのは、紫玉が、可厭しき移香を払うとともに、高貴なる鸚鵡を思い切った、安からぬ胸の波動で、なお且つ飜々とふるいながら、衝と飛退くように、滝の下行く桟道の橋に退いた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海　　海の憂鬱さは、無限に單調に繰返される浪の波動の、目的性のない律動運動を見ることにある。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身が無名でさへなかつたならば、何とかしたでもあつたらうけれど、私が話をした知名の人達はどう迂つ闊りとしてゐたものか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ茲で附加へたいことは、感動が、点睛の実現にまで到達する、つまりのどいりのする感動であるためには、私はどうしても宗教が必要だと思ふ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
