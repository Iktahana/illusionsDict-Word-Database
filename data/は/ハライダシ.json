        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新しい株式の払い出しが決定し、投資家たちの注目を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "国債の払い出しは、国の財政状況に大きな影響を与える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "配当金の払い出しは、株主総会で承認された後に行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
