        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死亡の三日前までは少しも払い出したことはなかったが、その日彼女は自分でやって来て四〇〇〇フランの金額を引き出した。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "パッタリ顔が合うや否や、馬上の二人は、退屈男の俄かに底気味わるく落ち付き払い出した姿をみとめて、ぎょッと色めき立ちました。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、直ぐ払い出しは出来ないと云う。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス大蔵省が今朝払い出した償金の額より多くの金を、彼等連合軍の兵士たちは、フランス商人の懐ろにねじ込んで行つたのである。",
              "citation": {
                "source": "時　処　人",
                "author": "――年頭雑感――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年末の勘定仕切のときであるが、払い出しの帳簿をみてゆくと、玄一郎が赴任したときの招宴の費用が書き出してあった。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……玄一郎はこれをすぐに払い出し帳簿から削り、勘定書を三者それぞれの詰所へ持ってゆかせた。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇分も経たずして、各銀行当局は今しがた払い出した金貨の山を、再び収納する作業に大わらわ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
