      {
        "index": 1,
        "gloss": "(ceremonial) bow used to drive off evil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
