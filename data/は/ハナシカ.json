  {
    "uuid": "8b14f837-0f1e-5ede-8e6c-35c9a799d464",
    "entry": "噺家",
    "reading": {
      "primary": "はなしか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
