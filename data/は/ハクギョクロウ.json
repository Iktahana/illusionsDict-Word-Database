    "definitions": [
      {
        "index": 1,
        "gloss": "celestial tower where poets, artists, etc. were said to go in the afterlife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "憾むらくは其の叙するところ、蓋し未だ十の三四を卒るに及ばずして、筆硯空しく曲亭の浄几に遺りて、主人既に逝きて白玉楼の史となり、鹿鳴草舎の翁これを続げるも、亦功を遂げずして死せるを以て、世｜其の結構の偉、輪奐の美を観るに至らずして已みたり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はじつに末頼もしい活溌な青年であったが、十八歳を一期として白玉楼中の人となった。",
              "citation": {
                "source": "私の子供時分",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物語を聞いた日から三日のちにＹ――の容態は急変して遂に白玉楼中の人となってしまったのでした。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、生ているうちから伝説化されて、いまは白玉楼中に、清浄におさまられた死者を、今更批判するなど、そんな非議はしたくない。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜むべし、彼は、治承三年八月三日を以て、溘焉として白玉楼中の人となれり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽て漢詩の大家何某先生｜白玉楼中の人となるや葬礼に際して俄に文学博士の学位を授られたる事あり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの世には悩みも恨みもこれあるまじく、父の手を執りて由利どのを追い、共に白玉楼中の人となるが、いまはの際の喜びに御座候。",
              "citation": {
                "source": "乳を刺す",
                "author": "黒門町伝七捕物帳",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
