        "examples": {
          "standard": [
            {
              "text": "この販売人は、商品の知識が豊富で、いつも親切に対応してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "顧客満足度向上のため、販売人の研修に力を入れています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は長年、この地区で誠実な販売人として信頼を得ている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ＮＥＣＩＳの製品計画、現地の販売チャネルの構築、日本からの営業支援を担当していた浜田は、繰り返しアメリカを訪れ、アストラの前にパーソナルコンピューターが立ちふさがろうとしている事実を肌で感じとっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
