[
  {
    "uuid": "773737ff-d4ea-570b-a4c5-5691bb6dda4f",
    "entry": "灰神楽",
    "reading": {
      "primary": "はいかぐら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
