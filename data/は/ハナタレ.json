    "definitions": [
      {
        "index": 1,
        "gloss": "runny-nosed child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
