        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この一家の人たちは、みんな早耳でしたから、いま、おとなりのメンドリが言ったことを、のこらず聞いてしまいました。",
              "citation": {
                "source": "ほんとにそのとおり！",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここで甘酒を飲まなくっては、鳩にして豆、」　と云うと、婆さんが早耳で、「はい、盆に一杯五厘｜宛でございます。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のほしいのは早耳と、それから、お嬢さんです」　いつの間に見染めたのか、陽子を妻にくれという章三の言葉は、鉱三を驚かせたが、しかし、小切手を背景にした章三の精悍な顔と、押しの強さは、鉱三の青年時代を想わせて、満更でもなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そう早耳を走らすとつんぼと間違えられますとさ」　と女将は事もなげに受け流した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳敏き者とあったその早耳の男も沢山交っているとみえて、歩きながらも内証話をきき出そうと、しきりにニヤニヤやっているのがいくたりか見えました。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早足に早耳に世間通に、世馴れ者のバクチ打ちとはひと狂言打てそうじゃ。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとのひとりはちと大物ゆえ、残った早足東五郎と早耳七五郎の両名揃うて参るがよい。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "早耳一番やりのおきてがあるからにゃ、この事件は早く聞きつけたあっしとだんなのものなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "のそのそしてりゃ、せっかく早耳に聞き込んだ事件を横取りされるんじゃねえですかよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "良因　　でも、つんぼうの早耳といふことも……。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "病院へ来て二週間目にあたるという晩には、お房は最早耳もよく聴えなかった。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に出羽殿にも御承知」「へえ――、えらいお早耳で」「出羽殿より早速これを御上の御耳にも入れたところ、以ての他の事。",
              "citation": {
                "source": "備前天一坊",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この友人は幾つもの会社の重役をしていた上に関西の財界の大立物を親戚すじにひかえていたから、日本の財界の動きにかけては誰より確実な早耳を持っていた。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人来た早耳の連中が、夕刊の締切が近いので、それ以上聞出し得ずに慌てて帰って行った迄の事よ。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "和、漢、蘭の書物にも、巾着切の早耳話ってのは、書いてないよ。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後油断をすると飛んでもないことになるぞ、早耳生――というのだ。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……検事さん、兄は心臓麻痺で死んだという話だが――ええ、早耳でね、僕のところへも聞えて来ましたよ――するてえと兄は病気で急死したんじゃないんですか。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と早耳の検事はその言葉を聞き咎めて、「――おい君、善良な警官を悪くしちゃ困るよ」「いや話を聞いておくだけなら、悪かなりませんよ」と帆村は弁解して、「――もちろん種があるんです。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯早耳の報道によれば、今日は尾久や日暮里附近がかなりやられたという話。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な物めずらしさで、よく見て居たいと思うともう私は婆さんの話には最早耳をかたむけなくなって仕舞った。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今泉は早耳好きだつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨・肥後・阿波其他早耳の琵琶坊も、足まめな万歳も、聴き知らぬ遠山陰の親方・子方の村が、峯谷隔てた里村の物資に憧れ出す時が来た。",
              "citation": {
                "source": "山のことぶれ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「萱野さんのご養子んとこへ徴用が来たんですつて……」　と、楯氏のところの女中さんはなかなか早耳である。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウム、彼なれば早耳地獄耳、江戸の屋根の下の出来ごとは、一から十まで心得ているにふしぎはない。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは江戸花川戸の岡っ引、早耳三次が手がけた事件の一つ。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "海へ帰る女",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやみみせいより”　予感は適中した。",
              "citation": {
                "source": "大脳手術",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
