    },
    "definitions": [
      {
        "index": 1,
        "gloss": "beach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "聞けばその後また横浜の小学校に転任したさうであるが、ナニ、ブラ公なぞが訪ねた所で誰が喜ぶものでもあるまい。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や干魚かけたる浜庇　海岸の貧しい漁村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで非常な期待と憧憬とをもって出かけたのであったが、運悪く漁がなくて浜は淋しいほど静かであった。",
              "citation": {
                "source": "初旅",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては五十鈴の流れ二見の浜など昔の草枕にて居眠りの夢を結ばんとすれどもならず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊橋も後になり、鷲津より舞坂にかゝる頃よりは道ようやく海岸に近づきて浜名の湖窓外に青く、右には遠州洋杳として天に連なる。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜松にては下りる人乗る人共に多く窮屈さ更に甚だしくなりぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "程が谷近くなれば近き頃の横浜の大火乗客の話柄を賑わす。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が生れて初めて原稿料というものを貰って自分で自分に驚いたのは「団栗」という小品に対して高浜さんから送られた小為替であった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高浜さんは覚えておられるかどうか一度聞いてみたいと思っている。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそういう点を高浜虚子氏に対して感ずる人は割合に少ないかもしれない。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高浜さんには礼を失した点も多かろうと思うが昔に免じて御宥恕を願いたい。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒が浜辺に大勢居る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜を見るとまぶしい。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板へ上がってボーイに上等はあいているかと問うとあいているとの事、荷物と帽を投げ込んで浜を見ると、今端艇にのり移ったマントの一行五、六人、さきの蝶々髷の連中とサヨーナラといっているのが聞える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫の処を見ると定さんが旗竿へもたれて浜の方を見ながら口笛を吹いているからそこへいって話しかける。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖の礁を廻る時から右舷へ出て種崎の浜を見る。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例のハイカラは浜行の茶船へのる。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論その頃はまだ東海道鉄道は全通しておらず、どうしても横浜から神戸まで船に乗らねばならぬ。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風であるから、これも自分には覚えておらぬが横浜から雇った車夫の中に饅頭形の檜笠を冠ったのがあったそうだ。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒き浜辺にマルガレエテが歩み寄するヴェールを風に千々にされながら。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も横浜通の紫紅兄（山崎）の批評で凹んでいるとあるのも、横浜付近の誤謬記事を指摘されたことを、付随して言ったのだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "越後の豪家｜高頭仁兵衛氏が、山岳辞彙ともいうべき浩澣な原稿をかかえて、志賀先生を訪問せられたとき、横浜にいる人が、こんな紀行文を発表している、山を知っている人らしいから、訪問してみたらどうかと、注意されたそうだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして孤雁木城二君が、横浜山王山の私の宅を尋ねられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜の波止場で、家族と友人の出迎えを受け、久しぶりで逢いたい顔に逢ったが、ただ一つ逢えない顔があった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾野は富士の物だ、富士のものを富士に返して、東海の浜にまで引き下り、さて仰いで見たまえ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "万寿丸は室浜の航海だ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に三回はいやでも浜に入って来らあ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "北海道から、横浜へ向って航行する時は、金華山の燈台は、どうしたって右舷に見なければならない。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはたぶん横浜岸壁あたりで訣別の色テープの束の美しさを見て来てから考えたものらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はまだ降るだらうかインキ壺をのぞいてニブリ加減をみよう",
              "citation": {
                "source": "（ツツケンドンに）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
