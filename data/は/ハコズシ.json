        "examples": {
          "standard": [
            {
              "text": "大阪の郷土料理である箱寿司は、見た目も美しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "お祝いの席には、彩り豊かな箱寿司がよく出される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "箱寿司は、押し寿司の一種で、木枠を使って作られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このごろ京阪流箱寿司は、上方の何処の地方にもはやってはいるが、なれ寿司を基調とする調理に意気のない野暮ったさが、即興に生きる江戸ッ子には、とんと迎えられる様子もない。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにはともあれ、大阪の箱寿司が握りに圧倒されたのは、寿司食いの勝で、寿司屋の負けである。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
