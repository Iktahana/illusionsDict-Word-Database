[
  {
    "uuid": "199f033d-a024-5142-b52a-4762a28cf4a6",
    "entry": "馬銜",
    "reading": {
      "primary": "はみ",
      "alternatives": [
        "はめ",
        "ハミ"
      ],
      "is_heteronym": false
    },
    "grammar": {
