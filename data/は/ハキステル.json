          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "京にても宿屋の下女、さすがになまめきて、三日のなじみ、さはらば落つべかりしが、それもここにては掃き捨てるほどぞかし。",
              "citation": {
                "source": "旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、森源は、白い眼をあげて私を一瞥すると、「ふん、輸入ものがいいと思ってるなア素人さ」　そう、ぺっとはきすてるようにいうと、知らん顔をして仕事の手を続けていた。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            }
          ]
