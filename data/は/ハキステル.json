[
  {
    "uuid": "ed19f849-dff2-50c2-8f21-957ac7b7ab13",
    "entry": "吐き捨てる",
    "reading": {
      "primary": "はきすてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
