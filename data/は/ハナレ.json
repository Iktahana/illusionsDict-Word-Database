[
  {
    "uuid": "c8fc342b-023b-5d72-8877-f3242ef3e562",
    "entry": "離れ",
    "reading": {
      "primary": "はなれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
