        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あのでれ助が胡麻の蠅とは、こいつはちいつと出来すぎたわい。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜荷では少しさびしく、七｜荷ではちいつとばかり贅沢だつたが、だいじな一人娘なぞには親がきばつて七荷にすることが多かつた。",
              "citation": {
                "source": "よめいり荷物",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
