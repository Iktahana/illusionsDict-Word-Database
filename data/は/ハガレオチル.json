        "examples": {
          "standard": [
            {
              "text": "長年放置された看板から、ペンキの破片がパラパラと剥がれ落ちる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "壁紙が剥がれ落ちて、下地のコンクリートが剥き出しになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かさぶたが自然に剥がれ落ちるまで、絶対に触らないでください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "とたんにハッキリ手応えあってゲソッと何かの剥がれ落ちるような音響がした。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、到るところ、面白いくらゐくるくるとはがれおちるものが感じられる。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
