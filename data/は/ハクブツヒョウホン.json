        "examples": {
          "standard": [
            {
              "text": "博物館には、貴重な動植物の博物標本が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この蝶の博物標本は、100年以上前のものだという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "研究室では、様々な地域の博物標本を比較研究している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "三　静かな博物標本室の中。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（18）Jardin des Plantes ――植物園ではあるが、パリでは動物およびその他種々の博物標本をも十分に備えたところを言う。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　或晩私はＧ氏の書斎で、博物標本の映画を観てゐた。",
              "citation": {
                "source": "交遊秘話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間も、博物標本室の、象の剥製標本の中から、のこのこと出て来た諜者がいたからね、わしの教室だって、決して安全な場所ではないんだ」　そういうカビ博士の顔には、いつにない不安の色が漂っていた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
