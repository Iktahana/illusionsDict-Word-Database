        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "實際その朝、彼は疾風のやうに訪ねてきて、いきなり二階の梯子を驅け登つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い高い梯子が立ってその上に天の戸が開けていた、王がそれを登りつめて最後の段に達した時に起こされたのだと言う。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "程なく新高知丸の舷側につけば梯子の混雑例のごとし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄下の溜池に海蟹の鋏動かす様がおかしくて見ておれば人を呼ぶ汽笛の声に何となく心｜急き立ちて端艇出させ、道中はことさら気を付けてと父上一句、さらば御無事でと子供等の声々、後に聞いて梯子駆け上れば艫に水白く泡立ってあたりの景色廻り舞台のようにくる／＼と廻ってハンケチ帽子をふる見送りの人々。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "革鞄と毛布と蝙蝠傘とを両手一ぱいにかかえて狭き梯子を上って甲板に上がれば既に船は桟橋へ着きていたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（立ちながら休むときは、脊の担い梯子へ、息杖を当てがって、肩を緩めるので「一本立てる」というのである。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと隣って、一段高く梯子段を上ったところに、浅間神社を勧請した離屋が、一屋建ててあり、紀伊殿御祈願所の木札や、文化年間にあげたという、太々神楽の額や、天保四年と記した中山道深谷宿、近江屋某の青銭をちりばめた奉納額などがあった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへは、縄梯子をガットにかけて下りるより外に方法はなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五六呎の長さの縄梯子でなければ、底へは届かなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな小さな穴からは、丈夫な生きた人間が「一人」で、縄梯子を伝って降りるより外に、方法は無かった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は民さん一寸御出でと無理に背戸へ引張って行って、二間梯子を二人で荷い出し、柿の木へ掛けたのを民子に抑えさせ、僕が登って柿を六個許りとる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長ガ無電ヲ神戸港ノ司令部ニ打ツ　兵来リテ汽車ニテ○○へ急グ　航行中ノ運送船ヨリ縄梯子ヲ降シ、モーターボートヨリ兵乗リウツル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝廊下　障子破れて、襖が倒れて、五六人の黒い影が組んづほぐれつ段梯子を折り重って転がり落ちる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鶴の野郎何を言ってやがるんだろう」　と、そっと梯子段の処で窺う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「なーに、この位えの傷ァ……七五郎、こんな事があるから俺ァお前にやくざになるなって言ったンだ」　石松、梯子を這いあがる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石松、吉兵衛になァお前の来た事を……」　「誰が言やがったんだろう……畜生」　七五郎、言えなくなって梯子を下りる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰もいねえ、いねえてえのに」　児分達、梯子を掛けて駈けあがる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝茶店の横手　進藤甚助と例の若侍が梯子掛けて進藤が屋根へ上る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い梯子段を上がる時、フリイデリイケはイレエネに囁いだ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "梯子を下り行く足音留る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急ぎ足にて梯子を登る音す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（梯子を駈け登りしため、息を切らしいる様子。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、兎に角梯子段の下までは一しょに行きましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして器械的に種々な駅の名を読んで、自分がたつた今｜転ばうとした梯子段を、可笑しがつて見てゐる人のやうな顔をしてゐた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "出ていらっしゃいませんか」「なぜ、裏梯子から上っていらっしゃらないの」「薄荷水をピストルで眼の中へ弾き込まれちゃかないませんからなあ」　小初は電球を捻って外出の支度をした。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の銅羅が暁を破ると見送人達は鉄梯子を下りて対岸に並ぶと、二度目の銅羅と一斉にわめき出す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　ストリート・ガールであった、鋪道のアヴァンチュールにかけては華やかな近代娘の典型であった四家フユ子が、赤い梯子を登ったのだ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く、二階から、梯子段をおりて来る靴の音がした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貨車の屋根に梯子をかけて這い上った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は、井村がケージの脇の梯子を伝って這い上った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
