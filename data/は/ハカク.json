        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大正九年、露細亜詩人ベールィの作を雑誌で見かけて破格語法なぞといふことは、随分先から行はれてゐることなんだなと安心す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしかしその役者の頭の悪い証拠でなくて良い方の破格の一例として取扱わるべきものであるかもしれない。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例を申せば、無塩君は醜婦でありましたが破格の出世を致しました。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御老体、」　雪叟が小鼓を緊めたのを見て……こう言って、恩地源三郎が儼然として顧みて、「破格のお附合い、恐多いな。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に七五調が破格を生み、単調のものが複雑になり、そして最後に、今日見る如き自由詩に到達した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂はば破格の着想である。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより我と其独人との間に破格なる会話は初められぬ。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "上条のお上さんがお世辞を言わない、破格な金遣いをしない岡田を褒め始めたのは、この信頼に本づいている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうの晩飯だけが破格なのだ」「ありがたいわ」さっきから幾つかのボタンをはずしていた手袋をぬいで、卓越しに右の平手を出すのである。",
              "citation": {
                "source": "普請中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれに銭をあたえて通ったという森積は、その翌年の正月に抜擢されて破格の立身をした。",
              "citation": {
                "source": "妖婆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "此細君丈は破格である。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "クララが今夜出家するという手筈をフランシスから知らされていた僧正は、クララによそながら告別を与えるためにこの破格な処置をしたのだと気が付くと、クララはまた更らに涙のわき返るのをとどめ得なかった。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "用語、語調等に於ける古典文学の中庸主義は破られて、激越な語句、詩法上の破格が自由に許された。",
              "citation": {
                "source": "文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当店が今秋の破格大安売りとして提供すべきこの品の一号二号三号までの価格を御決定下さい。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "としては最高前例にもない破格の出世をした女性であつた事はたしかである。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来、新聞劇評家が見物にゆくのは、大劇場格の劇場に限られていたので、吾妻座だけが一種の破格であったらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の社でも今の樣に破格の優遇はして呉れなかつたが、其代り私は一日として心の無聊を感じた事が無い。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ此方の社が擴張の機運に際して居たので、社長は隨分と破格な自由と待遇を與へて竹山を伴れて來たのだと云ふ事であつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の社でも今の様に破格の優遇はして呉れなかつたが、其代り私は一日として心の無聊を感じた事がない。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ此方の社が拡張の機運に際して居たので、社長は随分と破格な自由と待遇を与へて竹山を併れて来たのだと云ふ事であつた。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "例年なら今頃はとくに葉を振って、から坊主になって、野分のなかに唸っているのだが、今年は全く破格な時候なので、高い枝がことごとく美しい葉をつけている。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "入営中の勉強っていうものが大したもんで、尤も破格の昇進もしました。",
              "citation": {
                "source": "躯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「末つむ花」のような当時の文学のしきたりから見れば破格の面白さも、その点からこそ描いた源氏物語には女のはかなさというものへの抵抗が現われている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの破格の取扱いは、すべて秀蓮尼の信用によるものらしかった。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろその時京都から出品したのは、私のほかにと言っては岩井蘭香さんがおられたくらいのもので、蘭香さんは当時もう六十歳くらいの御年齢でしたから、まるで破格の待遇であったわけだ。",
              "citation": {
                "source": "最初の出品画",
                "author": "――四季美人図――",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し抽斎の次男優善は破格であった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一躍して中臈を贏ち得たのは破格である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "保は四月に第二等に進み、七月に破格を以て第一等に進み、遂に十二月に全科の業を終えた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴族の御曹司たる彼としては、まさに破格の生活であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
