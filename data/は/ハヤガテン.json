[
  {
    "uuid": "d122601a-158a-521c-a798-d3d3bdd1c288",
    "entry": "早合点",
    "reading": {
      "primary": "はやがてん",
      "alternatives": [
        "はやがってん"
      ],
      "is_heteronym": false
    },
    "grammar": {
