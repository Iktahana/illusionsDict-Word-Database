        "examples": {
          "standard": [
            {
              "text": "総会では、多数の賛成票に対して、わずかな反対票が投じられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は自分の意見を貫き、ただ一人、反対票を投じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その法案は、わずか一票の反対票差で可決された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ちなみに、ハイフンは「積極的反対票」、つまり、「ひっでえ曲、ゲエー」ということ）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその後になって、段々とデビーの感情もなおり、また一方で、ウォーラストンの誤解も分明になって、結局ただ一つの反対票があったのみで、翌一八二四年の一月八日に名誉ある会員に当選した。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、多くの男達は嘆いており、州政府に反対票を投じました。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
