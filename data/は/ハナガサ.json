[
  {
    "uuid": "48199a0a-64b3-52cf-9c2a-236d4b2b7091",
    "entry": "花笠",
    "reading": {
      "primary": "はながさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
