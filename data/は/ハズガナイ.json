        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "勿論、当局が小作人組合に眼を光らさぬ筈がない。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが監獄へ入るやうなそんな悪いことをした筈がないんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやまつた／＼今のはみんな嘘何うして中村の令嬢千代子君とも云れる人がそんな御｜注文をなさらう筈がない良之助たしかに承はつて参つたものは。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の如く間歇的な情熱に興奮して、三日も四日も不眠不休で書き續けたり、さうかと思ふと一月も二月も遊んでしまひ、何もしないでゴロゴロして居たりする人間には、到底大きな仕事のできる筈がない。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、立って走れる筈がない。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "半時間以上待たねば人車が出ないと聞いて茶屋へ上り今度は大ぴらで一｜本命じて空腹へ刺身を少ばかり入れて見たが、惡酒なるが故のみならず元來八｜度以上の熱ある病人、甘味からう筈がない。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが監獄へ入るようなそんな悪いことをした筈がないんだ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百花楼のおなじ名前の作家がふたりいる筈がない。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったいま手をかけて殺した男が、まさか、これほど離れた場所に居れる筈がない。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな女と死ぬ筈がない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」僕はたべる筈がないんだがと仔牛は思ひながら一つぶ口でとりました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんが監獄へ入るやうなそんな惡いことをした筈がないんだ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ当りが付いたかいな」「そ……それが、まあだカイモク付いとらんたい」「付かん筈がないがなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろんラケットの持ち方なんぞ知っていよう筈がない。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『これは異なことを言はるゝものじや、あんな大な石が如何して袂へ入る筈がない』と老人に言はれて見ると、袖は輕く風に飄へり、手には一本の長い杖を持ばかり、小石一つ持て居ないのである。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し元来狭い家だから別に安全な隠くし場の有ろう筈がない。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「否、私は炭籠の炭ほか使ないよ」「そうら解った、私は去日からどうも炭の無くなりかたが変だ、如何炭屋が巧計をして底ばかし厚くするからってこうも急に無くなる筈がないと思っていたので御座いますよ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつたけれども、それと不景気としつかり結び附ける程の痛ましさは、まだ持つて居よう筈がない。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほど子供のうちより心の繋りを持つ富士が、自分が死んで、やみやみ後に安泰で残る筈がない。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだベーリングに着く筈がないし故障ができたんだらうか。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにもない筈がないと思つて居た疑は、全く消え去つたのではないのであるが、さてどうしていゝか解らなかつた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の生きて居ることと木の生きて居ることとに情の交感がある筈がない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな大きな、神秘な問題は彼に解決のつくべき筈がない。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼は自ら此の如くに憎悪され、嫌忌され、害物視される筈がないと思つて居た。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田原よりか、函嶺からか、それとも三島、日金の方か、たとい家は崖の上でも、十里は見通し得る筈がない。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ鳴いた、障子を明けたのでは、めじろが熟として居よう筈がない。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左もなければ自分に対して、あんな乱暴を働く筈がない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世の中に物の祟りなどのあろう筈がない。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人がその空想の中で画くような、ファンタスチックな夢の国は、現実の地球上にあるはずがない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことは解るはずがないのに、夢のような記憶では、それがそうであったことになっているのである。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
