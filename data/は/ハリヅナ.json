        "examples": {
          "standard": [
            {
              "text": "テントが風で飛ばされないよう、張り綱をしっかりと固定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高所作業では、安全確保のために張り綱が必須だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "台風が近づいているので、物干し竿の張り綱を確認しておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "或る者は、水中の張り綱を切りながし、或る者は、氷雨と飛んでくる矢を払い、また、舳に突っ立った弓手は、眼をふさいで、陸上の敵へ、射返して進んで行った。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
