  {
    "uuid": "5ec486c8-2a65-5204-b623-fb7c6055c383",
    "entry": "廃置",
    "reading": {
      "primary": "はいち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "abolishing and establishing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いままで、おれはいちども、この山でこんな音を聞いた事が無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれはいちめん黒い唐草のやうな模様の中に、おかしな十ばかりの字を印刷したものでだまって見てゐると何だかその中へ吸ひ込まれてしまふやうな気がするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また窓の外で足をふんばってそらを見上げて鷺を捕る支度をしてゐるのかと思って、急いでそっちを見ましたが、外はいちめんのうつくしい砂子と白いすゝきの波ばかり、あの鳥捕りの広いせなかも尖った帽子も見えませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　窓はいちめん蘭か何かの葉の形をした氷の結晶で飾られてゐました。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊たちはいちばんはじの列から馬をひいてだんだん川へ入りました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓の仕事の中ではいちばんいやだとみんなが云います。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぼくはいちばんはじめにあんずの王様のお城をたずねるよ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻も台所から顔を出して、「三人がよくならんでしゃがんでること、奈々ちゃんや、鶏がおもしろいかい、奈々ちゃんや」　三児はいちように振り返って母と笑いあうのである。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚倉はいち早く逃げる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はフランス語はいちばん不得手だがしかしごくゆっくり話してくれればだいたいの事だけはわかるつもりだと言ったら、それで結構だと言ってぽつぽつ話しだしたが、その話の内容は実に予想のほかのものであった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの部屋はいちばん風がよく吹き通すので、みんながここに集まっていた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何と云ってもいちばん多くの独創的な点をもっているのはいちばん小さい冬子の自由画であったが、その面白い点が一度認められ賞められるとそれがもう十八番になって、例えば富士山が出だすとそれがいかなる絵にでも必ず現われるのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目に「つかまった」ときの巡査は今日出会った三人の中ではいちばん柔和で愛嬌のある人であったが「いったいどこへ行くんだ」「東京です」「東京なら此方へ来ちゃダメだぞ。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和四年八月『東京朝日新聞』）　　　　　　二　地図をたどる　暑い汽車に乗って遠方へ出かけ、わざわざ不便で窮屈な間に合せの生活を求めに行くよりも、馴れた自分の家にゆっくり落着いて心とからだの安静を保つのが自分にはいちばん涼しい銷夏法である。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大臣の子のタルラはいちばんさきに立って鳥を見てはばあと両手をあげて追い栗鼠を見つけては高く叫んでおどしました。",
              "citation": {
                "source": "学者アラムハラドの見た着物",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは人を軽べつするかそうでなければ妬むことしかできないやつらはいちばん卑怯なものだと思う。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の旱害はいちばんよかった所でもこんな工合だったのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに前は小林区の現場監督もしていたので木のことではいちばん明るかった。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "タネリはまたおっかさんのことばを思い出してもう棄ててしまおうとしてあたりを見まわしましたら南の岬はいちめんうすい紫いろのやなぎらんの花でちょっと燃えているように見えその向うにはとど松の黒い緑がきれいに綴られて何とも云えず立派でした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれはいちめん黒い唐草のような模様の中に、おかしな十ばかりの字を印刷したものでだまって見ていると何だかその中へ吸い込まれてしまうような気がするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また窓の外で足をふんばってそらを見上げて鷺を捕る支度をしているのかと思って、急いでそっちを見ましたが、外はいちめんのうつくしい砂子と白いすすきの波ばかり、あの鳥捕りの広いせなかも尖った帽子も見えませんでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはいちはやく水中眼鏡と鉤針を用意する。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この棟にかゝる蔦はいち早くもみぢしよう。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の不幸な生涯を通じて、このときほど仕合せなことはいちどもなかった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼等はいちにちいつぱいトランプをいぢくつてばかりゐるわけでない。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やうやく、私はいちまいの紙幣をポケツトから拔きとり、それを十圓紙幣であるか五圓紙幣であるか確かめてから、女給に手渡すのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩をすぼめ、大股をつかつてカフヱを出てしまつて、學校の寮につくまで私はいちども振りかへらぬのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく、私はいちまいの紙幣をポケットから抜きとり、それを十円紙幣であるか五円紙幣であるか確かめてから、女給に手渡すのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩をすぼめ、大股をつかってカフェを出てしまって、学校の寮につくまで私はいちども振りかえらぬのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそれはいちめん黒い唐草のような模様の中に、おかしな十ばかりの字を印刷したもので、だまって見ているとなんだかその中へ吸い込まれてしまうような気がするのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
