        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はお返しが上げ度くも気がせいて、手近に有合せの日本から持って行ったものを、一つかみにしてあとを追いました――猫の毛でつくった日本の細筆三本、五色のつまみ細工の小箱一つ、桜の縫いのしてあるハンカチ一枚――あとで考えても、おかしな贈物でした。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金は麻のハンカチへ一包、二包。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな太郎の為に…………太郎の美くしいお嫁さんに着物を買ふため麻のハンカチ古い革手袋、昔はやつたお高祖づきんの布つ片へ、そつと貯めて置かうとするお金なんです。",
              "citation": {
                "source": "愚なる（?!）母の散文詩",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから祭服の複雑な襞の間を捜して、大きいハンカチイフを取り出して、恭しく鼻をかんだ。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が部屋に這入ると絹のハンカチに涙の地図をかいた女が私の姿を見ると罵るように、妾は日本が憎い、妾の恋しい人を連れ出すのはこのインボスタ奴！",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は昨夜からの涙の滲んだ絹のハンカチを香港の朝の風景に飜えして、　――妾達は陳独秀の健康を祈るのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙが汚れたハンカチを振っている。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すゞは、ハンカチを裂いて、うたれた紫色の俊の太股をしばった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はハンカチで水洟を押えながら、無言で歩いて、さすがに浮かぬ心地でした。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして……おお……私たちの方に向って、白いハンカチを振って下さるのが、ここからよくわかります。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の手はしょっちゅう洋袴のポケットへ入れていましたが、胸のハンカチを取出すとき、案外白い大きい手の無名指にエンゲージリングの黄ろい細金がきらりと光ったのを覚えています。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言つて、紅のハンカチーフに笑顏を蔽ふた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "櫻木大佐等は一齊にハンカチーフを振つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をする」と呶鳴り付けると、「日が射して困る」と、ハンカチーフなんかで鼻の頭を撫でている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、やや息せいて、ハンカチで汗を拭って言った。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松王が身がわりの秘密を打明ける件になると、婦人の観客のうちにはハンカチーフを眼にあてているのが沢山ありました。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はしきりにハンカチを使った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は袂の端を掴み、新派の女優めいた恰好で、ハンカチを振った。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "船に乗るかも知れない……」　父はそう返事しながら、胸のかくしから疎い紫の格子のある派手なハンカチと一緒に大きな鼈甲縁の眼鏡をとり出すと、それをそのハンカチでちよっと拭いて悪くもない眼へ掛けた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "コティの香水の匂がハンカチからむせ返る程ふりまかれた。",
              "citation": {
                "source": "父を失う話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "お年よりの王さまは、立ちあがって、白いハンカチで、目の涙をふきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭だけは、水でよくあらってから、絹のハンカチにつつんで、宿屋に持って帰りました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、旅の仲間は、ヨハンネスにハンカチのつつみをわたしながら、「お姫さまが、『あたしは、なにを考えていますか？",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、ヨハンネスは、ハンカチのつつみをほどきました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "口にキスをしていただいたり、ししゅうをしたハンカチで、足をふいていただいたりしたものさ。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どう致しまして……」　と私もやっとの思いで初めて口を利くと慌てて袂からハンカチを出して顔を拭いた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然かすかな戦慄が未亡人の肩を伝わったと思うと、未亡人はいつの間にか手にしていた絹のハンカチで眼を押えた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま未亡人は二分か三分の間ヒソヒソと咽び泣いたが、やがてハンカチの下から乱れた眉と睫を見せた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
