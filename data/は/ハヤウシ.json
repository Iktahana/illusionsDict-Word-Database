        "examples": {
          "standard": [
            {
              "text": "早撃ちガンマンは、あっという間に敵を倒した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は銃の早撃ちが得意で、西部劇のヒーローのようだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「早撃ち勝負だ！」という掛け声とともに、二人は銃を構えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "もはやうしろ髪ひかるる思いのものは西国には何ものも無かった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、電気ボタンをおすと、大きな機械が一時に動き出すのとおなじように――「ばんざあいっ」　島に残った十一人が、のどもさけろとさけぶのも、はやうしろに、「えんさ、ほうさっ」　櫓と二つの櫂をしわらせて、うでっぷしのつづくかぎり、沖合はるかの帆船めがけて、ただ漕ぎに漕いだ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
