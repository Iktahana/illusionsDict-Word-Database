        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　私たちは、配給所の前を通り過ぎた。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この産院は、これまでにある市内の児童相談所のうち五ヵ所に属している牛乳無料配給所とも共同して働く。",
              "citation": {
                "source": "「市の無料産院」と「身の上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次五ヵ年計画のすんだ今では全農戸の七割が集団農場化し、耕作機械、刈入機械の配給所は三千百ヵ所にまで殖えた。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働者の合理的配給所とならなければならない。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳配給所との連絡もある。",
              "citation": {
                "source": "モスクワ日記から",
                "author": "――新しい社会の母――",
                "note": "青空文庫"
              }
            },
            {
              "text": "配給所まで一里あって、そこを二斗の米を背負って来ることは不可能である。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家は酒の配給所をもかねているから、集る炉の中の火の色も、燃え方が参右衛門の家のとは違っている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "配給所へ着いてもまだ肝心の豆が着いていない。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いやだったなああの時は……五キロもあるところへ山本先生とみんなでね、配給所へ米をもらいに行って、何度もからっぽの車をひいてかえる時、山本先生泣きながら歩いていらっしたよ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食後、細君に教はつて、近所の酒の配給所に電話を借りに行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気コンロが自由につかへなくなつてゐたので、ゆき子は、荷物を置いて、近所の炭の配給所に、高い炭を分けて貰ひに行つた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "米の配給所と運送を兼ねてゐる旅館は、旅館らしくないかまへで、陰気な店である。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉も、カラーなしの縞シャツの上から黒い上衣をひっかけて、片手にヤカンをぶらさげ、群集にまじって熱湯配給所へ出かけた。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱湯配給所の小舎のわき、棚の前へ土地の物売りが並んでいる。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に又そう云う学校を兼ねた食糧や衣服の配給所でもない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に又さう云ふ学校を兼ねた食糧や衣服の配給所でもない。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "五人の付添夫は順番に当直を務め、非番のものは配給所へ飯その他を取りに出かけたり、病人――附添夫たちはベッドに就いてゐる人々を病人と呼んでゐる――の頼みによつて売店へ買物に出かけたり、色んなこまごました仕事を各自担当してゐる。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "配給所へ味噌汁をとりに出かける。",
              "citation": {
                "source": "続癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "不自由舎には一室一名づつの附添夫がついてゐて、配給所（これは院の中央にあつて飯やおかずはここで配給される。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度三度の食事の配給所へ通ふのである。",
              "citation": {
                "source": "盂蘭盆",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "外食者用食堂とか、銀行とか、配給所が、疎開延期で残っている。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉も同じく、配給所の前に立並ぶ女達の中には少くとも五、六人は似た顔立を見るような奥さんである。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉も同じく、配給所の前に立並ぶ女達の中には少くとも五六人は似た顏立を見るやうな奧さんである。",
              "citation": {
                "source": "或夜",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母さんが配給所の前に立たされている時間のむだと脚の疲れだけでもなくしてあげたいものだね。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在百貨店が配達網を八方に布き、また遠方には配給所を設けて、専らその合理化につとめていても、なおその費用の莫大なのに当惑しているときくが、まことにさようであろうと案ぜられる。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "部落の非常時用として木炭数十俵、薪が何百束か、配給所である石田の物置に保管されていた。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "配給所へゆくのと同じ心でそこを通る人はなかった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――配給所の方も昨日も今日も私聞きに行ったけど、いつになったら入荷するか、けんとうが附かないと言うし。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこが配給所になったらいやだナと思っていたら、きのうかえりに通ったら大きい白い紙に謹告として、発展的閉店の余儀なきに至りとありました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの組の米、味噌、マッチ類の配給所もやけてしまいました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
