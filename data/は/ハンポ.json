          "literary": [
            {
              "text": "反哺という言葉の味をしみじみと知る。",
              "citation": {
                "source": "母の死",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳の根底に横たわるべき源泉なくして善といい悪と呼ぶがゆえに反哺の孝と三枝の礼は人生の第一義だと言われる。",
              "citation": {
                "source": "霊的本能主義",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
