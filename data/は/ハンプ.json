  {
    "uuid": "89c1e93b-0a66-5d10-8ed5-d4b793e08db1",
    "entry": "ハンプ",
    "reading": {
      "primary": "ハンプ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hump",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かつてロンドン滞在中、某氏とハンプトンコートの離宮を拝観に行った事がある。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいらハンプシャイアのベドウスさんとこへつっ走ろうかと思うんだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時私は、フォーデングブリッジと云うのはハンプシャイアにあることを思い出した。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた、このベドウス氏と云う、例の船乗りが、おそらくはユスルのであろうが、訪ねて行くと云っていた人も、またハンプシャイアに住んでいると云ってたらしいことを思い出した。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハンプシアのベドウズさんとこへ突っ込むわ。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、僕はフォーディンブリッジがハンプシアにあると思い出した。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、このベドウズという人、おそらく例の船乗りが訪ねていって強請るのであろうが、その人もハンプシアに住んでいると気づいた。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "地所は、北はバークシア、西はハンプシアまで広がっておりました。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は帰りにハンプトン・コートへも案内されました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンプトン・コートには楡の立派な立木もありますが、到底この栗の林には及びませんでした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、近所の理髪店へ行って、きのうはキウ・ガーデンからハンプトン・コートを廻って来たという話をすると、亭主はあの立派なチェストナットを見て来たかと云いました。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンプトン・コートには楡の立派な木もありますが、到底この栗の林には及びませんでした。",
              "citation": {
                "source": "栗の花",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンシルバニア地方を代表したフイラデルフイア大学はタフトを、ニユーハンプシヤイア地方からのハーバード大学はマツキンレイを、そしてメリーランド地方としてはワシントン大学がルーズベルトを支持した。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は西を探し南を探しハンプステッドの北まで探してついに恰好の家を探し出す事が出来ず、最後にチェイン・ローへ来てこの家を見てもまだすぐに取きめるほどの勇気はなかったのである。",
              "citation": {
                "source": "カーライル博物館",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらが、ケントやオークランドあるいはニューハンプシャーといった所に置かれたとしても、年代的には少しも違和感はないであろう。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その買手の住所姓名は、判っているか」「名前は――ちょっと忘れましたが、家は何でも、羅府ニュウ・ハンプシャア街八二六番地とか言っていたようですよ」　これに勇躍したライアン刑事は、同僚トレス・マックリィディの二人と緒に、早速其のニュウ・ハンプシャア街へ駈け付ける。",
              "citation": {
                "source": "アリゾナの女虎",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "大岡越前かなんか粋な旦那がいて、原告のポケットの中へそッとチャタレイ夫人でも忍ばせてやるのがオチであろうが、すると忽ちどこからともなく検事が現れて、ワイセツ文書ハンプの罪というカドによって越前守がからめとられてしまう。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その二　大岡越前守",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名なハンプデンの墓やこの憂国の士が倒れた戦場も訪れた。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ英国の革命を激成したるものいずくんぞひとりミルトン、ハンプデン、ピム輩のみならんや。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンプデンにあらずしてミルトンにあり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔はハンプデン、クロンウエル相率いて、チャールス王の圧制を逃れ、米国に奔らんとし、既に船に乗じてテームス河に在り。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "６番地で5人が死亡しているがそこの主人がハンプステッド・ヒースに出発した１日後のことであった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "大都会やその近郊なら、そう驚きもしないが、例えばニューハンプシアの北の果て近い僻地までがそうである。",
              "citation": {
                "source": "アメリカ種の落語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに　ナトキンは　まえを　かけまわって　おおごえで　――「ハンプティダンプティ　とこにふす　かけぶとんが　こんもりと　いしゃが４０　だいくが４０　それでもなおらぬ　ハンプティダンプティ！",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分そういう方針の下に、すぐハンプシャー州の飛行場に中規模の装置を作ったのである。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやに寒い或る冬の真夜中、閣僚、気象学者、科学者、陸軍並びに空軍の将兵達は、温かい床から呼び起され、冷たい霧をもとめて飛行場へ急行した」「この日の払暁、石油による焼払装置で、約二百平方ヤード高さ八十フィートの地域にあったハンプシャーの視界五十ヤードの濃霧が消散したのだ」と英紙は報じている。",
              "citation": {
                "source": "霧を消す話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
