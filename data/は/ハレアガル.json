    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to swell up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早速右の肩が瘤の様に腫れ上がる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八尾という数は自慢にはならないが、七寸五分、八寸という鉄砲ギスばかりで、それに小ダイ、イイダコと色とりどりでおもしろく、なかに、刺されるとはれあがるほど猛毒を持った「一寸」という小魚もあったりして、朝の話の散歩には大受けだった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、もう一度わたし、あなたの下唇を接吻しますわ、あなたの下唇ははれたようになってますけど、もっともっとはれあがるほど接吻してあげてよ。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし天性の泣き虫にかぎって、泣きだすのもはやいが泣きやむのもむぞうさに、ケロリと天気がはれあがる。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
