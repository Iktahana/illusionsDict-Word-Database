        "examples": {
          "standard": [
            {
              "text": "彼女はハワイの文化を深く愛し、ハワイ人としての誇りを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古代からハワイ諸島に暮らしてきた人々をハワイ人と呼ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの観光客向けのショーでは、ハワイ人が伝統的なダンスを披露していたよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "古代のハワイ人たちは、このスロープを下から頂上に向けて、作っていったという。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この島をハワイ人たちの手にとり戻そうという運動が、プロテクト・カフーラウェ・オハナだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
