        "examples": {
          "standard": [
            {
              "text": "彼のプレゼンは、話が歯切れが悪くて、一番伝えたいポイントがぼやけてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "もっとはっきりと、歯切れ良く話してくれないと、君の言っていることが理解できないよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "昨日の演説は、原稿を棒読みするだけで、言葉に歯切れが悪く、聴衆は退屈そうだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "どうも、あの関守さんの返答ぶりが歯切れが悪いと思い返さずにはおられません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
