        "examples": {
          "standard": [
            {
              "text": "昔は歯磨き粉が主流だったが、今は歯磨きチューブを使うことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅行には使い切りの小さな歯磨き粉を持っていくと便利だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この歯磨き粉は、ミントの香りが強くてスッキリする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "歯ブラシを出し、歯磨き粉をつけると、高志が、こっち見て笑え、という。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　野蛮人には、歯磨き粉を呑ませても、胃病がなおるということだ。",
              "citation": {
                "source": "味覚馬鹿",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの草を焼いて灰と成し、塩を交えてハコベジオと称する歯磨き粉を製する。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
