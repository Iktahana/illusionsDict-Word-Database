[
  {
    "uuid": "e927ce8b-dc38-5e79-ac94-14f4cf8be17d",
    "entry": "反対意見",
    "reading": {
      "primary": "はんたいいけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
