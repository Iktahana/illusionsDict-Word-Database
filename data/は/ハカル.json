[
  {
    "uuid": "35101745-c6f0-5338-888a-fbcdaabf7189",
    "entry": "諮る",
    "reading": {
      "primary": "はかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
