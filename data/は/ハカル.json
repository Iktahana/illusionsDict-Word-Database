  {
    "uuid": "c726dace-73fc-568e-90ff-0cc719b61558",
    "entry": "図る",
    "reading": {
      "primary": "はかる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to plan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もう少し心とからだの安息を与えて、思いのままに彼の欲する仕事に没頭させた方が、かえって本当にこの稀有な偉人を尊重する所以でもあり、同時に世界人類の真の利益を図る所以にもなりはしまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたとえば、土を刃に仕立てて水を斬ろうと図るようなものじゃ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "疎隔し、※離す、而して帝の為に密に図るものあり、諸王の為に私に謀るものあり、況んや藩王を以て天子たらんとするものあり、王を以て皇となさんとするものあるに於てをや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝の為に密に図る者をば誰となす。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "宜しく先ず周を取り、燕の手足を剪り、而して後燕図るべしと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "信つぶさに朝廷の燕を図るの状を告ぐ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し元帝兵を挙げて賊を誅し京に入らんことを図る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小を棄てゝ救はざる者は、大を図るの心有る也。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に己の害を知りて、而して彼の利を図る者は勝つ。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秦の哀公が会を設けて、覇を図る処があつて、斉国の夜明珠、魯国の雌雄剣、晋国の水晶簾などとならぶ中に、子胥先生、我楚国｜以て宝とするなし、唯善を以て宝とすとタンカを切つて、大気焔を吐く所がある。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄に石鹸を塗りつけるほどに、細心に安楽の往生を図ることについては、私も至極賛成であって、甥の医学生の言に依っても、縊死は、この五年間の日本に於いて八十七パアセント大丈夫であって、しかもそのうえ、ほとんど無苦痛なそうではないか。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼の生活がかさむにつれ、段々自分極めで危険率の多い投資に関係し増収を図るようになった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年七月廿八日神武天皇の御創業　皇孫｜彦火瓊瓊杵尊が、天照大神の神勅を奉じ、日向の高千穂の※触ノ峰に降臨されてから御三代の間は、九州の南方に在つて、国土を経営し、民力の涵養を図ると共に、周囲の者どもを帰服せしめ、之を化育することに依つて、いよ／＼興隆の基礎を築かれたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "尊皇思想の勃興　家康、秀忠、家光と、江戸幕府三代の将軍は、朝幕問題、諸大名問題、切支丹問題、外国との通商問題、その他法制、経済、教化などに腐心してゐたが、彼等は幕府の政権の永続化を図る以外、何等高遠の理想を持つてゐなかつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "日蔭者自殺を図るなどと同情のある書き方だった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知的財産戦略の推進」を国策としている我が国は、著作権保護のあり方について国際間の調和を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が国のコンテンツ創造サイクルの活性化と国際競争力の向上を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知的財産戦略の推進」を国策とし、コンテンツビジネスの積極的な海外展開を進めようとしている我が国は、保護期間をはじめとする著作権保護のあり方について、国際間の調和を図るよう努力すべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、我が国は、平和条約に基づいて定められた戦時加算により、連合国民の著作権については、すでに「死後50年」を越えて保護している実態があることから、この問題を整理しつつ保護期間の延長を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "保護期間を延長し、著作物からの収益性や資金調達力を高め、新たな創作活動に投じる資金を増大させることにより、コンテンツ創造サイクルの活性化と国際競争力の向上を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "でＩＢＭとの連合とくるわけだろうが、ここには生き残りを図るメーカーの算盤勘定はあっても、より良い世界を目指す理想の旗は存在しない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもが分散コンピューティングに対応して生まれたＵＮＩＸに、ネットワーク体系の Open Network Computing を加え、Open Windows でマック化を図る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ惟らく、儂は固より無智無識なり、しかるに今回の行は、実に大任にして、内は政府の改良を図るの手段に当り、外は以て外交政略に関し、身命を抛擲するの栄を受く、ああ何ぞ万死を惜しまんやと、決意する所あり。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "元気を出して、再挙を図るさ。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このため人はここに於いて身悶えして已まず、各自の持つ知力の有る限りを尽くして血路を開こうと図る。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは遠距離から往来する腰弁や労働者の便利を図るために出来たものらしく、朝は六時前後から三時間内外、午後は三時頃から四時間位、すべての電車が急行時間という札をかける。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人は多言を須ひずして知る、尤も多く並等を教ふるもの、尤も多く最多数の幸福を図るもの、尤も多くヒユーマニチーを発育するもの、尤も多く人間の運命を示すもの、即ち、此目的に適合する事尤も多き者なるを。",
              "citation": {
                "source": "国民と思想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "予約注文は早い方がいい、わしのところへ持込んでくれりゃ出来るだけの便宜と利益を図るよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその募集文の一節に、“――この際最も必要とするところは、如何なる方法により、かの怪人たちとわれわれとが意志の疎通を図ることが出来るかという問題にある。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はかるく狼狽の様子で、「くらべたりするもんじゃないよ」と言って笑ったが、すぐにけわしく眉をひそめ、「いや、ものごとはなんでも比較してはいけないんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
