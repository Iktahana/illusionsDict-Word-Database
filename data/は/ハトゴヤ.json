          "literary": [
            {
              "text": "「さう言へばあの釘はまだ鳩小屋の中に這入つてるだらうかね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳩小屋をこしらへて、たくさん鳩をふやしてみないかね。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち、わしが、鳩小屋をこしらへて上げるよ。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡様の屋根には、鳩小屋がたくさん出来ました。",
              "citation": {
                "source": "ふしぎな池",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガイ牧師が古い鳩小屋からメアリに挨拶した。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪が降ると、飢餓や災害が起こるって」　メアリがはしごを登って古い鳩小屋に入ると、今にも倒れそうな高所だが、高価なオーク材彫刻がたくさんあった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると１羽の鳩が鳩小屋に着地して、羽根を毛繕いした。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
