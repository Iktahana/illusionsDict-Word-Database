        "examples": {
          "standard": [
            {
              "text": "庭の植物に葉蜂の幼虫がついていないか、毎日確認している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "葉蜂の被害に悩まされており、農家は対策に追われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "葉蜂はハチの仲間だが、針を持たない種類が多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だから、知らずにしたことだから、米を踏みにじつても和尚さんにはばちがあたらなかつたのでせう。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、親の心子知らず、どこへ姿をかくしたのやら、弥七郎めはばち当たりでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "大薩の五條橋はばちのさえをおどろき呂昇は身振のひどくなったのと声のすまないのでああ云う程の芸人の末路は暗いものに思われた。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の意見にそむいてはばちがあたる！",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
