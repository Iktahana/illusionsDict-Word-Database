        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "軽率な言動は、後になって思わぬはねっ返りを生むことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "環境破壊のはねっ返りは、すでに様々な形で現れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の過去の行いは、今になってはねっ返りとして彼を苦しめている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
