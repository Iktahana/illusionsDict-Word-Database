        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの頃の彼女は、スカートをはくのを嫌がるはねっ返りだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近所のはねっ返りの少年は、いつも木登りばかりしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のはねっ返りな性格が、かえって周りの人から愛されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "振り返ると、無口な源助も、その配偶のお冬も、はねっ返りのお徳も、妙に気色ばんで、平次の後ろへ詰め寄っているではありませんか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "rebounding",
        "register": "standard",
