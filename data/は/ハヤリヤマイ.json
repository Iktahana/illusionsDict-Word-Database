          "literary": [
            {
              "text": "しかし、考へてみると、これが若し性のよくない流行り病ひだとしたらですよ。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくべつな用談ともみえず、唯、『いや、飼ってもみぬ手輩は、岡焼き半分に、鶉狂だの、流行り病の一つだのと、ろくな陰口は申しませんが、やってみれば、もうそれは……』と、この男もまた言うことは、鶉の知識やら自慢やらで、目も鼻もない方なのだった。",
              "citation": {
                "source": "美しい日本の歴史",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふた股者の座主を追っても、吉水の禅門が、相変らず、他宗を誹り、流行り病の念仏をふり撒いて、社会を害することは、すこしも変りがあるまい。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行り病のように、夜になると、辻々に、音頭が聞える。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
