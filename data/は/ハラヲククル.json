        "examples": {
          "standard": [
            {
              "text": "彼女はどんな困難が待ち受けていようとも、「腹をくくる」覚悟で挑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "もう後には引けない。「腹をくくる」しかないんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "覚悟を決めて「腹をくくる」ことで、意外な力が湧いてくることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だがあらためて拡張スロットを表にさらし、インターフェイスの技術情報を外部に公開するのだと腹をくくるために、小澤は大きく肩で息をつかざるをえなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
