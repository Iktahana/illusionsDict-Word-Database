[
  {
    "uuid": "d844df99-f5f7-50e5-a6b1-4297a4aa6af0",
    "entry": "拝辞",
    "reading": {
      "primary": "はいじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
