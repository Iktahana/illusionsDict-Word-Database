        "examples": {
          "standard": [
            {
              "text": "軍事政権下で、多くの反体制派が国外への亡命を余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は自国で反体制派の活動に参加し、投獄された経験がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その国の反体制派は、民主化を求めて国際社会に支援を呼びかけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "伝説的な長距離電話ただがけ装置、ブルーボックスの開発で知られる反体制派技術者、キャプテンクランチことジョン・ドレイパーは、アップル※用にワードプロセッサーを書き、イージーライダーをもじってイージーライターと名付けて好評を博していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
