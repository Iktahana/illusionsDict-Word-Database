[
  {
    "uuid": "52e1b1aa-64a8-56c6-bbdb-75343e83eebc",
    "entry": "廃位",
    "reading": {
      "primary": "はいい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
