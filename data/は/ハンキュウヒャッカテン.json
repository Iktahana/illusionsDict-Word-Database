          "literary": [
            {
              "text": "阪急百貨店の地下室の入口の前まで降りて行った時、新吉はおやっと眼を瞠った。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし小林一三さんの阪急百貨店は、一銭のコンミッションも要りません。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "阪急百貨店へ入り、ネクタイと、郵便物入れのいゝのがあったので買ひ、家へ送る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の終りに、地下のスエヒロでビフカツとライスカレー食って、阪急百貨店へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "阪急百貨店へ寄り、腕時計の輪と久保田万太郎の「釣堀にて」と麻雀のノート買ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
