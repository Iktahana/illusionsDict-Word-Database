        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八丁味噌の古い看板なども見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁味噌に充分調味を加え、狸肉を賽の目に切って泳がせたのであった。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回の八丁味噌のたぬき汁も、かつての猿唇に味品が相通じていて、まことに快興を催したのだ。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁味噌に充分調味料を加へ、狸肉を賽の目に切つて泳がせたのであつた。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今回の八丁味噌のたぬき汁も、曾ての猿唇に味品が相通じてゐて、まことに快興を催したのだ。",
              "citation": {
                "source": "たぬき汁",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "米は肥後の上白、味噌は岡崎の八丁味噌、出しは北国の昆布、椀は一合五勺はたっぷり入る大ものだが、選手として自らを任じて集まった勇猛の人々であるから、これしきの風景では胆を冷やすような仁は一人もいない。",
              "citation": {
                "source": "食指談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊川稲荷という迷信の本場と岡崎の八丁味噌が多少知れているぐらいのもんです」　と村田さんは畳の上で浜松の案内を終って最早三州へ入っていた。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡崎の八丁味噌も、僕は好きだ。",
              "citation": {
                "source": "駄パンその他",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、宿へ着いたら、八丁味噌の汁を、ふんだんに、と、たのむ。",
              "citation": {
                "source": "八の字づくし",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食には、その八丁味噌汁の三杯汁だ。",
              "citation": {
                "source": "八の字づくし",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時起き、なか川旅館の朝めし、岡崎の八丁味噌の汁、どんよりドス黒い。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
