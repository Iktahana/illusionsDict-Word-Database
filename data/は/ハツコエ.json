    "definitions": [
      {
        "index": 1,
        "gloss": "first sound of the year for an animal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
