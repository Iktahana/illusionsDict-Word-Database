    "definitions": [
      {
        "index": 1,
        "gloss": "naked man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "朗らかや、すがし葉の大広葉の蕗の葉の下つ人、コロポックル、　　呼べよ、げに、神はあり、オイナ・カムイ、　　さながらに立つ影の素の裸男。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男、窓の内にて、之を聽いて、獨り樂しみ居りしに、『今日は』とて、十口坊來たる。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "教へ給へ』といふに、裸男得意になり、『花といへば櫻、花見といへば、櫻を見にゆくことをいふ。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から行けば、時も亦好きに非ずや』と、裸男知つた風の事云へば、なるほどと山神感服して、共に出で立つ。",
              "citation": {
                "source": "久地の梅林",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍らしや、裸男が末斑をけがし居る好文會の幹事より、吉野村探梅の事を報じ來たる。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "明き盲目の裸男も、相伴して立どまる。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "斐己大人のは一合入、槇園君のは二合入、裸男のは六合入、一行の醉を買ふには不足なし。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪葉書を送るとて、裸男駄句りて曰く、來ぬ友を惜む梅見の日和かな　山を下れば、老樹最も繁き處に、掛茶屋あり。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は此處にて飮むべかりき』と、裸男覺えず口走れば、『然り／＼』と、槇園君相槌打つ。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち去らむとするに臨み、裸男幹事の槇園君に向ひ、『會費を』と云へば、槇園君嗔りて、『花の下に金錢を計算する沒風流あらむや』といふに、裸男閉口して頭を掻く。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男、肉を好まずして葱を好む。",
              "citation": {
                "source": "梅の吉野村",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "七百年後の今日、裸男この路を經過するに、白浪依然として沖の小島に寄る。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆山の浴舍に投ずれば、沖の小島近く窓に當りて、裸男を招かむとするに似たり。",
              "citation": {
                "source": "沖の小島",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "又裸男が夜光命と共に、梅を江東に探りし時も、山神が附纏ひたれば、矢張壬生忠岑の子となりたりき。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "薩摩守だけの罪は無けれども、『酒なくて何の己れが櫻かな』と云へり、いつも／＼山神に附纏はれては閉口と、裸男一人にて、越ヶ谷方面の梅を探らむとすれば、山神同行を乞ふ。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今直ぐに咏み申さむ』とて、愛でましし梅の花をば探る身に　　歌よましめよ菅原の神　裸男承諾して、午後より共に家を出で、大塚仲町より電車に乘り、廐橋を渡りて、外手町に下り、押上町行きの電車に乘換へむとせしが、雨大いに至る。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さりながら、多年風雨に鍛へし旅行家の身、我れ一人ならば、如何に老いたりとて、このやうな風雨に弱ることは無けれども、鼻の下の人竝より長きが、裸男の一大缺點、唯※一つしか無き晴衣を著たる山神を氣の毒に思ひての仕業に外ならずと、分疏するだけが野暮にて、馬鹿の上塗なるべし。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の鼻下長の裸男、山神をいたはりて、『この寒きに、御苦勞千萬なり』と云へば、『聞かせ給へ』とて、雨まじり身を切るごとき寒風も　　物の數かは二人し行けば『宇田川』と染め拔ける印半纏著たる男、後よりすた／＼歩み來り、『梅園に行かるゝか』と問ふ。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹の廻り一丈にて、十善梅より稍※小なる四恩梅は、今上陛下御即位大典の記念に植ゑたるものなりと記せるに、裸男一首うなり出して曰く、幾千代の雪を凌ぎて梅の花　　我大君の御世にあらはる　車を返して久伊豆神社に詣づ。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男、山神に謎をかけて曰く、『吝嗇坊の遊山とかけて何と解く』『分りません』、『斬髮屋』『心は』『きりつむ』。",
              "citation": {
                "source": "越ヶ谷の半日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男、二人に向ひ、『鹽原には七不思議あり。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男更に語を改め、『この行にも七不思議が出來さう也。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨又あれは大山公の別莊、又あれは松方侯の別莊』と、裸男知つた振して、のべつに饒舌る。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男相變らず、知つた振して説明す。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男二人に向ひ、『我等が宿屋に優待せらるゝといふことは、不思議に非ずや。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男二人に向ひ、『十口坊が酒飮まぬといふことは、これまでに例の無きこと也。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男口吟して曰く、名にし負ふ箒川べにゆあみして　　こゝろの塵も拂はれにけり『箒の縁語にて、塵を拂ふと云ひたるは、氣が利きたるやうにて幼穉なり』と、夜光命冷かす。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男さらばとて、醉倚欄干意氣豪。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸男、さらば又と氣張りしが、一句も浮かばずして、そのまゝ眠る。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
