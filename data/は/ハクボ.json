        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春の暮家路に遠き人ばかり　薄暮は迫り、春の日は花に暮れようとするけれども、行路の人は三々五々、各自に何かのロマンチックな悩みを抱いて、家路に帰ろうともしないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良という侘しい古都に、薄暗い古道具屋の並んだ場末を考えるだけで寂しいのに、秋の薄暮の灯ともし頃、宵の燈火の黄色い光をイメージすると、一層情趣が侘しくなり、心の古い故郷に思慕する、或る種の切ないノスタルジアを感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さびしき憂愁に閉されつつかくも靜かなる薄暮の空に汝は熱情を思ひ盡せり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎なり虎なり午後なり廣告風船は高く揚りて薄暮に迫る都會の空高層建築の上に遠く坐りて汝は旗の如くに飢ゑたるかな。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時薄暮に迫り、分列の式既に終りて、觀衆は皆散りたれども、灰色の悲しき軍艦等、尚錨をおろして海上にあり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "省線の四谷驛で降りて、薄暮、叔母の家を搜し當て、殆ど二十年ぶりで叔母と對面することが出來ました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小雨の降る薄暮の街に灯がともり始め、白い水面を一群のかもめが巴を描いて飛び交わしている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば薄暮の水楼の欄干に男女が相対して話している。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日の薄暮ごろに奈々子の身には不測の禍があった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして生きながら焼かれる人々の叫喚の声が念仏や題目の声に和してこの世の地獄を現わしつつある間に、山の手では烏瓜の花が薄暮の垣根に咲き揃っていつもの蛾の群はいつものように忙わしく蜜をせせっているのであった。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しい月夜かなしい遠景かなしい薄暮になれば、労働者にて東京市中が満員なり、それらの憔悴した帽子のかげが、市街中いちめんにひろがり、あつちの市区でも、こつちの市区でも、堅い地面を掘つくりかへす、掘り出して見るならば、煤ぐろい嗅煙草の銀紙だ。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なやましい薄暮のかげで、しなびきつた心臓がしやべるを光らしてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「薄暮」「壁」の陰氣な風景。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるときは岬の港町へゆく自動車に乗って、わざと薄暮の峠へ私自身を遺棄された。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして薄暮の山の中へ下りてしまったのである。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮に包まれているその姿は、今エーテルのように風景に拡がってゆく虚無に対しては、何の力でもないように眺められた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮の空に、時どき、数里離れた市で花火をあげるのが見えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年若く面清き海軍の少尉候補生は、薄暮暗碧を湛えたる淵に臨みて粛然とせり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日も君に世話に成つたと言ふから、知つてるだらうが、薄暮合、あの時間に旅館へ着いたのだから、あとは最う湯に入つて寝るばかりさ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルムホルツは薄暮に眼前を横ぎった羽虫を見て遠くの空をかける大鵬と思い誤ったという経験をしるしており、また幼時遠方の寺院の塔の回廊に働いている職人を見たときに、あの人形を取ってくれと言っておかあさんにせがんだことがあると言っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮、阿佐ヶ谷駅に降りて、その友人と一緒に阿佐ヶ谷の街を歩き、私は、たまらない気持であった。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暮の縁側の端居に、たまたま眼前を過ぎる一匹の蚊が、大空を快翔する大鵬と誤認されると同様な錯覚がはたらくのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊柱の声の様に聞こえて来るケルソン市の薄暮のささやきと、大運搬船を引く小蒸汽の刻をきざむ様な響とが、私の胸の落ちつかないせわしい心地としっくり調子を合わせた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しいことも、あつたのですが、回想されては、すべてがかなしい鉄製の、軋音さながらなべては夕暮迫るけはひに幼年も、老年も、青年も壮年も、共々に余りに可憐な声をばあげて、薄暮の中で舞ふ蛾の下ではかなくも可憐な顎をしてゐるのです。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "只今、狼に食われたという女の検察をしたがね、……薄暮です。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）……薄暮合には、よけい沢山飛びますの。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘆のまわりに、円く拡がり、大洋の潮を取って、穂先に滝津瀬、水筋の高くなり行く川面から灌ぎ込むのが、一揉み揉んで、どうと落ちる……一方口のはけ路なれば、橋の下は颯々と瀬になって、畦に突き当たって渦を巻くと、其処の蘆は、裏を乱して、ぐるぐると舞うに連れて、穂綿が、はらはらと薄暮あいを蒼く飛んだ。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "みると薄暮の中庭で、女房と店の主人が並んで立って、今しも女房が主人に教えられ、最初の一発を的に向ってぶっ放すところであった。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて私の生活は官能的にも頽廢の薄暮をかなしむであらう。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）青山、葉山、羽黒の権現さんあとさき言わずに、中はくぼんだ、おかまの神さん唄いつつ、廻りつつ、繰り返す。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
