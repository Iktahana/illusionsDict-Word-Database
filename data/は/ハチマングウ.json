    "definitions": [
      {
        "index": 1,
        "gloss": "shrine dedicated to Hachiman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "金刀比羅宮、男山八幡宮、天照皇大神宮、不動明王、妙法蓮華経、水天宮。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は八幡宮の石段を数えて登り、一、二、三と進んで七つと止まり、七つだよと言い聞かして、さて今の石段はいくつだとききますと、大きな声で十と答える始末です。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸数五百に足らぬ一筋町の東の外れに石橋あり、それを渡れば商家でもなく百姓家でもない藁葺き屋根の左右｜両側に建ち並ぶこと一丁ばかり、そこに八幡宮ありて、その鳥居の前からが片側町、三角餅の茶店はこの外れにあるなり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそから毎晩のようにこの置座に集まり来る者二、三人はあり、その一人は八幡宮神主の忰一人は吉次とて油の小売り小まめにかせぎ親もなく女房もない気楽者その他にもちょいちょい顔を出す者あれどまずこの二人を常連と見て可なるべし。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その言い草がおもしろいじゃアないか、こういうんだ、今度｜代々木の八幡宮が改築になったからそれへ奉納したいというんだ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂道の途中に八幡宮の境内と向い合って名物のどじょう店がある。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の上の交叉点からの電車の軋る音が前の八幡宮の境内の木立のざわめく音と、風の工合で混りながら耳元へ掴んで投げつけられるようにも、また、遠くで盲人が呟いているようにも聞えたりした。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと見通しの、油堀から入堀の水に、横に渡した小橋で、それと丁字形に、眞向うへ、雨を柳の絲状に受けて、縱に弓形に反つたのは、即ち、もとの渡船場に替へた、八幡宮、不動堂へ參る橋であつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大汐見橋を、八幡宮から向つて左へ、だら／＼と下りた一廓であつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　富岡八幡宮　成田山不動明王　境内は、土を織つて白く敷けるが如く、人まばらにして塵を置かず。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社へ参詣をして、裏門の森を抜けて、一度ちょっと田畝道を抜けましたがね、穀蔵、もの置蔵などの並んだ処を通って、昔の屋敷町といったのへ入って、それから榎の宮八幡宮――この境内が、ほとんど水源と申して宜しい、白雪のとけて湧く処、と居士が言います。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "花尾八幡宮の社殿で昼休み二時間。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠石八幡宮参拝、奥床しく尊い。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "花岡八幡宮はよいお宮だつた、多宝塔は特別保護建造物になつてゐる、古色蒼然として無量の含蓄がある、心しづかに味ふべし。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主の金作が朝早くから山芋掘りに行った留守に、あんまりお天気がいいので、女房のお米は家を閉め切って、子守女のお千代に当歳の女の児を負わせた三人連れで、村から一里ばかりあるＨ町の八幡宮に参詣した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿七日、丙午、晴、将軍家御不例の後、始めて鶴岳八幡宮に詣で給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八日、乙巳、甚雨、午剋大風、鶴岳八幡宮の鳥居顛倒す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日、戊子、晴、申剋、鶴岳八幡宮の別当三位僧都定暁、腫物を煩ひて入滅す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁治元年四月の地震には海嘯があって、由比ヶ浜の八幡宮の拝殿が流れた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、左手に北向き八幡宮があった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寿子はそう思って、北向き八幡宮の前まで来ると、境内の方へ外れようとしたが、庄之助はだまって寿子の手をひっぱると、さっさと生国魂神社の石段の方へ連れて行った。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "北向き八幡宮へも寄らなかった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の左側に石の華表のある社は、河津八幡宮で、元の祭神は天児屋根命であったが、後に河津｜三郎祐泰及びその子の祐成、時致の三人を合祀したものであった。",
              "citation": {
                "source": "火傷した神様",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日香以は松本交山を深川富が岡｜八幡宮の境内に訪うて、交山が松竹を一双の金屏風に画いたのを見た。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで八幡宮を見せたついでに、義雄はその近處に借家してゐると知つた友人の家をちよツと訪ねて見ようとしたが、分らなかつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "足利尊氏は途中｜近江鏡ノ宿にて、密勅を蒙るや、之を秘して、何気なく京都を通り、丹波に入つて、足利氏の所領たる篠村八幡宮祠前に於て、勤皇の旗を挙げ、山陰道を上つてゐた千種忠顕の官軍と合して、六波羅を攻めて、之を滅した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉の八幡宮の前にあったあの雪の下の饅頭屋へ、某日二通の書翰が届いた。",
              "citation": {
                "source": "二通の書翰",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは八幡宮の境内であった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳は八幡宮の前へ往っていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀州日高郡｜産湯浦という大字の八幡宮に産湯の井あり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
