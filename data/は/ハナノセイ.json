    "definitions": [
      {
        "index": 1,
        "gloss": "spirit of a flower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
