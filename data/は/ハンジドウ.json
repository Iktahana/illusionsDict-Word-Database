          "literary": [
            {
              "text": "九時半自動車で立つ。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "この演習のために、川湯や弟子屈から通っていたアストン博士と大使館の四名と私とは、七時の終列車には勿論乗れず、真暗い山道を一時間半自動車に揺られて十一時頃宿へ帰りついた。",
              "citation": {
                "source": "英国日食班の印象",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六里の高原を、一時間半自動車が走りつづける。",
              "citation": {
                "source": "由布院行",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日は午前七時起床、入浴し、雑煮を祝って、八時半自動車来り、雷門まで。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
