        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いよいよはいり切らなくなって吐き出し始めたら餅が一とつながりの紐になって果てしもなく続いて出て来たなどという話を聞かされたこともある。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の繰り言は果てしがない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一目逢いたかった……次から次と果てしなく思いは溢れてくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は当分毎日お墓へ参ります……」　話しては泣き泣いては話し、甲一語乙一語いくら泣いても果てしがない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "渾沌未分…………　渾沌未分…………　小初がひたすら進み入ろうとするその世界は、果てしも知らぬ白濁の波の彼方の渾沌未分の世界である。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまで行っても果てしがあろうとは思われなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先には光のような青空が果てしもなく人の視力を吸い上げて行く。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が身を倚せてゐる若木の楡の梢からは、秋の野葡萄のやうに色づいて卷きちゞれた葉が、そよとの風もないのに、果てしもなく散りつゞいて、寒さのために重くなつた空氣の中を靜かに舞ひ漂つて、やがて霜の上にかさこそと微かな音をたてゝ落着くのだつた。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも秋で、土手を通ったのは黄昏時、果てしのない一面の蘆原は、ただ見る水のない雲で、対方は雲のない海である。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小石は転がり出すと、果てしがない。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……果てしがなかった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それは二人の果てしなき回想に任して置く方が賢明だ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "話すべきことも多かったし回想が次から次へと果てしなかったからである。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の前には一筋の白い路がある、果てしなく続く一筋の白い路が、……（大正五年十一月廿七日の生活記録より）（「層雲」大正六年一月号）",
              "citation": {
                "source": "白い路",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "酢の面に縮緬皺のようなさざなみか果てしもなく立つ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たん嘆き始めると、何もかもあべこべな二人の運命に気がついて、果てしもなしに悲しくなつた。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「老人、唯今の心地を申さば、炎天に頭を曝し、可恐い雲を一方の空に視て、果てしもない、この野原を、足を焦し、手を焼いて、徘徊い歩行くと同然でござる。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが熱き炎の都、都なる煉瓦の沙漠、沙漠なる硫黄の海の広小路、そのただなかに、饑ゑにたるトリイトン神の立像、水涸れ果てし噴水の大水盤の繞には、白琺瑯の石の級ただ照り渇き痺れたる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬も早や絹のつや雲、巻雲の巻きのなびきに、氷凝り雲｜層雲の群、重ね雲、寂び金の雲、下｜明り雲ともわかず、薄ぎらひ山ともわかず、たださへも現ならぬを、たださへも果てしわかぬを、日の射すか末広の虹、幾すぢか透きて落せり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬も早や絹のつや雲、巻雲の巻きのなびきに、氷凝り雲｜層雲の群、重ね雲、寂び金の雲、下｜明り雲ともわかず、薄ぎらひ山ともわかず、たださへも現ならぬを、たださへも果てしわかぬを、日の射すか末広の虹幾すぢか透きて落せり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "左千夫君と話を始めるとこれも長くなつて果てしがない。",
              "citation": {
                "source": "竹の里人〔一〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は半ば凍り、泥濘も脛を没する深さで、行けども行けども果てしない枯葦原が続く。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、眞珠や黒耀石を追ひ求めては、果てしない太平洋の眞蒼な潮の上を、眞紅な帆でも掛けて、恐らくは葦の莖の海圖を使用しながら、或ひは、今でも我々の仰ぐオリオン星やシリウス星を頼りに、東へ東へと渡つて行つたに違ひない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、真珠や黒耀石を追い求めては、果てしない太平洋の真蒼な潮の上を、真紅な帆でも掛けて、恐らくは葦の茎の海図を使用しながら、あるいは、今でも我々の仰ぐオリオン星やシリウス星を頼りに、東へ東へと渡って行ったに違いない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく成り果てし吾身をいとしと思ひ給はぬにか。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来月の十日頃が来たなら、学校の方も休みになるから、海岸の方へ伴れて行つてやらう、一ヶ月位も呑気にしてをれば癒るだらう、」　砂丘に植ゑた小松の枝振りや、砂の細かな磯際、藍色をした水の色と空の色とが溶け合つた果てしもない海の容などが思ひ出された。",
              "citation": {
                "source": "あかんぼの首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "数えきれぬほど沢山な男に抱かれて踊っていたのだと思うだけでもやりきれなかったのに、踊ることによって自他ともにひそかに愉む気があったのかと思えば、もう豹一の嫉妬は果てしがなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "左右一面に氷の面が地平の遙か彼方まで果てしなく展がっている。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "この氷山は途方もなく広いので、われわれはその上を少なくも二十マイルは歩いたが、行けども行けども果てしがありそうにも思われなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてしなき、そが心母にも、……もとより友にも明さざりき。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
