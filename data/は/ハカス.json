    "definitions": [
      {
        "index": 1,
        "gloss": "to drain away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨夜の大雨で庭に溜まってしまった泥水を、溝を掘って速やかに道路側へと捌かす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ダムの貯水量が限界に達したため、放流を行って上流からの流入分を捌かすことにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "工事現場のぬかるみを解消するために、大型ポンプを使って溜まった地下水を捌かす作業が続く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
