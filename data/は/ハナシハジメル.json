    "definitions": [
      {
        "index": 1,
        "gloss": "to begin to speak",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、老人も話し始める。",
              "citation": {
                "source": "虎",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と依頼人が話し始める。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズは両足を炉棚の隅に乗せて、両手を懐に入れて反り返り、他に対して言うというよりむしろ独り言でもしているような調子で話し始める。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "円朝がいよいよ高坐にあらわれて、燭台の前でその怪談を話し始めると、私はだんだんに一種の妖気を感じて来た。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "児童たちがみなシーンと静まると、今度は声色を変えて優しい父親のような感じで話し始めると――自分の子どものようにみんなを可愛がることを約束した。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "圓朝がいよいよ高座にあらわれて、燭台の前でその怪談を話し始めると、私はだんだんに一種の妖気を感じてきた。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ話し始める時は、危篤の病人とは思われないほど、強い声を出した。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからここへ引き越して来た当時からゆっくりと話し始める。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつか、八五郎親分におすがりして、錢形の親分さんのお耳にも容れ、出來ることなら御智慧を拜借し度いと申上げて置きましたが、この家の祖先から傳はつたお寳――」　内儀のお照は話し始めるのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "富士見の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜お前がこゝに來てから、騷ぎが始まるまでのことを、どんなつまらないことも誤魔化さずに、念入りに話して見てくれ」「へエ」　八五郎は眼の角で、三輪の萬七の苦りきつた顏を眺めて、いさゝか腐つた樣子ですが、それでも大した惡びれた色もなく、かう話し始めるのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "浮世繪の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで司令官は、居ても立ってもいられないようになって、ここぞとばかりに話し始めるでしょう。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼にとってまだ不信の念を抱いている村の連中も、もし彼がたとい彼らの友人ではなくとも彼らの仲間となったときに、やっと話し始めるだろう。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、話し始めるとなると、むろん、ののしり合ったり、つまらぬおしゃべりをしたり、ほらを吹いたり、誇張やつくり話をきそったりするのですから、あの暗い馬小屋のなかで入れかわり立ちかわり叫ばれるとめどもない叫び声のなかには、せいぜい一つか二つの、真実をちょっぴり暗示する点があるくらいがせきの山でした。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が泣き聲で「あのジエィン・エアの畜生」がまるで氣狂ひ猫のやうに自分に飛びついたんだと話し始めるのが聞えた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、話し始めるやいなや、全くどぎまぎするのをやめてしまって、今度はリーズに心をひかれた。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線機のＶＯＸスイッチを押し、深呼吸してから話し始める。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は警部の驚き顔を無視して話し始める。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "話し始めると間もなく、訪問客が見えたり重役が入って来たりして、「それじゃ熊野君、今の続きは今晩ゆっくり話そう。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は話し始めると長い。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その理由をお話すれば、自然甲田君の殺人未遂の動機も明かになる訳ですが」と弘一君は少し云い悪く相に話し始める。",
              "citation": {
                "source": "何者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとたびこの老人が話し始めると、ミショノー嬢が彼を止めない限り、彼は話し続けた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
