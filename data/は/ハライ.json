  {
    "uuid": "cba4109b-b010-540b-a3c9-f98657c329a7",
    "entry": "払い",
    "reading": {
      "primary": "はらい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "payment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その朝は早々起きて物置の二階から祭壇を下ろし煤を払い雑巾をかけて壇を組みたてようとすると、さて板がそりかえっていてなかなか思うようにならぬのをようやくたたき込む。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五円で皿を買っても暮の払いには困らぬ。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下宿や洗濯屋の払いを済ませても二十円あれば足りる。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎坊へ着いて見ると、戸は厳重に釘づけにされ、その上に材木を筋交えに抑えにして、鋼線で結びつけてあるが、寂ッそりとして、人の気はなく、案内者の咳払いが、沈んだ空気を乱しただけだ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へべれけに酔っ払いてえなあ。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は全く酔っ払いだった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "素面の者は、質の悪い酔っ払いには相手になっていられない。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は煩わしく雫を払いながら朝餉を少し食べた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばか、そんなにしないだって、ご馳走あげるわよ」　柚木の額の汗を掌でしゅっと払い捨ててやり「こっちにあるから、いらっしゃいよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "患者のうちのあるものは、うるさそうにそれを髪から払いのけ、あるものは手を振ってよけました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がくるくるくるっと白く揺らぎ、草がバラッと一度に雫を払いました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "緊張した時には咳払いをしなければ声が出にくいのは誰も知る通りである。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかベルリンで見た歌劇で幕があくとタンホイゼルが女神の膝を枕にして寝ている、そして Zu viel! zu viel! と歌いながら起き上がる時に咽喉がつかえて妙な声になりそうなので咳払いを一つして始末をつけたのを記憶している。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラヽイラヽララー、絵具の払いはいつでもよい。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八人の酔ッ払いがどんな与太を飛ばすだろうかと思うと今から旅が楽しみです。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵、木太刀を捨てて塵打ち払い、悠然と立ち出でんとする。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家は忙わしく一はけ二はけ払いて、ブラシを投げ捨て、大股に、二三歩にて戸の処に行き、呼ぶ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は、勝利は自分のものだと見てとると、指についた飯粒を、ひとつひとつ払い落したりしてから、わざと落ちついて蠅帳のなかを子供に見せぬよう覗いて云った。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕、今日苦しんでるんだ」　薫は肘で払い除けるが、小初は関わず背筋へ入れた砂をぽんぽんと平手で叩き均らして、「ちっとも苦しんでるように見えないわ」「この間、水の中で君に…………、こんなに腫れた」　薫は黒くなっている唇の角をそうっと大事に差し出して見せる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "………………」「――その、今月分の衣裳屋の仕払いを引うけるよ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しいつもの時間になって、オテル・ド・ロンの鉄門が見え出すと妾は佐野の亢奮し、やつれた顔が車窓に映るような気がして、慌てて車内の空隙に現れた心影を妾は払いました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな防寒具にかゝった雪を払い払い彼につきあたって通った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりおり立ち止まっては毛布から雪を払いながら歩みます、私はその以前にもキリスト教の会堂に入ったことがあるかも知れませんが、この夜の事ほどよく心に残っていることはなく、したがってかの晩初めて会堂に行った気が今でもするのであります。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく刑事と警察医らしい人たちが来て、はじめて蚊帳を取り払い、毛布を取りのけ寝巻の胸を開いてからだじゅうを調べた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともＩ君の家は医家であったので、炎天の長途を歩いて来たわれわれ子供たちのために暑気払いの清涼剤を振舞ってくれたのである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔自分に親しかったある老人は機嫌が悪いと何とも云えない変な咳払いをしては、煙管の雁首で灰吹をなぐり付けるので、灰吹の頂上がいつも不規則な日本アルプス形の凸凹を示していた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は再び咳払いをすると、塀の横手から彼の男が跳り出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「満蒙の特殊利益は、日本が高価なる犠牲を払い、巨額の資金を投下して開拓したるものである。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は過去十余年間、巨額の資本と高貴なる犠牲（日独戦争）を払いて、山東の資源を開発し、現に邦人の投資額約一億五千万円に達する。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "袂のちり打はらいて空を仰げば、日脚やや斜になりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
