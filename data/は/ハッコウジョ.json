    "definitions": [
      {
        "index": 1,
        "gloss": "publishing house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大正八年アララギ発行所がわたくしの「食後の唄」を出版してくれた。",
              "citation": {
                "source": "本の装釘",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横堀｜筋違橋ほとりの餅屋の二階を月三円で借り、そこを発行所として船場新聞というあやしい新聞をだしたのは、それから一年後のことであった。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も『我楽多文庫』はそれより二タ月前頃から公刊されていたが、飯田町の国学院大学の横町の尾崎の家を編輯所兼発行所としていた頃には誰にも余り知られなかった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "漣はその時あたかも『新著百種』中の『妹背貝』を書終って、丁度発行所の吉岡書店から原稿料を請取って来た処だというので、紅葉はソンナラ午餐を奢れといい、自分は初対面であったが、三人して上野の精養軒へ行った。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに、鎌と鎚工場の工場新聞の発行所がある。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは一本の廊下だがその辺には工場委員会｜共産党青年ヤチェイカの札が見えるだけで、どこに新聞発行所があるかわからない。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、柵のところに立ってる男に、「新聞発行所はどの室ですか、」と訊いた。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオ、読書室、キャンプ新聞発行所等があり移動映画隊を利用する。",
              "citation": {
                "source": "ソヴェトの「労働者クラブ」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもう五十円足せば、市外に発行所を置くとすれば、月刊雑誌の保証金には間に合うのだ。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今見たい本は、『帝国文学』の発行所から出るもので物集博士の日本文明史略、長岡博士のラジュウムと電気物質観、鳥居氏の人種学、平塚学士の物理学輓近の発展、シジュウィックの倫理学説批判、高桑博士のインド五千年史、物理学汎論（著者の名は忘れた、二冊もの）以上、『帝国文学』の広告を見よ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『改造』『中央公論』などという綜合雑誌の発行所がその雑誌の属する第七部とかには出ていないで中央公論社は、『婦人公論』で第五部に、改造社は『短歌研究』、『俳句研究』で、研究社の『英語研究』と同じ類別のなかにくまれていたと書かれていたように記憶する。",
              "citation": {
                "source": "日本文化のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文学史」として、やはり岩波講座の「世界文学」と「日本文学」及び、日本評論社の「日本古典読本」（十巻）および同じ発行所の「日本文学入門」改造文庫「欧洲文学発達史」等をあげたい。",
              "citation": {
                "source": "世代の価値",
                "author": "――世界と日本の文化史の知識――",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁新聞発行所が主催で、レーニングラード市外の集団農場見学に出かけた記事がある。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜は、その発行所で、大学寄宿舎生活についての討論があった。",
              "citation": {
                "source": "ワーニカとターニャ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局、農場新聞発行所。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて職業意識をとり戻し、彼は、わきに案内役をしている工場新聞発行所の文学衝撃隊員或は工場委員会文化部員に訊くだろう。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ゴルロフカの「労働宮」にはロシア語の工場新聞のほかにもう二つ別にユダヤ語とタタール語の小新聞発行所が設けられていることだ。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「労働宮」の大きくない一室のドアの上に貼られた「ユダヤ語、タタール語新聞発行所」という紙は小さいものだ。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "発行所大阪毎日新聞社。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又斎藤さんと割り合にすいた省線電車に乗り、アララギ発行所へ出かけることにした。",
              "citation": {
                "source": "島木赤彦氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等は発行所へはいる前にあの空罎を山のように積んだ露路の左側へ立ち小便をした。",
              "citation": {
                "source": "島木赤彦氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "発行所の下の座敷には島木さん、平福さん、藤沢さん、高田さん（？",
              "citation": {
                "source": "島木赤彦氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "発行所は小石川区茗荷谷町五十二番地｜郷土研究社、定価は僅かに七十銭である。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "発行所は、今の精文堂であったらしい。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように興味中心でやった蕪村講義が、真面目な批評に上ることになった、その恐縮の言い訳でもないが、近来ホトトギス発行所の俳談会では、引続いて小学、中学の教科書に載っている俳句の批評に従事している。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻末には発行所も印刷所も書いてない。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、汽車の中の一室を、その新聞の発行所にあてた。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "気になると見えて発行所のことなどをも云つた。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角今夜アララギ発行所に来てもらひたい旨をいつて電話を切つた。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻に妹の家を辞して、途中で蕎麦を食ひ、その足でアララギ発行所に行つた。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
