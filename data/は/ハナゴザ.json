        "examples": {
          "standard": [
            {
              "text": "夏の暑い日には、涼しげな花ござの上で昼寝をするのが最高だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "客間には、日本の伝統的な花ござが敷かれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この花ござは、手織りならではの温かみがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこだけ敷いた花ござの模様がちらッと見えた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪合一　此庭に歌の上ずはありと聞く、歌へながらも心はづかし一　おんげんべりこおらいべり、山と花ござ是の御庭へさらゝすかれ○雲繝縁、高麗縁なり。",
              "citation": {
                "source": "遠野物語",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
