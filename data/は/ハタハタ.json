[
  {
    "uuid": "5f4f4786-1b14-5af8-94c9-5c5c15d387ae",
    "entry": "鰰",
    "reading": {
      "primary": "はたはた",
      "alternatives": [
        "かみなりうお",
        "ハタハタ"
      ],
      "is_heteronym": true
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sailfin sandfish (Arctoscopus japonicus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ハタハタは、このごろ東京にも時たま配給されるやうであるから、読者もご存じの事と思ふが、鰰、または※などといふ字を書いて、鱗の無い五、六寸くらゐのさかなで、まあ、海の鮎とでも思つていただいたら大過ないのではあるまいか。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し鮎鰯鰰等の字と同じく我が邦人の製にかゝるものにて、喜の字にきすのきの音あるに縁りて以て創め作りしなるべし。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠が、はたはたと木の虚から飛んで出た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雀が、いまお婆さんの退場後に、はたはたと軒下から飛んで來て、お爺さんの頬杖ついてゐる机の端にちよんと停る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀は、はたはたと空高く飛び去る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はたはたとお鈴さんは奧の間に飛んで行き、さうして、間もなく、稻の穗を口にくはへて歸つて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の国のみつぎとり、　　　　里長を追ひて出で来り、えりをひらきてはたはたと、　　紙の扇をひらめかす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しも土手のかなたなる、　　郡役所には議員たち、視察の件を可決して、　　はたはたと手をうちにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥はおどろきてはたはたと飛去りぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくしては立ちあがり、はたはたと着物の前をたたくのだ。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたはた　それは　はためいて　ゐたが、音は　きこえぬ　高きが　ゆゑに。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "手繰り　下ろさうと　僕は　したが、　綱も　なければ　それも　叶はず、　旗は　はたはた　はためく　ばかり、空の　奥処に　舞ひ入る　如く。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの時　この時　時は　隔つれ、此処と　彼処と　所は　異れ、　はたはた　はたはた　み空に　ひとり、いまも　渝らぬ　かの　黒旗よ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに相の山から戻腕車、店さきを通りかかって、軒にはたはたと鳴る旗に、フト楫を持ったまま仰いで留る。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜風は蝋燭をはたはたと揺る、遠洋と書いたその目標から、濛々と洋の気が虚空に被さる。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はたはたと袖を払いて、「身ぶるいがする。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁草履の擦切れたので、埃をはたはた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やッ、」というて目を※る義作と一所に吃驚したのは、茶店の女で、向うの鍵屋の当の敵、お米といって美しいのが、この折しも店先からはたはたと堤防へ駆出したことである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主はいよいよ心｜臆し、団扇にてはたはたと、腰の辺を煽ぎ立て、景気を附けて語りけるは、「ちょうどこの時分用事あって、雪の下を通りかかり、かねて評判が高いので、怯気々々もので歩いて行くと、甲走った婦人の悲鳴が、青照山の谺に響いて……きい――きいっ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈は遠し、手探りを、何の気もなく草鞋を解いて、びたりと揃えて、トンと船底へ突込むと、殊勝な事には、手拭の畳んで持ったをスイと解き、足の埃をはたはたと払って、臀で楫を取って、ぐるりと船の胴の間にのめり込む。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかけにて、竹の小笠はたはたと煽って遁げる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、それは、」　と思わず、膝を辷らした手で、はたはたと圧えると、爪も立ちそうにない上床の固い事。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手先が、心なしにちょいちょい触ると、僧の手首が自然はたはたと躍上った。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とまた差俯向く肩を越して、按摩の手が、それも物に震えながら、はたはたと戦きながら、背中に獅噛んだ面の附着く……門附の袷の褪せた色は、膚薄な胸を透かして、動悸が筋に映るよう、あわれ、博多の柳の姿に、土蜘蛛一つ搦みついたように凄く見える。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雀が、いまお婆さんの退場後に、はたはたと軒下から飛んで来て、お爺さんの頬杖ついてゐる机の端にちよんと停る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はたはたとお鈴さんは奥の間に飛んで行き、さうして、間もなく、稲の穂を口にくはへて帰つて来た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　氏の笑い声が、はたはたと、八月の海岸地の繁茂する野菜畑に響き渡った。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋のはじめの或る月のない夜に、私たちは港の棧橋へ出て、海峽を渡つてくるいい風にはたはたと吹かれながら赤い絲について話合つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
