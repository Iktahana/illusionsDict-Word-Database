    "definitions": [
      {
        "index": 1,
        "gloss": "abolish Buddhism, destroy Shākyamuni (slogan of anti-Buddhist movement at the beginning of the Meiji era)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
