        "examples": {
          "standard": [
            {
              "text": "久しぶりに友人と旅行に行って、思う存分羽を伸ばせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験が終わったら、好きなだけ羽を伸ばして遊ぼう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会社を休んで実家に帰り、のんびり羽を伸ばしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "二人とも久しく教壇と書斎との間を往復する生活に固定してゐたので、俄かに籠を放れて羽を伸ばすやうな気持である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月の顔ひかりはそのいろどりをのがれて、あしおともかろくかぎろひをうみつつ、河のほとりにはねをのばす。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "内門人、特に年少の者たちには、それがはねをのばす好い期間になっていた。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
