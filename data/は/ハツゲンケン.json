[
  {
    "uuid": "d7b2f769-ebb2-5480-bf12-09648db5464f",
    "entry": "発言権",
    "reading": {
      "primary": "はつげんけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
