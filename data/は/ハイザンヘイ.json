    "definitions": [
      {
        "index": 1,
        "gloss": "remnants of a defeated army",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「一言注意して置く、此の辺り一帯は尚敗残兵が徘徊している。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は、各国の帝国主義に尻押しをされて、絶えまなく小競合を繰りかえす軍閥の苛斂誅求と、土匪や、敗残兵の掠奪に、いくら耕しても、いくら家畜をみずかっても、自分の所得となるものは、何一ツなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔が合うと、美男の兵の方が、「敗残兵が帰って来たア。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敗残兵が帰って来たア。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく僕の大家さんなんだから……」　私は、丁度そこへ来合せた井河氏に、敗残兵とやらがこの辺にまだゐはせぬかを訊ねた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの山間の部落々々には、所謂敗残兵がまだうろうろしてゐるのだと聞いてゐたからである。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敗残兵が出たな」　誰かが囁いた。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体穏かだが、なかには油断のならん奴がゐるよ」「ある砲兵隊が舎営してゐる部落で、敗残兵だか匪賊だかの襲撃を受けたところがあるつてね。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、例の通州事変の後、一時、この界隈に匪賊化した敗残兵が出没して、夜道はむろん危険ですし、何処の家でも戸を閉めて子供を外に出さないことがありました。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残兵や便衣隊と間違へられては大変だ。",
              "citation": {
                "source": "北支の旅",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "往復をいれてわづか三週間といふ短い旅であつたが、当時、京漢線方面では、彰徳の攻撃がはじまる前であり、娘子関がまだ落ちず、保定、定県附近には敗残兵が頻々と出没して油断のならぬ頃であつた。",
              "citation": {
                "source": "後日譚",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや、かの敗残兵のいくぶん計画的とも云はれるゲリラ戦術とはどんなものか、それを見届けるためには、少し後方の辺鄙な地点を選ぶに如くはないと気づき、私は、一旦南京へ引返した。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在これらの水路は、所謂敗残兵の出没甚だしく、支那人は「税金」を払つて難を免れるといふことである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなく怪しげな挙動とも思はれるが、まさか敗残兵ではあるまい。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "御両所とも敗残兵の如しだが、自分もまた御両所以上にひどい姿である。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で同胞の敗残兵に強奪されたり、女が強姦されることまで心配してゐた。",
              "citation": {
                "source": "戦争と一人の女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞穴に追いつめられた敗残兵が突如として総攻撃に転じたような悲痛の様が思いやられますが、行われた現象としては必ずしもそうではなくて、素人芝居の中でも一番不出来なのに似ているようなオモムキだったようです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残兵の靴下よりも貧弱だわね」「さほどにも見えない。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、知らん」　升田は目の玉をむいてニヤリとして、「オレ、ちよッと、ねむりたうなつた」　とキョロ／＼あたりを見廻したが、敗残兵のやうなのが五六人、右に左に入りみだれて隅の方でねむつてゐるから、場所がない。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残兵の自覚がもてないところが哀れでもあり、ミソでもあるというわけらしいな」　青木は安心したらしく、酒をたてつづけに呷りだした。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧みにフランスの国歌を使って、ナポレオン軍の敗残兵を歌った技巧が面白い。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、山海関からは毎日、一万、五千、と敗残兵が帰って来る。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一度、奉天で我軍と、その敗残兵との間に干戈を交えんか、惧るべき市街戦となって、奉天在住の日本人はどんな目に遭うかわからない。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全滅したバルチック艦隊の敗残兵が、ボートに乗って、近くの海岸に流れつく事件があって、百姓や漁師たちが、鍬、鎌、櫓などをふりまわす珍騒動がおこった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなところへ来る以上、ただ者でないことは察したらしい歩哨が、「充分、気をつけて下さい」　このさきには敗残兵がまだ出没していると言った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩哨に注意された生きた敗残兵でなく、遺棄死体にぶつかった。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "沿岸の敗残兵を掃蕩しながら、やがて孫策は秣陵まで迫って行った。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残兵のことか」「ひと口に、敗残軍といえば、すでに弱力化した無能の群れとして、これを無視してしまう傾きがありますが、時利あらずで、その中には、惜しむべき大将や兵卒らも入りまじっています」「うむ。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「或る夜、近郷の山中に住む山賊と、諸州の敗残兵とが、一つになって、ふいに宣城へ襲せてきました。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "張繍は諸州の敗残兵を一手に寄せて、追々と勢威を加え、また、謀士｜賈※を参謀とし、荊州の太守｜劉表と軍事同盟をむすんで、宛城を根拠としていた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
