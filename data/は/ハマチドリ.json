          "literary": [
            {
              "text": "（汀をつたう）あゝ浜千鳥よ。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "保元物語に　浜千鳥あとは都に通へども身は松山に音をのみぞ泣く　といふ御歌がありその頂を白峰といふらしい。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の姿も恐れずに砂浜に遊びたわむれる、鴎や沖の浜千鳥でもいいから、俊寛の行方を知らせてはくれまいか、有王はつくづくそう思ったのである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第三巻",
                "note": "青空文庫"
              }
            }
          ]
        }
