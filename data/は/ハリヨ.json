[
  {
    "uuid": "ce4580a7-02e6-5b3c-bdcf-4af6af31dca0",
    "entry": "針魚",
    "reading": {
      "primary": "はりよ",
      "alternatives": [
        "はりうお",
        "ハリヨ"
      ],
      "is_heteronym": false
    },
