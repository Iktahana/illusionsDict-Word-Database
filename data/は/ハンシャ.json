[
  {
    "uuid": "923f3da0-d33d-58e0-9ee0-f01d27f29501",
    "entry": "反射",
    "reading": {
      "primary": "はんしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
