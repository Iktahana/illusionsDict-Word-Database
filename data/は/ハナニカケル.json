    "definitions": [
      {
        "index": 1,
        "gloss": "to be full of pride",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悪いことをしてここへ来ながら星だなんて鼻にかけるのは海の底でははやらないさ。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、そうだと答えたかったのだけれど、そうすると、なんだかお金持の子供を鼻にかけるようで私のロマンチックな趣味に合わなかったから、いやちがう、僕はあの家の遠縁に当る苦学生であるが、そんなことは、どうでもいい、十年ぶりでやっと思いが叶って逢えたのだ。",
              "citation": {
                "source": "デカダン抗議",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺を、学問に私すると云つた江戸の村田｜春海、古学を鼻にかける伊勢の本居宣長、いづれも敵として好敵ではなかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鼻にかける」という表現は、前の「鼻うごめかす」というのと同じような心理状態から出て来るものであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手近い例を挙げましても今までに出て来た……　……鼻をうごめかす……　……鼻にかける……　……鼻じろむ……　……鼻であしらう……　……鼻っ張りが強い……　……鼻毛が長い……　というような感じの中一つでも眼や口に出来るのがありましょうか。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを鼻にかけるやうになつたらもうお了ひである。",
              "citation": {
                "source": "手品",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "さして身分を鼻にかけるやうな人の姿も見えなかつた。",
              "citation": {
                "source": "青い風",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議と彼女に好い親類のあることがその後だんだんわかって来たのであったが、小夜子はそれを鼻にかけることもなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時私は、「子供の時に郷里で名を謳われたりしても、これを鼻にかけるようなことがあってはならぬ。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはまだこの時位、開化を鼻にかける兄を憎んだことはございません。",
              "citation": {
                "source": "雛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "強ち君に對して興味を棄てよと云ふのではないが、内々に好きからに筆を執つて樂んで居るといふのならば餘り駄作は公表せぬが宜ではないか、些か自ら文筆に得意なといふので鼻にかけるのは宜ろしくない。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　たゞ、彼は、文学者であることを鼻にかけるほど文学のわからない男ではない。",
              "citation": {
                "source": "田巻安里のコーヒー",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "美貌を鼻にかけるだけが能で、美貌が身上だと思っており、芸術についての心構えが根底に失われている。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の細君は父の主筋に当る家柄の娘で、元々父母が押しつけられ、その又父母が大いに有難がつて無理に押しつけた女で、別段家柄を鼻にかけるわけでもないが、陰気で、何かと云へば実家へ不満を書き送るやうなたちである。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ、反抗する奴はでてこい、痛い目にあわせてやる、という一人ぎめの社長や、柔道五段を鼻にかける編輯長のオソロイだから、タダではすみそうもない。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今度の初航海に充分に証明されたところであり、本人が、こっちにとってそれほど貴重な経験を、マドロスとしてあたりまえの働きとして、鼻にかけるところまでは行ってなかったらしいが、駒井にとって、天の助けとも、渡りに船とも、なんとも有難い唯一無二の羅針となったものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいか今だに処嫌わず西洋料理の通を振廻し、二言目には英語の会話を鼻にかけるハイカラであるが、酒もさしては呑まず、遊びも大一座で景気よく騒ぐよりは、こっそり一人で不見転買いでもする方が結句｜物費りが少く世間の体裁もよいと云う流義。",
              "citation": {
                "source": "夏すがた",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏を鼻にかけるようじゃ清貧ではなくて濁貧である。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "房子　　お身分を鼻にかけるやうな方ぢやありませんわ。",
              "citation": {
                "source": "古い玩具（一幕六場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょッとした学問を鼻にかけるのは、見苦しいわよ」「ハハ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その五　万引家族",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少しぐらゐ字を知つとるちふて鼻にかけるない。",
              "citation": {
                "source": "ある職工の手記",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "疎開児童の一種の優越感と、おやじが陸軍大佐だつていうことを妙に鼻にかけるところがあつた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお金や学問や武芸を鼻にかける男は、たったそれっ切りのような気がして、どうも心に染みません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第三夜　お化け若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ねて言えば、人間は縹緻を鼻にかけるうちは、まだ可愛らしいものだが、それを頭から抹殺してかかる奴に至っては、悪魔でも誘惑のしようがない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかばかりの給料を取って、働くのを鼻にかけるのか。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々、子のぼくにさえ「馬鹿にするな」と怒ったり、「稼ぎを鼻にかける奴だ」と、忌み嫌う容子を見せた。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「学問の出来るのを鼻にかけるな」「…………」「品行方正を自慢にするな」「…………」「能く考えて見ろ。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詰まらないことを鼻にかける婆さ」「あなた！",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大谷さんは然うでもないが、奥さんはこれを鼻にかける。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小兵ではあるが着飾らない程に身なりも整っておるし、一部でひどく悪口いうほど不縹緻でもないし、才気を鼻にかける男とも見えない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
