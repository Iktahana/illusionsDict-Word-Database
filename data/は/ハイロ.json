[
  {
    "uuid": "3f949263-d93d-5d6a-910c-f3e83bc401a3",
    "entry": "廃炉",
    "reading": {
      "primary": "はいろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
