    },
    "definitions": [
      {
        "index": 1,
        "gloss": "decommissioning (of a nuclear reactor, furnace, incinerator etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼はいろいろなことを訴へた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹はかよわい身一つで病人の看護もせねばならず世話のやける姪をかかえて家内の用もせねばならず、見兼ねるような窮境を郷里に報じてやっても近親の者等は案外冷淡で、手紙ではいろいろ体の好い事を云って来ても誰一人上京して世話をするものはない。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまちみんなはいろいろな国語で一ぺんにそれをうたひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "網シャツの人は、馬に乗って、またかけて行ったし、子どもらは、ぼくらの仲間にはいろうと、岸に座って待っていた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌ語「シリ」はいろいろの意味があるがその中で陸地を意味する場合もある。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｑはいろいろに変化するから ima, ime が「ウミ」であり水である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概の教師はいろんな下らない問題を生徒にしかけて時間を空費している。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ちに例の杉屏の前までやった　裏からはいろうと云う心でもなくまあ……のぞき込みにきたのだ。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さんは行ってもえい」　自分がそういうと、母はいろいろ頼むと云う様な事を云って立ちかける。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな目の子勘定をして紳士淑女の辛抱強いのに感心する一方では自分でこの仲間にはいろうという勇気を沮喪させていた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "按ずるに、霧の凝結する核となる塵埃中にはいろいろ香や臭のあるものもあってこれが鼻感を刺戟する場合があるのでそう云ったものではあるまいか。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆はいろいろに辯解した。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "物賣りの叫び聲はいろいろに變りました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "滴たって落つる水を受け止めているのも淵だ――」　父親は大体こんなふうに淵が水を受け入れる諸条件を九つの範疇にまとめて、「これを九淵の説と云って、水はいろいろの変化で向うが、それを受け容れる淵はたった一つなのだ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時ばかりはいろいろな病苦に慣らされた私も自分の病弱を恨み悲しまずにはゐられなかつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "張作霖と言はず、如何に支那人が麻雀を好くかといふことはいろいろ話に聞くが、驚くことは彼等二｜日も三｜日も不眠不休で戰ひつづけて平氣だといふことだ。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その點でとりわけ物事に縁起を擔ぐ支那人が如何に苦心焦慮するかはいろいろ語られてゐることだが、全く外のことでは如何なる擔ぎ屋でもない僕が麻雀の日となると、その日の新聞に出てゐる運勢が變に氣になる。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「やっぱし、あしこのところからはいろうとしたのか？",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "道々二人はいろいろな話をしたでしょうがよく覚えていません。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の島環の成因についてはいろいろの学説がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本において科学の発達がおくれた理由はいろいろあるであろうが、一つにはやはり日本人の以上述べきたったような自然観の特異性に連関しているのではないかと思われる。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはいろいろの研究が可能であるが、たとえば進化論的な立場からこの問題を考えてみるのも有益ではないかと思われる。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた遺伝のほうでいわゆる「突然変異」が行なわれるように、時々はいろいろな奇形児が生まれたであろうということは想像し難いことではない。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし心の世界の過去と未来はいろいろな絵巻物の紙面に自由に展開されているからおもしろい。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕なぎの継続時間の長短はいろいろな事情にもよるが海岸からの距離がおもな因子になる。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧拙にかかわらず一人の個人の歌集がおもしろいように個人画家の一代の作品の展覧はいろいろの意味で真味が深い。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立の向うにはいろいろの色彩をした建築がまともに朝の光を浴びて華やかに輝いていた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして便所へはいろうとする時に、そこの開き戸を明ける前に、柱に取付けてある便所の電燈のスウィッチをひねる。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はいろいろの骨董道楽をしただけに煙草道具にもなかなか凝ったものを揃えていた。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そ〔〕の中にはいろいろ派があるやうであるが、大体そのテーゼについて大きくわけると、同情派と予防派との二つになるらしい。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
