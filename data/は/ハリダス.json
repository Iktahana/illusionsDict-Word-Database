        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして余り切望するでもないことでも引つ張り出すより他仕方なかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "參考書を引張り出す。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎尚も亭主に、Ｔ「烏天狗　二十や三十」　鼻へし折って、と手振り身振りで威張り出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の普通の力、工夫努力が多ければ多いほど、飽くまで生き抜く力を引っ張り出すのに、それだけ余計に沢山の力を利用することが出来るのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃ……ないけども、これから、この早瀬さんと一議論して、何でも慈善会へ引張り出すんですから手間が取れてよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛岡は二三度わたくしと押問答しましたが、その甲斐もないのを知って漸やく、「女というものは小娘でも、意地を張り出すと強いものだな。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月早々からあんたをこんなことに引張り出すなんか、いけないと思ってたの。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何十年も坑内にいた馬を、明るいところに引っ張り出すと、すぐ死んでしまうんだっていうからなあ。",
              "citation": {
                "source": "狂馬",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵人は忠義だって、羽ばたきをするばかり、袖を啣えて引張り出す方角もあるまいと思いますとね。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "引っ張り出すんだって、よっぽど、力を入れなけりゃ抜けやしないじゃないか。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時から与次郎はこの桜の木の下が好きになって、なにか事があると、三四郎をここへ引っ張り出す。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一人でほうっておくと、けっして行く気づかいがないから、君が寄って引っ張り出すのだと理由を説明して聞かせた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘助手は、監禁室から犬塚を引張り出すと、実験室の台上に引据えた。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんを引張り出すに限るというので、私もやむなく兄を頼むことに致しました。",
              "citation": {
                "source": "佐竹の原へ大仏をこしらえたはなし",
                "author": "高村光雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いやに俺の名前を引ツ張り出すな！",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで彼が倒れてゐるその下の地面を少し掘つて、漸くにして引つ張り出すことが出來た。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ人達が寄つてたかつて、太神樂の道化役にも使ひ、酉の市の熊手のかざりにまで引張り出す。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ死んだ塊を引っ張り出すだけのもんだからね、素人が騒いだって何にもなりゃしない。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんを引っ張り出すに限るというので、私もやむなく兄を頼むことに致しました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "佐竹の原へ大仏を拵えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "座敷の御簾をいっぱいに張り出すようにして裾をおさえた中で、五節という生意気な若い女房と令嬢は双六を打っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "常夏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもう血塗になってシャチコばっているのであるが、此様な男を戦場へ引張り出すとは、運命の神も聞えぬ。",
              "citation": {
                "source": "四日間",
                "author": "ガールシン",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホルピを引張り出すまでもなく、現に世界一といわれたガリクルチもトティ・ダルモンテも、いたずらに他人の真似をしてうたったからとうとう高い声が出なくなってしまいました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、箱の中から、チューインガムを引張り出すと、それを口の中に放りこんで、にちゃにちゃやりだした。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時から与次郎は此桜の木の下が好になつて、何か事があると、三四郎を此所へ引張り出す。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚するまではさんざん機嫌をとって、人の後からついて廻っておきながら一度一緒になってしまうと、とたんに威張り出すんですからね。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし別にクラブ・バッグを引張り出すわけでもなく、細い節竹のステッキを軽く手にもつと、外へ飛び出した。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く云ふと、国際的にいつても一国の演劇文化を代表し、それが一つの見本になるやうな芝居といふもの、これが日本にはたしかに欠けてゐる、さういふものを生み出し、或はどつかに隠れてゐれば表面に引つ張り出す、といふことを僕はアメリカの方も考へてゐるんだと思ひます。",
              "citation": {
                "source": "対話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "参加を求めたくても、然るべき手蔓がなかつたり、よそ目にもあまりに忙しさうだつたり、かういふことにまで引つ張り出すのは多少気の毒と思はれる向きは、ひと先づ遠慮することにした。",
              "citation": {
                "source": "雲の会",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとこの犬がまた、わたしを引張り出すようにして外へ連れ出しましたから、もしやとそのあとをついて来てみると恵林寺様へ入りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞踏会に出ても、彼女はただ誰かに相手がない時だけ引っ張り出されて踊るぐらいなもので、貴婦人連も自分たちの衣裳の着くずれを直すために舞踏室から彼女を引っ張り出す時ででもなければ、彼女の腕に手をかけるようなことはなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "スペードの女王",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
