    "definitions": [
      {
        "index": 1,
        "gloss": "first wind of the season (esp. the first wind of autumn)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから初風炉の茶湯懐石の次第にまで深入りする。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "草の花うつくしよしと啼く蝉の声もまじれる秋の初風いたづらに過ぎにし世さへしのばれて秋風ふけば心さびしも荻の葉におとづるるこそさびしけれ風は心の無しと思ふに雁四首。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に歌ふトレモロ――秋の初風。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、互いに籤引きをして、真先に当選した会員の女が、これも最初風呂へ入り、体を洗いお化粧をし、それから男の寝ている部屋へ、導かれて侵入する。",
              "citation": {
                "source": "鴉片を喫む美少年",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜短詩社、句会などにも折々出席、磯萍水、安斎一安、高沢初風氏らの横浜文壇なるもの大いに盛り、与謝野寛、晶子氏などの歌壇も交じえて浜港の青春子女に文化志向の夢高まる。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の横浜で文壇めいた雰囲気をもっていた人々は、磯萍水、高沢初風、小島烏水といった人たちで、「藻しほ草」という文芸雑誌が唯一の月刊物であったと思う。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
