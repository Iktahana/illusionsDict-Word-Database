        "examples": {
          "standard": [
            {
              "text": "春のガーデニングシーズンに向けて、園芸店には色とりどりの花苗が並び始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女はベランダに飾るため、可愛らしいピンク色をしたペチュニアの花苗をいくつか購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この花苗、元気に育ちそう！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "若しそれが實行されないならわたくしはこの屋敷から出て行かないと、かんさんはななえに膝詰めで言ひ寄つた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はななえに直ぐ戻るからと言ひ、近い坂下の齒科醫院に出かけた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことは氣にしないで男と出かける時の用意が、その歸りにはななえは一文なしになつても、少しも氣にしなかつた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな男が背後にゐてはななえは裸にされて了ふとかんさんは言つたが、ななえは毎日のやうに出掛けてゐて最近では、家で夕食を攝ることは殆どなかつた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの行爲はななえにも、加へられてゐる行状であつて、若い肢體には少しの困憊感を見ることが出來なかつた。",
              "citation": {
                "source": "渚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
