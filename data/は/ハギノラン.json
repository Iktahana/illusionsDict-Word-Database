          "standard": [
            {
              "text": "萩の乱は、明治政府の士族授産政策に対する不満から発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の授業で、前原一誠が中心となった萩の乱について学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "萩の乱の舞台となった場所には、今も当時の激動を伝える碑が立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "見ると、萩の乱るる垣根越しに白い横顔――下婢を連れてたたずんだのが、細かい葉の間から艶めかしい姿をチラつかせている。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
