        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　伯爵夫人は微笑んだ。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "薔薇だつて、そりあマリイ・ボオマンだとか、テストウ夫人だとか、カモンド伯爵夫人だとか、或はまたエモオションだとか呼ばれてはゐます、が、それは殆ど無用の長物です。",
              "citation": {
                "source": "夢",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あれがねぇ君、帝政時代の或る伯爵の娘だと聞いたら驚くだらう。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ふうん、伯爵の娘か……」と、私は思掛ない氣持で、またその女の方を見返つた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別な家柄でもなく一介の土木技手上りに過ぎない貧乏な作家と、大地主で大金持で伯爵の名門に生れた作家と、その呟きには何か胸を打つものさへあるが、とにかくドストイェフスキイは時には境遇的にも自分の原稿を讀み返す暇さへ持てなかつた。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」泊りに来て居た友だちのヘルバ伯爵が上着のかくしに手をつっこんで云ひました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」伯爵の二番目の女の子がかくしから黄いろのリボンを出しながら云ひました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "南堂伯爵未亡人の死と、私とを結び付けて考え得る者は、今逃がしてやった一匹のお女郎蜘蛛以外に絶無である。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南堂伯爵未亡人との約束を果したいからだ。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今朝の零時半キッカリに、南堂伯爵未亡人を、その自宅に訪問した。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "南堂伯爵未亡人は、その尤なる者であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨万の財産を死蔵して、珍書画の蒐集に没頭していた故伯爵が四五年前に肺病で死ぬと間もなく未亡人は、旧邸宅の大部分を取毀して貸家を建てて、元銀行員の差配を置いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……事実……私が南堂伯爵未亡人の素行調査にアンナにまで夢中になり始めた、そのソモソモの動機というのは、アノ粗末な、赤煉瓦の煙突に外ならなかったのだ。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体が耐震耐火のルネッサンス擬いという、故伯爵の凝り性と用心深さを遺憾なく発揮したものであった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが伯爵の死後、玄関と正反対の位置に新たに取付けられた煙突というのは、普通の赤煉瓦を真四角に積み上げたデッカイ、不恰好なものであった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一方に伯爵未亡人が案外に手剛いらしいのにも驚いた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろんあの煙突が伯爵の死後に起工されたことも、こうした判断を有力に裏書しているにはいたが……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵家の不動産が担保に這入りかけているという事実を、意外な方面からチラリと聞き出したのは、その頃の事であった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも私が連れ込まれた室は、南堂伯爵が、生前に寝室にしていたものに相違なかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして伯爵の死後、未亡人が秘密の享楽場としていたものに相違なかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大変に失礼ですけど、故伯爵とお別れになった後の貴女は、非常に皮肉な御生活をお始めになったようですね。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更に伯爵未亡人の名声が高大な理由を認めない訳に行かなかった。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最後のリフレーンで「イズンティット・ロマーン」まで歌った最後の「ティック」の代わりに、バルコンの下から忍びよるド・サヴィニャク伯爵の梯子が石欄に触れる「ティック」の音を置き換えてある。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがヴァレンティーヌ夫人、ド・ヴァレーズ伯爵、ド・サヴィニャク伯爵へと伝播する。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の伯爵のガス排出の音からふざけ半分のホルンの一声が呼び出され、このラッパが鹿狩りのラッパに転換して爽快な狩り場のシーンに推移するのである。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばド・ヴァレーズ伯爵がけしからぬ犯行の現場から下着のままで街頭に飛び出し、おりから通りかかったマラソン競走の中に紛れ込み、店先の値段札を胸におっつけて選手の番号に擬するような、卑猥であくどい茶番はヤンキー王国の顧客にはぜひとも必要なものであろう。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長節の佳日に際し　　子爵　　伊東海軍大將　　　　　　肝付海軍少將　　伯爵　　吉井海軍少佐　　子爵　　小笠原海軍少佐　　　　　　上村海軍少佐各位の清福を賀※、つたなき本書のために、題字及び序文を賜はりし高意にむかつて、誠實なる感謝の意を表す。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "処は英国の或る海岸に、一軒の立派な家がある、之れは老貴族｜松浪伯爵の別荘で、伯爵は極く愉快な人物、それに三人の娘があって、いずれも絶世の美人と評判が高い。",
              "citation": {
                "source": "黄金の腕環",
                "author": "流星奇談",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の向ふにはくしゃくしゃに縮れた雲が痛々しく白く光ってゐた。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るすぎる赤毛の髪はくしゃくしゃに乱れており、垂れる毛で目と額は覆い隠されている。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
