        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はしだいに鬱積して酒を飮んだ。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな恐ろしいものが窺っているのかと、お蝶はいよいよ身をすくめて、ただ一心に机を見つめていると、障子は再び音も無しにしまって、縁側の足音はしだいに遠くなってゆくらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "オウベイのキンユウはしだいにヒッパクをテイしたそう……。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして動くに連れて、潮はしだいに増すようである。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水はしだいに溢れて、光物は衝々と尾を曳く。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼はしだいに遠ざかって行く空の旅行隊の後を追っていましたが、翼をひろくひろげて、ちょうどしゃぼん玉が静かな空気の中を沈んで行くように、沈んで行きました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども二杯三杯とのむにつれて、僕はしだいしだいに落ちついて来たのである。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤葛はしだいしだいにおりて来た。",
              "citation": {
                "source": "忘恩",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おうウイ」「おうウイ」「おうウイ」「おうウイ」　壮い木客の声と前方の声は交互に聞えだしたが、その声はしだいしだいに熱を帯びて来た。",
              "citation": {
                "source": "死んでいた狒狒",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の底はしだいに深くなって行った。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有様を見ながら、李陵はしだいに暗く沈んだ気持になっていった。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟浄はしだいに陶然としてきた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "許宣は四聖観の簷下へ往って立っていたが、雨はしだいに濃くなってきて、雨隙がきそうにも思われなかった。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "呵殿の声はしだいに近くなってきた。",
              "citation": {
                "source": "富貴発跡司志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声はしだいに近くなってきた。",
              "citation": {
                "source": "申陽洞記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでの吾平爺はわずかばかりの小作地を耕すかたわら、集落内の農家に雇われていったのであったが、耕地が住宅地になるにつれ爺を雇ってくれる農家はしだいに少なくなっていった。",
              "citation": {
                "source": "或る嬰児殺しの動機",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従前どおりに続いていく雰囲気の中で彼らの要求感はしだいに膨張して、弾けようとする力を持ちだしてきていた。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田弥平氏が思い悩んでいる間に、嵐の暗雲はしだいに近づいてきた。",
              "citation": {
                "source": "仮装観桜会",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、湿っぽい林道の両側には熊笹の藪が高くなり、熊笹の間からは闊葉樹が群立して原生樹林帯はしだいに奥暗くなっていった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつがあれを奪っておれに与えた苦しみを、おれはあれを殺っつけておれの背負わされた苦悶の何倍かの苦悶を、何倍かの深刻さであいつに突っ返してやるんだ）　正勝の思いはしだいに悪魔的になってきた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はしだいに、敬二郎と紀久子とを殺してしまったあとも、自分だけは安楽のうちに生きていたかった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　敬二郎の言葉はしだいに辛辣になっていった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、敬二郎はしだいに驚きの表情を失って、侮蔑的な微笑に崩れていった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯まあ飲め」　正勝はしだいに酔いが回ってきて、爺のほうへぐっと盃を突きつけながら叫ぶような高声で言うのだった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、彼女の胸はしだいに激しく疼いてきた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "許してね」　紀久子の声はしだいに啜り泣きになってきた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど他の側においては、ヴェル（ヴァルー）に向いてこの深さはしだいに減り、船舶の航行に不便にして、静穏な天候のおりにもしばしば岩礁のために難破するの危険あり。",
              "citation": {
                "source": "メールストロムの旋渦",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどそんなトラブルを繰り返しながらも、私はしだいに、この世界の仕組みになじんでいきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テクノロジーを頼る理由がここにあります」　幅広くツールキットの採用を働きかける中で、ボイジャーはしだいに、エキスパンドブックの可能性を認めようとする人たちを獲得していきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
