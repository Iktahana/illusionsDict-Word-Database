        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妊娠三カ月になる肩で息をしている女房や、ハッパをかけるとき、ほかの者よりも二分間もさきに逃げ出さないと逃げきれない脚の悪い老人が、皆と一緒に働いていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折れた脚が見え出すと、ハッパをかけるにしのびなかった。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、炭塵で真黒けになった日給三十銭の運搬華工や、ハッパをかける苦力がウヨウヨしていたね。",
              "citation": {
                "source": "防備隊",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には岩石に穴を穿って、ハッパをかけるのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
