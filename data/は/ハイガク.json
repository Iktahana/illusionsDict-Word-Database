    "definitions": [
      {
        "index": 1,
        "gloss": "abandoning one's studies",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
