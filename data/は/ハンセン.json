[
  {
    "uuid": "6a2881d1-91b3-5720-a0ac-8222351e9c9e",
    "entry": "反戦",
    "reading": {
      "primary": "はんせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
