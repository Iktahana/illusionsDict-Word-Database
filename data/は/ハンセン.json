      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "anti-war",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "-------------------------------------------------------　　　一、反戦文学の階級性　　　　　　一　戦争には、いろ／＼な種類がある。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体、その名前だけを挙げて、プロレタリアートの反戦文学に移りたい。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ゲエリングは、反戦的ではありながら、本当に書こうとしていることは、人類全体の上に蔽いかゝっている運命の力との関係であるようだ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、プロレタリアートの反戦文学には、それが表現されなければならない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアートの戦争に対する態度は、ブルジョア平和主義者や、無政府主義者や、そういう思想から出発した反戦文学者とは、原則的に異っている。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反戦文学は、こゝに於て、戦争が何のために行われるか、その真相を曝露し、その真実を民衆に伝え、民衆をして奮起させるべきである。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、反戦文学の恒常性　　　　　　一　戦争反対の思想、感情を組織して、労働者農民大衆に働きかける文学は、戦争が行われている時にのみ必要であるか。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反戦文学の恒常性はこゝに存在する。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義制度が存在する限り、プロレタリアートの反戦文学も存在し、それに向って戦わなければならない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　反戦文学は、勿論、兵営や、軍隊生活のみを取扱う文学ではない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時に於ける、反戦文学の主要力点は、こゝに注がれなければならぬ。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七〇年安保への反対とベトナム反戦をテーマとしたデモへの参加体験。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "気がつくとピート・シーガーの「若者と老人」なんてレコードを引っ張りだして、このオレは「♪ブリング・ゼム・ホーム〜」とベトナム反戦のプロテスト・ソング（ああ、こんな言葉を十七年ぶりに思い出しちまったぞ！",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこの戦争の時期に「メーデー」とか、八月一日の「国際反戦デー」というような大きなカンパを前にして、彼奴等はどうでもこうでも党の力を根こそぎにしなければならなかった。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教の仮面をつけ、芸術のヴェールをかむって、反戦思想や敗戦主義を、感情的に、国民に瀰漫させる程危険なことはない。",
              "citation": {
                "source": "世界の裏",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一部過激学生の　反戦平和運動に利用されるからと云って。",
              "citation": {
                "source": "東大での話の原稿",
                "author": "一九五〇・十二月八日",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは必ずしも私が確固たる反戦の信念を持ちつづけたためではなく、たまたま病身のため、そのような題材をつかむ機会に恵まれなかつたり、その他諸種の偶然的なまわり合せの結果にすぎない。",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボルシェビキの反戦闘争は、大経営の中に確個とした根を下して進んだ。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨークの反戦デモに参加するばかりか、中野は三十年間転々としてアメリカであらゆる労役に従事していた間に、鉱山の大ストライキにプロレタリアとして夜も眠らず働いたことがある。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも毎日新聞（十二月十五日）では「反戦・反軍をあおる少年の犯罪が激増しており」それらの子供たちの「逮捕留置」が、いまの少年法では困難だ、と論じられている。",
              "citation": {
                "source": "修身",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東條内閣のとき、反戦・反軍をあおる「犯罪」というものがあった。",
              "citation": {
                "source": "修身",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "反戦・反軍ということと「犯罪」という観念とを直結した用語の方法のうちにこそ、一九五一年度の、日本人民の人権擁護の要石がむき出しにされている。",
              "citation": {
                "source": "修身",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「軍服」が字づらの反戦小説でないだけ、その具体性はつよく深く憤りまでつきぬけた人民としての作者の現実理解に裏づけられなければならないのである。",
              "citation": {
                "source": "小説と現実",
                "author": "――小沢清の「軍服」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に戦争反対の心がなかったかといえば、小田切秀雄の「反戦文学の研究」をみてもわかるとおり、いつもときの戦争に反対した人道的な精神はありました。",
              "citation": {
                "source": "戦争と婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "写実主義時代の日本の民主的な文学、浪漫主義時代の作家によってかかれた反戦的な作品は、ここに見当らない。",
              "citation": {
                "source": "「現代日本小説大系」刊行委員会への希望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "反戦的な短歌が少くない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事実が小説やルポルタージュに反戦文学の少いことの一つの理由である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "反戦的な文学　一九四七年の後半になって、やっと少しずつ日本の侵略戦争に対する批判を表現した文学作品があらわれはじめた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年には小林多喜二の「蟹工船」がかかれ、中野重治の「鉄の話」、黒島伝治の特色ある反戦的短篇があらわれたのもこの時代である。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六九（昭和四十四）年十月十日、ベ平連、全国全共闘会議、反戦青年委員会など新左翼系の四〇〇団体は、安保粉砕、佐藤訪米阻止などをテーマに、全国五三か所で統一行動を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
