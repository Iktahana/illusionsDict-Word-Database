[
  {
    "uuid": "4ca2a1f2-6d02-5748-9d36-a3265850b47c",
    "entry": "はっと",
    "reading": {
      "primary": "はっと",
      "alternatives": [
        "ハッと"
      ],
      "is_heteronym": false
    },
    "grammar": {
