    "definitions": [
      {
        "index": 1,
        "gloss": "grinding of the teeth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
