        "examples": {
          "standard": [
            {
              "text": "昔の雑誌をめくると、ハイレグの水着を着たモデルたちが華やかに誌面を飾っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女は自身のスタイルを強調するために、あえて大胆なハイレグの衣装を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "レオタードの裾がハイレグになっていることで、脚の動きが妨げられず運動しやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここで話は数十行にわたって大きくずれてしまうのだが、それにしても自動車レースなんぞに登場してくるハイレグにハイヒールという女性は、時と場所を選ぶという感覚をどこにうっちゃってしまっているのだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの悪夢を、けつを半分むき出しにしたハイレグにハイヒール（あのハイヒールがいかん、ハイヒールが）のねえちゃんを見るたびに思い出して、オレは「祇園精舎の鐘の声　ベンベン〜」などと唸りながら山寺の苔むした石にでもなってしまいたい心境になる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "撮影のあいだ、私は裸かハイレグのショーツ一枚でした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
