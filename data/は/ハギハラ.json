        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "便なき幼兒のうたへる歌萩原朔太郎うすらさびしき我が身こそ利根の河原の石ひろひひとり岸邊をさまよひて今日も小石をひろふほど七つ八つとなりにけり",
              "citation": {
                "source": "便なき幼兒のうたへる歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うすやみ萩原朔太郎うすやみに光れる皿あり皿の底に蟲かくれ居て啜り鳴く晝はさびしく居間にひそみて鉛筆の心をけづるに疲れ夜は酒場の椅子にもたれて想ひにひたせる我が身の上こそ悲しけれ",
              "citation": {
                "source": "うすやみ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪萩原朔太郎青くしなへる我が指のリキユールグラスにふるるとき生れつきとは思へども侘しく見ゆる爪形をさしも憎しと思ふなり",
              "citation": {
                "source": "爪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋日行語〔菊もうららに〕萩原朔太郎菊もうららに咲きいでたれど我身は砂丘に寄りて悲しめりさびしや海邊のおくつきに路傍の草を手向くることこのわびしきたはむれにひとり樹木にすがりつきたましひも消えよとむせびなく。",
              "citation": {
                "source": "秋日行語",
                "author": "〔菊もうららに〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "からたちの垣根萩原朔太郎からたちの垣根の中に女のはしやぐ聲のする夕餉の葱のにほひする灯ともしごろからたちの垣根を過ぐる侘しさよ。",
              "citation": {
                "source": "からたちの垣根",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅上萩原朔太郎けぶれる空に麥ながれ、麥ながれ、うれひをのせて汽車は行く。",
              "citation": {
                "source": "旅上",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷の塔萩原朔太郎塔は額にきづかる、螢をもつて窓をあかるくし、塔はするどく青らみ空に立つ、ああ我が塔をきづくの額は血みどろ、肉やぶれいたみふんすゐすれども、なやましき感傷の塔は光に向ひて伸長す、いやさらに伸長し、その愁も青空にとがりたり。",
              "citation": {
                "source": "感傷の塔",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷品萩原朔太郎ほつねんなれば魚にとへしんじつなれば耶蘇にとへ",
              "citation": {
                "source": "感傷品",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月蝕皆既萩原朔太郎みなそこに魚の哀傷、われに涙のいちじるく、きみはきみとて、ましろき乳房をぬらさむとする。",
              "citation": {
                "source": "月蝕皆既",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "情慾萩原朔太郎手に釘うて、足に釘うて、十字にはりつけ、邪淫のいましめ、齒がみをなして我こたふ。",
              "citation": {
                "source": "情慾",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いゆき萩原朔太郎青いぞ、ゆきはまつさを、もも、さくらぎに花咲かず、青いこなゆき、光る山路に泣きくらす。",
              "citation": {
                "source": "青いゆき",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼天萩原朔太郎いつしんなれば、あふむけに屍體ともなる、つめたく合掌し、いんよくいちねん、きりぎりす青らみ、もはら、雀みそらに殺さる。",
              "citation": {
                "source": "蒼天",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "靈智萩原朔太郎ふるへる、微光のよるに、いつぱつ、ぴすとるを撃つ、遠方に、金の山脈、かすかな、黒曜石の發光。",
              "citation": {
                "source": "靈智",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕佛萩原朔太郎つゆしものうれひはきえず、わづかなるつちをふむとて、あなうらをやぶらせたまふ。",
              "citation": {
                "source": "祕佛",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永日和讚萩原朔太郎ひとのいのりはみなみをむき、むぎはいつしん、うをはいつしん、われはしんじつ、そらにうかびて、ゆびとゆびと哀しみつれ、たましひはねもごろにほとけをしたふ。",
              "citation": {
                "source": "永日和讚",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎたる彈くひと萩原朔太郎ぎたる彈く、ぎたる彈く、ひとりしおもへば、たそがれは音なくあゆみ、石造の都會、またその上を走る汽車、電車のたぐひ、それら音なくして過ぎゆくごとし、わが愛のごときも永遠の歩行をやめず、ゆくもかへるも、やさしくなみだにうるみ、ひとびとの瞳は街路にとぢらる。",
              "citation": {
                "source": "ぎたる彈くひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬を待つひと萩原朔太郎こほれる利根のみなかみに、ひねもす銀の針を垂れ、しづかに水に針を垂れ、さしぐみきたる冬を待つ。",
              "citation": {
                "source": "冬を待つひと",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびよりかへれる巡禮のうた萩原朔太郎いすらへるよりかへり　われはゆきのうへにたちぬ",
              "citation": {
                "source": "たびよりかへれる巡禮のうた",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原朔太郎評論集　無からの抗争中原中也　萩原氏の本はよく売れるさうである。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで萩原氏は文学的苦労人である。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何故だか萩原氏を思ふたびに、次のポオロの言葉をくちずさみたくなる。",
              "citation": {
                "source": "萩原朔太郎評論集　無からの抗争",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もみぢ萩原朔太郎霜つききたり木ぬれをそむるとおもひしものを庭にあづまやの遠見をそめうすべにさせる魚をそめわかるるきみのくちをそめ",
              "citation": {
                "source": "もみぢ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春晝――敍情小曲――萩原朔太郎うぐひすは金屬をもてつくられしそは畔の暗きに鳴き菫は病鬱の醫者のやうに野に遠く手に劇藥の鞄をさげて訪づれくる。",
              "citation": {
                "source": "春晝",
                "author": "――敍情小曲――",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶萩原朔太郎記憶をたとへてみれば記憶は雪のふるやうなものでしづかに生活の過去につもるうれしさ。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵萩原朔太郎鶉や鷓鴣の飛びゆくかなたにふたたび白堊の城は現はれ　風のやうに消えてしまつた。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近日所感萩原朔太郎朝鮮人あまた殺されその血百里の間に連なれりわれ怒りて視る、何の慘虐ぞ",
              "citation": {
                "source": "近日所感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかまのはらにかむづまります、すめらかむつかむろぎかむろみのみこともちて、すめみおやかむいざなぎのみこと、つくしのひむかのたちばなのをどのあはぎはらに、みそぎほらひたまふときに……　八百万の神たちを念じておいて、それから次に、塩を撒きながら、「心身清浄の祓」を唱えました。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
