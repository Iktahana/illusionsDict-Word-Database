[
  {
    "uuid": "00e10085-706a-5717-8e55-1236c509d73e",
    "entry": "廃盤",
    "reading": {
      "primary": "はいばん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "out-of-print record",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "廃盤にしたのは、性急であった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけてもエリッツァの「歌の殿堂」は名盤の一つであったと思うが廃盤になっている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "聴いた面白さはコロムビアの音楽史には及ばないが、歴史的な取捨と配列の妙に至っては遙かにそれ以上で、研究者に与うる便益は甚だ大きいが、惜しいことに解説が粗雑で資料としての役目を果さず、そのうえ早く廃盤になって、今では手に入れることはおろか単に聴くことさえもむずかしくなっている。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに「レヴォルュショナル・シーン」の合唱が二枚あったが、それは廃盤になった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはフィンランドの保護をうけて売出されたもので特色的な良いものであったが、「交響曲第四番＝イ短調」ストコフスキー指揮のビクター盤と共に廃盤になってしまった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "コロムビアにも二、三枚サティのレコードはあったが惜しいことに廃盤になったらしい。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌劇は「スペインの時」の全曲近いものがコロムビアに入っていたが、惜しいことに廃盤になったらしい。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第三ピアノ協奏曲＝ニ短調」をホロヴィッツのピアノでロンドン交響管弦団の入れたのもあったが、これは廃盤になった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードはラフマニノフ自身とフィラデルフィア管弦団の組合せで入っていたが、廃盤になってしまった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "オネッガーの傑作「ダヴィッド王」のうち、日本コロムビアから二枚出ているが、無残にも廃盤になった。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に「ピアノ協奏曲」がガーシュウィンのピアノでコロムビアに入っていたが、廃盤になったらしい。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ビクター会社はどういうつもりか廃盤にしてしまったが、この節のことだから、いずれ再プレスをする時期があるかも知れない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても『愛の夢』を廃盤にさせたというのは、日本人がバックハウスを知らなさ過ぎたためではあるまいか。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ廃盤になったブラームスの『ヘンデルの主題による変奏曲』がよかったかも知れない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショパンの『バラード』が四曲四枚あったのは、いつの間にやら廃盤になっている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターは廃盤にしてしまったが、私は『クロイツェル・ソナタ』のレコード中で、五本の指に数えられる佳作であったと思う。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本コロムビアはシューベルトの『ソナタ＝イ長調』を廃盤にして、ヘスの名をカタログから除いたのは惜しいことだ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターの電気直前から少しずつ入ったが、大方廃盤になって、メンデルスゾーンの『春の歌』とエンゼンの『葉蔭にそよぐ風』一枚しかない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビクターが全部を廃盤にしたのは残り惜しくもある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ペトルシュカ』のピアノに編曲した『ロシア舞蹈』が入っていたが、廃盤になったらしい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "バトリのレコードはラヴェルの『博物史』（Ｊ七八六四）が興味の深いものであったが、コロムビアは廃盤にしたようである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "他にも良いものがあったが、廃盤になったらしい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも廃盤組の一人。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "代表的なレコードは、テナーのマルティネリーと歌った『アイーダ』の「さらば此世」（三〇四一）であったが惜しいことに廃盤になった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃盤になったものに良いのがある。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに廃盤になったのでは、ベルマスとネメスに私は愛着を感じている。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "レコードも良いものが大分廃盤になった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にジーリを好きな人は廃盤カタログをあさるがいい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気吹込みで廃盤になったものが十枚以上あるが、その中になかなか良いものがあった筈だ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポリドール会社は廃盤にしてしまったが、シュルスヌスの歌ったヘンデルの『ラルゴー』はこの歌のレコードの代表的なもので、前掲『アデライデ』と並ぶべきものであったと思う。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
