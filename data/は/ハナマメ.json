    "definitions": [
      {
        "index": 1,
        "gloss": "scarlet runner bean (Phaseolus coccineus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この四つ目垣には野生の白薔薇をからませてあるが、夏が来ると、これに一面に朝顔や花豆を這わせる。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花豆の赤い花が火のように見えた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣根に沿うて花豆の植ゑてあるのが見えた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れも自分の庭の隅に花豆を植ゑて置いた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自分の花豆は胚葉が出たばかりであるのに、此所の花豆はもう大きな暗緑の葉を三つづゝも擴げてゐた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して彼れは言葉につくせぬなつかしさを以て、垣根の花豆と底の淺い井戸とを思ひ浮べた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人の側らに坐つてゐるとき、私の思惟は濕ひにぬれ、胸はなまめかしい香水の匂ひにひたる。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "露はなる日の光、そがもとに三味はなまめき、拍子木の歎またいと痛し古き痍に、かくてあな衰のもののいろ空は暮れ初む。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには何処へも出たことのない女の身にはなまめかしい姿の瞽女に三味線を弾かせて夜深までも唄わせることがせめてもの鬱晴しであったからである。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言葉丈はなまめかしく馴々しかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはなまめかしい紅扇子。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、小べやのうちにはなまめいた几帳があって、その陰からちらりと容易ならぬ品がのぞいているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　言葉｜丈はなまめかしく馴々しかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　突然真紀子の前夫のことをそんなに云い出した久慈に、一寸真紀子はなまめいた眼差で笑った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の鋪道はなまめかしくどろどろに暑い。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新燈は或は水中の魚※の動作を明照して便宜なかも知れないが、その白布の蓋に被はれた光はなまめかしく余りに現代的で、麻炬の火が花を散らしながら煙を含んで赤濁し、闇夜の水上に異鳥を駆使して魚族を捕ふる鵜人の姿を照し出す怪美には若かない。",
              "citation": {
                "source": "三次の鵜飼",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうとう、盛子はなまめかしい発作を起して、房一につめよつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "扱帯の上部はなまめかしい衣裳の間にかくれて先は見えない。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれも、その時分にはなまめかしさの感じの方が強かつたのだが、年を取るに従つて、ぱつちりしてゐた瞳も曇り、眼のふちには眼脂が溜つて、見るもトゲ／＼しい、露はな哀傷を示すやうになつたのである。",
              "citation": {
                "source": "猫と庄造と二人のをんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれも、その時分にはなまめかしさの感じの方が強かったのだが、年を取るに従って、ぱっちりしていた瞳も曇り、眼のふちには眼脂が溜って、見るもトゲトゲしい、露わな哀傷を示すようになったのである。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかというのに、その人形にはなまめかしい香水とお白粉の匂いが沁み込ませてあり、行李の蓋を開けたとたんにそれがぷーんと警官の鼻を打ったのであった。",
              "citation": {
                "source": "日本に於けるクリップン事件",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなまめかしい細い声であった。",
              "citation": {
                "source": "嬰寧",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶっきら棒な調子だが、その眼にはなまめいた色が輝いていた。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の宿にはなまめかしさがある。",
              "citation": {
                "source": "山の宿海の宿",
                "author": "河井醉茗",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の身体はなまめかしいのだ。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "法事姿なので、強い色彩や濃粧は嫌っているが、一点の臙脂は唇に濃く、ほんのりと薄化粧を刷いた白珠のおもむきが、むしろ日頃の艶姿よりはなまめかしい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、上がり口から三味線や太鼓がみえるし、すぐ次の部屋にはなまめいた女の衣類などがぬぎ散らしてありますが、世帯道具らしいものは一点も見当らない。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
