    "definitions": [
      {
        "index": 1,
        "gloss": "defeat (in battle)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして真率｜朴訥という事から出て来る無限の大勢力の前に虚飾や権謀が意気地なく敗亡する事を痛快に感じないではいられない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗亡の苦い淋しさが、彼を石の枕でもしてゐるやうに思はせた。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で別れた白根行きの二人、帰途、この茶屋へ知らずに飛び込み、有繋の両人も孤屋の怪婆に吃驚敗亡、後をも見ず一目散に逃げ出したそうである。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが草木とならん日にたれかは知らむ敗亡の歴史を墓に刻むべき。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸子は其多数が比々として表白しつゝある不浄と敗亡と乱倫とを如何せんとするや。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "良策の用いられざるや、古今敗亡のそれこそ、軌を一にする処である。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼が天目山で死んだのは天正十年だが、武田はこの一戦で敗亡の形を現したのである。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お嬢さん、」と例の敗亡。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十分判らぬがオクゼは置くぞえで、海神いざこれから自分の持ち物を算盤に置くぞえと言いしを、山神オコゼ魚が自分の本名を知られたと合点して、敗亡したらしい。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣人藤太これを羨み、長者より薬を貰い、今出川中将夫妻らに謁して芸を演じ損じ不浄を瀉し、随身に打たれ血に塗れて敗亡した始末を述べたものだ。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど夜這いに往って熊公じゃねえかと呼ばるると褌を捨てて敗亡するごとく、南無阿弥陀仏の大聖不動明王のと名号を唱えらるると、いかな悪人をも往生せしめ、難を救わにゃならぬ理窟だ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "その弱味に付け込んで、さあ長城を築くぞと囃し立てると、かれらはびっくり敗亡して、たちまちに姿を隠すのであると伝えられている。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや驚いたのなんのって、あの時こそびっくり敗亡し、時行グーの音も出ませんでしたよ」かえっておかしそうに笑ったが、「二本の巻軸島原の手から、やっと取りあげて帰宅してみれば、百人余りのおさむらいさん、なんの苦もなく拙者を捕縛、たたっ込んだは地下の牢屋『どうだ天草、参ったか！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆｜一溜りもなく敗亡する。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助はかつて、是を敗亡の発展と名づけた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方の波風靜にして、世は盛りとこそは見ゆれども、入道相國が多年の非道によりて、天下の望み已に離れ、敗亡の機はや熟してぞ見えし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四五年八月十五日から植民地在住の日本人にあらわに思い知らされた敗亡する侵略者としての足どりは、それらの人々にいってみればさか恨みの感情をもたせたとも思われる。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよは、額の隅を掻いて敗亡を示した。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自國の敗亡に臨んで、恬として之を返り見ないものゝ樣に、敵將ナポレオンと相見へて快談した、ゲーテの意氣は諸君も知つて居られよう。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの一派の民権論者は西郷の敗亡とともにほとんどその跡を絶ち、あるいは官途に入り、あるいは実業に従い、またあるいは零落して社会の下層に沈没し去れり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "快活的の一派はこれに反してますますその勢力を博し、当時西郷の敗亡を袖手傍観したる板垣氏はひとり民権派の首領たる名誉を擅にして、政界の将来に大望を有するに至る、これを十年十一年の交における政論の一局状となす。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く敗亡て、ホウとなって、殆ど人心地なく臥て居た。",
              "citation": {
                "source": "四日間",
                "author": "ガールシン",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、祖国を敗亡から救うかもしれない一人の巨人が、いま、梶の身辺にうろうろし始めたということは、彼の生涯の大事件だと思えば思えた。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "久内の敗亡を、作者は是認するや否や。",
              "citation": {
                "source": "「紋章」の「私」",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵の用意整へるを待つて、堂々と戰を開いたが、却つて宋軍敗亡いたし、襄公自身も痛手を負ひ、遂に之が爲に落命したことがある。",
              "citation": {
                "source": "支那人の文弱と保守",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度人・ビルマ人・シャム人・安南人・支那人・南洋人等は、何れもこの活動寫眞――實際以上に露軍敗亡の有樣を映寫してある――を見物して、數十百年來の溜飮を下げた。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那は日清戰役の敗亡に續いて、列強から要害の地を租借せられ、或は擧國瓜分の厄に罹らんとする形勢であつた。",
              "citation": {
                "source": "東洋史上より觀たる明治時代の發展",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
