    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be seen from the point of view of an onlooker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早く手廻しをすればよいのに、元日になってから慌てて書き始める、そうして肩を痛くし胃を悪くして溜息をしているのが、傍から見ると全く変った道楽としか思われないのであった。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍から見るとむごたらしいほどに手厳しく仕込んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっとしのび足で店に這入って、片隅の小僧が居る方へ行き、他人が見ている柄を傍から見る。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "當人は至極眞面目なのだらうが、傍から見ると、隨分片腹痛い場合がある。",
              "citation": {
                "source": "文藝中毒",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "義憤の當否は措いて、何に寄らず、けしからんけしからんを連發するのは、傍から見ると可笑しい。",
              "citation": {
                "source": "當流比較言語學",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍から見ると、直ぐにもうキの字だぜ、恐るべし、恐るべし。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母は、語尾に傍から見ると、実に異様な力を込めて云ひ放つた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は傍から見ると不機嫌そうに見えた。",
              "citation": {
                "source": "「禰宜様宮田」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも傍から見るんだなあ。",
              "citation": {
                "source": "染吉の朱盆",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして僕も寝ている時は、傍から見ると、やはりこう苦がない顔をしているのだろうかと考えなどした。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍から見るとまるで狂人としか思えない挙動をその場であえてした彼は、同席の一人残らずから、全くの狂人と信じられたのを見すまして、心の内で図に当った策略を祝賀した。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが青竜王は、傍から見るほど楽しく踊っているわけではなかった。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいたずらに自分たちだけを優越せる地位に置き、業界に対して絶対的、専制的な支配力を揮わんとして、そのためには、いかなる形においてか握った権力を放すまいともがいている……その有様は傍から見ると気の毒なくらいである。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "がその行為言動が、傍から見ると矛盾になっている。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思っている兄の方が、傍から見ると、もうそろそろ神経衰弱の結果、多少精神に狂いを生じかけて、自分の方から恐ろしい言葉を家中に響かせて狂い廻らないとも限らない。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は比較的堅固でない椅子の上に、わざわざ両足を載せて胡坐をかいたなり、傍から見るとさも窮屈そうな姿勢の下に、夷然として落ちついていた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところを生れ得て恭謙の君子、盛徳の長者であるかのごとく構えるのだから、当人の苦しいにかかわらず傍から見ると大分おかしいのである。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍から見ると、二人共丁度雲を踏むようでしたよ」「それからどうしたんだ」　平次は心せく様子で先を促しました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "死病っていうものは、傍から見ると、一目で分るものですってねえ。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほどに、裸の男の水浴びは、傍から見ると気狂いじみて見えた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
