[
  {
    "uuid": "0d4d0f95-2c13-56a9-b8fa-cfed7ecf67df",
    "entry": "覇気",
    "reading": {
      "primary": "はき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
