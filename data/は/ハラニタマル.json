        "examples": {
          "standard": [
            {
              "text": "この丼ものはご飯の量が多すぎて、一つ食べると腹にたまる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ラーメンと餃子のセットは、かなり腹にたまる組み合わせだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒い日には、温かい鍋料理が腹にたまって体が温まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さうして成程腹にたまる水はかういふ色をしてゐねばならぬ筈だと思つた。",
              "citation": {
                "source": "郁雨に與ふ",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆布茶は、少し、腹にたまるがうまい物だし（ヨードは確高血圧にも、よかったと憶えている）。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹にたまるようなものは避けたがよい。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹にたまるまでのたくさんの分量は出さぬので、どうしても味をおいしくする必要があり、甘味なども少しずつこの方面から加わってきたのだが、それでもまだ田舎には、ちっとも甘くはないお茶の子、どちらかというと少しまずいお茶の子がのこっている。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
