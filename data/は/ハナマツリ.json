    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Buddha's birthday festival (April 8th)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私どもには、何う考へても、譬へば、三河の花祭りに於ける神楽の断片が、ゆまはり・きよまはりの合理的解釈なる、生まれ清まりにあるとする様な系統の考へ方は、神楽そのものにとつては第二次の変化だと思はずにはゐられないのです。",
              "citation": {
                "source": "神楽（その一）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真中にあたる道が、丁度花祭りの行はれる三州北｜設楽の村々を通つてゐるので、極僅かな傾斜を登ると、すぐ信州領になつてゐます。",
              "citation": {
                "source": "信州新野の雪祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花祭り」号の後に「雪祭り」号が出る事は、感じの上で、まことに快い事だと、我々も思ひます。",
              "citation": {
                "source": "信州新野の雪祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三州北設楽の花祭りと比べても、非常に似た部分が多い様です。",
              "citation": {
                "source": "信州新野の雪祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此翁に就いては、鳳来寺・田峯、或は花祭りのものと、比較研究の興味があります。",
              "citation": {
                "source": "信州新野の雪祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、かうしたはだれの時に三河を歩いたのも、又三河の花祭りを知つたのも、皆早川さんの手引きでございました。",
              "citation": {
                "source": "三河の山村",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小正月を控へた残雪の山の急斜面、青い麦の葉生えをそよがしてゐた微風、目ざす夜祭りの村への距離を遠く感じさせる笛の響き、其後幾度とも知れぬほど、私どもの花祭りにあひに出かける心の底には、此記憶がひろがつて居るのです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年ほど此方、初春にさへなると、三・信・遠、三州の境山へ、ものにおびかれた様になつた訣は、この「花祭り」の作者早川さんが、最よく呑み込んでゐられるはずです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花祭りにもさうしたつき物の力が、籠つてゐる様な気がしてなりません。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花祭りを思ふ毎に、此大和絵かきの懐しい話しぶりを憶ひ浮べずには居られません。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私などの花祭りに関する乏しい知識は、隅から隅まで、此人の東道によつて、とりこんだものと言はねばならぬ。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花祭りに、「ねぎばな」と「法印ばな」とがあり、其が、設楽の奥山家に、昭和の代にも繰り返されてゐる。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此雪祭り見物の宿願と、その後、早川さんに唆られた花祭り採訪の欲とが、道順によい日どりも続いてゐる事を知つて、もう圧へることが出来なくなつたのでした。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "設楽の山村の、寒く霞んだ夕を、静かに見おろした其夜を徹して、翌日昼まで見続けたのが、私にとつて、初めての花祭りの行事でありました。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の此文章が、必しも花祭り及び山の神楽の本義を説き得て居ないかも知れません。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の神人団体一　問題の土地花祭りを行ふ村々は、早川さんの、細密な報告が既に明らかにして居る様に、此設楽だけでも二十所ばかりあります。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "南、北設楽郡を中心に、信・遠の国境一帯の山間には、啻に花祭りがあるばかりではありません。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、設楽といふ地名には頓著なく、此花祭りの這入つて来た時期を漠然と考へて見ます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、三河の山奥に傭兵の村――其は同時に神人団体であつた――があつて、こゝから多くの人が出かけて行つて、諸方の武家に力を貸した、其残りが花祭りの村々であると、かう考へるのです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三河に残つてゐる花祭りも、今は正月に行ふ所が多く、所によつては十二月にも行ひますが、元はやはり霜月の行事でした。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が三河の山奥に花祭り行事の残つた一つの原因だと考へるのです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、現在の花祭りが残つた原因は、単に、其だけではない様です。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近世に於ける移動一　伊勢神楽の影響私は、最初花祭りを見ました時には、以上述べて来た様な事を心に浮かべて、単にそれだけの興味と、一種の尊ぶ様な気持ちとで此行儀を見て居たのですが、尚よく考へて見ますと、其うちには、割り合ひに近世らしい移動のあとが見られます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　設楽神楽の輸入者早川さんの調査によつて訣つたのですが、こゝには元、三日三夜に亘る神楽があつたので、現在の花祭りは其一部分であると言はれてゐるのです。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "此を二人と伝へるのは、神楽・花祭りを通じて、みるめの王子・きるめの王子といふのがありますので、其から二人と言ひ出したのだと思ひます。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局これは、山人の職業を、其後幾度か人が変つて受け継いでゐる中に、最後に伊勢の神楽が這入つて来た、さうして以前からあつた花祭りを習合する様になつた、かう考へて見るのがよい様です。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "花祭り行事の主なる問題一　花祭りを行ふ人々――禰宜・山伏・行者話は愈花祭りに這入りますが、現在行はれて居るものを見ますと、純粋に花祭りだけを行うて居る所、田楽を兼ねてゐる所、まう少し不純な芸能を兼ねてゐる所などがあります。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした春の農作物祝福の祭りの系統を、はなまつりと言ふ。",
              "citation": {
                "source": "鬼の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
