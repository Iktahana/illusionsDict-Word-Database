        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "涎と鼻くそと手垢をこすりつけ、なぜかそうして満足し野方図にはしゃぎまわった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろあなた、後向きでもお客様の鼻くそをほじる音まで聞き分けるてえ驚きいつた天才でさア」　酔客のケンケンガクガクずらりと並んだあちら側を、首だけだしたオバサンがお盆を目の高さに捧げ持つてナメクヂの速度で往復してゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻くそをほじって居るのがいかにもじじいらしく哀れ、又腹立たしかった。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら鼻くそをほじつてもいかんと云ふのか？",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから眼くそが鼻くそを笑うことは出来ない筈である。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と対坐しながら鼻くそを丸める。",
              "citation": {
                "source": "くせ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　良寛の鼻くそでは、逸話がある。",
              "citation": {
                "source": "くせ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛は、たんねんに拵えた丸薬大の鼻くそを、場所がら飛ばしかねて、右にいる人の袂へ、そっと、こすりつけようとしたが、その人が、袂を引いたので、今度は左側の人の袖へ持って行った。",
              "citation": {
                "source": "くせ",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の諺にもし類似を求めるならば、「目くそ鼻くそをわらう」に当るだろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺本支配人、しぶ／″＼鼻くそほどの特賞を出した。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おやっ――此奴」　又八は、踏み蹌いた足を、草履の緒へかけ直すと、尻込みする城太郎へ、物々しい肩を昂げて、「なんだか、見たような鼻くそだと思ったら、てめえは北野の酒屋にいた小僧ッ子だな」「大きなお世話だ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このチビ」　掴みかかると、城太郎はすばやく、牛の鼻先から向う側へ逃げ廻って、「おいらが鼻くそなら、自分なんか何だい。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "書斎をひらけば、独座、鼻くそを掘りつつ、雲を見ているか、毛脛を撫でているかぐらいなものである。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稚子輪に結った髪も、曙染の袂も、金糸の繍も、紫濃の袴も、みんなお揃いであったが、元より山家の生ればかりなので、その袂で汗は拭く鼻くそはこする、せっかく化粧して貰った白粉も、黛も、かえってお道化たものになっていた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから蛾次郎、鼻くそをほじりながら、背のびをしてのぞきこんだ。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど直ぐ戻ってくると、鼻くそを抛るように云った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "於虎は、彼の威嚇にすこし恐れをなしたらしく、悄れ返って従いて行ったが、指の先にまろめていた鼻くそを、於市の襟元へポンと弾いて、くすりと口を抑えて笑っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ばてれんが来たよ」「ばてれんが行くよ」「きれいな鳥籠持って、南蛮寺の坊んさんが通るよ」　ひん曲った板屋廂の下や、荒壁と荒壁の路地のあいだから、この界隈の子達が、あせもだの腫物だの、鼻くそ光りの顔をもって、羽の強い虫みたいにいま飛び出して来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "小僧、鼻くそくうかあ　こういう幾分か教訓味を帯びた、軽い嘲笑に解釈した土地もあったけれども、終始は意地の悪い、殊に子供を嚇そうとする鳥として、わざと家庭用に残して置いたかと思う地方が多かったのである。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "比較的多く行われているのは小僧鳥てあるが、それでも「鼻くそ」を「かなくそ」といって見たり、また「かれくそ食うか」という処もある。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "やせ馬（二月十五日）　二月十五日の涅槃の日に作る食物に、釈迦の頭だの、おしゃか様の鼻くそだのというのがあるのも解しかねるが、それよりもさらに縁がなさそうに思われるのは、信州などに行われるヤセウマという団子である。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし貧農的要素と彼らとの間に對立が起れば、その對立は避けるべきではなくその結果組合の數的勢力が微弱になつても仕方がないと杉村は考へた。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは何ら他の物から成立ったのではなくそれ自身に永遠の物である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それはストリヒニンではなくそれよりも遥かに強いアコニチンという猛毒がはいって居るそうだ。",
              "citation": {
                "source": "卑怯な毒殺",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この意味に於て幾何学的空間と物理的空間とは単に区別されるばかりではなくその間の関係が全く断たれるとさえ云わなければならなくなる。",
              "citation": {
                "source": "物理的空間の成立まで",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "今茲に可能である二つの場合は、この関係そのものが何の特殊の存在をも有つのではなくその故にこそ夫を概念であると考えるか、或いは又そうではなくして、それが或る特殊の存在を有ち、そしてかく存在する、関係に就いて我々が関係という概念を有つか、二つである。",
              "citation": {
                "source": "範疇としての空間に就いて",
                "author": "――之は一つの習作である――",
                "note": "青空文庫"
              }
            },
            {
              "text": "純文学的の立場からではなくその小説を一読した女性の一人として、大体の筋の紹介と、簡単な感想を述べたいと思います。",
              "citation": {
                "source": "「母の膝の上に」（紹介並短評）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからいつとはなくそのことは忘れていった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三角点は一番高いところではなくそこから北の方に一町くらい離れた向うの山の瘤のようなところにありました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それも所詮かなわぬことであるなれば、せめて「詩人」とは書く人ではなくそれを読む人を言ふといふことになつてはみぬか。",
              "citation": {
                "source": "障子のある家",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
