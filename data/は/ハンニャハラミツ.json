[
  {
    "uuid": "9ddf6fac-aae1-5531-b97c-62794371880c",
    "entry": "般若波羅蜜",
    "reading": {
      "primary": "はんにゃはらみつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
