[
  {
    "uuid": "afd9b1f0-8342-5448-97d2-e03e6de96016",
    "entry": "発破",
    "reading": {
      "primary": "はっぱ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
