  {
    "uuid": "42476761-d4c1-5dff-9029-5e496897176b",
    "entry": "八々",
    "reading": {
      "primary": "はっぱ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eight times eight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八々のような金銭を賭ける遊びごとは品が悪いと言って母は許しませんでした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして左門を籠絡して、八々の手ほどきをした。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大砲の音やガス容器の爆発の音などとは全くちがった種類の音で、しいて似よった音をさがせば、「はっぱ」すなわちダイナマイトで岩山を破砕する音がそれである。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "にょきにょきのびて、しだいにはっぱをつけました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川にハスのはっぱがあっただわさね。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶあつい緑のはっぱが水面近くについていたので、水面に浮かんでいるように見えました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん遠いところにあるはっぱが、いちばん大きいはっぱでした。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "家でねていたと思っていたのに、小川に浮いた大きな緑のはっぱの上にいたのですから。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "母ガエルはかざり終えると、みにくいむすこを連れて、はっぱの上に一人でいるかわいそうなおやゆび姫のもとへ泳いでいきました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑のはっぱの上に座ってしくしく泣きました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」メダカたちははっぱのくきのまわりに集まりました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっぱはフワッと水面に落ちて、川を流れていきます。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆび姫は、はっぱに乗ってどんどん流されていき、ついによその国へ来てしまいました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく飛びつづけたあと、はっぱの上にとまりました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆび姫は腰のリボンを取り外して、はしをモンシロチョウにぐるぐる巻きつけて、もう一方のはしをはっぱにしっかり結びつけました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっぱは今までとくらべものにならないほど速く、水面をスーッととはしりだしました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑のはっぱはモンシロチョウと小川を下っていきました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっぱにきれいなモンシロチョウをくくりつけてしまったからです。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "コガネムシはそんな気持ちをおかまいなしに、おやゆび姫を木の中でいちばん大きなはっぱの上に乗せました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆび姫は食べ物のかわりに花のミツをすい、毎朝はっぱから落ちるしずくでのどをうるおしていました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆび姫はかれたはっぱにくるまりましたが、真ん中にひびが入っていてすきまからぬくもりが逃げていきます。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "五両ありゃ、はっぱ者なら一年がとこのうのうとして居食いができるんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッシェンプッテルはほかにかくれるところも見つからないので、だれにも見られないうちにと、木のはっぱの中へかくれてしまいました。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるとしの　あきは　きのみも　たわわ、　ハシバミの　やぶでも　はっぱが　きいろに　みどり　――　ナトキンと　チンクルベリは　おおぜいの　こどもりすと　いっしょに　もりの　そとへ　でて、　みずうみの　ほとりへと　むかいました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "カブトムシは　１ぴきずつ　ギシギシの　はっぱで　ていねいに　くるんで、　マツバを　さして　とめてありました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに　ひきかえ　ベンジャミンは　まったく　わがものがおで、　レタスの　はっぱを　かじります。",
              "citation": {
                "source": "ばにばにベンジャミンのはなし",
                "author": "THE TALE OF BENJAMIN BUNNY",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは　まるく　みどりの　こぶねで、　まるで　ふつうの　スイレンの　はっぱと　みわけが　つきません。",
              "citation": {
                "source": "つりびとジェレミーさんのはなし",
                "author": "THE TALE OF MR. JEREMY FISHER",
                "note": "青空文庫"
              }
            },
            {
              "text": "きづいたら　トランプは　ただ　きから　おちてくる　はっぱに　なってて、　かぜが　びゅーんて　かおのほうへ　ふきおろしてきててね。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿の葉を、おさとうのはっぱだと、小さいおとうさんはいっていたという話を、いつかきいたことがあります。",
              "citation": {
                "source": "柿の木のある家",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
