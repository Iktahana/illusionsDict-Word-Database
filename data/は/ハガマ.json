    "definitions": [
      {
        "index": 1,
        "gloss": "broad-brimmed cooking pot for rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大学校は、やっぱり大学校で、教授たちも、巡回視学官の私などが行ったからと云って、あんまり緊張をするでもなし、少し失敬ではありましたが、まあ私はがまんをしました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりすばらしいので、とうとう、イーダちゃんはがまんができなくなりました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊次さんも、米を踏んだのは自分だけではない、雲華寺の和尚さんが仲間であると思ふと、足の痛みも少しはがまんができました。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通五六十本の薪があれば、完全に焼けることになっているが、もう予定の薪は焚いてしまっても焼けないので、隠坊はがまんしきれなくなって、傍にあった漁師用の手鍵を執って死体の腹へ打ちこんだ。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしはがまんしなければね。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて、書く際にはがまんできる巻紙環境を読む際もそのまま流用してきたことで、画面上で読むという行為はかなりつらいものになってきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手間をとらせると、おれはがまんしてもこっちの伝六あにいが許すめえぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "廟の前にはがまのような形をした大きい石が蟠まっていて、その石の上に張訓の兜が載せてあった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、伝書鳩第一号はがまんをして、とうとう自分の鳩舎にたどりつきました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎はがまんするの。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ直き、お目に懸れるのですから、一日や二日位はがまんします。",
              "citation": {
                "source": "書簡　大杉栄宛",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはがまんするさ。",
              "citation": {
                "source": "くらげのお使い",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者はがまんができなくなって、とうとうあぶをつかまえて、さっきのわらでおなかをしばって、木の枝の先へくくりつけて持っていきました。",
              "citation": {
                "source": "一本のわら",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はがまん強く笑って来ました。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけのわからぬところへ使いに行くのはがまんがならないのだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに好きになりたいと思っても、あの桶の音をきいているのはがまんが出来ないのだそうです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はがまん強くよく笑って来ました、旅へ出たら、当分田舎の空や土から、健康な息を吹きかえすまで、働いて来るつもりです。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か私の胸の中にうごめいて居るもののある様にこみあげる笑いが私の頬に一人手にさし込んで来る、思って居る事をずんずんはこんで行かなければならない、三学期は短かいから学校のあるうちだけはがまんしようかとも思う。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きな力にひきずられて私はがまんして居るのだ。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　文子はがま口をあけて銀貨を掌に数えた、一枚二枚三枚……。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、またさーっと吹いてくる風が、顔をなでて、目かくしのハンケチの下の耳もとで、「ばかー、ばかー……」　マサちゃんはがまんしました。",
              "citation": {
                "source": "風ばか",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐわあは之と別に成り立つた語で、古くはがまであつたらしい。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "長いあひだはいらないものですから、身体中にしみて、お猫さんはがまんが出来なくて泣きました。",
              "citation": {
                "source": "お猫さん",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはやり切れない」空腹はがまんできるが寒いのはやり切れない。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "らしい、らしいの話ばかりで、正確なことはわからないのが残念だが、いずれ町へかえってから、ハイロにたずねなおせばいいであろうと、三根夫はがまんした。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもうこの上はがまんが出来ないのだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から声をかけたくて、しかたがなかったが、博士におこられてはたいへんと、先生はがまんして、あとからついていった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう、おかあさんはがまんがしきれなくなって、あるとき、腹だちまぎれに女の子をぶちました。",
              "citation": {
                "source": "三人の糸くり女",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧乏にはがまんできたし、こういう困苦も、自分の美徳を賞め讃えるものであるなら、それを誇りとしたところだが、トルコ人の忘恩と愛するサフィーの喪失は、それ以上につらい、取りかえしのつかない不幸であった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
