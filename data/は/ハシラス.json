[
  {
    "uuid": "aacfa88a-9a3d-5b6a-b7be-62425bd0c7e8",
    "entry": "走らす",
    "reading": {
      "primary": "はしらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
