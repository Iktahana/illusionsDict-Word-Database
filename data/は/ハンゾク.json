        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "公は罪を宥し位に敍せらる、南洲は永く反賊の名を蒙る、悲しいかな。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "「反賊、運のつきだぞ」「こころよく天誅をうけろ」　猛然、迫ってきたものこそ、まさに味方とたのんでいたその二人にまぎれもない。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "反賊仲達、その首をさずけよ」　蜀の姜維は、やにわに槍をすぐって、孔明の車の側から征矢の如く追ってきた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
