        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嫉妬に燃える女性の般若面のような形相に、彼はたじろいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "怒りや悲しみが極まると、人は般若面のような表情になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「そんな般若面みたいな顔をしてどうしたんだい？」と友人が心配して尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
