[
  {
    "uuid": "eb77b4a1-7671-5cd4-8062-ae9c86c5f321",
    "entry": "初湯",
    "reading": {
      "primary": "はつゆ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "first bath of the year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おなじく二日の夜、町の名を言ひて、初湯を呼んで歩く風俗以前ありたり、今もあるべし。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて楽しみにした初湯にと手拭を下げて浴室へ下りて行った。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには母親が、畳の上に桐油を敷き詰めて、盥に初湯か湯灌かの加減を見ていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日は初湯、初荷、買初、弾初、初夢など江戸ッ児にとっては事多き日である。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃありゃありゃありゃ、ソレソレソレソレ」　掛声と一緒に据風呂桶を次第に高く持ち上げたが、ヌッと裾から顔を覗かせると、「一夜明ければ新玉の年、初湯を立てようと存じやしてな、風呂桶を借りて参りやした。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで何と滝沢氏、明日は是非とも年始がてら初湯を試みにお出かけ下され。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はともあれ初湯一風呂さあさあザッとお召しなさりませ。",
              "citation": {
                "source": "戯作者",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉のバラーをシチュウにしてもその通りですがこれは最初湯へ入れてから二時間ほど煮て野菜を加えてまた一時間煮ます。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがどうした苦労であつたか、語らうなぞとはつゆさへ思はぬ。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも騙すにしても、その理由はつゆも思いつかないが。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヌンチヤタが上はつゆばかりも聞えざりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "結納の交されし日も宮は富山唯継を夫と定めたる心はつゆ起らざりき。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "子を生みし後も宮が色香はつゆ移はずして、自ら可悩き風情の添りたるに、夫が愛護の念は益深く、寵は人目の見苦きばかり弥よ加るのみ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに兩人ともツイ二三年前までは私の母が引取つてこの家で育てゝ居たので他の山家の娘連中同樣の賤しい風采はつゆほども無かつた。",
              "citation": {
                "source": "姉妹",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあなたのお傍にゐましても、楽ばかりいたしたいとはつゆ思ひませんけれど、また苦しいことや悲しいことをゆめ考へたこととてございません。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は春での、小石はつゆのしたたりそうな葡萄と同じ色になって居りまいた。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の作家たちに拮抗してゆこうなどとはつゆ思わないけれども、せめて、もう一段背のびをしてみたいと思っている。",
              "citation": {
                "source": "生活",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい文学的作意が多少あったにせよ、畢竟「文学以前」のもので、文学の過剰などはつゆほどもない。",
              "citation": {
                "source": "文学以前",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "内部から酔っていくたちの者には用心の必要は少いと、前に述べておいたが、そればかりでなく、中江と村尾との間には、互に用心しなければならないような相対的用件はつゆほどもなかったし、彼等の様子が明かに示しているように、二人は多年の知友で、偶然落合って「一杯やる」ことになったまでである。",
              "citation": {
                "source": "慾",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば不思議な縁でおじゃるが、その時には姫御前とはつゆ知らず……いたわしいことにはなッたぞや、わずかの間に三人まで」　母はなお眼をみはッたままだ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しながら碧色の草花の中で、彼はつゆ草の其れに優した美しい碧色を知らぬ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心ではつゆほどもそんなことを思ってはしなかったのだ。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "14　恐しい日　窓の外に、そのような椿事がひきおこされているとはつゆ知らず、天文研究所では、蟻田博士と新田先生とが、しきりにむずかしい勉強をやっていた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　歩いて行く中、春子が二、三歩先になった隙を窺って、重吉はつゆ子の側に寄り、「深沢とみ子ッていうのを知りませんか。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはつゆ子さんのはなしを聞いてびっくりしました。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この原謡を『潮来図誌』で見ると、その末句の方が「あやめ咲くとはつゆしらず」となっている。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までこんなにも自分は、この腹違いの弟がひとすじの強い強い心を内に持っていようとはつゆしらなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "が――しばらく待っていただきたい、あれほど焦れに焦れて止まなかった落語家という世界に飽きだして小圓太、日夜を儚みだしたのではつゆ更ないのだから。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな原因から幕を下ろし、囃し立てているのだとはつゆ知らないで、陽気な囃子の音色にボンヤリ聴き入っていたろうその晩のお客たちの顔を思うと、じつにおかしい。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もかくの如きは人の多く自覚せざる所、いはゆる知らず識らずの間にかくなりゆくものにして、自らはつゆばかりも私情を挟まざる公明なる理論をなすと確信しをるなり。",
              "citation": {
                "source": "仏教史家に一言す",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "first bath in one's life (i.e. for a baby)",
        "register": "standard",
        "nuance": null,
