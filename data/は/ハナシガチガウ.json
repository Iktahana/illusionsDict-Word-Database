    "definitions": [
      {
        "index": 1,
        "gloss": "to be different from what was previously said",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何、そんな処にお浦が居るか、と……詰らん事を――お浦の居処は居処で話が違う。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし野良調子を張上げて田園がったり、お座敷へ出て失礼な裸踊りをするようなのは調子に合っても話が違う。",
              "citation": {
                "source": "おばけずきのいわれ少々と処女作",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "閣下それではお話が違うではありませんか」　ミルキ夫人は狂人のようになって扉をドンドンと叩いた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私のいうところの余裕はあくまでも豊かな心からのみ生れる余裕のことであつて、客観的情勢によつて現われたり消えたりする安ものの余裕とは話が違うのである。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それじゃまるで話が違うがな。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはちと話が違うでしょう。",
              "citation": {
                "source": "仙人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、同志の士は皆妻子を離別してきたというが、それとこれとは話が違う。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "（困って）第一、どうしろ、こうしろと言う話と話が違うじゃありませんか。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おいおい、金を持って来れば、売ると言ったのに、それじゃあ話が違う。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもわたしの聞いたところじゃ、版籍奉還ということはだいぶ話が違う。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きに話が違うので出かけて行き「お墓参りはあなた一人ではないのですか」と質ねると、「この人は赤坊が生れた時から知っているし、この人には病気の時親切にして貰ったし、この子は母親と一緒に行きたがって承知しないし……」という長話が始まった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねおい、銭形の、若いくせに耄碌をしちゃいけねえ」「それは話が違うだろう、爺さん」　平次も今さら驚きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "御落胤殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアの党のないところに、プロレタリアの乃至プロレタリアの党の文化はあり得ない、というような場合と、多少話が違うのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の頬を張るなんて話が違うじゃないか。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本で店を開いていたとか、同じ時期に別府で温泉療養していたとか、伯母が死んだのも終戦直後だったとか、昭和三十年頃だったとか、しゃべる度に話が違うんだよ。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、室内楽、ピアノ、管弦楽などは話が違う。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかもしれないが」と彼は不決断に云った、「それとこれとは話が違うから」「あの三人は先生のことをよく知っていますよ、海石のことも、豊島屋のことも、日済し貸しのことも」とおみのは云った。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その友人は、話が違うが、私たちにまたこんなことも言った。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は仲人を物色する為めに関係を悉皆調べたんだ」「それじゃ少し話が違う」「ハッハヽヽ」　と安達君が笑い出した。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
