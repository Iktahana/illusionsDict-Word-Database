        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "即ち彼の自殺は、勝利によつての自殺で、敗北によつての自殺でないといふことである。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗北に享楽したことがなかったか。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作を説明するという事は、既に作者の敗北であると思っている。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、日本は大敗北を喫しました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが血のように赤く鮮明に印象されることは、心の傷いた空虚の影に、悔恨の痛みを抱きながらも、悲壮な敗北の意気を感じさせずにいなかったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、弱さ、かね」とＹ君に、笑はれても、私は抗辯することもできず、かの赤犬の出現以來、もう、めつきり氣が弱くなつて、それからの議論は、ことごとく私の敗北になりました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチ山　カチカチ山の物語に於ける兎は少女、さうしてあの慘めな敗北を喫する狸は、その兎の少女を戀してゐる醜男。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その適さない道具を以て出發した僕等の歴史は、新體詩の出發以來あらゆる敗北のしつづけだつた。",
              "citation": {
                "source": "悲しき決鬪",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "攻勢の華やかな時代にプロレタリア文学があって、敗北の闇黒時代に、それぞれちゃんと生きている労働者の生活を書かないのは、おかしな話だ。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山東軍は散々な敗北でしゅよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗北した軍隊は、雪崩を打ってこの古い都済南へ総退却した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、僕はこの敗北の告白をも、この小説のプランのなかにかぞへてゐた筈である。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは作家の敗北である。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んという、簡単な敗北を見なければならないだろう。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からは皆三の憤怒に歪んだ顔が現われ「ばか――」　と叫ぶのだが、その語尾はおろおろ声の筋をひいて彼自身の敗北を示していた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "露国は陸にあつては予定の退却、海にあつては絶間なき圧迫を受けて、世にも見苦しき敗北を遂げたり。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪さんが、抱いたり、擦ったり、半狂乱でいる処へ、右の、ばらりざんと敗北した落武者が這込んで来た始末で……その悲惨さといったらありません。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の根氣くらべは、遂に父子爵の敗北となツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "カチカチ山　カチカチ山の物語に於ける兎は少女、さうしてあの惨めな敗北を喫する狸は、その兎の少女を恋してゐる醜男。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "権利がなくつて負けるのはまだしもだが、権利がある上に負けるのは二重の敗北である。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓からは皆三の憤怒に歪んだ顔が現はれ「ばか――」　と叫ぶのだが、その語尾はおろ／＼声の筋をひいて彼自身の敗北を示してゐた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは別に、クリスチャンではないが、しかし日本が聖書の研究もせずに、ただやたらに西洋文明の表面だけを勉強したところに、日本の大敗北の真因があったと思う。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンニングは不名誉に非ず、落第こそは敗北の基と心掛ける事。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕力の弱い男子は、永遠に世の敗北者です。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗北の歌　曳かれものの小唄という言葉がある。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全に私の敗北を意識したなら、私は文学をさえ、止すことが出来る。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は敗北しなかった。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と素直に、敗北の告白をこそせよ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じる能力の無い国民は、敗北すると思う。",
              "citation": {
                "source": "かすかな声",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じて敗北する事に於いて、悔いは無い。",
              "citation": {
                "source": "かすかな声",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
