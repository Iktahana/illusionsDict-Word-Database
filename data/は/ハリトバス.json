        "examples": {
          "standard": [
            {
              "text": "強風が街路樹を張り飛ばし、あたり一面に葉が散乱した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は怒りに任せて、テーブルの上の書類を床に張り飛ばした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "喧嘩になった時、相手を力いっぱい張り飛ばしてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "活動どころかと子供の頭を張り飛ばすのもいゝ気持ちぢやない。",
              "citation": {
                "source": "工場の窓より",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "留吉　（ベラベラと気が狂つたやうに喋りながら顔を突出して来る香代の顔を、黙つて張り飛ばす。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横っ面をはりとばすか、蹴倒してやるか、唾でも吐きかけてやればいいじゃないか、男じゃないか留さん、と私は心の中で叫んだ。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
