        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "羽根布団というなら全部羽根布団だ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の翡翠色の羽根布団を押除けて一つの驚くべき幻影がムクと起上った。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉虫色の羽根布団を頭から引っ冠ったが、私はこの羽根布団の下の人の形の胸のあたり眼がけて、グサッと短刀を突込んだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、不思議や羽根布団がビシャンコになってしまった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "慌てて羽根布団をマクリ上げて下を覗いて見た私は、アッと叫んで立竦んだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽根布団の下は真赤な血に染ったシーツばかりである。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややしばらく立って目をさました時躰に羽根布団がかけられてわきに電気のスタンドがふくれた色にともって居た。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと、山の中では珍しい寝台やその上にかかっている厚い羽根布団を見せたかったのだろうと思う。",
              "citation": {
                "source": "上林からの手紙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光りで、羽根布団の茶と緑の大模様がぼんやり浮き立って見えた。",
              "citation": {
                "source": "墓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂に入る時などは幕を張り、屏風をめぐらし、そして静々と、ふくよかな羽根布団にくるまれて、室内を軽く辷る車で、それらの人々にはこばせるのであった。",
              "citation": {
                "source": "明治美人伝",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いレエスに包まれている少女の、透きとおった首筋の向う側に、イキナリ右手のマキリを差し廻わしながら、左手でソロソロと緞子の羽根布団をめくった。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "温柔しく夢を見ているんだよ……ウフウフ……」　それから返り血を避けるべく、羽根布団を引き上げながら、すこしばかり身を背向けた。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前に据っている色真綿の肘掛椅子の中に妾の身体を深々と落し込むと、その上から緞子の羽根布団を蔽いかぶせて、妾の首から上だけ出してくれた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾も仕方なしに、真綿の椅子の中で羽根布団に埋ったまま、おなじようにしてハラムの顔を見上げていた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すると、そのうちに何だか胸がスウ――として来たようなので、妾は羽根布団からヒョイと顔を出してみた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも構わないから教えて頂戴って云ってるじゃないの……あたしの運命を、お前の力で、死ぬほど恐ろしいところに導いてくれてもいいわ」　ここまで云って来ると妾は思わず羽根布団を蹴飛ばしてしまった。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから妾もすぐに、寝台の上に這い上って、羽根布団にもぐり込んで寝た。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三時頃眼をさまして、羽根布団の中で焼き林檎を喰べていると、いつの間に這入って来たのか、狼が枕元に突立っていた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "パジャマと羽根布団で身体を深々と包みながら、横のカアテンを引いた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の上に置かれた羽根布団と離被架とを、静かに片わきへ引き除けて、寝顔をジイッと覗き込んだ。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽い緞子の羽根布団を、寝床の下へ無造作に掴み除けて、未亡人の腹部に捲き付いている黒繻子の細帯に手をかけたのであったが、その時に私はフト奇妙な事に気が付いた。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくこの事件の中では一番デリケートなところでしょう」　それから犬田博士は寝台の上にかけて在った羽根布団をめくってシーツの表面に残る隈なく拡大鏡を当てがってみた後に、署長と、検事、判事、司法主任を招き寄せた。",
              "citation": {
                "source": "Ｓ岬西洋婦人絞殺事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時すぎて来ると妙に四辺が寒くなって羽根布団にくるまって居てもぞくぞくしたほどである。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ着物を更めた妻も羽根布団やバスケットを運んで来た。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚ぼったい敷布を二枚、上に夜着と羽根布団、それらの柔かな綿の中に、すっぽりとはいっているので、どこに胴体があるのか四肢があるのか、見当がつかない。",
              "citation": {
                "source": "白木蓮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長椅子の上には既に過去となった其の日の半日午睡の夢をやどさせた羽根布団。",
              "citation": {
                "source": "写況雑記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポケットの中とか、あるいは、一番近くにある羽根布団のぬくもりの下とか。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "李　しばらく寝つかれないで、彼らは羽根布団の中でもぞもぞしている。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「グウー、グウ、グウーグウ……」　そのなかで、竹童ばかりが、鷲の翼をはねぶとんにして、さもいい気もちそうに、いびきをかいて寝こんでいた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
