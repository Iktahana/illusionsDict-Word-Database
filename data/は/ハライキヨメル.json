        "examples": {
          "standard": [
            {
              "text": "神官が厳かに祝詞を奏上し、その場を払い清めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "滝の水で身を清め、心を払い清める修行に励んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "汚れた場所を払い清めることで、運気が上がると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "茶人に第一必要な条件の一は掃き、ふき清め、洗うことに関する知識である、払い清めるには術を要するから。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろその友情の単なる思い出としてではなく高めるためにも、その間にわだかまった異国という幻影を払い清めることを芽出度しとしてこそ、以後の健康な日常の日の友情とすることが出来るように思われる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
