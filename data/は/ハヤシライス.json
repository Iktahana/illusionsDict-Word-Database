    "definitions": [
      {
        "index": 1,
        "gloss": "hashed beef in sauce over rice",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "葱とチーズを壺焼にしたスープ・ア・ロニオンとか、牛舌のハヤシライスだとか、莢隠元のベリグレット・ソースのサラダとか、彼がふだん好んだものを註文したので鼈四郎は慥え易かった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日新亭のハヤシライスが食べたいってよく泣いたのは誰だっけね。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は子供の頃、ハヤシライス位｜旨いものは知らなかった。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父は自分はスープを、私にはハヤシライスを誂えた。",
              "citation": {
                "source": "桜林",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "田原屋のハヤシライスとオムライスとって貰って食ひ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜食八時頃、食堂へ下りて、オムレツ・ハヤシライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食大阪屋のホワイトシチュウとハヤシライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事は大阪屋ハヤシライスとホワイトシチュウ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "間に、大阪屋のシチュウとハヤシライスを食ひ、六時頃から「われらが猫騒動」の稽古。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って大阪屋のポタージュとハヤシライスを食って、おね／＼してるともう夜の「芝居」が開く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所でソーダ水と大阪屋のハヤシライスを食ひ、理髪しに行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪屋のハヤシライスとトースト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って入浴し、大阪屋のハヤシライスと毛利の肉まん。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻迄二三カット、食堂でハヤシライスをパクつくと、又始まる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "麻雀クラブへ、やり乍ら、ハヤシライス一、ちらし一、しるこ一、ざうに一、皆おどろく。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚へ引かへして、楽屋で二十銭のハヤシライスを食ったのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食もクラブで、ハヤシライスのまづいの。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹込みとなるとひどく手間がとれて、結局四時すぎになり、食事もビクターの地下でハヤシライスですませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東洋亭でハヤシライスをかき込むと座へ引返す。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一々自分で朱筆を入れたからうまくカット出来たが、時間になって食事できず、「大久保」終ってからスエヒロのオムレツとハヤシライス冷たいのを味気なく食ったのみ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼終ると、プランタンのビーンズとハヤシライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しきハヤシライスを食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂のハヤシライスかっ込み、セットへ入る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "御殿、小笠原章二郎の家光公の前へズラリと並び、夕方迄に大分進んだ、夕食は食堂のハヤシライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "広養軒でハヤシライスなど食ひ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ雨やまず、円タクで浅草迄行き、常盤座の舞台稽古をのぞき、広養軒でハヤシライス食って座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は田原屋のハヤシライスをとって貰った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "田原屋のハヤシライス、井うちの支那そば食べつゝやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹は干してゐたが、昼終りに、卵サンドイッチとハヤシライスの肉をどけて食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食は、ハヤシライス、半分位でいやんなった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
