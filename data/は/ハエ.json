[
  {
    "uuid": "294a5196-5f99-5a8d-9c21-6ae218acd1ad",
    "entry": "蠅",
    "reading": {
      "primary": "はえ",
      "alternatives": [
        "ハエ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
