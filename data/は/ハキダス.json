[
  {
    "uuid": "adbac4ec-e842-59a7-b1aa-e5792581c2f8",
    "entry": "掃き出す",
    "reading": {
      "primary": "はきだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
