        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "陣痛が強くなって破水が起こり、胎児の頭は産道にのぞいたが、それっきりひっかかってしまったのである。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "足蹴にしたかと思うと、その、はずみをくらって取りおとす大刀を拾い取るが早いか、やはり、のっそりの仁王立ちの、流祖自源坊案｜不破水月のかまえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすいた電車の来るまで、気長く待つという方法である。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして多少の除外例はあるにしても、だいたいにおいて長い間隔の後には比較的混雑した車が来る事、短い間隔の後にはすいた車が来る事がわかるだろう。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜月でした――夜汽車はすいていますし、突伏してでもいれば、誰にも顔は見られませんの。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本植物圖鑑ではすいばと云ふのが普通の名稱として認められてゐる。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "各項目に付ける言い訳の原稿が、今日はすいすい書けそうな気がした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃあ俺も一ッ風呂泳いで来ようか」　半七は更に表へ廻って、普通の客のように湯銭を払ってはいると、まっ昼間の銭湯はすいていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "卯平が凝然として居ると萵雀が忍び／＼に乾いた落葉を踏んで彼の近くまで來てはすいと枝へ飛んだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹はすいているが、食いものはない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "関さんはすいかずらやじゃのひげや大黄などを枯れ草の中に見いだして教えてくれた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その車はすいていた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩にはすいとん汁をこしらへた、御飯が足らないらしいから。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹はすいていないし、ゆっくりやるには、いきおい、ビールか日本酒だ。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはすいている　と思って見ていると、やはりステップに立ってつかまっている人々がかなりある。",
              "citation": {
                "source": "無題（十二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり汽車はすいては居た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車はすいて居たが、段々こんで来た。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれほどの関係が、腕を断つと一方によって宣言されれば、他方はすいと方向を変えている。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "正午近い銭湯はすいていた。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "割合に山の手はすいて居たけれども真向いに居る一人は二十五六の、も一人は二十位の女が悪ずれした目つきをして二人の間にはさまれてツンとして居る千世子の風の変った髪やじみはでな着物の着こなし方なんかをわざわざきこえる様に批評するのが気にさわってたまらなかった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さきへおはいりなさい」　東助が先に、それからヒトミ、それから先生の順で、小さい樽ロケットの中に三人はすいこまれた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の中などを眺めても、膝を両方にひろげて、自分の股の間はすいているのに、隣りの人とは股で押し合っています。",
              "citation": {
                "source": "男ぎらい",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の凉気に、ビヤホールはすいていた。",
              "citation": {
                "source": "悲しい誤解",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車はすいていたが、車内では、話すこともなかった。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クイーン・メリー号、ばんざーい」「ばんざーい」　待ちくたびれて不平をいっていた群衆も、いまはすいこまれたように、メリー号の方にのびあがり、さかんに黄色い声をおくった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時はすいて居る戸の間から音も立てず入って来て、これもすいて居た戸棚の中へ二分ばかり入って居た。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　水を乱さずにそっと狙い寄ったり、不意に馳け出して追っかけたりしたが、小鮠はすいすいと身をかわして平気な風をしていた。",
              "citation": {
                "source": "人間繁栄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵はすいこまれるように鍵穴にはいりました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだおなかはすいてないし、それに、顔なんかどうだつていいんでせう。",
              "citation": {
                "source": "村で一番の栗の木（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、お困りでございましょうがなあ」「疲れはしたし、お腹はすいたし」　どうも、さもしい。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
