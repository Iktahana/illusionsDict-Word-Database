    "definitions": [
      {
        "index": 1,
        "gloss": "to have one's teeth set on edge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の見え透いたお世辞を聞いていると、こちらまで歯が浮くような心地がする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "映画のラストシーンのあまりにも甘ったるい台詞に、歯が浮く思いで画面を眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "若いカップルの過剰な演出によるプロポーズを見て、周囲は歯が浮くような気恥ずかしさを感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「心持のだね、持ち次第で、だね――何を見たつて君、感傷に走らうとすれば走るだけのことさ、俺だつて何も感傷的気分を軽蔑はせんよ、だが君のは何だか歯が浮く――。",
              "citation": {
                "source": "夏ちかきころ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は案に相違して、むしろ歯が浮くような厭味を感じた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲馬の馬は泣くべき暇も無し、慳貪なる黒奴の曲馬師は広告のため、楽隊の囃しに伴れて彼を歩ませぬ……夜の声手風琴が鳴る……そんなに、そんなに、驢馬が啼くやうな、鉄葉が慄へるやうな、歯が浮くやうな、厭な手風琴を鳴らさないで下さい。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯が浮くとは正にこんな事である。",
              "citation": {
                "source": "勝太郎",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to get loose teeth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "酷い歯周病のせいで、奥歯のあたりが常に歯が浮くような違和感がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "疲労が溜まると、決まって歯が浮く感じがして食事がしにくくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歯医者で「歯が浮くのは歯茎が炎症を起こしているサインです」と言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
