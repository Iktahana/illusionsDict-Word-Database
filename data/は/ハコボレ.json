    "definitions": [
      {
        "index": 1,
        "gloss": "nick in a blade (sword, knife)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、鞘へ納めた刀を、もう一度抜いて、刃こぼれを調べた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "強靱な野生の笹は、むざんな刃こぼれの損害でむくいてその鎌に抵抗した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕提灯に刃こぼれをしらべる件の形は無類だが、菊五君としては当然である。",
              "citation": {
                "source": "合邦と新三",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷を負わせたは二十人はあろう」　彼は刃こぼれを見ようとした。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、有難い、刃こぼれはない」　これは刃こぼれはない筈であった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刃こぼれがあってたまるものか」　そこで、ソロリと鞘へ納めた。",
              "citation": {
                "source": "前記天満焼",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九十郎の片腕斬り落としました際、大切の備前長船を、刃こぼれさせましてござります」「ハハハハ」と冬次郎は笑った。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鍛えは関、銘は孫六、随分人を切ったから、二所ばかり刃こぼれがある、抜いて口からズーッと腹まで！",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、小さな刃こぼれが三つ並んでいるのは！",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ササラのように刃こぼれがしているのだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し新しい刃こぼれのあるのも凄まじく、柄にひどく血の付いているところを見ると、下手人はさぞ猛烈な返り血を浴びたろうと思うだけのことです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「刃物を見付けました」　手拭に包んで来たのは、匕首が一口、切っ先が血に染んで、少し刃こぼれがあります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂の浮いた刀か、刃こぼれのある刀を、近頃研屋へ持込んだ奴が判れば、占めたものだ」「なるほど、そいつは気が付かなかった、――それじゃ親分、三日ばかり待っておくんなさい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬綺談",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は受取って、流儀も作法もなく、灯先に透かしましたが、血曇りも刃こぼれもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄のところが晒し木綿で巻いてあり、刀身に刃こぼれがある。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日のこと年の頃六十ばかりの武士が刀の手入れを頼みに参りましたで、音八が鞘を払って見ますと、切先に少々刃こぼれがありました。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『業物ではございますが、惜しいところに疵がありますな』と申しますと、武士は、『指折り数えれば早二十五年の昔、小夜の中山で女を斬ったことがあるが、これはその折石に当っての刃こぼれじゃ』と答えました。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと闘えば忽ち刃こぼれを生じる、刀の折れる惧れも勿論ある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "血刀の刃は鋸のように刃こぼれしていた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "刃こぼれ、曲がりなし』　と呶鳴って、立会い人の方へ渡して、引き退がった。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬り人は刃を挙げて、『※から一尺上、刃こぼれ有り――。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、先に鍔を斬った真雄の一刀を受けてみると、故意に斬り人が無理をした痕が歴然とその刃こぼれに読める。",
              "citation": {
                "source": "山浦清麿",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小文治は敵を串刺しにして、大樹の幹につき立った槍をひき抜き、穂先の刃こぼれをちょっとあらためてみた。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅や鉄を斬っても刃こぼれ一つしない」「ふん。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片隅でムクムク動いている者があれば、それは用意の黒布を出して、顔の覆面や足拵らえにかかっている者で、中には腰の皎刀を抜き払って、刃こぼれをあらためている者がある。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "上方の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし当選した正解者の答案は極めて簡単明瞭で「水はこぼれますよ」というのであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう筋も抜け、骨崩れて、裳はこぼれて手水鉢、砂地に足を蹈み乱して、夫人は橋に廊下へ倒れる。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんさんとふきあげの水はこぼれちりさふらんは追風にしてにほひなじみぬ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その騒ぎで酒はこぼれて了つたので、馬右エ門も床に這入つた。",
              "citation": {
                "source": "鍛冶屋の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれうれしや、」と婆はこぼれるばかりの愛嬌を示して、一歩金を押しいただき、「鯛など買わずに、この金は亭主に隠して置いて、あたしの帯でも買いましょう。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
