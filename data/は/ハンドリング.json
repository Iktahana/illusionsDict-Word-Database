        "examples": {
          "standard": [
            {
              "text": "試合終了間際、相手選手にハンドリングの反則があり、PKになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "サッカーでは意図的なハンドリングはイエローカードの対象となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今のハンドリングは故意だったんじゃないか？」と監督が審判に詰め寄った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "麻薬、食料、女性、金銭まですべてを共有し、基本的にはパンハンドリング（物乞い）と盗みによって生活を支えている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
