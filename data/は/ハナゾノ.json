        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ともかく門から建物までの花園は昔のまゝであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うへ越して交番に百花園への道を尋ね、向島堤上の砂利を蹴って行く。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手に萩の園と掛札ある家を、これが百花園かと門内を覗くに、どうやら変なれば、客待ちの車夫に問うに、百花園はまだずっと先なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三囲の稲荷堤上より拝し、腹まだ治まらねば団子かじる気もなく、ようやく百花園への道札見付けて堤を右へ下り、小溝に沿うてまがりくねりの道を行く半町ばかり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が道ばたの花園の青芝の縁に杖を垂直に立てて考えることには、「ヒヤシンスはとても喫むまいが、チュリップというやつはこいつどうも煙草を喫みそうな花だ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか云う名の洋紅色大輪のカンナも美しいが、しかし札幌円山公園の奥の草花園で見た鎗鶏頭の鮮紅色には及ばない。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十五日　向島の百花園に行く。",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前に百花園からつるの手をつけてある目籠に長命菊つくし石竹の苗其他数種の青草を植込にしたやつを買って来て置いたのを持って往ったのであるきょうは暖炉の掃除をやったとの事で先生は八畳の座敷に石油暖炉をたき東向になってねていられた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓はターリング・プレースの花園に隣った寺の墓地の静かな片隅にある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、赤い蝶のようにホールを旋回しながら、僕は粟鼠の毛皮をつけた甘美な女の顔の花園を眺めながら云うのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が更けると、米良は陳子文とイサックを伴って電車路からクインス・スタチウの花園の附近にあるマダム・レムブルクの夜の家を訪れる。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良はビイクトリア・ブリテッシュ・スクールの学生が、花園のなかのジャックソンの銅像に礼拝する姿を見るのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "香港の階段の街が涙に濡れて濶葉樹の葉がビクトリア女皇の銅像前の花園で金色に光った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はベグノニアの花園を踏んで商業的騒音に生きる、商権の雑音を愛した。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし多数の読者を導いてこのルクレチウスの花園に入るべき小径の荊棘を開くにはぜひともこれだけの露払いの労力が必要であると思った。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学もやはり頭の悪い命知らずの死骸の山の上に築かれた殿堂であり、血の川のほとりに咲いた花園である。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから蛇によって象徴された執念深い肉慾に二人が囚われて、信仰をなくしちゃって、エデンの花園を逐われてから、お互いの裸体が恥かしくなったお蔭で、子供がドンドン生まれ初めてこの地上に繁殖し初めたんだから、トドのつまりこの地上で栄えるものはエホバの神の御心じゃない。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "六平太先生のお能を見ていると花園の中を行くような……又は名画の連続を見るような有難い……トテモ気楽な気持になる。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あき地には草花でも作って一面の花園にして見ようという美しい夢を見ていたが、これはほんとうの夢である事がじきにわかった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもう一二年たって、われわれ「東京者」に対する子供らの好奇心と反感のずっと減少した時分にもう一ぺん「花園の夢」を見るのもいいかと考えている。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると前には見えなかった別の扉のようなものがすうと開いて、それをはいって行くと前とはまたまるでちがった風物の花園が眼前に広がって行くのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花園の側に行くとその受持ちをしているファニーが花の中からついと出てきて私たちをさしまねいた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞紅の花の咲滿ちた、雲の白い花園に、朗らかな月の映るよ、と其の浴衣の色を見たのであつた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……日を隔てたカアテンの裡なる白晝に、花園の夢見る如き、男の顏を凝と見て、「恐入りました。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼をつむると、リアリズムは去り、センチメンタリズムの花園の中を、甘い口づけがさまよっているかのようだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はペルデイタの如くに彼女の花園で薄荷と金仙花の間で生活することが出来る……』『ふっ、何と云う君は子供だろう。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "距離が、やつらのはね」藤原はなぞのようにいった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく仕立てた駕籠に乗ると、名人はなぞのひとそろいをたいせつにうちかかえながら、ひたすらに一石橋へ急がせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなぞのような、とても考えられないほど破廉恥な話だから、私はぜひ語ろうと思う。",
              "citation": {
                "source": "トビアス・ミンデルニッケル",
                "author": "TOBIAS MINDERNICKEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お姫さまはなぞのこたえがわかりますと、そっとぬけだそうとしました。",
              "citation": {
                "source": "なぞ",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
