    "definitions": [
      {
        "index": 1,
        "gloss": "bankruptcy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "世は挙げて性格破産。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活は破産し切つて、ただしようことのない生存の一日一日が続き、如何なる行為らしい行為も最早見られないとしても猶、『無償の行為』は在つて存するのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような立場から云うと、基礎の怪しい会社などを始めから火葬にしないでおいたためにおしまいに多数の株主に破産をさせるような事になる。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして之れ、明白に僕の思想生活の破産だからだ。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時、僕の家には、田が、親爺が三年前、隣村の破産した男から二百八十円で買ったのが一枚あるきりだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "破産した人間の土地を値切り倒して、それで時価よりも安く買えると彼は、鬼の首を取ったように喜んだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自作農で破産をする人間、誰れもかれも街へ出て作り手がなく売りに出す人間、伊三郎が、又、息子の学資に畠の一部を売る場合――秋に入ると一と雨ごとに涼しくなる、そんな風に、地価は、一つの売出し毎に、相場がだん／＼さがった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、彼が、破産した男の土地を、値切り倒して面白がって買ったように、今度は、若いほかの男が、彼の土地を嬲るように値切りとばした。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、おかしいことには、これと同日同所で見せられたアメリカ映画「流行の王様」に、やはり同様に破産した事務所の家具が運び出される滑稽な光景がある。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「性格が破産しちゃったんじゃないかしら」と笑っている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "家が破産でもしたら、その日から食ふに困るのだもの。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾を殺して頂戴って云うのよ」「……ハハハ……死にたいんですか」「……ええ……死にたいの」「……どうして……」「……だって妾は破産しているんですもの」「……ヘエ……ホントウですか」「貴方に上げたのが妾の最後の財産よ。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「殖産」という流行語にかぶれてついに破産してしまった。",
              "citation": {
                "source": "非凡なる凡人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "則ち肉類の需要が減ずるものでもなし又私たちの組合がこわれたり会社が破産したりするものではない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "破産した実家へ妻を帰らすに就て、彼は全く意久地なく振舞った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私は、ロマンティストの生活を長く暮しすぎたために破産してしまいました。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして其の屍體が地の底に納まるか納まらぬに、お房の家は破産の宣告を受けて一｜家離散となツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことに今朝になってみると、田舎の兄のやっている陶器会社が破産状態に陥った時、相談を持ちかけられ、郁子を説得したうえ、万に近い金をようやく融通して急場を救ったことがあり、後に紛紜が起きて困ったことがあったが、結局解決がつかずじまいであったことが、今朝の清澄な心にふと思い出された。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪野は小さい時分から、米の大問屋へ奉公にやられ、機敏に立ち働き、主人の信用を得ていたが、主人が亡くなり妻の代になってから、店を一手に切りまわしていたところから、今までの信用を逆に利用し、盛んに空取引の手を拡めて、幾年かの間に大きな穴をあけ、さしも大身代の主家を破産の悲運に陥れたものであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は病気あがりの銀子が、座敷へ現われるようになってから、またひとしきり頻繁に足を運ぶのだったが、ちょうどそのころ経済界に恐慌があり、破産する店もあり、彼も痛手を負い、遊んでも顔色が冴えず座敷がぱっとしなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "その長男の手紙と同時に勧業銀行から破産宣告に関する通知が来ているのを私は見て参りました」「フーム。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この調子で行くと叔父は殆んど破産に近い打撃を受けるであろう事が、その石みたいに冷え切った表情で察しられた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父は破産しているんだよ。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その性格悲劇は、彼の人生を破産しようと試みてゐる。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親が破産しかかって、せっぱつまり、見えすいたつらい嘘をついている時、子供がそれをすっぱ抜けるか。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、二十五回の破産である。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなにぼろぼろでも自分専用の楯があったら」「あります」私は思わず口をはさんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の壇へ御洗米と塩とを純白な皿へ盛ったのが御焼物の鯛をはさんで正しく並べられる。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ生れのＯ夫人がちゃんと時刻をたがえずやって来て一つの鍋のロースを日本の箸ではさんでいた。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郭光はその王の独りごとを耳に聞きはさんだ。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
