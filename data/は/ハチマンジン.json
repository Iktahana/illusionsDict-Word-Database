    "definitions": [
      {
        "index": 1,
        "gloss": "Hachiman (god of war)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
