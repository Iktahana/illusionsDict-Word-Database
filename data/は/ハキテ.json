        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、山にはまだ春はきていませんでした。",
              "citation": {
                "source": "里の春、山の春",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫の、珠の履をはきて坐しぬ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "・椿の落ちる水の流れる・みそさゞいよそこまできたかひとりでなくか・梅がもう春ちかい花となつてゐる・轍ふかく山の中から売りに出る・枯枝をひらふことの、おもふことのなし　そこら一めぐりする椿にめじろはきてゐる　ふるさとなれば低空飛行の爆音で　二月六日くもり、何か落ちてきさうだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンダラの服はきていませんでしたが、正坊にちがいないことがわかると、クロはウォーンウォーンと、のどをしぼるような、うれしなきのさけびをあげました。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "尖りたる帽を紐もて結び、褐色の短き外套を纏ひ、足には汚れたる韈はきて、鞋を括り付けたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日、明けて糠くさき飯ろくにも喰わず、脚半はきて走り出づ。",
              "citation": {
                "source": "突貫紀行",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビーチボーイズやハーマンズ・ハーミッツはきても、ビートルズが日本なんかにくるわけがない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉田工業は本来の軍需工場ではないので、まだ憲兵までにはきていないが、事態がもう少し進むと、そこまで行き兼ねないことが考えられる。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "播磨は庭下駄をはきて降り立つ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯枝の間にかゝれる比、はるか、へだたりて、氷はりたる地づらを、高履はきて、おとたて歩む聞ゆるいとものかなし。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方より俳諧師鬼貫、四十餘歳、導引のこしらへ、頭巾をかぶりて破れたる傘をさし、足駄をはきてとぼ／＼と歸り來る。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "名を問へば、お花とて、極めて無心なる風情ながら、弱々しき足先に草履をはきて、おもしろげもなく、おかしげもなく、たゞ／＼むつちりとして、われより先に行く有樣、年はわづかに十二なりといへり。",
              "citation": {
                "source": "山家ものがたり",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "田辺哲学の批判もそこまではきている。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "経済的な点からもこのことはきている。",
              "citation": {
                "source": "故郷の話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯壺は去年まで小屋掛のようなるものにて、その側まで下駄はきてゆき、男女ともに入ることなりしが、今の混堂立ちて体裁も大に整いたりという。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ往かんとて菅笠いただき草鞋はきて出でたつ。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "横川よりゆくての方は、山の頽れおちて全く軌道を埋めたるあり、橋のおちたるありて、車かよわずといえば、鞋はきていず。",
              "citation": {
                "source": "みちの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊香保近くなりたるほどに、重荷背負ひ、草鞋はきて、とぼ／＼とたどりゆく老僧あり。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "花の如く、玉の如く、愛すべく、貴むべく、真に児女子の風を備えて、かの東京の女子が、断髪素顔、まちだかの袴をはきて人を驚かす者と、同日の論にあらざるなり。",
              "citation": {
                "source": "京都学校の記",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "武男が仙台平の袴はきて儀式の座につく時、小倉袴の萎えたるを着て下座にすくまされし千々岩は、身は武男のごとく親、財産、地位などのあり余る者ならずして、全くわが拳とわが知恵に世を渡るべき者なるを早く悟り得て、武男を悪み、叔父をうらめり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですが、私のところへはきていません。",
              "citation": {
                "source": "盗難",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの砂糖壺の報告はきていませんか」「砂糖壺とココアの飲み残りは目下検査を依頼中です。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「着物くらゐはきてゐるだらうよ。",
              "citation": {
                "source": "大寒小寒",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "また大田南岳の山高帽に木綿の五ツ紋、小倉の袴をはきて、胸に赤十字社の徽章をさげたる。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨中は靴の上に更に大きなる木製の底つけたる長靴をはきて出勤せられたり。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に番頭が顔を出して、「だれも、家にはきていない。",
              "citation": {
                "source": "けしの圃",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しまいには一｜軒一｜軒、よその家を訪れて、「家の猫はきていませんでしょうか。",
              "citation": {
                "source": "少年の日の悲哀",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、そこには春はきていなかった。",
              "citation": {
                "source": "角笛吹く子",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
