        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "庭に植えた花大根が、紫色の美しい花を咲かせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "春の訪れとともに、道端に花大根が可憐に咲き誇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "花大根の群生が、あたり一面を紫色に染め上げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "所が花大根の句に到ると、ただ純白の花の上に今し漆黒な蝶が翅をあげてとまった、その動中の一ポイントを捉まえ、一瞬間の姿を活動的に描いた点が新らしい写生句である。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "麦の穂も、ほとんど出そろい、花期の長い菜の花大根の花には、もう青い実がむらがりついている。",
              "citation": {
                "source": "天草の春",
                "author": "長谷健",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
