    "definitions": [
      {
        "index": 1,
        "gloss": "half-agricultural and half-fishing (village or economy)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
