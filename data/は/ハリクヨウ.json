        "examples": {
          "standard": [
            {
              "text": "使えなくなった針を供養するため、毎年2月8日には針供養が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "裁縫教室の生徒たちが、感謝の気持ちを込めて針供養の儀式に参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "古い針を豆腐に刺して供養する、という針供養の風習に興味がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "お針の師匠が針供養をやっているのをみれば、花供養をしてもよかろうと思います。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "針供養みてえなの、やったほうがいいんじゃねえかな」　と、汗のひいてきた山崎が、ぽつりといった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　聖燭節から節分になり、初午から針供養、そうして※槃会の季節となった。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小ざつぱりしたる身なりや針納町娘｜笑みかはし行く針供養二月七日　二百二十日会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この禰宜の妻｜二日灸針供養　この禰宜の細君も私の知人であります。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この禰宜の細君はよくお灸をすえたりお針をしたりするということを幸いに、春季になっている二日灸、針供養の二つで表したのであります。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
