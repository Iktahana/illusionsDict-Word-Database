        "examples": {
          "standard": [
            {
              "text": "「ハクション！風邪ひいちゃったかな。」彼はくしゃみをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然のくしゃみに、隣の人が「ハクション！」と驚いた声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "花粉症の季節になると、一日中「ハクション、ハクション」とくしゃみが止まらない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どうして髯の中になんか入つたんだらうないい声だなア○（コロ　コロ　コロ　ハクション）アレッ　コオロギが　くしやみをした！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りきった時、その薮の中で、「ハクション」　と虎の杉山がくしゃみをした。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
