          "literary": [
            {
              "text": "渋茶、甘茶、渋糟、甘糟、渋皮、甘皮などの反対語の存在も、この対立関係を裏書する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがＣＤが普及し始めると、あえてデジタルの反対語を頭にくっつけて、「アナログレコード」と呼ばないと特定しにくくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キヨメはすなわち浄人で、穢人の反対語を以て表わしたものとも解せられる。",
              "citation": {
                "source": "「エタ」名義考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンダイの反対語が「アシ」である。",
              "citation": {
                "source": "符牒の語源",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
