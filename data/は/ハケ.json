[
  {
    "uuid": "08cfa387-9f7d-57df-bbdc-4a9d2526c9f5",
    "entry": "刷毛",
    "reading": {
      "primary": "はけ",
      "alternatives": [
        "ハケ"
      ],
      "is_heteronym": false
    },
    "grammar": {
