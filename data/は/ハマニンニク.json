        "examples": {
          "standard": [
            {
              "text": "浜大蒜は、北日本の海岸に自生するイネ科の植物で、ニンニクのような匂いがする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "浜大蒜の地下茎は、砂丘の侵食を防ぐのに役立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この草、ニンニクみたいな匂いがするね。浜大蒜っていうんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "濃緑色の浜大蒜と白い砂。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "……派手な海岸日傘の列からすこし離れた、浜大蒜の中で鮎子さんとトクさんと、ピロちゃんが胡坐をかいて、むずかしい顔で何か話をしている。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
