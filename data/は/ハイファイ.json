          "standard": [
            {
              "text": "祖父は昔からオーディオに凝っていて、書斎には本格的なハイファイシステムが組まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ハイファイな音質でクラシックを聴くと、まるでホールの最前列にいるかのような臨場感だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最近はアナログレコードの持つハイファイな響きが見直され、若い世代にも人気が広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり人間の認識の方法にそった使いやすいインターフェイスを通して文字やグラフィックス、ハイファイの音声がリアルタイムで取り扱え、どこにでも持って行けて常に無線でネットワークに接続されており、自分にあった環境をたやすく作っていくためのプログラミング環境が組み込まれている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
