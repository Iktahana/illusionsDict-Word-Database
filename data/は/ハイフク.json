        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六月十日木戸一郎　　井原退蔵様　拝復。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月三十日木戸一郎　　井原退蔵様　拝復。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十六日木戸一郎　　井原退蔵様　拝復。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベイカー街一一月二一日　　　吸血鬼の件拝復　一九日付のご来信について、当方、貴社依頼人ロバート・ファーガソン氏（ミンシン横町の紅茶卸ファーガソン＆ミュアヘッド経営）の調査を請け負い、案件を無事解決したことを恐れながらここに申し上げます。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（七月一日）五十一○拝復。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトン・コワリョーフ拝アレクサンドラ・グリゴーリエヴナ様　拝復　お手紙を拝見いたし、この上なく驚き入りました。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "榎本武揚氏の答書　拝復。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "書簡",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十年度劇界への指針岸田國士　拝復　別に新しい意見でもありませんが、小生の持論を要約します。",
              "citation": {
                "source": "昭和十年度劇界への指針",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三八、一一、二四）　　　　　　○　拝復　十四日にしめ切ると仰せあるが十四日には六ずかしいですよ。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目金之助　　　　　高浜清様　　　　　　○明治四十一年三月十九日（封書）　拝復　ページ数相分り候とよろしく候えどもまだ判然不仕。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や主と云はれし御月並　　　六月三十日夏目金之助　　　　　高浜清機　　　　　　○明治四十一年七月十日（封書）　拝復。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四日金之助　　　　　虚子先生　　　　　　○明治四十一年七月十一日（封書）拝復　御ふささんは異存はなかろうと愚妻が申します。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田好道様　拝復　厚意のこもったお情けのあるお手紙と図画をいただきありがとうございました。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝復御尋ねの場面は、京都｜四条通りです。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――拝復おくれ馳せながら新年おめでとう存じます、そちら皆々様お揃いよきお正月をお迎えなされし由およろこび申します。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十三拝復先日は失礼致｜候。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝復先日はまことに思いがけないお手紙を拝見して、どうしたらよいか途方に暮れ、あれから毎日そのことでばかり頭を悩ましつつつい御返事も上げずにいましたところ、只今二度目のおたよりを戴いて、ほんとうにほっと安心しました。",
              "citation": {
                "source": "細雪",
                "author": "下巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「拝復、渡良瀬川沿岸に君の如き青年ある事を知りたるは掘り出し物をした如く嬉しく存申候。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝復、君が孤軍奮闘あくまで其の主張を貫かんとする意気を非常に嬉しく存候。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝復　昭和十七年四月十五日附御照会の件拝読｜仕りました。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「拝復、今回は栄転に無之、寧ろ左遷に候。",
              "citation": {
                "source": "変人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　＊　　　　　　　　＊　拝復、日ましに暖かさが加わって、心地よい季節になってまいりました。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　＊　　　　　　　　＊剛ちゃんへの御葉書　拝復、御手紙を拝見しました。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
