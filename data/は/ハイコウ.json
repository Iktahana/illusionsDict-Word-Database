    "definitions": [
      {
        "index": 1,
        "gloss": "closure of a mine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まもなく彼は、話があるから廃坑へ行かないかと、彼女に切出した。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六百尺の、エジプトのスフィンクスの洞窟のような廃坑に、彼女は幽霊のように白い顔で立っていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃坑で待ちほけにあった、タエは、猫のように這いおりて来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃坑の入口は、塞がれた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督が上にあがって行くと、出しかけていた糞桶をまたもとの廃坑へ放りこんだ。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃坑春ちかけれど坑々の、　　　　祠は荒れて天霧し、事務所飯場もおしなべて、　　鳥の宿りとかはりけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "監督官が検査に来ると現に掘っている坑道はふさいで廃坑だということにして見せないで、検査に及第する坑だけ見せる。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの内、あるものは活坑なれどもその他は廃坑なり。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "この線は、ハートシーズの廃坑へ、以前英国の炭坑として最も大きなものの一つだったその場所へ通じているのだ、正確にいえば、通じていたのだ。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡てはふたたびハートシーズの廃坑の静けさに帰った。",
              "citation": {
                "source": "臨時急行列車の紛失",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は荒れ地のどこか凹地か廃坑にいるものかと。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、すっかり採炭し終った廃坑の、炭柱を崩し取って退却する時なぞに、どうかすると聞くことの出来る恐ろしい物音であった。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "崩落に瀕した廃坑に、再び重い鉄扉を鎖した係長は、慌しく電話室に駈けつけると、立山坑の地上事務所と札幌の本社へ、海水浸入の悲報を齎した。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "多島警視は、大きくうなずき、「北見氷子女史の話は、わが二人の刑事の報告と、完全に合っています」「博士は、アメリカで何をしているのかね」「廃坑を五カ所、買いました」「廃坑とは、役に立たなくなった鉱山のことかね」「そうです。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、それを買って、どんどん廃坑の中へしまいこんでいます」「ほう。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは愕いた」「博士は、廃坑の底にエンジンを持ちこんで、地底で発電しようと計画しています。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はどこか荒地の中の凹みか、廃坑の中に殺されているかもしれません」「襟飾のことはどう弁明していますか？",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い長いトンネルをぬけて炎天　廃坑日ざかりの煙突また煙吐いてゐるけふは誰か来てくれさうな昼月がある親船子船すずしくゆれてゆく　非常時色古い葉新らしい葉七夕の竹は立て八月五日　晴、鏡子居。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃坑を散歩した、アカシヤの若葉がうつくしい、月草を摘んできて机上の壺に※して置く。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "杭木の領収書を受け取った馬子が、再び熱い日中を麓の方へ下って行ってから、彼は一人で廃坑の前に登って行った。",
              "citation": {
                "source": "恨なき殺人",
                "author": "宮嶋資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは銅山の廃坑であつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この廃坑は旧幕時代の末頃まではまだ採掘されてゐて、これあるがために河原町は当時幕府直轄の天領となつてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅山が廃坑となり、時代が移ると共に、他所の町村が発展するのに河原町だけは産業的に衰微し、とりのこされたが、以前の天領気分は今でもなほこの町を中心とする一廓に残つてゐた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの山ぢあね、随分家屋敷をなくした者があるんですがね」　恐らくその一かたまりでは赤山廃坑の話がさつきから賑かだつたのだらう。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとになつて考へれば、それは結局、とうに涸れてゐる廃坑から、あらたに金を掘り出さうとするやうなものだつた。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうどぶつく以上は、何か変事でもあるか、または廃坑へでも連れ込まれたに違いない。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、三人は支柱のない危険な廃坑の中で働いていた。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも過去数年はほとんど廃坑になっていた。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿はいこうおむずかりじゃに……。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝夕はいこう冷えまする。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
