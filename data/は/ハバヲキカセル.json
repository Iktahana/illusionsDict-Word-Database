    "definitions": [
      {
        "index": 1,
        "gloss": "to throw one's weight around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高価な上に保守にも金を食い、そのくせ大した意味のない、動画やステレオ音声や、アイコンとマウスのインターフェイスの化け物ばかりが幅を利かせるようになった」と、締め出しはハートを嘆かせます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語を使う当人が必要に迫られて懸命に知恵を絞った見返りに、日本語ワードプロセッサーは日本オリジナルが幅を利かせる結果となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢字仮名混じりの厄介な文章が幅を利かせるこの国では、夢の範疇にしか存在しなかった日本語タイプライターも、見事に実現してみせた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢張佐渡の惚薬の効能で幅を利かせる方だから之で邸の嬢様を落さうと云ふは飛んでもない心得違ひだ。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "天聲は幅を利かせることが出來る北海メールの主筆でありながら、さう野心のない男なのだらう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "短歌や俳句はいつになつても畢に幅を利かせることは出来ない。",
              "citation": {
                "source": "変遷その他",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな奴が幅を利かせるだろう。",
              "citation": {
                "source": "どぶろく幻想",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
