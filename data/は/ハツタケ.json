    "definitions": [
      {
        "index": 1,
        "gloss": "red milk mushroom (Lactarius hatsudake)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども虫がしんしん鳴き時々鳥が百｜疋も一かたまりになってざあと通るばかり、一向人も来ないようでしたからだんだん私たちは恐くなくなってはんのきの下の萱をがさがさわけて初茸をさがしはじめました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近くへ行って見ると居なくなった子供らは四人共、その火に向いて焼いた栗や初茸などをたべていました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番初めに、初茸が立ち上って挨拶をしました。",
              "citation": {
                "source": "きのこ会議",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども虫がしんしん鳴き時々鳥が百｜匹も一かたまりになってざあと通るばかり、一向人も来ないやうでしたからだんだん私たちは恐くなくなってはんのきの下の萱をがさがさわけて初茸をさがしはじめました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だん／＼近くへ行つてみると居なくなつた子供らは四人共、その火に向いて焼いた栗や初茸などをたべてゐました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近山裏の谷間には、初茸の残り、乾びた占地茸もまだあるだろう、山へ行く浴客も少くなかった。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "処で、火気は当るまいが、溢出ようが、皆｜引掴んで頬張る気だから、二十ばかり初茸を一所に載せた。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（初茸と一所に焼けてしまえばいい。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでに、頭のてっぺんへ流れる涙の中に、網の初茸が、同じように、むくむくと、笠軸を動かすと、私はその下に、燃える火を思った。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも松露の香がたつようで、実際、初茸、しめじ茸は、この落葉に生えるのである。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋には、初茸、土かぶり、なめこなどのキノコ類が、アヤの形容に依れば「敷かさつてゐるほど」一ぱい生えて、五所川原、木造あたりの遠方から取りに来る人もあるといふ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と筵の上を膝で刻んで、嬉しそうに、ニヤニヤして、「初茸なんか、親孝行で、夜遊びはいたしません、指を啣えているだよ。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金澤にて言ふ松みゝは初茸なり。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "松茸、初茸、木茸、岩茸、占地いろ／＼、千本占地、小倉占地、一本占地、榎茸、針茸、舞茸、毒ありとても紅茸は紅に、黄茸は黄に、白に紫に、坊主茸、饅頭茸、烏茸、鳶茸、灰茸など、本草にも食鑑にも御免蒙りたる恐ろしき茸にも、一つ一つ名をつけて、籠に裝り、籠に狩る。",
              "citation": {
                "source": "寸情風土記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　鮎の大きいのは越中の自慢でありますが、もはや落鮎になっておりますけれども、放生津の鱈や、氷見の鯖より優でありまするから、魚田に致させまして、吸物は湯山の初茸、後は玉子焼か何かで、一｜銚子つけさせまして、杯洗の水を切るのが最初。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初私の眼分量できめた豫定は宅を朝の六七時に出て十一時には頂上に着く、そして一二時間を其處で休んで歸りかける、歸りみちにはあたりの松山で初茸でも取つて來やうといふ樣なことであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "四邊の山より富士を仰ぐ記",
                "note": "青空文庫"
              }
            },
            {
              "text": "打こぼし投げ払いし籠の底に残りたる、ただ一ツありし初茸の、手の触れしあとの錆つきて斑らに緑晶の色染みしさえあじきなく、手に取りて見つつわれ俯向きぬ。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ハツといふのは初茸に類似の茸で此の地の方言である。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋は、到る処の松林に初茸が出た。",
              "citation": {
                "source": "スケツチ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の初茸狩がまた面白かつた。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "女でも子供でも時の間にかごに一杯になるほど、初茸を採つて帰つて来ることが出来た。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "山で取れるものには、初茸、松茸、しめじ、まひ茸などがあつた。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷校から程近い平田野といふ松原、晴れた日曜の茸狩に、この秋草の香と初茸の香とを嗅ぎ分けつつ、いとけなき自分は、其處の松蔭、此處の松蔭と探し歩いたものであつた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷校から程近い平田野といふ松原、晴れた日曜の茸狩に、この秋草の香と初茸の香とを嗅ぎ分けつつ、いとけなき自分は、其処の松蔭、此処の松蔭と探し歩いたものであつた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "松茸は別として、……初茸、いぐち、卵茸、しめぢ、じごぼ、さうめん茸……」とあげて、そのあとにまだ何かあるやうで思ひ出せなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "籠の中を見ると初茸としめじがほんのちよつぴりだ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはそれとして膳の上は肴一皿、初茸汁、したし物と定む。",
              "citation": {
                "source": "明治卅三年十月十五日記事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度は一軒置いてお隣りの多宝院の納所へ這入り坊さんのお夕飯に食べる初茸の煮たのを摘んでいるところを捕まえました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "栃の木で老猿を彫ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして彼は、これから大漁が続くと予言しながら、漁の少い夏場だけやって来る旅客をけなし、遅くまで居残ってる私をほめ、第一これからは、川に群れてる鯔にも脂がのってくる、鯔の食える季節は、山に初茸の出る時期の間だけだと、そんなことを話してきかした。",
              "citation": {
                "source": "初秋海浜記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その郷里の家からは、烟草屋の二階に室借をしていた独身時代にも、時々｜林檎や柿を寄越してくれたが、今年は初茸と湿地茸を送って来た。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
