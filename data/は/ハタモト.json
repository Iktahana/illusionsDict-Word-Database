        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは昔の旗本が住んでた屋敷で、大きな武家風の門があり、庭には蓮池などがあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "（移動）　（ヘッド・タイトルを道の移動にダブらしたらどうかと思います）（速やかにＦ・Ｏ）　＝（Ｆ・Ｉ）松平帯刀の邸　一人の旗本、斬られてダダーとのけ反った。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又他の桟敷には進藤甚助始め、旗本の連中五人何か話して居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗本連も花道の方見る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の旗本、数名の浪人者の立廻り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗本を後にして、Ｔ「友人の誼　助勢致す！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉が、Ｔ「拙者、強い方を　叩き斬る」　面喰って居る旗本を尻目に大吉尚も、Ｔ「貴殿が御強よう　厶ったら、今頃　貴殿の其の首は　まさか胴には……」　「着いちゃいまいテ」と大笑する。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗本、オホホと首をおさえた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川春はなかなか大きい店で、旗本屋敷や大町人の得意場を持っている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に云ったような人間の多い時代ですから、旗本の隠居や大町人の贅沢な奴らが川春の宇三郎にたのんで、御留川のむらさき鯉を食うのがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手はなんでも旗本の隠居で、こっちから時々にそっと通っていたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかその旗本の隠居が殺したんじゃありますめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "その旗本はなんという屋敷で、隠居の下屋敷はどこにあるんだ」「屋敷は大久保式部という千石取りで、その隠居の下屋敷は雑司ヶ谷にあるそうです」「じゃあ、なにしろその雑司ヶ谷というのへ行って見ようじゃあねえか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃この番町に松村彦太郎といふ三百石の旗本が屋敷を持つてゐた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その妹のお道といふのは、四年前に小石川西江戸川端の小幡伊織といふ旗本の屋敷へ縁付いて、お春といふ今年三つの娘まで儲けた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが即ち小幡の近所に住んでゐたＫのをぢさんで、をぢさんは旗本の次男であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗本に限らず、御家人に限らず、江戸の侍の次三男などと言ふものは、概して無役の閑人であつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の話の様子じゃあ相手はいずれ大きい御旗本か御大名だろうが、なぜそんなことをするんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀｜様実はね、大木戸の御前が例の串戯に妖怪談話をお始めなすって、もとこの邸は旗本の居た所で、癇癪持の殿様がお妾を殺したっさ、久しいものだがその妄念が残っていて、今でも廊下へ幽霊が出ると謂って、婦人方を恐怖がらせた奴よ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は旧旗本の嬢なりき、幼にして両親を失い、嫁して良人を失い、人に計られて財を失い、餬口のために家を失い、軒下に眠ること実に旬余、辛酸を喫して癪に閉じられてすでに絶せんとせるとき、綾子のために救われしなり、と渠は語りぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、その一時代前には、そこは一面の大竹藪で、氣の弱い旗本は、いまの交番の處まで晝も駈け拔けたと言ふのである。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸番町の御廏谷に屋敷を持っている二百石の旗本根津民次郎は箱根へ湯治に行った。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗本といっても小身であるから、伊助という仲間ひとりを連れて出た。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は身持のよくない小旗本の次三男か、安御家人か、さう云ふたぐひの者に相違ないとは誰でも容易に想像する所であつた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯田町の家は大久保｜何某といふ旗本の古屋敷で随分広い。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつらは徒党を組んで、大きい町人や旗本屋敷をあらし廻って、相当に纏まった仕事をしていたらしいんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の姦吏などハよほど勢もこれあり、大勢ニて候へども、龍馬二三家の大名とやくそくをかたくし、同志をつのり、朝廷より先ヅ神州をたもつの大本をたて、夫より江戸の同志はたもと大名其余段々と心を合セ、右申所の姦吏を一事に軍いたし打殺、日本を今一度せんたくいたし申候事ニいたすべくとの神｜願ニて候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月二十九日　坂本乙女あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "集っているのは上杉の四家老、長尾越前政景、石川備後為元、斎藤下野朝信、千坂対馬清胤をはじめ、二十五将とよばれるはたもと帷握の人々であった。",
              "citation": {
                "source": "城を守る者",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは徳川家のはたもとで酒井榊原とともに四将とよばれ、いく戦陣ともに馬をならべて戦ってきたあいだがらである。",
              "citation": {
                "source": "青竹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学と実践はたもとを分かっていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
