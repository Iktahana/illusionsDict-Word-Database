    "definitions": [
      {
        "index": 1,
        "gloss": "platinum (Pt)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
