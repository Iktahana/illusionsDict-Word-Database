  {
    "uuid": "9da531d2-41e5-5542-839f-30a27435485f",
    "entry": "爬行",
    "reading": {
      "primary": "はこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
