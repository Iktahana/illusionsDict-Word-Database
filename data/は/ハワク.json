    "definitions": [
      {
        "index": 1,
        "gloss": "to sweep (with a broom)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジョバンニはわくわくわくわく足がふるえました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街は美しく、太郎の胸はわくわくした。",
              "citation": {
                "source": "太郎と街",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう言いながら、私はわくわく興奮しだした。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニはわくわくわくわく足がふるへました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラスは二三枚物すごい音して砕け窓はわくのまま外へ落ちました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳と眼とが酔ったくれていうことを聴かなくなってしまう、と渡瀬はわくわくしながら考えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」署長はわくわくして云った。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "照子はわくせく気を急らし、腰元附添い駈出でて、永田町へ……「御急ぎッ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子はわくわくして、人ごみのうしろから、背伸びをして覗いてみた。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりはわくわくして修繕にとりかかった。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "處が……」體中はわくわくしながらも、喋舌り出してみると、思ひの外私の舌は滑かに動いた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神中の頭はわくわくとした。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がわるかつたのに――」「……………………」「さつきの電話で、貴方の声を聞いた時にはわく／＼して了つたんですもの……。",
              "citation": {
                "source": "時子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "定子の住む同じ土地に帰って来たと思うだけでももう胸はわくわくした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と男はわく／＼して私語く。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉葉はわくわくしながら、『まア、ねえ……』『何うしたの？",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇吉はわくわく震えた。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻、蜂、油虫、夜は名の知れぬ虫がしきりにズイズイと鳴き、蛙の声はわくようにした。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　通りしなにふと氣づいて襖をあけたらしくつくろつてはゐるが、實はわくわくする興味をおさへかねてわざとのぞきに來たことをその眼は語つてゐる。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真向うへ顔を持ってくるのでなくても、近く寄り添って来る薫に、大姫君は羞恥を覚えるのであったが、これだけの宿縁はあったのであろうと思い、危険な線は踏み越えようとしなかった同情の深さを、今一人の男性に比べて思うと、一種の愛はわく姫君であった。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎんはわくわくしながら、手紙をよむとすぐに支度をして送ってやった。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会衆はわくがごとくわらった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "その老人は川魚を取ったり、些細な施与を村人から受けたりして、暮していたが、彼の重な収入はわくどうに在った。",
              "citation": {
                "source": "蝦蟇",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそれはわくどう爺のうちに居なかった。",
              "citation": {
                "source": "蝦蟇",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、そのまま何事もなかったら、私はわくわくしながらも、いつしか力無く首垂れて、すごすごと下宿へ帰ってゆき、翌日また出勤するために、おとなしく眠ってしまっただろう。",
              "citation": {
                "source": "悪夢",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の上にも、谷口にも、砲声はわくように起こった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれが思いついて、だれがそれに調子を合わせるとも言えないような「えいじゃないか」のめずらしい声が、町々にはわくように起こって来た。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "南アフリカ滞在中に、あなた方がロシア軍に対して見事な勝利を収めたと知った時はわくわくしたものです。",
              "citation": {
                "source": "日本の全ての方々へ",
                "author": "マハトマ・ガンジー　Mahatma Gandhi",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
