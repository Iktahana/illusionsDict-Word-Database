    "definitions": [
      {
        "index": 1,
        "gloss": "clear weather",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "空には、晴れた空の一部分に黒い濃い雲形定規のやうな雲があつて、一寸欠け初めたばかりの月が、みえたり隠くれたり、可なり威勢よく渡れ亙つてゆくのが見られた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は土曜日で、朝からよく晴れていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "モオニングが、こんな晴れの日にお役に立ったら、うちのひとだって、よろこぶ事でございましょう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も新しい主婦の晴れやかな顔を見て、何となくこの店に一縷の明るい光がさすように思うた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心よく晴れた夕方など、亭主はこの幼時を大事そうに抱いて店先をあちこちしている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に生温かい、晴れるかと思うと大きな低い積雲が海の上から飛んで来てばらばらと潮っぽい驟雨を降らせる天候であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空よく晴れて朝風やゝ肌寒く露の小萩のみだれを吹いて葉鶏頭の色鮮やかに穂先おおかた黄ばみたる田面を見渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手洗い口すゝぎなどするうち空ほの／″＼と明けはなれたるが昨夜の雨の名残まだ晴れやらず、蚊帳をまくる風しめっぽきも心悪からず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえて西の空｜麗しく晴れて白砂青松に日の光鮮やかなる、これは水彩画にも譬うべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨と晴れとの中にありて雲と共に東へ／＼と行くなれば、ふるかと思えば晴れ晴るゝかと思えばまた大粒の雨｜玻璃窓を斜に打つ変幻極まりなき面白さに思わず窓縁をたたいて妙と呼ぶ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより下り坂となり、国府津近くなれば天また晴れたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今朝汽車が出てしまって改札口へ引返すと同時に、なんだか気抜けがしたように、プラットフォームの踏心も軽く停車場を出ると空はよく晴れて快い日影を隠す雲もない。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れきった空からは、かすかな、そして長閑な世間のどよめきが聞えて来る。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一瞬で、周圍の景色が、からつと晴れたやうな、自分が急に身の丈一尺のびて、ちがふ人種になつたやうな、やはり、晴れがましい氣持であつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんて珍らしくもない話に大仰に驚いて見せたり、一から十まで嘘ばかりの社交を行ひ、天晴れ上流の客あしらひをしてゐるつもりのケチくさい小利口の大馬鹿野郎どもに、この龍宮の鷹揚なもてなし振りを見せてやりたい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そが暗き思ひいつの日　　晴れんとの知るよしなくて、溺れたる夜の海より　　空の月、望むが如し。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには毎日午後から雷雨と聞いているから、晴れた朝によく見て置きたいと思ったからだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "三合四合と登るほどに、黒砂は凝結したように、ポロポロと硬くなって、時に生れどころの解らない大霧が、斜面を這って、煙のように舞い立つこともあったが、五合へ来たときには、それも拭うように晴れて、北風が起り初めた、鳶が一羽、虚空に丸く輪を描いて山体の半分を悠揚と匝ぐって、黒い点となって、遥かに消え失せた。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "／＼：二倍の踊り字（「く」を縦に長くしたような形の繰り返し記号）（例）おそる／＼-------------------------------------------------------　　　　上　あくまでも蒼く晴れ上つた空であり、渓谷には微風さへもない。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日も雨は止んだが空は晴れさうもなかつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はもう半ば晴れていたが千切れ千切れの綿雲が嵐の時のように飛んでいた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の晴れた夜には地面は盛んに温熱を放散して冷却し、雪などに比べては遥かに低い温度に下がって土は凍って作物の芽も凍死する事があるが、雪で蓋をするとこの過度の冷却を遮られ却って凍死を免れるのである。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はやんで、晴れ上つた青空の奧に、私は今窓に現はれた印度人が正しく前へ向けて開いてゐたかんらん色の瞳の色が光つて居るのを見つゝ歩いた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏はおちこちで鳴き盛って来たが、行く手の垂れ雲は晴れようともしなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "選まれたということの孤独の寂しさ、また晴れがましさ、責任の重苦しさと権利の娯しさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸く見渡せる晴れ空をしら雲が一日じゅうゆるく亙って過ぎた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日は全山を玲瓏と人の眼に突付けて、瑕もあらば、看よ、看よと、いってるような度胸のよい山の姿である。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山は晴れ、麓の富士桜は、咲きも残さず、散りも始めない一ぱいのときである。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は昨日までの雨に拭はれて、すがすがしく、それは海の方まで続いてゐることが分ります。",
              "citation": {
                "source": "死別の翌日",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなか伝説的存在にされてあゝ、この言語玩弄者達の世に、なまなか伝説的存在にされて、（パンを奪はれ花は与へられ）あゝ、小児病者の横行の世に！",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
