        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "嵐の中、船を軽くするため、やむを得ず一部の貨物を撥ね荷とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "緊急事態が発生し、安全確保のため高価な積荷も撥ね荷となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "船長は、乗客の命を守るため、撥ね荷の決断を下した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
