    "definitions": [
      {
        "index": 1,
        "gloss": "to view (cherry) blossoms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
