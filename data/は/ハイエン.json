[
  {
    "uuid": "759062e5-e129-5734-8a6f-42cf50667afa",
    "entry": "肺炎",
    "reading": {
      "primary": "はいえん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pneumonia",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで肺炎から結核になろうと、なるまいと、そんな事は念頭にも置かなかった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎は必ずなおると定ったわけでもなし、一つ間違えば死ぬだろうに、あの時は不思議に死と云う事は少しも考えなかったようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ肺炎だろうか。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論治る事はきっと治ると思ってみたが、ふっと二、三年前肺炎で死んだ姪の事を思い出す。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎は容易ならぬ病気だと思うと、姪の美しく熱にほてった、いまわの面影がありあり見える。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎になってしまってからの愛児の看護に骨を折るよりも、風邪を引かせぬ予防法、引いたときに昂じさせぬ工夫に一倍の頭を使う方が合理的である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月九日帰朝早々から風邪を引き、軽い肺気腫の兆候があるというので大事を取って休養していたが、一度快くなって、四月五日の工学大会に顔を出したが、その翌日の六日の早朝から急性肺炎の症状を発して療養効なく九日の夕方に永眠した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお蔭で幸いに今年はまだ流感に冒されず従って肺炎にもならずに今日までたどりついたような気がする。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七歳から十八歳へかけては肺炎カタルで少量の喀血までした。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝れば直るが無理すると肺炎になる。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先妻は、白痴の女児ひとりを残して、肺炎で死に、それから彼は、東京の家を売り、埼玉県の友人の家に疎開し、疎開中に、いまの細君をものにして結婚した。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死因について院長をはじめ醫員の大部分は急激な乾酪性肺炎の結果だらうと云ふに一致したが、彼れだけはさう信ずる事が出來なかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病室で死骸を前に置いて院長が死亡屆を書いてくれた時でも、院長は悔みや手傳ひに來た醫員達と熱心に彼れの妻の病氣の經過を論じ合つて、如何しても乾酪性肺炎の急激な場合と見るのが至當で、斃れたのは極度の衰弱に起因すると主張したが、彼れはどうしても腑に落ちなかつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾酪性肺炎か粟粒結核か、事の眞相を否應なしに定むべき時が來た。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先達は肺炎を患つて、一ヶ月余り顔を見せなかつた。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はその頃は私の方が危かったので、風邪のあとで軽い肺炎になって寝ている間に米斎君は亡くなってしまったのです。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その三日後に、急性肺炎に罹り、かなり良い医者に見てもらったのだが、ぽくりと軽部は死んだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ある日、春松は雨の土砂降りの中を廃球買いに出歩いたのが原因で、感冒を引き、肺炎になった。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は今度は肺炎に罹った。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで十八位にしか思えないわ……それに煤だらけになりながら梯子をかけて煙穴のない煙突へ管を通しに上ったりなんかして……可笑しい人ね……そうそう、あたしの肺炎が快くなりかけて、はじめてあの煙突から煙の出ているのを見付けて笑った時、あの人は泣いていたわ……けれども、もう、みんな……みんな……台なしだわ！",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断薄情に仕向けているだけに、容体ただならずと見てお神もあわて、さっそく電話で係りつけの医師を呼び、梅村医師が時を移さず駈けつけて来たところで、診察の結果、それが急性の悪性肺炎とわかり、にわかに騒ぎ出した。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　母は言っていたが、二日三日たっても、湯に馴染めそうには見えず、花の萎むような気の衰えが感じられるのだったが、湯を控えめにしていても、血の気の薄くなった躰に、赤城おろしの風も冷たすぎ、肺炎がまたぶり返しそうな気がしてならなかったので、五日目の晩帰ることに決め、翌日の朝電車で山をおりた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから大正三年の夏に脊髄病に罹って大正五年の秋まで足かけ三年の間私に介抱されたあげく肺炎で死んだ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九の冬に、肺炎になったとき、あのとき、なおらずに死ねばよかったのだ。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "という順序で子供をつくり、四男が風邪のこじれから肺炎おこして、五歳で死んで、それからすっかり老いこんで、それでも、年に二篇ずつ、しっかりした小説かいて、五十三歳で死にます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年たって、八重子は軽い肺炎に罹り、南紀の白浜温泉に出養生した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こじれて急性肺炎になった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺炎と坐骨神経痛と風眼とが同時に起った時、彼は、眼に繃帯を当て、絶対安静の仰臥のまま、囁き声で「ダイナマイト党員」を口述して妻に筆記させた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まア生きてはいるけど、あんまり達者とはいえん」「そんなこと……」「いや、ほんまや、いっそ死んだ方がましや思ってるくらいや」　三好は寂しく笑いながら、弱々しい咳をしていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも世の中にはそういう階層もないとはいえん。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
