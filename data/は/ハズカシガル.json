[
  {
    "uuid": "03aa50be-7ce5-58ea-aa02-0a78778df0ce",
    "entry": "恥ずかしがる",
    "reading": {
      "primary": "はずかしがる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行"
      ],
