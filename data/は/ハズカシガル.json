    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be shy of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして、あなたは、アパートの小さい部屋を、恥ずかしがるようになりました。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人中に出ることをひどく恥ずかしがるくせに、自らを高しとする点では決して人後に落ちない彼の性癖が、才能の不足を他人の前にも自らの前にも曝し出すかも知れない第一の生き方を自然に拒んだのでもあろう。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえ、もう恥ずかしがるところはござんせんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえー、恥ずかしがる奴のほうが、おかしいんじゃないの。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志のほうは、恥ずかしがるどころか、右手を令子の首にまわして、さらに引きよせにかかり、令子もそれにこたえて、ゆっくりと高志のベンチに躰を動かし、やがて、完全にむこうに移った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の女王は非常な内気で、母の夫人にさえも顔を向けて話すことなどはなく、病気と思われるほどに恥ずかしがるところはあるが、性質が明るくて愛嬌のある点はだれよりもすぐれていた。",
              "citation": {
                "source": "源氏物語",
                "author": "紅梅",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく恥ずかしがるふうも見せず、感じよく少女らしくはあるが機智の影が見えなくはない。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れて子供のように自動車に寝ている男の事を思うと、走ってかえって起してやろうかしら……でも恥ずかしがるかも知れないな、私は松さんが落ちついて、運転台で煙草を吸っていた事を思うと、やっぱり厭な男に思えた。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりに彼女らの恥ずかしがる言葉をささやいて、ひそかに復讐の一種を遂げることが、森林ではできない。",
              "citation": {
                "source": "ヤトラカン・サミ博士の椅子",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恥ずかしがるにゃあ及ばねえ、ニッコリ笑って出て来ねえ」　グイと引いた手に連れて、若い娘がヨロヨロと出た。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　するとお前は、恥ずかしがる代りに怒り出したね。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、我々が知る範囲の人たちをもって私が経験しましたところによりますと、訳が分らずに書を恐がるとか、書けないことを無闇に恥ずかしがるというようなことでございます。",
              "citation": {
                "source": "習書要訣",
                "author": "――美の認識について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、青年は、二十になるまでは、自分の詩や文章を見せることを、どちらかといえば恥ずかしがるものだ。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くか、恥ずかしがるか、この様子では、よもや、苦しがる事はなかろうと思って、ちょっと景色を伺うと、「まあ、窮屈な世界だこと、横幅ばかりじゃありませんか。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚くか、嬉しがるか、恥ずかしがるかと寒月君の様子を窺って見ると別段の事もない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで薫に見られるとも知らないでいる姫君たちの恥ずかしがる気持ちが姫君の側から描かれる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お恥ずかしいことでございます」「恥ずかしがることはねえが、命なんか狙われるようじゃ、好い男に生れつくのも考えものだね」　と八五郎。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくの考えでは、ふだんぎのまま、多少のつぎはぎはあるにしても、そんなもの恥ずかしがるようでは、なんのために詩人の女房なのかとおもわないではないのであるが、カメラというものは、女房にとって晴れの舞台に見えるのか、「着物一枚も買ってやれないくせになにが写真ですか。",
              "citation": {
                "source": "貧乏を売る",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "時とすると、自分で言ってる事柄を恥ずかしがることもあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにいっておくが、アリョーシャはこういう風に自分の考えを恥ずかしがるような気味で、この一か月のあいだ、どうかして、こういう考えが浮かんでくるたびに、自分で自分を責めるのであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃り落とした頭や印のついた上着などを彼として恥ずかしがる筋がどこにあろう？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年前の彼のことを、いえば今は恥ずかしがる大吉なのを知っている。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冗談じゃないわよ、新さん、男のくせになによ、そんなこと恥ずかしがるなんてだらしがないじゃないの、はっきりしなさいよ」　新八は下帯をとった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬のほうはまるなどというやさしそうな名にもかかわらず、四十キロもありそうな巨躯と、ゴリラも恥ずかしがるだろうようなものすごいつら構えをしていて、その子供をみつけると、歯を剥き出して唸りながら、のそりのそりと近よって来るのである。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春彦という自分の名を恥ずかしがる程度に神経質で、愛他精神と利己主義を兼ね備えた即物的センティメンタリストで、そうして事業家であった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルタルコスは、「つまらないことを恥ずかしがる悪い癖から、何を要求されても意気地なくずるずると承知してしまう者は、やがてまた、わけもなく前に言ったことを翻し約束に背く」といったが、同様に軽々しく喧嘩を始める者には、また軽々しくそれをやめる癖がある。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじ、口に出して頼むからはずかしがるのだ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて欠点をあげれば、彼安東はまるで徳川時代の箱入娘のように気が小さすぎて、人前にもろくに口がきけず、況んや婦人に向いあうと、たとえ相手が八十の梅干婆さんであっても、彼は頬から耳朶からすべてを真赤に染めてはずかしがるのだそうであった。",
              "citation": {
                "source": "心臓盗難",
                "author": "烏啼天駆シリーズ・２",
                "note": "青空文庫"
              }
            },
            {
              "text": "五番目の子供だね、みな見知らぬ人たちだもの、はずかしがるのは無理もないわけさ。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "はずかしがることはないぜ」「あんたに会うのが、はじめてだから、ダメなのさ」　再び戻ってくるという仕掛が妙であった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
