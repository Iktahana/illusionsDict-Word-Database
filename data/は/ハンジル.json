          "literary": [
            {
              "text": "話し声で判じると三、四人らしい。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯草の中にぽつりと尖がっている、無愛想な灯台形の白い小箱が、運命を判じるアンテナのように底気味悪く見え、その声を運んで来るものまでが、ただの科学的なことではすまされぬ、神秘な光りのように見えるのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「悪声」　それは、焔の音を判じるのであった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "話し声で判じると三四人らしい。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "利口な人間は知りたがるし、知っていて正邪を判じる力があり、敢て悪を行わぬところに美点はあるかも知れないが、単に知らぬということは頭が悪いというほかの何物でもなく、長じて知るようになると、純変じてどんなスレッカラシになるか分りやしない。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その一〔判官巷を往く〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "美か醜かで判じるような物指に、どれだけの力があろう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、地形から判じると、駿河の今川の背後には、強国北条が小田原にある。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
