        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "紅茶に砂糖の代わりにハニーを少し入れよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "このヨーグルトは、ハニーとフルーツの甘みが絶妙だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "採れたてのハニーは、まるで宝石のように輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "打楽器セクションの指導者は、なぜか、かならず、「高橋路子先生」と、フルネイムで呼ばれている（慶一は、女のドラマーはハニーカムズのハニー・ラントリーしか知らないので、心のなかでは、高橋路子先生ではなく、ハニーと呼んでいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、『ハニーにおまかせ』のハニー・ウェストとは、きちんと区別してだ）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハニーカムズは、オン・ビートは嫌いだ、という慶一の主張で落選。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ハニーにおまかせ』のハニー・ウェストは、中学生のころは、こんなじゃなかったのだろうか。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりに、そんなことができるとしての話だが、この子を二五歳にして、色情狂にしたら、ハニー・ウェストになるんじゃないか、という気がする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お兄さん」　と呼びかける幼いハニーちゃんに、慶一は思わず返事をしそうになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くで見ると、ハニー・ウェストには似てない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、レイ子は、ハニー・ウェストなんかにはまるで似てない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生のキアウェ・ハニーさ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのドーナツに、キアウェ・ハニーは、この上なく調和していた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "本にはさまれてラジオがあり、ナット・キング・コールがピアノを弾いているトリオの演奏で、『ハニーサックル・ローズ』が聞こえている。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
