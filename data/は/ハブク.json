[
  {
    "uuid": "5ce84159-b336-53dc-9ae9-8e877d844e2c",
    "entry": "省く",
    "reading": {
      "primary": "はぶく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to omit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これを省くとも鉄道運河の大体の設計にはなんらの支障を生ずる事なかるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにも同人を擧げなければ「青空」についての全體は語られないが、まとまつて「青空」のことを書く積りでもなし、管々しいことは省く。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、これを省くと何となく物足りない感じがします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "入用る雑用を省くと唱え、八蔵といえる悪僕一人を留め置きて、その余の奴僕は尽く暇を取らせ、素性も知れざる一人の老婆を、飯炊として雇い入れつ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはここの場面をも悉しい説明することを省く。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君の大體の輪廓は、嘗つて一文を草してこれを描いてゐるつもりであるから今は省く。",
              "citation": {
                "source": "淡島寒月のこと",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　要なければここには省く。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒の肴は品数を省くほど酒の味は深くなるんですよと言った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉六は片手に盃を、片手では額を押えて、ちっ／＼／＼と笑って、「省くにしても、少し省き過ぎましたな。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日の事とて妻は娘を家に残しつ、小児を携へて出で行きしが、米買ふ銭を算へつゝ、ふと其口を洩れたる言葉は「もしこの小児なかりせば、日々に二銭を省くことを得べきに」なりし。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "イニシャル用の特大の飾り活字を用意するか、いっそイニシャルを省くか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コード化の作業をライターにやらせれば、これまで印刷屋が受け持っていた作業のなにがしかを省くことができると出版社が気づいてからは、フロッピーディスクで渡すか電話回線で原稿を送るかになった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らにはよくわからない社会のことですから上の品は省くことにしましょう。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなのを今度は省くことに源氏は決めたのである。",
              "citation": {
                "source": "源氏物語",
                "author": "絵合",
                "note": "青空文庫"
              }
            },
            {
              "text": "書いた人の身分、書き方などが補ってその時はよい文章、よい歌のように思われたことも、改めて本の中へ書き載せると拙い点の現われてくるものであるから、手紙の文章や歌というようなものは、この話の控え帳に筆者は大部分省くことにしていたので、採録したものにも書き誤りがあるであろうと思われる。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "その尾の縁に鰭を附けて誇る事となったが、更に支那人の喧嘩に豚尾を巻き固めたごとく、鰭を畳み頭の一側に立たせて長尾で頭巾に巻き付ける風になり（ハ）、後には手数を省くためニのような出来合のシャパロンが出来た。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "を一言すればいゝんだが、冗言に陥ることをおそれるから省くが――。",
              "citation": {
                "source": "鸚鵡の思ひ出",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――以下の数言は省く。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ説明は省くが、兎も角彼は、それを新しい「某誌」に出したのである。",
              "citation": {
                "source": "「或る日の運動」の続き",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけにそれは勿論、創作以外にわたる「お互ひに許してゐる無遠慮、同情、非難」で、同志に解りきつたことは省く……といふやうなあんばいで、極めて安易に行ふ、客観的には批評の形式になつてゐないといふやうなものより他に経験がない。",
              "citation": {
                "source": "海浜日誌",
                "author": "六月創作評",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他にも二三あつたがこゝでは省く。",
              "citation": {
                "source": "海浜日誌",
                "author": "六月創作評",
                "note": "青空文庫"
              }
            },
            {
              "text": "（普通のそれとは趣きを異にしてゐるが、説明は省く。",
              "citation": {
                "source": "余の倅に就いて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（以下を省く）　それからちょうど夕方の事でした。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "Vitality――別にこれらは重要でないから註は省く。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラン・ポーの作品――殊にかの「黒猫」のごときは、当然ここに編入すべきであったが、この全集には別にポーの傑作集が出ているので、遺憾ながら省くことにして、その代りに、ポーの二代目ともいうべきビヤースの「妖物」を掲載した。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "序／目次",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｂ、Ｃ、Ｄ、Ｅ……そして私などが、それから何んな申出をし、何んな感慨に陥つたかは今日は省くことに仕様よ。",
              "citation": {
                "source": "くもり日つゞき",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロヤ戦争余聞、木馬の腹に潜んで敵地に赴く決死隊の一員、勇士シノンに就いてのエピソードを挿入すると、この場の情景が鮮明になるのであるが、「シノンの芝居」は私が前の晩に森の中で大見得切つて演じた後であるから、省く。",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、それがどうして斯うなつたかの説明は省くつもりだ。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "の記述は省くが、あの「親不孝な男」を読んだ人にだけは想像がつくかも知れない。",
              "citation": {
                "source": "冬の風鈴",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここに、その時訪ねた修道院の印象なり感じなりを述べることは、既に「修道院の秋」の中に書き盡したことであるから、はぶくことにしたい。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
