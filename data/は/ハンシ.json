    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese calligraphy paper (approx. 25cm by 35cm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
