[
  {
    "uuid": "52e1d2c9-574f-568c-adda-2aff6c3c1c05",
    "entry": "敗訴",
    "reading": {
      "primary": "はいそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
