    "definitions": [
      {
        "index": 1,
        "gloss": "lying on one's belly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "はっと鯰入とともに泳ぐ形に腹ばいになる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根が地面についていて、そのうえ、入り口がたいへん低かったので、家の人たちは、腹ばいになって、出入りしなければなりませんでした。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙出し人形が、さっそく、テーブルのはしまでかけていって、腹ばいになって、引出しをほんのちょっとあけました。",
              "citation": {
                "source": "イーダちゃんのお花",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そうして彼女を無事に逃がして遣りたいというような願望を、夢うつつのように抱きながら一所懸命の思いで腹ばいに起き直った。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はかわりばんこに、泉のふちの、しだやぜんまいの上に両手をつき、腹ばいになり、つめたい水の匂いをかぎながら、鹿のように水をのみました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兵児帯のまま腹ばいになって、夜具の裾の方に投げ出してあったハンドバッグを、素足の先につまんで、ひょいと肩越しに枕元へほうり上げ、その中から煙草を取り出すと、「火貸してちょう……。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年の五月、私が麹町の武田さんの家をはじめて訪問した時、二階の八畳の部屋の片隅に蒲団を引きっぱなして、枕の上に大きな顎をのせて腹ばいのまま仕事していた武田さんはむっくり起き上って、机のうしろに坐ると、「いつ大阪から来たの？",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、彼女がパトロンと一緒にいる光景がちらついて、眠れず、机の上に腹ばいになって、煙草ばかし吸った。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると靴ぬぐいのようなものは、むくむくと半たち上って、よろよろと肉のきれのそばへ来て、たおれるように腹ばいました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波から高野線の終電車に乗り、家に帰ると、私は蚊帳のなかに腹ばいになって、稿を起した。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると天井の丸太からつるしたランプの光に集まる虫を追いながら、必要な計算や製図をしたり、時にはビスケットの罐をまん中に、みんなが腹ばいになってむだ話をする事もある。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鞄を受け取ったホームズは凹地の底へ下りていき、敷物を中央へ押し出してから上に腹ばいになり、両手に顎を載せて目の前の踏みにじられた泥を注意深く調べた。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、三上は、西沢の室の前に、腹ばいになって、西沢の寝物語をすっかり聞いたりなどするのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "四〇　藤原は、自分の寝箱の中で、腹ばいになって、紙きれに何か書いていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてつぼを伏せるのかい」　ごろりと腹ばいになると、あざやかな手つきで、ガラガラポーンと伏せました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三は午後から二階の六畳に腹ばいになって、東京や行田や熊谷の友人たちに転居の端書を書いた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直なところさ」お町グルリと腹ばいになった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩組みの上に腹ばいになり、滝壺の中をのぞいている。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、文学恋いから太宰だの、椎名麟三だのを腹ばいになって読む。",
              "citation": {
                "source": "平和運動と文学者",
                "author": "――一九四八年十二月二十五日、新日本文学会主催「文芸講演会」における講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこには年の若い軍楽隊の楽手が一人甲板の上に腹ばいになり、敵の目を避けた角燈の光に聖書を読んでいるのであった。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっち、あげんこツウ、お父さんや、おッ母さんが食えんでも、めんめが腹ばい肥やしたかなア」「食いたかもの、仕様がなかじゃなっか！",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "タローはつかれてへとへとになっていたのか、岩のところへ来ると、そこへ腹ばいになって、ウオー、ウオーと谷底をながめながらほえたてています。",
              "citation": {
                "source": "ふしぎな岩",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕は腹ばいになり、一本の巻煙草をふかしながら、この妙に澄み渡った、小さい初秋の風景にいつにない静かさを感じました。",
              "citation": {
                "source": "手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他はめいめい猟銃をさげて、堤のかげをつとうて河口へおり、浜辺の岩のあいだを腹ばいになってすすんだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日毎日おしめで取って、お床も居間の陽のあたる囲炉裏の部屋に移して、母は始めは腹ばいして床から床へ移られたが、だんだん不可能になって、私が抱えてお床を移して差上げた。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそのきらきらきらは、恐竜がそれまでに腹ばいになっていた岩の上で特にきらきらきらとかがやいたように見えた。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪人は鉄の棒を放りだして、ガラス天井に腹ばいになると、岩がなくなって出来た穴の中へ、細い長い腕をつっこんだ。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、ヤヨイ号は、かたい雪の斜面に、ななめにかしいだまま、腹ばいになっているのであった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがしょうこに、それから五、六｜日のち、海蔵さんは、椿の木に向かいあった崖の上にはらばいになって、えにしだの下から首ったまだけ出し、人々の喜捨のしようを見ていました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと引返して、また手を支くと、婦の膝をはらばいに乗出して、（何じゃな、向うから金子くれい、と使が来て店で待つじゃな。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
