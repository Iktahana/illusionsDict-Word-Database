    "definitions": [
      {
        "index": 1,
        "gloss": "to carry out (of somewhere)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其骨の尖角の間から洩るる大空が、気味の悪いほどに澄切っているのは、軈て真黒な雪雲を運び出す先触と知られた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこのあひだ中は随分世話を焼かせた復興局の人たちですから、かみさんや娘たちも精々お世辞をならべて、お誂へを運び出すと、三人ともに黙つて飲んでゐるばかりで、わたしの方から何か話しかけても、碌に返事もしないんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さまの考えで、部屋が違っていたにもせよ、自分が帰って来るのを待って引越させてくれてもいいではないか、たとい雇人であろうとも、他人の留守に勝手に、荷物を運び出すなんて……女中のせいではないと思いながらも、かの女はつい険のある眼になって、「そして、新しいお部屋は……」と訊いた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女を他の部屋へ運び出すと、裸にしてそこの真っ白いベッドの上に革紐で固く縛りつけた。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には握飯を貰いて、ニタニタと打喜び、材木を負うて麓近くまで運び出すなどいうがあり。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "工事列車の通る線路際まで煉瓦を運び出すのだった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はふるえる手先にその皿をうけ取って、座敷へいよいよ運び出すまでは元の箱へ大切に収めておくことにした。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どやつか牢番に鼻薬をかがして、清め塩を盛らしたんだろうよ」「じゃ、破牢罪人の野郎め、そのすきになんか細工をしやがったんですね」「穴も掘らず、壁も破らずに破牢したっていや、牢役人どもとぐるでのことか、でなきゃ死骸を運び出すときに細工したとしか、にらみようがねえじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まてッ」「はッ」「いずれは警固もきびしく運び出すであろうゆえ、それと分らば合図致せよ」「心得ました！",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビールやサイダーの壜を運び出すのもあった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蟹の顔を見ないうちは迂濶にほかのお料理を運び出すことも出来ないので、まことに困っていると、お杉は顔をしかめて話しました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "午に近いころになって、黒太夫の家では木馬を運び出すことになりました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは休養のために二、三日の暇を貰うことにして、あなたの輿のなかへ家僕の死骸をのせて持ち出せば、誰も気がつく者はありますまい」　言われた通りにして、彼は家僕の死骸をひそかに運び出すと、あたかも軍門を通過する時に、その輿のなかからおびただしい血がどっと流れ出したので、番兵らに怪しまれた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "池北偶談",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ヨイショ、ヨイショ、ヨイショ、ヨイショ、武器を運び出す掛け声だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、ランプがともると間もなく、性体なく寝込んで、朝は、一番馬（トロツコが通じてゐる山の中腹まで、板にされた製材を運び出す馬の一行）の鈴で目を醒した。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "自動車問答６・25（夕）　亜米利加の前大統領タフト氏が、先日ある街の四辻で、自動車からのつそりとあの大きな図体を運び出すと、其処に立つてゐた八つ許りの子供が前に出て来て、鄭寧にお辞儀をするのに出会した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人更に語を続ぎて「さる騒ぎに紛れ居る内、行政部附の人は来りて最早約束の期限も過ぎたれば只今この家を立ち退いてくれと言ふや否やわれらの荷物を外に運び出すなど一時は混雑を極めたるなり」とわれは怒気は最早頂上に達せり。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "×村から野菜を○○へ運び出すのに、道はここ一つだ。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ひとつ運び出すひまもなく類焼の災にあってしまったのであるが、苦心して描いた縮図や絵の参考品も失ってしまった時には、さすがの私も呆然としてしまった。",
              "citation": {
                "source": "母への追慕",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さん行って参ります」「お母さん帰って参りました」　文展に出品する絵でも、その他の出品画でも、必ず家を運び出す前には、母の写真の前に置くのである。",
              "citation": {
                "source": "母への追慕",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく家財や、はづした建具を奥庭へ運び出す音がし出した。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "火災に遭つたものの荷物を運び出す舟が、大川にはばら蒔いたやうに浮かんでゐる。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が鰻飯の丼を運び出す。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鹿の死骸も、田母沢源助の戯れ呆けて寝た体も、運び出す暇はなかった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のりをつけるもの、帯封を張るもの、県別に束ねるもの、戸外へ運び出すもの、四囲はほこりがもうもうとして、みな、たすきがけで、手拭の姉様かぶり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして長い時間をかけて坑口まで運び出すと、医局に持ち込んで検屍を受けてから、初めて僧侶や、身よりの者の手に引渡すのであった。",
              "citation": {
                "source": "斜坑",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の仕掛けに気がついて天井裏に潜り込んだ時に、予期した通り最後の研究の原稿は見つかりましたが運び出す事が出来ません。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし大急行で、ここからはこびだすのでないと、まにあわないかもしれませんよ」　そのとおりであった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初その部屋のものでないものをはこびだすときに、もしもその中に食べ物など（菓子の盛ってある菓子器など）があったなら、一番さきにかたづけなければなりません。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "できるだけの書籍を集めて、はこびだすようにしろ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
