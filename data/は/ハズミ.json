  {
    "uuid": "c1a5ca81-6379-5a23-b1ea-0ba557fb1760",
    "entry": "弾み",
    "reading": {
      "primary": "はずみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
