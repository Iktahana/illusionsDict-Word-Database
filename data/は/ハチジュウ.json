    "definitions": [
      {
        "index": 1,
        "gloss": "eighty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（Ｆ・Ｏ）８０＝（Ｆ・Ｉ）峠の頂上　五人組が腰打ち掛けて待って居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主役に据えたＮＥＣはその後、16ビットに移ってからもＰＣ―９８００シリーズを大成功させました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その市場独占の経過をたっぷり見てきた後で再刊するのなら、せめて長めの後書きを用意して、ＰＣ―９８０１が市場を制覇する、その後の流れにも触れておきたい。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ＰＣ―９８０１の成功の軌跡をさらりと跡づける」くらいの気持ちではじめてみると、話を聞かせてくれたある人が、驚くような手がかりを与えてくれました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＰＣ―９８０１にとって社内のライバルのような立場にあったＰＣ―１００という機械を作るときには、「パーソナル・ダイナミック・メディア」を作ろうと、はっきり意識していたと言います。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の事業の責任者に、「ＰＣ―９８０１にＰＣ―１００と二つの16ビット機がぶつかって、売りにくくはありませんか」と、図式的な質問をした証拠が残っています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "再取材でそのコメントに巡り合って、ＰＣ―１００をＰＣ―９８０１の横に置き、二つの対抗関係を軸に流れを見ていけば、一九八〇年代に起こったことが良く見えるだろうと気付きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "筺体も付いていない、基板むき出しのアップル※の互換機やＰＣ―９８０１、シンセサイザーなどでうまった下宿に、さっそく上がり込んできた元気のいいオヤジは、人なつっこそうな笑顔をはさみながら話し始めました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前のきっかけとなったのは、ＰＣ―９８０１用に書いたハイパーカードを動かすための環境でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら自分でと、日本の標準機のような地位を占めたＰＣ―９８０１で、ハイパーカードを見られるようにするソフトウエアを作ろうと考えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―９８０１という日本独自の規格が幅を利かせていたところに、一九九〇年代に入って世界の標準仕様がなだれ込んでくると、日本の企業からはソフトウエアに関する新しい試みがほとんど生まれなくなりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校三年の時、友人の兄がＮＥＣのＰＣ―８００１を持っていると耳にします。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "設計のいろはをここでたたき込まれる一方で、会社に転がっていたＰＣ―８００１を使って収支計算を処理するプログラムを書き、これがきっかけになって、設計のかたわら業務のコンピューター化を仰せつかります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その会社を代表するＰＣ―９８０１は、日本でも大きな勢力圏を築いたＰＣ互換機と同様に、ウインドウズを採用しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気がその後の独走の基礎を固めるＰＣ―８００１の発売に踏みきった一九七九年八月から一年半をさかのぼる前年三月にはすでに、Ｔ―４００と名付けた試作機を西ドイツのハノーバー・メッセで開かれたショーに展示するところまでこぎ付けていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターで主流になった、Ｘ８６（８０８６、８０２８６、３８６といった具合に、ケツに８６とつく一連のシリーズだ）を作っているインテルという会社は、そもそもは日本のメーカーの依頼を受けて電卓用部品としてマイクロコンピューターを作った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後日本電気では、半導体部隊に変わって本流の電算部隊がパーソナルコンピューターを引き継ぎ、ＰＣ―９８００シリーズの大成功となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "つごうがいいことに、モトローラという別の会社はＤＥＣのミニコンピューターの作りを意識した、６８系（６８０００、６８０２０、６８０３０と続くシリーズだ）の製品を出していた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、今更インテルのＸ８６にマイクロソフトのＭＳ―ＤＯＳで追いかけても勝負にはならないだろうと踏み、モトローラの32ビット６８０２０と、ＵＮＩＸで行くというアウト・ラインだけを決めていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "余談になるが（まだ本論に入っちゃいないか）、香川の高校生が四十人がかりでＸ６８０００狙いのウイルスを作ったと報じた一件を始め、『朝日新聞』のパーソナルコンピューター関連記事は実に、祭りに出張ってくる見せ物小屋のレベルで楽しませてくれる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "組み立てキット式のＡｌｔａｉｒ８８００用に移植したベーシックをメーカーのＭＩＴＳ社に売り込んだのをきっかけに、ビル・ゲイツがマイクロソフトを起こしたのが一九七五年。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "８０８６、８０２８６を搭載した低価格のノートブック・マシンは、ワークスに類似した低価格統合ソフトとの組み合わせで専用ワープロを越えた情報家電の本命をパーソナルコンピューターの裾野に形成することになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かてて加えて、日本電気がＰＣ―９８００シリーズの三百万台突破を記念して開いたスーパーセミナー（名前からして物凄い）には、ビル・ゲイツに加えてインテルのアンディ・グローブ社長が登場。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハードウエアは、８０２８６搭載の松下電器のＰａｎａｃｏｍ　Ｍ５３０である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ターゲット・マシンはその直後に発表された日本電気のＰＣ―９８０１とされた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが乗り込んできた本流のコンピューター屋が作ったＰＣ―９８０１と同門のガチンコ勝負となって、破れ去った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
