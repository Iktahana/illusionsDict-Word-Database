        "examples": {
          "standard": [
            {
              "text": "パーティー会場の真ん中に大きな配膳台が置かれ、彩り豊かなオードブルが並べられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "給食の時間は、廊下にある配膳台から教室までおかずを運ぶのが当番の仕事だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "狭いキッチンでも、折りたたみ式の配膳台があれば作業スペースを確保できて便利です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "キャビアを分厚に塗りたくつたパン片が、三畳敷ほどもありさうな配膳台にぎつしり並べてあることもある。",
              "citation": {
                "source": "灰色の眼の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアと配膳台とのあいだの片隅の、ストーブの近くに、一人の娘がうずくまって、マッチの光に照らされ、やっと見開いたねぼけ眼で彼を見つめていた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
