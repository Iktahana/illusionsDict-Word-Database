        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ポマードは生え際ばかりに厚く塗つたくつてあつて、その太い首が動くたびに山猫か何かの感じがした。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから頬は……生え際は……耳は云々。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木の鼻に香油の匂いがして、胸の前に後｜襟の赤い裏から肥った白い首がむっくり抜き出て、ぼんの窪の髪の生え際が、青く霞めるところまで、突きつけたように見せた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚木の鼻に香油の匂いがして、胸の前に後襟の赤い裏から肥った白い首がむっくり抜き出て、ぼんの窪の髪の生え際が、青く霞めるところまで、突きつけたように見せた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜ざね顔の上品な生え際と可愛らしい腮。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼は情熱に輝きみちみち、その唇は何とも形容の出来ない恨みに固く鎖されて、その撫で上げた前髪の生え際には汗の玉が鈴生りに並んで光っていた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭半分も後退した髪の毛の生え際から、ふらふらと延び上った弱々しい長髪が、氏の下駄｜穿きの足踏みのリズムに従い一たん空に浮いて、またへたへたと禿げ上った額の半分ばかりを撫で廻わす。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はあ」「歯の生え際には歯茎が痒ゆいんだって言うことよ」　こどもは母親の指をうるさがって、意固地のように歯を食いしばる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとの羨むような美女でも、もし彼女がウェーブかセットを掛けた直後、なまなましい色気が端正な髪や生え際から漂っている時は、私はよしんば少しくらい惚れていても、顔を見るのもいやな気がする。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は亜麻色の髪の生え際あたりまで顔を紅潮させ、後者は珠のような目を不愉快だ、腹が立つ、と言わんがごとくぎらつかせていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ブラウンはぎくりとして生え際まで顔を真っ赤にさせた。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い髪の生え際まで紅潮していた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして下に掛けられたキャラコの白い布を引っ張って、生え際の所までかけた。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "根の生え際が小屋の屋根からではずつと上にあるので猶更に延びて見える。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭をとつたら顏が赤らんで生え際には汗がにじんで居た。",
              "citation": {
                "source": "炭燒のむすめ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "△石渡風古――『おしばな』少女の表情、デッサン、主題いづれも良い、髪の上の色のあせた淡さはさらにいゝ、髪の生え際は美しいが、眉と眼の関係は拙い。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿げ上がった額の生え際まで充血して、手あたりしだいに巻煙草を摘み上げて囲炉裡の火に持ってゆくその手は激しく震えていた。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼蓋の裏を返して見たり、鼻の孔を仰向かして見たり、口を開かして覗いたり、耳朶の裏表を検めたり、眉や髯の中から生え際まで撫でて見たり、医者の診察の二三層倍も入念に三人を代る／＼に見てから徐ろに天眼鏡を下に置いた。",
              "citation": {
                "source": "人相見",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者大原は中脊の、でっぷりふとった赭ら顔の紳士で、額の生え際は大ぶ禿げ上っていた。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "睫毛の長い目や、生え際の綺麗な額の辺が、うつむいていると、莫迦によく見える。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "生え際がクッキリしていて、お作も美しい女だと思った。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "口を窄めて火を吹いている、生え際の詰ったお増の老けた顔を横から眺めながら、お庄は毎日弁当を持って図書館へ通っていた芳村の低い音声や、物優しい蒼い顔を想い出していた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が巴里へよこした手紙には、心細いほど赤く短く切れちゃったなんて書いてあったっけが」「漸くこれだけに成ったんですよ――」　と節子は言って、生え際のあたりの髪の毛をわざと額のところへ垂れ下げて見せた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "背丈は一メートル六十、色の白い青年で、額の生え際に小さい傷跡がある。",
              "citation": {
                "source": "鍵から抜け出した女",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか生え際の薄い様な人であったがなどとも思われる。",
              "citation": {
                "source": "ひととき",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ一寸来てこの様子を御覧」　その叫びで、十三の痩せて雀斑だらけのアーニャは、生え際まで赧くなった。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私の額口が、さよう独立的と言いますか後家星と言いますか、生え際が角ばっている。",
              "citation": {
                "source": "三味線の胴",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の女の人は生え際がせまくて山形になっている。",
              "citation": {
                "source": "三味線の胴",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はもう童女じゃない、処女になってしまったんだね」　ファニーは見る見る額のはえぎわまで真赤になった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでまずこの境界線のはえぎわを整理した後に平たい面積に掛かるほうが利口らしく思われた。",
              "citation": {
                "source": "芝刈り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
