        "examples": {
          "standard": [
            {
              "text": "「はてはて、どうしたものか。こんなに難しいとは予想外だ」と彼はうなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「はてはて、これで本当に合っているのか、自信がないな」と彼女は首を傾げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「はてはて、昔はもっと簡単だったような気がするんだが」と老人は回想した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "はてはてこころいたいことでござる。",
              "citation": {
                "source": "狂言『食道楽』",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳　「はてはて、そのように争うてはなりませぬぞ」鼻　「ヤア、大切な鼻をつまむとはなにごと」目　「どうせそなたは鼻つまみもの」　　　と二人あらそう。",
              "citation": {
                "source": "狂言『食道楽』",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてはて意気地のない」「弱いのです」「弱いのは、剣術じゃろう」　と、ひどい皮肉をいう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
