[
  {
    "uuid": "437ca5c5-57b3-5844-bb03-d5593f1725a5",
    "entry": "撥ね付ける",
    "reading": {
      "primary": "はねつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
