    "definitions": [
      {
        "index": 1,
        "gloss": "extensive knowledge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
