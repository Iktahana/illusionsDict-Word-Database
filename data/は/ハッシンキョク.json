        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "発信時刻は十時四十五分、発信局は大塚である。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば、この旬日、発信局の知れない電波信号が盛んに受信器に混信すると思っていた。",
              "citation": {
                "source": "十八時の音楽浴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "発信局はロンドンなんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "発信局はどこだかはつきり判らない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その発信局の名がＥ市の駅。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その報ずるところは、人数も発信局も区々で、いずれを信ずべきだろうかと、正造はなおも躊躇した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
