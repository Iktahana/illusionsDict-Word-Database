    "definitions": [
      {
        "index": 1,
        "gloss": "(school) recital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ときどき素人の義太夫発表会が、まちの劇場でひらかれる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムの夏子も、誰かとアベックでリベラルクラブの発表会へ行ったのか、店にはいなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "知合いの医学博士の夫人が遊芸好きで、ちょうどいたいけな祥子くらいの女の子に、本式に日本舞踊を習わせていて、その踊りの師匠の花柳｜何某の春秋二度の発表会に、今日がその子の初舞台である。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "エキスポから十日ほどたった二月二十二日には、ハードウエアの会社の新製品発表会に出かけています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士通が出しているＦＭ　ＴＯＷＮＳというパーソナルコンピューターの新機種発表会に、危うく遅れかけたからだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして十一月七日、息せき切って駆け込んだ新製品発表会は、この電子紙芝居によるＦＭ　ＴＯＷＮＳの表現力を表に立ててスタートを切ったばかりだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが発表会の席上でオレの脳裏をかけ巡っていたものは、改善されたスペックの数値ではなく、四か月ほど前にやはり自らの開発したマシンを用いてプレゼンテーションを演じた人物の姿だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして厚顔の芸能レポータも顔負けの暴問が発せられたのは、事もあろうにダイナブックの発表会場であったのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八九年六月二十六日、新宿センチュリーハイアットで開かれたダイナブックの発表会で新しいマシンの概要を知ったオレは、心底ぶっとんだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に浮かんだ疑問を抑える理性も分別もなく、発表会が終わるや横綱のもとにすっ飛んでいって挨拶もそこそこに聞いてしまったのである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソニー本社で開かれたラップトップＮＥＷＳの発表会場を抜けて階段を下りる途中、偶然一緒になったＤ博士に「パームトップとラップトップとどちらにより興奮してます？",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同社のトッテン社長がじつに稀代のパフォーマーであり、オレがここの新製品発表会をほとんど『たま』のコンサートに向かう乗りで楽しみにしていることも書いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はこの日のオレはある下心をもって発表会場に向かっていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのトッテン師匠が、アシストの新製品発表会で一席語る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが少年の日の寝床に溢れたあの終わりを恐れる涙を、一九九〇年七月十一日、神宮球場脇のイベント会場、ＴＥＰＩＡで開かれたマイクロソフトワークス（以下ワークスと書く）の発表会場で、なんとオレはまざまざと思いだしてしまった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "発表会を終えた後、別室に用意されたパーティー会場で酒肴を振る舞うスタイルは、これまでに何度も見てきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし参加者の脳味噌にはじめからアルコールをぶち込んでハイな雰囲気を盛り上げ、イベントを回していこうという仕立は、パーソナルコンピューターではもちろん、かつて数年間にわたって総なめにした経験のある栄華を極めた時代のオーディオ業界の発表会でも、まったく経験したことがない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "冒頭に立ったマイクロソフトの古川享社長は、この日の発表会にパーソナルコンピューターとはこれまで直接関係を持たないできた幅広い分野の雑誌の記者を招いたことを指摘し、会社紹介から挨拶をスタートさせた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこの発表会でも顔を見かける業界誌の記者には、こうしたマイクロソフトそのものの紹介は蛇足だったろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この冒頭の挨拶こそ、振り返ってみればワークスの発表会がある意味で葬儀であったことの象徴だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ではワークスの発表会場で、何が死に、何が生まれたのか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊ワークスの発表会には、入院中の病院を抜け出していった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "破れかぶれのライターに発表会を葬式にされてしまったワークスは、売り上げランキングの上位をキープする大ベスト・セラーとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四六年以後久しく行われなかった学会、研究発表会などが各専門分野で盛んに行われ始めた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "池袋のサンシャイン60で開かれたＪＸの発表会で、早水潔は、自らｊＸ―ＷＯＲＤの商品説明に声を張り上げている浮川和宣の姿を目にした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九九三（平成五）年五月十七日、新高輪プリンスホテル飛天の間に業界関係者と報道陣およそ二〇〇〇人を集めて、マイクロソフトはＷｉｎｄｏｗｓ３・１日本語版の発表会を催した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜田はこの指示を置きみやげに、ＶＭの発表会にも臨むことなくパーソナルコンピューター事業の表舞台から去った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "発表会の最後に再び立ったビル・ゲイツは、Ｗｉｎｄｏｗｓが切り開く未来をあらためて展望する中で、「我々のＷｉｎｄｏｗｓに対する野心はコンピューターを超えている」と指摘した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎緑郎が服部正の作品発表会で、自作の「インターメッツォ」を初めて公表した。",
              "citation": {
                "source": "日記",
                "author": "一九三六年（昭和十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
