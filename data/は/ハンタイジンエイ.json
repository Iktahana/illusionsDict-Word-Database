        "examples": {
          "standard": [
            {
              "text": "選挙戦では、与党と反対陣営の候補者が激しく論戦を繰り広げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "交渉のテーブルでは、我々のチームと反対陣営の間に深い溝があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの企業は常に競争相手と見なされる反対陣営の動向を注意深く観察している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "全てのナショナリストは、反対陣営の言葉を潰すために自分の言葉を広げることを義務と心得ている。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
