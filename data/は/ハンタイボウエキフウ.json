          "standard": [
            {
              "text": "赤道付近では、貿易風とは反対方向に吹く反対貿易風が見られることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "気象学では、地球の大気循環における反対貿易風の役割が研究されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "高層大気では、地表付近の風とは異なる反対貿易風が吹いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私どもアンボン人は、サムナー法といって、星を見て、夜だけ航海いたすのですが、東南貿易風が西北の反対貿易風にかわる変り目の一ト月と、雨季明けの一ト月は航海しません。",
              "citation": {
                "source": "手紙",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
