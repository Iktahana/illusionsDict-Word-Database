    "definitions": [
      {
        "index": 1,
        "gloss": "string tied across the open chest of a haori",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
