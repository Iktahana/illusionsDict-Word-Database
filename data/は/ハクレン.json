        "examples": {
          "standard": [
            {
              "text": "この湖には、大きな白鰱がたくさん生息している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "白鰱は、プランクトンを食べる淡水魚だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "養殖池で白鰱を育て、食用として出荷している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「それぢや、何かい、こんなに言うても不承してはくれんのかの。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「誰も歡迎會をやつてはくれんのかね、昔の同志諸君はどうした。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "判っているなら、何故、士分と、同じに取扱ってはくれん。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "『“ときのこえ”を買ってくれませんか、一部二銭です』『よし買おう、その代わりに君の帽子には世を救うと書いてあるがひとつおれを救うてはくれんか？",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、誰も取り合うてはくれん。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
