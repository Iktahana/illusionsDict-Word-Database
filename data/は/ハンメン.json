[
  {
    "uuid": "17c7945d-54af-5620-88f0-a4d300e84d0e",
    "entry": "半面",
    "reading": {
      "primary": "はんめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接続詞",
