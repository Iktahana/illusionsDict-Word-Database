    },
    "definitions": [
      {
        "index": 1,
        "gloss": "while",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "筆者がかつて評論した、有名なヘルンのエッセイ『ある女の日記』も、校本に拠るところがあるとは言いながら、実はその愛妻節子夫人を、半面のモデルにしたものと言われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため夫人は一面において旧日本的な婦道と礼節とによって、恭しく彼に仕えながらも、半面においては彼を子供扱いにせねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ色々でこそ此の世が成立つのだらう……」――そんな客観的な考へで、私は自分が何かに付けて思索する癖のあることを、不幸かも知れないといふ半面の気持に強ひられて、好い加減でうまく胡魔化して置きたかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでゐて結構つよい半面もあつて、學問上の議論となると、なかなか讓らない。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の影には他の工場の倉庫らしい丹塗りの單純な建物が半面を日に照らされて輝いて居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた他の半面の考え方によれば、科学者の知識は「物自身」の知識ではなくて科学者の頭脳から編み上げた製作物とも云われる。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその半面の随伴現象としていわゆる骨董趣味を邪道視し極端に排斥し、ついには巧利を度外視した純知識慾に基づく科学的研究を軽んずるような事があってはならぬと思う。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただかくのごとき方則というものが如何にして可能であるかという事に関して浅薄ながら半面観を試みたい。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ同じ事のちがった半面を云っているのであろう。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ともかくも、一度も科学者流にこういう風の考え方をしたことのない人もあるとしたら、そういう人にとっては、上記のような半面的な見方の可能だという事実が、あるいは何かの参考になるかもしれないと思うのである。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、いつも半分風邪を引いているのが風邪を引かぬための妙策だという変痴奇論に半面の真理が含まれているとすると、その類推からして、いつも非常時の一歩手前の心持を持続するのが本当の非常時を招致しないための護符になるという変痴奇論にもまたいくらかの真実があるかもしれないと思われる。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱いものの負惜しみの中にも半面の真があるというだけの話である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "情に脆く人なつこい性質とその半面の孤獨――時として彼はまいまいつぶらの樣に蓋を閉ぢてしまふ。",
              "citation": {
                "source": "青空同人印象記（大正十五年六月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭石の根締めになっていたやしおの躑躅が石を運び去られたあとの穴の側に半面、黝く枯れて火のあおりのあとを残しながら、半面に白い花をつけている。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に労働者と鼻突きあわして住み、また農産物高の半面、増税と嵩ばる生活費に、農産物からの増収を吐き出して足りない百姓の生活を目撃している者には、腑甲斐ない話だとそれは嘆ぜられるのだ。",
              "citation": {
                "source": "田舎から東京を見る",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来アメリカにジャズ音曲とナンセンス映画とが流行する事実は、かの国に古い意味での哲学と科学と芸術の振るわない事実の半面であって、そのかわりに黄金哲学と鉄コンクリート科学と摩天楼犯罪芸術の発達するゆえんであろう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上の所説は、一見はなはだしく詭弁をろうしたもののように見えるかもしれないが、もし、しばらく従来の先入観をおいて虚心に省察をめぐらすだけの閑暇を享有する読者であらば、この中におのずから多少の真の半面を含むことを承認されるであろうと信ずる。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この所説もはなはだ半面的な管見をやや誇張したようなきらいはあろうが、おのずから多少の真を含むかと思うのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一見相反する二つの命題は実は一つのものの互いに対立し共存する二つの半面を表現するものである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "居間のすみの箪笥のわきにある鏡台の前へすわって左から来る光に半面を照らさせ、そして鏡に映っているものは画架でも背後の箪笥でもその上にある本や新聞でも、見えるだけのものはみんなそのままにかいてみようと思ってやり始めた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の半面は亀井戸辺より小松川へかけ木下川から堀切を包んで千住近傍へ到って止まる。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝日が日向灘から昇ってつの字崎の半面は紅霞につつまれた。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の影には他の工場の倉庫らしい丹塗りの単純な建物が半面を日に照らされて輝いている。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう見方にも半面の真理はあるかもしれない。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の完璧の半面だけが光ってすぐ消えた。",
              "citation": {
                "source": "俳諧の本質的概論",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、そこには素晴しい文化があるかわりに、その内面には人間の醜い半面が集合していることになります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖のムラノ島を半面影像のように左に見て大運河へ入った。",
              "citation": {
                "source": "橋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の上なる雨戸へ半面、ぬッと横ざまに突出したは、青ンぶくれの別の顔で、途端に銀色の眼をむいた。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十九　巡査は、持替えた角燈に、頬骨高く半面暗く、葛木の名刺を指の股に挟んで、「これは非常に皺になっとる名刺じゃねえ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
