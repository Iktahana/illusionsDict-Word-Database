        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "歯が生え始めてむずがゆいのか、赤ちゃんが一生懸命シリコン製の歯固めを噛んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "友人の出産祝いに、可愛い動物の形をした木製の歯固めを贈ることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "どこへ行くにもお気に入りの歯固めを離さない姿は、見ていて微笑ましい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "上品な重味のあるふうをして、あちらこちらに一団を作っているこうした女房らは歯固めの祝儀などを仲間どうしでしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二、歯固めのお式の事　　　　並に意外なる口説の事　安南国皇帝宗竜王は自分の寝台の上で眼を覚ました。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねて日本びいきでいられる殿下には、歯固めの古式による御雑煮、数の子、ごまめ等を殊のほか御賞美になり御機嫌麗わしく外務次官以下の年賀を受けさせられた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
