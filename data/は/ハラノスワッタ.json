        "examples": {
          "standard": [
            {
              "text": "彼は腹の据わった男で、どんな困難にも臆しない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "腹の据わったリーダーシップで、チームを勝利に導いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の腹の据わった決断が、事態を好転させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "腹の据わった名人の芸に向き合うのも、これでなかなか厄介だ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　斎藤茂吉は、なかなか腹の据わった人であった、又、前に引いた二通の葉書の文句でもほぼ想像がつくように、腹の中で如何なる事を考えていても、逢えば、誰にも、愛想がよく、人をそらさず、ずいぶん如在のない人である、それで、大抵の人は、茂吉を、「木訥」な好い人である、と思っているようである。",
              "citation": {
                "source": "茂吉の一面",
                "author": "宇野浩二",
                "note": "青空文庫"
              }
            }
          ]
        }
