    "definitions": [
      {
        "index": 1,
        "gloss": "falling cherry blossoms",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
