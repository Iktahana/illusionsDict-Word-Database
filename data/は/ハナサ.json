    "definitions": [
      {
        "index": 1,
        "gloss": "(winning) by a nose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "直線登りで一瞬もたついたが、ぱっと立ち直り、ぐんぐん脚足が伸び、終点から十二馬身の位置で先頭集団をとらえ、鼻差でゴールを駆け抜け、勝利をもぎ取った。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の推察も、だいたいに於いて間違ひはなささうだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、み空はたかく、吹く風はこまやかに　　――祈るよりほか、わたくしに、すべはなかつた……寒い夜の自我像きらびやかでもないけれどこの一本の手綱をはなさずこの陰暗の地域を過ぎる！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "などは十二、五、七、七と切って読んでもさしつかえはなさそうである。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし此の平板な野の森陰の小屋に日當りのいゝ縁側なりヴェランダがあつて其處に一年の中の選ばれた數日を過すのはそんなに惡くはなささうに思はれた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局私はこの油の漏れる和製の文化的ランプをハンダ付けでもして修繕して、どうにか間に合わせて、それで我慢する外はなさそうである。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑人の道楽ならばいいが、仕事のあるお神さんやおばさん達にはあまり楽な仕事ではなさそうである。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいへ、我々は決してぽつねんと切りはなされた宇宙の単位ではない。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能と良心と、わかちがたき一つの心をふたつにわかたんとする大人の心のうらさびしさよ、力をこめて引きはなされた二つの影は、糸のやうにもつれあひつつ、ほのぐらき明窓のあたりをさまようた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう致してあなたがおいでなさりはなさるまいかと二週間位は心待に待つのでございましょうよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚はなさらなかったのでございますの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸家協会は作品の受取を拒否し、サロンはその撤回をロダンさんに迫ったのですが、ロダンさんは沈黙して自分の意見を発表することはなさらなかったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大西は窓から眼をはなさなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは何度読んでも結局はただの活字の行列を見物しているのもたいしたちがいはなさそうである。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもない事のように思っていたが、考えてみると、これはそう簡単な問題ではなさそうである。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私のこの案はやはり賛成してくれる人はなさそうである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心相こころの師とはならんとも、　　こころを師とはなさざれと、いましめ古りしさながらに、　　たよりなきこそこゝろなれ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜誌に讀み耽つてゐた莊之助は、兄の視線の下で、身體を起しながらも、その頁から眼をはなさず、それでも兄のいらいらしてゐる視線にゆきあたつた時、機嫌をとる樣な作り笑ひをして近づいて來た。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の様子では彼らは別に友達というのではなさそうであった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、誰もそれを見た人はなさそうだった。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし落し物ではなさそうだと悟った以上、この言葉はその人影に話しかける私の手段に過ぎませんでした。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴僧はこちらへいらっしゃる道でお心着きはなさいませんかい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしマライはこの点についてはおそらく前二者に劣る事はなさそうに思われたのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでやってもついにできあがる見込みはなさそうに思われだした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙芝居にしても悪くはなさそうである。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇のほうはやはり受動的であって、こっちから追っかけて行って飽くまで勝負を迫るほどの執念はなさそうである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の二つ三つがどうにかなったとしてもたいした事はなさそうにも思われるが、しかしまた脳髄によって営まれていると考えられる精神現象の複雑さは想像のできないほど多様なものである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この悪臭によって自分はこの現世から突きはなされてただ一人未知の不安な世界に追いやられるような心細さを感ずるのであった。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうだとすれば、科学の力をかりて災難の防止を企て、このせっかくの教育の効果をいくぶんでも減殺しようとするのは考えものであるかもしれないが、幸か不幸か今のところまずその心配はなさそうである。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一つの有機体であるところの身体の全部にたとえ微少でもなんらかの影響のないはずはなさそうである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
