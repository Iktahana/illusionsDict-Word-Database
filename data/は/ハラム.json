    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to conceive",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "好奇心は満足され、自虐の喜悦、そして「美貌」という素晴らしい子を孕む。",
              "citation": {
                "source": "好奇心",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハハハと笑って、陽気に怯かす……その、その辺を女が通ると、ひとりでに押孕む……」「馬鹿あこけ、あいつ等。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前様の前だがの、女が通ると、ひとりで孕むなぞと、うそにも女の身になったらどうだんべいなす、聞かねえ分で居さっせえまし。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてまた、鈍く曇れる水の面、濁れる胎のもの孕む音ともなしに、静寂の深みに呻く夜の色。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山男に生捕られて、ついにその児を孕むものあり、昏迷して里に出でずと云う。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しッ越もない癖に、情人なんぞ拵えて、何だい、孕むなんて不景気な、そんな体は難産と極ってるから、血だらけになって死なないようにとお慈悲で堕してやったんだ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野で、他所と懸絶した地点の小家の牝猫が、近所に一疋も牡なきに孕むを、これは交会の結果でなく、箒で撫でれば牡なしに子を儲けるなど信じいる人を見た。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのごとく、馬が交会せずに孕み生むを見て、始めは人に見えぬよう竜と交わると信じたが、追々は竜の精を含める水さえ呑めば孕むと想い、甚だしきは女護島の伝説同様、ある馬は風に孕まさるといった。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし母系統を重んずるにはまた拠るべき道理の争われぬものありて、女はいつ誰の種を孕むやら自分ですら知らぬ場合もあるもの故（仏教にこれを知るを非凡の女とす）、普通に夫の子と認められながら誰の種と判らぬが多い。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "孕む事五月にして子を生んで多く澗に浴す。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本草綱目』に、〈猿初生皆黒し、而して雌は老に至って毛色転じて黄と為る、その勢を潰し去れば、すなわち雄を転じて雌と為る、ついに黒者と交わりて孕む〉。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって雌雄二猴あり、前に来って交感し、婦人これを見て帰れば孕む。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴食わず交わらずば孕む事なし。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを孕む時近所の木にケシてふ猴居るを見たから、ハヌマンは猴の形を受けたというと。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "孕む事七、八日で子を生み、四辻に置けば往来する人々指先から乳を出して飲ませる。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄句りて曰く、九端帆の風を孕むや行々子　女中來りて、『お誂へは』と問ふ。",
              "citation": {
                "source": "川魚料理",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ萎縮した心持では、とても社会にまたは自己に徹した作品を孕むことは出来ないと私は思つてゐる。",
              "citation": {
                "source": "作者の言葉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉にこぼれし米ありて三粒の糧に飽きたりや、にこ毛ふくらむ汝が胸は、幸や孕むと疑はる。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "火移りの火は慕ひ合ひ、たはれてはまた火を孕む。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "魂の孕むすべての美しいものは、この寂しさから生れ出て来るのだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間がそんな怪物を孕むということは絶対にあり得ないではありませぬか」　と訊ねました。",
              "citation": {
                "source": "メデューサの首",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の礼儀か分らぬが曲芸をみているようで、荘厳な式場もために一角から崩れかかる危機を孕む。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分に危惧を孕む事柄の成つた大きな喜びの前には往々何らかの技巧が行はれがちである。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モナドは何処までも自己自身の内から動いて行く、現在が過去を負い未来を孕む一つの時間的連続である、一つの世界である。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも述べた通り、文化の単なる向上という言葉はすでに多義性を孕むに至っている。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよは、自分がこういう気持で対している良人の子を孕むことを想うと、恐怖と愧しさとで手足が氷のようになった。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母たちは孕むもの、産むもの、生産的なものの象徴である。",
              "citation": {
                "source": "ゲーテに於ける自然と歴史",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "無の體驗とも考へられる創造の體驗は却て最も積極的なものを孕む。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "「現在は過去を含み未來を孕む」〔Le pre'sent est plein du passe' et gros de l'avenir〕 といふライプニツの言葉は、深き洞察として好んで口にされるところである。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、まぼろしのかもめどり、渚はとほく砂丘はさんらん、十字の上に耶蘇はさんらん、女の胴は砂金に研がれ、その陰部もさんらん、光り光りてあきらかに眞珠をはらむ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
