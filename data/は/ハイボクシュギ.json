        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アジトを逃げろと云ったのは、自分が若し捕かまったら三日か四日目にアジトを吐くという、敗北主義を自認していることになる。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴は個人主義者で、敗北主義者で、そして裏切者だ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は、それを極左的だというのは、卑怯な右翼｜日和見主義者が自分の実践上での敗北主義をゴマ化すために、相手に投げつける言葉でしかないと、須山に云った。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "右翼的日和見主義を撃破し、トロツキーの極左的敗北主義に対して、建設の全事実が一国社会主義の可能を証明した。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はそんな敗北主義には賛成しないな」　やがて若い階級的な妻である女は、自分が良人のところへかけ込んだことを自己批判し、終局に「物事が乱れるような結果になるかもしれない。",
              "citation": {
                "source": "新しい一夫一婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルキシズムの立場で書かれているわけなのだろうが、敗北主義で、政治と文学との見解は、ブルジョア・インテリゲンチアの宿痾、二元論だ。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に「菊の花」の方は、主題のつかみかたがプロレタリア的な立場で見れば敗北主義くさいという、理論上の欠点ももっていた。",
              "citation": {
                "source": "新たなプロレタリア文学",
                "author": "――アレゴリーと諷刺――",
                "note": "青空文庫"
              }
            },
            {
              "text": "獨斷家は甚だしばしば敗北主義者、知性の敗北主義者である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとは敗北主義から獨斷家になる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼は、いよいよ東野は有無を云わせず押しよせて来ているこの現実の思想から、逃げ歩いてばかりいる敗北主義の男だと思っていくばかりだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "独断家は甚だしばしば敗北主義者、知性の敗北主義者である。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとは敗北主義から独断家になる。",
              "citation": {
                "source": "人生論ノート",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えれば考えるほど、朝倉先生が敗北主義者になったような気がして腹がたって来た。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "この考えは戦争中インテリゲンチャが流した敗北主義の中に表明されていた。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
