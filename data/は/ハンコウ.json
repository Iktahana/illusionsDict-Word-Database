[
  {
    "uuid": "e479b035-d71d-508c-a686-868ad6dc161b",
    "entry": "反抗",
    "reading": {
      "primary": "はんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "opposition",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すくなくとも自分より「上手の人物」から、應接で壓倒されてることを感じ、一種の反抗的な氣分に驅られた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの卑屈な反抗心は、その後の交際に於てさへも、ずつと最後まで續いてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れがまた、いつも自分の反抗心を驅り立てた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の反抗は、未だ組織づけられていなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、火夫が、憐を乞うような眼で、そこら中を見廻しながら、そして、最後の反抗を試みながら、「勝手」に飛び込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "みち子は柚木の権柄ずくにたちまち反抗心を起して「人が親切に持って来てやったのを、そんなに威張るのなら、もうやらないわよ」と横向きになった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野暮は垣根の外がまへ、三千楼の色｜競べ、意気地くらべや張競べ」というように、「いき」は媚態でありながらなお異性に対して一種の反抗を示す強味をもった意識である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野暮は垣根の外がまへ、三千楼の色競べ、意気地くらべや張競べ」というように、「いき」は媚態でありながらなお異性に対して一種の反抗を示す強味をもった意識である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその不正義に対する反抗心が彼の性格に何かの痕跡を残さない訳には行かなかったろうと思われる。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "意識上では自分の正しきを信じてゐて、あくまでも他人の反抗を憎んでゐる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　莊子が反抗的の態度で言つた。",
              "citation": {
                "source": "橋上",
                "author": "――詩壇の議論家に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝が、Ｔ「憎いのは　此村大吉とか仰しゃる　御武家様……」　弱い者が強い奴への果敢ない反抗です。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "革鞭と樫の棒との間斷なき脅威、粗食と過勞と濕氣のための病氣――反抗の氣力も、性格さへもなくしてしまつた人夫達が、最後に解放されて吹雪のなかへ出てゆき、死物狂の復シユウに立ち歸るまでのことが重々しい印象で書かれてゐる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　痛痛しい反抗の姿だつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、反抗的な、むずかしい気持になった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、圧迫せられた意気の揚らない老人が発する声とはまるで反対な、力のある、反抗的な声だった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と、反抗的な熱情が涌き上って来るのを止めることが出来なかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼ばかりではなかった、彼と同じ不服と反抗を抱いている兵卒は多かった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そういう反抗も、その経験を繰返えすに従って、一部の兵卒の気まぐれなやり方では、あまりに効果が薄いことを克明に知るばかりだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、軍医の顔を、何か反抗するように見つめた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、満洲、支那に於ける中国人労働者及び鮮人労働者たちの反抗を鎮圧するために使われているのだ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉江喬松、中村星湖、加藤武雄、犬田｜卯等がそれまでの都市文学に反抗していわゆる農民文学を標ぼうした農民文学会をおこした。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、彼等は、役人に反抗したが、結局、どうにもせられなかった。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして多勢に無勢であるから、中間はとても反抗する力はなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜすぐ自身番へでも連れて行かないんですえ」　かれらは半七の顔を識らなかったが、それでも庄太の連れであるので、薄々はその身分を覚ったらしく、余計な世話を焼くなというような反抗の顔色も見せなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りも、憎悪も、反抗心も。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、憎むことも、反抗することも知らねえんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自分が貧乏な百姓や、労働者の出身でありながら、詰襟の服を着とるというんで工人や百姓の反抗を抑えつけているんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、幹太郎は、自分たち自身も、反抗もなにもよくしない、おとなしい動物だと感じた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、おとのさま」「二十人も三十人も馬に乗って、氏神様のお神行のようじゃ」「藩公が来られたか」「はんこうか、鮟鱇か知らんが、高知の城下から来たそうじゃ」「真箇か。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
