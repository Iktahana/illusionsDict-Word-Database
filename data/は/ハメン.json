[
  {
    "uuid": "51103287-72cd-54cd-b3cb-0038f06ab294",
    "entry": "波面",
    "reading": {
      "primary": "はめん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
