      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wave surface",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "拿破里灣に沿ひて行けば、熔岩の赤き影と明月の青き影と、波面に二條の長蛇を跳らしむ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "地平線に接する處に、我身を距ること甚だ遠からず、青光まばゆき一星ありて、その清淨なる影は波面に長き尾を曳けり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　夜はこのときようやく初更に近く、宮戸あたり墨田の川は、牽牛織女お二柱の恋星が、一年一度のむつごとをことほぎまつるもののごとく、波面に散りはえる銀河の影を宿して、まさに涼味万金――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "海上二里間風なく波面席のごとし。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "波面と、砂がまぼしくひかる上から、短かい、細かな「かげろう」がチラチラもえて居る。",
              "citation": {
                "source": "冬の海",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大島や伊豆に通う蒸気船の、ボボー、ボボッボーと云うめ入る様な汽笛がその黒い波面を渡って来る。",
              "citation": {
                "source": "冬の海",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "海面から、この艇の背中が漸く没する位、つまり数字でいえば、波面から二三十センチ下に潜り、それ以上は潜らない一人乗りの潜波艇だ」「ふむ、ふむ」「これを作ったわけは、如何なる防潜網も海面下二メートル乃至十数メートル下に張ってあるから、普通の潜水艦艇では、突破は困難だ。",
              "citation": {
                "source": "独本土上陸作戦",
                "author": "――金博士シリーズ・３――",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼に入るものは、二三の漁火の星の如く、遠くちらつくと、稀に、銚子行汽船の過ぐるに当り、船燈長く波面に揺き、金蛇の隠現する如きを見るのみにして、樹林無く、屋舎無く、人語馬声無く、一刻一刻、人間界より遠ざかる。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の陽ざしも、こたえがなく、北日本特有の寒風が、槍のごとく波面をかすッて、港｜泊りの諸船の帆ばしら、ゆッさゆッさとゆさぶれあうさま、まるで盥のなかの玩具を見るよう。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の仕事が実にいそがしい主人が、たまにはめんどうと思っても、主人は主人のひまを割いてわたくしの為にして呉れます。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き物だから飼っておくのはめんどうだろうが。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　蟹はめんくらいました。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりよく睡るので死んではいないかと思って、小さな声で「ポチや」というとポチはめんどうくさそうに目を開いた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子はめんどうくさくなったので剣をぬいていきなり小藪をばらんと切ってしまいました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門松や輪飾りはめんどうくさいから止めにして、裏山から歯朶を五六本折ってきて瓶に挿した。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "道路はめんめんたる一列供養のみち、夕日にけぶる愁ひの坂路、またその坂を昇り降らむとする聖徒勤行の路でもある。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神さまはめんくらいました。",
              "citation": {
                "source": "子どものすきな神さま",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹島先生は、酒をお猪口で飲むのはめんどうくさい、と言い、コップでぐいぐい飲んで酔い、「そうかね、ご主人もついに生死不明か、いや、もうそれは、十中の八九は戦死だね、仕様が無い、奥さん、不仕合せなのはあなただけでは無いんだからね。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時のパンの有様は今もよく記憶に残つてゐるが、詳しく書くのはめんどくさい。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚はめんくらって訊いた。",
              "citation": {
                "source": "竹青",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人が来てはめんどうだから、あいつ逃げて往く処だ、もう、俺達の用も済んだから、いっしょに帰ろう」　書生が往きかけるので、主翁もすぐ後に引添うて往った。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はめんどうなものとされているが、こんな場合には、年を取っていて世の中のいろいろな経験を持っている人が頼もしいのである。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも古藤さんも手紙の上では一枚がた男を上げていますわね」　木村の意気込みはしかしそんな事ではごまかされそうにはなかったので、葉子はめんどうくさくなって少し険しい顔になった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その赤らみ方というものが、また、まるで男とは見えないほどにいかにもういういしく娘々していたものでしたから、右門もちょっとそれにはめんくらったようでしたが、ちょうどそのとき手すきとなった店員が腰低くやって来て、注文の品を尋ねましたので、気がついてぶっきらぼうに答えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、ごいっしょに現場の検分をいたさせてもらいますかな」　めんくらったのは敬四郎で、またこれはめんくらうのが当然でしたろう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、めんくらうことはめんくらいましたが、もとよりそれは一瞬間だけのことで、右門はどこまでもわれわれの尊敬すべき立て役者です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "人目にかかってはめんどうじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえ、ひとりでやれ」　ヤマはめんどうくさそうだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、ちょっとな」　にわか雨に追いたてられた街に目をやったまま、高志はめんどうくさそうにこたえた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
