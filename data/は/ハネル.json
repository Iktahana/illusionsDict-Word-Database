  {
    "uuid": "60bf53f2-7ed9-5505-86b5-133989a11f99",
    "entry": "刎ねる",
    "reading": {
      "primary": "はねる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cut off (someone's head)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）お前ん、お孝が蒲団を取って向うへ刎ねると、その時ですわい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此奴、（白拍子）別嬪かと思えば、性は毛むくじゃらの漢が、白粉をつけて刎ねるであった。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刎ねる処は鮒だ奴さ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "刎ねる問屋もまだ可かつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちつつ胴の間で、一刎、刎ねると、そのはずみに、船も動いた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "令夫人は、駒下駄で圧えても転げるから、褄をすんなりと、白い足袋はだし、それでも、がさがさと針を揺り、歯を剥いて刎ねるから、憎らしい……と足袋もとって、雪を錬りものにしたような素足で、裳をしなやかに、毬栗を挟んでも、ただすんなりとして、露に褄もこぼれなかった。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばしゃんばしゃん、氷柱のように水が刎ねる、小児たちは続けさまに石を打った。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へ、お前様なんざ、畳が刎ねるばかりでも、投飛ばされる御連中だ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするともう、わっと言って、飛ぶやら刎ねるやら、やあ！",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鱸は刎ねる、鯔は飛ぶ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "板の間の乾びた、人なき、広い湯殿のようで、暖い霞の輝いて淀んで、漾い且つ漲る中に、蚊を思うと、その形、むらむら波を泳ぐ海月に似て、槊を横えて、餓えたる虎の唄を唄って刎ねる。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が三疋、赤手拭、すッとこ被り、吉原かぶり、ちょと吹流し、と気取るも交って、猫じゃ猫じゃの拍子を合わせ、トコトンと筵を踏むと、塵埃立交る、舞台に赤黒い渦を巻いて、吹流しが腰をしゃなりと流すと、すッとこ被りが、ひょいと刎ねる、と吉原被りは、ト招ぎの手附。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（やれ羽打つ、へへへ、小鳥のように羽掻を煽つ、雑魚のように刎ねる、へへ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "物干から、（やあ、小鳥のように羽打つ、雑魚のように刎ねる。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足腰が、水馬の刎ねるように、ツイツイツイと刎ねるように坂くだりに行く。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古手拭で、我が鼻を、頸窪へ結えたが、美しい女の冷い鼻をつるりと撮み、じょきりと庖丁で刎ねると、ああ、あ痛、焼火箸で掌を貫かれたような、その疼痛に、くらんだ目が、はあ、でんぐり返って気がつけば、鼻のかわりに、細長い鳥の嘴を握っていて、俎の上には、ただ腹を解いた白鷺が一羽。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ぽんと、丸めた紙の頭を順にたたくと、手だか足だか、ふらふらふらと刎ねる拍子に、何だか、けばだった処が口に見えて、尖って、目皺で笑って、揃って騒ぐ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴち／＼と刎ねる……いや、恁うあらうと思ふた……見事なものぢや、乾して置くと押死ぬべい、それ、勝手に泳げ！",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "案山子が簑を捌いて捕らうとするなら、ぴち／＼刎ねる、見事に泳ぐぞ。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢朝に対する忠信という点から考えるなら、いつまでも節旄を持して曠野に飢えるのと、ただちに節旄を焼いてのち自ら首｜刎ねるのとの間に、別に差異はなさそうに思われる。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚を殺し、傷つける敵の首を刎ねることによってではない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村は、首を刎ねることは許されよ、幸村の命は豊家のために失い申さん、志なればと云った。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……魔の沼へ落込むのに怯えたから、尻を餅について、草鞋をばちゃばちゃと、蠅の脚で刎ねる所へ、浪が、浪が、どぶん――「お助け。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――透かして見ると、ぴちぴち刎ねるのが尾のようで……とにかく、長くないのだから、安心して、引つかまえると、（お魚よ、お魚よ。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、天から降った、それほどの逸物だから、竜の性を帯びたらしい、非常な勢で水を刎ねると、葉うらに留まった、秋近い蛍の驚いて、はらはらと飛ぶ光に、鱗がきらきらと青く光りました。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹴込に腰を掛けて待っていた車夫、我が主来れりと見て、立直り、急いで美しい母衣を刎ねる。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちつゝ胴の間で、一刎、刎ねると、其のはずみに、船も動いた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事な鮒よ、ぴちぴちと躍って、宙に雨脚を刎ねるようである。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、言葉尻が泣声で切れて、ひょいと刎ねるように両袖で顔を隠した。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がぴちゃぴちゃはねる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
