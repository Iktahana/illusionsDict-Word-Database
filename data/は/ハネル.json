    "definitions": [
      {
        "index": 1,
        "gloss": "to jump",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "而も突如として電流体の感情が頭から足の爪先まで震はす時、君はぴよんぴよん跳ねる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは紫がかった金色に光っているのでございます」　お徳の顔色は俄かに動いて、おもわず台所の方をみかえると、そこでは大きい魚の跳ねるような音がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、奥で何か跳ねるような……」　お徳はやはり黙っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の跳ねる音でございます。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "太い雨が竿に中る、水面は水煙を立てて雨が跳ねる、見あげると雨の足が山の絶頂から白い糸のように長く条白を立てて落ちるのです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈が高う、穂が伸びて、小屋は屋根に包まれる、山の懐も隠れるけに、月も葉の中から出さされて、蟹が茎へ上っての、岡沙魚というものが根の処で跳ねるわや、漕いで入る船の艪櫂の音も、水の底に陰気に聞えて、寂しくなるがの。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "疾い事、但し揺れる事、中に乗った幼い方は、アハハアハハ、と笑って跳ねる。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（鯉跳ねる）わい！",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（鯉跳ねる）ふあ、銀の鱗だ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾鰭はのらのらと跳ねるなれども、ここに、ふと、世にも気懸りが出来たじゃまで。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌食がその柔かな白々とした手足を解いて、木の根の塗膳、錦手の木の葉の小皿盛となるまでは、精々、咲いた花の首尾を守護して、夢中に躍跳ねるまで、楽ませておかねばならん。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀杏の葉ばかりの鰈が、黒い尾でぴちぴちと跳ねる。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "車蝦の小蝦は、飴色に重って萌葱の脚をぴんと跳ねる。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の跳ねるのではない。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分二人で地酒を大酒盃かなんかで飲んで、都出の興世王は、どうも酒だけは西が好い、いくら馬処の相馬の酒だつて、頭の中でピン／＼跳ねるのはあやまる、将門、お前の顔は七ツに見えるぜ、なんのかのと管でも巻いてゐたか何様か知らないが、細くない根性の者同士、喧嘩もせずに暮して居た。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐の魚の跳ねる響を肉体に感ずると彼は腹を引込め、眠いような眼つきで薄笑いをしました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "跳ねる、飛ぶ、眼で媚び、股でひねる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そういって、その瓶を目よりも高く差し上げると、また飛び跳ねる馴鹿の仔のように活溌に走り出した。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」や、十三七つの「お月さま」や、十五夜お月さま見て跳ねるのあの「うウさぎ兎」や、こつちの水は甘いぞ、あつちの水は苦いぞの「赤い帽子の蛍」や、一羽の雀が云ふことにのあの「三羽の小さな雀」の謡や、思ひ出せば数かぎりもありません。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "うさうさ兎てんてん手毬、おててん手毬、手毬の中に、何がゐて跳ねる。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんてん手のなし、めんめん眼のなし、みんみん耳のなし、うさうさ兎の子が跳ねる。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに鯔らしいのが水の上に跳ねるのを見れば、魚類だけは目覺めてゐるらしい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに鯔らしいのが水の上に跳ねるのを見れば、魚類だけは目覚めているらしい。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色の女の姿が、吉田の胸の近くまで、跳ねるようにして寄って来た。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮した馬が飛び跳ねるごとに、どこか角にぶつけて、さらに興奮を高める。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵男子二人、若くは女子二人なるが、跳ねる如き早足にて半圈に動き、その間手をも休むることなく、羅馬人に産れ付きたる、しなやかなる振をなせり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "餌食が其の柔かな白々とした手足を解いて、木の根の塗膳、錦手の木の葉の小皿盛と成るまでは、精々、咲いた花の首尾を守護して、夢中に躍跳ねるまで、楽ませて置かねば成らん。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は何處へでもべたりと坐るので臀を丸出しによう見ろよう」と小笊を枉げてはちよこ／＼と跳ねるやうにして小刻みに足を動かしながらおつぎの譽める詞を促して止まない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸のやうな脚で跳ねるのがふわ／＼とした綿の上でも跳ねるかと思ふ樣に見えて如何にも輕げである。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "水がぴちゃぴちゃはねる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
