        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と浦島はやけくそに似た大きい聲で叫んだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室はやけに混んでいた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人はやけになった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「彼はもはやけっしてうたわざりき、親しき人々にすら言葉かわすことを避くるようになりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "顏や首から油汗がねつとり滲み出てゐたが、手拭を忘れて來てゐたので、と云つても洋服の汚れた袖で拭くのはなほのこと氣味がわるく、私はやけ氣味に汗まみれであるいてゐた。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はやけに風呂敷包を抛り出して机の前に坐つて見た。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　と主人が、尻で尺蠖虫をして、足をまた突張って、（成程、気がかわっていい、茸は焼けろ、こっちはやけだ。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と浦島はやけくそに似た大きい声で叫んだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄蔵はやけつぱちで、「まんだ撞くよッ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやけくそで、突拍子ない時に大拍手をしてみたり、ろくに聞いてもいない癖に、然りとか何とか、矢鱈に合槌打ってみたり、きっと皆は、あの隅のほうにいる酔っぱらいは薄汚いやつだ、と内心不快、嫌悪の情を覚え、顰蹙なされていたに違いない。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊右衛門はやけにその蛇の胴中をむずと掴んで裏の藪へ持って往って捨てた。",
              "citation": {
                "source": "四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪寒どころですか、身体はやけますようですのに、冷い汗を絞るんです。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はやけのようになって踊り廻りながら唄い出した。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐助はもはやけちくさい自己反省にとらわれることなく、空の広さものびのびと飛びながら、老いたる鴉が徒労の森の上を飛ぶ以外に聴き手のない駄洒落を、気取った声も高らかに飛ばしはじめた。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "オーバの上からだったが、彼女の肌の柔かさと、体温がじかに触れるような気がして、白崎の手はやけどをしたような熱さにしびれた。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしても他じゃない」「どうしてあげる」「鉤のようなものを入れるか」「はやけりゃ助かるかも判らん」「何人か胆力の強い者はないか、入ってもらいたいが」　人びとは頭をあつめて評議をした。",
              "citation": {
                "source": "蟹の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "征矢なす水のはやけば。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」赤井はやけになってそう叫び、黙ってむつかしい顔をしている豹一の傍へ寄ると、「行こう。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、知ると、北山はやけくそになって朝っぱらからの迎酒に泥酔したあげく、ふらふらと二階の客席にまぎれこんで、しきりに銀子の名を呶鳴り出したのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何と云うあくたれだ、てめえは、気がちがったか、なんと云うことだ」　お杉はやけくそであった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ちょっとの間待っていたが、靴の音もしなければ返事もしないので、今度はやけに強く押し鳴らした。",
              "citation": {
                "source": "警察署長",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょろひょろしながら先生、」といって、愛吉は椅子に懸りながら身悶をして見せた、金之助はやけに頤を撫でて、「悪くない、うむ、そうすると、」「いつも交返すんだから盲目め、声を知ってまさ、かねてお気にゃあ入らなかったと見えて、（ああ、弾くがね、お鳥目をおくれ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の病院に通って、横浜駅から自転車で漕ぎだしたあの日も、ペダルはやけに重かった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ女でしょうよ」　妻はやけにそういえば、産婆は声静かに笑いながら、「えィお嬢さまでいらっしゃいますよ」　生まれる運をもって生まれて来たのだ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやけになつて、すぐそこを游いでゐる三寸ばかりの魚を目がけて鈎を下した。",
              "citation": {
                "source": "魚の憂鬱",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はやけになって、すぐそこを游いでいる三寸ばかりの魚を目がけて鉤を下した。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてまたきょうはやけにそう足がはええんだろうな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "凍え死んだ者はやけどそっくりじゃとか聞いておったが、雪か！",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "２「許せよ」　ずいとはいっていった覆面姿をながめて、お忍び通いのお客さまとでも思ったものか、初めのうちはやけにあいきょうを振りまいていましたが、さすがは目ききを元手の質屋に仕える少年店員です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
