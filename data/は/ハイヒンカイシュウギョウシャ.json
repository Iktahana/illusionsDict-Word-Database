        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "毎週決まった時間に、廃品回収業者が古い新聞紙や雑誌を集めに来てくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "粗大ゴミを出す際は、事前に廃品回収業者に連絡して予約する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝早くから働く廃品回収業者のおかげで、私たちの街は清潔に保たれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "出入りの廃品回収業者に『もう少し給料のええとこないやろうか？",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを教えてくれた廃品回収業者の話では月給は三円のはずだったのに、二円五十銭しかくれない。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "またビールの空びんや割れた皿などをこっそり廃品回収業者に売って小金をためる手も覚えた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがある日、すずのへちゃげた皿を廃品回収業者に売るところを、中国人の店員に見つかった。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃品回収業者のたて場から、ぼろ布を買って来る。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夫婦は相沢七三雄という、屑鉄専門の廃品回収業者の二階に住んでいた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
