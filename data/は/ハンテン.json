[
  {
    "uuid": "9aab1c1a-ffc2-5ab8-b1b6-5b41bbfd0d0a",
    "entry": "半纏",
    "reading": {
      "primary": "はんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
