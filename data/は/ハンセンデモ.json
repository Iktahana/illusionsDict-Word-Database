        "examples": {
          "standard": [
            {
              "text": "週末、市内で大規模な反戦デモが行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若者たちはプラカードを掲げ、反戦デモに参加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "反戦デモの参加者は、平和を求める声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ニューヨークの反戦デモに参加するばかりか、中野は三十年間転々としてアメリカであらゆる労役に従事していた間に、鉱山の大ストライキにプロレタリアとして夜も眠らず働いたことがある。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "反戦デモには、共産主義者たちがまじっていた、とあなたがたを教育する将校は言うだろう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
