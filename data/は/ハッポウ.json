[
  {
    "uuid": "f2ef9852-6384-5de9-9388-0db319e89016",
    "entry": "八方",
    "reading": {
      "primary": "はっぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "all sides",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は汗を拭い、ちょっと威容を正して門をくぐり、猛犬はいないかと四方八方に気をくばりながら玄関の呼鈴を押した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方八方に、幾久しゅう、幾久しゅうとばかり言うのも、まがぬけているような気がして、こんどは、「末永くお願い申します。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」忽ち先を爭つて、手のある限りの者は四方八方から走り集つた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう扁平な板のような天体の中央に居て八方を眺めたと仮定すると、板の面に沿うた方向には沢山の星が重なって帯のように見えるはずでこれがすなわち天の河である。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この奇妙さがふたたびリゼットへ稼業に対しての、冒険の勇気を与えて彼女は毎夜のような流眄を八方に配り出した。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポアッソニエの大通はもう五色の光の槍襖を八方から突出していた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人殺しの罪人でさえも官費で弁護士がつけられる世の中に、効はあっても罪のない論文提出者は八方から虫眼鏡で瑕を捜され叱責されることになるのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠傘の上などに落ちて凍った雨滴を見ると、それが傘の面に衝突して八方に砕け散った飛沫がそのままの形に氷になっている。",
              "citation": {
                "source": "凍雨と雨氷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、実地ではこんなに演奏者を八方から色々の距離と角度で眺めることは不可能であるが、そればかりでなく映画のカメラは吾らの眼の案内をして複雑な管弦楽の編成の内容を要領よく解明してくれる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝源兵衛宅表　番頭の長吉や手代が提灯持って娘を探しに八方へ走る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それッとばかり八方に散る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んで、　八方に走り去る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小路が四方八方から臭ひはじめる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "足をばた／＼やつて大聲を上げて泣いて、それで飽き足らず起上つて其處らの石を拾ひ、四方八方に投げ付けて居た。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "足をばたばたやって大声を上げて泣いて、それで飽き足らず起上って其処らの石を拾い、四方八方に投げ付けていた。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、あの神様の手が障れば鉄砲玉でも通るまいと、蜘蛛の巣のように評判が八方へ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあたかも蛇の皮を脱するごとく、物体の表面からはがれて、あとからあとからと八方に飛び出す。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い旗竿から八方に張り渡した縄にはいろいろの旗が並んで風に靡いている。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方ふさがり、と言ってしまうと、これもウソなのである。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方手をつくしたのですが、よい方法がなく、五六回、巻紙を出したり、ひっこめたりして、やっと書きます。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方手をつくしたのですが（まず、三四人にも出したか）よい方法がなく、五六回、巻紙を出したり、ひっこめたりして（この辺は真実ならん）やっと書きます。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦になり、細君と女児を、細君のその実家にあずけ、かれは単身、東京に乗り込み、郊外のアパートの一部屋を借り、そこはもうただ、寝るだけのところ、抜け目なく四方八方を飛び歩いて、しこたま、もうけた。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀は友達を大勢集めて評議をしましたが、やがて八方に飛び散って鳥さしを探しました。",
              "citation": {
                "source": "鵙征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぱっと塔のねもとからまっかな雲が八方にほとばしりわき上がったと思うと、塔の十二階は三四片に折れ曲がった折れ線になり、次の瞬間には粉々にもみ砕かれたようになって、そうして目に見えぬ漏斗から紅殻色の灰でも落とすようにずるずると直下に堆積した。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "需要を高めるまで八方了解さす工夫を続ける。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三三課　婚約の前に八方手を尽せ　婚約ということは、殆んど結婚したも同様で、婚約してしまった後で、また取り消すということは、人情的にも、法律的にも面倒です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて候補者が見付かったので、彼女は自分でも、八方手を尽して、その男の身元、素性、性癖、能力、健康、収入等を知ろうと努めます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この八方手を尽して充分の調査をすることは仏教での俗諦に当ります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婚約するまえに八方手を尽さず、ただ向う見ずの覚悟で、僥倖を頼りに結婚するのは、一種の迷信であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "心が八方へ浸み通るような真空な気持ちです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
