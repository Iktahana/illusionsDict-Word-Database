[
  {
    "uuid": "a8d24ada-c723-5067-ba77-9d8ff6823682",
    "entry": "腹を立てる",
    "reading": {
      "primary": "はらをたてる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
