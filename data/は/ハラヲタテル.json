    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to take offense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がどんな生意氣を言ひ、屁理窟をこね、憎々しく突つかかつて行く場合にも、彼は寛大に情意を理解し、決して腹を立てることがなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹を立てる、腹立つというのはあて字であろうと思われる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は一國者で、何でも自分の主觀で人のことまで押し通し、それが意の如くならないといつて腹を立てる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから他人の言が、少しでもその部分に觸れる時、君は眞つ赤に腹を立てる。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日のすつかり暮れ切らぬうちに、まだ彼の運ばれない部屋がひとつも無くならうものなら、彼はひどく腹を立てるのだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "信濃国東筑摩郡松本中が粗相をしても、腹を立てる私ではない。",
              "citation": {
                "source": "錦染滝白糸",
                "author": "――其一幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯の浮くような、甘ったるいラヴシーンで、凡そくだらない一幕だった上に、現代劇だというのに、新内流しの下座がはいっていて、いつもの信吉なら、そのチグハグさに腹を立てるか、噴き出した筈だ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて人は何様いう強いことを言われても、急所に触れないのは捨てても置けるものであるが、たまたま逆鱗即ち急所に触れることを言われると腹を立てるものである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、頭山翁を平凡人なりと断定されて腹を立てる取巻きの非凡人諸君の中には、頭山翁が超特級の非凡人でなければ差支える連中が多いようである。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は此の言葉に腹を立てるべきかどうか、ちょっと思案した。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "自尊心を傷つけられたと腹を立てるよりも、自分は就職など出来る人間ではないのだと自信のない気持でしょんぼり気が滅入った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に、（俺は生命保険の勧誘員にも成れないんだ）としょんぼり頭に泛んで、腹を立てる元気もなく、片一方の足で踏まれた足をこそこそと撫でていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく私が代役するぶんには変りありません」　豹一はこのふざけた「演説」に腹を立てるべきかどうかちょっと考えた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう男は得てして生真面目な男を怒らせるものなのだが、豹一は自分で思っているほどには人から生真面目に思われない男だったから、莫迦にされてるような気はしたものの、すっかり腹を立てるまでには到らなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとつには豹一は土門の話よりも、土門の煙草を吸う動作にすっかり気を取られていたので、腹を立てる余裕などは無かったのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶくぶくのオーバーの下に大人に成りきらないきゃしゃな体がかくれているのかと思うと、彼女は本気になって腹を立てることも出来なかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（あんな男を相手に腹を立てるのは、いっそ恥しいことだわ！",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一はからかわれていることに腹を立てる余裕もなかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　そんな不義理をしていたのだが、しかし寒そうに顫えている横堀の哀れな復員姿を見ると、腹を立てる前に感覚的な同情が先立って、中へ入れたのだ。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが犬一匹にこのお祭り騒ぎはにがにがしい事だと言ってむきになって腹を立てる人もあった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも残念そうなので、私は心から同情したが、両刑事はこの試みに腹を立てるどころか、ただあざ笑うような微笑みを浮かべていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のちょっとした無愛想などに腹を立てるような馬鹿な君ではないと思う。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、あんまり手近かな奴に対して腹を立てると、言い合いをしたり、まかり間違ったら殴り合いをしなければならん。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおようで美しく柔らかい気持ちの女性であるが、さすがに嫉妬はして、恨むことも腹を立てることもあるのが、いっそう複雑な美しさを添えて、この人をより引き立てて見せることだと源氏は思っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "気嵩なる彼は胸に余して、聞えよがしに、「※、貴方には軽蔑されてゐる事を知りながら、何為私腹を立てることが出来ないのでせう。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は腹を立てるよりも、ただ驚いて怪しんだ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外は向腹を立てる事も早いが、悪いと思うと直ぐ詫まる人だった。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腹を立てるほどの事でもなかったので、少と早まり過ぎたのサ、」とばかり軽くいっていた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "返辞をされなくとも、話したいと思えば話しかけるだけで、返辞をしないからはらをたてるとかもう話しかけてはやらない、などということは決してないのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
