    "definitions": [
      {
        "index": 1,
        "gloss": "suddenly popular god",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
