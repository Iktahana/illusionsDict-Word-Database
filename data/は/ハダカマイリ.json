        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは病気が平癒したら裸参りをさせますという祈願を籠めて、それが叶ったので遣らせるのであった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "又寒中｜裸参りといふあり、家作にかゝはるすべての職人の若人らがする事なり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤジは大いに怒ってその日から毎日毎晩水を浴びて金比羅サマへ裸参りをし、始終海舟を抱いてねて誰にも手をつけさせず、毎日毎日あばれたから（但し、あばれたのはオヤジ自身の方である。",
              "citation": {
                "source": "安吾史譚",
                "author": "勝夢酔",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田地方の風習には、雨乞に婦女が裸参りをする例が二三ある。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
