    "definitions": [
      {
        "index": 1,
        "gloss": "Hakata (old but still commonly used name for Fukuoka)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『春色恋白浪』に「鼠色の御召縮緬に黄柄茶の糸を以て細く小さく碁盤格子を織｜出したる上着、……帯は古風な本国織に紺｜博多の独鈷なし媚茶の二本筋を織たるとを腹合せに縫ひたるを結び、……衣裳の袖口は上着下着ともに松葉色の様なる御納戸の繻子を付け仕立も念を入て申分なく」という描写がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春色恋白浪』に「鼠色の御召縮緬に黄柄茶の糸を以て細く小さく碁盤格子を織出したる上着、……帯は古風な本国織に紺博多の独鈷なし媚茶の二本筋を織たるとを腹合せに縫ひたるを結び、……衣裳の袖口は上着下着ともに松葉色の様なる御納戸の繻子を付け仕立も念を入て申分なく」という描写がある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは姓と結び合せて自分を宮城縣人と思ふ人もあるらしいが、たゞ生誕の地といふだけで、三ヶ月後には仙臺を去り、それから土木技師である父の轉勤につれて東京・神戸・熊本・博多・長崎と轉住した。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は博多から来たのだと言った。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は上衣と胴衣を脱いでワイシャツ一つのネクタイを緩めているし、眉香子も丹前を床の上に脱ぎ棄てて、派手な空色地の長｜襦袢に、五色ダンダラの博多織の伊達巻を無造作に巻きつけている。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田五十五万石の城下、博多の町の南の外れ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの……蔵元屋の……アノ博多小町……」　そんなヒソヒソ話が急に途切れて皆、一時にバラバラと逃出しそうな身構えになった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "イクラ据物斬りでもあれだけに腕の冴えた町人が、福岡博多におる筈はない……」　良助が独言のように言った言葉を聞咎めた和尚はギックリとして又立止まった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "……とにかくあの赤猪口爺を探し出いて、口を割らせて見んことには、見当の付けようがない」　博多瓦町はずれ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "このサ中に何処へ行たもんじゃろか……あの朝寝坊が……」　それから毎日のように晴れ続いた福岡博多の狭い町々に、蔵元屋の騒動の噂が隈もなく行き渡ってしまった三日目……三月十三日の正午下り。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "春も闌の遅桜、早桃が見渡す限りの筑紫野の村々に咲き乱れて、吾れ勝ちに揚る揚雲雀も長閑な博多東中洲の野菜畑の間を縫うて行く異様な二人連れがあった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、福岡の種子屋六兵衛老人と並んで、博多随一と呼ばれている捕物上手の目明、良助。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの博多一番の分限者の一人娘で、蔵元屋のお熊さんチュウテなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがは博多一の目明の良助さん」「おだてなさんな、面目ない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言うにもあの蔵元屋と言うのは博多切っての大金持の為替問屋。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日田金を日田の材木屋が下請けのようにして、日田の月隈の奉行所に御座る大公儀の御金奉行の監督を受けながら、九州の諸大名の城下城下におる御用金預り……博多で言えば蔵元屋のような主立った商人にソレゾレ貸付ける。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多随一の鶴巻屋を定宿にして、蔵元屋の帳面をドダイにした黒田藩の財政を調べに来よるに違いないがなあ」「フン。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は博多｜竪町の荒物屋渡世……当年五十六歳で……ヘエ……」　と淀みなく言ううちに涙ぐんだ赤んべえ面を上げて水洟を一つコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは役柄をもって相尋ねるが、その方は只今も申す通りズット以前は博多の荒物屋渡世。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば相尋ねるが、その方は博多蔵元町、蔵元屋の一人娘、お熊というものを存じておるか。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多中の妙齢の娘の乳房の黒い、赤いを間違いなく存じておりまする者は、この赤猪口兵衛タッタ一人で。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "チトお話が荒う御座いますが、何にせい博多中の恵比寿講の帳面を預っておりますので、帳面合わせとか、金勘定とか申しまして、時々奥庭の別｜土蔵の二階でチャランチャラン遣っているのが、真夜中になると微かに聞こえます。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その振袖娘の振る骰子が、内部に錘玉の付いたマヤカシ骰子と言う事実を存じておりまするのは今の処、広い博多に私一人かと存じますので……」「コレコレ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多の町の南の出外れ、万延寺の本堂と背中合わせの竹瓦に板庇、板敷土間に破れ畳二枚、ガタガタ雨戸の嵌め外しがやはり二枚という、乞食小舎の豪華版から、墓原越しに見晴らす筑紫野は、これも晩春の豪華版であろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四、五日福岡博多で大流行のこの歌を知んなさらんか」「……知らん。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタ今わかった」「どうしてかいな」「どうしてと言うて知れた事……この四、五日が間、福岡博多の何処の家にも下がっとるこの渋団扇の由来を知らんと言うからには、遠方行きにきまっとる」「成る程なあ」「ところで今日の用向きは何かいな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽二重の襦袢に博多織を締めとったけに、その中へ石を詰めとけば心配はない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽二重や博多織は墓の中でも一番しまいまで腐り残るけになあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "袷の紺飛白に一本｜独鈷の博多の角帯を締め、羽織の紐代りに紙繕を結んでいる青年音楽家は、袖をつめた洋装を着た師の妹娘を後に従えて、箱根旧街道へと足を向けた。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯はかたわらのフィンを呼んで「あの帆柱のそばの背の高いやつを射よ」と命ずる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
