        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "モオニングが、こんな晴れの日にお役に立ったら、うちのひとだって、よろこぶ事でございましょう。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝港内をこめていた霧が上がると秋晴れの日がじりじりと照りつけた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生徒も先生も不断にこの強制的に定められた晴れの日の準備にあくせくしていなければならない。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れの日で、病院の庭には、未だコスモスが咲き残っていた。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が本年発表した創作に就いて八篇の力作牧野信一「秋・二日の話」――「或る日の運動」――「悪の同意語」――「貧しき日録」――「環魚洞風景」――「鏡地獄」――「秋晴れの日」――「極夜の記」等であります。",
              "citation": {
                "source": "私が本年発表した創作に就いて",
                "author": "八篇の力作",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れの日の事は好くは知らないが、かうした静かな夕暮時に競馬の練習を見物してゐるのも、また一興といふほどの心地なのだつた。",
              "citation": {
                "source": "娘とドリアン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しい秋晴れの日に縁側へ出て庭をながめながら物を考えたりするのにぐあいのいいような腰の高い椅子があるといいと思う。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一箇月そこで暮して、秋晴れの日の午後、やっと退院を許された。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れの日は、点呼は野球場だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の赤蜻蛉、これがまた実におびただしいもので、秋晴れの日には小さい竹｜竿を持って往来に出ると、北の方から無数の赤とんぼがいわゆる雲霞の如くに飛んで来る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために房川の船渡しは十日あまりも止っていたが、九月になって秋晴れの日がつづいたので、ようやく船を出すことになると、両岸の栗橋と古河とにつかえていた上り下りの旅人は川のあくのを待ちかねて、さきを争って一度に乗り出した。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは爽やかな秋晴れの日のことだった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　――――――――――　或る秋晴れの日に不図訪れて来た樽野に、床の間に剥製の鶴が飾つてある座敷で青野が話したことの断片――。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後大学の教室に立つて、欧羅巴の近代文学を論ずるやうになつても、梅雨晴れの日光が硝子窓からちらちらするのを見ると、いつもその※菜の葉が幻のやうに想ひ出されると言つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その黄白い魚臭が冬晴れの日光に波紋して、修築中の郵便局の屋根へ、鎖で縛った瓦の束がするすると捲き上って行った。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年の功を積んだ晴れの日の名誉感が傷ついただけでなく、不公正への憤懣があった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のためには晴れの日であることに男が関心を持っていたことだけがうれしかったか、あわただしい中で、もう車に乗らねばならぬ時であったが、かざしてもかつたどらるる草の名は桂を折りし人や知るらん博士でなければわからないでしょう。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月、秋晴れの日に張りものをする、のんびりした心持は、若さと、健康に恵まれた女ばかりが知る、軽い愉快さである。",
              "citation": {
                "source": "西川小りん",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "只けふはそれ等は勿論、崩れ落ちた煉瓦やスレヱトも秋晴れの日の光にかがやいてゐた。",
              "citation": {
                "source": "ピアノ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋晴れの日などに、かすかに煙を立ててゐる火の山をぼんやり眺めながら、貧しい旅びとらしいものがそこに休んでゐる姿を今でもときどき見かけることもあるのだつた。",
              "citation": {
                "source": "ふるさとびと",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、年若な求馬の心は、編笠に憔れた顔を隠して、秋晴れの日本橋を渡る時でも、結局彼等の敵打は徒労に終ってしまいそうな寂しさに沈み勝ちであった。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "見覚えがある筈である、これこそ、学校時代に一級上だつた佐藤氏で、今日は、同氏が采配を振つてゐる鉄道部隊の晴れの日なのである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三四ヶ月過ぎて、或る秋晴れの日に、私は友人と連立って、郊外に住んでる懇意な女洋画家を訪れた。",
              "citation": {
                "source": "小説中の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "春は春霞に、夏は夏霞に面を掩うて、晴れやかに里の人々に国境の寂しさを物語ることは少ないが、九月から十月にかけての秋晴れの日には丸裸となった嶺の容が眼に近い。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、秋晴れの日の越後の国の空へなびく煙を眺めれば、明日の釣り道具の用意をはじめて結構だ。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから数年後の、或る秋晴れの日だった。",
              "citation": {
                "source": "三つの挿話",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころそのあたりに頻と新築せられる洋室付の貸家の庭に、垣よりも高くのびたコスモスが見事に花をさかせているのと、下町の女のあまり着ないメレンス染の着物が、秋晴れの日向に干されたりしているのを見る時、何となく目あたらしく、いかにも郊外の生活らしい心持をさせたことを、わたくしは記憶している。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和の日本人は秋晴れの日、山に遊ぶことを言うにハイキングとやら称する亜米利加語を用いているが、わたくしの如き頑民に言わせると、古来慣用せられた登高の一語で足りている。",
              "citation": {
                "source": "十九の秋",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "タキシードにシルクハットの晴れの日にあいにく美貌に傷をつけまして相すみません。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大学は国家の機関だから、国家に枢要な研究をすべきだ」というのでは、秋晴れの日に今日は良いお天気だというようなものである。",
              "citation": {
                "source": "語呂の論理",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
