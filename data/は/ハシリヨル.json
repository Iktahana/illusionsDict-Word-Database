        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "長七が君江を見て喜んで走り寄る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を妙な格好をした浪士が、妙にちょこちょことあっちへ走り寄るかと思うと、またこっちへ駆け寄る。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小紋まがいの裾を引擦った突かけ草履の脛も露わに、和尚と良助を突飛ばすようにして死骸の傍に走り寄ると……ワッ……とばかりに取縋って泣出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚きてわが走り寄る時、遁路あきたれば潜り抜けて、猫は飛び出で、遠く走る音して寂然となりたり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫ぶホームズのもとへ、私は息を切らせながら走り寄る。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのように道徳に反しても、恋するひとのところへ涼しくさっさと走り寄る人妻の姿さえ思い浮ぶ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（云いつつ歩み来たりしが、このていを見るより走り寄る。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようござんすか、とらえますぜ」木の間をくぐって走り寄る。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその時、後ろから聲をかけて、走り寄るものがあつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "路傍で遊んでゐる子供も声をあげて走り寄るのであつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "真鍮の城の眷族に、良人を奪われたそのために、発狂をした女があったが、それが突然走り寄ると、手に持っていた鋏の先で、庄三郎の腕を突いた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小太郎は、小半町余り、行っていたが、走り寄る足音に、振向くと、一人の男が、鋸を構えて「待てっ、おいっ」　その後方からも、得物をもった若い者が、走って来ていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつちへ迷ひ此方に走り寄る。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、あの家へ入り込んだな」　こう思った彼は走り寄ると、躊躇なく表戸へ手を掛けた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、奸智にたけた彼は、躊躇せずに走り寄ると、「お珍らしや加藤氏、霜降氏、拙者は刃三十郎でござる！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地への愛着を喪つて、只管金儲を夢見る農民が、夏虫の火中に飛び込む如く、黄金火の漲る都会を眼がけて走り寄るのは当然である。",
              "citation": {
                "source": "吾等の使命",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士がその傍らへ走り寄ると、狸は苦しげな声で自分は年古くこの城のなかに棲んでいる。",
              "citation": {
                "source": "老狸伝",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、「なんだ、なんだ」　と、驚いて案内人の傍らへ走り寄ると、案内人が無言で指す砂の上に、大きな獣の足跡が、花弁のように凹んでいる。",
              "citation": {
                "source": "香熊",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分方では仮葺きの屋根瓦を百枚ほども吹き落とされたと言って、それを告げに彼のところへ走り寄るのは隣家伏見屋の年寄役伊之助だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と呼んでいち早く彼の姿を見つけながら走り寄る梅屋の三男｜益穂があり、伏見屋の三男三郎がある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "友田は握つた女の手を離すと共に、言ひかけた言葉を杜絶した時、またしても電車が来て駐ると共にあたりの人達はざわめき立つて其方へと走り寄る。",
              "citation": {
                "source": "男ごゝろ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、夫のそばへ走り寄る。",
              "citation": {
                "source": "カライ博士の臨終",
                "author": "人生の最も厳粛であるべき瞬間に、わたくしがもし笑ひの衝動をおさへることができぬとしたら、いつたいどんな罪に問はれるであらう？",
                "note": "青空文庫"
              }
            },
            {
              "text": "小侍は走り寄るなり、地面へ坐り手をつかえたが、「お腰元楓殿が築山の背後にて、頓死いたしましてござります」「ナニ※」　頼母は胸を反らせ、「楓殿が頓死※　頓死とは？",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、その紙帳目掛け、松五郎なのであろう、一人の乾児が、抜き身を引っさげたまま、仲間の群から駈け抜け、走り寄るのが見えた。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梨枝子は、父の姿をみつけると、そばへ走り寄るやうにするのだが、そのたびに、「さ、パパは忙しんだから、あとでね。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――もう一度顔を拝し度さ、――命に賭けて参りました」「ま、お前も」　姫は走り寄ると、そのまま命の最後の灯を燃やし尽くして、大地の上に崩折れそうな男の手を取ったのでした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "夢幻の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートルレも驚いて走り寄る。",
              "citation": {
                "source": "奇巌城",
                "author": "アルセーヌ・ルパン",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言って飛上って走り寄る。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらの、治子と俊子は聞き取ろうとして、トラックの方へ走り寄る。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と叫ぶといきなり、つと身を翻して寝台の枕許へ走り寄ると、そこに据えられたスタンドの小卓の上へ手を差し伸べた。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
