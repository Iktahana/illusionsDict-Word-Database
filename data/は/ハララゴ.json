        "examples": {
          "standard": [
            {
              "text": "鮭の「はららご」をたっぷり使った親子丼は、贅沢な味わいだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "市場には、新鮮なイクラ、つまり鮭の「はららご」が並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「はららご」は、醤油漬けにするとご飯のお供に最高だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私はそのなかから魚のはららごに似た憂鬱な紋々があらわれて来るのを見る。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い羊のはららごの毛皮でこしらえたアストラカン帽をかぶり、同じ毛皮の襟のついた外套を着た瀬川雅夫について、素子と伸子とは雪の降る往来へ出た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
