        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「オウマノ　アカチヤンハ　モウ　オメメヲ　アイタカ　ミテ　キテ　チヨウダイ」　テフテフハ　スグ　ウマヤノ　マドカラ　ナカニ　ハイツテ　イキマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲトコハ　オ花バタケノ　ソバノ　アル　クサヤネノ　コヤニ　ハイツテ　グツスリ　ネムリマシタ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウサギノ　ハイツタ　カゴヲ　モツテ　ヲリマシタ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノ　ウチニ　サムラヒハ　ムラニ　ハイツテ　イキマシタ。",
              "citation": {
                "source": "ゲタニ　バケル",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘り達者でない・公學校式の角張つた日本語で、ウチヘハイツテ、休ンデクダサイと言ふ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヒトノ後ヲ尾行シタリ隣室ヘハイツテ散々俺ノ悪口ヲ言ツタリ、俺ノ生活ヲ覗イタリスルコトハ、今後絶対ニヤメテクレ。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ私ハイツワラナイデ始メタ時カラノヲ全部送リマシタ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ハ何々運動トイウヨウナコトハイツサイ虫ガ好カヌ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然したつた一つの彼女の形見である『ワザーリング、ハイツ』を繙く者には何れだけ強く深い人生の経験が、この不幸な、嘗て一たびも恋の囁きさへ耳にしたことのない少女の胸の中に潜んでゐたかといふことがわかる。",
              "citation": {
                "source": "愛は、力は土より",
                "author": "中沢臨川",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れることのできないのは『ワザーリング、ハイツ』の最後の一節である。",
              "citation": {
                "source": "愛は、力は土より",
                "author": "中沢臨川",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソシテ、玉ネギサンノ　ノツテヰル汽車ノ中ヘハイツテイツテ、席ニコシヲ下シテ、グウ　グウ　グウ　グウ眠リコンデシマヒマシタ。",
              "citation": {
                "source": "オ寝坊ナ　ジヤガイモサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレデ、ボンコチヤンハイツモ、アタラシイ時ノヤウニ美シウゴザイマス。",
              "citation": {
                "source": "バウシ　ノ　ユクヘ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレデ、ボンコチヤンハイツモ、モンコチヤンノアタマニイヤイヤノツカリマシタカラ、アマリニアヒマセンデシタ。",
              "citation": {
                "source": "バウシ　ノ　ユクヘ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジロウハ　ウミニ　ハイツテ　ブリキノバケツニ　ミヅヲ一パイ　クミマシタ。",
              "citation": {
                "source": "スナマンヂウ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレカライクラ、オモシロクツテモ、アンマリナガク水ノ中ニハイツテヰルト、カラダニドクデスカラネ。",
              "citation": {
                "source": "ウミベノマヒゴ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京ハイツデモアツイソウデスガ、今年ハトクベツニアツクテ、三十五年カラナイホドダサウデス。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮なくカレッジの庭を通りぬけて、三哩ばかり自動車を走らすと、ハイツに着く。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイツとは詩人ウオーキン・ミラー翁の住んでいた旧邸である。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイツは詩人ミラー翁を記念する為に、ミラーの死後千九百十九年に、オークランド市が買取って永久保存の公園としたミラー翁の旧邸なのである。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイツの森を出た者は、誰でも後を振り向いて考えるであろう。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "問　被告ガ道子ヲ殺ス気ヲ起シタノハイツ頃カ。",
              "citation": {
                "source": "彼が殺したか",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の一人、時々ハイツ、ハイツと掛声を掛けてゐるのは、此の旭亭の娘（千代――通称ミル）。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナマメカシイト云ッタライヽノカ、色ッポイト云ッタライヽノカ、己ハ今マデニアンナ妖艶ナ女ヲ見タコトガナイ、妖婦ト云ウノハ正シクアンナ女ノコトヲ云ウンダロウナ、アンナ女ニナラ殺サレタッテイヽト思ッタト、湿ノ父親ハイツモ忰ヲ掴マエテヨク／＼感ニ耐エタヨウニ云イ暮ラシタソウダ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "………「軽井沢ヘハイツイラツシャルノ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソウナルト予ハイツモノ癖デ依怙地ニナリ、直グニハ立チ上ロウトシナイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アタシハ一下足オ先ニ参リマス、オ爺チャンハイツイラッシャルノ」ト、婆サンハ云ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春久ハイツ帰ッタンダネ」四阿デ直グソノ話ニナッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ハ糊ノ硬イゴワ／＼シタ単衣ヲ着セラレルノガ嫌イデアッタガ、寝間着ニハイツモ甘ッタルイ腐リカヽッタヨウナ糊ノ匂イガシタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良ノ三月堂ノ不空羂索観世音菩薩ノ足ヲ見ルト、予ハイツモ母ノ足ヲ思イ出ス。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
