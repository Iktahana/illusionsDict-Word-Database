    "definitions": [
      {
        "index": 1,
        "gloss": "hummingbird (Trochilidae family)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
