          "standard": [
            {
              "text": "木漏れ日の下で、静かに読書を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "森の奥深く、木漏れ日が幻想的な光のカーテンを作り出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "幼い頃、夏休みに祖母の家で見た木漏れ日の温かさを今でも覚えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すると、うす暗い台所の板敷の上に眩しいやうな、うすい葉洩れ日のやうな気配が立つた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            }
