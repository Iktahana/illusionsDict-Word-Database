[
  {
    "uuid": "4cb5aa6e-24ed-5c78-9634-63f14e1a2362",
    "entry": "反射光",
    "reading": {
      "primary": "はんしゃこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
