    "definitions": [
      {
        "index": 1,
        "gloss": "being boxed in on all sides",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "八方ふさがり、と言ってしまうと、これもウソなのである。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "首がまわらぬ、八方ふさがり、全体がたゞハリツメタ重さばかりで、無性にイライラするばかり。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして事件は、八方ふさがりの迷宮入りをしたかに思われるに至った。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、大逆事件があつて以來、わたしどもの生活の道は八方ふさがりになりました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そののち、もうほどなく、うちじゅうまた八方ふさがりになりました。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウクライナをとられ、八方ふさがりの現在、東大の先生がこう言っているのだ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "棉ごみの中で青春は八方ふさがりニキビの吹き出た頬っぺたをつめたい窓硝子に寄せるネクタイの連中は朝ッぱらから花見に出かけたしたんぽぽの咲く花は命がけ癪だ天井を突き抜ける轟音とその三層倍も湧きあがった棉ごみの中――見たかのみでもぶち込まねば赤い血の出そうにもない襟首を――のしかかる労働強化！",
              "citation": {
                "source": "無念女工",
                "author": "榎南謙一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによると八方ふさがりでどこへいっても頭ばかり下げているからこの自分にだけ、天下御免と怒鳴りちらすのかもしれない。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗剣殺……八方ふさがり。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、与吉がこうやってころげこんでくるのは、目下八方ふさがりの証拠で――もっとも、相手が与の公ですから、お藤姐御はてんで歯牙にもかけていない。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは八方ふさがりです。",
              "citation": {
                "source": "スザナの物語",
                "author": "――経典外聖書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう八方ふさがりになつてしまつちや、もうおしまひだ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色気が八方ふさがりの一劃に封じ込まれた為め、町が内訌してゐる塩梅だらう。",
              "citation": {
                "source": "洲崎の印象",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国王さま、もはや八方ふさがりです。",
              "citation": {
                "source": "コロロッチョ",
                "author": "GRILLINO",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士というものが学術優等で且つその上に品行まで方正でなければならぬと仮定する以上、右のような八方ふさがりに陥るのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の吉運は八方ふさがりの間にだって、その一点で開運、上吉の卦にかわっていたのですものね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の馬春堂先生が、桃源の夢こまやかであッたり、地獄の羅刹に魘されたりしながらも、どうしても逃げ口がない八方ふさがりの密室！",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
