    },
    "definitions": [
      {
        "index": 1,
        "gloss": "lecture hall of a temple (esp. Zen)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "双方、法堂へ行って支度をしなさい」　三要はこう言ってじろりと昭青年を見ました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、もう知らん顔で三要は座を立ち法堂へ急ぐ様子でした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "建築に於ても亦、佛殿法堂式の建築は、日本に於ては寺院のみに限れるも、支那にては宋代以後の大建築は大體みな法堂の如きものなり。",
              "citation": {
                "source": "日本の肖像畫と鎌倉時代",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "傳法堂の乾漆佛は戸外よりのぞきしのみ、夢殿の觀音は祕佛にて拜まれぬよし、中宮寺の如意輪觀音も、穗井田忠友が觀古雜帖にて摸本ばかりは見し天壽國曼陀羅も、容易くは拜まれずといふにて止みぬ、古寫經の屏風なども多かりしも仔細に諦觀せんひまなかりしをかこたんは、あまりに欲深くやあるべき。",
              "citation": {
                "source": "寧樂",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "古色を帯びた甃の上の柱廊を以て、護法堂その他の建物が連絡されている。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青蓮堂に藤左衛門の像、護法堂の有名な彫塑大布袋、大方丈の沈南蘋の牡丹の絵などを見せて貰った。",
              "citation": {
                "source": "長崎の印象",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺は、建物も大観門から青蓮堂――観音廟を見たところ、同じ辺から護法堂へ行く窟門の眺めなど、趣き深い。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "護法堂の布袋、囲りに唐児が遊れて居る巨大な金色の布袋なのだが、其が彫塑であるという専門的穿鑿をおいても、この位心持よい布袋を私は初めて見た。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだにそのまわりの伝法堂などは板がこいがされているが、このまえ来たとき無慙にも解体されていた夢殿だけは、もうすっかり修理ができあがっていた。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "法堂や本堂や山門は無論のことですが、斎堂や浴室にも家庭の要素は想像することができません。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその大蛇を祭って、今も閼迦井護法堂とて小さい堂があるのだというのである。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　護法と天狗――天狗は一種の魔神　鞍馬では右の護法堂の大蛇以外、別に天狗という名高い護法のあることを忘れてはならぬ。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四夢殿――夢殿秘仏――フェノロサの見方――伝法堂――中宮寺――中宮寺観音――日本的特質――中宮寺以後　ひるから夢殿に行った。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし講堂たる伝法堂は橘夫人の邸宅より移した住宅建築である。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の奥にその伝法堂の見えている絵殿のぬれ縁に立って夢殿をながめると、かろうじて堂の全貌を見ることができる。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根のひくい絵殿の廊下を通りぬけて、その後方の伝法堂に行った。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、当院の鐘は、どうしたのじゃ」西塔の如法堂で、学頭の中年僧が、方丈から首を出した。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白き世界　泉岳禅寺の常法堂には、その朝、僧寮のものが、みな集まっていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "門内へ入って来た四十六名の代表者が、そこに立って、大きな声でものを云っているのが、常法堂の伽藍までよく響いて来た。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばし、墓所へ通って、君霊に御報告仕ります間、余人共の立ち入らぬよう、山門をお閉めおき下されたい』　常法堂の僧たちは、いつの間にかしんとして、その声音に耳を奪われていた。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに女は仕合わせに生れ、心配でも何でも長つづきがしない、はっとうれしいことで直ぐ忘られるから。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっとうしろをふりかえると、防毒面に防毒衣をつけた人相のわからない者が、二人ばかり入ってきた。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
