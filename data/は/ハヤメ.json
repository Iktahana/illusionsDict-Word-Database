    "definitions": [
      {
        "index": 1,
        "gloss": "early",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "銭湯から帰って、早めの夕食をたべた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "網の竿をのばしたと思うと急に足を早めて網を投げた。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美代と二人でよこせばよかったと思いながら、無言で歩調を早める。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また特にフィルムの繰り出し方を早めあるいは緩めて見せる事によって色々の知識を授ける事が出来る。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次急に足を早めて侍を追い越すとその儘走り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来の人が空を見上げ乍ら足を早めます。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスと並んで歩く少佐夫人は、体の太つたのと反対に、いつも忙しさうに足を早めたがる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不意に高く動氣打たせながら、ただ歩調を早めるばかりだつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は、暫らく行くと、急に速力を早めた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり詳しい計算などは略して、ごく概略に考えても、要するに少しおくれて停留所に来た車は、少し早めにそこに来た車よりも統計的に多数の乗客を収容しなければならない事は明らかである。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この三つの音が次第に調子を早める。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして気がついてゆるみかかった歩度を早めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは雨の方に向つて足を早めた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私は、そうなると、却って猛勇を奮い起し、遮二無二翼を早めて、太陽を目がけて、飛びつこうとしました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて其翌日「日の昨の御獻立出來上り候、早めさせ給ふべきか」と御膳部方より伺へば、しばしとありて、彼の何某を御前に召させられ、「近きうちに鳥を納れむと思ふなり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行船は始めその両翼を静かに動かしながら徐々に上昇しつつあったが、次第にその速力を早めて来た、秋山男爵は東の方へ、雲井文彦は西の方へと針路を取って進んで行く。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "文彦は速力を早めて近づくと、先方もそれと察したか忽々に飛び乗って、もはや飛行船は飛び去る準備をすべく、その大きな両翼を緩やかに動かし初めた。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "月ならぬ眞晝の緋葉を潛つて、仰げば同じ姿に、遠く高き峰の緋葉は蒼空を舞つて海に散る……を鹿なく此の山里と詠じけむ嵯峨のあたりの秋の頃――峰の嵐か松風か、尋ぬる人の琴の音か、覺束なく思ひ、駒を早めて行くほどに――　カーン、カーンと鉦の音が細く響く。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかにきゃっと叫んで逃げるほどでもなかったが、わたしは再び振返る勇気もなく、ただ真直に足を早めてゆくと、女もわたしを追うように附いて来る。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "月が明るいので見失う虞れはないと、元八も最初はわざと遠く距れていたが、往来へ近づくに従って彼は足を早めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「足の早い奴らだ」　元八も足を早めて、うす暗い森を出ぬけると、その行く手に男二人と女ひとりのうしろ影が明るい月に照らされて見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、結局それだからと云って如何なるものでもないではないが……彼は一層足を早めて、そして近道をするために薄暗い拱路へ入った。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそのパジャマの袖を取って、それを崖の上に置いて、如何にもそこで幸子とお前との間に格闘でも行われたように見せかけて、その筋の発見を早めようかと思ったがなまじそんな細工をして、お前自身に第三者の介在を気付かれては却って困ると考えて、止めた。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆この鼓の音を聞いたために死を早めたのである。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして或る朝何の故ともなく自害をして世を早めた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "足をこころもち早めた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食を早めにして下さい。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何の理由もなく、急に足がすくむやうな羞しさと、一人で居るきまりの悪さを感じたので、歩調を早めながら、わざと彼等の方を見ないやうにし、特別にまた肩を怒らして追ひぬけた。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は追いすがるように、二、三歩足を早めて、「何か兄さんに言われましたか？",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場は音たかく舌打ちして、「おい佐竹、からかうのはやめろ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
