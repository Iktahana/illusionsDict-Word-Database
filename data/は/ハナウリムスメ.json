          "literary": [
            {
              "text": "裸足の少年靴みがき団を筆頭に、花売り娘、燐寸売子、いかさま賽の行商人、魔窟の客引き――そう言えば、このポウト・サイドには、土人区域の市場を抜けて回教堂の裏へ出ると、白昼、数時間寄港の船員や旅行者を相手にする、陰惨な点で世界的に有名な一廓がある。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は花売り娘かい」　少女はうなずきましたが、そのひょうしに、またはらはらと涙をこぼしました。",
              "citation": {
                "source": "街の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は花売り娘だった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二の花売り娘がひもじがって、ぶっ倒れている。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その花売り娘も今は人の魂にその花をささげていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
