        "examples": {
          "standard": [
            {
              "text": "電話番号を記載する際、市外局番と市内局番の間にハイフンを入れるのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「マイページにログインするためのIDには、ハイフンは使用できません」というエラーが出た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "名前のスペルにハイフンが含まれている場合、航空券の予約時に正しく入力しないとトラブルになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "トム君は、アメリカ式のチェックマークとハイフンを使う。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに、ハイフンは「積極的反対票」、つまり、「ひっでえ曲、ゲエー」ということ）。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "括弧やイタリックや、ハイフンも出来るだけ少く使うこと、みんな陳腐です。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六〇年代のなかばから後半にかけて、おしまいにハイフンをつけてＶの字をひとつ加えた名前が、いくつかある。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
