    "definitions": [
      {
        "index": 1,
        "gloss": "for the first time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がこの本を初めて知つたのは大正十四年の暮であつたかその翌年の初めであつたか、とまれ寒い頃であつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことが果される時に詩は初めて「作品」として通用するのだと思ふ。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕としてそんな用命にあづかつたことは生れて初めてでもあつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレベーターに初めて乗つたのも、その夏である。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくヘルンはその時初めて心の隅に、幸福という物の侘しい実体を見たのであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の告白によれば、自分の良人に対する真の愛は、その時初めて起ったという。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて大久保の新居に移った時は、春の麗らかな日であって、裏の竹藪で鶯がしきりに鳴いてた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて病気の発作が起った時、ヘルンは自己の運命をすっかり自覚し、死後における妻子の保護と財産の管理とを、親友の法学士に一任して、後に心がかりのないようにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿を初めて見た時、田圃の中に建設された、一夜作りの大都會を見るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて自分の物を好いと思つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の、本当の悲劇は物質を基調として初めて存在する。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前初めて辻氏を訪ねたら貴兄に手紙を出してみるがいゝといはれたので、手紙を書かうとしたのですが、手紙つて奴が僕には六ヶ敷いから、過日書いた貴兄についての論文（？",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それを聞いた妻君は初めて笑顔を作つても好い機会を持つたわけであつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論彼の家に来るのも初めてだつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きな仕事が一つあり、たえずそれに心が集中される時に初めて、人生変化も感じられるといふものである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳で聽いて意味がわからず、文字に書いて見せた上で、初めて視覺から語意が通ずるといふやうな言葉を、日常語の會話に使用するやうな國民があるとしたら、世界で最も不便で最惡の國語を所有する民族と言はねばならぬ。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの時、初めて日本語に眞の「韻」といふものが出來、支那西洋の國語と同じく、我々の言葉にもまた眞の「韻律」が發生する。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の価値が、初めて正しく評価され、その俳句が再批判されたのは、彼の死後百数十年を経た後世、最近明治になってからのことであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その崇拝する芭蕉の庵を、初めて親しく訪ねた日は、おそらく感激無量であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言えば、その心に「詩」を所有している真の詩人が、対象を客観的に叙景する時にのみ、初めて俳句や歌が出来るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば詩の翻訳者は、原作を自分の中に融化し、自分の芸術的肉体として、細胞化した場合にのみ、初めて訳者としての著作権を有するのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がド氏の名を初めて知り、その作品を讀む機縁になつたのも、實は白樺派の人に教はつた爲であつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が初めて讀んだド氏の小説は、例の「カラマゾフの兄弟」であつた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕は詩を作り、初めて文壇的に出發したので、二三の友人と共に同人雜誌を發行して居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで初めてドストイェフスキイが、眞の文學的本質によつて理解される機縁が來た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は二十八歳の時に、初めてドストイェフスキイの小説『白痴』をよんで吃驚した。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを初めて読んだ時、まさしくこれは僕のことを書いたのだと思ったほどだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もさう言はれて、初めて喫茶店の客が「何を考へて居るのだらう」と考へて見た。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分にナショナルリーダーを教わったときに生れてはじめて雪橇というものの名を聞き覚え、その絵を見て、限りなき好奇心と異国の冬への憧憬を喚び起こされたのであったが、その実物をこの眼に見、その鈴の音を耳にしたのは実にこの夜が初めてでありそうしてまたおそらく最後でもあった。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまらない草花がみんな「いきもの」だという事をこれほど明白に見せつけられたのは初めてであった。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
