    "definitions": [
      {
        "index": 1,
        "gloss": "a ferment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冷たくなる前に酵母と発酵素を入れる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに含まれるガムのような物質はビールにとってあまりにも多くの発酵素（酢酸発酵の酵素か）をビールに与えて駄目にする。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはつさんは釜や飯櫃にくっついた御飯粒や種子飯（パンの発酵素をつくる）の残りを集めて煮てたべているのですよ』と代って返答したので初めて謎が解け、年若とはいえあまりに認識の足らなかった自分を恥しく思うとともに、おはつさんの心がけにはほとほと感心いたしました。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもヨーロッパの心がロジャー・ベイコンの発酵素にたいして準備されていて、人々がスコラ派の哲学やドゥンス・スコトゥス（スコットランドの神学者）、アベラル、トマス・アキナスの微妙なことに何世紀も無駄に過ごさないで、物理学、天文学、化学の役に立つ研究をしていたらどのような運命になっていただろうか？",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでアルケウスは局所にある発酵素（ferment）という媒介物を通して作用する。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると次々と傷に届く血液は発酵素を介して腐敗を起こす」と。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国学派の一般とおなじように彼はイタリア学派よりも全く機械的であり、発酵素とか酸とか、消化すらも聴こうとしなかった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラケルススのアルケウスが生きている生物の支配的な魂であり、特定な局在している発酵素を通して働き、これによって各臓器の機能は制御される。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "17世紀の傑出したイギリス哲学者であり、その世紀における誰よりも実験方法の重要さを知っていたロバート・ボイルが、発酵素および発酵の本質を発見した者はある種の病気の本質を誰よりもよく説明できる、と言っていたことは素晴らしい事実である。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち彼らは、活動の発酵素であり、生活の酵母である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルケウスは直接には作用しないで物質に影響するには「発酵素」を利用する。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "発酵素はきわめて微妙な物質であってアルケウスと同じようにガス状である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルケウスは体内の内在性のものであるが発酵素は超個人的なものであり神により未来永遠のために作られたものである。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は物質的な基本物質であり発酵素すなわち種子物質は動的な基本物質である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによって発酵素は変化しこの変化は臓器を構成している物質に影響し沈殿が作られる。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前に酵母は結晶性の発酵素とみなされていたがカビの一種で生物であることが判った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがってこのような発酵素の働きを「生きているコンタギウム」と比較するのは当然なことであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "疫病が広がるときに作用する毒素はたぶん発酵素のような生きている生物であろう。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "脾脱疽すなわち炭疽病についてミアスマやコンタギウムは神秘的な物質ではなく曖昧な発酵素ではなく、微生物、分裂菌、細菌またはその胞子、であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
