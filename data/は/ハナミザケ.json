        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "満開の桜の下で、友人たちと花見酒を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "今年の花見では、少し肌寒いので熱燗の花見酒が体に染みた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「乾杯！」「やっぱり花見酒は格別だね！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "あっちの花見酒で酔い潰れ、こっちのお祝い酒で奢り潰されてなあ」「太平楽なにも程がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "……これからがお花見酒だ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい水がこん／＼あふれてゐる、この家のよさの一つ、朝酒、それは花見酒でもあつた、裏から桜の花片がしきりに散りこんでくる。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お猪口一つ持つて行きさへすれば、墨堤十里、あつちでさゝれ、こつちでさゝれ、随分いい心持ちによつぱらつてお花見ができたものですよ、あなた」　さてこそな、落語の「花見酒」。",
              "citation": {
                "source": "下町歳事記",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "松川源十のいうように、花見酒ではないのである。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
