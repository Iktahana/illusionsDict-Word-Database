    "definitions": [
      {
        "index": 1,
        "gloss": "to burst open",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サムソンというんだ」　綺麗な疳高い、少し野趣を帯びた笑声が弾けるように響いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その度に今日こそあの隙のない名人に不意討ちをかけ、一泡吹かしてやるのだと思うと勇気が凜々と五体に漲り弾ける思いがするのでした。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ喜野、あすこの広間へ行ってな、内の千がそう言うたて、誰でも弾けるのを借りて来やよ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんど来るときはもっと仰山弾けるようにして来て、いろんな曲をきかしてくれや」といったので木之助は「ああ」といった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたり万遍なくぽちん／＼と雨滴のように水面に弾ける沼気の気泡。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲は「チゴイネルヴァイゼン」――七つの春、小学校にはいった時から、ヴァイオリン弾きの父親を教師に習いはじめて、二年の間に、寿子はもうそんな曲が弾けるようになった位きびしく仕込まれていたのだ。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次なるは聾しぬる清き尼三味線弾ける。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばらばらと云う怪しいものの弾ける物音が裏山の方でしはじめた。",
              "citation": {
                "source": "不動像の行方",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さをおそれず、肌を刺すような北風の中で弾けるだけに、なんとはなしに草木の先駆者というような気がします。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで何かぴゅん……と弾ける音がした。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小品ばかりか難しい曲も弾けることは、要望に応えて、メンデルスゾーンのリートや私のお気に入りを何曲か演奏してくれたことからもよくわかる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はごまかしでなくほんとうに琵琶の弾けるという人はあまりなくなりました。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "負けぬ気の椿岳は業を煮やして、桜痴が弾くなら俺だって弾けると、誰の前でも怯めず臆せずベロンベロンと掻鳴らし、勝手な節をつけては盛んに平家を唸ったものだ。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、なにか弾けるの」　その日の夕食後、じぶんのとなりのベッドを割り当てられた片桐に、慶一は話しかけてみた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高志って、オルガン弾けるのかさ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すこしは弾けるのかさ」　慶一は不安だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じぶんのギターは、弦をさかさまに張り替えて使っているが、右用のギターでも、そのままひっくりかえしてコードを弾ける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラツパとオルガンと手風琴だけは、あの人は自慢なのよ――我流だから暗闇でも弾けるのよ。",
              "citation": {
                "source": "断唱",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板のすぐ真上に、ぱらぱらぱらと弾けるような音がして、眼もくらむようなマグネシウムの大光団が現れた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "中橋新文部10・１（夕）　無茶苦茶な世の中に生きてゆく必要から、自分は余り物事に心を動かさないやうに腹を据ゑてゐるが、それでも今度の新内閣の顔触に、中橋徳五郎氏の文部大臣を見た時には、急に可笑しくなつて弾けるやうに笑ひたくなつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "はにかんで、ほんとうに弾けるようには指を動かさないで、音だけ出しているのであった。",
              "citation": {
                "source": "白藤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたは音楽はおやりになりませんの」「オルガンが少し弾けるきりだ」「僕は今度運動会の折には音楽隊をこしらえるつもりです。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "琴などはまして稽古をする者がなくなったということですからあなただけ弾ける人はあまりないでしょう」　と院がお言いになると、宮は無邪気に微笑んで、自分の芸がこんなにも認められるようになったかと喜んでおいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかで爆竹の弾ける音がすさまじく耳のそばでしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やぶれかぶれの気持ちの中から、いろいろな光彩が弾ける。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝雨にあらわれたあとの、すがすがしい空には、パチパチと弾ける音がして、明治神宮奉祝の花火があがっている。",
              "citation": {
                "source": "大橋須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええね、ええね、なんか嬉しい気がするぞ、今日は良う弾けるかも知れんなあ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしも、いろんな弟子をもったが、その女子ほどの名手は、実際会ったことがないほどで、それが、こっちから訊かなければ何も知らんふりをしているが、なんでも弾けるのでなあ、忘れてしまうと、わしのものを、わしが教えてもらうので――いや、ほんのこっちゃ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古というものは、教えて見て、弾けるか弾けないかで断わりもするが、小さいから大きいからっていうことはない。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鼓村さんは、自分だけでなら、どんなふうにも弾けるので、癖になってしまってて、困ると自分でこぼして、気持ちが軽々したように、「浜子さん、有難う有難う、助かったわい。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
