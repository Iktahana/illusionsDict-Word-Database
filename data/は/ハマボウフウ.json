        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日の当る砂丘の蔭に浜防風が鬱金色の芽を出していた。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは別荘へ帰ってその夜の晩飯には、娘の摘んだ浜防風と生のしらすと酢のものにしたのを食べた。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年正月のためとて浜防風と生のしらすは欠かさず送って来る。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源吉は浜防風のあぎた砂山の踏みごたへのしない砂を踏んでゐた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が浜の浜防風を喜ぶ彼女はまったく子供であった。",
              "citation": {
                "source": "智恵子の半生",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が浜の浜防風を喜ぶ彼女はまつたく子供であつた。",
              "citation": {
                "source": "智恵子抄",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃は浜防風のとうがたって、丸い手毬のような実をつけている、実を覚えていらっしゃるかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物の名は知らないが、浜木綿とか浜防風とか呼ぶのだろう。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
