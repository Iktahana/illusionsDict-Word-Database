    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Osaka-Kobe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "阪神の踊子が工場へはいったと、新聞に写真入りである。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "学生の頃の木崎が八重子と知り合った時は、しかし八重子はもうダンサーではなく、阪神間のあるホテルの受付で働いていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店の経営者は蘆屋のマダム連中で、かつては阪神間のブルジョワの有閑夫人を代表していた蘆屋のマダム連中も、洋裁教授の看板を出したり、喫茶店の共同経営を思いついたりしなければならぬくらい、恥も外聞も忘れた苦しい新円生活に追い込まれていたのであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「細雪」は大阪と神戸の中間、つまり阪神間の有閑家庭を描いたものであって、それだけに純大阪の言葉ではない。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、阪神の香櫨園の駅まで来ると、海岸の方から仮面のやうに表情を硬張らせて歩いて来る修一とぱつたり出会つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りの阪神電車は混んでゐた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下道にある阪神マーケットの飾窓のなかで飾人形のように眠っている男は温かそうだと、ふと見れば、飾窓が一つ空いている。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが出展締め切り直前の一月十七日、阪神大震災が起こってそれどころではなくなってしまいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "』の三号には、阪神大震災に際して木津田さんがどう振る舞ったかの記録が、「建物診断ボランティアに参加して」と題して掲載されました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後は阪神附近をアチコチと流離していたが、ドコにも容れられないでとうとう九州に渡って別府に逼息し、生活に労れた病躯を抱えて淋しく暮した。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレビのまえには、慶一たち派に勝った、六人ほどのプロ野球派が、巨人−阪神のデイゲーム中継を見ている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十三　八阪神社の祭礼はにぎやかであった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "虱５・16（夕）　今日阪神電車に乗ると、私の前に齢の頃は四十恰好の職人風らしい男が腰をかけてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の途連れ８・２（夕）　七月三十一日午後六時｜過の事、阪神電車の梅田停留場から神戸行の電車に乗込んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "知事と電車８・16（夕）　八月十四日午前九時――もつと判り易く言へば昨日朝の事――阪神線の香櫨園停留場から電車に乗つた男があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "阪神電車で大阪に通つてゐる私は、初めての不通の折は読み古しの夕刊を、二度目には使ひさしの汽車の切符を水神様に手向けたが、供物が気に入らなかつた故か、水は少しも減らなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」原敬氏の頭で大発見３・30（夕）　阪神急行電車の小林一三氏は、この一二年来めつきり頭に白髪が殖えて来たので、それが気になつて堪らない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらためて言つておくが、小林氏は阪神急行電車の重役である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車は大阪神戸といつたやうな、二つの都市の最も速い交通機関であるのみならず、また地獄への捷径である事をも知つてゐる小林氏は、電車ほど人生にとつて必要なものは無いと信じてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方の大阪から神戸兵庫を経て、須磨の海岸あたりにまで延長していっている阪神の市民に、温和で健やかな空気と、青々した山や海の眺めと、新鮮な食料とで、彼らの休息と慰安を与える新しい住宅地の一つであった。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが漁場漁場へ寄って、魚を集めて阪神へ送るのです」桂三郎はそんな話をした。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の郷里の竜野は近年は阪神地方からの遊覧者も多い山水明媚の地であるが、その風物は武蔵野などとはまるで違っている。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるか麓の方に阪神電車の走るのが見えて、ここは兵庫県の六甲山であることは慥かに知っている。",
              "citation": {
                "source": "六甲山上の夏",
                "author": "九条武子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり被害者の家には申合わせたようにＳ・Ｓ式軽油ストーブが在ったところから、もしやと思って京阪神地方の煖房具店を調査すると果せる哉、東京から廻送して来た写真の女が開いている軽油ストーブ店が三の宮で発見されると同時に、その店の主人と雇男が犯人に相違ないことが判明したものである。",
              "citation": {
                "source": "老巡査",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近年、私は阪神沿線へ居を移してからというものは、殊の外、地面の色の真白さと、常に降りそそぐ陽光の明るさに驚かされている。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば素晴らしく平坦な阪神国道、その上を走るオートバイの爆音、高級車のドライヴ、スポーツマンの白シャツ、海水着のダンダラ染め、シネコダックの撮影、大きな耳掃除の道具を抱えたゴルフの紳士、登山、競馬、テニス、野球、少女歌劇、家族温泉等であるかも知れない。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
