        "examples": {
          "standard": [
            {
              "text": "歯医者でレントゲンを撮ってもらい、歯骨の状態を確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "加齢とともに歯骨が弱くなり、歯周病のリスクが高まる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、歯骨の成長に影響する遺伝子の研究をしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は細君を火葬に附して、骨上げをした歯骨の中から上下の門歯と犬歯合せて十二本を取り出し、それを上下の顎の大きさの金具に排列し、更にそれを鋳物のときにつかう釘抜のような鉗子の先へ固定し、大原の咽喉笛をはさみ切って殺そうと計画したのである。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はせい子さんが、ただ汚されたということだけを恥じて物を言わぬのだろうと察したが、大原がせい子さんの父だとは夢にも思わなかった」「仏壇参詣は無論歯骨を捜しに行かれたのですね？",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに谷村も、人の血で汚された歯骨をもとの所へ置く気にならなかったのだろう。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "穏「私が見て居ねえでは歯骨や何か分るまい。",
              "citation": {
                "source": "黄金餅",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "お文さんは私が金ピカの袋に入れて持つて来た母の歯骨を仏壇に飾つて拝んだ。",
              "citation": {
                "source": "念仏の家",
                "author": "小寺菊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はみんなにとめられるのを断り、仏壇から母の歯骨をおろして、夕方再び汽車に乗り、三里さきの我生れ故郷富山に向つた。",
              "citation": {
                "source": "念仏の家",
                "author": "小寺菊子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
