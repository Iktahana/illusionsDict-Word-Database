[
  {
    "uuid": "0d055a23-44ec-528b-8fd8-20e9fb7a73fd",
    "entry": "半畳",
    "reading": {
      "primary": "はんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
