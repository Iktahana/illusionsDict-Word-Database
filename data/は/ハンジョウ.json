    "entry": "斑条",
    "reading": {
      "primary": "はんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "variegated streaks",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "感心な犬の話は、そこからかしこへとつたわって、町中で大評判になり、わざわざ肉を買いがてら見に来る人もあったりして、肉屋ははんじょうしました。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔からその角に煙草やがあって、はんじょうしていたから、やはり煙草やがいいと思ったのだ。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦敗街道　天幕ばりながら源一の一坪店は、はんじょうしている。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "じくさいは　きょうとに　きて　はたやを　ひらいて、大へん　はんじょうしました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくつくったロウ人形館もいっこうはんじょうしないのでした。",
              "citation": {
                "source": "仮面の恐怖王",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この月世界を作った会社の重役は、警視庁によびつけられて、ひどくしかられましたが、そのことがまた宣伝になって、人工月世界旅行は、おそろしくはんじょうしました。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に土地がはんじょうして、働く人が多く、食べる人が多くなれば、だれしもこういう野原をひらいて、なんか作ったらという気になる。",
              "citation": {
                "source": "母の手毬歌",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
