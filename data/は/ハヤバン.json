    "definitions": [
      {
        "index": 1,
        "gloss": "early edition (of a newspaper)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "住田とレンラクはないんだね」「ないから困ってんだよ」「これは明日の早版の朝刊だ。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　放二は早版の夕刊新聞を買いこんで、電車にのった。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「畜生ッ、――もう三分話せば、朝刊の早版へ三段以上は書けたのに」　千種十次郎がガチャリと受話器を投ると、まだ銀座あたりを泳ぎ廻って居た編輯局長の織戸友吉が、市内版最後の大組を見る為にフラリと編輯局を覗きました。",
              "citation": {
                "source": "音波の殺人",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に持っていたのは夕刊紙の早版だ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "早版は通常、どの新聞も正午ちょっとすぎに発行する。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここへ来たとき夕刊紙の早版で読んだ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
