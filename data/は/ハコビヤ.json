        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "男の運び屋のように、たくさんの荷を背負っては来なかったが、リンゴも三度に一度は取りあげられると、浮ぶ瀬がないので、味噌とか、ゴマのようなものを混ぜて買って来ては、結構｜利潤がのぼっていた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆虫が病気の運び屋であることの発見もまたその生活史の知識を大きく広げることになった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもどうして手紙を俺に書かせたいのだ」「だって、私が手紙の運び屋をやらされそうだからです。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひとが　にわの　いりぐちのわきに　かごを　おいておくと、　はこびやさんが　とおりすがりに　ひろっていく　というわけで。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "びくっとして　めを　さますと、　かごが　ちょうど　はこびやさんの　にぐるまに　つまれるところで。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいえの　すいじがかりは　はこびやさんに　はくどうの　コインを　１まい　わたしました。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかんとなれば、もしはうそうするものあれば我子といへども家に居らせず、山に仮小屋を作りて入れおき、喰物をはこびやしなふのみ。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
