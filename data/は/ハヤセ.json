        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かれは意にもなく手近の小枝を折り、真紅の葉一つを摘みて流れに落とせば、早瀬これを浮かべて流れゆくをかれは静かにながめて次の橋の陰に隠るるを待つらんごとし。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし雲巌寺を出発してから行く途々、渓流に沿うて断岸の上から眼下を見れば、この渓流には瀑布もあれば、泡立ち流るる早瀬もあり、また物凄く渦巻く深淵などもあって、好奇に盥に乗って下ろうものなら、二人や三人土左衛門と改名したかも知れぬのだ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "※｜廓へ近き畦道も、右か左か白妙に、この間に早瀬｜主税、お蔦とともに仮色使と行逢いつつ、登場。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "※｜往来のなきを幸に、人目を忍び彳みて、仮色使の退場する時、早瀬お蔦と立留る。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　どうかもしていようよ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　済まないな、今更ながら。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）※｜慥にここと見覚えの門の扉に立寄れば、（早瀬、引かれてあとずさりに、一脚のベンチに憩う。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　何、月夜がかい。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　そうさな、不思議と云えば不思議だよ、世の中の事は分らないものだからな。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　（懸念して）え、なぜだ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　…………お蔦　ねえ、貴方、私やっぱり、亡くなった親の情が貴方に乗憑ったんだろうとそう思いますわ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　難有い、俺ら嬉しいぜ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　何という事はない、が、月を見な、時々雲も懸るだろう。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　ああ、行くが可い、ついで、と云っては失礼だが、お前｜不忍まで行ってはどうだ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　お心まかせになさるが可い。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　なぜ、他の事とは違う、信心ごとを止しちゃ不可ない。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　お茶屋じゃない。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）早瀬　早く行って来ないかよ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　何だ、ぶしつけな。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　（ほろりと泣く。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　それ見ろ、弱虫。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　可し、大きな目を開いて見ていてやる。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "※互に心合鍵に、早瀬見送る。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬、腕を拱きものおもいに沈む。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　おお早かったな。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　お前、せいせい云って、ちと休むが可い。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　おまいりをして来たかい。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　何と云ってさ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　聞きたいんだよ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早瀬　それから、……お蔦　だって、あとは分ってるじゃありませんかね。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
