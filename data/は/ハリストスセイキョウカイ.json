          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "日本ハリストス正教会は、ロシア正教会の宣教から始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "東京復活大聖堂（ニコライ堂）は、日本ハリストス正教会の中心的な教会だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "日本ハリストス正教会は、日本の文化や歴史と深く関わりながら発展してきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
