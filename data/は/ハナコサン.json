    "definitions": [
      {
        "index": 1,
        "gloss": "Hanako-san (ghost rumoured to haunt school toilet stalls)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "交番の前で、巡査に叱られるような気がしたといったら、花子さんは悪いことをしているつもりでいるのかときいた。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎さんと花子さんは、お父様とお母様に手を引かれて東京の近所のばあやの処へ逃げて来ました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると花子さんもねむったままで、「メリーさん、メリーさん」　と呼びました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、太郎さんと花子さんは二人揃ってお父様とお母様の前へ出て、「どうぞも一ペン東京に連れて行って下さい。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は悲しくなってシクシク泣き出しましたが、やがて花子さんはばあやのお庭の隅に、「メリーさんのお墓」と書いた木の札を立ててコスモスやケイトーの花を上げて拝みました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだよくわからないのだからお墓を建てるのおよしよ」　と止めましたが、花子さんはただシクシク泣いて拝んでいました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おうちに来ると花子さんは何より先に押入れをあけて人形を見つけますと、抱き締めて飛んでよろこびました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんはそれを見て、「お兄様、お人形が焼けなかったからポチもきっと無事ですよ。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様もお母様も花子さんも驚いてみんな表へ出ますと、泥棒のようななりをした大男が犬に食いつかれて跛を引き引き向うへ逃げて行きます。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱりあの夢はほんとだったわね」　と花子さんは人形を抱きながら太郎さんに言いました。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんは夢中になってお友達と羽子をついているうちに、羽子板のうらの美しい姉さんの顔の頬ぺたが、いつの間にか羽子のムクロジに当って、ポコンと凹んでいるのを見つけました。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんはわっと泣き出して、おうちへ駈け込んで、お母さんの膝へ泣き伏しました。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんは羽子板の美しい姉さんの顔が可愛そうでなりませんでした。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんは思わず飛起きて、飛び付きました。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんはどうしようかと思いました。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへどこからか、「それは花子さんが悪いのではない。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて姉さんと花子さんとが顔を挙げてそちらを見ますと、それは恐ろしい、真黒い、骸骨のような木乃伊でした。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "木乃伊は赤と青の美しい着物を引きずって、恐ろしさにふるえている姉さんと花子さんの傍へしずしずと近寄りながら、白い歯を出してニッコリ笑いました。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、花子さんが私の生まれ代りの羽子のムクロジにあたたかい息を何べんもはきかけて下さいましたので、二千年も昔に生き返る事が出来たのです。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その御礼に今日は国中の者を集めて御馳走をします」　やがて三人は眼もまばゆい大広間に来ると、王様を真中に、姉さんは右に、花子さんは左に腰をかけました。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッと思って気がつきますと、夜が明けて、花子さんは矢張り寝床の中にいて、羽子と羽子板をしっかりと抱いているのでした。",
              "citation": {
                "source": "黒い頭",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんのところへそろそろ行かずばなるまい」　北山薪炭はそう言って、山の炭焼小屋の中で、背のびをしました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「汽缶車さん、ひとつおいらをのっけて、花子さんの町までいってくれないか」　北山薪炭が、そう言いました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山薪炭はそばへよっていって、「こんちは、君ひとつ花子さんの町までいって貰えないかね。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんはおいらを毎日待っていらっしゃるんだ」　と言いますと、いままで昼寝をしていた汽缶車は眼をさまして、大儀そうに言うのでした。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "花子さんが待ってるから」「うるせえな、昼寝をしている方がよっぽど楽だからな」　そう言って、ぐうぐう眠ってしまいました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしてはやく花子さんのところへ薪炭をおくりたいという一心です。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐに花子さんの所へつきました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、花子さん来ましたよ」「はやく来られたわね」　そこで、花子さんも、おばあさんも、冬の用意が出来ました。",
              "citation": {
                "source": "玩具の汽缶車",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
