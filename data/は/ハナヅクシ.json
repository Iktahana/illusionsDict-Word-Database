        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この百人一首の歌集は、花づくしで春の情景が目に浮かぶようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女が描いた絵は、四季折々の花を題材にした花づくしだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日のメニューは花づくしで、見た目も華やかですね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "花の枕、花の褥、花づくしの閨のぐるりに花の幕無きは口惜しからずや。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "multi-flowered design",
        "register": "standard",
        "nuance": null,
