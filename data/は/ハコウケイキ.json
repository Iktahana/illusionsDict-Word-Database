          "standard": [
            {
              "text": "現在の日本経済は、業種によって好不調の差が大きい跛行景気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "跛行景気が続くと、格差がさらに拡大する恐れがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は跛行景気からの脱却を目指し、経済対策を検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "商業に従う者で〇％二増大していること、恐らく恩給や利潤による生活者であろう無業が二％六減を示していること等は、或る意味で跛行景気を反映し、更に雄弁に昨今の物価騰貴が、無職生活者を脅している有様があらわれているのである。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
