        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ファゼーロがいまごろ山羊なんぞ連れてあるく筈ないんだから。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄りが知らん筈ない。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはある筈ないよ。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私知ってるわよ、それなら」「知ってる筈ないじゃないか、昨日横浜から来たばっかりだってのに」「違うわ、読んだのよ、ほら、今度の代り目っから専門家の歌をきかせるって大きく予告してあったじゃあないの」　母親は余り身にしめず、「そうだっけか」と答えた。",
              "citation": {
                "source": "部屋",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある筈ないんだけど、と、愛が行って机の引出しをあけて見たら、計らず其がとりあげられて居た。",
              "citation": {
                "source": "斯ういう気持",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんパリにいる筈ないや。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに温いの、死んでる筈ないじゃありませんか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな男のひとと一緒になってみても同じ事だろうと私が云うと、「そんな筈ないわ、石鹸だって、十銭のと五十銭のじゃ随分品が違ってよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな男と一緒になっても同じ事だと私が云うと、「そんな筈ないわ、石鹸だって、拾銭のと五拾銭のじゃ、随分品が違ってよ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫迦々々しすぎるから大人に分る筈ないわ。",
              "citation": {
                "source": "木々の精、谷の精",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "売ったことはなかったろうね」「売る筈ないわ」「僕の留守に人に貸しはしなかった？",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうねえ、雑誌や小説だったら御近所へかしてあげたかも知れないけど、こんな大きな堅い本、貸す筈ないわね」「盗まれたことは？",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイタイ先生ならそんなふうに仰有る筈ないから、行つてお話うかゞつてちやうだいなんて、ほんとに先生、あさましい作家におなりですことねえ」「アッハッハ」「なんですか、あなた。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう間違つてもあんな化け猫になる筈ないから安心ですもの。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヂミ屋の寮を捜したって出てくる筈ないわ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍備や戦争をすてたって、にわかに一等国にも、二等国にも、三等国にも立身する筈はないけれども、軍備や戦争をすてない国は永久に一等国にも二等国にもなる筈ないさ。",
              "citation": {
                "source": "もう軍備はいらない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "従業員ですから」「ところが居ませんよ」「そんな筈ないわ。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "より江　　そんな筈ないつておつしやるんでせう。",
              "citation": {
                "source": "温室の前",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "令嬢は鳩が豆鉄砲くらったように目をパチパチさせたが、百合子をやさしく睨んで、「たとえ本当にそうだとしても、そうですなんて、誰だって言う筈ないわよ。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボクは今日にも自殺するほかには手がなくなったんだ」「アラ、そんなこと、ある筈ないじゃないの」「キミには、わからないことさ。",
              "citation": {
                "source": "行雲流水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "気違ひ共に服装の云々はある筈ない。",
              "citation": {
                "source": "競馬興行と競馬狂の話",
                "author": "初代　桂小南",
                "note": "青空文庫"
              }
            },
            {
              "text": "更子　　わからない筈ないわ。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "又蔵　　をかしいなあ、そんな筈ないがなあ。",
              "citation": {
                "source": "取引にあらず",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の財産がどれくらゐだつてことは、ご承知ない筈ないんですもの……。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "トランプがはじまつてね」「細君のゐる男をそんなに引留める筈ないわ」　彼女は突つ撥ねるやうに云つた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなわけが、ある筈ないぢやありませんか」「ところが、あるの。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕もお願ひするから、一度専門家に調べて貰ひませうよ」「斎木さんにもそのことをお話しましたらね、あの幾島さんに水源のことなんぞわかる筈ないつて、笑つておいででしたよ」「笑ふのは勝手だけれども、自分でなんにもしないのはなほいけないさ。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に俺が売ったべか」　伸子は、心が平らな時には、はははと思わず笑って、「私にわかろう筈ないじゃあないの。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「だってそんな事ある筈ないと思うんですけれど、まあ、あなたって方、女でもないみたいに、ちっとも羞かしがらないで、何でもふつうの事のようにおっしゃるわね、強く抱いたら潰れてしまうなんて、」「潰れてしまうわ、あたい、ちいちゃいんですもの。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたい、これ以上愉しいことある筈ないと、何時もそう思っていたんですもの。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
