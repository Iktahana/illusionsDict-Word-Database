    "definitions": [
      {
        "index": 1,
        "gloss": "skin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其処へやつて来た此の鉄色がかつた栗色の肌の牧野信一は、部屋に這入るなり進みもしないで坐つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか瓜の肌でも見るやうだ。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その教会は板で囲つてあり、六百坪位の庭園を有し、フランス人のからだの大きい、学者肌の神父がゐて、その神父は大きい望遠鏡を持つてゐて、甞て夏の静かな夕べ、その庭に立つて空の星を見せて呉れた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "チツポケな虚栄心を持つてるに過ぎない奴等が、いつかどのきほひ肌や、伝法肌のつもりになつて得々としてるのだ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女等はきほひ肌でも伝法肌でもない！",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川君の如くインテリ型の秀才肌で、文明人の纖細な神經から、社交的の禮節にのみ氣を疲らして居た人にとつて、室生君の自然兒的な野性や素朴性やは、たしかに痛快な驚異であり、英雄的にさへ見えたのだらう。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹の顔は肌理も毛穴も全然ないてかてかに磨きあげられた乳白色の能面の感じであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家肌のひとで、多少、政黨にも關係があつたやうである。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "共に冬の日の薄ら日和を感じさせ、人生への肌寒い侘びを思わせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「侘び」の心境するものは、悲哀や寂寥を体感しながら、実はまたその生活を懐かしく、肌身に抱いて沁々と愛撫している心境である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大泥醉の粹背肌、弓手を拳で懷中に蓄へ、右手を延ばして輪を畫くと、手頸をぐいと上げて少し反身のかたち。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯然と二の腕を捲ると、生白い肌が現出れて酒氣を帶びた頬が薄赤い。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "足袋裸足で痛痛しい、胸が開張けて、雪の肌が白百合の匂ひ、島田の根が外れて忙しい呼吸である。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてじめじめする肌の汚れも洗って清浄な心になりたくなるので、手拭をさげて主婦の処へ傘と下駄を出してもらいに行く。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空よく晴れて朝風やゝ肌寒く露の小萩のみだれを吹いて葉鶏頭の色鮮やかに穂先おおかた黄ばみたる田面を見渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を拍ちて床をのべさせ横になれば新しき浴衣の肌さわりも快く、隣室の話声遠きように聞えし後は魂いずこへか飛んで藻ぬけの殻となり電燈消しに来し事もいつか知らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな訳だから、学校でも軍人希望の者などとはどうしても肌が合わぬ、そう云う連中から弱虫党と目指されて、行軍や演習の時など、ずいぶん意地悪くいじめられたものだ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広間の四方の障子はスツカリ取り払はれ、大洋を拭ふて来る海風は無数の蝋燭の焔をユラユラさせながら気持ちよく皆の肌に入つて行くのであつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腫物が、なほるばかりでなく、肌がなめらかになり色が白くなるかも知れない、と家の者に冗談を言ひ、靜かに横臥し、藥のききめを待つてゐました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄布をとほして眞白い肌が見える。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "埴輪のやうな、テラコツタの肌をしてゐるのであります。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、幹には苔が蒸して、皮は土より柔く、ぼろぼろに腐っているから、生あるものの肌のようで、ぬらりと滑り、ぐちゃりと触れて、いやな気持がする。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "根曲り竹も、楊の根も、樅の肌も、はた長くしな垂れるサルオガセも、その柔嫩の手に、一旦は、撫でられぬものはない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "我ら一行の手は、初めてこの秘められたる、白い肌に触れたのである。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に喬木の森林に入った、白く光る朽木は、悪草の臭いや、饐えたような地衣の匂いの中に立ち腐れになっている、うっかり手が触れると、海鼠の肌のような滑らかで、悚然とさせる、毒蚋が、人々の肩から上を、空気のように離れずにめぐっている、誰も螫されない人はない、大樺池を直ぐ眼の下に見て、ひた下りに下る。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜など、燭を秉って、湯殿へ通うと、空には露が一杯で、十一月頃の冷たさが、ひしひしと肌に迫る、そうして凸凹のないところは、ないくらいな山の中にも、梓川が、静かな平坦な大道路となって、森の中を幅びろくのしている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑波山の紫は、花崗石の肌の色に負うことが多いが、富士山の冬の紫は、雪の変幻から生ずる色といっても大過はあるまい。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は冷気のために雪が岩石の膚肌に凝結し、昼はそばから蒸発して行くので、冷熱の変化から岩石を破壊し、山体を陶器の破片のように滅茶滅茶にして散乱させる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "通路を距てて直ぐの向ひ側には、鉄道従業員の妻君みたいなのが、胸をはだけて赤坊に乳を飲ませてゐる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ積めるに決つてゐると、腹の立つてゐる矢先ではあり「えゝこなひだ府の何とか課長さんの引越が一台で出来たといふ新聞の記事を見ましたよ」と、僕は二人の間に立ちはだかるやうに云つたのだつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
