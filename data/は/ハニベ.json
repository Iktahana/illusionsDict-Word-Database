    "definitions": [
      {
        "index": 1,
        "gloss": "vessel made of clay",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
