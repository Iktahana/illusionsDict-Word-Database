        "examples": {
          "standard": [
            {
              "text": "そのニュースは、まず半官報にひっそりと掲載された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府の見解が半官報を通じて非公式に示唆されることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史家はその時代の半官報を分析し、当時の社会情勢を読み解いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "半官報にある事は、半官報に據る。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ何しろニュースは殆んど軍自身の発言以外には認められないような状態にあるのだから（同盟通信ニュース）、スクープをつかむことの出来ないなどは云うまでもないし、云わばニュースの後続部隊としてノコノコと半官報の後をこね回してあるく他ない。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
