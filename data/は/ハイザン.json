[
  {
    "uuid": "6c3b0695-94e1-5d01-b939-f0b03d00e3f3",
    "entry": "敗残",
    "reading": {
      "primary": "はいざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "survival after defeat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私が山王山を知つてから、いづれも生活の敗残者であらう、この森の中で、首縊りが二人ばかりあつた、人目を避けるに、都合がいゝとは言ひながら、不思議なことに、死ぬ人は原始的に安息な自然を選ぶ、川や海に身を投げる人と森の中で縊る人と。",
              "citation": {
                "source": "亡びゆく森",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一言注意して置く、此の辺り一帯は尚敗残兵が徘徊している。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓は、各国の帝国主義に尻押しをされて、絶えまなく小競合を繰りかえす軍閥の苛斂誅求と、土匪や、敗残兵の掠奪に、いくら耕しても、いくら家畜をみずかっても、自分の所得となるものは、何一ツなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ少数な江戸っ子の敗残者がわざわざ竹仙の染め物や伊勢由のはき物を求めることにはかない誇りを感ずるだけであろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は精神上肉体上の敗残者なのだ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の気の毒な敗残者みたいな感じの先生さえ居るようだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは、敗残者の来るところではないかと思った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生の敗残者なんて感じはない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会的には、もう最初から私は敗残しているのである。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの片腕のアラビア人は赤痢のためにおとろへつくした、敗残のからだを引きずつて、とう／＼アデンの町までたどり着きました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三　独・英・米三国に対する敗残の一マターファでは、帰趨は余りに明かであった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "望月甚八郎、山県討死の処に乗入れて敗残の兵を引上げしめようとしたが、弾丸一度に九つも中り、脚と内冑を撃たれて果てた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はただ一人の旧世界の敗残者として新世界のただ中にほうりだされたような気がしたのである。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それは結局彼｜一人を救うことすら至難であり不可能であることがあらゆる努力を尽くして後、彼を敗残の身にしたことによってわかったのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、帰って来れば、不具者か敗残の病躯か、多くは屍になって帰って来るのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど顧みれば、吾れ敗残の生、枯槁の躯、一脚歩を屋外に移す能はざるの境に在りて、能く何をか為さむ。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の哀れな敗残の跡を物語る畑も、勝ちほこった自然の領土である森林も等しなみに雪の下に埋れて行った。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び上京したらと元気を附けてやった事もあったが、盛返す勇気もなくて悶々数年の後、終に大正四年の初冬に別府の同情深い友の家で淋しい敗残者の生涯を終った。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の美妙の返事は敗残者の卑下した文体で、勝誇った寵児のプライドに充ちた昔の面影は微塵も見られないで惻隠に堪えられなかった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の随所には敗残した、時代の遺骸の側に青い瓦斯の火が点り、強い色彩と三味線とに衰弱した神経が鉄橋と西洋料理との陰影に僅かに休息を求めてゐる。",
              "citation": {
                "source": "新橋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "志操堅固な杜だったけれど、どういうものかその夜の尿の音を思いだすごとに、彼はどうにも仕方のない興奮状態に陥ってしまい、その後もその度に、彼は哀れな敗残者となることを繰りかえした。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、旅順の大戦に足を折られ手を砕かれ、両眼また明を失つた敗残の軍人の、輝く金鵄勲章を胸に飾つて乳母車で通るのを見た時と、同じ意味に於ての痛切なる敬意が、また此時自分の心頭に雲の如く湧いた。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、作品の到るところに散在する敗残の美の描写も、一方にきわめて常識的な通念が人生における敗残の姿としている。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなりの形、動き、色調を、荷風もそのまま敗残の内容として自身の芸術の上に認めている。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗残者としてさん／″＼やつつけられる夢を見た、それはまつたく私自身の醜態だつた、私自身しか知らない、私自身にしか解らない私の正体だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕の様に精神的に敗残した人間は、已を得ず、あゝ云ふ消極な意見も出すが。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは、淫売婦や貧しい大学生、人生での敗残者などがごたごた棲んでいるカザンの貧民窟の一隅に、急進的な一人の学生と暮した。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "通行の群集はまるで世界中の敗残者から成り立っている。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
