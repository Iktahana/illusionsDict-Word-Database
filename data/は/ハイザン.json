    },
    "definitions": [
      {
        "index": 1,
        "gloss": "abandoned mine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから一時廃山となつたが、慶長、元和に至つて再興し、寛永年間に至つて繁昌を極めた。",
              "citation": {
                "source": "支流",
                "author": "齋藤茂吉",
