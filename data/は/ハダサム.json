[
  {
    "uuid": "4f8f0ae0-92de-5d72-a7cf-71f16a5e32dc",
    "entry": "肌寒",
    "reading": {
      "primary": "はださむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
