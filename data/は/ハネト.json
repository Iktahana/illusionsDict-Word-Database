        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しゅっこはよろこんで、いよいよ水をはねとばした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、物をはねとばさぬばかりのひどい見幕でやって来る憲兵を見ると、自分が罪人になったような動揺を感ぜずにはいられなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし豚は棒を持った男が近づいて来ると、それまでおとなしくしていたやつまでが、急に頭を無器用に振ってはねとびだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎の二人の妹は、中津が帰ると、チンバ、チンバと、おかしそうに笑いながら、家の中をぴん／＼はねとんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チンバがやって来ると、おかしがって、家の中をはねとんでいたすゞが、門の外から王を呼ぶ中津の巾のある押しつけるような声に、耳の根まで真紅に染め、どこかへ逃げかくれだした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石はカチンと松の幹にぶつかって、反射してほかへはねとんだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すばしっこい火箸のような、痩せッこつの七五郎が、板の橋を渡って公会堂に様子をさぐりに、ぴょん／＼はねとんで行った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けん坊は、はねとばされた子ねこのような顔をして、ふたりを見送っていました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎はよろこんで、いよいよ水をはねとばしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄かに舟がぐらぐらゆれ、何でも恐ろしくむかし風の竜が出てきて、わたくしははねとばされて岩に投げつけられたと思って眼をさましました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うめばちそうはまるで花びらも萼もはねとばすばかり高く鋭く叫びました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度爆発すれば、たぶん山は三分の一、北側をはねとばして、牛やテーブルぐらいの岩は熱い灰やガスといっしょに、どしどしサンムトリ市におちてくる。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その調子をはねとばす様に豹一は勝手なお世話です。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、なにかが、はねとびました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けん坊ははねとばされた仔猫のやうな顔をして二人を見送つてゐました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんも、ねまきのそででこっそり眼のふちをふきました、そして文六ちゃんがはねとばした、小さい枕を拾って、あたまの下にあてがってやりました。",
              "citation": {
                "source": "狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはずみに一本足の兵たいは、いきなりぽんとはねとばされて、その三階の窓から、下の往来の石だたみの上へ、まつさかさまに落ちました。",
              "citation": {
                "source": "一本足の兵隊",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会活動の渦からはねとばされ、もしくははねとばされんとしつつ、なにもかも思うようにできないで、失意に嘆いてる人などに、ひとりだって同情するものはない。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして続けさまに、続けさまに速射砲のやうに、ちやつぷりんが尻餅をついたといつては笑ひ、電車にはねとばされたといつては笑ひ、その度毎に彼女は水島に接吻の雨を降らした、喜劇は短かつた次には長い／＼悲劇物が映写された。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、どらねこ退治に参ってな」　しかし、右門は相手にもせずに、にやにやとうち笑みながら、伝六からくだんの長槍をうけとると、さッと石突きをふるって毛鞘をはねとばしたと見えたが、えい！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いましはねといふ所にきぬ。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかき童この所の名を聞きて「はねといふ所は鳥の羽のやうにやある」といふ。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "このはねといふ所問ふ童の序にて（ぞイ）、又昔の人を思ひ出でゝいづれの時にか忘るゝ。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹の根ツこをくべてある爐の火が、節の處に行つたせゐか、パチ／＼となつて、火が爐の外へはねとんだ。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に彼ははねとばされるように椅子から突ったちガラス棚の蒲鉾のほうへいきなり両手をさしのべ、「そいつだ。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
