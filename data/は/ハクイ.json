    "definitions": [
      {
        "index": 1,
        "gloss": "white clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西日が窓越しに看護婦の白衣と車の上のニッケルに直射する。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じ白衣着けたる連れの男は顔長く頬髯見事なれど歩み方の変なるは義足なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和大峰いりのほら貝は聞えないが、町から野、野から山へと、秋草をわたり、落葉松の枯木をからんで、涼しくなる鈴の音は、往さ来さの白衣の菅笠や金剛杖に伴って、いかに富士登山を、絵巻物に仕立てることであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉一枚動かない沈鬱なる空の下に、案じたほどのこともなく向う岸へ渡り、崖の上へ立って振り返ってみると、白衣の道者の一連が来て、大沢の手前でうずくまり、先達がお祈りを上げている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また白衣の道者の一群に、森の出口でゆき遇う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "灰青色した緻密の熔岩と砂礫と互層をしているところを、筋違いに岩脈がほとばしって、白衣の道者たちが大沢で祈ったのと同じように、この岩脈を十二薬師の体現と信じて、崇拝するという話である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "救護隊の屯所なども出来て白衣の天使や警官が往来し何となく物々しい気分が漂っていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして球技場の眩しい日照の下に、人知れず悩む思いを秘めた白衣のヒロインの姿が描出されるのである。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白衣の女はいかに、また青衣の女はいかに。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はなんだか自分の白衣が羞かしくなつた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの白衣はわたくしにすつかりあなたの權利をお預けになつてゐるのに……」　………………………………………「あなたはあの毛の粗い服を戀しがつていらつしやるの？",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は腕のなかに、氣を失つた白衣の夫人のやうに、旗をかかへてゐた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あゝあの時の、死顔が、まざ／＼と、いま我が膝へ……　白衣幽に、撫子と小菊の、藤紫地の裾模様の小袖を、亡体に掛けた、其のまゝの、……此の友染よ。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　世界の屋根　この映画で自分のもっとも美しいと思った場面はおおぜいの白衣の回教徒がラマダンの断食月に寺院の広場に集まって礼拝する光景である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「白衣の騎士」などもやはり同じ定型に属するものと見ることができはしないかと思う。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かの白衣の妻が答えた。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の間に白帽白衣の警官が立ち交って、戒め顔に佩劔を撫で廻して居る。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して倒さに着せられた白衣の下に、小さく平べつたく、仰臥さしてある妻の死骸を眺めて默然としてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無造作に死體を被つた白衣の上には小さな黒い汚點のやうに蠅が三四匹とまつてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れはせき込む感情を、強い事實で拂ひのけるために死體から白衣を剥いで取つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るくなって見ると、二列の僧座の一方は黒衣の男僧であって、一方は白衣の尼僧であるのが分る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また白衣を身に着けねばならぬ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――（やや驚きつつ）……何故に髪を切り、白衣を着ねばなりませぬか……。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　白衣のが一番上に、水色のその肩が、水紅色のより少し高く、一段下に二人並んで、指を組んだり、裳を投げたり、胸を軽くそらしたり、時々楽しそうに笑ったり、話声は聞えなかったが、さものんきらしく、おもしろそうに遊んでいる。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時緑青色のその切立ての巌の、渚で見たとは趣がまた違って、亀の背にでも乗りそうな、中ごろへ、早｜薄靄が掛った上から、白衣のが桃色の、水色のが白の手巾を、二人で、小さく振ったのを、自分は胴の間に、半ば袖をついて、倒れたようになりながら、帽子の裡から仰いで見た。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆の白きより白衣の婦人、水紅色なるがまた一人、続いて前後に船を離れて、左右に分れて身軽に寄った。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "波を渡るか、宙を行くか、白き鵞鳥の片翼、朝風に傾く帆かげや、白衣、水紅色、水浅葱、ちらちらと波に漏れて、夫人と廉平が彳める、岩山の根の巌に近く、忘るるばかりに漕ぐ蒼空。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と一口がぶりと遣って、悵然として仰反るばかりに星を仰ぎ、頭髪を、ふらりと掉って、ぶらぶらと地へ吐き、立直ると胸を張って、これも白衣の上衣兜から、綺麗な手巾を出して、口のまわりを拭いて、ト恍惚とする。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがた白衣の鮮女が、道を掃いた小店の奧に、暗く目を光らして居た、鐵あみを絞つたやうに、皺の數を面に刻んで、白髮を逆に亂しつゝ、淺葱の筒袖に黒い袴はいた媼である。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那の手を、美少年の方から迎へるやうに、じつと握る、と其の手の尖から雪と成つて、再び白衣の美女と變つた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
