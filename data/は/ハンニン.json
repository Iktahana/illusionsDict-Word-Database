[
  {
    "uuid": "64d04239-cfa6-58cb-ac69-0de21f46674f",
    "entry": "犯人",
    "reading": {
      "primary": "はんにん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "offender",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "犯人は未だ縛につかない、か。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年団や、消防組が、山を遠巻きにして、犯人を狩り出していた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "このダンサーは後に昔の情夫に殺されるための役割でこの喜劇に招集されたもので、それが殺されるのはその殺人罪の犯人の嫌疑をこの靴磨きの年とった方、すなわち浅岡了介に背負わせるという目的のために殺されなければならないことになっている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、この真犯人の姿と顔とを誰かにこの現場近くではっきり見届けさせておかないとあとで困る。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて来てみるとダンサーの室の前で変な男すなわち真犯人が取乱した風で手を洗っている。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面台に犯人の遺した腕時計が光っていて、それが折から金につまった小娘を誘惑する。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは真犯人の旧騎士吉田を今の新聞記者吉田に仕立ててそれをこの法廷の記者席の一隅に、しかも見物人にちょうどその目標となるべき左の顋下の大きな痣を向けるように坐らせておく必要があるのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刊売りが問題の夜更けに問題のアパート階上の洗面場で怪しい男の手を洗っているのを見たという証言のあたりから、記者席の真犯人に観客の注意が当然集注されるから、従ってその時に真犯人は真に真犯人であるらしい挙動をして観客に見せなければならないこと勿論である。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、特に目につくような赤軸の鉛筆で記事のノートを取るような風をしながら、その鉛筆の不規則な顫動によって彼の代表している犯人の内心の動乱の表識たるべき手指のわななきを見せるというような細かい技巧が要求される。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に、よほどのぼんやりでない限りのすべての観客のおのおのの大きくみはった二つの眼が一斉にこの不幸な犯人の左の顋下の大きな痣に注がれるのはもとより予定の通りである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしかしこういう場合における実際の犯人の心理を表現したものであるかどうか少し疑わしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "干からびた犯罪どこから犯人は逃走した？",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、犯人の武装を解除して見よう。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人は英国の大銀行団と、その背後のフイナンシャーであった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "資本主義戦争の尖端を行くもの、これも、犯人は英国であった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやり方がうまいんで、どうしても犯人の手掛がつかない、係長初め何人かの仲間、警察の人達までが一生懸命に奔走し始める。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "變なもので、その手掛から犯人があがつた時には得意とか安心とか云ふよりも、寧ろ何となく胸を抑へられぬやうな厭やな氣持がするもんです。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "從つてあんまり露骨に奇々怪々だつたり、ふんだんに血潮やピストルが飛び出したり、厭やに眼まぐるしく探偵や犯人の隱現出沒する探偵小説はほんとの面白味には乏しい。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、云ふ處の犯罪や祕密や不思議が犯人の科學知識の深さの中に複雜にされると同時に、探偵もそれに敵對出來るやうな科學的素養を以てすると云つたやうなのが、私達には面白いのである。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿密に嚴重に調べてみたが、犯人が外から室に入りこんだ樣子もなく、他殺の形跡は全然ない。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不思議な事件の犯人は何者だらう？",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人をせんさくし出さなければ、役目がつとまらなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
