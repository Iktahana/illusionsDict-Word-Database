        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "饗応の法則は越えないようにして、ことに手厚く演者はねぎらわれたのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "真木柱",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちからはねぎ、にんじん、馬鈴薯、かぶを少し分ける。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この中で欠くことのできないのはねぎだ。",
              "citation": {
                "source": "美味い豆腐の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはねぎをこの中へ干しておいた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度｜拘引された留置場にはねぎが転がしてはなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遠路、おつかれであろう」　孫権はねぎらう。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
