    "definitions": [
      {
        "index": 1,
        "gloss": "roundworm (Ascaris lumbricoides)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これらの沢山の不愉快な顔が醸す一種の雰囲気は強い伝染性を持っていて、外から乗り込んで来る人の心に、すぐさま暗い影を投げないではおかない、そして多くの人の腹の虫の居所を変えさせようとする傾向がある。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術の技巧に関する伝統が尊重された時代には、芸術の批評権といったようなものは主に芸術家自身か、さもなくば博学な美術考証家の手に保存されて、吾々素人は何か云いたくなる腹の虫を叱り付けていなければならなかった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「先生はそれでよいかも　しれませんが　此の五郎蔵の腹の虫　が収まらぬ」　と本気になって怒り出した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、何故か、彼は、腹の虫がおさまらなかった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その時の私の腹の虫の居所がよほど悪かったと見えて、どうもそういうあっさりした気になれなかった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが目明根性と言うものか、話の筋がつづまらぬと、腹の虫が承知せんわい」「うむうむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ごたえのある処にいって暴れてみないじゃ腹の虫が承知しないからな。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドモ又の命が買いもどせるくらいの罰金を出させなけりゃ、俺たちの腹の虫は納まらないや。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、一たび、「何か人をあっといわせるようなことをしてみたい」　と、思うと、もう腹の虫がむずむずして来て、いても立ってもおられなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて言えば、雪子を警官の手から奪うという、大それた暴挙が「何か人をあっといわせるような破天荒なことを今直ぐしてみなくっちゃ、おれの気が済まない……」　という、たった今さき腹の虫を動かせて来た不意の思いつきに、ピッタリ合っているではないかと咄嗟に自分に云いきかせる余裕だけは、さすがに残っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門はそれで宜いが、良兼等は其儘指を啣へて終ふ訳には、これも阪東武者の腹の虫が承知しない。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の虫が泣くんじゃねえ、金子の音だ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏になると、しきりに比律賓への郷愁にかり立てられる他吉の腹の虫を、お鶴は見抜いていたのだろうか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "比律賓へ行くのはもうすこしの辛抱だと、じっと腹の虫を圧えている内、新太郎の家の隣りから火が出て、開業早々丸焼けになった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "オイチョカブの北田は何をっと一時は腹の虫があばれたが、しかし彼も今は土地での気受けもよく、それに小鈴のお産も遠いことではなかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は肝をつぶし、そしてカッとなりましたが、その腹の虫を押えるために飲んだ酒と花代で、私が白浜から持ってきた金はほとんどなくなってしまい、ふらふらと桔梗屋を出たのは、あくる日の黄昏前だった。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでまだ夕飯を食わずにいるのでは、四谷で西洋菓子を二つぐらい食ったのでは腹の虫が承知しまいと察せられました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一私あ飲む気はねえが、腹の虫が承知しねえや。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の虫は承知をしても、やっぱり私あ飲みてえや。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鄙吝でもあったろうが、鄙吝よりは下女風情に甘く嘗められてはという難かし屋の理窟屋の腹の虫が承知しないのだ。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉公人にさえ勘弁出来ないで、些細な不行届にすら請人を呼び付けてキュウキュウ談じつけなければ腹の虫が慰なかったのだから、肝癖の殿様の御機嫌を取るツモリでいるものでなければ誰とでも衝突した。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから馬場を通り抜け、九段を下りて神保町をブラブラし、時刻は最う八時を過ぎて腹の虫がグウグウ鳴って来たが、なかなかそこらの牛肉屋へ入ろうといわない。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは腹の虫がいえるまでいいますよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は御前があ奴の身の上を御承知の上で、尻押しなさったのじゃろうと邪推致しましたゆえ、ついカッとなりまして、あの翌る日職を奪われました時から、こうしてお出ましの折をつけ狙っていたのでござりまするが、そうと分らば手前の腹の虫も大分｜癒えてござります。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は御前があ奴の身の上を御承知の上で、尻押しなさったのじゃろうと邪推致しましたゆえ、ついカッとなりまして、あの翌る日職を奪われました時から、こうしてお出ましの折をつけ狙っていたのでござりまするが、そうと分らば手前の腹の虫も大分癒えてござります。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、あっしのほうには――待ちなってことよ、江戸っ子にも似合わねえ意地のきたねえ腹の虫だな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこでようやく地主は、はらのむしがおさまりました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
