        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "般若湯を少しばかり、幸ひ腥を口にせぬ場合で、思出すに丁ど可い。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は二合入の空瓶を拾うて戻つた、行乞途上、般若湯を詰めて持つてあるく用意として。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……待つてゐた敬坊がやつてきてくれた、間もなく樹明君もきてくれた、お土産の般若湯がうまいことうまいこと。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の般若湯の残りがあろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "切れる様な水で顔を洗ひ、囲炉裡にどんどと焚いて、お茶代りの般若湯を嘗めてゐると、やがて味噌汁が出来、飯が出た。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「てかてか顔のほてっているところを見ると、またひのき稲荷へ回って、般若湯でも用いてきたな」「冗、冗談じゃございませんよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の用じゃ」「えッへへへへ、どうもね、この通り般若湯ですっかり骨までも軟かくなったんで、うれしまぎれに御殿様の御容子を拝見に参ったんでござんす。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからお坊さんの間ではお酒の事を「般若湯」といいます。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠足の小学生がうれしさうにおべんたうを持つてゆく、私の頭陀袋にも一郎君から貰つた般若湯が一壜ある。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵主は般若湯が好き、いつも赤い顔して赤字で苦しんでゐる、山頭火よ、と自から嘲り自から慰める。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時のサイレンを聞いてから出かける、ニユースといふのはＫさんの事だつた（彼に幸福あれ）、いつものやうに夕飯をよばれ（無論、般若湯も！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日から塩飯を食べつゞけてゐるので（時々般若湯を飲むけれど）、身清浄心寂静を感じる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主が酒を般若湯というということは世間に流布しているが、鶏を鑽籬菜というということは本を読まないものは知らない。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、般若湯はおことわりにしたのよ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日旅の路すがら、箱根を越して三島の近辺、とある山寺に一宿なし主僧と汲んだ般若湯などが、まず拙者が飲んだ酒の中での第一じゃ」　ところへ、仲居の案内につれてお春が現れ閾際でしとやかに平伏します。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでかういふ問答の結果がどうかと言へば、仲間同志の禅坊主だけ寄り集つて、彼奴は悟りの分らない担板漢だなどと言つて般若湯で気焔をあげてもゐられるけれども、然し、かういふ約束の足場は確固不動のものではないから、内省の魔が忍びこんでくる時には晏如としてはゐられない。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、坊主といふものは宴席で誰よりも幅の利く身分であつて、「てへへん、これは結構な般若湯でげす。",
              "citation": {
                "source": "村のひと騒ぎ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お経のあとでは持ち寄りのご馳走や、般若湯の供養でたのしい一夕をすごす習慣になっている。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日八人の山伏たちは、兵衛から届けられた般若湯を、炉の火であたため汲みかわしながら、山伏言葉で話していた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、これを受け取った寺方では、何もかもそう残らず保存しておいたのでは、早い話がたちまち置き場にも困ることになるから、古いところから順に売り払って、これがお寺の所得になり寒夜の般若湯に化けたり獣肉鍋に早変わりしたりする。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜助　トウたあ、般若湯のトウだ、お薬だい、ははは、さあ飲め。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば酒のことを般若湯といって見たり、甘露水といって見たり香水といったりするのはみな隠し言葉である。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯から上れば、座敷の炉ばたに、精進料理の膳が出て、誰か近付きの坊さんと一座で、般若湯を汲み汲み、談笑のうちに、満ち足りた食事をする。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主が般若湯をのむというのは落語や小咄に馴染のことだが、あれは大概山寺のお経もろくに知らないような生臭坊主で、何代目かの管長候補に目されている高僧は流石に違う。",
              "citation": {
                "source": "勉強記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「般若湯の方は坊さんも飲むからと言って、制限を加えません。",
              "citation": {
                "source": "人生正会員",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて般若湯（酒）もすっかり廻ると、また祭壇へ出て宵のお経。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
