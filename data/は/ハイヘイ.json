        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帰り路に虎渓橋の上でカーキ色の軍服を着た廃兵に逢った。",
              "citation": {
                "source": "秋の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰って来ても、廃兵とか、厄介者とか云われるのやろう。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、空想の驢馬から転落して重傷を負ひ、おそらく消極的な喪心の廃兵だつた。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "保険屋８・22（夕）　今の世に廃兵と生命保険の勧誘員ほど蒼蠅い者は、たんと有るまい。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かかる官府の豹変は平安盛時への復帰とも解釈されるし、また政府の思想的一角が今日、俄かに欧化した」とも云い得るかのようであるが、実際には帝国芸術院が出来ると一緒に忽ち養老院、廃兵院という下馬評が常識のために根をすえてしまった。",
              "citation": {
                "source": "矛盾の一形態としての諸文化組織",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの住人であった一人の廃兵と労働者とが憲兵に引っぱられた。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの住人であった一人の廃兵と労働者とが憲兵に引っぱって行かれた。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これら三つの戦争は、そのときどきの英雄大将を生みつつ一方では日本の街頭に廃兵の薬売りの姿を現出し、一将功なって万骨枯る、の思いを与えた。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはその研究に廃兵院の森で夜明かしをしたことがごぜいますが、人の足音がしますと、いったん向うの声が途切れます。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　廃兵院で鶴の啼く声が澄みわたってよく聞える午前の一時近くになって、皆が席を立った。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて廃兵院の森を過ぎると、二三間で自分の長屋横丁の入り口なので、「この奥がわたくしの住居ですから、むさいところですけれども、もしお通りすがりにはお立ち寄りを願います」と言って、彼は皆に別れを告げた。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃兵院は森道があまりに暗いので、電車通りから曲ってくる通行人のため、かねては自分の広告のために、自分の名を書き入れた瓦斯灯を立てさせてくれるように願いでてある。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この法外にだらだらと長い奇妙なお城は、どこか老耄れの廃兵といった恰好をしている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が今日の新聞を見ると生活に窮した廃兵たちは、「隊長殿にだまされた閣下連の踏台」とか、「後顧するなと大うそつかれ」とか、種種のポスタアをぶら下げながら、東京街頭を歩いたさうである。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃兵そのものを抹殺する事は、官憲の力にも覚束ないらしい。",
              "citation": {
                "source": "澄江堂雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "国内には廃兵が充満した。",
              "citation": {
                "source": "ナポレオンと田虫",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の小使いは廃兵であった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤトラカン・サミ博士の椅子は、あの、欧州戦争に参加した国々の公園などで、時おり、足の悪い、あるいは全然脚のない廃兵が、嬉々として乗りまわしているのを見かけることのある、一種の locomotive chair だった。",
              "citation": {
                "source": "ヤトラカン・サミ博士の椅子",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日の寂しさ門に立つのはうその苦学生、うその廃兵、うその主義者、志士、馬車、自動車に乗るのはうその紳士、大臣、うその貴婦人、レディイ、それから、新聞を見ればうその裁判、うその結婚、さうして、うその教育。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃兵ではなく、廃人なんです。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは廃兵院なのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもの民衆に対する関係が、あり来たりの慈善の性質、つまり育児院だとか廃兵院だとかに見られるような性質を帯びているあいだは、私たちは狡く立ち廻ったりごまかしたり、自己欺瞞をやったりして済ましているだけの話です。",
              "citation": {
                "source": "妻",
                "author": "ЖЕНА",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの遺骸も、それから間もなくフランスへ帰ったものと見てよいから巴里の旧廃兵院の大円蓋の下、血紅色の埃及大理石の墓塋におさめられているナポレオンの心臓は、セント・ヘレナで死んだ似非ナポレオンのそれではなく、一八三〇年に加奈陀で死んだ真正ナポレオンのそれなのであろう。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃兵院の緑青色の円屋根の上に洩れ陽がさしかけ、エッフェル塔のてっぺんで三色旗がヒラヒラと翻っている。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃兵院の広地の奥、その濠や高い壁の後ろ、厳粛な寂寞さの中には、遠い昔の戦勝の交響曲のように、薄黒い金色の円屋根が浮き出していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは、廃兵院の円屋根を頭にいただき、大堂宇の無数の腕で空を抱いてるルーヴル美術館を帯にまとい、ナポレオン凱旋門の堂々たる両足を世界に踏み広げてる、一民族であった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私共は、既にかうした青春時代の花やかな、とはいへいくぶん狂気じみた創造の夢を過去に微笑して観ることさへもできる。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "日劇の前もう行列で客止め、紀元節で一帯人の波とはいへいゝ景気。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
