        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水は半ば凍り、泥濘も脛を没する深さで、行けども行けども果てしない枯葦原が続く。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、眞珠や黒耀石を追ひ求めては、果てしない太平洋の眞蒼な潮の上を、眞紅な帆でも掛けて、恐らくは葦の莖の海圖を使用しながら、或ひは、今でも我々の仰ぐオリオン星やシリウス星を頼りに、東へ東へと渡つて行つたに違ひない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは、真珠や黒耀石を追い求めては、果てしない太平洋の真蒼な潮の上を、真紅な帆でも掛けて、恐らくは葦の茎の海図を使用しながら、あるいは、今でも我々の仰ぐオリオン星やシリウス星を頼りに、東へ東へと渡って行ったに違いない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また同じように、外の牧草地から来る羊や牛の群や、果てしない旅に人馬ともに疲れ果てた移民団などが来ていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、今まで自分の病室の前にこんな果てしないやうな廊下のつゞいてる事を知らなかった。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この影のような記憶がぼんやりと語っているところによると、背の高い者たちが、無言のまま私の体を持ち上げて、下の方へ――下の方へ――なおも下の方へと運んでいったので、とうとう私はその果てしない下降ということを考えただけで気持の悪い眩暈に圧倒されてしまったのだ。",
              "citation": {
                "source": "落穴と振子",
                "author": "THE PIT AND THE PENDULUM",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの歯はしゃべるたびにがちがちいうが、これは夜の――果てしない夜の――寒さのためではないのだ。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "一株の樹もまた数果数十果ないし数百果の実を結ぶのであって、その一果からはまた数株ないし数十株の樹が生じ、果と樹は相交互循環して、無量無辺（限りなく果てしない）の発生と産出とを為すのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体この人のどこからああ果てしない糸のあやは流れ出、その綾に私はつつまれているのだろうか。",
              "citation": {
                "source": "曲者",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "道太は九官鳥が一生懸命にお饒舌をつづけているのを聞きながら、ついに果てしない寂しさに浸されてきた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "山頂や谿谷へ降り注ぐ梅雨の響を耳にしながら、雲霧の變貌去來の果てしないのを眺めやりながら、畫伯は一切を忘れて、山氣の身に迫るのを繪絹の上へ展開せしめて居られることであらう。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗碧の色をした果てしない水の廣野、四方から迫るが如く響きを寄せて來る夕方の海を初めて彼が眺めやつた時は、恐れと悲しみと、寂しさと、然かもなほ言ひ難い誘引とを身に感じたのであつた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "「氷島の漁夫」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "抑へんとしても抑へられない、已むに已まれぬ生命の發動、生命の果てしない汾湧によつて、何ものか無限の力の活躍を信ずる外はない。",
              "citation": {
                "source": "生みの力",
                "author": "片上伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹きとばす石もあさまの野分かな　さういふ古人の句さながらに、昔噴き上げられて落ちてきた燒石があちこち草の中に見えてゐるきりの、果てしない裾野がこの村を過ぎる旅びとの足もとまで迫つてきてゐ、見あげると、ついもうそこに火の山の火口がちぎれちぎれに煙を飛ばせてゐる。",
              "citation": {
                "source": "ふるさとびと",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "果てしない大陸の平野は夢のように淡く続いている。",
              "citation": {
                "source": "淡紫裳",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを道綱に持たせてやった後も、しかし私はいつまでも自分の裡に何物に対するともつかない、果てしない不満のようなものが残っているのをどうしようもなかった。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は勢蝶夫婦のよう、こちらが果てしない腐れ縁に悩まされだしたのである。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるのは忘却と、塵と、果てしない暗黒だけだ。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然のままの緑に波うつ果てしない大平原。",
              "citation": {
                "source": "わたくし自身について",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、果てしない、その方を見やって、ただ悲しみのために泣いていました。",
              "citation": {
                "source": "海のかなた",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚職騷ぎなども果てしない人類墮落の現れともみられようが、創造主もかういふ人類には愛想をつかして、いつそこれを全滅して、新たなる世界を造り出さうと思ひついて、前例なき兇器を驅使して、自分で自分を全滅させる道を採つたといふ者があるかも知れない。",
              "citation": {
                "source": "今日は無事",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこでは、行動は、すべて未完成で、幼稚で、所在に主たることを失い、思考作用の空虚と無為は、果てしないものになる。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "行っても行っても一色のみどり、尽きずの森、果てしない草原、与惣次は悲しくなった。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "槍祭夏の夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ひろびろと果てしない支那海は、ただ水と空と連なっているのをみるのみである。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "広々とした海波のかなたには雲一つなく、やがて一輪の明月が果てしない海を照らしたのである。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "（麦畑のうねが蘭の野につらなり、白義国は果てしない。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし帰ったところでその救いは到底得られそうもないのみか、ただ果てしない覚醒の闇になおも身を任しつづけるよりないことは目に見えていた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし帰つた処でその救ひは到底得られ相もないのみか、只果てしない覚醒の闇になほも身を任し続けるよりない事は眼に見えてゐた。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人たちの姿は薄れ、慈悲深くも私は再びかの暗く果てしない空間へと引き戻されていった。",
              "citation": {
                "source": "感覚の殻",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その果てしない運行の全く同一の瞬間に於いて、しかし、其處では、それが全く異つた色を帶んで、青色がゝつた空に一層高く懸つてゐた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
