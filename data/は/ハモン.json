  {
    "uuid": "acf735d8-0dd9-5ab1-a57a-9f68a136294f",
    "entry": "波紋",
    "reading": {
      "primary": "はもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
