        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "変てこなねずみいろのだぶだぶの上着を着て、白い半ずぼんをはいて、それに赤い革の半靴をはいていたのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃古靴を売る事は……長靴は烟突のごとく、すぽんと突立ち、半靴は叱られた体に畏って、ごちゃごちゃと浮世の波に魚の漾う風情がある。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト半靴の先を反らした、母親の白い足が卓子掛と絨氈の間で動いた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半靴を履いてゐる足音はすこしもしなかつた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰りついた玄関の靴脱ぎ石の上には岡の細長い華車な半靴が脱ぎ捨てられていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階へ上がるのだ」　瀬戸は下駄や半靴の乱雑に脱ぎ散らしてある中へ、薩摩下駄を跳ね飛ばして、正面の梯子を登って行く。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、鵞ペンが一束に、まだ白紙のままの公用紙が一帖、半靴下が三足、ズボンからちぎれたぼたんが二つ三つ、それに読者諸君が先刻御承知の【半纏】――それだけであった。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球は重い物體だから、こいつが乘つかつた日には、われわれの鼻は粉微塵に潰れてしまふと考へるとおれはもう居ても立つてもゐられなくなつたので、靴下をはき、半靴をつつかけざま、大急ぎで參議院の議事堂へ駈けつけた――警察に命じて、月に乘つからせないやうに地球を取り押へさせようと思つたからだ。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつとでもさはつたなら、ぼろぼろにくだけてしまひさうな、暗褐色の長上衣、両の肩へ垂れ下つてゐる苧屑のやうな長い黒髪、日焦けのした素足にぢかにはいた半靴――さうしたものがすべて彼の身について、その人柄を形づくつてゐるやうに見えた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウェターに首を突込んで、靴下を穿いて、帽子を引っ掴むと、梯子段の途中に引っかかっている女将の巨体を飛び越すようにして上り框から半靴を突かけると表の往来……千代町の電車通りに飛出した。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "結び目を解くと、白いボール箱に入れた大学生の制服と、制帽、霜降りのオーバーと、メリヤスの襯衣、ズボン、茶色の半靴下、新聞紙に包んだ編上靴なぞ……そうしてその一番上に置いてある小さな革のサックを開くと銀色に光る小さな腕時計まで出て来た。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしボーイは素直に白い半靴を脱いで差出したので、私はそれを両方に提げて廊下に出たが、やがて帰って来ると、靴をボーイに返して飯村警部に代って訊問し初めた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かけがへが無いので、ぱくぱく口の開いたのを我慢して穿いてゐたが、全く絶望になつたので、此の方は金高も洋服に比して遙かに少ないので、何時も會社のゆきかへりに前を通る靴屋で、半靴をあつらへた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の足には黄革の半靴を穿いている。",
              "citation": {
                "source": "橋の下",
                "author": "フレデリック・ブウテ　Frederic Boutet",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴は多くゴム靴で随分半靴などもあった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴は半靴を好んで穿いた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の中から取り出されたのは、二十才前後の女の死体で、普通のスーツにオーバーをまとい、ゴムの半靴をはいていた。",
              "citation": {
                "source": "死因の疑問",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからポンポンと半靴を脱ぎ、井戸側に片足をかけた所で、首を廻して大隅学士の方をみた。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○半靴は米国にては人々酷暑の折これを用ゆ。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧洲にては寒暑共に半靴を穿つものなし。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに日本にてはフロックコートに赤皮の半靴はきたる人折々あり。",
              "citation": {
                "source": "洋服論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その身なりを見ると言合せたように、男は襤褸同然のスェータか国民服に黄色の古帽子、破れた半靴。",
              "citation": {
                "source": "買出し",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "その身なりを見ると言合せたやうに、男は襤褸同然のスヱータか国民服に黄色の古帽子、破れた半靴。",
              "citation": {
                "source": "買出し",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、私はパルテンキルヘンの靴屋がつくった丈夫な半靴を一足買い、山麓を歩き廻ったからである。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "半靴と白い靴下と下シャツとカーキのシャツを持っている。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからスコッチのメリヤスシャツや、鳥打帽子や、半靴などを自分で勝手に見立て私に買つてくれた。",
              "citation": {
                "source": "ある職工の手記",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところへ花道から俳人｜高浜虚子がステッキを持って、白い灯心入りの帽子を被って、透綾の羽織に、薩摩飛白の尻端折りの半靴と云うこしらえで出てくる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛ちやんは何が何だか薩張道理が解らず、『長靴にもなれは半靴にもなる！",
              "citation": {
                "source": "愛ちやんの夢物語",
                "author": "ALICE'S ADVENTURES IN WONDERLAND.",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
