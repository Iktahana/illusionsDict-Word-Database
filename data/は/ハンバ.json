[
  {
    "uuid": "8d083096-2cdd-510c-8e81-7a67557708a0",
    "entry": "飯場",
    "reading": {
      "primary": "はんば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
