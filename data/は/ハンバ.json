    },
    "definitions": [
      {
        "index": 1,
        "gloss": "construction camp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "釜石よりの帰り宮沢賢治かぎりなく鳥はすだけどこゝろこそいとそゞろなれ竹行李小きをになひ雲しろき飯場を出でぬみちのべにしやが花さけばかうもりの柄こそわびしきかすかなる霧雨ふりて丘はたゞいちめんの青谷あひの細き棚田に積まれつゝ廐肥もぬれたり",
              "citation": {
                "source": "釜石よりの帰り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川下の方の捲上げ道を登れば、そのまま彼等は飯場まで帰る事が出来た。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯場には吹き曝しであるにしても風呂が湧いていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、飯場の人たちが、親も子も帰らない事を気遣って、探しに来なかったならば、その親たちと同じ運命になるのであったほど、執拗に首を擡げる事を続けたであろう。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯場の血気な労働者たちは、すっかり暗くなった吹雪の中で、屍体の首を無理にでも持ち上げようとする、子供たちを見て、誰も泣いた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃坑春ちかけれど坑々の、　　　　祠は荒れて天霧し、事務所飯場もおしなべて、　　鳥の宿りとかはりけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、仏法僧のなく音覚束なし、誰に助けらるるともなく、生命生きて、浮世のうらを、古河銅山の書記になって、二年ばかり、子まで出来たが、気の毒にも、山小屋、飯場のパパは、煩ってなくなった。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山は、丁場を休んでいたので、そのハガキを見ると、すぐに叔母に返事を出して、飯場の暗がりの中に、仰向けに引っくりかえった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが失くなったてなあ、おかしいじゃないか」　と言うと、タア坊は、飯場の入口に立ったまま首を傾けた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯場から学校までの、一里半の峻嶮な上り一方の坂道は、同時に、峻嶮なる児童の社会生活である。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者は飯場頭の子であり、ある者は親方の子であり、ある者は労働者の子であった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええと――　と、その考えを突き詰めようとすると、板壁一枚隣りの飯場の婆さんの、カン高い饒舌がうるさく耳につき出した。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯場の便所が、オーバーしそうになったので、そいつを三尺ばかり低くなった、川堤の方へ移転したのだった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邪魔になる部分は、飯場の土地とは所有者が違う。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、農民たちは、その便所の最も近くに住んでいる小林という、飯場頭に、その言い分を持ち出したのであった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山が食事するために、丁場から飯場の方へ降りて行くと、田と飯場との間の狭い畦道で、小林が大きな声を出していた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、何だって俺はこんな愚劣な事を、飯場の中で考えねばならないのか。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、むつっぺえでもからかってやろう――　睦子というのは、小林飯場の飯炊女であった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」という噂が立った時の、小林飯場の動揺は大きかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、飯場の若い衆たちは、外国人みたいに女の脚から、美や魅惑を、発見しようとはしなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お睦を繞って、小林飯場の若い衆の間に、親切競争が捲き起こされた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の長い、十一時間または十二時間の労働を終えて、草臥れ切った肩に、重い橋桁を担いで帰って、それを切って割って薪にするもの、その薪を、飯場の中の焚火の周りに立てかけて乾かすもの、そういう間接な好意でなく、いきなり睦ちゃんの、お尻を撫でる事によって、意志表示するもの。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、この小男が最初土方になったのは、朝鮮人の飯場においてであったからであった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウヒャーッ」　と、身もだえするような笑いを、お睦は上げて、飯場の蒲茣蓙の上を、転げ廻った。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何しろ、顔中真っ白けに白粉は塗ってるし、女の着物は着ているし、姐さん被りまでしているので、花見時でもない、寒中、飯場の外に飛び出すという冒険は、できなかった。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、この調子で行けば、小林の飯場は和気靄々として、若い衆の足も止まり、楽しみもあり、各々の若い衆が、故郷に残して来た苦い、肉親の境遇も、幾分ぼやけ得たであろう。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、うまく大きくさえすれば、いい値に売れるので、方々の飯場でそいつを買ったのである。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、人間さえもが鶏小屋に類する飯場に住んでいるんだから、鶏と人間を同じ待遇にするという訳には行きかねた。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、以前、小林の飯場にいて、白粉を塗ってお睦の着物を着ては、ふざけ散らしていた、小男の林田が駆けて来た。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鼻先へ出て「行政官は早いですなあ」と俺の顔と官報とを一目で覗き分けをしつつ云つたあいつの顔は「この冷笑と侮蔑と憐憫とを君に捧げよう」と云はんばかりであつた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
