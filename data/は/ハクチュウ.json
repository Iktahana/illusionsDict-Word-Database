[
  {
    "uuid": "81aa06fb-9c8a-54c6-b660-a8a440a4f841",
    "entry": "伯仲",
    "reading": {
      "primary": "はくちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
