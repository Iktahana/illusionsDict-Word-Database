        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで一八八〇年までは全く助手なしで独りで実験していた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "B. A. の方法によって一八八一年に得た結果は、これと同時にグレーズブルックが他の方法でやったものとよく一致した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八〇年七月には三番目の子息のジュリアンが生れた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八一年三月に Trinity の Honorary Fellow になった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八二年サザンプトンにおける大英学術協会では Section A の座長をつとめた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八二年十月に発熱性のリューマチスに罹って数週間出勤が出来なかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八四年カナダのモントリオルで大英学術協会が開かれたときにレーリーが会長に選ばれた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸素対水素の比重に関する最初の論文を出したのは一八八八年で、つまりこの仕事をはじめてから三年の後である。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後のは一八八九年と一八九二年に出た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結果の比は一五・八八二であった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八四年にレーリーは王立協会の評議員をつとめたことがあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小麦が安くなったので、乳牛を飼い始め、一八八五年に十二頭だったのが一九一九年レーリーの死んだ年には八〇〇頭の牝牛と六十人の搾乳夫が居た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八三年には鳥の飛翔について、『ネーチュアー』誌に通信を寄せた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この結果に拠れば、広い室で演説する場合ならば、一時間につき一四四ないし二八八キログラムメートルの仕事をする。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれから、一八八〇年代の天鵞絨の長い外套をきて、使ひ古しの帽子の上に造花の薔薇をつけ（その帽子の下からは毛髮の束がはみ出してゐました）、足早に人々の間を通り拔けてゆく老婆たちもありました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルネラは体重一一九キロ身長二・〇五メートル、ベーアは九五キロと一・八八メートルだそうで、からだでは到底相手になれないのである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現フォワイヨの名前は一八八四年ルイ・フィリップの料理頭フォワイヨがこの店をマネージしはじめてから付けた名だ。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三年（庚辰）　一八八〇○一月、新富座にて各新聞記者を招待して劇評を依頼す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四年（辛巳）　一八八一○二月三日、三代目中村翫雀、大阪に死す、四十一歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五年（壬午）　一八八二○一月二十三日の夕刻、猿若座の興行中に出火して全焼。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六年（癸未）　一八八三○四月、春木座にて「菅原実記」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七年（甲申）　一八八四○四月、新富座の一番目に「二代源氏誉身換」を初演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八年（乙酉）　一八八五○久松座の再築落成して、千歳座と改称し、一月四日より七日まで開場式を行う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九年（丙戌）　一八八六○二月二日、四代目助高屋高助、名古屋に客死す、四十九歳。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年（丁亥）　一八八七○三月、中村福助の人気頂上に達し、新富、市村、千歳の三座かけ持ちにて出勤。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一年（戊子）　一八八八○一月、猿若町市村座の新築落成し、八日より三日間、開場式を行う。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十二年（己丑）　一八八九○二月、俳優の等級を定め、更に正副頭取を置く。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八三（明治十六）年　四月、学齢未満であったが、国生小学校に入学。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしきり、沈黙やぶれて、煤けたる江戸絵の壁に禁軍の紅帽あかり、はちはちと火の粉飛びちり、しづまりぬ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯かしぐゆふべの煙庭に這ひてあきらけき夏の雨は降るなりはちはちと降りはじけつつ荒庭の穗草がうへに雨は降るなり俄雨降りしくところ庭草の高きみじかき伏しみだれたり澁柿のくろみしげれるひともとに瀧なして降る夕立の雨　一日のうちでは朝がいゝ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "なまけ者と雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
