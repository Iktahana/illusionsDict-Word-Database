    "definitions": [
      {
        "index": 1,
        "gloss": "to spare the trouble (of doing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
