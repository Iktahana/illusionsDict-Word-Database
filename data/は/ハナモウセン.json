        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "秋の末にもなりたれば、籐筵に代うるに秋野の錦を浮織にせる、花毛氈をもってして、いと華々しく敷詰めたり。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "火は葡萄染の深帳、花毛氈や、銀の籠、また、羅のころも、緑髪、わかき瞳に炎上の匂香熱く、『時』の呼吸、瞬き燻る『追懐よ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "階上には一めんに花毛氈を敷いて、室の中も門口も、垣根も便所も、皆燈籠を点けてあった。",
              "citation": {
                "source": "西湖主",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに物のねびたれば、沈める音の絃の器に、※をかけたる思にて、無言を辿る恋なかの深き二人の眼差も、花毛氈の唐草に絡みて縒るゝ夢心地。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "春をやがて迎えることになった花壇は、園丁の苦心で、早や咲きのチューリップ、ヒヤシンス、シネラリヤ、オブコニカ、パンズイなどを程よき位置に移し、美しい花毛氈が組立てられていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "花毛氈の上であるから並んだその白足袋が美くしく見える。",
              "citation": {
                "source": "住吉祭",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前は畝から畝へ花毛氈を敷いた紫雲英の上に、春もやゝ暮近い五月の午後の日がゆたかに匂うて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堤の北は藻隠れに鮒の住む川で、堤の南は一面の田、紫雲英が花毛氈を敷き、其の絶間には水銹が茜色の水蓋をして居た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茜がかった紫と白と、一本二本はさしてめでたい花でもないが、午の日を受けて何万となく庭一面に咲く時は、緑の地に紫と白の浮き模様、花毛氈を敷いた様に美しい。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑と紅にて彩どりし花毛氈を敷詰めたる一室の正面には大なる硝子窓ありて、異国の旗立てし四、五｜艘の商船海上に泛びたるさまを見せたり。",
              "citation": {
                "source": "江戸芸術論",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "花毛氈の草のへに、彩羽うちふる、楽の譜か、姿すゞしく、移香の、やをら心にしみいりて、愛の泉にゆあみする、新らしき、吾が酔ひごゝち。",
              "citation": {
                "source": "ふるさと",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一階の窓には、花毛氈の窓掛けがつけられた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
