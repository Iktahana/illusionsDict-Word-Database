    "definitions": [
      {
        "index": 1,
        "gloss": "mountain in early spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "實は一昨年の出雲路の旅には、仔細あつて大阪朝日新聞學藝部の春山氏が大屋臺で後見について居た。",
              "citation": {
                "source": "城崎を憶ふ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その神が弟の春山の霞男という神に向かって、「私はあの女神をお嫁にしようと思っても、どうしても来てくれない。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳶尾草の濃紫にほひすみれのしぼ鹿子、春山祇の來て遊ぶ泉のもとにつきぬれば胸もとゞろに、かの君を今こそ終に得てしかと思ふ心のそらだのめ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "青野季吉氏は「紋章」にすっかり「圧迫され」横光氏の「自由の精華」に讚辞を惜しまれなかったのであるが、横光氏のこの「高邁」の発明も、その傍観性、非動性、負かされづめで結局勝ったのだという主観的な独善性等に引き下げられて、本質には春山行夫氏が評した次の言葉がふさわしい種類の身ぶりであった。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤森成吉氏の戯曲「火」は脱獄後の長英と親友鈴木春山とが描かれ、「三十年」は昨年の同じ作者による「シーボルト夜話」の続篇として書かれた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不安の文学提唱、その流布の浅薄な性質については、春山行夫などが、言葉に衣をきせずに批判した。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春山行夫という批評家は、その人としてのいい方で、横光の自我は現実を裁断する力がないから未完成である、といっている。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈春山霞壮夫〉と題した作は古事記か何かにある神話で、珍しく時代物だった。",
              "citation": {
                "source": "土田さんの芸術",
                "author": "土田麦僊追悼",
                "note": "青空文庫"
              }
            },
            {
              "text": "・青空の筍を掘る・春山の奥から重い荷を負うて鮮人・蕗のうまさもふるさとの春ふかうなり　四月廿八日けふも晴れてつめたい、きのふのやうに一天雲なし。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理は氷解、水ぬるむ、春水、春山の類をいふ。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は思ふ、天智天武兩帝同じ思ひを額田王にかけ給ひきと聞けば、此歌も暗に春山を天智帝に比し秋山を天武帝に比し、此時いまだ志を得られざる天武帝をひそかになつかしく思ふ旨を言ひいでられたるには非るか。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この神さまたちの中に、秋山の下氷男と春山の霞男という兄弟の神さまがありました。",
              "citation": {
                "source": "春山秋山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九二八・三）春山行三月の扇ノ山付近　十八日午前二時半私は山陰線浜坂へ下車しました。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち春山のようにクラストを利用したり、雪崩の後を伝ったりして歩いて登ることができない。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "審査は春山行夫君にたのむつもりであつた。",
              "citation": {
                "source": "身辺雑記",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一証を示さんに、駿州清見寺内に石碑あり、この碑は、前年幕府の軍艦｜咸臨丸が、清水港に撃たれたるときに戦没したる春山弁造以下脱走士の為めに建てたるものにして、碑の背面に食人之食者死人之事の九字を大書して榎本武揚と記し、公衆の観に任して憚るところなきを見れば、その心事の大概は窺知るに足るべし。",
              "citation": {
                "source": "瘠我慢の説",
                "author": "瘠我慢の説",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし蒹葭堂コレクシヨンの当代に与へた恩恵の外に、巽斎の真価を見出さうとすれば、どうしても是等の作品に――少くともちよつと前に挙げた一幀の春山図に立ち帰らなければならぬ。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも度たび挙げた春山図は老木や巨巌の横はつた奥へ一条の幽径を通じてゐる。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の愛する蒹葭堂主人はこの寂寞たる春山に唯一人驢馬を歩ませて行つた。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "春山図の逸趣に富んでゐるのも素より怪しむに足りないかも知れない。",
              "citation": {
                "source": "僻見",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マーチン＆マーチン」と云ふ小説の題はどうも變だが、僕はなんでもその夜、寢床の中で、或る雜誌を讀みながら春山行夫の詩集の廣告を見てゐた。",
              "citation": {
                "source": "本のこと",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの春山さんは、赤インキなども用意して実感を出して下さったようだが、とにかくお前がピストルと別れてくれたことはおれも嬉しい。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "春山の半折が懸かっていた。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、此をひようすべと言ふ地方が多く、春山から下り、冬山に入るものとせられてゐるのは、山の神と海の神との職掌混淆の筋合ひを辿つて見れば、難問題でもない。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋山下冰壮夫に対する春山霞壮夫の御母の採つた方法などは、此例のとこひの著しい例である。",
              "citation": {
                "source": "「ほ」・「うら」から「ほがひ」へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "春山のしなひさかえて、秋山の色なつかしき……（万葉巻十三）うらぐはしは、「うるはし」の語原だとの説もあるが、ともかくも、美意識が動いてゐることは事実だが、稍自由である。",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が、子の姿を易へてやる例は、古事記の春山霞壮夫の御母がさうである。",
              "citation": {
                "source": "小栗外伝（餓鬼阿弥蘇生譚の二）",
                "author": "魂と姿との関係",
                "note": "青空文庫"
              }
            },
            {
              "text": "春山唐七家の老母は甚だ彼に好意的であった。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元の一方に坐していた春山唐七にはそれを聞きわけることができたが、彼は隠居の言葉には馴れていなかったから、またしても聞きのがしてしまった。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ために葬式が終ると春山家のお奈良さまに対する扱いは打って変って悪くなり、唐七は距てられてか姿を見せることが少くなった。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
