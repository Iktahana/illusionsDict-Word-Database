          "literary": [
            {
              "text": "」特務曹長「なるほど、ハムサンドウィッチですな。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャバレ・※ールでバタサンドヰッチと、ハムサンドヰッチを私は取つた、ハムの方は少し冷え過ぎてゐた。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "――にこにこしながら、バタサンドヰッチと、ハムサンドヰッチを色彩のある皿に盛つて運んで来たのだ。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "使いの者は鞄からハムサンドを取り出して差しだし、赤のキングはそれを食べる。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "国光映画としても、徹夜ともなれば、テトラ牛乳とハムサンドウィッチが出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
