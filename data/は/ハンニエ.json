        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分は半煮えのような返事をする。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからまだ世間に半煮えのコスモポリタンが多い。",
              "citation": {
                "source": "櫻と狆と愛國心",
                "author": "コスモポリタンの心理",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、小さな一ぴきの魚が、半煮えになって、ひょこりと、地面へはね上りました。",
              "citation": {
                "source": "ぶくぶく長々火の目小僧",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひそかに周囲を見回したる後、台所に忍び寄り、鍋の蓋を開け、まだ半煮えの大根を、がつがつ貪り食う。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪ホテルのシャトウブリヤンを塩からいと思っていた舌は、半煮えの飯を食道へ押し込み、固い干鱈の一片を奥歯の方へ押してやる。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私など、ちかごろ雑誌などにのっている戦後派作家や「肉体派」作家たちの半煮えめしのような小説を三つ四つ読んで、ダラケたような気もちになった後では、口なおしによく志賀や葛西善蔵の小説を引っぱり出して読む。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪ホテルのシャトウブリヤンを塩からいと思っていた舌は、半煮えの飯を食道に押し込み、固い干鱈の一片を奥歯の方へ押してやる。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなり洗練された、うるさい口も、山では半煮え飯を平気で喰う。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
