          "standard": [
            {
              "text": "彼には何か腹づもりがあるようで、何も教えてくれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議に臨む前に、自分の腹づもりをしっかりと固めておこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最初からそのような腹づもりだったとは、驚きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこで、建築材料木材は、紀州熊野の奧から出て來る人が引きうけて、それほどの豫算では見る影もない借家建だと、はじめ、首をひねりはしたが、その人の腹づもりはすぐ出來てしまつて、木の國生れの人が、丹波に飛び、江州に行き、草鞋がけで山の杉の立木を買ふ。",
              "citation": {
                "source": "家",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、義貞の腹づもりにしてみると、「それにしては？",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
