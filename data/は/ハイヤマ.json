        "examples": {
          "standard": [
            {
              "text": "対局の準備を整えるため、卓の上に牌を並べて立派な牌山を築き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "勝負の行方は、牌山の奥に眠っている最後の一枚に託されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "集中力が切れたのか、彼は不注意にも自分の肘で牌山を崩してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "色付きの絵が動くとなるとガキの興奮はいやますだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はと云って挨拶をした時老師はいやまるで御見逸れ申しましたと、改めて久濶を叙したあとで、久しい事になりますな、もうかれこれ二十年になりますからなどと云った。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさひの高くなるまゝに、つちのかわきはいやまして、のどをうるほす露あらず、悲しやはらばふ身にしあればあつさこよなう堪へがたし。",
              "citation": {
                "source": "北村透谷詩集",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
