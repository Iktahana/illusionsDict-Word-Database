        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宮沢賢治全集刊行に際して中原中也　宮沢賢治全集の、第一回配本が出ました。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボイジャーは、日本語版エキスパンドブックの第一回配本を五月二十五日に予定しているとのこと。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方『パソコン創世記』は、第一回の配本には間に合いませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "記念すべき一回目の配本に間に合わなくなるのは残念でしたが、その時にはもう、浮かんできた構図を確かめながら書いて行くことが、心のあらかたを占めていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "囘顧（『日本文學講座』に寄す）　改造社から出版された日本文學講座はすでに第十四囘の配本を終り、和歌文學に、物語小説に、隨筆日記に、俳諧文學に、その他明治以來の新しい文學等に、一大文學史の觀あるこの講座もまさに完成されようとしてゐる。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを考えていた折から河出書房版、新世界文学全集第十一巻、シチェードリンの「ゴロヴリョフ家の人々」が配本されて来て、非常に興味をひかれ、今三分の二ほどよみ進んでいる。",
              "citation": {
                "source": "翻訳の価値",
                "author": "――「ゴロヴリョフ家の人々」にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "御蔭でいよいよ第一回配本を了したこと喜びと感謝にたえません。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年五月二十三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "私担当分の講座原稿は一応の準備ができておりますから臥床中執筆、第六回配本に間に合わすよういたします。",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三三年三月",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の車に大量の雑誌を積み込みマフラーをこすりながら郡司は配本に走りまわった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと配本を済ましたばかりだ。",
              "citation": {
                "source": "雅俗貧困譜",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち社預かり第五回配本の分まで三分。",
              "citation": {
                "source": "分配",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三五・一〇東京戸坂潤再版序　第二回の予約配本になるのを機会に、少なからぬ誤植を訂正して、再版の体裁にすることにした。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "西田哲学の凡ゆる部分が「形而上学序説」の意味を有つことが出来るのである（岩波講座『哲学』第十四回配本参照）。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "三笠のは配本を中絶したので大変おそくなってしまいましたが、古いのお送りいたします。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千だけ刷ったが、第二日でもう千部刷るという話が配本の方から出ている由、まだわかりませんが。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
