        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからまたグリューズの「破瓶」の娘の顔も好きらしかった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "破瓶を画師うち抱き、死人を法師みちびき、秋の野へ、葬りの途に、また聞きぬ、見ぬ、黒牛のこれも呻吟。",
              "citation": {
                "source": "如是",
                "author": "末吉安持",
                "note": "青空文庫"
              }
            },
            {
              "text": "破瓶一　最後の一計もむなしく半途に終って、それ以来、呂布は城にあって、日夜｜悶々と、酒ばかりのんでいたが、――その呂布を攻め、城を取囲んでいる曹操のほうにも、すでに安からぬ思いが濃かった。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはびんぼうな教師の子どもにうまれて、ずうっと本ばかり読んで育ってきたのだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこで、ヘンデル先生の銅像をたてることにきめましたが、なにしろ、伝染病という大さいなんのあとだから、村はびんぼうになってしまって、だれもお金を出すものがありません。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイリイはびんと蛇を持って上っていきました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばさんは、くびをふって、「私の家はびんぼうな百姓ですもの。",
              "citation": {
                "source": "岡の家",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "握りつぶしてはびんから引き抜いて手欄から戸外に投げ出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といって、山姥はびんつけ油を取りに行きました。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうだいが上でびくびくしていると、山姥はびんつけを取って来て、桃の木にこてこてなすりはじめました。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形はびんつけで髪を結っていた。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はびんとなって、ベンチからのり出した。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだおばあちやんはびんばふは知らないで死んでしまつた。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮫ヶ橋のかれらの生活は、びんばふはびんばふなりに明るく幸福だつたのだらうと考へてみた。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ夢の寝言みたいな私の感想をある人が聞いて「あなたはびんばふの本当の味を知らないから、そんな夢を見てゐるのですよ。",
              "citation": {
                "source": "赤とピンクの世界",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼是二十｜尋ばかり引き去りて、止まりたれば、即ち又手繰れるに、ごつごつと、綸に従きて近づく様明に知れ、近づきては又急に延し、其の勢いの暴き、綸はびんびん鳴りて、切るるか切るるかと、胸を冷せしことを一再のみならず。",
              "citation": {
                "source": "大利根の大物釣",
                "author": "石井研堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、男はびんを取り上げて、口に目を当ててのぞきました。",
              "citation": {
                "source": "びんの中の世界",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関のとびらのかんぬきがはずれているぞ」　ホールはびんを片手に、ぽかんとドアの前につったって、ゆうべたしかに玄関のドアはしめたはずだ、と思った。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはびんの一ばん底に残った滓までかきさらうような努力だった！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はびんを引っつかんで、無遠慮に窓の外へほうり出した。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "中「きょう、勇ちゃんはびんどを持って川へえびを取りにいくといったが、僕もいっしょにゆこうかな。",
              "citation": {
                "source": "真昼のお化け",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "タランチュラ蜘蛛には非ず、大なるもそはびんより出づるぶどう酒そは汝のいずこを咬みしや、わがいとしの者よわれに示せ、そはいずこおお汝の足ならば、おお乳房ならば（松藤訳）他の人たちは歌詞を限りなく繰り返した(30)。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてなかなか、とても一夜稽古のでっちあげとは思えない、張のある声はびんびんと書院の四壁に響きわたり、端座した体からは光を発するかと疑われる。",
              "citation": {
                "source": "若殿女難記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "照彦様は華族様でなに不自由のない身分だけれど、点数だけはびんぼうだ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
