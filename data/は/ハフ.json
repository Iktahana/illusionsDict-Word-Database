[
  {
    "uuid": "ec7b44f7-386c-583a-9da7-d57b2dcb3c4f",
    "entry": "破風",
    "reading": {
      "primary": "はふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
