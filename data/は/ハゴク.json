    "definitions": [
      {
        "index": 1,
        "gloss": "breaking out of prison",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで話は終った訳だが、一般には、近い中に救助破獄が行われるだろうと固く信じられている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夜のこと、死刑にする筈の四人の囚人が、破獄したという通知が来たので、奈良原典獄は直ぐに駈付けて手配をさせた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、それがタッタ今破獄したばかりの四人の囚人たちで、海水にズブ濡れのまま到翁の足下にひれ伏して三拝九拝しているのであった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事ではドウにもならんから、破獄を諦らめよう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "破獄逃亡の大罪人です。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "パベルのお母さんが、その子の入獄とともに、その老い行く身を革命運動の中に投じて、あるいは秘密文書の配付に、あるいは同志の破獄の助力に、粉骨砕身して奔走するあたり、僕は幾度か巻を掩うて感涙にむせんだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで BASTILLE の破獄ですわ。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、それ故破獄して浮世の風に当ろうと云うのは大丈夫として為すべからざることじゃ。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十七年三月二十七日の夜で、此頃河野広中氏は福島事件に連座して、此処監房に入れられていたが、同室の赤井｜景韶と同じく松田克之の二人に破獄逃亡を勧められたのである。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "武東氏はつくづく見ていたが、「ふうん、犯人は破獄囚だな」唸るように呟いたものである。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "――武東氏は獄衣を手に取り乍ら、「これは恐らく斯うだろう、犯人の破獄囚は情を明かし、否寧ろ嚇し付けて俥に乗って此処まで来たが車夫の密告が怖くなった処から、車夫を殺して着物を剥ぎ、そいつを着て車夫に化け、俥を曳いて逃亡したのだろう。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる近県の監獄に向かって破獄囚の有無が照会された。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも凶猛の国事犯人が破獄したというのである。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "破獄囚赤井景韶が、坊主となって広教寺に……」「えッ」　と署員総立ちとなる。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十八年七月二十七日、破獄謀殺二重の罪に依って、市ヶ谷監獄の絞首台で二人乍ら死刑に処せられたが、流石に名を惜む壮士だけあって、その最後振の立派さは立会の人達を驚かせたそうである。",
              "citation": {
                "source": "国事犯の行方",
                "author": "―破獄の志士赤井景韶―",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ロストフの牢屋を破獄して君が逃亡して以来、どんなに俺は探がしたことか！",
              "citation": {
                "source": "死の復讐",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……如かずそれよりも我らが方より、急速に出で機先を制し、萩丸殿の首を斬り、それをひっさげて紀州に潜入し、紀州公を怯かし、破獄して同志を奪還いたすこそ、策の得たるものと存ぜられ申す！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長英の「夢物語」、崋山の「愼機論」を幕府が忌むところとなつて崋山は天保十二年、昌造十七歳のとき自殺し、長英は昌造が二十七歳、嘉永三年に自刄するまでは破獄したまま行衞不明だつた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は曾て甲府の牢に囚われていて、破獄を企てつつ宇津木兵馬を助け出した奇異なる浪士であります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きな銅貨は、徒刑場の気長い仕事によって暗黒な用途のために暗黒の中で作り出される驚くべき手工品の一つであり、破獄の道具にほかならない驚くべき品物の一つだった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼女は、今夜、彼女たちが奉じる悪の一党の首領が、その黒幕から指令するところがあったので、奉行所内に忍びこんで、唖男と、掏児の新七とを、外部から、牢の合鍵をもって、やすやすと、破獄させて来たのであった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それに、てめえたちだって、破獄したばかりの体だから、しばらくの間、海風にでも吹かれて、ほとぼりを、さましていろ」「なるほど、一挙両得というわけで」「おい」　と、唖へも、顎を向けて、手まねで、耀蔵のからだを縛れと命じた。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また磁石が電波を受けた瞬間にその磁力を変ずる事を利用したマルコニ式のマグネチック・デテクターと称するものもあって、これはごく遠距離の通信に限って用いられる。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タングステンというはクロム属の金属元素で、これまではごく硬い鋼鉄を造るに用いられていた。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に日本はごくごくこの間、三、四千年前までは、全く人が居なかったと云いますから、もちろん誰もそれを見てはいなかったでしょう。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体お増はごく人のよい親切な女で、僕と民子が目の前で仲好い風をすると、嫉妬心を起すけれど、もとより執念深い性でないから、民子が一人になれば民子と仲が好く、僕が一人になれば僕を大騒ぎするのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに近頃はごく軽便な誰にも一人で出来る測量法がだんだん使われるようになった。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――考へても見て下さい、（私は今朝それを數へた許りですが）私は百十五通の手紙を書きました、しかもその一通として四頁以下のものはなく、その大部分はごく細かい字で八頁から十二頁ぐらゐのものまであるのです。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この非常に單純なリズムのある散文を、彼はごく輕い抑揚をつけただけで、いつも殆ど夢のなかでのやうに、朗讀しました。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、私はごく若い時分から、仕事以外のものを求めませんでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
