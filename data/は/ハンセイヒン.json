          "literary": [
            {
              "text": "いや、正確には、半製品とでもいうべきか――。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにたくさん打製石斧のあるのは、あるひはこゝで石斧の半製品を造つて、各地へ輸送したものかも知れないと思はれるのであります。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集が必要とするほど早く教育ある医師たちを作り出すことは出来ず、時代は半製品の黄金時代であった。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            }
          ]
        }
