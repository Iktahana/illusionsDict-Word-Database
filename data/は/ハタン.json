    },
    "definitions": [
      {
        "index": 1,
        "gloss": "failure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども此處に、彼の著るしい破綻が感じられた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぐい稀な特質だ」「しどろもどろの看板」「懐疑説の破綻と来るね。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に一分も心を寄せ合はなかつた相愛の男女が、三年目の再会後、間もなく永遠の破綻を来らしめました。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年前、私は或る出来事のために私の神経の一部分の破綻を招いたことがありました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それが単なる地貌学的ないし生物学的の記述でなく、文学的作品と呼ばれ得る所以は、これらの対象中に作者の人格が滲潤している点にあるが、その作者から流出したものを盛るべき容器が科学的事実である限り、その容器に科学的｜破綻があっては工合が悪いのである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそれは読者の科学的知識の水準次第で、甲がこの種の破綻や矛盾を感じても、丙は知らずに観過する事はしばしばある。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ロダンさんは中年時代、シャトウ・チェリイから出て来た女弟子のカミイユ・クロオデル嬢との恋愛の破綻によって、思索上にもロダンさんの生理学にも余程の変化があったのだそうです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三民主義の進出とソビエット・ロシアの東方政策の破綻となったのだ。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って見ていてたまらなく不快な破綻を感じる程度が剣劇に比して少ないように思う。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、現在の日本のジャーナリズムがその魔術の呪縛に破綻を示してときどき醜いしっぽを露出するのはいわゆる科学記事の方面において往々に見受けられるのは注意すべき現象である。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お神さんは時田のシャツの破綻を繕っている。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの間に錯雑して現われて来るいろいろな作者のそれぞれちがった個性はなんらの破綻を生じないのみか、かえってちょうどいろいろ違った音色をもつ楽器のそれぞれの音のような効果をもって読者の胸に響いて来るのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともわざと焦点をはずした場合のように全部が均等に調和的にぼやけたのならば別であるが、明確なものと曖昧なものとが雑然と不調和に同居しているところに破綻があり不快がある。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは自然なものと不自然なものとの衝突から生じる破綻である。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、もしも人形の顔なりからだなりが、あまりに平凡な写実的のものであったとしたら、おそらく人形の劇的表情は半分以上消えてしまうであろうのみならず、不自然、非写実的な環境の中に孤立した写実は全く救い難い破綻を見せるであろう。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "調書は法律知識のある判検事が理詰で作上げたものであるから、前後一貫、些の矛盾や破綻を示さない。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋人同志が、同じ一人の父親をもっていたとすれば、これ以上惨めなローマンスの破綻はない。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一つは養家へ対する反感から来ているのでもあり、自身の生活の破綻を諦め忘れようとする意気地なさの意地とでも言うべきものであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "放漫な財政の破綻もあって、財界に恐慌が襲い来たり、時の政治家によって財政緊縮が叫ばれ、国防費がひどく切り詰められた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者がることは彼女も嫌いであり、ただ結婚の破綻で、女にしては最も大切な時代の四年を棒に振ったことは、何と言っても心外であり、再び振り返ろうとも思わなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして結果は、両方の場合に於て、破綻なく満足であつたのである。",
              "citation": {
                "source": "家庭の痛恨",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは何事かを思い詰めると、狂人の如くその一念に凝り固まり、理想に淫して現実を忘却してしまうために、遂には身の破綻を招き、狂気か自殺かの絶対死地に追い詰められる。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は大家の若旦那に生れついて、家の跡取りとなり、何の苦労もないうちに、郷党の銀行にただ名前を貸しといただけで、その銀行の破綻の責を一家に引受け、預金者に対して蔵屋敷まで投げ出したが、郷党の同情が集まり、それほどまでにしなくともということになり、息子の医者の代にはほぼ家運を挽回するようになった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年目の年が明けて、梅もぽつ／＼咲き初めた頃、添田家縁者一統の総代が、泰松寺へ出頭して、宗右衛門の家事不取締りから、使用人の怠慢、家業｜破綻の条々を縷述し、その上、娘お小夜の急病を報じて宗右衛門の自宅へ復帰することを老師に願ひ出でた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時はたんねんに集めていた切り抜き版画などの展覧会をやったり、とにかく相当に自分の趣味を満足させるだけの環境はあったらしい。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事業は清逸にとってはたんなる遊戯ではなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人のことならいざ知らず、自分の醜聞を愛する奴はたんとは、あるまいよ。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこら一めんに陽炎がもえ、路のふちにはたんぽぽが、黄金のお銭のやうに落ちてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたんぜんを着たままその間にはひつて、むつつりしながら彼等の話を聞いてゐるのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東一君はたんすにもたれて、ひき出しのかんをカタンカタンといわせていたり、店に出てひげを生やした農学校の先生が『大根栽培の理論と実際』というような、むつかしい名前の本を番頭に注文するところを、じっと見ていたりした。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
