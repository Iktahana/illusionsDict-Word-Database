[
  {
    "uuid": "4b720862-f91c-5b24-8d91-833b72a4cb05",
    "entry": "破綻",
    "reading": {
      "primary": "はたん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
