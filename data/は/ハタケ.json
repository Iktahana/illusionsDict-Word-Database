    "definitions": [
      {
        "index": 1,
        "gloss": "field (for growing wheat, fruit, vegetables, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "麥萩原朔太郎麥はさ青に延び行けり遠き畑の田作りの白き襦袢にえんえんと眞晝の光ふりそそぐ九月はじめの旅立ちに汽車の窓より眺むれば麥の青きに驚きて疲れし心が泣き出せり",
              "citation": {
                "source": "麥",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地宮沢賢治焦ぎ木のむらはなほあれば山の畑の雪消えて〔以下なし〕　――――――――青年団が総出にてしだれ桜を截りしなり",
              "citation": {
                "source": "開墾地",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗谷〔一〕宮沢賢治まくろなる流れの岸に根株燃すゆふべのけむりこらつどひかたみに舞ひてたんぽゝの白き毛をふく丘の上のスリッパ小屋に媼ゐてむすめらに云ふかくてしも畑みな成りてあらたなる艱苦ひらくと",
              "citation": {
                "source": "宗谷〔一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もその不平たるや、独りで文学を思ふ時と、Ｂが面前にある時とだけのものであつて、一般生活、つまり彼の畑に帰れば、あつてなきが如きものでさへあるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面の麦畑に囲まれた田舎の家で、夏の日の午睡をしていると、麦の穂を渡った風が、枕許に吹き入れて来たという意であるが、表現の技巧が非常に複雑していて、情趣の深いイメージを含蓄させてる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句を読むと、田舎の閑寂な空気や、夏の真昼の静寂さや、ひっそりとした田舎家の室内や、その部屋の窓から見晴しになってるところの、広茫たる一面の麦畑や、またその麦畑が、上風に吹かれて浪のように動いている有様やが、詩の縹渺するイメージの影で浮き出して来る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居鳥寺見ゆ麦林寺とやいふ　夏の日の田舎道、遠く麦畑の続いた向うに、寺の塔が小さく見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には秋のような日が照り渡って、地上には麦が実り、大鎌や小鎌を持った農夫たちが、至るところの畑の中で、戦争のように忙がしく働いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月雨や蚕わづらふ桑畑　暗澹とした空の下で、蚕が病んでいるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気は梅雨で重たくしめり、地上は一面の桑畑である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか知らねど萩原朔太郎なにか知らねど泣きたさにわれはゆくゆく汽車の窓はるばるときやべつ畑に日は光り風見ぐるまきりやきりりとめぐる日にわれはゆくゆく汽車の窓なにか知らねど泣きたさに",
              "citation": {
                "source": "なにか知らねど",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏畑の竹藪の中の小径から我家と往来が出来て、垣の向うから熟柿が覗けばこちらから烏瓜が笑う。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず裏の畑の茄子｜冬瓜小豆人参里芋を始め、井戸脇の葡萄塀の上の棗、隣から貰うた梨。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし裾野の所々に熟したオレンジの畑は美しく、また日本の南国に育った自分にはなつかしかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺りまで畑打つ男女｜何処となく悠長に京びたるなどもうれし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩淵の辺｜甘蔗畑多くあり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "折から畑に入るゝ肥料なるべし異様のかおり鼻を突きて静岡にて求めし弁当開ける人の胸悪くせしも可笑しかりける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝来の家や田畑を売り払って株式に手を出すと同じ行き方である。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広々した畑地に霜解けを踏んで、冬枯れの木立の上に高い蒼空を流れる雲でも見ながら、当もなく歩いていたいと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の甘蔗畑が月に照らされて一枚一枚の甘蔗の葉影も鮮やかに数へることが出来た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして謝源にはその青白い色をして居る畑が自分を冷笑して居るやうにも見えた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菓子を、あげますから」と言つて、せんべい一枚をヒユウと向ふの畑地へ投げてやります。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い夏山、山の中腹までは畑地である。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにが悲しいつたつてこれほど悲しいことはない草の根の匂ひが静かに鼻にくる、畑の土が石といつしよに私を見てゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏血を吐くやうな　倦うさ、たゆけさ今日の日も畑に陽は照り、麦に陽は照り睡るがやうな悲しさに、み空をとほく血を吐くやうな倦うさ、たゆけさ空は燃え、畑はつづき雲浮び、眩しく光り今日の日も陽は炎ゆる、地は睡る血を吐くやうなせつなさに。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "農鳥山は大約三峰に岐れているようだ、手近を私たちは――後の話だが――仮に南農鳥と名づけた、雪が二塊ばかり、胸に光っている、近づくほど、雪の幅が成長して大きくなる、雪の側はいわゆる御花畑で、四ツ葉塩釜、白山一華、小岩鏡などが多い。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "月見草の花が白い、カケス畑を知らぬ間に過ぎて、自動車はスケッチ帳入りの小嚢を手に下げた茨木君と私と長男隼太郎外、強力一人を大野原に吐き出して、見送りのため同乗せられた大山さんと、梅月の主人をさらって、影を没してしまう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が知ってからでも、その当時新道なるものが出来て、仏坂を経てカケス畑に出で、馬返しから四合半で古道に合したものだが、これも長くは続かず、私たちの今度取った路は最新のもので、二合目で前の新道なるものを併せ、四合目で村山からの古道を合せている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤黒い顔に鉄縁の眼鏡を掛け、紋付羽織が好きで何時もその広い胸ははたけられてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "器械はやっぱり凍ったはたけや牧草地の雪をふるわせてまわっています。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
