    "definitions": [
      {
        "index": 1,
        "gloss": "the eight legions (devas, nagas, yaksas, gandharvas, asuras, garudas, kimnaras, mahoragas)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
