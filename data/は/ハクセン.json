[
  {
    "uuid": "4f99549e-505e-5bfe-a328-c07060ab1e93",
    "entry": "白線",
    "reading": {
      "primary": "はくせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "white line",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白線を巻いた生徒を見ると誰かじゃないかと思う。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の白線の帽子が身がはりになつて呉れたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の白線の帽子が身がわりになって呉れたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから麦酒会社のコートに来てみると、新しくニガリを打って眩い白線がクッキリと引き廻して在る。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "帽子の白線は三本、桜の中に三の字のはいった徽章、先斗町の「桔梗家」から吉田の三高へ通っている梶鶴雄といえば、この界隈で誰ひとり知らぬ者はない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やがて、三本の白線のはいった穴だらけの帽子を無造作に掴んで、のそっとはいって来たのは、果して梶鶴雄だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法使いに、白線ついた制帽は不似合いと思ったのかも知れません。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外套には、白線の制帽も似合って、まさしく英国の海軍将校のように見えるだろうと、すこし自信もあったようです。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺の腹掛、唐桟の単衣に角帯、麻裏草履、そのような服装をしていながら、白線の制帽をかぶって、まちを歩いたのは、一たい、どういう美学が教えた業でしょう。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐桟、角帯、紺の腹掛、白線の制帽、白手袋、もはや収拾つかないごたごたの満艦飾です。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃私の居た地方の高等学校では、真紅色のリボンに二本の白線を入れた帽子を、一高に準じて制定して居た。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそれが厭だつたので、白線の上に赤インキを塗りつけたり、真紅色の上に紫絵具をこすつたりして、無理に一高の帽子に紛らして居た。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯カスリの袷にキチンと袴を穿いて、少しよごれた一高の制帽の白線が色の黒い兄の丸顔と可愛らしく対照して居ました。",
              "citation": {
                "source": "処女時代の追憶",
                "author": "断片三種",
                "note": "青空文庫"
              }
            },
            {
              "text": "掟を破るのはいまだ）　豹一はその決心を示すように、白線のはいった帽子を脱いで、紺ヘルの上着のポケットへ突っ込んだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々がみな去つてしまひ、がらんとした講堂の中に、野村長命博士が腑抜けのやうに、前方の黒板に、講演者がチョークで書きのこして去つた、直線や、電光形や、渦巻きやの白線を凝然とみつめてゐた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも三機の偵察機が、白線の滑走路にそい、戦闘機の前をすりぬけるようにして、爆音勇ましく暗の夜空に飛びだした。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その志村が、自分の隣村の中どこの地主の息子だといふことがわかつては、白線の帽子から後光が射して見える頃の駿介の心は掻き立てられずにはゐなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの制帽は白線が三条巻きつけてあったが、酒井君は細い絹糸のような条を巻き、ひさしの広い、別の型の帽子を被り、鞄を右肩だけにかけて、新しいスタイルをはじめた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺サージの制服、緑に白線の入ったバンド　安積的口調　十二日に旅行アルラシ　東京日比谷、東京駅、横須賀、江の島などゆくらしい。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は決然として、あのあこがれの二条の白線の帽子を地に投げすて、校門を出たのでした。",
              "citation": {
                "source": "悪魔の弟子",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏ならば、それとは見えざるべき水のしたゝり、氷に大きくあらはれて、船尾上の上よりかけて、いくつとなく、縱に長大白線を引けり。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に一台の猾いタクシーが白線から飛び出したがために叱っておく必要がある。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "土曜日の晩らしく、むこう側の明るい書店に白線入りの制帽をかぶった数人の学生の姿が見えたり露店の花屋の前でむき出しの電燈に顔を近々と照らされながら並んで佇んで何か云っている夫婦づれの姿も見える。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　床屋の親方は風呂敷包を解いて、中から青年団式の雨外套と、カアキイ色の白線の入った兵隊式の帽子を取出し、いきなり仕立屋の頭へかぶせた。",
              "citation": {
                "source": "遺産",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の低い中肉の女で、紫色と白線とが目立つ着物をきていた。",
              "citation": {
                "source": "霧の中",
                "author": "――「正夫の世界」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　長火鉢の前にぴたりと坐り、水色の地に波の白線を大きくうねらした浴衣の襟元をきつく合せ、散らし髪で猪口を手にしてる、彼女の姿は、なんだか情の薄い冷たさに見えた。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父はいつもの通り頭に繃帯をし、杖を持って居、私は、十位までよく着て居た赤地に細い白線で市松が小さく小さく切ってある遠方から見ると真赤に外見えない様な着物を着て居たと覚えて居る。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　グラウンドに入った瞬間、眼を射るような幾条もの白線、直線、曲線、円、楕円それ等のものの前に先ず人々は緊った昂奮を感ずる。",
              "citation": {
                "source": "近代美の研究",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "父を出むかえに、その頃、出張は必ずつばめの白線のある車で、日曜の朝着くことになっていたから、母と子供達は自動車で迎えに行った。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白砂糖の層は横の硝子板から見ると、白線になってあらわれ、これが断層の目印になるのであった。",
              "citation": {
                "source": "実験室の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
