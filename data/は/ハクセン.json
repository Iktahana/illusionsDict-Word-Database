  {
    "uuid": "089d9f6a-b10a-5a2a-b74f-6310f68ca99d",
    "entry": "白扇",
    "reading": {
      "primary": "はくせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(plain) white fan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新らしい袴を出し、新らしい足袋と白扇を進めて、それが威容の料とはならず、罪問ふ敵への礼儀とあらば、何たる切ないことであらう。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士を、白扇さかしまなど形容して、まるでお座敷芸にまるめてしまっているのが、不服なのである。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶店で羊羹食いながら、白扇さかしまなど、気の毒に思うのである。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "的言イアテルヨリハ、ワガ思念開陳ノ体系、筋ミチ立チテ在リ、アラワナル矛盾モナシ、一応ノ首肯ニ価スレバ、我事オワレリ、白扇サットヒライテ、スネノ蚊、追イ払ウ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白扇ばたつかせて、今宵の蚊のせはしさよと呟やくあり。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分日焼けのした顔色で、帽子を被らず、手拭を畳んで頭に載せ、半開きの白扇を額に翳した……一方雑樹交りに干潟のような広々とした畑がある。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおい、おおいと、汽車の窓に乗り出して、一人が麦藁帽を振ると、　おおい、おおいと、また一人が麦藁帽を振ると、　おおい、おおいと、また一人が白扇を振ると、　おおい、おおいと、またまた一人がハンカチーフを振ると、　おおい、おおいと、あ、向うで何か振った、振った、振った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜、翁の請に応じて即吟、白扇に題したる我句は、越えて来て又｜一峰や月のあと　暁天の白むまで眠り得ず、翌朝日｜闌けて起き出でたるは、いつの間にか明方の熟睡に入りたりしと覚ゆ。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣に袴の、白扇を持った痩せ形の老人が謹厳に私達を迎えた。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎鬚を綺麗に削り、鼻の下の髭を短かく摘み、白麻の詰襟服で、丸火屋の台ラムプの蔭に座って、白扇を使っている姿が眼に浮かぶ。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同変ることもないか」　五郎三郎は機嫌よくみんなに挨拶して、腰から白扇を取り出してはらはらと使った。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "左岸の樹疎らなる處、秩父の連山孱顏をあらはし、右岸には、箱根足柄の山々手に取る如く見えて、その上の、八朶の芙蓉峯、倒まに白扇を懸け、花にひときはの趣を添へぬ。",
              "citation": {
                "source": "小金井の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、お先に失礼」　何かののしろうとしてつっ立ち上がりながら、二足三足追っかけてまいりましたが、右門はもうそのとき白扇で涼風を招きながら、さっさとお牢屋敷の表門を往来へ踏み出しているときでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の場合ならば、お互い先にねたをあげたものがてがらとなるんだから、負けるまでにも競争するのは当然なのに、われらのむっつり右門にかぎっては、いっこうそんなけぶりすらも見えないで、涼しげにばたばたと胸もとへ白扇の風を入れていたものでしたから、敬四郎はむッとただ右門をにらみかえしたばかり――。",
              "citation": {
                "source": "右門捕物帖",
                "author": "村正騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "青ざめ顔でしんねりむっつりと腕を組んでいる様子が、やはり今の珍相撲の一番に頭を悩ましてでもいるらしく思われましたので、右門は目ざとくもそれを認めると、あばたの敬四郎たち一党に気づかれないようにというつもりから、腰にしていた白扇をそっと抜きとって、こっそりそのほうへ投げつけました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴衣に袴の、白扇を持つた痩形の老人が謹厳に私たちを迎へた。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は奥へ通って、小さい白扇を遣っていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私の持っている扇をみて、しきりに欲しそうな顔をしているので、私はその白扇に漢詩の絶句をかいてやると、彼はよろこんで貰って行った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも白扇の題詩を見るに及んで、私が軍人でないことを知ったというのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも白扇を取り直して、やや伏目になって一斉に歌い始めた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "張訓もおなじく押し頂いて披いて見ると、どうしたわけか自分の貰った扇だけは白扇で、なにも書いてない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢のなかで、どうして白扇がおれの手にはいったことを知っていたのかな。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりの女がおれの枕もとへ来て、昨日張訓に下さいました扇子は白扇でございました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（白扇をひらきて遣ひながら。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝居ならば、わたくしが座頭役で、白扇でも開いて見事見事と褒め立てようと云うところです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事後に、栗村君はすゞりと筆と白扇とを取りよせ、その日の記念にと私に揮毫を求められた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "つたない筆の跡を臆面もなく殘して行くやうで、私も心苦しかつたが、強ひて辭退するのもどうかと思つて、求めらるゝまゝに白扇をひろげて見た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は書きにくい白扇よりも、その紙片の方を選んで、日頃好きな芭蕉の言葉の中から一つ二つを書いて贈ることにした。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "こまかいたて縞のすきとおる着物にうすい羽織を着た浅吉は、白扇をパチリ、パチリ鳴らしながらあんまり物を云わず、笑いもせず、木菟のような眼の丸い頬ぺたのふくらんだ顔で坐っている。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
