        "examples": {
          "standard": [
            {
              "text": "この店は、クリスマスの時期が一年で最も繁忙期となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "繁忙期中は、残業や休日出勤が増える傾向にある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事前に繁忙期がわかっていれば、人員を増やすなどの対策が取れる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "見樣によつては、今年からは、秋の終りから冬を通じての翌年の春までが、駿介にとつて一番の活動期、繁忙期になるかとさへ思はれた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
