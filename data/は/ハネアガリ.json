        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "馬は、苦痛にたえかねて跳ね上がりました。",
              "citation": {
                "source": "あらしの前の木と鳥の会話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜度、三｜度、水の面へ白い腹を出して、跳ね上がりました。",
              "citation": {
                "source": "魚と白鳥",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はふいに、命かぎりの力を出して、跳ね上がりました。",
              "citation": {
                "source": "魚と白鳥",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "べっとりとした毛の束が無秩序に頭の上で跳ね上がり、埃にまみれている。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、老人が見ていると、小さなマグロが一匹跳ね上がり、空中で逆さになって頭からまた水に潜った。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "水面から高く跳ね上がり、その大きな体を、力と美しさを、残さず見せつける。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして魚が水から跳ね上がり、落下する前に空中で静止した時には、何かとてつもなく異常なことが起きているとしか思えず、現実と信じることができなかった。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、トビウオが舳先から船の左右に跳ね上がり、ホンダワラの黄色い塊が漂っているだけだ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "パンの値段が一｜斤九ペンスに跳ね上がり、一番安い肉でも一ポンドあたり二シリング以下で買うことができなくなった。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夜などは、側に寝ていたおつみを蹴とばし、おつみがびっくりして、泣きだすと、「八幡っ、八幡っ、八幡っ」　と呶鳴って、いきなり寝床から跳ね上がり、眼ざめて、宥めても、まだ寝呆けて、何か昂ぶり続けるようなことがままあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだがつちにつくかつかないうちに、よだかはひらりとまたそらへはねあがりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その時向ふ岸ちかくの少し下流の方で見えない天の川の水がぎらっと光って柱のやうに高くはねあがりどぉと烈しい音がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはもうはねあがりたいくらゐ気持が軽くなって云ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」達二ははねあがりました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなや否とよ立てきみと、　　博士が云へばたちまちに、けりはねあがり山つ祇、　　　をみなをとりて消えうせぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔キッコは筆記帳をもってはねあがりました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時向う岸ちかくの少し下流の方で見えない天の川の水がぎらっと光って柱のように高くはねあがりどぉと烈しい音がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはもうはねあがりたいくらい気持が軽くなって云いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど兵隊のかたちが見えないねえ」　その時｜向こう岸ちかくの少し下流の方で、見えない天の川の水がぎらっと光って、柱のように高くはねあがり、どおとはげしい音がしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはもうはねあがりたいくらい気持ちが軽くなって言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼どもは一ぺんにはねあがりました。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鹿はそれからみんな、みじかく笛のように鳴いてはねあがり、はげしくはげしくまわりました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の子供らは夢中になってはねあがりまっ青な寂静印［17］の上をかけまわりました。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天の子供らは夢中になってはねあがりまっ青な寂静印の湖の岸硅砂の上をかけまわりました。",
              "citation": {
                "source": "インドラの網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時向う岸ちかく、少し下流の方で、見えない天の川の水がぎらつと光つて、柱のやうに高くはねあがり、どおと烈しい音がしました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニはもうはねあがりたいくらゐ氣持が輕くなつて云ひました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ファゼーロはもう地図をもってはねあがりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファゼーロは、そっちへ挨拶するように両手をあげてはねあがりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは思わずはねあがりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔馬も悦んではねあがりました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
