    "definitions": [
      {
        "index": 1,
        "gloss": "to begin to run",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、くるっと踵を返して走り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊も後から走り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次急に足を早めて侍を追い越すとその儘走り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃと一同そろって走り出す。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次がヨーイ・ドンと手を叩くと、　二人別々の道から走り出す。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車が景氣よく走り出す、函嶺諸峰は奧ゆかしく、嚴かに、面を壓して近いて來る！",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして全速力で走り出す。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西生まれの道化人形は英国生まれのねむり人形と一緒にそのあとから走り出す。",
              "citation": {
                "source": "キューピー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「由」が轅棒を上げて走り出すと、いつの間にか皆のうしろに来て居た老犬のくまが、わん、わん、吠えてあとを追った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "用事はないのだから、ゆつくりゆつくり行けばよいのだが、町の人に見られると體裁が惡いので、自然何か買物にでもゆくやうな風をして走り出すのである。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラガラガラガラガラガラ、走り出す。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏頭が莫迦に光る、それかと言つてくわつと光つた外光の中に何かしら厭な陰気さが嘲笑つてでもゐるやうに、赤い鶏頭が眼に染みる、茎が戦ぐ、その根元から小さい蜥蜴が走り出す。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、庄平は殿りより、のろ／＼とスタートして走り出す。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」葉子「裏の休閑地にいますの、呼んで来ましょうか」庄平「いや、遅れるといけませんから、後でまた」庄平、走り出す。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は言伝を書いて、ホイットニの利用料を払い、数分のうちに馬車まで連れて行って、夜のなかへ走り出すのを見送った。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも走り出すと急に顔は引っ込んで、まるで不意に部屋の闇の中へ引っ張られたみたいでした。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして俥が走り出すと同時に、強く抱きしめた。",
              "citation": {
                "source": "秋は淋しい",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、流石に私の聲を聞いて走り出すまでにはならなかつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "桃の實",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして池田さんが死によって取り落としたバトンを拾い上げ、一企業の占有技術によらざる標準の確立に向けて、誰かが走り出すべき時が否応なく訪れることは、歴史の力学によって決められていたのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡ゆる部分々々の留釘を換へ、錆を落し、油磨きをかけて組立直して見ると、何とまあこの千八百年代の新型自転車は再び春に回り合つたのを微笑むかのやうにれきろくとして走り出すではないか。",
              "citation": {
                "source": "写真に添えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中で家のほうへ走り出すころに、海のほうは蒲団を拡げたように腫れながら光っていて、雷鳴と電光が襲うてきた。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、写真班の一人が叫んで、走り出すと、皆は風声鶴唳と云う有様で、バタ／＼と下車しかけて居る乗客を押しのけながら、列車の後方を目がけて駆け出しました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏とくと見澄ました体で、いよいよ犬が鮮やかに見えて来たというので、狐それでは僕は失敬すると走り出す。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "止つたかと思ふと直ぐに走り出す。",
              "citation": {
                "source": "お蝶の訪れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその附近の舟も一斉にその後を追ふやうに走り出すのでした。",
              "citation": {
                "source": "初夏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――止つたかと思ふと直ぐに車は走り出す、さうして彼がいざ降りようといふ決心が付いた、と同時に車は走り出す、奇妙に（と彼は思つた。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）車が走り出す瞬間と、彼が降りようと決心が付く時とが不思議にも間一髪も挿まぬ同じ瞬間なので、彼は降りる機会を見失ふやうな気がした。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "刹那に、バタバタとその影が走り出すと走り乍らけたたましく呼び子を吹き鳴らした。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、あんなに憎んでゐた堀田を忘れでもしたかのやうに慌てゝ一散に戸外に走り出すので森野も、その後を追つた。",
              "citation": {
                "source": "街角",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ってことで　はしりだす。",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
