        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "森の中で、子熊を連れた母熊に遭遇した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母熊は子供を守るため、必死に敵と戦った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "動物園で、餌を食べる母熊と子熊の姿が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "この母熊の肉は探険隊員のあまたの食卓をにぎわすと同時に隊員のビタミン欠乏症を予防する役に立った。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に子熊をつれた母熊を殺すのは、普通の三倍も、いや三倍の三倍も危険なことです。",
              "citation": {
                "source": "負けない少年",
                "author": "吉田甲子太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、子引き熊といつて、仔熊を連れてゐる母熊は、こいつは油断がならぬ。",
              "citation": {
                "source": "山形屋の青春",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
