        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "始めよりかれが恋の春霞たなびく野｜辺のごとかるべしとは期せざりしもまたかくまでに物さびしく物悲しきありさまになりゆくべしとは青年今さらのように感じたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れの末を打ち見やれば春霞たなびきたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば懶い駘蕩たる春霞の中にあって、十万七千の包囲軍はひしひしと犇き合って小田原城に迫って居る。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都特有の春霞のなかに、キラキラと澄んだ光で輝いている四条通の灯が山の上から眺められた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白く煙つた碧い海原には、もはや春霞がたつて、観音崎の出鼻から現れたアメリカ航路の船が、その乗員たちも一勢に空の戦ひを見あげてゐるだらう、とおもはれるやうに鈍い船あしに見えた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、春霞を衝いて沖合ひを走つてゆく艦隊の出動の光景を見損つたのを残念がつてゐた。",
              "citation": {
                "source": "岬の春霞",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクにでも乗つて、あてどもなく海岸通りなどをまはり、春霞みを衝いて出てゆく船を眺め、ゆつくりと支那料理屋にでも休んでから、夜はまたひとりでオデオン座の特等席になりとをさまつて、居眠りでもして来ようといふやうな、何とわたしには全く珍しい「好日」には違ひなかつたのである。",
              "citation": {
                "source": "好日の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚容は気抜けの余りくらくら眩暈して、それでも尚、この場所から立ち去る事が出来ず、廟の廊下に腰をおろして、春霞に煙る湖面を眺めてただやたらに溜息をつき、「ええ、二度も続けて落第して、何の面目があっておめおめ故郷に帰られよう。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも漸く岬の彼方に春霞みが立つて、間もなく聯合艦隊が出動すると噂がたつ頃には、あはれな銀笛の音も辛うじてわたしの口笛に合ふ程度になつた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔雀は星の様に美しい瞳――然も銀の雨に打たれてぼつと滲むだ春霞の底から瞶めるやうな美しさで――顔を上げました。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の夜の暖かい静かな室、春霞の軒に煙る浅春の宵――凝とたゞひとり机の前に坐つてゐると、大抵の方はこの法悦の気持に入ることが出来るだらうと思ひます――意味のない悲しさと悦ばしさとに感ずる淡い涙、支那の有名な詩人白楽天が「春宵の一刻価千金」と云つたのも、つまり「法悦」の喜びをうたつたのであります。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何か遥かなものばかりを眺めてゐるかのやうにいつも眼をうつとりとさせてゐるためか、白く切り立つた鼻筋の嶺の左右に据つてゐる眼は春霞に煙つてゐる湖のやうなひろさを感じさせた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「真夏の夜の夢」の、ひようきんな役者達のやうに馬鹿／＼しい夢を春霞みの深い森の中に置き去りにして――。",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄明な音声が、春霞みの中を走つて行くのが窺はれるかのやうな、小川とその三個の点景人物と、そして麦畑だけの広い、平らな風景であつた。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くモンマルトルの頂上の、サクレクールがかすかに春霞の中に浮んでいる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "野面は晝になつても尚ぼんやり霞んでゐて、花曇りか春霞みがもうやつて來たかと思はせるやうな日があつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「国歌の人を鼓舞して忠誠を貫かしめ人を劇奨して孝貞を竭くさしめ」云々「豈翅に花を賞し月を愛で春霞に思を遣り風鳥に心を傾くる」云々の数行、文章も変だが議論も変なり。",
              "citation": {
                "source": "人々に答ふ",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ春霞のため伯耆の大山が見えなかったのは残念でした。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗鞍以南は春霞で見えぬ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当年流行の新月色に、眼も眩ゆい春霞と、五葉の松の刺繍を浮き出させた裲襠。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "春霞何よりなるぞ桃桜瀬戸の万戸の陶器の窯　昭和四年四月尾張の瀬戸に遊んだ時の作。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは桃の花から立ち登るガス、桜の花から立ち昇るガス、葉もあらうかと思はれる焼物窯から立ち昇るガス、さういふものの合成したものがこの町の上に棚曳いてゐる春霞である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "小手を、かざして御陣原見れば武蔵｜鐙に、白手綱鳥毛の御槍に、黒｜纏指物、素槍で、春霞　益満の家から、益満の声で、益満の三味線で、朗らかな唄が聞えて来た。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "春霞、浅間の峯は、立ちなかくしぞ。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "春霞たなびきにけりと半行ほど来るうちに、どうも出が好くなかったと後悔し始めた。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歌と一しょに、「巻向の檜原に立てる春霞おほにし思はばなづみ来めやも」（巻十・一八一三）というのがある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○春霞ながるるなべに青柳の枝くひもちて鶯鳴くも　〔巻十・一八二一〕　作者不詳　春雑歌、作者不詳。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "春霞が棚引きわたるにつれて、鶯が青柳の枝をくわえながら鳴いているというので、春の霞と、萌えそめる青柳と、鶯の声とであるが、鶯が青柳をくわえるように感じて、その儘こうあらわしたものであろうが、まことに好い感じで、細かい詮議の立入る必要の無いほどな歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○射ゆしゝをつなぐ河辺の若草の（斉明紀）　………………認河辺の和草の（万葉巻十六）○はるがすみ春日の里｜爾殖子水葱（同巻三）　上つ毛野いかほの沼｜爾宇恵古奈宜（同巻十四）今日我々の持つ時間観念を含まずに、此に似た熟語を作つた場合は、沢山ある。",
              "citation": {
                "source": "形容詞の論",
                "author": "――語尾「し」の発生――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
