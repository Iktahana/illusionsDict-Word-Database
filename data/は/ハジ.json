[
  {
    "uuid": "6f833500-958d-5e0e-8f5b-a3c9cc102dfe",
    "entry": "恥",
    "reading": {
      "primary": "はじ",
      "alternatives": [
        "じょく"
      ],
      "is_heteronym": true
    },
    "grammar": {
