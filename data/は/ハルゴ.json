    "definitions": [
      {
        "index": 1,
        "gloss": "spring breed of silkworm",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
