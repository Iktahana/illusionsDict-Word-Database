        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "背低き櫨堤の上に樹ちて浜風に吹かれ、紅の葉ごとに光を放つ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その片陰に家｜数二十には足らぬ小村あり、浜風の衝に当たりて野を控ゆ。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ、そういえば、軒を渡る浜風が、さらさら水の流るる響。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月の半ば頃｜一日晩方の事……」　この時座敷｜寂として由井が浜風陰々たり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "館内には横浜風を粧う日本の美婦人あり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮟鱇坊主と、……唯今でも、気味の悪い、幽霊の浜風にうわさをしますが、何の化ものとも分りません。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者は大抵東京の海沿いから渡ったもので、下町らしい気分があり、波の音かと思われる鼓や太鼓が浜風に伝わった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜風が次第に勁くなつて来た。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　ゆだん大敵西　ゆうれいの浜風　東のは意義顕露なり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "梢に響く波の音、吹当つる浜風は、葎を渦に廻わして東西を失わす。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はまだ十六、七で、色こそ浜風に黒ずんでいるが、眉は濃く、眼は大きく、口もとはきっと引締まって、これに文金島田の鬘をきせたらば、然るべき武家のお嬢さまの身代り首にもなりそうな、卑しからざる顔容の持ち主であった。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜風がそよ／＼と吹いてゐましたので、私はうまく煙草に火がつけばいゝが、と思ひながらマツチをすりました。",
              "citation": {
                "source": "I Am Not A Poet, But I Am A Poet．",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "名手の弾く琴も何も聞き分けえられそうにない土地の老人たちも、思わず外へとび出して来て浜風を引き歩いた。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには妻や母や娘らが、寒い浜風に吹きさらされながら、うわさとりどりに汀に立って君たちの帰りを待ちわびているのだ。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白の股引に白足袋、尻端折のいそがしい横浜風の風俗の客や、異人の旦那を連れた洋妾風の女の客なぞが入って来る度に、捨吉は自分の腰掛を離れて、店のものの口吻を真似た。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは月見草などの蓬々と浜風に吹かれている砂丘から砂丘を越えて、帰路についた。",
              "citation": {
                "source": "蒼白い月",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには愛馬｜浜風が繋いであった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は浜風に少しは焼けているが、それでも生地は白いと見えて、浴衣の合せ目からチラと見える胸元は、磨ける白玉の艶あるに似たり。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねんねころ市おやすみなんしょ朝もとうからおきなされよいの浜風ア身にしみますで夜サは早よからおやすみよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねんねころ市おやすみなんしよ朝もとうからおきなされよひの浜風ア身にしみますで夜サは早よからおやすみよ……。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も芸妓、歌舞伎、落語、三味線、柳腰、の世界へ閉じ籠っていたいと思いますが、それでは何か、も一つ、私の心に大きな風穴が開いてしまって、その穴から何ともいい知れないところの幽霊の浜風が吹き込んでまいります。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "声はむなしく浜風に吹きさらわれた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "平板な河口の水面と、浜風が吹きならした白い砂っ原であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと熱海の漁場に揚がるあじ・いか・かれい・あまだいなど、さかなの種類も相当のものだが、干上がりの条件として、もってこいの浜風と気温に恵まれている点が、味をよくする最大原因となっているらしい。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "干ものの完成、これには気温と浜風の和合がなにより肝心だ。",
              "citation": {
                "source": "小ざかな干物の味",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツバキ吾妹子乎　早見浜風　倭有　吾松椿　不吹有勿勤　ツバキは椿である。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "色とりどりの旗差しものを浜風にはためかせながら、おめき叫んで攻め立てると、城の平家も防ぎ戦い、合戦は主力が激突して火の出るような、すさまじさに変った。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時代より前には、津軽では葛かずらの根の餅を、ハナモチといっていたこともある（率土が浜風）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
