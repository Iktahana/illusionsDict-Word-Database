    "definitions": [
      {
        "index": 1,
        "gloss": "long-handled Chinese spear bearing a small flag",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ラヂオは傳へる式殿の森嚴を、目もあやなる幢幡、銀の鉾射光の珠を。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "因齎詔書黄幢拜假難升米。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "天蓋には、瓔珞、羅網、花鬘、幢旛、仏殿旛等。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "七百年のうちに、竜樹、世にいでて、邪見の幢をくだかん。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の腹は巨万の富と一世の自信とを抱蔵してゐるかのごとく素晴らしく大きく前に突き出てゐて、一条の金の鎖が腹の下から祭壇の幢幡のやうに光つてゐた。",
              "citation": {
                "source": "頭ならびに腹",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて、幢を持った三人の宿禰が進んで来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）風通しのいゝ室で、竹婦人に靠れながら、棋局を闘はせてゐると、召使ひの※鬟が来て、「唯今、宝幢寺とかにゐると云ふ、坊さんが御見えになりまして、是非、御主人に御目にかゝりたいと申しますが、いかゞ致しませう。",
              "citation": {
                "source": "酒虫",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝幢寺にゐる坊主と云ふのは、西域から来た蛮僧である。",
              "citation": {
                "source": "酒虫",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその歌は寛に編めよと兄達の命じければ、父が若き頃より壮年に到る草稿を京都なる兄大圓より、晩年の詠草を周防なる兄照幢より乞ひうけて、読みもてゆくに、歌の数は長き短き打まじへて三万首に近からし。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "同三十年の冬、周防徳山なる子照幢のもとに遊び、翌三十一年六月より病を得、八月十七日午前三時に身まかり給ひき。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "京に来り、山崎氏を娶りて大圓、照幢、巖、寛、修の五男、靜子の一女を挙げられたり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大圓は和田氏を冒し、照幢は赤松氏を冒し、寛は家を襲げり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるはしく紅に白きをうちまぜて残る紅葉に初雪ぞ降る天霧ひ時雨の降れば狭丹づらふ紅葉は散りぬ山はさびしも日ならべて大雪ふれり奥山の松の木末も土につくまで膝を枕にわが命終らんと思ひし子の照幢を、明治十九年の春、周防徳山なる徳応寺の養子に遣すとて。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のかぜ花に吹くなりひと羽に千里おほはん大鳥もがも花守もこころ狂ひし人と見ん桜のもとに酔ひて寝たれば明治二十五年の秋、周防国徳山なる照幢の許に遊びにまかりける途中。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃の花したてる路を行けばかも垢つく衣も袖にほふらし大圓、照幢等の、老が身に事ふることのまめやかなるも嬉しく、はた仏の慈悲、天地のめぐみの深きをも喜びて、折折に詠める。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大圓もろともに仏の道をよろこびて後の世までも親子とや言はん照幢親といひ子といふも世のかり名にて入我我入のさとり楽しも寛親といへばなほ人の世のわかれなりまた遇ひ難き仏とぞ思ふ　　　訂正追加。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は早くから大和朝廷に於ける中央文化圈の佛教とは趣きを異にした別種の佛教、即ち印度教化した佛教の法幢を樹て、教權を布いてゐたのであらう。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女菩薩の幢を仰ぎますと、二人とも殊勝げな両手を合せて、わなわな震えながら、礼拝いたしました。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女菩薩の幢、墨染の法衣、それから十文字の怪しい護符、一目見て私の甥は、それが例の摩利信乃法師だと申す事に、気がついたそうでございます。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後にはいつもの女菩薩の幢が、秋の日の光の中にいかめしく掲げられて居りましたが、これは誰か供のものが、さしかざしてでもいたのでございましょう。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ひ見よ、幾千の山法師が、日吉権現の神輿を擁して、大法鼓をならし、大法螺を吹き、大法幢を飜し、咄々として、禁闕にせまれるの時、堂々たる卿相の肝胆屡※是が為に寒かりしを。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、シシリーに破れたるカルセーヂは、暫く蟄して大ローマの轅門に降ると雖も、捲土重来、幢戟南伊太利の原野に満ちて、再カンネーに会稽の恥を雪がずンばやまず。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "風なく搖らぐ法幢の、　暗き方へと靡くとき、　佛も寒く御座すらん。",
              "citation": {
                "source": "鬼哭寺の一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大法鼓を鳴らし、大法螺を吹き、大法幢を樹てて王城の鬼門を護りし昔しは知らず、中堂に仏眠りて天蓋に蜘蛛の糸引く古伽藍を、今さらのように桓武天皇の御宇から堀り起して、無用の詮議に、千古の泥を洗い落すは、一日に四十八時間の夜昼ある閑人の所作である。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣は普通の剣ぼこで、其と四神の違つてゐる点は、旗竿の頭の黒塗りの折敷様のものに四神の像を据ゑてゐる点で、下にはいづれも錦の幢を垂れてゐる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が下町の山車になると、柱の存在などは殆ど不明で、寧祇園の鉾に近づいてゐるが、多くの物はやはり人形の後に小さく、日月幢を立てゝ俤を止めてゐる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小子部栖軽が三諸山の神を捉へに行つた時は、朱蘿をつけ、朱幢を立てゝ馬を馳せた（霊異記）と言ふ。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良の寺々に樹て並べた外国風の幢幡は、見も知らぬ飛鳥・藤原の宮人の口などから、生れたものと思はれる。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は大体契沖の説だが、「青旗の木旗」をば葬儀の時の幢幡のたぐいとする説（考・檜嬬手・攷證）がある。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『日蓮ハ日本国ノ棟梁ナリ、予ヲ失フハ日本国ノ柱幢ヲ倒スナリ――』これは撰時鈔――」　白雲は再び小冊子をくりひろげて、いちいち書抜きを指点しながら、「ともかく、こういう真実性を持った巨人が現われて来ますと、凡俗は驚きますよ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
