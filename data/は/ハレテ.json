        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その日は土曜日で、朝からよく晴れていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空よく晴れて朝風やゝ肌寒く露の小萩のみだれを吹いて葉鶏頭の色鮮やかに穂先おおかた黄ばみたる田面を見渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえて西の空｜麗しく晴れて白砂青松に日の光鮮やかなる、これは水彩画にも譬うべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今朝汽車が出てしまって改札口へ引返すと同時に、なんだか気抜けがしたように、プラットフォームの踏心も軽く停車場を出ると空はよく晴れて快い日影を隠す雲もない。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三合四合と登るほどに、黒砂は凝結したように、ポロポロと硬くなって、時に生れどころの解らない大霧が、斜面を這って、煙のように舞い立つこともあったが、五合へ来たときには、それも拭うように晴れて、北風が起り初めた、鳶が一羽、虚空に丸く輪を描いて山体の半分を悠揚と匝ぐって、黒い点となって、遥かに消え失せた。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はもう半ば晴れていたが千切れ千切れの綿雲が嵐の時のように飛んでいた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにラストシーンがダレると困りますから、三四郎の立廻りをなるべく簡単にやって頂きたい）Ｔ「空晴れて風そよぐ――」Ｓ＝垂れ下った柳　静かな川の流れ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまじき晴れて来ますわよ」　小初が赤い小旗を振って先に歩き出すと、雨で集りの悪い生徒達の団体がいつもの大勢の時より、もっと陽気に噪ぎ出した。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄は子供の頃京城で結婚した女と別れて晴れてお前と夫婦になりたいと真剣だったぞ。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の午後――もう夕方近くになつて雨がからりと晴れて、雲切の間から夏らしく澄んだ紺青の空が見え出した。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空は名残なく晴れて朝日｜麗かに輝き、光る物には反射を与え、色あるものには光を添えて雑踏の光景をさらに殷々しくしていた。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "海陸風の原因が以上のとおりであるから、この風は昼間日照が強く、夜間空が晴れて地面からの輻射が妨げられない時に最もよく発達する。",
              "citation": {
                "source": "海陸風と夕なぎ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日はよく晴れて暑い日であった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝よく晴れていた空は、いつの間にかすっかり曇って、湿りを帯びた弱い南の風が吹いていた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは炭坑の底に働いている坑夫に、天気が晴れているのか暴れているのかが分らないのと同様である。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のもが／＼は、濃くなって、ぼんやりして来るかと思うと、また雲が散るように晴れて透き通って来たりした。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すっかり晴れて暑くなった。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二課業がすんでキッコがうちへ帰るときは雨はすっかり晴れていました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく晴れて結構ですな。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は大へんよく晴れて、風もしずかでございます。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて大学生諸君、その晩空はよく晴れて、金牛宮もきらめき出し、二十四日の銀の角、つめたく光る弦月が、青じろい水銀のひかりを、そこらの雲にそそぎかけ、そのつめたい白い雪の中、戦場の墓地のように積みあげられた雪の底に、豚はきれいに洗われて、八きれになって埋まった。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　空は晴れて月が出ていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、空は悲しいまで晴れていた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空よく晴れて一点の雲もなく、風あたたかに野面を吹けり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "空青く晴れて日影まばゆく、木も草もてらてらと暑きほどなり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲晴れても、雨は不断に降るであらう。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、川の幅一｜杯に、森々、淙々として、却つて、また音もなく落つる銚子口の大瀧の上を渡つた時は、雲もまた晴れて、紫陽花の影を空に、釣舟草に、ゆら／＼と乗心地も夢かと思ふ。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の樹たる見当へ首を向けて眼を遣ると、もう心安げになった蔵海がちょっと肩に触って、　あの音のするのが滝ですよ、貴方が風呂に立てて入ろうとなさる水の落ちる……といいさして、少し間を置いて、　雨が甚いので今は能く見えませんが、晴れていればこの庭の景色の一ツになって見えるのです。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼は清らかに澄み、その面は明らかに晴れていた。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また晴天には現われず「晴れては曇り曇っては晴れる、村雲などが出たりはいったりする日に限って」現われるとある。",
              "citation": {
                "source": "怪異考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
