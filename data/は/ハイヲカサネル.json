        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "故郷の友人と居酒屋に寄り、昔話に花を咲かせながらゆっくりと杯を重ねるひと時を過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美味しい地酒と旬の料理に満足し、気づけば自分でも驚くほど何度も杯を重ねていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お祝いの席だからといって、そんなに杯を重ねては明日の仕事に響きますよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "彼は大坂城がまったく暮れてしまった空に、まだところどころ真紅に燃え盛っているのを見ながら、それを今日の自分の大功の表章として享楽しながら、しきりに大杯を重ねるのであった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、四方山の話に杯を重ねるのであった。",
              "citation": {
                "source": "縁談",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで同行の士が珍しがって杯を重ねるとよろしくないので、「プレゼントだからと言って、いい気になって飲むのは日本人の恥だ」　と、たしなめた。",
              "citation": {
                "source": "すき焼きと鴨料理――洋食雑感――",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
