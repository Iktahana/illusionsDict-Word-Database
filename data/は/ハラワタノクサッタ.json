        "examples": {
          "standard": [
            {
              "text": "彼は「腸の腐った」人間で、人を利用することしか考えていない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そんな「腸の腐った」やり方で成功しても、本当の幸せは得られないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの政治家は、常に私腹を肥やすことばかり考えている、「腸の腐った」輩だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「裁許掛は、一人ではない」「左様、腸の腐ったのも居りましょう」「退れっ」　平は、怒鳴った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋の相手は売物の遊君、しかも腸の腐った女。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
