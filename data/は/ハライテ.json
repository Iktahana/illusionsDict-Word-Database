          "literary": [
            {
              "text": "行人欄に倚りて見るものあるも更に恥る色なく指頭に一物を拈って静に雫を払い手鼻をかんで笘の中に入る。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "袂のちり打はらいて空を仰げば、日脚やや斜になりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨月は法衣の塵をはらいて、にが笑い。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "野枝さんはらいてう氏の同情と理解によって、「青鞜」社員になって働いた。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして私はらいてう氏の感想を読んだ。",
              "citation": {
                "source": "人間と云ふ意識",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "心一たびその姑の上に及ぶごとに、われながら恐ろしく苦き一念の抑うれどむらむらと心にわき来たりて、気の怪しく乱れんとするを、浪子はふりはらいふりはらいて、心を他に転ぜしなり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
