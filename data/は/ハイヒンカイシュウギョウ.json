        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "出入りの廃品回収業者に『もう少し給料のええとこないやろうか？",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを教えてくれた廃品回収業者の話では月給は三円のはずだったのに、二円五十銭しかくれない。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "またビールの空びんや割れた皿などをこっそり廃品回収業者に売って小金をためる手も覚えた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがある日、すずのへちゃげた皿を廃品回収業者に売るところを、中国人の店員に見つかった。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃品回収業者のたて場から、ぼろ布を買って来る。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肇くんと光子　福田肇くんは二十七歳、なにがし私立大学中退だそうだが、いまはこしかけに廃品回収業をやっている。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夫婦は相沢七三雄という、屑鉄専門の廃品回収業者の二階に住んでいた。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "福田くんに廃品回収業の世話をしたのは、相沢七三雄であり、同時に自分の家の、空いている二階を提供したのであった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
