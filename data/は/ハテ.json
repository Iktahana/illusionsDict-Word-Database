    },
    "definitions": [
      {
        "index": 1,
        "gloss": "end",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これは校長が若い時分から、自分の生来根太い狡猾な性質に困り果てながら、聖賢の書を漁つた時に、始終心で云つてたことが、今生徒を前にした今、形を取つて表れて来たのである。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくては「統一」の要求は忘れ果てられるのみならず、昔日の粗朴ささへもが、はや「血迷つた粗朴さ」でしかないのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓より首さしのべて行手を見るに隧道眼前に水色｜縮緬を延べたらんごとく、遠山｜糢糊として水の果ても見えず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は西洋人も婦人まで草鞋にて登る由なりなどしきりに得意の様なりしが果ては問わず語りに人の難儀をよそに見られぬ私の性分までかつぎ出して少時も饒舌り止めず、面白き爺さんなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景と云うよりはただ何となくそぞろに荒れ果てた景色である。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時に於ける郭光の切腹して果てたことも謝源の心に何の反省も与へては呉れなかつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても此浦は平家の一門果て給ひたる所なれば痛はしく存じ、毎夜此磯邊に出でて御經を讀み奉り候。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」兎は輕蔑し果てたといふやうに、つんとわきを向いてしまつて、「助平の上に、また、食ひ意地がきたないつたらありやしない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と兎もさすがに呆れ果て、「めちや苦茶ね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ソロモン僕はもうバッハにもモツアルトにも倦果てた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの幸福な、お調子者のヂャズにもすつかり倦果てた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "川楊の大木が、嵐にも洪水にも抵抗し抜いて、力も何も尽き果てたというように、ぐったりと根こそぎに、岸から川の中へ打ち倒れているのを、橋代りにして渡ったが、向う岸に着くまでには、三度ばかり冷たい水の徒渉をしないわけには行かなかった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙突なども倒れかゝつたまゝになつて何となく荒れ果てた眺である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男が中学校の始業日で本所の果てまで行っていたのだが地震のときはもう帰宅していた。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、翁は、「命終のとき」　といって、従容とその親猪の牙にかけられて果てた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父さまは山中の猪の相撲場で、猪の仔の瓜わらべと遊び戯れているとき、猪の親に襲われ、牙にかかってお果てなされた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い獣神はいう「この乳を、あの方は、生に対しても根が尽き果て、さればといって死へも急げない、生けるものに取っていちばん遣り切れないときに飲めと仰しゃるんです。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の為め、自分を恋ひ慕ふの情にさいなまれたその結果、斯うやつれ果てたといふ憐憫の意識は、直ぐその後に頭に登つては来ましたが、いぢわるく一瞥の時の悪感につきまとはれてどうすることも出来ませんでした。",
              "citation": {
                "source": "恋愛といふもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、旅支度さえ充分でない上にすぐと悪漢達に追いかけられたりして、姫は全く不安と饑えとで、疲れ果ててしまったのでした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそんなことで、主人も私も東海道のことはすっかり忘れ果て、二人ともめいめいの用向きに没頭して、名古屋での仕事もほぼ片付いた晩に私たちはホテルの部屋で番茶を取り寄せながら雑談していた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、この言葉はまた、おまえ自身、頑な現実の壁に行き当って、さまざまに苦しみ抜いた果ての体験から来る自戒の言葉ではあるまいか。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの勇士達はこれからどこの国のどこの道の果てまで行くのであろうか。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先刻までは悲しみと疲れとにやつれ果てていた老母の顔が、さも嬉しそうに、今まで見たことのないほど嬉しそうにかがやいて見えるのであった。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよはいり切らなくなって吐き出し始めたら餅が一とつながりの紐になって果てしもなく続いて出て来たなどという話を聞かされたこともある。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い手術着を着た助手らしい男がしきりにあちこち歩き廻ってそれを助けてくれようとするのだが、一向｜利目がないので困り果てたところで眼がさめたのだという。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれでも海べに出ていちばん見飽かずおもしろいと思うのは、遠い沖の果てから寄せて来ては浜に砕ける、あの波でしょう。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の繰り言は果てしがない。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お通夜の人々は自分の仕振りに困じ果ててか、慰めの言葉もいわず、いささか離れた話を話し合うてる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一目逢いたかった……次から次と果てしなく思いは溢れてくる。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は当分毎日お墓へ参ります……」　話しては泣き泣いては話し、甲一語乙一語いくら泣いても果てしがない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
