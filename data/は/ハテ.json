[
  {
    "uuid": "a5498dbb-3f67-5ebd-8e96-5f98d1a30d0c",
    "entry": "果て",
    "reading": {
      "primary": "はて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
