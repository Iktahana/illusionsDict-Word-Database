    "definitions": [
      {
        "index": 1,
        "gloss": "biting louse (any louse of order Mallophaga)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "羽虫が飛び、甲虫が歩く。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜂すずめは花の蜜をたべ、かわせみはお魚を食べ、夜だかは羽虫をとってたべるのでした。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな羽虫が幾匹も幾匹もその咽喉にはいりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ああ、かぶとむしや、たくさんの羽虫が、毎晩僕に殺される。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」弧光燈にめくるめき、　　　　　　　羽虫の群のあつまりつ、川と銀行木のみどり、　　　　　　　まちはしづかにたそがるゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ今頃は無鉄砲な羽虫が沢山集ってぶっつかったりよろけたりしてゐるのだ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもやがて月が頭の上に出て月見草の花がほのかな夢をたゞよはしフィーマスの土の水たまりにも象牙細工の紫がかった月がうつりどこかで小さな羽虫がふるふ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに紫苑の花びらが羽虫のやうにむらがり飛びかすかに光って渦を巻いた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "微粒子のような羽虫がそんなふうに群がっている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝生まれて晩に死ぬる小さな羽虫があって、それの最も自然な羽ばたきが一秒に千回であるとする。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルムホルツは薄暮に眼前を横ぎった羽虫を見て遠くの空をかける大鵬と思い誤ったという経験をしるしており、また幼時遠方の寺院の塔の回廊に働いている職人を見たときに、あの人形を取ってくれと言っておかあさんにせがんだことがあると言っている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな虻だのべっ甲いろのすきとほった羽虫だのみんなかはるがはる来て挨拶して行くのでした。",
              "citation": {
                "source": "畑のへり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろな羽虫が本当にその火の中に飛んで行くのも私は見ました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽虫が水を摶つごとに細紋起きてしばらく月の面に小皺がよるばかり。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん羽虫が飛ぶのであろう折り折り小さな波紋が消えてはまた現われている、お梅はじっと水を見ていたが、ついに『幸ちゃんの話は何でした。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜘蛛も巣をかけはじめたけれども、その巣にはまだ犠牲になった羽虫がからまっているようなことはない。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから青や紺や黄やいろいろの色硝子でこしらえた羽虫が波になったり渦巻になったりきらきらきらきら飛びめぐりました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お日さん、ありがとうございました」　そしてちょうど星が砕けて散るときのように、からだがばらばらになって一本ずつの銀毛はまっしろに光り、羽虫のように北の方へ飛んで行きました。",
              "citation": {
                "source": "おきなぐさ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつと思へば、烏ほどの真黒な鳥が一羽虫蝕だらけの格天井を颯と掠めて狐格子をばさりと飛出す……　目一つ抉られては半身をけづり去られたも同じ事、是がために、第一の作は不用に帰した。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、死といえば蟻、螻蛄、羽虫になっても縷々と転生してしまう暢気極まる死です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明な芝草がよじれて引っちぎられて、飛び立つ羽虫のように飛んだ。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なつかしい円弧燈に真白なあの羽虫のたかるやうに細かなセンジユアルな悲しみが、向ふの空にも、橋にも柳にも、水面にも、書割のやうな遠見の、黄色い市街の燈にも、多分冷たくちらついてゐる筈だ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "聲はむしろ沈痛にさへしづんでゐた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川君の死去の報に接した時、自分はむしろ彼の前に、舌を噛んで慚死する恥を感じた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はむしに、ならないだらうか？",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（私はむしになるのだつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり詳しく言へば、彼等は眞の「科學人」となつたのでなくして、實にはむしろ「小理智人」「小常識人」となつたのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画よりはむしろ油絵の画題であろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか南画くさい、古い趣味の美文めいたあの辺の景色は、今日ではむしろ俗である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも別の事であるが流行あるいは最新流行という衣装や粧飾品はむしろきわめて少数の人しか着けていない事を意味する。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
