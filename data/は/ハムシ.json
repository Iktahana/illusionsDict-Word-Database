    "definitions": [
      {
        "index": 1,
        "gloss": "leaf beetle (of family Chrysomelidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
