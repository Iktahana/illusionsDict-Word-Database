        "examples": {
          "standard": [
            {
              "text": "昔ながらの花札屋には、珍しい花札の種類がたくさん並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、家業の花札屋を継ぐため、伝統的な花札の作り方を学んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その地域には、代々続く花札屋があり、今も手作りで花札を製造している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
