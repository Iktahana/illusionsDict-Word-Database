        "examples": {
          "standard": [
            {
              "text": "彼は、葉巻タバコを吸いながら、ビジネスの戦略を練っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "葉巻タバコは、通常のタバコよりもゆっくりと時間をかけて楽しむものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この葉巻タバコ、なかなか良い香りがするね。」と、彼は満足そうに言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "二十面相はその椅子のひとつに、ゆったり、腰をかけて、テーブルの上の金色の箱から、葉巻タバコをとって、金色のライターで火をつけました。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉巻タバコのいいにおいが、ポケット小僧のところまで、流れてきます。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
