        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、ぽんと鼻を鳴らすような咳払をする。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、第六の条項、深夜サンパンを船長の「私用」では漕がない、と言う点に至っては彼は鼻を鳴らすことをやめた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々｜咽喉でも締られるように、消魂しく※々と啼き立てる其の声尻が、軈てかぼそく悲し気になって、滅入るように遠い遠い処へ消えて行く――かとすれば、忽ち又近くで堪え切れぬように啼き出して、クンクンと鼻を鳴らすような時もあり、ギャオと欠びをするような時もある。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くない処で馬の鼻を鳴らす音も聞える。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くない處で馬の鼻を鳴らす音も聞える。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と情けない声で申したきり、さすがに今日は大鼻を鳴らすだけの元気も出ないと見えて、そのまま南大門の柱の根がたへ意気地なく蹲ってしまいました。",
              "citation": {
                "source": "竜",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、次郎の愛撫に身をまかせていたフハンが、両耳をキッと立てて鼻を鳴らすと、河岸を上手へ走った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "といままで、寝台の下におとなしくうずくまっていたフハンが、音高く鼻を鳴らすと、耳をピンと立て、目をいからして戸の外をにらみ、ひとほえすると、歯をむき立ててもうぜんとかけだした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてますます感心し「ふうん――」と鼻を鳴らすのであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し側から小供が咳をするその方へ注意が集る小供はピチヨ／＼と舌を鳴らし鼻を鳴らす。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ不意におそろしい顔をして見上げ、霧笛のように鼻を鳴らすだけだった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "退屈な乳牛共が板敷をコトコト踏みならす音や、ブブブブと鼻を鳴らすの、乾草を刃物で切る様な響をたてて喰べて居るのなどが入りまじって、静かな様な、やかましい様な音をたてて居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「釣りでもしてるのさ」　鮎子さんが、ふうん、と鼻を鳴らす。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知りませんね」　キャラコさんは、ふうん、と鼻を鳴らす。",
              "citation": {
                "source": "キャラコさん",
                "author": "雁来紅の家",
                "note": "青空文庫"
              }
            },
            {
              "text": "グツグツと獣の鼻を鳴らす音が奥からかすかに聞える。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（抱く）ミルは鼻を鳴らすが、しかし拒みはしない。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚北　　（後から振り返って、拳固で鼻を鳴らす）ちえッ、業平様のお通りに気が付きゃがらねえ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで押し殺した叫びが聞こえ、鼻を鳴らすようなむせるような音がし、何であれ開けた物を慌てて締めたようだった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかちょいと鼻を鳴らすとその場はごまかして。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん」「照れかくしだよ、あいつの」　鼻を鳴らすような発音をした。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前もそれか」　軽蔑したように鼻を鳴らす音がした。",
              "citation": {
                "source": "蜆",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルルルと鼻を鳴らす。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、フン、フン、と、鼻を鳴らす。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくの間坐りて居ればやがてまた頻に鼻を鳴らす音あり。",
              "citation": {
                "source": "遠野物語",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
