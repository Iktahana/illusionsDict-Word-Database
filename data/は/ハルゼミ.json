        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山の中では、もう春蝉が鳴いていました。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかに、春蝉は彼のかなしい感傷の小曲をうたいあげたのである。",
              "citation": {
                "source": "夏秋表",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のもっとも潤沢のこの一刻に、私は、忘れていた春蝉のことを思い出し、この虫とあれと考え比べた。",
              "citation": {
                "source": "夏秋表",
                "author": "立原道造",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しすると、松も交つてゐる裏の山の木立ちのあたりに、春蝉の鳴くのが聞えた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "春蝉――松蝉――初夏だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春蝉が鳴きだした、夏ちかい温かさだ。",
              "citation": {
                "source": "道中記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が強かつた、はじめて春蝉を聞いた、銀杏若葉が美しい、小倉警察署の建物はよろしい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "風の中から呼びとめたは狂人だつた・寝ころ□□はもう春蝉の二声三声四月廿六日　曇后晴、市街行乞、宿は同前。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて春蝉をきいた、だるくてねむくなる、五日ぶりに入浴、さつぱりした、しづかに読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "春空雲なくなまけものとしなまけてゐる・春蝉もなきはじめ何でもない山で・裏からすぐ山へ木の芽草の芽・けふも摘む蕗がなんぼでも・みんな芽ぶいてゐる三日月・三日月さんには雲かげもなくて　四月廿九日天長節日和とでもいはうか、まことにのどかな日だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかれ霜を気遣うたは昨日の様でも、最早｜春蝉が鳴き出して青葉の蔭がそゞろ恋しい日もある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春蝉らしいものが鳴き出した、河鹿の声に似ているが更に細く幽で、透き徹るようにほがらかだ、森の精が歌っているのではなかろうか。",
              "citation": {
                "source": "渓三題",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "林の奥では蝦夷春蝉が雨の降り灑ぐように鳴いている。",
              "citation": {
                "source": "渓三題",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛する神の歌父が洋杖をついて、私はその側に立ち、新らしく出来上つた姉の墓を眺めてゐた、噴水塔の裏の木梢で、春蝉が鳴いてゐる。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "軈て志す處に達すると忽ち春蝉がかぶさるやうに鳴いてゐて、涼しい風が松を透かして落ちて來るのであつた。",
              "citation": {
                "source": "横山",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして空も海もただ眼に入る限りは青々とした一色の中に、泛んでいる船もなければ島影一つもなく、眼を遮るものとてはただ春蝉の啼きしきっているこの断崖の上に俯瞰したひょろ高い赤松の梢だけであった。",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきまで、はるぜみが、どこかで鳴いていました。",
              "citation": {
                "source": "草を分けて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの、やさしい声のはるぜみをつかまえたいな。",
              "citation": {
                "source": "草を分けて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジイー、ジイーといって、すぐ近くで、はるぜみの鳴く声がしました。",
              "citation": {
                "source": "草を分けて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "貝がらのような蛾、赤い茸、おはぐろとんぼ、いい声で唄をうたうはるぜみなど。",
              "citation": {
                "source": "草を分けて",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
