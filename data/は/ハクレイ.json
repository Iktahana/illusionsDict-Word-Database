        "examples": {
          "standard": [
            {
              "text": "彼女は将棋の白玲戦で初のタイトルを獲得した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "白玲の称号は、女流棋士にとって最高峰の栄誉だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今年の白玲戦の決勝は、若手とベテランの対決となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "巖の中より滴るしづく、滴り／＼て、凍りて大氷柱をなし、小龕をかこみて、白玲瓏たり。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれよと、仰ぐうちにも、焔の首は黒煙をつらぬいて、どこまでもどこまでも昇天して行き、やがて、その赤きもあまりに遠ざかって薄れたかと思うと、白玲瓏たる十五夜の月が、下界を嘲笑うかのように満々と雲間にかかっていた。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
