    "definitions": [
      {
        "index": 1,
        "gloss": "first flower of the season or year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれが躄勝五郎の物語で有名な初花の滝さ」　少しわき道をして慶四郎は、千歳に滝を見せたりした。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○四月、新富座にて「天衣紛上野初花」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまゝ佇んで、しめやかな松の初花の樹脂｜臭い匂ひを吸ひ入れながら、門外のいさかひを聞くとも聞かぬともなく聞く。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の長崎にて見し紅化粧したる天女たちとは事変り、その物腰のあどけなさ、顔容のうひ／＼しさ、青葉隠れの初花よりも珍らかなり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当日の模様、物珍らしきまゝに、われも竹矢来の外の群集に打ちまじりて見物するに、今しも丸山一の大家、初花楼の太夫職にして、初花といふ今年十六の全盛なる少女が、厳めしき検視の役人の前にて踏絵を踏む処なりとて人々、息も吐きあへず見守り居る体なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初花太夫は全盛の花魁姿。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍の下役人左右より棒を構へ、声を揃へて大喝一声、「踏めい……踏み居らぬか」　と脅やかすに初花は忽ち顔色蒼白となりつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "母しやま／＼と悲鳴を揚げつゝ竹矢来の外へ引かれ行けば、並居る役人も其の後よりゾロ／＼と引上げ行く模様、今日の調べはたゞ初花太夫一人の為めなりし体裁なり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の初花楼の主人｜甚十郎兵衛と申す者。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ初花太夫は母御の病気を助け度さに身を売りしものにて、この長崎にても評判の親孝行の浪人者の娘に候。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に引比べて初花楼の主人甚十郎兵衛こそ日本一の愚者にて候へ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこしばかりの賄賂を吝しみし御蔭にて憐れなる初花太夫は磔刑か火焙りか。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "音に名高き初花楼も取潰しのほか候まじ」　と声をひそめて眼をしばたゝきぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて其｜後、程もなく初花楼の初花太夫が稲佐の浜にて磔刑になるとの噂、高まりければ、流石の鬼畜の道に陥りたるわれも、余りの事に心動きつ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ五人の中央に架けられたる初花太夫が、振り乱したる髪の下にてすゝり上げ／＼打泣く姿、此上もなく可憐らしきを見るのみ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その左の端に蓬たる白髪を海風に吹かせつゝ低首れたるは初花の母親にやあらむと思ひしに、果せる哉。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央の床几より立上りたる陣羽織物々しき武士が読み上ぐる罪状を聞くに、初花の母親が重き病床より引立てられしもの也。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、初花の右なる男は初花楼の楼主。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "左なる二人の女は同楼の鴇手と番頭新造にして、何れも初花の罪を庇ひし科によりて初花と同罪せられしものなりと云ふ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初花楼に対するお役人衆の憎しみの強さよと云ふ矢来外の人々のつぶやき、ため息の音、笹原を渡る風の如くどよめく有様、身も竦立つばかりなり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて捨札の読上げ終るや、矢来の片隅に控へ居りし十数人の乞食ども、手に／＼錆びたる槍を持ちて立上り来りアリヤ／＼／＼／＼と怪しき声にて叫び上げつゝ初花太夫を残したる九人の左右に立ち廻はり、罪人の眼の前にて鑓先をチヤリ丶／＼と打ち合はし脅やかす。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、今まで弱げに見えたる初花、磔刑柱の上にて屹度、面を擡げ、小さき唇をキリ／＼と噛み、美しく血走りたる眥を輝やかしつゝ乱るゝ黒髪、颯と振り上げて左右を見まはすうち、魂切る如き声を立てゝ何やら叫び出せば、海を囲める数万の群集、俄にピツタリと鳴りを静め、稲佐の岸打つ漣の音。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此の長崎で皆様の御ひいきを受けました初花楼の初花と申す賤しい女で御座りまする。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初花の言葉は此処にて切れ／″＼に乱れ途切れぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ初花は全く身に大波を打たせ、乱髪を逆立たせ渦巻かする大苦悶、大叫喚のうちに、「……母しやま……済みませぬツ」　と云ふ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
