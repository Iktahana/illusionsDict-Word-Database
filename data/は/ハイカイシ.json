    "definitions": [
      {
        "index": 1,
        "gloss": "writer of haikai poems",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なぜならば、おまえはわたしの生涯の外面的なるものを知り、洒落の風流人で江戸っ子気質で、ソレ者で通人と言われ、ときには放埒無慙の人物のようにも見えている中年過ぎの俳諧師が脱然、胸を断ち割って動く本心の心臓を見せたからだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十年ばかり前に俳諧師が建てたというね。",
              "citation": {
                "source": "狐",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "取巻は河原崎座の作者岩井紫玉、同座附茶屋の主人武田屋馬平、品川の幇間富本｜登名太夫、同熨斗太夫、桜川善二坊、その他俳諧師｜牧乙芽、力士｜勢藤吾等であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "王侯貴人が往々文芸の士を羅致して、声威を張り儀容を飾る具となすように、藤次郎は俳諧師、狂歌師、狂言作者、書家、彫工、画工と交って、その多数を待つことほとんど幇間と択ぶことが無かった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧師には既に挙げた為山、永機の外、鳥越等栽、原田梅年、牧冬映、野村守一がある。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "源之助の番頭新造が吉六の俳諧師東栄の胸倉を取っている。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら俳諧師だといって、昼顔の露は吸えず、切ない息を吐いて、ぐったりした坊さんが、辛うじて……赤住まで来ると、村は山際にあるのですが、藁葺の小家が一つ。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の俳諧師、雪中庵の門人、四五輩。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁打ちになる、俳諧師になる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたに伺ったら判るだろうと思うのですが、几董という俳諧師はどんな人ですね」　時は日清戦争後で、ホトトギス一派その他の新俳句勃興の時代であたから、わたしもいささかその心得はある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧師の庵というだけに、家の作りはなかなか風雅に出来ていたが、其月の宅は広くなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によると、其時君は既に紅葉の門に入つてをり、脚気を患つて帰郷してゐた時であつたか、或はまだ一度も上京しない前であつたか、其の点は詳かでないが、俳諧師のやうに道行を着てゐたことが、記憶に残つてゐる。",
              "citation": {
                "source": "亡鏡花君を語る",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "今残つてゐるかれの画像の法体は、単に俳諧師又は幇間と言ふ風に私には見ることは出来なかつた。",
              "citation": {
                "source": "西鶴小論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "片野の主人は、町役場の質素な吏員だが、若い頃少しばかりの道楽者で主に江戸に住んで浮世絵師や俳諧師と親しみ、江戸つ子の渇仰者だつたから、無性に園と話が合つた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう訳でしたから、書家とか画家とか俳諧師という人たちが北国の方へ旅まわりして来ると、きっとわたくしの家へ草鞋をぬぐのが習いで、中には二月も三月も逗留して行くのもあったといいます。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりは名古屋の俳諧師で野水といい、ひとりは江戸の画家で文阿という人で、文阿の方が二十日ほども先に来て、ひと月以上も逗留している。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも申上げた通り、わたくしの家には俳諧師の野水と画家の文阿が逗留していまして、野水はそのとき近所へ出ていて、留守でした。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母も店へ出て大勢の話を聴いていますと、奥から俳諧師の野水が駈け出して来まして、誰か早く来てくれというのです。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪花の町はづれ、俳諧師鬼貫のわび住居。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方より俳諧師鬼貫、四十餘歳、導引のこしらへ、頭巾をかぶりて破れたる傘をさし、足駄をはきてとぼ／＼と歸り來る。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思へばこそ家代々の祿をすてゝ、自分の好きな俳諧師にもなつたのだ。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方より俳諧師路通、三十餘歳、乞食の姿にて破れたる菰をまとひ、古手拭をかぶりて出づ。",
              "citation": {
                "source": "俳諧師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どくだみ７・14（夕）　むかし京都の島原に五雲といふ俳諧師が居た。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（蕪村が宵つ張なのに何の不思議もない筈だ、彼は画家であると共に、夜更しが附物の俳諧師でもある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば俳諧師でなかつたにしたところで、文部留学生の洋画家が、昼間はカルチエル・ラタンの居酒屋と球突屋で暮し、夜になつて漸と絵具箱を担ぎ出すのが多いのを見ると、蕪村にしても夜｜画をかいたかも判らないのだから。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに歌咏みだの、俳諧師だのといふ輩は人殺しの口からでもいゝ、相手が自分と同じ風流人である事を聞くのを、何よりも嬉しく思つてゐるものなのだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟師の姿が見えなくなると、猿公は俳諧師の鳴雪翁のやうな（忘れてゐたが、鳴雪翁も猿きちと同じやうに四国生れである）新派か旧派かどつち附かずの顔をにこにこさせて、直ぐ戸棚に入つて来る。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧師の頓智12・19（夕）　いつ頃だつたか、一寸はつきり判りかねるが、長崎に素行といふ俳人があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうど冬の最中で、寒さは無遠慮に俳諧師の背筋から懐中から入つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳諧師は石のやうに冷い拳をあげて門の戸を叩いた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
