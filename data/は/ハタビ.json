        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "・ふるつくふうふう逢ひたうなつた　　　再録・誰かきさうな雪がちらほら・落葉ふんでは枯木をひらふあたゝかさ・雀おどるや雲かげもなし・ちようど酔のでたところが墓地で梅のさかり　二月十一日旗日も祝日もあつたものぢやない、身心の憂欝やりどころなし、終日臥床、まるで生ける屍だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアの旗日　コツ、コツ、コツ………………。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺だちはお互に起床のときと、就寝のときと、飛行機が来たときと、元気なときと、クシャンとしたときと、そして「われ／＼の旗日」のときに壁を打ち合った。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ブルジョワ階級が色んな「旗日」を持っているのと同様に、もはや今では日本のプロレタリアートも自分自身の「旗日」を持っている！",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは隣りの同志が実によく「われ／＼の旗日」を知っていることである。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと気がつくと、何かの旗日だと見えて、頭の上に米国の国旗が一つ動いてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空をわたりゆく鳥へ寝ころんでゐる　春たけた山の水を腹いつぱい・晴れきつて旗日の新国道がまつすぐ・けさも掘る音の筍持つてきてくれた・摘めば散る花の昼ふかい草・送電塔が山から山へかすむ山　四月三十日曇、をり／＼雨、夕方からどしやぶり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとを……旗日だってったら、証拠を見せろだって手なんぞ出しやがって……チェッ！",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜とたまの旗日には、それが、「さあ最う起きて頂戴」に變る丈であつた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まあそんなものです」「じゃ旗日にだけ突いて出るの」　敬太郎は一人で二人に当っているのが少し苦しくなった。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小林翁に招かれて野口の生家を訪うたのは九月二十四日の旗日であつた。",
              "citation": {
                "source": "野口英世博士の生家を訪ひて",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜とたまの旗日には、それが、「さあもう起きてちょうだい」に変るだけであった。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に見えない旗日があった。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たしか、瀬川の御友達のかただったと思うんですけれど……わたしは御存じないんです」　きょうが目には見えない女と子供のひとつの旗日であったように、誰の目にも見えないカドリールの輪がある。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、かやは旗日でもないのに何を思いついたのか、赤飯を炊くことを孫たちと約束した。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は旗日で、家の玄関の前に国旗が掲げてあったのを覚えている。",
              "citation": {
                "source": "生い立ちの記",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将張飛も最大な敬意と静粛をもって、出迎えの兵を閲し、黄旗青旗｜金繍旗日月旗など、万朶の花の一時にひらくが如く翩翻と山風になびかせた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように夏｜稼ぎの水泳場はたびたび川筋を変えたが、住居は今年の夏前までずっと日本橋区の小網町に在った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れて、雪の中に倒れ、そのまま凍死してしまう者があるのを松木はたびたび聞いていた。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌女代は若いに似合わない奇特な人で、墓まいりにはたびたび来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "召使はたびたび出代りをしてゐるから一々に記憶してゐないが、近い頃にそんな名前の女を抱へたことはないと云つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、だんだん聞いてみると、まったく今朝ばかりじゃあねえ、この頃はたびたび鶏を取っていく奴があるそうですよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "監獄へこそ行かなかったが、警察へはたびたび呼びつけられていた。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "役員はたび／＼見まわりに這入って来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キッコの机はたびたび誰かにぶっつかられて暗礁に乗りあげた船のようにがたっとゆれました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちの雪はかたまってはゐましたがでこぼこでしたから馬はたびたびつまづくやうにしました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちはだんだんのぼりになりつひにはすっかり坂になりましたので楢夫はたびたび膝に手をつっぱって「うんうん」とふざけるやうにしながらのぼりました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎はたびたびうしろをふりかへってはゐましたがそれでも楢夫はおくれがちでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　喬はたびたびその不幸な夜のことを思い出した。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色の蛙はあとあしで砂をけとばしましたので、あいてはたびたび目玉から砂をはらわねばなりませんでした。",
              "citation": {
                "source": "二ひきの蛙",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
