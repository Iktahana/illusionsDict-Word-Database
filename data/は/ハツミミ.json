    "definitions": [
      {
        "index": 1,
        "gloss": "something heard for the first time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
