      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "eight hereditary titles (designated by Emperor Tenmu in 684 CE: Mahito, Ason, Sukune, Imiki, Michinoshi, Omi, Muraji, Inagi)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "平野の神社も八姓の神樣の合祀と言はれて、源氏もあれば平家もあり、何もかも皆取込んで、大凡京都に居る名族の人達は皆平野神社に詣らなければならぬやうに仕組んである。",
              "citation": {
                "source": "近畿地方に於ける神社",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで其の頃出來た八姓の神といふ説でありますが、今日ではどの位の程度で平野神社といふものを考へて居るかと申しますと、斯ういふ鐵道院の方で書いた本に出て居ることも好い加減のものであります。",
              "citation": {
                "source": "近畿地方に於ける神社",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "古え八姓の首に真人というのがあった。",
              "citation": {
                "source": "「ケット」と「マット」",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サン　　さ、拔いたわ、鬪爭を買はっせい、尻押をせう。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレ　　（サンプソンに對ひ、小聲にて）勝つわいと言はっせい。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
