        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところで私のように長い病気で久しく仕事をしないで生きているものはそれではその逆で自然が仕事が出来るまで長命さして呉れるだろうか、あるいはながいき出来そうな気もする。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はながい間じいっと眼を放さずにその窓を見ているのです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はながい間ある山間の療養地に暮らしていた。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うさぎのみみはながいけど　うまのみみよりながくない。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うさぎのみゝはながいけど　うまのみゝよりながくない。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと窓があいたとおもうと、王女はながい白マントの上に、まっ黒なつばさをつけて、ひらりと舞い上がりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その雲よりももっとはやく、野のはくちょう」は底本では「はくちょう」］のむれが、それはながい、白いうすものが空にただようように、しずんで行く夕日を追って、波の上をとんでいきました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはながい間どんなにわしを愛してくださったろう。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その力によってゴーリキイはながい歴史の波瀾の間に自分自身の結合せらるべき意志はどういうところにあるかということを理解した。",
              "citation": {
                "source": "私の会ったゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし伝統の日本髪の歴史はながいから、まだ若い女性の内部には、その香りが残っていると見えて、お正月とか節分、お盆になると、ふるさとの髪、日本髪を結う娘さんのいるのは嬉しいことである。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "元三爺はながい間そのまま失神したように身動くことも忘れていた。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "外はながい雨である。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "重吉は煙草だけは配給を貰ひそこねてゐるので、新しい紙卷の煙草はながい間の魅力であつた。",
              "citation": {
                "source": "なぐさめ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符は赤、黄、水色、白――電車はながい。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――――」　安倍誠之助はながい上体をおしのばして耳に掌をあてた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、帰って来た堀大主典にとって、このことはながい間腹の底に積み重ねていた憤げきに火をつけたことであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しめきつてある戸の前で、シロはながいあひだまちました。",
              "citation": {
                "source": "シロ・クロ物語",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはながい間風呂敷に包んでいたので、どこか損じたところでもありはせぬかと案じたためだった。",
              "citation": {
                "source": "抱茗荷の説",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはながい間、一体なにをしていたのだろうか。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このねだんをきめるまでに、源一はながいこと考えた。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして席につくと、すぐさま二人の方へ顔をむけて、「まだまだ、道中はながいから、お前たち、こっちの寝室へいって、ねてきなさい」　と早口で言った。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その跡、私はながいこと、灯をそむけたまま、薄暗いなかに、ひとり目をつむっていた。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はながい間じッと耳を澄して聞いていた。",
              "citation": {
                "source": "親ごころ",
                "author": "モオパッサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "稿本は頁のまはりに朱色の子持枠がひいてあり、一方の頁の下部には小姓風の若侍が、一方の頁の上部にはながい袂で顏をかくした、頭をかんざしでいつぱいに飾つてゐる姫樣の繪があつて、一つの情景が釣合よく描かれてゐる。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それにはながい話があるんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはながい間、胸にたまっていた思いをケンプ博士にうちあけて、ほっとしたのか、ゆったりといすに腰かけて、たばこに火をつけた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはながい間その前に立っていたが、ついにＹ氏の後援のもとに壇上にのぼり、台座に描かれている壁画式の画をつまびらかにながめた。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木立が影をひく、蒼白い路のうえに立って、二人はながい接吻をした。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　磯崎の葬式がすんで二日めの午後、マダム・ラゴンデールの授業をうけるために帰ったホテルの屋根裏部屋で、伸子はながいこと一人でいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、二人はながいことだまって、ホテルの室のバルコンのところに坐っていた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
