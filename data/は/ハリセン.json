      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "paper-covered folded fan used in noh and storytelling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "能の演目では、登場人物の感情表現に張り扇が効果的に使われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "講談師は、張りのある声で語りながら、張り扇をパチンと鳴らして調子を取る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この時代の落語家は、小道具として張り扇を巧みに操っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "くりくり坊主の桃川如燕が張り扇で元亀天正の武将の勇姿をたたき出している間に、手ぬぐい浴衣に三尺帯の遊び人が肱枕で寝そべって、小さな桶形の容器の中から鮓をつまんでいたりした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時ふつと此へ這入ると、正面高座に、おまはりさんの兄と言つた一山だか、一口だかゞ控へて居て張り扇を叩いて居た。",
              "citation": {
                "source": "寄席の夕立",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちみち彼は、さんざん丁稚に威張りちらして、自分と玄内の二人が先日の晩、七人の浪藉者を手玉に取った経緯を、「見せたかったな、」を間へ入れては、張り扇の先生そのままに、眼を丸くしている子供へ話して聞かせた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃はいつなんめり元治元年は夏の頃、まずこの辺で張り扇が欲しいとこだ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊はやはりせんの男の子にあいました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、戸だなの中から、昨夜買った金銀の小判を取り出してみようとしますと、また、いつ変わったものか、やはりせんべいの小判であったのであります。",
              "citation": {
                "source": "金銀小判",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中にわれ文章をつづらんにもの懶くあぢはひ悲しければけふもヒツポドロムを見にきたりつ、そのなかに空わたりするマテニと云へる露西亜のをんなのありき、肥えたるからだに肌衣を着け露き出しの手と足とをもておのれ空中を泳ぎまはりせん方もなく危なげに悲しくぞ見ゆ。",
              "citation": {
                "source": "忘春詩集",
                "author": "忘春詩集",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "paper fan used in slapstick comedy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "舞台上のコメディアンが、張り扇で顔を叩くギャグは定番だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "時代劇のドタバタシーンで、張り扇がコミカルな効果を生み出していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「はい、これ！」と、芸人が張り扇を小道具に観客に投げかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
