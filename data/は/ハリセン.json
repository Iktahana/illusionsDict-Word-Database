    "definitions": [
      {
        "index": 1,
        "gloss": "paper fan used in slapstick comedy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "お笑い芸人が使うハリセンは、大衆演劇などでもお馴染みの小道具だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "テレビ番組で、失敗した出演者がハリセンで叩かれるのを見て、大笑いした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう、ハリセンで叩きたい！」と思うほど、彼の失態はひどかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "母国を叩く師匠のハリセンの音が、高くパーンと響くたび重苦しいしこりの一角がぼろっと崩れ落ちて胸のつかえがとれる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
