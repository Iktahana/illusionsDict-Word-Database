        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえ興行者のほうでは芝居のつもりであったとしても、動物のほうでは芝居気などは少しもない正真正銘の命がけの果たし合いだからである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神的にこれとよく似た果たし合いは人間の世界にもしばしばあるが、不思議なことにはこういう種類の決闘は法律で禁じられていない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンバラの果たし合いでも安芝居の立ち回りの引き写しで、ほんとうの命のやりとりらしいものはどこにも求められない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲秋三五の月「おお、果たし合いか！",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夏彦様夏彦様、果たし合いにお勝ちくださりませ！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋しい夏彦は帰らずに、名ばかり許婚の宗介が果たし合いに勝って帰って来たのだ。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小梅田圃では意外のことから、せっかくの果たし合いが中折れ致した。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩のどんづまりは果たし合い！",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺すか殺されるかの土壇場に立って血を流して果たし合いをする。",
              "citation": {
                "source": "闘牛",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "果たし合いましょうぞ！",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いあたりに人はなし、果たし合いにはもってこいの森でござる。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士が恥辱をそそぐ法は一つしかないはず」「果たし合いをしろ、後見はわれらが引き受けるぞ」「心得た。",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝九郎はおどろいて手をふり、「これはめいわく、どうぞおまちください」「この期におよんでまてとは――なにごとだ※」「おわびはいかようにもつかまつる、果たし合いだけはひらにごかんべんねがいたい、ひらに――」「ならん、貴公も武士なら刀のぬきようぐらいは存じておろう、さあこい！",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたしあいにでもまけて切られたのだろう。",
              "citation": {
                "source": "怪しの館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴力と暴力のはたしあいでした。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "会の帰り、甚吾左衛門は十郎兵衛にこっそりはたしあいを申し込んだ。",
              "citation": {
                "source": "寛永相合傘",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、寺中、はたしあいもいいがつまらんではないか。",
              "citation": {
                "source": "寛永相合傘",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じつはまえからいちどお耳にいれようと思っていたのですが」と伊平次は低い声で云った、「織部どのと西沢とのはたしあいには不審な点があるのです」　隼人は伏し眼になり、ぐっと顎をひき緊めたが、なにも云わなかった。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれが江戸で受取った兄の手紙だ」と隼人は云った、「日付は十二日、はたしあいをする五日まえに出したものだ、読んでくれ」　帯刀は手紙を披いた。",
              "citation": {
                "source": "ちくしょう谷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……相手は森田久馬という、あの酒の強い男だった、ふじむらを出て二軒ばかり呑み、鳥羽へ帰る積りで五十鈴川を渡った、その渡し舟の中で喧嘩になり、向うへあがった草原ではたしあいをした、そして彼は久馬を斬ったのである。",
              "citation": {
                "source": "初蕾",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　春木氏は、まるではたしあいでもするような、おそろしく力のこもった声でたずねました。",
              "citation": {
                "source": "少年探偵団",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二十面相が、はたしあいのような声でいいました。",
              "citation": {
                "source": "青銅の魔人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
