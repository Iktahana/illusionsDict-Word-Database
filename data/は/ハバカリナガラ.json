        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "畫と數學となら、憚りながら誰でも來いなんて、自分も大に得意がつて居たのである。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "画と数学となら、憚りながら誰でも来いなんて、自分も大に得意がっていたのである。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、それだっても無銭じゃあいけねえよ、憚りながら神方万金丹、一｜貼三百だ、欲しくば買いな、まだ坊主に報捨をするような罪は造らねえ、それともどうだお前いうことを肯くか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら平吉売らないね。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞしかし、湖畔五｜里余り、沿道十四｜里の間、路傍の花を損なはず、樹の枝を折らず、霊地に入りました節は、巻莨の吸殻は取つて懐紙へ――マツチの燃えさしは吹き消して、もとの箱へ納めましたことを憚りながら申し出でます。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら未だ三十二で御座る。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升｜徳利をぶらさげて先生、憚りながら地酒では御座らぬ、お露の酌で飲んでみさっせと縁先へ置いて去く老人もある。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一升徳利をぶらさげて先生、憚りながら地酒では御座らぬ、お露の酌で飲んでみさっせと縁先へ置いて去く老人もある。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬は少し憚りながらも、まじまじとおぬいさんを眺めなおさずにはいられなくなった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫っけらの眼から贅沢水を流す様な事をして居やがって、憚りながら口幅ってえ事が云える義理かい。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……其の黒繻子に、小辨慶の藍と紺、膚の白さも可いとして、乳房の黒子まで言ひ當てられました、私が其の時の心持、憚りながら御推量下さりまし。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "處を惣領が甚六で、三男が、三代目の此の唐やうと來た日には、今はじまつた事ではなけれど、親たちの迷惑が、憚りながら思遣られる。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら御亭主は鉄道馬車の馬糞を浚いやす、強い※人さね。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンよしてもくりゃ、憚りながら、犬の小屋としか思われねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら鼻はきく。",
              "citation": {
                "source": "火の用心の事",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度行つて見よう見ようで、まだ出かけた事のない堀切へ……急ぎ候ほどに、やがて着くと、引きぞ煩らはぬいづれあやめが、憚りながら葉ばかりで伸びて居た。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　憚りながら法師もこれに。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、憚りながらそうではない。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ見な、やっぱりそれ、手があって、足で立って、着物も羽織もぞろりとお召しで、おんなじような蝙蝠傘で立ってるところは、憚りながらこれ人間の女だ。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遁も隠れもしませんから、憚りながら、御萱堂とお見受け申します年配の御婦人は、私の前をお離れになって、お引添いの上。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あんたが野暮天か道楽者か、その見分けが付かないようで、憚りながら芸妓の鑑札を持っていられるかって云うんだ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やら氣が退けて、甚く其處らを憚りながら、急足で長屋の通路を通り抜けると……兩側に十軒の長屋が四軒まで空家になってゐて、古くなツた貸家札は、風に剥がれて落ちさうになツてゐた。",
              "citation": {
                "source": "昔の女",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "憚りながら俺の腹の中には、赤玉が二つ納まっているんだぞ……と怒鳴りつけてやりましたら、その医者は青くなって逃げ出すかと思いの外……ジーッと私の顔を見て動こうとしません」「フーム。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、憚りながら褌は白い。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「対手は素人だ、憚りながら。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おい、其だつても無銭ぢやあ不可えよ憚りながら神方万金丹、一｜貼三｜百だ、欲しくば買ひな、未だ坊主に報捨をするやうな罪は造らねえ、其とも何うだお前いふことを肯くか、）といつて茶店の女の背中を叩いた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君がその気なら憚りながら一臂の力を貸す決心でいるんだからね」　山岸の提言に他の社員たちも、佐藤加奈江を仇討ちに出る壮美な女剣客のようにはやし立てた。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は、エデンの園の蛇ぢやない、はばかりながら日本の龜だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "龜自身も以前、浦島に向つて、「しかし、私は、エデンの園の蛇ではない、はばかりながら日本の龜だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――けふ、みなさまの食堂も、はばかりながら創業滿三箇年の日をむかへました。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
