        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "チェロ奏者オットカール・レヴェズは洪牙利コンタルツァ町医師ハドナックの二男。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっして喝采をうけるほどの終局じゃないけれども、まさかこの洪牙利の騎士が、犯人とは思いも寄らなかったよ」それ以前すでに、棺台の上が調査されていた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "レヴェズ――あの洪牙利の恋愛詩人は、秋を春と見てこの世を去った――と」と一息深く莨を吸いこんでから二人が惑乱気味に嘆息するのも関わず、法水は云い続けた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草ばかり吹かしている洪牙利人や、顔色の黒いヌビヤ人や、身長の高くない日本人や、喧嘩早い墨西哥の商人などが、黄金の威力に圧迫され、血眼になって歩いている。",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　巴里の北の町はずれ、ラ・ヴィエットの市門からプウル・ヌーヴのほうへ行く町角に、※にニスで「洪牙利亜兵」と書きつけた、安手な一品料理店がある。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラスキーは、依然たる沈鬱な口調で、「この『洪牙利亜兵』で、先生が、どんなことになりかかっているか、これでだいたいおわかりになったことでしょうが、その他に、まだいけないことがあるんです」　さすがに、少々空恐ろしくなってきて、うろたえた声でたずねた。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼、トランシルヴァニアが洪牙利より羅馬尼亜に移譲されたることを嘆きて(*16)、彼が城に我等の知れるものの多からざれば、場所替えせんものをと書きたり。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーの夏は 〔nya'r〕（ニヤール）。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーやセルボクロアチアンからフィンランドまで行ってみても同様である。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はハンガリー人で、日本の留学生のことを仕組んだものだそうです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばリュート類似の弦楽器として概括さるべきものに、トルコのコプズ、ルーマニアのコブサ、またコブズ、ロシヤ、ハンガリーへんのコボズなどがある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻末の解説を読むと、これは、ドイツ、オーストリア、ハンガリーの巻であることがわかります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーの吸血鬼信仰。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリオストが記したヒポグリッフ、ハンガリーのタトス、古ドイツとスカンジナヴィアのファルケいずれも翼ありて空中を行く馬だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリー人も黒犬に斑犬を魔形とし、白犬は吉祥で発狂せぬと信ずる（グベルナチスの『動物譚原』二の三三頁注）。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし『ふた夜』には、同じドイツの味でも何処かオーストリア・ハンガリーの味や匂ひが残つてゐる。",
              "citation": {
                "source": "ペチヨリンとゲザ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "バルザックがヴェニスやハンガリー、ポーランドやロシアなどで熱烈に愛読され、社交界の貴婦人、紳士がバルザックの作品に現れた人物の名を名乗ってその役割りに扮そうという言いあわせをして或るシーズンはランジェー公夫人だのラスティニャクが社交界に現れたということにふれ、サント・ブウヴは書き添えている。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次女モニカはハンガリーの美術史家の妻。",
              "citation": {
                "source": "明日の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ、オーストリー、ハンガリーなどの専制君主制は崩壊した。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリーのプロレタリア詩人カニャート。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ語、ハンガリー語、英語、ロシア語。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツへ、チェッコ・スロヴァキアへ、イギリスへ、ハンガリーへ、日本へ！",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、壁新聞やピアノや、この前ハンガリーの共産青年同盟員が訪ねて来たときみんなでとったという写真や、シュロの植木鉢などが飾ってある。",
              "citation": {
                "source": "従妹への手紙",
                "author": "――「子供の家」の物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンガリー生まれのユダヤ人数学者で、ヒットラーのドイツを逃れてプリンストン大学に移っていたジョン・フォン・ノイマンは、マンハッタン計画に貢献するとともに、コンピューターの基本原理の確立においても決定的な役割を演じた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄色髪の方は、濃紺のハンガリー服を著ており、髪の黒い方は、あたりまえの縞の韃靼外套を羽織っていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャンパンに次いでハンガリー酒が抜かれ、それで一層景気づいた一座は更に陽気になった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "元時代には蒙古人は東の方は朝鮮から、西の方はロシア、ハンガリーの邊りまでも皆領地にして置いて、アジア大陸を横切つてヨーロッパまで領地にして居りましたから、其間には非常に交通が便利になつて居りまして、ヨーロッパの人なども澤山來たのであります。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "歐洲征伐の時蒙古兵はハンガリーを攻めたことがありますが、其時は秋の頃で四方を見ると五穀がよく實つて居る。",
              "citation": {
                "source": "元時代の蒙古人",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がそこで紹介された人だけでも、メキシコの詩人兼雑誌記者、ハンガリーの舞台監督、チエコ・スロヴアキアの文学青年、トルコの版画家、セルヴイヤの映画俳優、コルシカの女城主！",
              "citation": {
                "source": "世界人情覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに一年半居るうち、雨模樣の日には必ず洋傘を持參し、二三日ぐらゐかかる旅行の時にも必ず洋傘を持參し、それからその洋傘を持ちながら、ハンガリーにもイタリーにも獨逸にも旅行した。",
              "citation": {
                "source": "燒跡",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
