        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "羽根ペンを拵らへるのにどれだけ鵞鳥を裸かにし、紙を漉くのにどれだけ襤褸くづをつかつたら堪能ができるのだらう！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "翼の羽根ペンも軽やかに、彼女らはぐるぐると誰にも真似のできない花押を書きなぐる。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "書類は粗い手すき紙に、羽根ペンで書いてあります。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務所で聞こえるのは助手が羽根ペンを走らせる音だけ、調査報告書を下書きしている。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
