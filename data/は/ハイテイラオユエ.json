        "examples": {
          "standard": [
            {
              "text": "麻雀の最終局で、彼は見事海底撈月をツモり、逆転勝利を飾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まさか海底撈月になるとは思わなかったよ！」と彼は興奮気味に語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの局面で海底撈月を狙うとは、彼も相当な勝負師だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それにさすがは文學の國支那の遊びで、役の名に清一色とか、國士無雙とか、海底撈月とか、嶺上開花とか、四喜臨門とかいふやうな如何にも詩味のある字句を使つてあるのも面白い。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
