[
  {
    "uuid": "d13822e4-7870-5826-9377-0d5302e60412",
    "entry": "排する",
    "reading": {
      "primary": "はいする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-他動詞"
      ],
