    "definitions": [
      {
        "index": 1,
        "gloss": "small profits and quick returns",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
