[
  {
    "uuid": "d3bebe72-7b56-5a86-a289-21be0b38721c",
    "entry": "反日",
    "reading": {
      "primary": "はんにち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
