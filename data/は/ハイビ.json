[
  {
    "uuid": "0d208cef-0d35-5eaf-ba35-ae7787276f4a",
    "entry": "配備",
    "reading": {
      "primary": "はいび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
