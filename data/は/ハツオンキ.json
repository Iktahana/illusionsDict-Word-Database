      {
        "index": 1,
        "gloss": "sound-producing organ (esp. of land-dwelling vertebrates and insects)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
