[
  {
    "uuid": "44120025-e3e5-5233-9bd8-9f72a108bb92",
    "entry": "敗戦",
    "reading": {
      "primary": "はいせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
