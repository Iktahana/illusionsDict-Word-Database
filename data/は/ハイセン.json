    "definitions": [
      {
        "index": 1,
        "gloss": "defeat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "転々した敗戦のあとが傷ましくずっと数えられる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさんは、日本を敗戦国にしたのは、軍閥と官僚だとお思いになっていらっしゃるかも知れませんが、実は猫と杓子が日本をこんなことにしてしまったのです。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしいくら敗戦して焼け出されたとしても、せめて思想の借着だけはしたくないものです。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は敗戦しました。",
              "citation": {
                "source": "猫と杓子について",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本は敗戦と共にわびしく貧弱になったが、私は日本とともにわびしく貧弱になることを私の文学のためにおそれる。",
              "citation": {
                "source": "私の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦と共に小説が下手になったといわれることをおそれる。",
              "citation": {
                "source": "私の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都で一番賑かな四条通、河原町通の商店の資本は、敗戦後たいてい大阪商人から出ているという話である。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦国に焼け残った唯一の大都市だといってしまえば、それまでだが、しかし、この浮ついた、はなやかさは何か気ちがい染みている。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに深夜とはいえ、敗戦の大阪とはいえ、一糸もまとわぬ若い娘の裸の体が、いきなり自分の眼の前に飛び出して来るなんて、戦争の影響で相当太くなっているはずの神経にとっても、これは余りに異様すぎる感覚だった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……敗戦になってから、急に酒を飲みだしたんです」　おまけに煙草は日に八十本、病院もやめてしまい、毎日ぶらぶらして、水すましのように空虚な無為徒食の生活をはじめた――と道子はスカートの端をひっぱりながら言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君たちは敗戦につきものの混乱と頽廃の園に咲いた悪の華だ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに依つて考へれば、良正良兼は記の本文記事の通り、源家が敗戦したによつて婦の縁に引かれて戦を開いたのだが、最初はたゞ源護一家と将門との間に事は起つたのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、敗戦の前には徴用で、伊豆の大島にやられていまして、毎日毎日、実にイヤな穴掘工事を言いつけられ、もともとこんな痩せ細ったからだなので、いやもう、いまにも死にそうな気持ちになったほどの苦労をしました。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "与太者としての顔を、敗戦後のどさくさまぎれの世相の中で利かすことをむしろ軽蔑し、わざとグッドモーニングの銀ちゃんなどという安っぽい綽名を作って、自嘲しているのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦当時、彼らはよれよれの国民服に下駄ばきだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋服に草履ばきは、昨日今日ざらにある敗戦の身なりで、何の不思議もないとはいうものの、烱眼に掛れば、囚人用の草履であることを見抜くかも知れない。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の努力というものは奇妙なもので、努力するという限りでは、ここ数年間の軍官民はそれぞれ莫迦は莫迦なりに努力して来たのだが、その努力が日本を敗戦に導くための努力であった如く、日本の文壇の努力は日本の小説を貧困に導くための努力であった。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、一たび神様となるや、その権威は絶対であって、片言隻句ことごとく神聖視されて、敗戦後各分野で権威や神聖への疑義が提出されているのに、文壇の権威は少しも疑われていないのは、何たる怠慢であろうか。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦、戦災、失業、道義心の頽廃、軍閥の横暴、政治の無能。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜っ葉服らのそれは、敗戦の実証であって、抄紙機に駆使され頤使されて、周章狼狽の果ての過失から、まざまざと彼らは弱者たる彼ら自身を彼らの運転する機関の前に曝さねばならない惨めなジレンマに堕ちてしまったといっていい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん、全体としては漢軍の成功と匈奴の敗戦とを望んでいたには違いないが、どうやら左賢王だけは何か負けさせたくないと感じていたらしい。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自発的に来る場合もあり、敗戦の結果強制的に出させられることもある。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後数年、※陵の敗戦の責を引いて、子反は自ら頸はねた。",
              "citation": {
                "source": "妖氛録",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦となると惨めなもので、どう云われても仕方がない。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "平壌に於ける敗戦までは、まだまだ積極的な態度であったが、これ以後の日本軍は処々の戦勝あるとは云え、大局に於て退軍の兆が現れるようになった。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌四日、土方は昨夜の敗戦に激怒して、千本松に陣立をなした。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月｜晦日、大野治房等は樫井の敗戦から還り、大阪で軍議をした。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の子供を育て、結婚した長女に初孫の生まれたのが、敗戦から間もない一九四六（昭和二十一）年一月。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦後の混乱と困難の中で、祖父には再び絵筆を取る機会が訪れませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "復活の象徴となった『山びこ学校』　こうしていったんは途絶えた生活綴方の精神を敗戦後の日本に蘇らせる上で、山形の山村の中学校教師、無着成恭が指導してまとめた『山びこ学校』という文集は、大きな役割を演じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
