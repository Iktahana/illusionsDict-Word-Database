[
  {
    "uuid": "f89edfe4-9b00-5efa-ad2d-18789f6343da",
    "entry": "春雨",
    "reading": {
      "primary": "はるさめ",
      "alternatives": [
        "しゅんう"
      ],
      "is_heteronym": false
