[
  {
    "uuid": "9c014845-9b30-58d8-8b1f-1f39d5d02c35",
    "entry": "鼻衝",
    "reading": {
      "primary": "はなつき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "meeting head on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "初めて会った時、二人はお互いの鼻衝で言葉もなく見つめ合った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "細い路地でばったり出会い、危うく鼻衝になるところだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "突然の事態に、車と電柱が鼻衝の状態で停止した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "牛舎の中へ入って行く、馴れない故で牛の鼻柱の前を通るのはあんまり良い気持はしないけれ共、静かに草をかんで居る様子は、どうしても馬よりはなつきやすい気持を起させる。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "名はなつきの磯と言ふ。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中で生まれて、森の中で大きくなったので、めったの人にはなつきませんでしたが、勇ちゃんは、自分のもらったお菓子を分けてやったり、また、魚の骨があれば、わざわざ持っていってやったり、平常から、クロをかわいがっていましたので、クロは、だれよりも、いちばん勇ちゃんになついていました。",
              "citation": {
                "source": "青い石とメダル",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "増長して始末におえぬものじゃ」「それはあなたの考え違い、それでは女はなつきませぬ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――若樣は何方かと言へば疳の強い方で、滅多な人にはなつきませんでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "神隱し",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
