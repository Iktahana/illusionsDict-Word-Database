        "examples": {
          "standard": [
            {
              "text": "現代社会においても反セム主義は根強く残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "教育は反セム主義を撲滅するための重要な手段だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "残念ながら、彼の中にはまだ反セム主義の偏見が見られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "即ち共産主義、政治的カトリシズム、シオニズム、反セム主義、トロツキズム、および平和主義である。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "スコットランドのナショナリズム、シオニズム、反セム主義ないしトロツキズムとそれらとの間も同様だ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "「反セム主義」という単語を耳にする程度の教育を受けていれば、当然それは無くすべきだと主張するのだし、ユダヤ人に反対する意見はあらゆる層の文芸から注意深く取り除かれる。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "新トーリー主義と政治的カトリックは反セム主義に屈するのが常だ、少なくとも時々は。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
