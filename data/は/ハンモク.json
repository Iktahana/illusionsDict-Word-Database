    },
    "definitions": [
      {
        "index": 1,
        "gloss": "half a point (esp. in go)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "半目をとぢて怠屈さうに椅子にもたれて居た検事は、立つて論告をした。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "うとうとして、三時半目を開きしに、樹影天幕に映れり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど一年半目に人間の住む社会なるものを例の金網ごしにのぞき見した。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも他人のことまで立ち入ろうとする半目醒の女はやり切れない。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方迎へられて知人の家に赴く、夜半目覚めて枕頭の灯影に驚く。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「両通」といって、これのもすこし精巧な奴になると、金粉の重味が両方にかかるような仕掛になっていて、賽の粉を下の方へ通して伏せると、五三一の半目が出、上に向けて振り動かして伏せると、二四六の丁目が出る。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は一種の半目的を持った。",
              "citation": {
                "source": "サレーダイン公爵の罪業",
                "author": "THE SINS OF PRINCE SARADINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この先はいつかオール讀物に「雉子郎物語」として書いたやうに、ペンキ塗の作業中、足場板もろともドツクの底に墜落して、一年半目で、病院入りになつてしまつたわけである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気がよくなつたの」　帝大病院に通ひはじめて、丁度、一年半目のある日、花子は泣きながら三吉の部屋へ駈けこんできた。",
              "citation": {
                "source": "悪夢",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
