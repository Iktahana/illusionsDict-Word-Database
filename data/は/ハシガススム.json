        "examples": {
          "standard": [
            {
              "text": "祖母が作ってくれた料理はとても美味しくて、つい箸が進んでしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "久しぶりに会った友人と話が弾み、食事の箸もどんどん進んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今日の夕食は、僕の大好物ばかりで、箸が進むこと間違いなしだ。",
