[
  {
    "uuid": "749c03df-03c0-50c6-b8aa-4e493162c4b2",
    "entry": "廃藩置県",
    "reading": {
      "primary": "はいはんちけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
