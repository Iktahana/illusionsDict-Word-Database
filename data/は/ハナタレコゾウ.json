        "examples": {
          "standard": [
            {
              "text": "兄は、いたずらばかりする弟のことを「洟垂れ小僧」と呼んでからかっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "祖父は、孫たちのことを愛情込めて「元気な洟垂れ小僧たちだ」と笑っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は昔、村一番の洟垂れ小僧だったと、大人になってからよく聞かされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そこへ汚い洟垂れ小僧が立並んで、看板を見上げている。",
              "citation": {
                "source": "百面相役者",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……はい、さようでございまする」　沢庵の姿を仰ぐと、以前の洟垂れ小僧に返って、彼はただ恐れ入るばかりな容子だった。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
