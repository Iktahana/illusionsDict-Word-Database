      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to dispel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何となくその不満の気持ちを晴らすらしく、みち子は老妓に当ったりした。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見晴らす広漠とした河原に石と砂との無限の展望。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、何かしら体のうちに切ないものがあって、それを晴らす方法は急いで求めてもなかなか見付からないように感ぜられた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは大まじめで、この鬱憤を晴らすつもりで取りかかつたのだが、書いてゐるうちに、滑稽になつてしまつた。",
              "citation": {
                "source": "『玩具』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、獲物があがらないということは巡警の疑念を晴らす足しにはちっともならなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に客のない時は大広間の真中へ椅子を持出して、三十畳を一人で占領しながら海を見晴らす。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫野を見晴らす大根畠と墓原の間の小径の行止まりに、万延寺の本堂と背中合わせにして一軒の非人｜小舎がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多の町の南の出外れ、万延寺の本堂と背中合わせの竹瓦に板庇、板敷土間に破れ畳二枚、ガタガタ雨戸の嵌め外しがやはり二枚という、乞食小舎の豪華版から、墓原越しに見晴らす筑紫野は、これも晩春の豪華版であろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りつめるときれいな芝を植えた斜面から玉川沿いの平野一面を見晴らす事ができた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが又、彼の意気込みの激しさはただならぬものがあったから、あるいは彼は部屋にはいって来た時ぼくらの容子を見て、何か疑わしく思ったのではなかろうかと思われて、それでは矢張りその疑いを晴らす為に飲む可きだとも思った。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやかしの鼓にこもった霊魄の迷いを晴らす道はもうわかったろうから。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしな奴さ」　かの女は、そのキラキラする鋏の刃を見て、むす子が親に訣れた後のなにか青年期の鬱屈を晴らす為にじょきじょき鳴らす刃物かとも思い、ちょっとの間ぎょっとしたが、さりげない様子で根気よくむす子に室内の家具の配置を定めさせた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思って来ると、口惜しさを晴らす意地のようなものが起って来て、私は炬燵の布団から頬を離して立ち上った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体に日本の菊のようにおっとりした品が無くって徒にパッと開いて居ますね」　宮坂は景子の直ぐ傍へ来て今までの鬱屈を晴らすような明快な声で言い放った。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はだんだん強くなって、二階の縁側から見晴らす海も潮けむりに暗かった。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだ、それだ、多年わが國を最も子供扱ひにして來た、あの傲慢無禮な米國に對し、商賣的にわが利益の鬱憤を少しでも晴らすのもそれだと、渠は即坐にきめてしまつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「拙者は竹腰藤九郎でござる、お首を頂戴して、先君道三｜入道殿の修羅の妄執を晴らす存念でござる」　それは背のずんぐりした白髪の眼だった男であった。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の行きとまりに低い珊瑚樹の生垣、中ほどに形ばかりの枝折戸、枝折戸の外は三尺ばかりの流れに一枚板の小橋を渡して広い田圃を見晴らすのである。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五六人打殺してやつて、これ／＼のいはれで恨みを晴らすのだといつて一人生かして還してやれば、屹度日置に傳はる。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々は以前の癖の藝者を買つたりして鬱を晴らすこともあつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは目上の人の指図の許にのみ暮してゐる自分達にとつては、かういふことで充分に日頃の鬱憤を晴らすことが出来たのであります。",
              "citation": {
                "source": "泣き笑ひ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　一寸した不満をこれで晴らすやうに私は、それでも甘えるやうな笑ひを浮べながら、さう云ふと、拾つた石を力一杯水の上へ投げました。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、ははんそうか、さてはだれかその用人の身内の者がお手討ちの恨みを晴らすために、あんな左の目のない生首をこしらえて、味なまねしやがったんだなと思いましたからね、すぐにおやじへきいたんでがすよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋常なことでは嫌疑を晴らすはずアねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "七年まえのだんごのかたきを伝六は捕物で晴らすつもりか、雨の道をもものともせずに、ここをせんどと急がせました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の東海道は品川から浜川、鮫洲で、鮫洲から八幡さまのあたりまでは、農家や漁師町が続いていますが、それから大森までは人家が途切れて、一方は海、いわゆる安房上総をひと目に見晴らすことになる訳で、仕置場までの間を鈴ヶ森の縄手と呼んでいました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　径の在所も知れぬ熊笹の崖である、流れの岩を飛んで胸突きの崖をよぢ登ると、国境の山々を見晴らす明るい芝の野原に出るが、私は何時かの春の蕨狩りに出掛けた時、崖を這ひ登りながら胆を冷したのを思ひ出して、銃を担いだ娘がひとりであれを登るさまは想像が困難だつた。",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は務めの往復此処に立寄つて、終日沈黙を守つた仕事に疲れた饒舌慾を晴らすのである。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "養子に往くのは、戦争に出かけると同じやうに敵をそつくり生捕るか、さもなければ身一つで逃げ出すだけの気転が無くてはならぬが、それでも養子に往けぬとなると、先を折られたやうな気持がするかして、こんな輩は養子に往けない鬱憤を晴らす為に大抵浪人になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、そのような私の遊びの相手になって、私の饗応を受ける知人たちも、ただはらはらするばかりで、少しも楽しくない様子である。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
