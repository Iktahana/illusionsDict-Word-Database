[
  {
    "uuid": "bd57dd6c-e2af-5073-b75c-7ecacc5a5238",
    "entry": "晴らす",
    "reading": {
      "primary": "はらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
