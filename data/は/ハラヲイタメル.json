          "literary": [
            {
              "text": "別に仏さんのお腹を痛める訳でも無いので、お礼にはこんな手頃なものは無かつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰れも無意義に自分の腹を痛めるものはないだけのことだ。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虫の湧いたやつを飲ませると、子供などは腹を痛めるしね。",
              "citation": {
                "source": "あばばばば",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう、後腹を痛めるほど、値うちのあるきりょうとは、惚れられている彼の眼にも踏めていなかった。",
              "citation": {
                "source": "治郎吉格子",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
