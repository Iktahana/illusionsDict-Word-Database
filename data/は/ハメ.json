  {
    "uuid": "9d6d4883-e611-5990-ae83-487c4111e352",
    "entry": "ハメ",
    "reading": {
      "primary": "ハメ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接頭辞",
        "名詞-接尾辞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fucking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人々は誰れでもこれを知っていて、かの女がこの意味でのハメを外ずすのを待受けた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実力以上の長考をしたが、ハメ手に掛って負けた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "千日前の大阪劇場の楽屋の裏手の溝のハメ板の中から、ある朝若い娘の屍体が発見された。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "溝のハメ板の中に屍体があるとは知らず、女優たちは毎日その上を通っていたのである。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は善悪と云ひ、或は陰陽と言ひ、或は光暗と云ふが如き、ペルシヤのむかしに、アームズトの神、アハメルの神ありし如く、イスラエルのむかしに、ヱホバ神と悪魔とを対比せし如く、顕著なると顕著ならざると、一神と多神との区別あり、あらざるとに拘らず、彼の元を二にするの性は此観念に離れざるなり。",
              "citation": {
                "source": "他界に対する観念",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石の謹厳な八代大将も総｜義歯をハメ直しハメ直し鼻汁と涙を拭い敢えず、苦り切ってシキリに汗を拭いていた武谷博士も、とうとう落城してニヤリとしたのが運の尽き。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪木がモハメッド・アリとやると言いだした日には、実にまったく驚かされたものである。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏等にはハメを脱すやうな不安がない。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の野郎まで行きがけの駄賃に、馬小屋のハメ板ケッ飛ばしてゐるだ、俺達も別れに、役所の玄関にショウベン、じやあ／＼やつて行くべよ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は若い作家でさういふハメに陥つた人々を多勢知つてゐる。",
              "citation": {
                "source": "小説新論",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命、ハメ、罪悪、さういふ方面の心理を描いて見たいと思つて筆を執り始めた作だから……。",
              "citation": {
                "source": "初冬の記事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労人とか世間人とか言ふ名を奉られて、泣きたい時にも泣かずにゐるやうなハメには陥りたくない。",
              "citation": {
                "source": "閑談",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォーターを「ワラ」と発音したため、それをあだ名として頂戴するハメになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、そうなると、また県教委がさわぎだして、男子校にもどすようなハメにならんともかぎらないがね」「そんなことになったら、タイヘンだ」　口をつぐんでいるつもりだった慶一が、思わず驚きの声をあげた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "手もとに国内盤の「訳詞」がある場合は参照し、一致しないように努力したが（おかげで〈ウェルカム・バック〉は、あえて誤訳するハメになった）、当然ながら、すべてを参照できたわけではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の足をとめた所から少し斜め下の、高くハメ込んである小さい硝子窓の中に――男と女の薄い影が動いている。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――円るい型にハメ込んだ番号の打ってある飯をワッパに、味噌汁を二杯に限って茶碗に、それから土瓶にお湯を貰う。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は浮き立つた連中とローランドの店へなど赴いて、若しやハメでも外してはならない――と留意してゐた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となくムハメットがいそうな空の色と岩の色だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人生研究の為お糸さんに接近しようと思ったのだけれど、接近しようとすると、忽ち妙なハメになって、二番さんだの八番さんだのという番号附けになってる俗物共の競争圏内に不覚捲込まれて了った。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "たといそれが庸三自身の計画的な行動ではなく、彼女自身の悧巧な頭脳から割り出されたトリックであるにしても、葉子自身そうした苦しいハメに陥ったことに変りはなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "たえ子は次の火曜日の昼頃に、再び三越の休憩室で落合ふことを約束して、そこ／＼に袂を分つたのであつたが、二度も三度も……そして終ひには抜差のならないハメに陥つて行くのが不安であつた。",
              "citation": {
                "source": "復讐",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつてハワイで、ハワイナポレオンと称せられた、大虐殺王タメハメハの死んだ時などは、大勢の人間の強制的犠牲を供えたのみならず、なお無数の忠良な臣下が自殺しまたは自ら傷つけて不具になった。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその後数年間、国民は毎年その日に糸切歯を抜いて、タメハメハを祭った。",
              "citation": {
                "source": "奴隷根性論",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "』モハメッドのために！",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "モハメッドのために！",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "「モハメッドのために」幾らかくれと言うのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "地久節チキユウセツハメデタイナクワウゴウサマノオウマレ日ガツカウモ　ヤクバモイハヒマス。",
              "citation": {
                "source": "未刊童謡",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがもう一面でゲイツもまた、デジタルの調べを奏でて人々をディスプレイの世界へと導く、新世代のハメルンの笛吹きとなることをいとわなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
