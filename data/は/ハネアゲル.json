        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "蓋を跳ね上げると、中から香ばしい匂いが立ち上った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は前髪が邪魔になったので、指でさっと跳ね上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このスイッチを跳ね上げると、電源が入ります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
