  {
    "uuid": "f9abd8eb-2bd8-59a4-b49b-9da12ba750ed",
    "entry": "反旗",
    "reading": {
      "primary": "はんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
