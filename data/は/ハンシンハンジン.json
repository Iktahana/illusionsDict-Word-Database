        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "復一の何ものにも捉われない心は、夢うつつに考え始めた――希臘の神話に出て来る半神半人の生ものなぞというものは、あれは思想だけではない、本当に在るものだ。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "半神半人、ポントスの娘の一人、ユウリュビア（Eurybia）の婿である。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち日曜だけ画家となり得る生活を持つところの半分の神様すなわち半神半人の一群である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んといっても半神半人の域にある。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "一個の半神半人の英雄神にして、其神話に関しては、甚だ議論あるも、今しばらく、「テーバン」の伝説に従って、其神話を大要を記せん。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半神半人の英雄神にして、其性質大にプロメトイスに似たり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
