        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うひうひしい、といふ形容も亦、甚だ以てきざであるが、誠實、と置きかへてみても、なほきざである。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、近頃盛に探偵小説を愛讀する自分だが、小説の上ではスリリングな殺人事件も現實に近所に起つてみると甚だ以て有り難くない。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "推して之を察したまはば、甚だ以て幸なり。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども是は批評をするのだと、馬琴｜大人に甚だ以て相済ぬ、唯ね、どうもネ。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東泉先生曰く、君の頭は植林地か、それとも開墾地か、後者だとすれば着々成功して居るが、植林の方だと甚だ以て不成績ぢやないか！",
              "citation": {
                "source": "雪中行",
                "author": "小樽より釧路まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故及ばないかといふに、この表情美の線が甚だ以て粗いからだ。",
              "citation": {
                "source": "「香水の表情」に就いて",
                "author": "――漫談的無駄話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が然し、庵の場所は全く申し分なしで、只今申上げた通り、市中を去る事余り遠くもなく、さりとて又近過ぎもせず、勿論、巣居であり、穴居でありますが、俗物にとつては甚だ以て都合の宜しい位置に建つて居るのであります。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩は甚だ以て不同心なり。",
              "citation": {
                "source": "亞細亞諸國との和戰は我榮辱に關するなきの説",
                "author": "福澤諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚だ以て穏かならぬ言い分ではあるが、賊の立場からの弁解としてはその謂われがないでもない。",
              "citation": {
                "source": "時勢と道徳観念",
                "author": "大賊小賊・名誉の悪党",
                "note": "青空文庫"
              }
            },
            {
              "text": "志水　それが甚だ以て心細いんだ。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この眞夜中に俺を引ぱり出すのは殺生だぜ」　叩き起された平次は、甚だ以て不服さうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "密室",
                "note": "青空文庫"
              }
            },
            {
              "text": "傅次郎は塀にもたれて、ニヤリニヤリとその後ろ姿を見送つたことだらう」「すると誰が殺したといふのだえ、錢形の」　三輪の萬七は甚だ以て平かでない顏色です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "小便組貞女",
                "note": "青空文庫"
              }
            },
            {
              "text": "推して、察し給はらば、甚だ以て幸なり。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち飛んでしまうというはなはだもって神さまらしくない無責任な行為をもやっている。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "民権論は余輩もはなはだもって同説なり。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "智者の所業にははなはだもって不似合なり。",
              "citation": {
                "source": "学者安心論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定まりの登山綱、氷斧、角灯などという小道具もさることながら一行の装というものははなはだもって四分滅裂。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の家茂の言葉に、朝廷を尊崇して参内する身に危害を加えようとするもののあるべき道理がない、もしこんな懐剣を隠し持つとしたら、それこそ朝廷を疑い奉るにもひとしい、はなはだもって無礼ではないかと。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、あの隠居が何を言い出すかと思いましたら、しかし街道の世話をする宿役人を手打ちにするなんて、はなはだもってわがままなしかただ、いくら官軍の天下になったからって、そんなわがままは許せない、ですとさ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはだもって異様な光景となった。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙者は当家のあるじ、いかなる意趣、遺恨かは知らねども、拙者門前にての斬りあいは、はなはだもって迷惑いたす。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これははなはだもって油断ならぬ性格の人物です。",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
