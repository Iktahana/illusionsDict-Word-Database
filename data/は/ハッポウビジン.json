        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕の八方美人を憎んでいる。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方美人の偽道徳家は人々に良い人と思われ、真に徳の高い者は薄馬鹿の様に思われるのが世の常である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "表面は円転滑脱の八方美人らしく見えて、その実椿岳は容易に人に下るを好まない傲岸不屈の利かん坊であった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらかと云えば八方美人にも見えるし、一種の変態性欲主義者ではないかと思われる。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり人なつっこいあんまり八方美人に芸術はなりかかって居る。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、身分の高いあいつらの父親どもといへば、そろひもそろつて八方美人で、宮廷への出入りを狙ふ手合だが、あれでゐて自分免許に、愛國者だの何だのと納まりかへつてゐるものの、どつこいこの愛國者先生、利權漁りに憂身をやつしてばかりござる！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばここに笑みを含んで話するものがあるとすれば、甲はこれを、「巧言令色の人、阿諛※佞の人」　と評するし、乙は、「よいぐあいに世渡りする上手者、愛嬌を振りまく八方美人」　という。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "性格や気質の分類は、一々これをしてゐる暇はないが、例へば、強気、弱気、神経質、多血質、偏屈、八方美人、何れも、それらしい言葉をもつてをり、何れも、興味の対象となり得るものである。",
              "citation": {
                "source": "「語られる言葉」の美",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、こゝで注意すべきことは、いはゆる「八面玲瓏」殊に「八方美人」といふやうなことが必ずしも「嗜み」ではないといふことです。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くは「八面玲瓏」の油断のならなさ、「八方美人」の頼りなさが誰の眼にもそれと感じられ、もうそれが感じられるだけで、その人物は、それだけの人物だといふことがわかるのであります。",
              "citation": {
                "source": "青年の矜りと嗜み",
                "author": "――力としての文化　第四話",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんといふか、八方美人つていふのの反対だよ。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、一宗一派に偏せず、多くの宗教のよい点を集めるというのであるから、自然その態度が、人をつまずかせない、人ずきのするようなところだけ集めることになり、八方美人的な、合理主義的な教訓集となって、啓示宗教としての霊感をもたず、人間を人間以上の霊的生命につなぐところの革命的な力を失ってしまうのである。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "又之が尻拭ひとして八方美人の伊藤侯が韓廷の御機嫌を取りに行つた事だけは確実である。",
              "citation": {
                "source": "文明の強売",
                "author": "大石誠之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　ここでちょっとつけ足して置きたいのは、いわゆる「八方美人」と「苦労人」とのちがいである。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方美人の特徴は、自分を相手によく思わせて、結局、自分がとくをしようとする心が、意識的にか、無意識的にか、働いている点にある。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点、八方美人とは似ても似つかぬ人間の型なのである。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "八方美人は、人に好感を持たれるにしても、それは極めて表面的である。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの人は八方美人だ。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考えて来ると、八方美人は頼りない人間の標本であり、苦労人は頼りになる人間の標本である、ともいえるのである。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして自分は彼を一種の八方美人的な政策家だと誤解してゐた。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに較べると、八方美人の悪弊は同じ血を吸うのでも肺病の方だ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も江戸ッ子の一人ですからご多分に洩れず短気者ですし、八方美人は嫌いですから、断然絶交いたします。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
