        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十一　排日案に対して、フィルムや、化粧や、耳かくしのボイコットが問題になっている。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなものの二つか三つも掘り出したら、排日問題などは容易に解決されるにちがいない。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米国の排日法は、桐の一葉のようなものである。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名をなすために排日宣伝を仕事とする者もあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故、排日をやるかときくと、食えないからやるのだ、と答えたりした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは排日委員会で決議されたスローガンの一ツだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出兵の結果、支那には、排日、反帝国主義運動が、かえって強くみなぎった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の対支外交や排日問題などについて意見を述べたり、英米の対支文化事業や支那女性の現代的｜覚醒を驚嘆していた。",
              "citation": {
                "source": "小唄のレコード",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "其ノ罪正ニ大帝ノ陵墓ヲ發クノ大逆政策ヲ改メズシテ支那ノ排日ヲ怒リ米國ノ排日ニ憂ヘ尚且ツ茫々然トシテ天佑ヲ夢ム。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "排日ノ聲ガ支那ト米國トニ一齊ニ擧レル所以ハ日露戰爭ニヨリテ保全サレタル支那ト、日露戰爭ヲ有力ニ後援シテ日本ニ支那ヲ保全セシメタル米國トガ、天ニ代リテ當年ノ保全者ニ脚下ノ陷穽ヲ警告スル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "米支兩國ノ排日ニ省悟一番シテ日露戰爭ノ天道宣布ニ歸ル時、日本ハ排日ノ實ニ天寵限リナキヲ見ルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ガ首ヲ擡ゲテ英領ヲ直視スル時、支那ノ排日ハ根本的ニ永久的ニ跡ヲ絶ツベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「しかし、あれは君、検視してみたら弾丸が印度人のと日本人のとが這入っていたというので、何んでも今日あたりからいままでの排日が、排英に変っていくそうだ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "排日宣伝業者に費用を与えた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "安いものだ、排日などとあまりしみつたれたことをいふと罰があたる。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "白木屋の展覧会には、よくわけを知らない見物人に腹を立てさせるため、排日のビラだけを実によく集めて並べている。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の大衆は排日をしているばかりではない。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、Ｍは小さな宿屋では排日で日本人は泊めないからと言って、とにかくそこへ連れて行った。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "がすぐまた、彼が排日運動の熱心家で、そのために日本の警察からかなり注意されていたことに気がついた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄んだ大きい眼をしていて、格別、眼を患っているようでもなかったが、「彼の地では赤線ひとつあってもそれを理由として、日本人の上陸を拒むんですからね」何故そんなに排日の激しい処に行かなければならぬのか知らないが、彼女は異情な情熱を見せてそういった。",
              "citation": {
                "source": "独り旅",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、東洋の邪魔者日本に挑戦すべく、猛悪な排日案を挙国一致の一般投票で決議する一方、自国内に於ては資本主義社会に附きものの暗黒面組織をぐんぐん拡大深刻化し初めた頃である。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう排日が非道くちゃ、荷物一つ動かないからね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから君はツイこの頃になってＧ・Ｐ・Ｕの遊離細胞となって、上海に流れ込んで来ると間もなく、最近上海で国際スパイ兼、排日団体の首領として売り出している、青紅嬢の一｜乾児となったもので、Ｒの四号というのはヤッパリ君の事らしいという王君の報告だがね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海の排日で……上海の排日で……それがどうした……オイ……シッカリしろ……サ……ブランデーを飲ましてやる……シッカリしろ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海の排日がどうした……ウム。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海の排日で、世界大戦の導火線を作る見込みが充分に付いた……×××は他の国と同盟せずにキャスチングボートを握ってくれ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
