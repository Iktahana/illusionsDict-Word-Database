        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この服は、ボタンの代わりにハーケンで留めるデザインだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "釣り針のハーケンが鋭く、魚を確実に捕らえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "壁にハーケンを取り付けて、絵を飾った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
