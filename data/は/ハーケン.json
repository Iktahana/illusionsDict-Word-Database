    "definitions": [
      {
        "index": 1,
        "gloss": "piton (metal support peg used when climbing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
