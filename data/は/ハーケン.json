        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ロッククライミングでは、安全確保のためにハーケンを岩に打ち込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の装備リストには、様々な種類のハーケンが含まれていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "垂直な壁を登るには、強固なハーケンが必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "せめて氷でもならアイス・ハーケンにものをいわせようが、あのような雪の壁など、どうして僕に登ることができよう。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山内桟橋の大クレーンの傍でハーケンクロイツの旗を翻したドイツの汽船が荷役中で、ぞっとするような汚い海の面を鴎が低く飛びちがっていた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにもハーケンがぬけそうで気持が悪い。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハーケンがきいていないとこぼしながらＮがのぼってきた。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右上で確保しているＮのところまで、ハーケンがきいていない。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "静荷重にやっと耐えているようなハーケンとわずかつま先がのるくらいのスタンス、――というより外傾ぎみのフットホールドでＮは確保していた。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなハーケンでこんなところで一晩明かすのはごめんだ。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人がきかないハーケンをムリヤリに叩きこんで計三本で確保する。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッドランプの光でハーケンをさがす。",
              "citation": {
                "source": "穂高岳屏風岩にて",
                "author": "早川鮎子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、とても理論にくわしく、岩登りをやったことが無いのに、マウエルハーケンと木製楔との関係を知っていたり、氷河を歩いたことも無いのに、クレヴァスに墜ちた時の処分法を論じたり、進んではシェンクのピッケルの力学的優秀点を知っていたりする。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
