[
  {
    "uuid": "cfcefc9b-657c-5cd0-9ecc-345f24d28562",
    "entry": "破竹",
    "reading": {
      "primary": "はちく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
