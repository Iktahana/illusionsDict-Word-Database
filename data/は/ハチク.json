    "definitions": [
      {
        "index": 1,
        "gloss": "breaking bamboo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「胃」　彼れは破竹の勢でべちや／＼に潰れた皮袋のやうなものを取上げて臺の上に置いた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは瑣々たる問題にも、きわめて丁寧にいらえしつる余が、このころより官長に寄する書にはしきりに法制の細目にかかずろうべきにあらぬを論じて、ひとたび法の精神をだに得たらんには、紛々たる万事は破竹のごとくなるべしなどと広言しつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体何という藪だ、破竹か、孟宗か、寒竹か、あたまから火をつけて蒸焼にして噛ると、ちと乱だ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは瑣々たる問題にも、極めて丁寧にいらへしつる余が、この頃より官長に寄する書には連りに法制の細目に※ふべきにあらぬを論じて、一たび法の精神をだに得たらんには、紛々たる萬事は破竹の如くなるべしなどゝ廣言しつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｗ」の側のこの日の優勢は、何か目に見えぬ、凡そ予想もつかなかつた破竹の勢ひであつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚に脱帽す６・29（夕）　独逸の軍隊が破竹の勢で東部仏蘭西に攻め込んだ時、そこらに住まつてゐた仏蘭西の住民は、予てから独逸人が吝つたれで、慾深で、有る程のものは掻つ払はずには居られない癖を知つてゐるので、てんでに財産を慝まふのに智慧を絞つたものだ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "依然として自由主義に止つた諸國家も、第二次大戰起り、ドイツのフランス、イギリスにたいする緒戰の壓倒的勝利、さてはドイツの破竹の進撃にたいするソ連の頑強なる抵抗を見るにおよんで、自由主義をもつてしては到底統制主義の高き能率に匹敵し得ざることを認め、急速に方向を轉換するに到つた。",
              "citation": {
                "source": "新日本の進路",
                "author": "石原莞爾將軍の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに破竹の勢いでパリの前面まで侵入したドイツ軍はマルヌ会戦に破れて後退、戦線はスイスから北海に及んで交綏状態となり、東方戦場また決戦に至らないで、遂に万人の予想に反し四年半の持久戦争となった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルギー方面に侵入した独軍また破竹の勢いでマース川の大障害を突破して西進、特にアルデンヌ地方に前進した部隊は仏軍の意表に出でて五月十日既にセダン附近に於てマースを渡河し、マジノの延長線を突破したのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "疫病は破竹の勢で東京の各所に拡がった。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "治承五年の春を迎ふれば、世愈々亂れ、都に程なき信濃には、木曾の次郎が兵を起して、兵衞佐と相應じて其勢ひ破竹の如し。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までは瑣々たる問題にも、極めて丁寧にいらへしつる余が、この頃より官長に寄する書には連りに法制の細目に拘ふべきにあらぬを論じて、一たび法の精神をだに得たらんには、紛々たる万事は破竹の如くなるべしなどゝ広言しつ。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」瑞英の声望は破竹の勢を以て長じた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歌よみに与ふる書」の論鋒｜破竹の如きは言ふを待たず。",
              "citation": {
                "source": "病中雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかもそれは、ナポレオンの軍馬が破竹のごとくオーストリアの領土を侵蝕して行く地図の姿に相似していた。",
              "citation": {
                "source": "ナポレオンと田虫",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者自身の心境さへ進めば、鑑賞上の難関も破竹のやうに抜けるものであります。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "北風競はずして義仲の軍大に破れ、士卒矛をすてて走るもの数百人、東軍の軍威隆々として破竹の如し。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇軍破竹の進撃に付随して、このやうな景気の良い議論が方々を賑はし始めてゐるけれども、尤もらしく見えて、実際は危険な行き過ぎである。",
              "citation": {
                "source": "外来語是非",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "破竹の秀吉を小牧山で叩きつけて、戦争に勝つたが、外交に負けた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "上昇期の秀吉はまさに破竹であつた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "是を以て破竹の勢ありたり。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "一の木戸二の木戸三の木戸、四の木戸までも打ち破り、勇気百倍した攻囲軍は破竹の勢いで押し登った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある部隊などは兵隊に、日本の陸軍部隊がアメリカの西海岸へ逆上陸して、いま破竹の勢いでワシントンへ進軍しているなどといってきかせているそうで、そこへこんなビラを撒かれると、あの方が降伏などをされるわけがないというんで騒ぎをおこすかも知れない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏国大使の乗った汽車ははや静岡へんまで来ているというのに、誘拐された皇帝の行方が皆目わからんというのだから、当局の苦慮心痛というものはまさに破竹の勢い、実に以て察するに余りあるので……。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストフの破竹の勢いを感嘆した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "元亀、天正とうちつづく戦国時代のことで、彼もまた一国一城の主になる野心をもったのであろう、多くの海賊なかまをひきつれて有明の海から島原へと入り、大村領の西岸へ上陸するとともに、村々へ火を放ったり良民をおったり、無慈悲のかぎりをつくしながら破竹の勢で大村城へと攻めよせてきた。",
              "citation": {
                "source": "伝四郎兄妹",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府案をもみつぶすことあたかも破竹の勢で、逓信省所管もまたすべて査定案通りに採決した。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この頃の相馬殿の勢威は、そんな風にいっても、おかしくない程、いわば破竹の勢いであったろうとは想像できる。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "露はちくちくっとおしまいの青光をあげ碧玉の葉の底に沈んで行きました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわれてみると、おたかはちくちく胸が痛み、改めて敬吉の歳を数えてみると、三十だった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
