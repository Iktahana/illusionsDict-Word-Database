          "literary": [
            {
              "text": "俺達あみんな働きすぎたんだ。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の想像が働きすぎ、アユ的ウソと云うに近いものとなった。",
              "citation": {
                "source": "一九二三年冬",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "働きすぎるんじゃないですか。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり根底があさいのに、外界に大きく働きすぎるからだったのか。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "働きすぎたからなあ、ばあやさん。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "年はとるし、働きすぎてへとへとだし、俗物にはなるし、感情はすっかり鈍ってしまうし、今ではもう僕は、とても人間とは結びつけそうもありません。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君達のグループは働きすぎるよ」「うちのものはみな癌で死んでいるんです。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "――が、こいつは働きすぎたかも知れないよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "梅吉殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川さんは働きぬいた、そして働きすぎた、だから暫く休養せねばならぬ。",
              "citation": {
                "source": "小島の春",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "この働きすぎて疲れきった家庭で、だれがどうしても必要やむをえないこと以上にグレゴールなんかに気を使うひまをもっているだろうか。",
              "citation": {
                "source": "変身",
                "author": "DIE VERWANDLUNG",
                "note": "青空文庫"
              }
            },
            {
              "text": "働きすぎや何かで疲れたのね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも忙しい」「働きすぎないように。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にいると、人は働きすぎてしまうから」「だいじょうぶだよ」「この店のストーリーは、書いたのかい」　ドーナツを食べ、コーヒーを飲みながら、ぼくは父親の質問を受けとめた。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれいのように、はたらきすぎないように、はたらくにもあそびにも、時間をきめて、まい日を有益にたのしく送って、時間をじょうずに使い、時間のねうちをさとるようになさい。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
