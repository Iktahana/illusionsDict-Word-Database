    "definitions": [
      {
        "index": 1,
        "gloss": "streetcar decorated with flowers (oft. in celebration or commemoration)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一台の花電車が三日も前から町の上下を運転して、弁当持で便乗する見物客が満員だつた。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "京橋日本橋の大通りには、数万燭の電燈が昼のように輝きわたって、花電車が通るたびに万歳の声が終夜聞こえたという。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの「花電車」を読みながら涙が頬を伝って流れて来た。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はぽんぽんと埃を払ひ、こんなところにこんな絵が、と、両手に支へ、証書を読むやうに眺めたり、壁へ両手で張りつけて、首を後ろへ引きつけて眺めたり、――私はアンリ・ルッソオの絵の広告を今ごろこゝでする用もないが、この花電車の中にはルッソオも伴に乗ってゐるからだ。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "子は絵本に電車を見つけるとその上に乗って足をバタバタさせるのだ（花電車と子）　冬になって私はまた東京へ戻って来た。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に一年してから、この花電車の詩の草稿が私の手に届けられた。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛火の底をかい潜って出て来たこのルッソオは、花電車に乗ってゐるのだ。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓風おのづから起って消えていくところを見てゐると、「あの電車ウソ電車ね　乗れないんだもの」三歳のわが子が口走った（花電車）　なるほどまだ誰も花電車にだけは乗ったものはないだらう。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔欄外に〕○皇太子の生れてよろこびの花電車（1933の暮）春日町のところで会った。",
              "citation": {
                "source": "情景（秋）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、プリンスオブウェールス歓迎のアーチ、花電車を見に行く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "花電車が風を截って来る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯行列や花電車やいろいろな催しがほとんど年中行われた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　　　　　　　　＊　　　　　　　　＊　今年昭和十一年の秋、わたくしは寺島町へ行く道すがら、浅草橋辺で花電車を見ようとする人達が路傍に堵をなしているのに出逢った。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か事のある毎に、東京の街路には花電車というものが練り出される。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕人から今しがた花電車が銀座を通ったことを聞いた。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、其夜の花電車は東京府下の町々が市内に編入せられたことを祝うためであった事をも見て来た人から聞き伝えたのであった。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宮還御の当日なる由にて、花火花電車提灯行列等あり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断腸亭日記巻之五大正十年歳次辛酉",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ時代空気を漂はせたものには、花電車菊のないのは安く見え久良伎花の日の菊に弐銭も出し憎い同　花の日のの句は大正六年の作品。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
