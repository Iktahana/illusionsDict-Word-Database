    "definitions": [
      {
        "index": 1,
        "gloss": "fragment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高きより、風のただ中に、思ひ出の破片の翻転するをみたり。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには笹竹や芹などの雑草が生え、塵芥にまみれて捨てられてる、我楽多の瀬戸物などの破片の上に、晩春の日だまりが力なく漂っているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石小舎の前には、樺や偃松が、少しは生えて、生々しい緑が捨てられている、谷底一杯は石の破片で埋まっていると言って、いいくらいで、白壁のような残雪が、崖の腹からくずれかかってその破れ石の上を、継ぎ剥ぎに縫っている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は冷気のために雪が岩石の膚肌に凝結し、昼はそばから蒸発して行くので、冷熱の変化から岩石を破壊し、山体を陶器の破片のように滅茶滅茶にして散乱させる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを破片岩（Debris）と称している。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢庵漬の重石程な岩石の破片が数町離れた農家の屋根を抜けて、囲炉裏へ飛び込んだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちている破片の量から見ると、どうもこの二本は両脇の二本よりだいぶ高かったらしい。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも知れない鳥の声が、瀬戸物の破片を擦り合すような鋭い叫声を立てている。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような微塵は通例有機質の繊維や鉱物質の土砂の破片から成り立っている。",
              "citation": {
                "source": "塵埃と光",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体私がこの壷を買う事に決定してから取り落してこわしたのだから、別に私の方であやまる必要もなければ、主人も黙って破片を渡せばいいのではなかったかと、今になってみると考えられもする。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "代価を強いて取らせて破片だけを持って帰るのもあまりにぎごちない窮屈な気がする。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二個分の代価を払って、破片と、そうして破れないもう一つをさげて来るのも何だか殊更で、そこに説明の出来ない無理があるように思われる。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし世の多くの人々は、小さな夢の破片でさへも、果敢なく實現しないで死んで居るのだ。",
              "citation": {
                "source": "所得人　室生犀星",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が笑ふ時には、それは彼等の中で何かが墜落したやうな音を立てます、何かが墜落し、碎け、そして彼等をその破片で一ぱいにしてしまふやうな。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその大きな破片がどつと笑ひ、小さな破片がくすくす笑ふのを聞く。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は噛み取った煎餅の破片をじゅうぶんに咀嚼して咽喉へきれいに嚥み下してから次の端を噛み取ることにかかる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、彼女は云うと猛然と私におどりかかって、銀色の唾液のなかで二枚の褪紅色の破片が格闘をはじめた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砂の破片が、顔一面に、そばかすのように填りこんだ者は爆弾戦にやられたのだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　砕かれた雪の破片が、彼の方へとんで来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日本の土地が言わば大陸の辺縁のもみ砕かれた破片であることには疑いないようである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダイアモンドを見たあとでガラスの破片を見るような気がした。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙片の外にまださまざまの物の破片がくっついていた。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿糸の結び玉や、毛髪や動物の毛らしいものや、ボール紙のかけらや、鉛筆の削り屑、マッチ箱の破片、こんなものは容易に認められるが、中にはどうしても来歴の分らない不思議な物件の断片があった。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュートンがその一つの破片を掘り出し、フレネル、ホイゲンス等はもう一つの欠けらを掘り出した。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての破片がことごとく揃ってそれが完全に接合される日がいつかは有限な未来に来るであろうと信ずるか、あるいはそれには無限大の時間を要すると思うかは任意である。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともそういう人はどこにもないであろうが、ともかくも古いものも新しいものもやはり破片である。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の新しい破片は明日の古い破片でなければならないことは歴史のエキストラポレーションが証明する。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ昨日の破片より今日の破片の方が一歩だけ「全体」に近づいて来ただけである。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と龜はへんに慈愛深げな口調で教へる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのやうな内容のお手紙を受取り、私はへんな、夢見心地に似たものを感じた。",
              "citation": {
                "source": "同じ星",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
