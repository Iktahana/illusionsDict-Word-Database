        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつの代でもそうかも知れませんが、昔は神仏に流行り廃りがありまして、はやり神はたいへんに繁昌するが、やがて廃れる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "神様にも流行り廃りがあるから不思議ですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう云ふものを読むと、知らず識らず流行り廃りを気にするやうになり、料簡がコセついて来るのを恐れた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬にも流行り廃りがあって、大正から昭和のはじめ頃までは、このブルドックが盛んであった。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやりすたりを気にしないで、むかしのものでも役にたついいものは、今もどんどんつかってやるのが、ほんとうにすぐれた人と申せましょう。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
