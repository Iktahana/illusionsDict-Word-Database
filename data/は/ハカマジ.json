        "examples": {
          "standard": [
            {
              "text": "老舗の呉服屋で、息子の成人式に向けた特別な一着を作るために、厚手で光沢のある袴地を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最高級の仙台平の袴地は、その独特の縞模様と何度座っても崩れない張りの強さが大きな特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "祖父から譲り受けた上質なシルクの袴地を使い、今の自分に合うサイズへと仕立て直してもらう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "金巾御紋付御小袖一つ、※御紋付一つ、為別段唐桟御袴地一つ、唐更紗御布団地一つ、計四品、於御納戸頂戴。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時、私が静岡へ帰ってみましたら、こたつの上に袴地を並べて、楽しそうに父母が相談しているのです。",
              "citation": {
                "source": "棚田裁判長の怪死",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この町で出来る袴地には見るべきものがありました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台平は専ら袴地として作られ、その質のよさを以て名が知られました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この絹織物を見ますと、袴地としては最も正しい系統の品だということを感じます。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主に袴地で名を得ました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
