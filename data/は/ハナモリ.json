    "definitions": [
      {
        "index": 1,
        "gloss": "person who guards flowers (esp. cherry blossoms)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "古蓑が案山子になれば、茶店の骸骨も花守をしていよう。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山のかぜ花に吹くなりひと羽に千里おほはん大鳥もがも花守もこころ狂ひし人と見ん桜のもとに酔ひて寝たれば明治二十五年の秋、周防国徳山なる照幢の許に遊びにまかりける途中。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "唖々子はその頃｜頻に斎藤緑雨が文をよろこび雅号を破垣花守と称ししばしば緑雨が『おぼえ帳』に似たるものを作りゐたり。",
              "citation": {
                "source": "書かでもの記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "うせものをこだわり探す日短か思ふこと書信に飛ばし冬籠十二月二十七日　立子、泰、迷子、孔甫、花守と共に稽古会をはじむ。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の頃からともなく、前栽に花を植ゑ水を灑ぎ草を採り、自ら「花守」と名乘て出られた。",
              "citation": {
                "source": "花守",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「花守」と「お師匠」さま、何といふ詩的の生活であらう。",
              "citation": {
                "source": "花守",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
