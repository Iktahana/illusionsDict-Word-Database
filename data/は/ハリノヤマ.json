    "definitions": [
      {
        "index": 1,
        "gloss": "hell's mountain of needles",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お沢　いいえ、夢は地獄の針の山。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の針の山を、痒がる土根性じゃ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠の霜は針の山、熱海はたちまち八寒地獄、日金がおろして来ましたので、烈しい陽気の変りよう、今日が危い、とまた誰いうとなく、湯殿の話、辻の風説、会うものごとに申し伝えて、時計の針が一つ一つ生命を削りますようで、皆、下衣の襟を開けるほど、胸が苦しゅうござりましたわ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寒い月に積ったら、桑名の町は針の山になるだろう、堪らねえ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の池や、針の山や、無間奈落といふ白い煙のたちこめた底知れぬ深い穴や、到るところで、蒼白く痩せたひとたちが口を小さくあけて泣き叫んでゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "峠の原で、たぶさを取って引倒して、覚えがあろうと、ずるずると引摺られて、積った雪が摺れる枝の、さいかちに手足が裂けて、あの、実の真赤なのを見た時は、針の山に追上げられる雪の峠の亡者か、と思ったんですがね。",
              "citation": {
                "source": "第二菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いう馬鹿丁寧な返事に、新子は針の山へ入る思いで、部屋にはいった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の池でも針の山でも構わず駈出して行って支度して迎に来ます。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛頭馬頭にひッぱたかれて、針の山に追い上げられるように、土手へ縋って倒れたなりに上ろうとなさると、下草のちょろちょろ水の、溝へ片足お落しなすった、荷があるから堪らないよ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがソフトウエアが革新的であればあるほどついて回ることになる、目標の高さとマーケティング上の踏ん切りとの狭間にあって、スタッフ全員が針の山の上に張った綱を渡るような緊張を、長期間に渡って強いられていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "針の山から血の池地獄。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や針の山や血の池などは二三年其処に住み慣れさえすれば格別｜跋渉の苦しみを感じないようになってしまう筈である。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "この極楽の蓮池の下は、丁度｜地獄の底に当って居りますから、水晶のような水を透き徹して、三途の河や針の山の景色が、丁度｜覗き眼鏡を見るように、はっきりと見えるのでございます。",
              "citation": {
                "source": "蜘蛛の糸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすれば、もう針の山へ追い上げられる事もなくなれば、血の池に沈められる事もある筈はございません。",
              "citation": {
                "source": "蜘蛛の糸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからあのぼんやり光っている恐しい針の山も、足の下になってしまいました。",
              "citation": {
                "source": "蜘蛛の糸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や針の山や血の池などは二三年其処に住み慣れさへすれば、格別｜跋渉の苦しみを感じないやうになつてしまひさうである。",
              "citation": {
                "source": "侏儒の言葉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や針の山や血の池などは二三年其處に住み慣れさへすれば格別跋渉の苦しみを感じないやうになつてしまふ筈である。",
              "citation": {
                "source": "芥川龍之介論",
                "author": "――藝術家としての彼を論ず――",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩「成程、血の池地獄、針の山などはまだございますか。",
              "citation": {
                "source": "明治の地獄",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆「いゝえ、ございませんよ、岩崎弥太郎さんと云ふ方が入らツしやいまして、あの旦那様が針の山を払ひ下げて、其山を崩した土で血の池を埋めてしまひ、今では真ツ平らで、彼処が公園に成りまして、誠に面白うございますよ、女が燈心で竹の根を掘つたりする観物が出ますよ。",
              "citation": {
                "source": "明治の地獄",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世で叶わぬ恋の夢を、針の山のぼりの道中で、晴らさなけりゃあならないのだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばここに下らない人の書いた地獄の絵と、名人のかいた山水とならんであるとすると、山水は一寸いいかげん見て置いて地獄の針の山に追い上げられる亡者や、火の池をおよぎそこねるものなんぞを「ずいぶんいやな絵ですネー」と云いながら前よりも長い間そこに立ちどまって見る。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ針の山であろうと無間地獄であろうと、追いやられるところへ素直に行くしかないのだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い子は、針の山や火の海を越えてゆくの」　ときかされた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は針の山を歩く自分を想像した。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は毎夜、火の中にたっている自分や、針の山をあるいている自分の夢をみた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "色男はとかく浮世が針の山だ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「若しお釋迦樣の云はれたやうな未來があつても、殺人者が極樂へ行つて、慈善家が針の山へ追はれたりしたら、皆んなの當てが外れて餘程變なことになるでせうね。",
              "citation": {
                "source": "假面",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "足は、蹣跚として雲を踏むよう、針の山に追い上げられた泥酔者のように、一歩一歩、床板に弾き上げられて、不作法な怪奇な、命がけの跳躍を続け、手は、紙の上へピンで留められた巨大な昆虫の肢のように、虚空を掻きむしって、醜怪の限りを尽した線を描いて居ります。",
              "citation": {
                "source": "死の舞踏",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、やうやく元気づいてはひつてゆくのだが、竹の切株や根つこが到るところ出てるうへにいたいいたい草がいちめんに生えてるのがふだん石ころひとつにも伯母さんがやかましく世話やいてくれる私には針の山をゆく気もちで足の踏みどころもない。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾か勢子はいつく遊くらんおき津ものなはりのやまを気布か古ゆらん６九日。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
