        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それはじょうずな芝笛のように聞こえるのでした。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜこんなに雨をふらせたのだ」　蜂雀はじょうずな芝笛のように叫びました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえさんの歩きかたはじょうひんで、軽そうで、どんな踊り子だって、おまえさんみたいにはいかないさ。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り縁日ものを買うことなんぞはじょうずでね。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "話にはじょうずへた、物にはこつというものがあるんだ、こつがね、そのこつをよく心得ているからこそ、あっしがあちらのだんなに代わって、手間をとらせず、むだをいわず、事のあらましをかいつまんで、のみこみのいいように物語ろうってえいうんじゃねえですか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファンだなんて、あやしいもんだな」　むろん私はじょうだんにそんなことを言ったのです。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "長者もいまさら、それはじょうだんだともいえないので、「ああ、ほんとうだとも。",
              "citation": {
                "source": "たにしの出世",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッハハハハハいまのはじょうだんだよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いまのはじょうだんだよ……」　何度顔を洗ってもこの言葉がこびりついている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃はじょうし茂一の店へおいでるそうじぁないけ」「……そうもいかん」「どうで――大分儲かりよったか？",
              "citation": {
                "source": "猫車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまにはじょうだんも云うものですよ、サ行きましょう」　片手ではしっかり衣をかかえ、片手を兄君に引かれて障子に入った。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はじょうだんをいったのである。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまえがギンネコだから、きっとネコばばをするのはじょうずなんだろう」「ははは。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギンネコだからネコばばはじょうずか。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この望遠鏡みたいなものの中に、なにか仕掛があって、絵でも書いてあるのではないか」　と、そのえらい軍人は、半分はじょうだんにまぎらわして、不審な顔をした。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球が、粉みじんに、くだけてしまうのじゃ」「先生、それはじょうだんですか。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉屋はじょうだんだとばかり思っていましたが、お百姓さんはいいました。",
              "citation": {
                "source": "うまい商売",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに湖の岸にすむ人たちは、女でも子どもでも船をこぐことはじょうずですから、おかあさんもお里へかえるときは、いつも自分で船をこいでいきました。",
              "citation": {
                "source": "あたまでっかち",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるならこっちの足を」というと、またそのとおりにしたのがもとで喧嘩をしだしたに、母は見かねて、「今のはじょうだんにしたのだ。",
              "citation": {
                "source": "妖怪玄談",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはじょうだんを言っているのだろうと思って、かれの顔を見た。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんながうっとりするほど、シンデレラのダンスはじょうずでした。",
              "citation": {
                "source": "シンデレラ",
                "author": "CINDERELLA, OR THE LITTLE GLASS SLIPPER",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみはじょうずにこいで行ってくれる。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえきみがわたしの所持金に目をつけて、うしろからかいでひとなぐりして、わたしを冥府へ送ったとしても、やっぱりきみはじょうずにこいで行ったことになるのだろう。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　殿村はじょうだんのように言いながら、部屋のまんなかの大机に近より、その下においてあった大きなくずかごの中から、クシャクシャにまるめた書類のたばを取りだしてみせました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
