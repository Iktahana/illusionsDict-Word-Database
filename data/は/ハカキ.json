    "definitions": [
      {
        "index": 1,
        "gloss": "(girl's arrival at) puberty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところが、そのボネーベ式の拱貫が低く垂れ、暗く圧し迫るような建物が、たちまち破瓜期の脆弱な神経を蝕んでいったのだ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう当分は打ちくつろいでいてもよかろう」　今まで薄暗かった行燈の灯はかき立てられて、座敷は俄かに明るくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに赤や青の灯や池にはかきつばたの形した電燈の仕掛けものそれに港の船の灯や電車の火花じつにうつくしかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれの心はかき乱されぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "読経の声が、ずつと高くなると娘達の姿はかき消えて、今度は店の番頭小僧、はした達のまぼろしがぞろ／＼眼の前をとほり始めた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また五月にはかきつばた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜はかきながら昏倒しました。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから会社の人に会おうじゃないか」「ええ」　二人はかき船を出て、車を拾った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋中ひっくり返され、引き出しを開けられ、戸棚はかき回され、結果としてはポープ訳ホメロスの一方、めっきの燭台を二台、象牙の文鎮ひとつ、楢の小型気圧計に糸撚玉ひとつしか消えておらんかった。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "越えることなんて滅多にありませんが、何とかいくらかはかき集められて。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくあきらめができた今になって、また動揺することになってはならない危険な会見を避けていたのであるが、予感したとおりに御息所の心はかき乱されてしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うまもなくその白い大きな帆さえが、降りしきる雪の中に薄れて行って、やがてはかき消すように見えなくなってしまった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然――それはほんとうに突然どこから飛び込んで来たのか知れない不快の念のために葉子の胸はかきむしられた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日漕ぐと樂しみて見る沼の面の闇のふかみに行々子の啼くわが宿の灯かげさしたる沼尻の葭のしげみに風さわぐなり苫蔭にひそみつつ見る雨の日の浪逆の浦はかきけぶらへり雨けぶる浦をはるけみひとつ行くこれの小舟に寄る浪聞ゆ　さきに私は若葉の頃になれば旅をおもふといふことを書いた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫蔭にひそみつつ見る雨の日の浪逆の浦はかき煙らへり雨けぶる浦をはるけみひとつゆくこれの小舟に寄る浪聞ゆ　平常爲事をしなれてゐる室内の大きなデスクが時々いやになつて、別に小さな卓を作り、それを廊下に持ち出して物を書く癖を私は持つて居る。",
              "citation": {
                "source": "樹木とその葉",
                "author": "なまけ者と雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "挿画にでもピストルはかきたくないと松野氏も言っていたように記憶する。",
              "citation": {
                "source": "伊豆の国にて",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "部室から聴こえてくる、〈シークレット・エイジェント・マン〉のイントロのリフに、その声はかき消されそうになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫蔭にひそみつつ見る雨の日の浪逆の浦はかき煙らへり雨けぶる浦をはるけみひとつゆくこれの小舟に寄る浪聞ゆ　平常為事をしなれてゐる室内の大きなデスクが時々いやになつて、別に小さな卓を作り、それを廊下に持ち出して物を書く癖を私は持つて居る。",
              "citation": {
                "source": "なまけ者と雨",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白壁へふたりはかきぬ。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しらぬこと」ふたりはかきぬ。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よろこび」とふたりはかきぬ。",
              "citation": {
                "source": "どんたく",
                "author": "絵入り小唄集",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍服のボタンは外れ、胸の辺はかきむしられ、軍帽は頷紐をかけたまま押し潰され、顔から頬にかけては、嘔吐した汚物が一面に附着した。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の恥はかきずてとや、旅は失策の少々あらんこそ後々までも興ある者なれ。",
              "citation": {
                "source": "寧樂",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件は一段落ついたとはいえ、間もなく起こった二つの事件で、その平和はかき乱された。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅の恥はかきすて、浮世は三分五厘と、人生を茶化して渡る、彼らの馬鹿気な行動を読んだ時、全く私どもはふき出さずにはおられません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "とは申せ上手に濁す濁さぬはかき廻し手の器用不器用によるのじゃが……法　　どぶのわるさも自らの落ちぬ限りでのう、泥深くてやたらともぐり込むそうでござるから……王　　勿論の事じゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失業と多産のためにほとんど飢餓にひんしているこの階級の親たちにとっては全く天来の福音である」と新聞の記事はかきたてている。",
              "citation": {
                "source": "「市の無料産院」と「身の上相談」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一太は、興にのって、あっちへ行っては下駄で枯葉をかき集めて来、こっちへ来てはかきよせ、一所に集めて落葉塚を拵えた。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」枕もとに坐つて、そ知らぬ風はして見たが、心のうちはかき亂されてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年程｜經つうちに、エメルソンの形式的方面が厭になつたので、斷然棄てゝしまつたが、その同情的精神の沈痛なのには、當時、自分の頭腦と胸奧とはかき亂されて、また整へられて居たのだ。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
