[
  {
    "uuid": "184d92f4-d08f-52cc-9d8c-93313acf8a37",
    "entry": "排除",
    "reading": {
      "primary": "はいじょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
