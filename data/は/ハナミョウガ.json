        "examples": {
          "standard": [
            {
              "text": "庭の片隅に植えた花茗荷が、可愛らしい白い花をつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "薬草として知られる花茗荷は、独特の香りが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この葉っぱ、何？」「花茗荷だよ。お風呂に入れるとリラックスできるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "けさ、萩にかくれて咲き残っている花茗荷をふと見つけた。",
              "citation": {
                "source": "白い花",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やうやく花茗荷が咲いた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やうやく花茗荷が咲きだした、私の好きな花である、白い花だ、匂ひのよい花だ（水仙のやうに、くちなしのやうに、泰山木のやうに）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "散歩、呂竹さんへ花茗荷を持つていつてあげる、句稿を投函する、Ｗ店で一杯ひつかける（アルコールのたゝりか、それともマイナスのたゝりか、めつたにない頭痛がした！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
