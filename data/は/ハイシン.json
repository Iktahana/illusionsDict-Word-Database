[
  {
    "uuid": "41010fc8-d7b9-577d-973b-3b94436d6fdc",
    "entry": "背信",
    "reading": {
      "primary": "はいしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
