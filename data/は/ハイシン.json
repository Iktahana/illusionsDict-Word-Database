    },
    "definitions": [
      {
        "index": 1,
        "gloss": "betrayal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
