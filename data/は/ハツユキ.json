    "definitions": [
      {
        "index": 1,
        "gloss": "first snow (of the season)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
