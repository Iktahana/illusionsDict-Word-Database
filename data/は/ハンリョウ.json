  {
    "uuid": "c395869e-e356-5e3b-a751-2984deb1eee7",
    "entry": "半量",
    "reading": {
      "primary": "はんりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
