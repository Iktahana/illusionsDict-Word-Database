        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "円福寺の椿岳の画　椿岳の大作ともいうべきは牛込の円福寺の本堂の格天井の蟠龍の図である。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "椿岳はこの依頼を受けると殆んど毎日東京の諸寺を駈巡って格天井の蟠龍を見て歩いた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "友之助は左様なことゝは存じません、翌々日は整然と結構な品物ばかり取揃えて風呂敷に包み、大伴蟠龍軒の名前を聞いて居るから、本所割下水へ行くと、結構な誂え物をした上に始めての交際だと云うので、多分の目録をくれ、馳走をして帰しました。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "友之助は結構な出入先が出来たと喜んで足を近く行って見ると、何時も能く来たと云って大伴蟠龍軒も蟠作も兄弟揃って友之助をヤレコレと云う。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日になり漸く七所借をして百両｜纒めて、日の暮々に大伴蟠龍軒の中の口から案内もなしで通りましたが、前と違い門弟｜衆も待遇が違う。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "大伴蟠龍軒の次に蟠作が坐り、其の次にお村が坐りまして、其の次にお崎｜婆が猫脊になって坐って居る、外に門弟が四五人居ります。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の一番下の一合入の盃をとってポーンと投付けると文治郎も身をかわして除けたが、投げる者も大伴蟠龍軒、狙い違わず文治郎の月代際へ当ると、今とは違い毛がないから額の処へ斯う三日月なりに瀬戸物の打疵が出来ました。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話し二つに分れまして、蟠龍軒はお村を欺き取って弟の妾にして、御新造とも云われず妾ともつかず母｜諸共に此に引取られて居ります。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄蟠龍軒は別間に居りましたが、夕方になりましたから庭へ水を打って、涼んで居ります処へ来たのは阿部忠五郎という男でございます。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹「先生々々」　「おー」と答えて二番河岸から上って来たのは大伴蟠龍軒、暑いのに頭巾を冠り、紺足袋雪駄穿きでございます。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟠龍軒は高い処へ上って向うから来るかと見下す、処が人の来る様子がございませんから、神田の方から人が来て認められては適わぬと思いまして、二番河岸の根笹の処へ蹲んで居りますと、左官の亥太郎が来ました。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから蟠龍軒と亥太郎と暗仕合に相成ります。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "十四　亥太郎が拳骨を固めて大伴を打ちました時、流石の大伴蟠龍軒もひょろ／＼として蹌めきましたが、此方も剣術の先生で、スーッと抜きました。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "亥太郎が二度目に上った時は、蟠龍軒は風を喰って逃げた跡で、手に遺ったのは胴乱。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "亥「盗人が提げていた恰好の悪い煙草入、これは打き売って酒でも食え」　と腹掛へ突込んで帰りましたが、悪い事は出来ないもので、これが紀伊國屋へ誂えた胴乱でございます、それが為に後に蟠龍軒が庄左衞門を殺害したことが知れます。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六　大伴蟠龍軒の家に連なる者、或は朋輩などは目の寄る処へ玉と云って悪い奴ばかり寄ります。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度七つ下りになりまして大伴の処へ参りますと、幸い蟠作も居りません、蟠龍軒独りで小野庄左衞門を殺して取った刀へ打粉を振って楽しんで居ります。",
              "citation": {
                "source": "業平文治漂流奇談",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて其の翌日は安永五年の六月三十日でございます、蟠龍軒の道場にて何者にか数多の者が殺されたという届出がありますから早速北割下水蟠龍軒の道場へ御検視が御出張になりまして吟味いたしましたが、誰が殺したのか一向分りませぬ。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の頃八丁堀の町与力｜小林藤十郎という人は、「これは多分蟠龍軒のためさん／″＼恥辱を受けた友之助の仕事であろう」と疑いましたが、誰あって文治の仕事と心付く者はございませぬ。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々木を切り魚を捕りますごとに、思わず、　文「汝蟠龍軒、切って／＼切殺しくれん」　と大声に呼わりましては又我に返り、　文「これで思いが届かねば、人と生れた甲斐もなし、蟠龍軒達者で居れよ」　と云う折しも、木蔭に怪しき声ありて、「達者で居れ」という。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "お町は素より顔を知らぬものですから、蟠龍軒とは心付かず、　町「いゝえ、お恥かしゅうござんす」　と裏口から逃出しました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "町「あいたゝ／＼」　蟠「さアこれでもか、何うだ／＼」　と無理｜強談、折柄暮方の木蔭よりむっくり黒山の如き大熊が現われ出でゝ、蟠龍軒が振上げた手首をむんずと引ッ掴み、どうと傍に引倒しました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "恟り驚いて、　門「やア先生が倒れて居る、先生々々、何うなすった、やッこりゃ大変、先生が気絶して居る、これ名主、水を、早く／＼」　二人の介抱で蟠龍軒は漸く心付きました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "文治は静かに太刀を抜放ち、　文「さア大伴氏、其許は舅の敵の其の上に、よくも此の文治が面部に疵を負わし、痰唾まで吐き掛けたな、今日こそ晴れて一騎討の勝負、疾く／＼打って来い」　蟠龍軒はぶる／＼総身に震いを生じ、すらりと大刀抜くより早くお町の方を目がけて一太刀打込みました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲「この野郎め、途方もねえ野郎だ」　同心「これ百姓、静かにしろ」　見物「何だ箆棒め、糞の掛けられ損か、それ打込むぞ、やア御新造｜危え／＼、此方へお出でなせえ、やアれ危えッてば」　こゝぞと文治は打込もうと隙を窺って居りますと、蟠龍軒は其の切っ先に怖れてか、じり／＼後へ退ります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物「やア親爺、後は川だぞ、もう一足で川だ、馬鹿野郎」　と口々に呶鳴り立てられて、元来卑怯未練な蟠龍軒、眼が眩んだと見えまして、五分の隙もないのに滅茶苦茶に打込みました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "文治はチャリンと受流し、返す刀で蟠龍軒の二の腕を打落しました。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "花時の向島、敵討があると云うので土手の上は浪を打ちますよう、どや／＼押掛けてまいりまして、蟠龍軒の死骸を見ては唾を吐くやら蹴飛ばすやら弥次馬連が大騒ぎをして居ります。",
              "citation": {
                "source": "後の業平文治",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
