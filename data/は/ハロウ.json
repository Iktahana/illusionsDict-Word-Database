[
  {
    "uuid": "9bb06b0a-3f6d-53b4-9a87-f7e856b6417a",
    "entry": "波浪",
    "reading": {
      "primary": "はろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
