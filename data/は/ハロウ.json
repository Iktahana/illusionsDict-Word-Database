      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "waves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "船舶工学方面の研究では、波浪による船のヨーイングに関するもの、同じくドリフトに関するもの、いずれも理論的計算のみならず、簡単な模型実験を行ってその結果を比較したものである。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "和喰　「ワシ」波浪「ケプ」破れる。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しかし、彼女は青磁のリノリウムに花の浮いた波浪をつくると、突然、佗しさを堪えた悲しみの堰がこわれるのだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "盤の一つ一つは独木舟を差し込んだように唐突で単純に見えるが、その底は傾斜して水の波浪性を起用し、盤の突端までに三段の水沫を騰らしている。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて眼界｜頓に開けた所へ出れば、重畳せる群山波浪のごとく起伏して、下瞰すれば鬼怒の清流真っ白く、新しき褌のごとく山裾を迂ぐっている。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖面暗くして波浪上らず、雨脚矢のごとく湖上を打つ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "審かしき迄船脚の深く沈んで見えた其船が、今や闇黒なる波浪の上に朦朧と認められたのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しも波浪に揉まれて、此方に廻りし其艦尾には、赫々たる日輪に照されて「日の出」の三｜字が鮮かに讀まれた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓て本艦の間際になつたが、海は盤水を動かすがごとく、二千七百｜餘噸の巨艦ゆらり／＼と高く、低く、我が端艇は秋の木の葉のごとく波浪に跳つて、迚も左舷々梯に寄着く事が出來ない。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "戀びとよあの遠い空の雷鳴をあなたは聽くかかしこの空にひるがへる波浪の響にも耳をかたむけたまふか。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば時計のチクタク、心臓の鼓動、海洋の波浪等であって、元来、規則正しきものを指すのであるから、自由詩にリズムの無い事は始めから解っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは凡べて新しき刺激は心海に新しい衝動を與へて波浪を扇るものであつて、そして其の波浪の活動衝激は心海の死靜を破り、腐氣を掃蕩し、元氣を振策するが爲に、自ら氣の張るを致すと云ふのに本づいて居るので、新境の現前は言ふまでも無く新しい刺激を與へるからである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い信仰を持つて居る法師であつたから、到底龍神如きがこの俺を沈めることは出來ない、波浪不能沒だ、と信じて疑はぬぢやから、其處でそれ自若として居られる。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として、それは一人の人間の現在、未来に重大に働きかけ、また、一時の波浪の如くにも起って消えるということだった。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今にして思へば政海の波浪は自から高く自から卑く、虚名を貪り俗情に蹤はるゝの人には棹を役ひ、橈を用ゆるのおもしろみあるべきも、わが如く一片の頑骨に動止を制し能はざるものゝ漂ふべきところならず。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども我は実にこの波浪に漂蕩して、悲憤慷慨の壮士と共に我が血涙を絞りたりしなり。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "下田を出ると、船は忽ち烈しい波浪の中に入つた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの岩から岩の間にかもされた波浪は、見ごとでもあり凄くもあつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "万寿丸｜甲板部の水夫たちは、デッキに打ち上げる、ダイナマイトのような威力を持った波浪の飛沫と戦って、甲板を洗っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船体は保険マーク以上に沈んでいるので、充分に抵抗的であって、波浪は一つも残らずデッキへと打ち上げた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫らは、デッキを洗う波浪からダンブル内への浸水を護るために、ハッチカバー（船艙のおおい）や、それを押えた金具や、またその上から厳重にロープを通して縛らねばならなかった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのたびに柄杓が水をすくうように、デッキは波浪をすくい込んだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはそのからだが、そのまま凍るような風の下に、メスのように光る、そして痛い波浪に刺された。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船首の船底は、波浪と決闘するように打ち合った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間にも波浪は、船首甲板ほどではないにしても三、四｜度、ここを洗った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この仕事は、波浪の恐れは全然なかったが、動揺と、風と、おまけに「てすり」がないので、海へ落ちるという危険を伴った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は暮れかけて、闇は、波と波との谷間から煙のように忍び出しては、白い波浪の飛沫に、け飛ばされていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂犬の口をおおう泡のようなおそろしい波浪と、この夕暗とに、あの船はのまれてしまうんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫らは、セキメーツの怒鳴るのと、波浪のほえるのと、スクルーの轟音と、リギンの裂くような音とをゴッチャゴッチャに聞いてしまった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「偽善者奴、お前は又偽善をはろうと云うのだな」私の傍で一つの声が聞えた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
