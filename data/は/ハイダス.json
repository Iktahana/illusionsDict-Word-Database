    "definitions": [
      {
        "index": 1,
        "gloss": "to crawl out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私達戸外に這い出す。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はうるさそうに、ベッドから這い出すと、「もし、もし……」「須賀さんでいらっしゃいますか」　電話の声は美しかった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、眼をさましてからもあわてて寝床から這い出すようなことはなく、二時間ほどは眼をつぶって眠ったふりをしているのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、啄木鳥に穴の底を叩かれて、ノコノコ這い出すような謙信ではなかった。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはあわてて洞穴から這い出すと、眇目の男は手をふってさえぎった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの声がほととぎすか」と羽団扇を棄ててこれも椽側へ這い出す。",
              "citation": {
                "source": "一夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分外でどんなに夢中で遊んでいても、薄闇が這い出す頃になると、泣きたい程家が、家の暖かさが恋しくなった。",
              "citation": {
                "source": "粗末な花束",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白銅や銀貨がつぎつぎに彼のポケットへ消えて、代りに何羽ものひよっこが甲板を這い出す。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて隙間があるのに気づき、そこから這い出すと、工場の方では、学徒が救いを求めて喚叫している――兄はそれを救い出すのに大奮闘した。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、圧しにかかった梁は、虫の這い出すほども動きません。",
              "citation": {
                "source": "疑惑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂人のようになれぬ以上は、このみじめな環境から這い出すべしだと思う。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、むつは風呂桶から這い出すと、薄い材木をかついで來たり、わらなわを探して來たりして風呂桶のなかで自分の脚と腰をしばり、上へ、材木をならべてふたをしてしまいました。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春眠暁を覚えずとか何んとかいう言葉があるが、全く春の朝寝のぬくぬくとした寝床の温気は、実はこうしていられないのだと思いながらも這い出すことが容易でないのと同じように、大阪地方の温気に馴れた純粋の大阪人にとっては、何かの必要上、この土地を抜け出すことには随分未練が伴うようである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "穴はかなりに大きくて、蟹はすぐそこから這い出すことが出来ました。",
              "citation": {
                "source": "椰子蟹",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして毛穴から這い出すような膏汗が、背中と腋の下を不意に襲った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると、身体にたまった糞を出しに土の上へ這い出すんだ。",
              "citation": {
                "source": "みみず先生の歌",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中でも慣れた目でよく見れば、中から這い出すようにして庭へ下りる人は、小脇に白い物を抱えていることがわかります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "マドロス並びに兵部の娘らしいのが、万石浦を小舟で渡ったというのを見た者があるというから、これは、いずれその辺の、木の根、石の蔭に当分こらえていて、たまらなくなれば這い出すのだ、この方は発見にそう骨が折れない！",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳数枚にもあたる巨大な白蜘蛛が、暗い洞窟の中から這い出すように、今、離座敷の、左門の部屋から、縁側の方へ這い出しつつあった。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の隙からでも、小判がぞろぞろ這い出すところを、見てえもんだ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "悲願百両",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし幸い一本道だったから、どぎまぎしながらも、細い穴を這い出すと、ようやく初さんがいた。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくの思いで笹原を這い出すと向うに大きな池がある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（ガサガサと言わせて炭焼ガマから這い出す）ふう！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "へっついの上に立って、引窓から漸く首が出るだけで、屋根に両手を掛けて這い出すのは、並大抵の芸当じゃありませんぜ」「人一人抱えて、あの窓から出られると思うか」「とても」　八五郎は大きな掌を、以っての外といったように振って見せるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に八五郎は自分の身体一つを這い出すんでさえ、一と騒動やったじゃないか」「すると親分、あの軽業師」「明石の五郎八はくさいが、あれでもない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次はそれからすっかり寝正月をして、三日の朝不精床を這い出すと、「お早う」　ガラッ八の八五郎が忠実な顔を持って来たのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかしたら、閻魔の屋敷の雪隠の床下かも知れないと思って這い出すと、眼の前に燃え残りの護摩壇が見えるじゃありませんか」　ガラッ八の話は手振りが交りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "火遁の術",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、私が」　お国は障子を押し倒して這い出すと、跣足のまま格子の外へ、母親の本能の導くままに、暁闇を縫ってバタバタと伜の後を追って行くのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死骸の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう雨の日にきつくなって肌にまつわりつくような潮の匂い、雨だれのところに這い出すカニ、そんなことを思い出します。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "火がぐるりをかこんでも大丈夫と主人公は申しますが、さてそれはどうでしょう、わたしはまだローステッド・ブランカになるには早すぎますから、火事が本式となったら、その穴からは這い出すつもりで居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
