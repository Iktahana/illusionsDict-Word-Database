        "examples": {
          "standard": [
            {
              "text": "鼻炎が長引くと、鼻の中に鼻茸ができてしまうことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "耳鼻科で検査を受けたら、鼻茸が見つかり手術が必要だと言われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鼻茸が大きくなると、鼻詰まりや嗅覚障害の原因になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小樽の森本春雄が兼ての鼻茸を治療して貰ふ爲め入院してゐるからである。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度、久保｜猪之吉氏が学会で九州から上京され、駿河台の宿屋に泊っておられ、豊国の描いた日本で最初に鼻茸を手術した人の肖像を写すことを依頼されて、その宿屋に毎日私が通っている時に、鏡花先生御夫妻が遊びに見えられて、お逢いしたのでした。",
              "citation": {
                "source": "泉鏡花先生のこと",
                "author": "小村雪岱",
                "note": "青空文庫"
              }
            }
          ]
        }
