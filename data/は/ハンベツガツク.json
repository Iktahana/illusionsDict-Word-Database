        "examples": {
          "standard": [
            {
              "text": "暗闇の中では、何が何だか判別がつかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の書く文字は個性的なので、誰の字かすぐに判別がつく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "音だけでは、どの楽器が演奏されているのか判別がつかない時がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "でも、判別がつくほどはつきり叫んだわけではなかつたのですが、腹ではそんな間違ひをして居りました。",
              "citation": {
                "source": "早春のひところ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんなことは、ちょっと見たくらいで判別がつくものではなかった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕闇のほの明りではあるが、正四郎の顔ぐらいは判別がつく。",
              "citation": {
                "source": "その木戸を通って",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
