[
  {
    "uuid": "f2c743de-610a-5ef5-87f2-e300704d1888",
    "entry": "沛然",
    "reading": {
      "primary": "はいぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "torrential (rain)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浴後の茶漬も快く、窓によれば驟雨沛然としてトタン屋根を伝う点滴の音すゞしく、電燈の光地上にうつりて電車の往きかう音も騒がしからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然強風が吹起こつて家を揺がし雨戸を震はすかと思ふと、それが急に丸で嘘を云つたやうに止んで唯沛然たる雨声が耳に沁みる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然強風が吹起こって家を揺るがし雨戸を震わすかと思うと、それが急にまるで嘘をいったように止んでただ沛然たる雨声が耳に沁みる。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "沛然と大雨になり、無力な私も、思わぬところで御奉公できるかも知れない。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中に沛然たる雨の音で目がさめる。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほこりっぽい、乾苦しい、塩っ辛い汗と涙の葬礼行列の場面が続いたあとでの、沛然として降り注ぐ果樹園の雨のラストシーンもまた実に心ゆくばかり美しいものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕立が沛然とやつてきた、よい雨だつた、よろこんだのは草木ばかりぢやない、虫も人もよろこんだ。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士が、そのマダムとわかれてから、沛然と夕立ち。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を出すとやがて驟雨は沛然として到つた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "而かも沛然たる一雨のあとで、煙草製造工場の屋根が銀碧の色に輝いて居た。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父母にはたゞ諦めよと告げよ」と聞えたと見るまに、黒雲は元に納まり、再び大雨が沛然と降り注いだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、五右衛門もさる者であったから、いつまでも蟇の我慢という洒落に、甘んじていず、再び「南無さつたるま、ふんだりぎや、守護しょうでん、はらいそはらいそ……」　と、必死の呪文を唱えたかと思うと、沛然と雨を降らした。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎明印度画趣白き鷺、空に闘ひ、沛然と雨はしるなり。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の滴々なるもの忽ちにして沛然として下り、飛沫散じて四顧漠々たり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "山ふところに吹き付くる、雲のちぎれの雨に凝り、沛然として降る三日、土洗はれて山痩する。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日は朝から暑かったが昼頃になって雷鳴と共に豪雨が沛然と降り下り、風は山々の木をゆるがせた。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "風に煽られた大雨が一頻り沛然として降り注いで来た。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやッと思う間に、一朶の黒雲が青空に拡がって、文字通りの驟雨沛然、水けむりを立てて瀧のように降って来る。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ためらひ勝ちに落ちてゐたが、やがて沛然と音をたてゝ勢のいゝ雨が訪れる。",
              "citation": {
                "source": "かげろふ断章",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の救ひとなつた沛然たる大雨が思ひ出された。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが五葉のマツはそうでもなかったが、巨グリのほうは倒れながら叫んで、この下村を泥の海にするといったと思うと、たちまち大雨が沛然と降り出して大水が出た。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時頃、沛然として夕立がやつて来た、よい雨だつた、ありがたい雨だつた、何よりも農家の歓喜が思ひやられる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時半頃に數日來暫く催してゐた雨が沛然と降り出し、それがために群衆は四散し屋敷の周圍を警戒する警官は大いに助かつた。",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵一昼夜経てば天候は変るのに、その雨は三十日になってもやまず、一日同じひどさ、同じ沛然さで、天から降り落ちた。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、急に頭上の空が暗黒と化したかと思ふと、沛然として大粒の雨が落ちて来た。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、急に頭上の空が暗黒と化したかと思うと、沛然として大粒の雨が落ちて来た。",
              "citation": {
                "source": "夏の花",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "沛然とした雨が終日つづく。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中空知のぼんもじりより沛然たる雨で、澤梨の白い花が虹のやうに光つて見えた。",
              "citation": {
                "source": "摩周湖紀行",
                "author": "――北海道の旅より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、兵太郎君はいぜんから、死んだふりや、腹のいたむまねが、ひじょうにうまかったからである。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "荻生さんはいぜんとしてもとの荻生さんで、町の菓子屋から餅菓子を買って来てご馳走した。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
