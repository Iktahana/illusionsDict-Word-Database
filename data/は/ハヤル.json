    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be popular",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "近頃｜流行る高山旅行などではなおさらである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋の通った劇よりも、筋はなくて刺戟と衝動を盛り合わせたレビューの流行る現代に、同じような傾向が色々の他の方面にも見られるのは当然のことかもしれない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、近頃の教科書には本文とは大した関係のない併し見た眼に綺麗なような色々の図版を入れることが流行るようである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊の撲滅　北米バルチモアーでは蚊のためにいろんな病気の流行るのを防ぐために一昨年市会で二万円ほど支出して撲滅にかかったが、結果がよかったので今年また一万円ほど支出したそうである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　半分風邪を引いていると風邪を引かぬ話　流感が流行るという噂である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹の花が咲くと流感が流行るという説があったが今年はどうであったか。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっしの近所にどうも変なことが流行り出してね」「なにが流行る、麻疹じゃあるめえ」「そんなことじゃあねえので……」と、庄太はまじめにささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、なかなか流行ることだと半七は思っていると、やがて自分の番がまわって来て、かれは正面の祈祷所へ通された。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はね、きっと流行るやうな新らしい鬚の型を知ってるんだよ。",
              "citation": {
                "source": "床屋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、この頃外国でこんなのが流行るというので、ミュルで作って見たのだというのである。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "唄うはこのごろ流行る歌と覚しく歌の意はわれに解し難し。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先端的なものの流行る世の中で古いものを読むのも気が変わってかえって新鮮味を感じるから不思議である。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは何、懇意な男だから、先方でもそう言ってくれるけれども、上手なだけ流行るので隙といっちゃあない様子、それも気の毒じゃあるし、何、寝ているほどの事もないんだよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭球もある、「クリツケツト」もある、射的塲もある、相撲の土俵もある、いづれも櫻木大佐が日本を出づる前から、かゝる孤島の生活中、一同の無聊を慰めんが爲めに凖備して來た事とて「テニス、コード」も射的塲も仲々整頓したものである、然し、此島で一番流行るのは端艇競漕と野球競技とであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の知りあひに、御旅館とは表看板、實は安下宿に居るのがあるが、秋のながあめ、陽氣は惡し、いやな病氣が流行ると言ふのに、膳に小鰯の燒いたのや、生のまゝの豆府をつける。",
              "citation": {
                "source": "湯どうふ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前には濃い紫と云ったけれども――肩に手を掛けたのは、近頃｜流行る半コオトを幅広に着た、横肥りのした五十｜恰好。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつがこの頃｜流行るスットントンという歌を知らんちうて逃げて帰って来たもんですけに……どうも申訳ありませんで……」　二人の青年はいよいよ訳がわからなくなった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が遊び盛りの若いうちは運びの留守番、医者になつて流行るうちは客の取次、薬の調合、それからやつと家にゐるやうになると、病人になつた夫の介抱だ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の者を語ったり観たりするのも、流行る流行らぬは別として、まんざら面白くないこともあるまい。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦ということが元来博奕的のものだから堪らないのだ、博奕で勝つことの快さを味わったが最期、何に遠慮をすることが有ろう、戦乱の世は何時でも博奕が流行る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃｜流行るけれど、ありゃ不躾だね。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えー、えー行き度いなら勝手に行っちまいなさいとも、安宅先生といいこの頃は勝手に一人で行くことが流行るらしいわ」「よし、行く」　葛岡は上衣を持って立上りかけました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女自身も流行ることは一向に望まなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "墨子の流れを汲む世界的愛他主義が流行るかと思えば一方楊朱の一派は個人主義的享楽主義を高唱した。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行る人の處へは猫も杓子も尋ねて行く。",
              "citation": {
                "source": "長谷川辰之助",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は翻譯書と云ふ翻譯書を予の家に持ち込んで、序文を書かせることが流行る。",
              "citation": {
                "source": "翻譯に就いて",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　下谷の坂本通りで善吉を斬ったのは何者であるか、このごろ流行る辻斬りであろうというだけのことで、遂にその手がかりを獲ずに終った。",
              "citation": {
                "source": "兜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊野で聞いたは狼もっとも痘瘡の臭を好み、この病｜流行る時村に忍び入って患者に近づかんとすと。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳ／２だＷｉｎｄｏｗｓだ、ＵＮＩＸは流行る流行らん、ＲＩＳＣがああだ、Ｌａｎ　Ｍａｎａｇｅｒがこうだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この分野はほうっておいても絶対に流行る。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
