        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "プロジェクトの進捗について、お互いに腹合わせをして課題を共有した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重要な決定を下す前に、関係者間でしっかりと腹合わせをしておく必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「何かあったらすぐに腹合わせしようね」と、チームのメンバーに伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
