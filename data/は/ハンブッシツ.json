          "literary": [
            {
              "text": "または反物質でもなければ光子でもない。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "通常の原子とは逆に、負の電荷を持った電子の周囲を正の電荷を持った陽子が回転しているという反物質はの構成要素ではあり得ないだろう。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら反物質は通常の物質と接触したときに核爆発を起こすからだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
