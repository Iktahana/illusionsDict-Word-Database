          "literary": [
            {
              "text": "肺は正常で空気が一杯だがある種の病気では病的な分泌が肺胞を満たすことがある。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様に左手を胸の上に優しく置いて左手の１本の指を右手の指で叩くともしも肺胞に空気が一杯であると音色は「清音」（共鳴音）であり病的分泌液で一杯なら音色は「濁音」である。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
