[
  {
    "uuid": "6aecf7d6-4e54-5849-abf0-34096c8aadcc",
    "entry": "範囲内",
    "reading": {
      "primary": "はんいない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
