[
  {
    "uuid": "0e9cadf8-beef-5a8e-9810-b62c3cd81432",
    "entry": "発想",
    "reading": {
      "primary": "はっそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
