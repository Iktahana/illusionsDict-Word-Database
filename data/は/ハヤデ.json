    "definitions": [
      {
        "index": 1,
        "gloss": "leaving early (for work)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "早出の蚊を食おうとぬるい水にもんどり打つ池の真鯉――なやましく藹たけき六月の夕だ。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、どうせ今日は繰り越し仕事が溜っているんだから、偶には早出も信用を取り返していいだろうさ。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "早出の蚊を食はうとぬるい水にもんどり打つ池の真鯉――なやましく※たけき六月の夕だ。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに末造が女房の病気に試みた早出遅帰の対症療法は全く功を奏せなかったのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "イブニング・スタンダードの早出しだ。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は僕を呼びちかづけて、座敷船はまだ出づべしやと問ふに、僕は飛行く雲を指さして、この覚束なきそらあひなれば、最早出でざるべしといふ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し之れありとせば、ソは最早出来事とは称すべからざるなり。",
              "citation": {
                "source": "罪過論",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "――亭乎とした体を真直にして玄関から上つて行くと、早出の生徒は、毎朝、控所の彼方此方から駆けて来て、敬しく渠を迎へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "――亭乎とした體を眞直にして玄關から上つて行くと、早出の生徒は、毎朝、控所の彼方此方から驅けて來て、恭しく渠を迎へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い路次にある裏の入口に立つてみると、そこに細い二段の階段があり、階段の側にむせるやうな石炭や油の嗅気の漂つたコック場のドアがあり、此方側の、だらしなく取散らかつた畳敷の女給溜りには、早出らしい女給の姿もみえて、その一人が立つて来て、じろ／＼晴代の風体を見ながら、二階の事務室へ案内してくれた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の昨今では、早出、残業、夜業は普通であるし、設備の不十分な下請け工場の簇出と不熟練工の圧倒的多数という条件は、工場内での災害をこれまでの倍にした。",
              "citation": {
                "source": "新しい婦人の職場と任務",
                "author": "――明日の婦人へ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉が郷里から出て来てくれることに成っていますからね」「姉さんは最早出ていらしったんですか」「いえ、まだ……来月でなきゃ」「あなたは今月のうちに神戸へお立ちに成るというじゃ有りませんか。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日西役所え云云の由、早出帆と決心仕候ニ付、通弁者其外、人数をそろへ異館へ参候所ナリ。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月六日　佐々木高行あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「糸ッ、何を泣いてるのや、早出してやらんかい。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからほどなく、早出に篠宿を発った一人の旅人が、峠の裾はるか底に、一団の火焔が上るのを認めた。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桜こそ咲いては居りませんでしたが金糸桃の花は家々の園で黄金のような色を見せ夢のように仄な白木蓮は艶かしい紅桃と妍を競い早出の蝶が蜜を猟って花から花へ飛び廻わる――斯う云ったような長閑な景色は至る所で見られました。",
              "citation": {
                "source": "天草四郎の妖術",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仄かな暁の蒼褪めた光が戸の隙間から射し込んで来て、早出の花売りの触れ声が聞こえる時分になっていたが、彼の苦吟は止まなかった。",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを生出す計畫を立て原圖を拵へてやるだけの技術が最早出來て居つたのです。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の中に土蔵の塗直しが始まり、質屋さんでは土蔵を大事にあそばすので、土蔵の塗直しには冬が一番｜持がいゝと云うので、職人が這入ってどし／＼日の暮れるまで仕事をして、早出居残りと云うのでございます。",
              "citation": {
                "source": "真景累ヶ淵",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうは一月遅れの七夕ですから、初穂として早出来の甘藷を掘って見ました。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それ、うまうま」　と子供に乳房を咬えさせたが、乳は最早出なかった。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも大抵カッフェーにいる間から予め知れていることで、今日のような早出の朝、不意に尋ねて来ることは滅多にない。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "良吉は最早出立したのか知らんと、急いで階下へ下りると、弟は竹の手のついた煙草盆を膝に載せてゐる父親の前に不恰好なお辭儀をして、これから出掛けようとするところだつた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　朝の七つ半刻、むらさき色の薄靄が暗黒を追い払おうとして、八百八町の寺々の鐘、鶏の声、早出の青物の荷車――大江戸は、また新しい一日の活動にはいろうとして。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お久美は、早出の用意に脚絆など揃えながら、手を休めてそう思った。",
              "citation": {
                "source": "あの顔",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "胆をつぶしたのは沿路の百姓、早出の旅の衆で、「うわアい！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半時ほど前だから卯の上刻だ、親分も知ってなさるだろうが采女の馬場の中屋敷ね、あすこの西尾様お長屋の普請場へ面出しすべえとこちとら早出だ、すたすた来かかってふいと見るてえとこの獄門じゃあねえか、いや、親分の前だが、これにゃああっしも胆を潰したね。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私にはそんなスマートな同情を持つことすらもはやできないのだ。",
              "citation": {
                "source": "放送された遺言",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "能などでは袖なしの前のあいてる側継、あれがちはやである。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では昨夜本署から引取っていった若い女の轢死体というのは、お前の妹ではなかったというのだな」「どうも何ともはや……」「何ともはやで、済むと思うかッ」宿直はあとでジロリと一座の署員を睨みまわした。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
