        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "初日の出、」　いいかけて急に膝を。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオが湯気に籠りながら、山の初日の出見物の光景をアナウンスする。",
              "citation": {
                "source": "健康三題",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "來年はこれよりも美くしい初日の出を拜みたいものだ。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は其柔和な顏に微笑を浮べて『毎年初日の出を拜みに出るのか。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大島老人が彼を救ふた時、岩の上に立つて、『來年はこれよりも美くしい初日の出を拜みたいものだ。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをなまじつか今の歌人に頼んで作らした所でありふれた、初日の出の歌などは感心しないぜ。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうして、その島の向うに初日の出の見えるところを描いて戴きたいのです。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「島が二つ並んで、向うに初日の出……すると先づ、二見が浦といつたやうな所なんですね。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは元日の黎明に若水汲んで含嗽し、衣を改めて芝浦、愛宕山、九段、上野、待乳山などに初日の出を拝し、帰来屠蘇雑煮餅を祝うて、更に恵方詣をなす、亀戸天神、深川八幡、日枝神社、湯島天神、神田明神などはその主なるものである。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日の出を慕って午前六時剣ヶ峰へ向う。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし東の空はよく晴れていて――午前六時四十分――雲の上から出る初日の出は実に荘厳の極であった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "憶ふ昔と云ふ程でもないが、明治二十五年の一月其頃寄宿舎に居た子規子始二三の人が俳句と云ふものを作るので、僕も少々真似がして見たくなつて、四十五の夢をさまして初日の出元日や仏に成るも此の心と遣つたが、どうも恥しいので人に見せられない。",
              "citation": {
                "source": "鳴雪句集",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "東天に向つて初日の出を拝す。",
              "citation": {
                "source": "日記について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "エッフェル塔のてっぺんで初日の出を拝んだといったら話の種になるわね」「ええ、のぼれるのよ。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "エッフェル塔のてっぺんで初日の出を拝んだといったら、話の種になるわね」「ええ、のぼれるのよ。",
              "citation": {
                "source": "野萩",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦の初日の出を、伊豆近海におがみ、青空に神々しくそびえる富士山を、見かえり見かえり、希望にもえる十六人をのせた龍睡丸は、追手の風を帆にうけて、南へ南へと進んで行った。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安直普請とはいえ、油断がならない――一方には、まだ初日の出ない興行場を見物に来た人が、原の四方を鹿の子まだらに埋めるほどになっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――初日の出の元日――あたりはどうだ。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日の出が上る――　五人は、匕首を抜いて、「さ、兄弟分の盃」　と、二の腕を切り、日の出より赤い血を、啜り合った。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの意気も、約束も失ったので、今では、義兄弟とも、乾分とも、思っていないが一度は、間の山の初日の出に、大盗立志伝中の人間になろうぜと、血をすすり合った事もある四人の最期に――。",
              "citation": {
                "source": "雲霧閻魔帳",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、身を浄めて、初日の出を待とうか」　流れの瀬へ寄って、彼は帯を解いた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、帰るお城があるというのは、何といいものじゃないか」　部下の足軽たちへそう話しかけながら行く彼のその顔は――しかし、初日の出よりらんらんと元気であった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こよいに限り夜空もあかあかと篝が照り映え、今朝の初日の出がまだ沈みきらずにあるようだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
