    "definitions": [
      {
        "index": 1,
        "gloss": "hash (function, table, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何もかも、一時でも忘れさせて呉れるなら、酒でも阿片でもハッシュシュでも、私は即座にのみこむ。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暗殺者」（アサシン）という言葉はアラビア語のハッシュラッシュ（大麻を食べる人）から来ている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷凍のハッシュド・ブラウンの、茶色に焼けた平たい四角な切り身のようなものを、気にいった個人的な時間のなかで食べるなら、美味ですらあり得る。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥー・エッグス・ウィズ・ハッシュド・ブラウンズ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハッシュ・パピーなんかはいちゃってさ」（エレン・ベイカー）29「ボクはマッチ箱だ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月二日　朝食＝煎り卵と、コーンビーフ・ハッシュ。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだっけ、昔は、ここの朝飯に、コーンビーフ・ハッシュってものが出た。",
              "citation": {
                "source": "富士屋ホテル",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "入浴、食堂へ、スクラムブルエグとコンビーフハッシュ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪屋のポタアジュとトースト、ハッシュライスを食ひ、又大西・会田に揉ませる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
