        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "運転手がハンドルを握った。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、早仕舞にしようじゃないか」　秋山と云う、ライナーのハンドルを握ってるのが、小林に云った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、もう五尺は入っただろう」　ガラガラッとハンドルを廻しながら、六尺鑿を抜き出した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき女がオルガンのハンドルを※した。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、右手の直ぐとつつきの部屋の扉の前に歩み寄つて、ハンドルに手を掛けた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような自動車のハンドルを握って四通八達の街頭に立っているようなものである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "座席に腰かけた人の右手にハンドルがあってそれをぐるぐる回すとチェーンギアーで車台の下のほうの仕掛けがどうにかなるようにできているらしい。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様なわけで器械の工率のディメンションは時間のマイナス三乗を含むから、映写機のハンドルを二倍の速さで回せば、一馬力の器械が八馬力を出して見えるのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばね仕掛けであるはずの戸が自然にしまらないのを不思議に思ってふと気がつくと、彼女が静かにハンドルを握りながら、ほほえんで立っていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "オールを入れて左右のハンドルを片手で握り乍ら素早くシートへ彼女は腰を滑り込ます。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん上にのぼって行って、とうとうそのすりばちのふちまで行った時、片手でハンドルを持ってハンケチなどを振るんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "びっくりしてブドリが窓へかけよって見ますと、いつか大博士は玩具のような小さな飛行船に乗って、じぶんでハンドルをとりながら、もううす青いもやのこめた町の上を、まっすぐに向こうへ飛んでいるのでした。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の運転手がハンドルを動かしているのとはわけが違う。",
              "citation": {
                "source": "久保田米斎君の思い出",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドルが水牛の角のやうな形をし、ブレーキと荷｜掛けとチエーンのカバーがない。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉のハンドルががちやりと鳴つて、教壇の上に先生の姿を見るまでの數秒間、先生の動作は講堂で見た時のそれとは、餘程落ち着いてゐるやうに思はれた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "股を刳った女乗りの紅色の自転車にはまたハンドルに幅広のリボンが蝶型に結び付けられていた。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓司はハンドルを尾根山道の方へ取りながら、ふとわたくしを見つけて「おゝ、ぼんやりのお蝶か。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その贔屓の仕方が結局はいま言うわたしの性格の弱さをハンドルに握って、わたしを自由自在に自分の好みに叶う装飾品に仕立てるに外ならなかった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに一台の自転車が錆びたハンドルだけ見せていた。",
              "citation": {
                "source": "褐色の求道",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ハンドルを握ったとたんに、もう君枝は尻餅をついて、便利屋の前はたちまち人だかりがした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、章三はドアのハンドルをつかんではなさなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず絶えず電車が通る……おしろい汗を吹く草の葉に、裁縫器の幽かな音に、よせかけた自転車の銀のハンドルの反射日は光り、かるい埃が薄い車輪をめぐる……赤い花、小さい花、石竹と釣鐘草。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　プ…………ッ、ピッピッピッピッピッ、急に帽子の後頭をすくめた運転手は、やたらに逃げ腰の、ハンドルにばかりしがみついた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの鉄橋からまわりますか」「よし」　そこでハンドルを右へきゅっと廻す。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドルを両手に、パナマを阿弥陀に頭の毛を振り振り、例の快活な笑いの持ち主だ。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ハンドルを持ったとたんに、もう君枝は尻餅をついて、便利屋の前はたちまち人だかりがした。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の手は出前の盆を高くさし上げたまま、左の手をハンドルにかけ、左の足をペダルに掛けて、つっと車を乗り出すと同時にからだを宙に浮かせ、右脚を軽く上げてサドルに腰をかけようとしたが、軽い風が水色模様の浴衣の裾を吹いて、その端が危うくサドルに引っかかりそうになった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇帝が前の座席の左側にすわってハンドルを握り、皇后はその右側にすわって一枚の地図を拡げ何か皇帝にお尋ねになると、皇帝は右を向いてその地図をのぞき込まれた、その瞬間に車の右の前輪が道の片側を仕切るコンクリートの低い土手の切れ目にひっかかった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは先代の皇帝も今の皇帝も自分でハンドルを握って墜落の危険の絶無ではないような道路を走らせることに興味を持たれたという事がたしかに一つの必然な因縁でつながれているのである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉川機関手は腰を上げて、リバース・シングルバース・ハンドルを引き倒した。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            }
          ]
        }
