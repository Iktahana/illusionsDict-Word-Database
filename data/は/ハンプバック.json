          "literary": [
            {
              "text": "ラハイナのすぐ近くの海を堂々と泳いでいく鯨、ハンプバックの姿がスクリーンに登場したシーンを思い出すと、そのシーンは、双眼鏡をとおして現実のハンプバックを自分の目で見たときのシーンに、重なっていく。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十フィートもの高さに潮を吹くのは、大人のハンプバックだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくがはじめて見たハンプバックは、北の海へ帰っていくときの彼らのうちの一頭だった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のハンプバックも見た。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
