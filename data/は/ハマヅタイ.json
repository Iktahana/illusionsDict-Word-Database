          "literary": [
            {
              "text": "「行けますがね、それは浜伝いのほうが趣がありますよ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜伝いにＳ村へ出る途は高い砂山の裾をまわり、ちょうど海水浴区域とは反対の方角に向っていた。",
              "citation": {
                "source": "海のほとり",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔し房州を館山から向うへ突き抜けて、上総から銚子まで浜伝いに歩行た事がある。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴルフリンクの下の砂浜伝いの細道は、岬のすぐ先きで陸に向かい、やがて立派な道になつてクレイブン邸のほうへ通じていた。",
              "citation": {
                "source": "緑色の人",
                "author": "THE GREEN MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「郵便配達がはつきり話してくれたけど、提督が浜伝いに帰つてくるのを見たんですつて。",
              "citation": {
                "source": "緑色の人",
                "author": "THE GREEN MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "千本というだけあって浜伝いは見霞む限り松原だ。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本海道は廻り道、三枚橋の浜伝い、勝手覚えし抜け道を……」「成程、あの三枚橋か。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
