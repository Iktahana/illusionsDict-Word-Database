          "standard": [
            {
              "text": "新しい会社を設立するにあたり、払込資本の額を決定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "企業の財務諸表を確認する際、払込資本の項目に注目した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "払込資本は、会社が株主から調達した資金の総額を示す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一方は熊本の山奥の僅か八百キロの電気会社から出発して今では構成会社二十七、払込資本三億円。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方は熊本の山奥の、僅か八百キロの電気会社から出発して今では構成会社二十七、払込資本三億円の小口翼の日興コンツェルン。",
              "citation": {
