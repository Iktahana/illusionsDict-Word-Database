[
  {
    "uuid": "2a2d190c-a84a-5556-865d-20cec360574f",
    "entry": "含羞む",
    "reading": {
      "primary": "はにかむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
