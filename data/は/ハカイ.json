[
  {
    "uuid": "2d82aecc-4e1b-5d1f-a970-770467427786",
    "entry": "破壊",
    "reading": {
      "primary": "はかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "destruction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我等は過去の詩形を破壊すること。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や私共の狂暴な破壊は終つた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "このケーブル線路の上の方の部分は近頃の噴火に破壊されていたので徒歩の外に途はなかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれが近代人の伝統破壊を喜ぶ一種の心理に適合するために、見当違いに痛快がられているようである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処の深山から出て何処の幽谷に消え去るとも知れぬこの破壊の神は、あたかもその主宰者たる「時」の仕事をもどかしがっているかのように、あらゆるものを乾枯させ粉砕せんとあせっている。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにこの美麗なる上高地の峡谷に対して、早くも残虐なる破壊が、その森林から始まった。",
              "citation": {
                "source": "上高地風景保護論",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は冷気のために雪が岩石の膚肌に凝結し、昼はそばから蒸発して行くので、冷熱の変化から岩石を破壊し、山体を陶器の破片のように滅茶滅茶にして散乱させる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪のある地方より高く抜いた山は、風化作用という破壊力のために、次第に低く削られるけれども、それが雪の多いところまで低下して来ると、かえって雪氷のために風化作用の爆裂から保護されて、傾斜も柔和になって、相応に高い平均高度を有することになる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし破壊的地震としては極めて局部的なものであって、先達ての台湾地震などとは比較にならないほど小規模なものであった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水で下車して研究所の仲間と一緒になり、新聞で真先に紹介された岸壁破壊の跡を見に行った。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした工事が天然の風致を破壊すると云つて慨嘆する人もあるやうであるが自分などは必ずしもさうとばかりは思はない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この颱風は日本で気象観測始まって以来、器械で数量的に観測されたものの中では最も顕著なものであったのみならず、それがたまたま日本の文化的施設の集中地域を通過して、云わば颱風としての最も能率の好い破壊作業を遂行した。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした工事が天然の風致を破壊するといって慨嘆する人もあるようであるが自分などは必ずしもそうとばかりは思わない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにも伝統の破壊があるのである。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に糸を引き切る場合ならば簡単なれども、地殻のごとき場合には破壊の起り方には種々の等級あるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "破壊がただ一回に終らず、数回の段階的変化によるとすれば、これらの推移中に歪みの変化は複雑に起り、場合によりては毎回地震の強度は微弱なる事もあるべく、また時にはその中に強震を生ずる事もあるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体的に云えば地辷り等がある限界内に止まれば、それだけにて止むも、少しにてもこれを超ゆれば他の弱点の破壊を誘起して更に大なる変動を起す事もあるべく、その際如何なる弱点が誘発さるるやはまた偶然的なる地下の局部的構造によると考えらる。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし仮りに「来る六、七月の頃、東京地方に破壊的地震あるべし」との予報が科学的になし得られたりと仮定せよ。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお一般弾性体の破壊に関してその弱点の分布や相互の影響あるいは破壊の段階的進歩に関する実験的研究を行い、破壊という現象に関するなんらかの新しき方則を発見する事も必ずしも不可能ならざるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、惜しい事には、この能力は人間に都合のよいほうにはあまり使われないで、かえって海岸を破壊したり、またせっかく築いた港を砂で埋めたりするほうに使われています。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "震動の筋肉感や、耳に聞こゆる破壊的の音響や、眼に見える物体の動揺転落する光景などが最も直接なもので、これには不可抗的な自然の威力に対する本能的な畏怖が結合されている。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに附帯しては、地震の破壊作用の結果として生ずる災害の直接あるいは間接な見聞によって得らるる雑多な非系統的な知識と、それに関する各自の利害の念慮や、社会的あるいは道徳的批判の構成等である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るだけ伝統的の型を離れるには一度あらゆるものを破壊し投棄して原始的の草昧時代に帰り、原始人の眼をもって自然を見る事が必要である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠にはならないまでも、私はいわゆる新しい大和絵や歴史画を見ると、せっかく頭の中にもっている「過去」の幻影を無残に破壊される場合が多い。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もここで「野獣の群」というのは破壊的な乱暴者でもなければ、無意味に変態な病的のものを求める猟奇者でもないことは勿論である。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月二十二日『東京朝日新聞』）　　　　　　　　　二十四　　　　　　水雷破壊器の発明　今度米国政府のためにアンリ・スタンフィーバンという仏国人が敷設水雷を破壊する器械を発明し、実地の試験をしたが好結果を得たという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの考では、破壊せられた旧思想が、随即新思想だとは認められないように思うのですよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなさまざまの事を考えながら、毎日熱心に顔を見つめてはかいていると、自分の顔のみならず、だれでも対している人の顔が一つの立体でなくて画布に表われた絵のように見えて来た。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ではこれから出かけてきますからね、渡瀬さんがいらしったらよろしく」　こういい残して母はかいがいしく、雪のちらちら降る中を病家へと出かけていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる傾向は層雲を中心とする人々ばかりの間に起ったのではかい。",
              "citation": {
                "source": "俳句に於ける象徴的表現",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
