[
  {
    "uuid": "a1822144-266c-5c33-83e8-12b120dfc391",
    "entry": "背後",
    "reading": {
      "primary": "はいご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふと私は友の背後に立つ二つの黒い投影を見て驚いた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくに私自身の背後にもまた、その同じ二つの投影を見たことであらう。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺は庭が広く、背後に老杉の茂った林があったので、彼の瞑想的な散歩に最も好ましい所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の背後には、大勢の若い壯士が立つてた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふり返つて背後をみると、彼は悄然と坂の上に一人で立つてゐる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんは私の背後で床の間を拭きながら、ええ、惡くなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」下の姉さんが、上の姉さんの背後から美しい笑顔をのぞかせて言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の背後の方の戸が開く音を聞くと直ぐ彼は振り返つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "謂はばその主観的な抒情詩の背後に、如何なる具合に客観的能力が働いてゐるかを示すことこそ、此の小論の主旨でもあるのだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の背後の、ブランコのある所を見たいと思つて建物の横を廻りかけたが、何しろ休暇中だし、朝の五時半であつたし、小使の女房か女学部の舎監であつたか知らないが、炊事場の小窓から一寸顔をのぞけて、ケゲンさうにこちらを見たから、諦めてコソコソと引返した。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後の間では義理の祖母が、洗濯の済んだ幾枚もの着物を畳んでゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の扉のトップの金属が、たゞ矢鱈に冷たく鈍く光つてゐた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「粗野で逞しいポーズ」と、そのポーズの背後に潜んでゐる「優しくいぢらしいセンチメント」とは、彼のあらゆる小説と詩文学とに本質してゐるものなのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳壇のいわゆる俳人たちは、彼らの宗匠的主観に偏して、常に俳句を形態上のレトリックでのみ皮相な手法的技巧観で鑑賞するため、句が詩情している本質のポエジイと、その背後にある主観の貫ぬく哲学とを、ややもすれば閑却無視することになるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら多くの人は、これらの客観的特色の背後における、詩人その人の主観を見ていないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤や青やの派手な色をした更紗が、春風の中に艶かしく吹かれているこの情景の背後には、如何にも蕪村らしい抒情詩があり、春の日の若い悩みを感ずるところの、ロマネスクの詩情が溢れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲壮な、痛々しい、骨の鳴るような人生が、一本の枯木を通して、蕭条たる自然の背後に拡がって行く。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の場合で言えば、リリックは詩の背後に隠されているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の場合では、そのリリシズムと同じように、哲学が句の背後に隠れており、表面上の一通りな鑑賞では、容易に発見できないのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後の壁には乾鮭がさがり、戸外には空也念仏の声が通る。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "且つ「蛙」といふ動物は、日本人にはとつては特殊の俳味的詩趣をもつて居り、夏の自然を背後に感じさせるやうな季節感をさへ有してゐるが、西洋人にとつては何等特殊の連想がなく、食用蛙の醜怪を思ひ出させる位のものであらう。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無限に遠き空の彼方續ける鐵路の柵の背後に一つの寂しき影は漂ふ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後に楢の林を負ひ、周圍みな平野の麥畠に圍まれたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あれ、芳ちやん』此の時女は耐り兼ねて、紳士の背後から躍り出た。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から靠掛る樣に抱きついて密接顏を押し附けると、切なげに身を悶えて『堪忍してよ、芳ちやん………』『………』男は何か言はうとして、僅に手先を動かしたが『阿※』と一｜唸呻、言下に反繰返つて仰樣に僵れた。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその背後にはやはり自分の一生涯の人間生活の記録が隠されているのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はじめて氣がついたのであるが、乙姫の背後には、めだかよりも、もつと小さい金色の魚が無數にかたまつてぴらぴら泳いで、乙姫が歩けばそのとほりに從つて移動し、そのさまは金色の雨がたえず乙姫の身邊に降り注いでゐるやうにも見えて、さすがにこの世のものならぬ貴い氣配が感ぜられた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕は日が背後に没して、紫水晶のように匂やかに見える。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後から陶器の盃でも伏せたように、透き徹っているのは、言うまでもなく富士の山だ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "中の茶屋へ着くと、松虫草の紫は、見る影もなく褪せているが、鳥冑草は濃紫に咲いている、そして金屏風を背後にした菊花のように、この有毒植物の、刺戟強い濃紫は、焼砂の大壁を背景にして、荒廃の中に、一点の情火を、執念くも亡ぼさずにいる。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
