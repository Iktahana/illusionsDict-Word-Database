    "definitions": [
      {
        "index": 1,
        "gloss": "nasal (voice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
