        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フランス無政府主義者の破壊活動か。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治以後の御用学者は、維新は、国民の尊王心から生じたものである、とこじつけ、当時の破壊活動をやつた連中をさして、義士だの、功臣だのと、激賛している。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにたいして、攘夷論者という破壊活動者が、朝廷がわや長州藩などにあらわれた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、明治以後の日本人は、この破壊活動を煽動した破壊者を、救国の忠臣のように賞めたてている。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "その破壊活動者は、幕府の外交を、口をきわめて非難した。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "公卿と薩長人とは、その破壊活動者の本拠であつた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "討幕は、ただ天下とりの野心家がおこなつた破壊活動にすぎなかつた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
