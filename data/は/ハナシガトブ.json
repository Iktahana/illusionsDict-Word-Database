          "literary": [
            {
              "text": "いやに話が飛ぶようだけれど、飛ぶ必要があるんだから仕方がない。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪談なんかに話が飛ぶと、たい子さんも千葉の海岸で見た人魂の話をした。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪談なんかに話が飛ぶと、たい子さんは千葉の海岸で見た人魂の話をよくした。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし話が飛ぶようですがそうではなくて、私は今年カーペットを貰っていいと思う。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
