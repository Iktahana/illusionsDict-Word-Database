[
  {
    "uuid": "10399d27-33e3-5123-867d-47d0c682a00d",
    "entry": "針箱",
    "reading": {
      "primary": "はりばこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
