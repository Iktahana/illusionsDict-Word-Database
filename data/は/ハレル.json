[
  {
    "uuid": "3e330d33-e7cd-56bb-ac52-07122c623088",
    "entry": "腫れる",
    "reading": {
      "primary": "はれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
