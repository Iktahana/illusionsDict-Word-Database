        "examples": {
          "standard": [
            {
              "text": "近くの清流で腹赤が釣れると聞いて、釣りの道具を準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "炭火で焼いた腹赤は、皮はパリパリ、身はふっくらとしていて最高だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は腹赤の美しい模様に魅了され、水槽で飼育している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "と、かっきり描かれたようないもりのような腹赤な唇が、男の目にいきいきとうつってきたのである。",
              "citation": {
                "source": "香爐を盗む",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "Japanese dace (Tribolodon hakonensis)",
