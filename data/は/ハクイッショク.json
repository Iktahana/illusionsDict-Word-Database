    "definitions": [
      {
        "index": 1,
        "gloss": "bright white (esp. for snow and ice)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何の触覚を与えない雲は、聖者を周囲から閉じ込めて、とうとう白一色だけが聖者の視覚の奥に感じられた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪、白一色のうつくしさ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白一色の曠野である。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた、白一色に彩られて、空しくがらん洞の景観でもある。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の雪が一二寸積もり、江戸の町々どこを見ても白一色の銀世界で今出たばかりの朝の陽が桃色に雪を染めるのも冬の清々しい景色として何とも云えず風情がある。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはテューリップ畠と、アネモネ畠でひろびろとした耕地の間に途方もなく大きな毛氈を敷きひろげたように、しかも、このテューリップ畠は赤は赤一色、黄は黄一色、白は白一色で、中に紫はアネモネの花畠だった。",
              "citation": {
                "source": "レンブラントの国",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽然響き渡る鼓の音　今年の最初の雪だというに、江戸に珍らしく五寸も積もり、藪も耕地も白一色、その雪明りに照らされて、遠方朦朧と見渡されたが、命ある何物をも見られなかった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山も人家も川も谷も、一面に雪に蔽われて白一色の眺望となった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おりから、十六夜の冬の月寒々と空に冴え返り見渡す限り丘も山も雪の白無垢に包まれて白一色の物凄さ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵐は益※｜吼え狂い、雪は滝のように降り注ぎ、硫黄ヶ滝の絶壁は経帷子で蔽われたように、白一色の物凄さ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の企ては失敗ながら俺にとってはいい経験であった」　烏の啼く音が全山に響き、白一色の四辺の光景へ、紅色の朝陽が照り栄えた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで面白いことには、この広大な氷原は、白一色の氷の原にはなっていない。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は濃霧にとざされていることが多く、秋になると、早々に雪がきて、全体が白一色の世界になってしまう。",
              "citation": {
                "source": "アラスカの氷河",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るかぎり白一色に結晶し、白金よりも堅く厳めしい大氷原のただなかで、眼をくすぐるような都雅な色彩に接しようなどとは思っていなかった。",
              "citation": {
                "source": "南極記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すがれた葭と真菰の池の岸まで美しいほどの白一色。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "白一色の平野は、紫にかすむ遠山のながめを澄んだ空の中に浮かせ、葉の落ちつくしたポプラのしなやかなこずえが、刷毛でぼかしたようなすがたで、一列に立ちならんでいた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月二日は白一色であるが雪の深さは一尺あるかなしである。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊かにくびれた腰の線や、重たげに張りきった胸のふくらみが白一色に消されて、いつもの陽気で嬌羞にあふれているかよとはまったくべつな、初い初いしく、殆んど清浄な印象を与えるのであった。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北は冬にでもなれば、満目凡て雪に被われ、山も河も野も家も、凡て白一色に変ります。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し経つと、部屋が真っ暗になり、外は白一色になった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "白一色の町に、向う見ずな連中があちこちから歩きだし、物珍しげに眺めるのは、庶民のあくせく働く姿だ。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            },
            {
              "text": "裃と小袖を除けば、かれの今朝の装いは、白一色の死装束であった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
