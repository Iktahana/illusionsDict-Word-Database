        "examples": {
          "standard": [
            {
              "text": "病室では、白衣の天使たちが患者の不安な心を和らげていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「お母さん、あの白衣の天使みたいな人になりたいな！」と、少女は将来の夢を語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過酷な医療現場で奮闘する白衣の天使たちには、感謝の言葉しかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "救護隊の屯所なども出来て白衣の天使や警官が往来し何となく物々しい気分が漂っていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は政子姉や、藤子姉を美しい白衣の天使かのように思い、繃帯を巻いてくれるのに任かせつつ、担架に載せられて実に幸福であった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「白衣の天使」とシェクスピアの「お気に召すまゝ」つまらないの何のって、結局ニュースが一ばん面白かった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
