  {
    "uuid": "943bddd9-ba94-5e69-b3c3-2131fa3b8a9a",
    "entry": "洟",
    "reading": {
      "primary": "はな",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
