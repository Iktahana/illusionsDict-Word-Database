    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その時だ、その壺が花を開く、その花は、夜の部屋にみる、三色菫だ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまなか伝説的存在にされてあゝ、この言語玩弄者達の世に、なまなか伝説的存在にされて、（パンを奪はれ花は与へられ）あゝ、小児病者の横行の世に！",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "野望の上に造花は咲いて迷つた人心は造花に凭る。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "造花作りは花屋を恨む、さて、花は造花程口がきけない。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "造花造りの羽振のよさは、あゝ、滑稽なこつた滑稽なこつた。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが滑稽だとみえないばかりに、花の言葉はみなしやらくさい。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌もつれようともつれまいと花に嘘などつけはしないんだ。",
              "citation": {
                "source": "（辛いこつた辛いこつた！）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、それは花屋の前であつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてケシの花だつたかを買つて円タクに帰つて来ると、その男は花を一本づつ我々に配つた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真昼の光はあつても少しくであり、それもやがて暮れるとしてのことのやうであり、此処では、紅の花も、やがて萎れて黝ずんだ色になるとしてのことである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかこれは、ロマンチシズム開花する国で云ふにふさはしいことのやうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、いづこぞ夢の序樂のぽろねえず、會社は河岸に涙をひたし、花店の飾窓つゆにぬれたり、しばしまたつりがね鳴らむ、あさまだきにほふ葉影に、しろじろとかざし泳がせ、この列をなす少女らあゆむ。",
              "citation": {
                "source": "若き尼たちの歩む路",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青いゆき萩原朔太郎青いぞ、ゆきはまつさを、もも、さくらぎに花咲かず、青いこなゆき、光る山路に泣きくらす。",
              "citation": {
                "source": "青いゆき",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水部の線宮沢賢治きみがおもかげうかべんと夜を仰げばこのまひる蝋紙に描きし北上の水線青くひかるなれ竜や棲みしと伝へたるこのこもりぬの辺を来れば夜ぞらに泛ぶ水線の火花となりて青々と散る",
              "citation": {
                "source": "水部の線",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜石よりの帰り宮沢賢治かぎりなく鳥はすだけどこゝろこそいとそゞろなれ竹行李小きをになひ雲しろき飯場を出でぬみちのべにしやが花さけばかうもりの柄こそわびしきかすかなる霧雨ふりて丘はたゞいちめんの青谷あひの細き棚田に積まれつゝ廐肥もぬれたり",
              "citation": {
                "source": "釜石よりの帰り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり水が低きにつく如く、花がひそやかであるが如き気持がなければ、詩は駄目だと思つた。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、今日私が、過去の錯乱を去つたのは、実に私が、謂はば、自力的に求めたればこそで、却て今日はじめて、花の美しさをも感じられるやうになつた次第である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が其処で暮し、其処で耕した所から花が咲いたのに、別の所で暮し、別の所で耕してた奴が、その花を面妖がるのが変な話でなくてなんとしようぞ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "で此の場合、仮りに一私人が罷り出たとして、放校された生徒に同情するとしますと、では、中学生が、イヤな病気になるやうなことをしてもよいといふのか、なぞといふことになつて、凡そ「病気軽重と処分軽重」の問題とは、外れた所に文句の花が咲きさうであることはお分り下さる所でせう。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、田舎の川べりにでも住んで、夏は縁台を出して夕顔の花をみてゐるといふ、あの消極的平安の中に安住しなければならないのです。",
              "citation": {
                "source": "我邦感傷主義寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはやがて花のやうに萎む。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は朝顔の花のやうに夏の朝、感じてゐるが、それは彼の心中、形なき歌ともなるが、彼が声を出して歌つてゐるのをみたものはない。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――三造はものを朝顔の花のやうに感じてゐる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は悲劇をみて泣いたことはない悲劇に遭遇したことのある自分を発見したゞけであつた。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才以外の仕事ではないのが此の芸術ですね。",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが諦めとは思はないでだ。",
              "citation": {
                "source": "疲れやつれた美しい顔",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に邪魔になる程に、大声で笑つたわけでもなかつたし、それにしてもだ、先生がカン／＼になつてたことは事実だし、先生自身何をそんなに怒るのか知つてゐぬらしいことも事実だし、俺としたつて意地やふざけで笑つたわけではなかつたのだ。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別俺は人生がどうのかうのと云ふのではない、理想派でも虚無派でもあるわけではない。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も通るものはなかつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代といふ今は尠くも、あんな具合な元気さでゐられる時代ではないのです。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
