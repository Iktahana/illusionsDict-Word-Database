    "definitions": [
      {
        "index": 1,
        "gloss": "small calendar (or almanac) affixed to a pillar or wall",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "Ｓ軒のＢ教授の部屋の入り口の内側の柱に土佐特産の尾長鶏の着色写真をあしらった柱暦のようなものが掛けてあった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計の下の柱暦に小母さんとおぬいさんとの筆蹟がならんでいるのも――彼が最初にその家に英語を教えるのを断りに来た時に気がついたものだけに――なつかしかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「己らまた、柱暦の絵に描いた、倭武尊様かと思った奴さ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "臺所の煤でてらてらと黒光のする大きな戸の表には、赤と黒との字の刷られた柱暦が貼つてあつた。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時話し手は、うしろにある柱暦を一枚めくって、「今日は四月一日だね」というのがあった。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」浅子女史は鴉のやうにぶる／＼肩を顫はせながら、柱暦を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "清子は立って外し忘れた柱暦を一枚めくった。",
              "citation": {
                "source": "茶粥の記",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんな対話を聞きながら、巻煙草を啣えた洋一は、ぼんやり柱暦を眺めていた。",
              "citation": {
                "source": "お律と子等と",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛飾北斎は江戸の町を柱暦を売り歩いていた。",
              "citation": {
                "source": "北斎と幽霊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "花街の柱暦が立夏を示すころになると毎年きまつて夜毎の流し芸人はめつきりとその数を増して来た。",
              "citation": {
                "source": "旧東京と蝙蝠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "皺をのばして見ると、柱暦からひきちぎった紙で、櫛から拭きとった女の長い髪が十本ほど丸めこまれてあった。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱暦は昨年十二月廿七日の日附であった。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとはといえば、土間の花簪と柱暦に巻き込まれていた女の髪の毛から始まったことだった。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、考えて見ればその花簪は島の誰かが馴染みの娼婦からでも貰って来たのかも知れず、柱暦の日附も、昨年のものだとする理由はどこにもない。",
              "citation": {
                "source": "海豹島",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ガラッ八は立上がって柱暦を覗きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "カレンダーと云えばね、今あるような柱暦、今年はないかもしれないのですって、実に不便ね。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
