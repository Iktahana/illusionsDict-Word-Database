        "examples": {
          "standard": [
            {
              "text": "日陰でも育つ花筏は、庭のアクセントとして重宝されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山道を歩いていると、葉の真ん中に花が咲く珍しい花筏を見つけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この花筏は、赤い実をつけるので冬でも庭を彩ってくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
