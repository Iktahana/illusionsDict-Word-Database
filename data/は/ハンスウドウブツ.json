        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうしてニヤグニヤグと頤を動かせながら反芻動物のやうにそれを噛みしめてゐた。",
              "citation": {
                "source": "痴想",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九世紀が生んだ不肖の長子はレアリスムと称する得体の知れぬ反芻動物であり、これが人間性を濁らせてしまった。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "顳※に凍てついた古い昔の襤褸をほぐす、丁度あのノウノウとした反芻動物のやうに、僕はウラウラとした海岸のベンチや、たまさかに翳りの深い樹の下で、一つづつ食べ直すものの如くに襤褸をほぐすのが日課であつた。",
              "citation": {
                "source": "海の霧",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "反芻動物の胃は彼の興味を引き起こし、その構造を記載した。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウシや他の反芻動物ヒツジなどのこぶ胃（噴門洞）に住んでいる微生物はとくに活性が強かった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度｜反芻動物が、一度胃の腑の中へ納ったものを、また吐き出してニチャリニチャリと噛みしめては、楽しみを繰返す様に、北川氏は、今日の野本氏との会談の模様を、始めから終りまで、文句の細い点まで注意しながら、ユックリユックリ思出して行った。",
              "citation": {
                "source": "恐ろしき錯誤",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
