[
  {
    "uuid": "fd063bd7-1ce2-55d7-a203-07a6f80f9ad7",
    "entry": "発生学",
    "reading": {
      "primary": "はっせいがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
