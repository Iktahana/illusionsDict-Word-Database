        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "配膳室の箱の中に、今朝中にもって来た「おかちん」がまっ白い体をよこたえて居る。",
              "citation": {
                "source": "午後",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所との間には、どんなに小さくても配膳室があった方がよろしいでしょう。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕をするのに、一々、大きな扉の開閉をせず、配膳室との境に、適当な大きさのハッチをつけ、台所で料理出来たものは、彼方側から其処の棚にのせ、給仕人が、此方から、部屋を出ず食卓に運ぶ。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "配膳室には、食器棚、料理の仕上げをする位の意味で瓦斯、周囲の壁は、タイルででも張った流し。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂、十一二畳、配膳室三畳。",
              "citation": {
                "source": "書斎を中心にした家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関の敷居を跨いだ時から心に湧いた素直さで、自分は何気なく配膳室と台所との境の硝子戸を押しあけた。",
              "citation": {
                "source": "二つの家を繋ぐ回想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時頃に一度お乳を遣った丈だったので、空おっぱいをあずけたまま、先ぐお乳を作りに配膳室へ出て行った。",
              "citation": {
                "source": "盗難",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "配膳室のドアをわざとコトコト叩いたら、内の連中は時間が時間だし何が来たのかと一どきにこっちを見ている。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
