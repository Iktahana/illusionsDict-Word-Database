[
  {
    "uuid": "83b99ee3-6905-597a-800d-ef44a594bbad",
    "entry": "榛の木",
    "reading": {
      "primary": "はんのき",
      "alternatives": [
        "ハンノキ"
      ],
      "is_heteronym": false
    },
    "grammar": {
