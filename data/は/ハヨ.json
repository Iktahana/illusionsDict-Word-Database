        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "early",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貧乏したら石油まで早よ無うなる。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなら、お早よう――云うんは？",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早よ軍医殿にそう云って呉れろ！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると親爺は、「えゝい、そんな早よ、なりゃえゝけんど、十年や十五年でなに、そんなになろうに！",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」真に大事だという話し振りで、「早よ、内地へ軍隊をくり出しゅように云ってやって貰わなけゃ、財産（しゃん）や工場だけじゃない、頭やチンポまで引きちぎられてしゅまいますぞ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早よ、Ｓ病院、去。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、「早よ、ほかで嫁を貰うてやらんせんにゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早よ呼び戻したらえいわ。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、早よう……孫の墓へ参りました帰り途に、裏通りを近道して、祇園町へ帰ろうと致しましたれば……あ……あの桃の花の上がっておりまする、蔵元屋の……お墓の前で……」　すこし落着きかけた婆さんの歯抜け※が又もガタガタ言い出した。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝は珍しゅう早よう何処かへ出て行きおったと寺男が申しておりましたが……」「ナニ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝早よう……ふうむ……」　本堂に近い柴垣の処で立止まった良助は、又もや腕を組んで、今出て来た墓所の奥の暗がりを振返った。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八か九の別嬪が、一昨日の朝早よう、万延寺の菩提所で、胴中から真二つに斬られとった騒動なあ……最早、聞いておんなさるじゃろう」「聞いとる処か。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの朝早よう、イの一番に見て置いたが、残酷い事をしたもんじゃなあ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも罪人は一｜刻も早よう引っ捕えいと言う注文じゃから先ず、これ位、困難しい探偵事件はなかろうわい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞこの事ばっかりは秘密にして、一｜刻も早よう御嬢様を蔵元屋の外へ出いて下さい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに最早、年頃のことじゃけに、早よう何処かへ嫁に遣って一刻も早くお嬢様の足を洗わせねば、わたしゃ心配で心配で夜の目も寝られませぬという、乳母のお島どんの涙ながらの物語……」「う――むむ」　松倉十内は腕を組んで今一度太い、深い溜息を吐いた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那様……」「何じゃ……」「早ようお手当なさりませぬと、蔵元屋は夜逃げ致し兼ねますまいて……肝腎要の金の蔓の娘が殺されたので御座いますから……」「うう――――むむ……」　松倉十内は恨めしそうな白い眼で赤猪口兵衛を白眼み付けた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の壺の振りよう一つで蔵元屋の身代が立直るか、直らぬかの境い目と、両親に言い聞かせられたお熊さんの、一心から身を斬らるるような思いをしながら毎夜毎夜のカラクリ丁半……早よう死にたい死にたいと花の盛りのお熊さんが、神仏を祈って御座ったいじらしさ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればお付の乳母のお島どんも、一｜刻も早ようお嬢さまを、何処かにお嫁に遣って下さい。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "出際に上り口から頭を出して『お早よう』と言いさま、妙に笑って頭を掻いて見せまして『いずれおわびは帰ってから』と、言い捨てて出て参りました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面所で逢っても、廊下で逢っても、風呂場で逢っても、お早ようございますの挨拶さえもする人は少い。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はもちろん、女でさえも洗面所で顔をあわせて、お早ようはおろか、黙礼さえもしないのが沢山ある。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お腹の子供のこともあることやし、金のなくならぬうちに早よ地道な商売をしようと照枝は言い、坂田は伏し拝んだ。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おや、山崎さん、お早ようございます。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人で、苦労してこれだけの人間になりました言うて、お父さんの前へ早よ出られるようにしよ思て、一所懸命になってるわての気持は、あんたには判れしめへんのんか。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "他あやんにしてみたら、早よあんたに良えお婿さんを貰て、それから隠居しよ思たはるのんと違うやろか」「――さあ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "わいは飛行機で行くさかい、お前の乗ってる船追い抜いて、お前より早よ着くわい。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お祖父ちゃんの魂は〆さんより早よマニラへ着いたはりまっせ」　と、言った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ兎が飛んで来て、もしもし、頼みぢや、早よお出で、よしよし待たしやれ、今直ぐぢや。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうほう蛍ほうほう蛍、篠蛍、昼間は赤い豆頭巾、日暮はピカピカ、豆袴、一のお宮で灯を貰ろて、二の宮田圃へ灯とぼしに、三の鳥居は藪の中、四の宮くぐれば貉堀、貉が啼き出しや、雨がふる、早よ早よお戻り、夜は凄い、真夜中過ぎれば帰られぬ。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
