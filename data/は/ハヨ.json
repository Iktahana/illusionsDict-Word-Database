[
  {
    "uuid": "f9aec75a-8bcd-519d-a3b1-6775b1d2d9bf",
    "entry": "早よ",
    "reading": {
      "primary": "はよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
