    "definitions": [
      {
        "index": 1,
        "gloss": "involuntary nocturnal tooth grinding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "歯ぎしりして死んでいったと聞いている。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌女寿は歯ぎしりをして口惜しがった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は村のひとたちのそんな安易な嘘を聞くたびごとに、歯ぎしりをし耳を覆い、飛んで彼の家へ帰るのであった。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年生のときは、洞熊先生が点数の勘定を間違ったために、なめくぢが一番になり蜘蛛と狸とは歯ぎしりしてくやしがった。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、幼くして、峻厳酷烈なる亡父、ならびに長兄に叩きあげられ、私もまた、人間として少し頑迷なるところあり、文学に於いては絶対に利己的なるダンディスムを奉じ、十年来の親友をも、みだりに許さず、死して、なお、旗を右手に歯ぎしりしつつ巷をよろばいあるくわが身の執拗なる業をも感じて居るのだ。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と口々になだめると、短慶いよいよわが身の不運がうらめしく、なげきはつのり、歯ぎしりして、「お言葉は有難いが、そのお情も冥途への土産。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て、三日間、歯ぎしりして泣いてばかりいた。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不能の文字なし、とナポレオンの歯ぎしり。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が女だけに、女の中にある不潔さが、よくわかって、歯ぎしりするほど、厭だ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急に、歯ぎしりするほどジャピイを可愛くなっちゃって、シッポを強く掴むと、ジャピイは私の手を柔かく噛んだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二十三　其の声が、五位鷺の、げつく、げつくとも聞こえれば、狐の叫ぶやうでもあるし、鼬がキチ／＼と歯ぎしりする、勘走つたのも交つた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙をズウウと流しながら歯ぎしりをして半分起き上ろうとします。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝は歯ぎしりをして恨んだ。",
              "citation": {
                "source": "水莽草",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うッふ、ねずみはきいきい歯ぎしりして、わらくずや木切れに、どんなによびかけたことでしょう。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作は歯ぎしりをかんで競うて見ても、おとよさんにかけてはほとんど子供だ。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中達は皆好く寐ている様子で、所々で歯ぎしりの音がする。",
              "citation": {
                "source": "心中",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "田村泰次郎氏の暗雲の下――（同上）は、現代の青年の身動きのならぬ憂悩に歯ぎしりをして突つかつてゐる逞しい構えが、まつたく冗談事としてゞはなくわれわれの上にまでもひゞいて来る何物かゞ、さうだたしかに何とも指摘も適はぬ何物かゞ感ぜられる。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれがもうこんなわがままな人の所に来てやるものか」そう思いながら、生垣の多い、家並みのまばらな、轍の跡のめいりこんだ小石川の往来を歩き歩き、憤怒の歯ぎしりを止めかねた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ギリギリと歯ぎしり噛んで、苦しげに訴えた弥太一の血まみれ姿を黙然と見守りながら、わが好もしき江戸名物の旗本退屈男はじりじりと傍らの白柄細身をにぎりしめました。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "うぬかッ、うぬかッ、うぬが計ったかッ、うぬが計ったかッ」　歯ぎしり噛んで怒号したがもう遅い。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならそうとぬかして逃げりゃ、腰の骨まで痛くしやしねえのに、いまいましいね」「今ごろごまめの歯ぎしりやったっておそいや。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがあばたのやつに負かされるなんて、さるが木からおっこちたより、もっとおかしいよ」　でも、右門にはまだしゃくしゃくとして、それをつぶやくだけの余裕がありましたが、伝六は黙然と歯ぎしりをかみつづけたままで、さながらふたりの位置は、むっつり屋とおしゃべり屋とが、入れ替わったようなかっこうでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠行かっしゃい」　爆発するような主水之介の声に、溝口豊後守も、取り巻いてひたひたと随っている十人の影も一様に歯ぎしりしたらしかったが、物を言うべき物が駕籠にかかっていたのでは手の出しようがないのです。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大分歯ぎしりをお噛みのようじゃが、虫歯ならば沼田正守医道の心得がおじゃるゆえ、ことのついでに癒して進ぜましょうかな」「勝手にさッしゃい！",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔あくたうかべる朝の水〕宮沢賢治あくたうかべる朝の水ひらととびかふつばくらめ苗のはこびの遅ければ熊ははぎしり雲を見る苗つけ馬を引ききたり露のすぎなの畔に立ち権は朱塗の盃をましろきそらにあふぐなり",
              "citation": {
                "source": "〔あくたうかべる朝の水〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大三ははぎしりしてくやしがりました。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人は彼の雄弁と諧謔とにみせられて、哄笑をするたびに、そのかげにおれという被害者がはぎしりしていることにぜんぜん気がつかなかった。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウウム、無念な」　と、はぎしりしながら左近将監めがけてきりつけましたが、もはやこの深傷ではたまりません。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしいのと、寒いので、宗三ガタガタと身を震わせて、はぎしりをかんだ。",
              "citation": {
                "source": "接吻",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ていると、ゾーッとして、はぎしりがしたくなるほどです。",
              "citation": {
                "source": "鉄塔の怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
