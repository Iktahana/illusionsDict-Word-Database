          "literary": [
            {
              "text": "二十六日（月曜日）晴後雨　燕小屋午前六時出発、この路アルプス銀座通りといい非常に景色よく道も良し、今朝の御来迎は相当よく富士などはっきり見え槍も見ゆ。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十日（日曜）晴後雨　才の妹てる、田舎の生活に不満で再度上京した。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月二十一日（火曜）晴後雨　伊豆山桃李境、養老の間に眠り、夜半、小便に起き、便所が入口にあるのを忘れて、廊下へ出て迷ひ、部屋へ戻って漸っと気がつき、あはてゝ小便する前に、もう洩れちまってた、醜態。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十八日（木曜）晴後雨　十一時に起されて、暫く起きられず。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
