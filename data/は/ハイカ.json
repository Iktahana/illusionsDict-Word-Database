    },
    "definitions": [
      {
        "index": 1,
        "gloss": "distribution (e.g. of products to a retailer)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
