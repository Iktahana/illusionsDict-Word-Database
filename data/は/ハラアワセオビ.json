        "examples": {
          "standard": [
            {
              "text": "娘の成人式のために、着物に合う華やかな腹合わせ帯を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "腹合わせ帯は、一本で二通りの着こなしが楽しめるので、着物愛好家には人気がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "着付けの先生が、腹合わせ帯の結び方を丁寧に教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "眉の痕の青い櫛巻髪に黒繻子の腹合わせ帯。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "うらうらと燃える陽炎を背に、無造作な櫛巻き、小弁慶の袷に幅の狭い繻子と博多の腹合わせ帯を締めて、首と胸だけをこう背へ振り向けたところ、「おや！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟のかかった渋い縞お召に腹合わせ帯をしめて、銀杏返しに結って居る風情の、昨夜と恐ろしく趣が変っているのに、私は先ず驚かされた。",
              "citation": {
                "source": "秘密",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
