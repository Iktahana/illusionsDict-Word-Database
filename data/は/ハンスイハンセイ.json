    "definitions": [
      {
        "index": 1,
        "gloss": "half asleep and half awake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
