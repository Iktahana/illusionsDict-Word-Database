        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "拝観料　侍達はそれに小判を置いて室へ入る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎も紙入れを逆さにして拝観料を払う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五銭十銭という拝観料が大概きまっています。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "取引高が拝観料というワケですよ。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昔から法隆寺に遊ぶたびにそこへ道寄りして、別の拝観料を払って礼拝するのである。",
              "citation": {
                "source": "冬の法隆寺詣で",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつかましさの故に、今は我々も拝観料を払って見物しうるのかもしれぬ。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝観料を払った当然の権利のように思って見物する。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "拝観料だの、展望台の入場料だのと、次から次に、週刊誌約一部ぐらいな小銭がついつい出てしまう巧い仕組みにできている。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
