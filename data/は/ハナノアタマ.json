    "definitions": [
      {
        "index": 1,
        "gloss": "tip of one's nose",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オットセイは鼻の頭で鞠をつく芸当に堪能である。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長秀吉の鼻の頭をちょっと弾いたところ、お公卿様にもこういう人の一人ぐらいあった方が慥に好かった。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の頭にくっついたのを吹き飛ばそうとするところは少し人間臭いが、尻に膠着したのを取ろうとしてきりきり舞いをするあたりなど実におもしろい。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大酒飲みと見えて顔色が赤ぼったく垂弛んで、両眼の下瞼がベッカンコーをしたように赤く涙ぐんでいる上に、鼻の頭がテラテラと赤熟れになっている処は、何がかなしに人を馬鹿にした面構えである。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どのような御大家でも縁辺のお話となりますと、一度はキット私の存じ寄りを聞きに御出でになりまっするで、私が、あれなら大丈夫と請合いますると、それからお話が進みまするような事で……ヘエ……」　と自慢そうにモウ一度、鼻の頭をコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い鼻の頭を今一度、念入りにコスリ上げると、炭俵の上からガサガサと一膝進み出た。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い鼻の頭が白くなる程、顔色を変えた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に「それが何んだ」と云ふ聲が雷霆の如く心を撲つたので、彼れは「へん馬鹿め」と誰れかに鼻の頭でもはじかれた樣な顏をした。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をする」と呶鳴り付けると、「日が射して困る」と、ハンカチーフなんかで鼻の頭を撫でている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、第一日の夜、市勝が俯向いて手紙を書いてゐると、鼻の頭の障子が自然にすうと明いた。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さア何がいいかなア……」　小田は鼻の頭を撫ぜながら考えていたが、急にニヤニヤ笑いながら、鶴雄の前に坐ると、「――君、賭けというやつは大きい方がいいね、五円や十円を賭けるのは、下足番共か太陽先生のする賭けだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、鼻声で言いながら、ハナヤへはいって来た十七、八の、鼻の頭の真赤な男の方へ、視線を移さねばならない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間後に、もう夕陽丘女学校の四年生になっていた鼻の頭の赤いお兼の長女が豹一に乱暴な接吻をされて、十日余り、ぽうとした気持になっていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だ、貴様たちは」「兵隊だ」「何しに来た」「貴様たち三人を捕まえに来た」「お前たちの鼻の頭にかぶせた布片は何だ」「これは昨日のように貴様に香水を嗅がせられない要心だ」「アハハハハ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白く痩せこけた上にコテコテとお化粧をした……鼻の頭がツンと上を向いた……眼の球のギョロギョロと大きい……年はいくつかわからない西洋人のようにヒョロ長い女であった。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その眼の眩むような大光熱は、山々の青葉を渡る朝風をピッタリと窒息させ、田の中に浮く数万の蛙の鼻の頭を一つ一つに乾燥させ、地隙を這い出る数億の蟻の行列の一匹一匹に青空一面の光りを焦点作らせつつジリジリと真夏の白昼の憂鬱を高潮させて行った。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……額と、頬と、鼻の頭に受けた軽い火傷に、冷たい空気がヒリヒリと沁みるのを感じていた……そうして工場全体の物音が一つ一つに嘲笑しているのを聴いていた……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "拇指を鼻の頭に当てがって、はるかに追いかけて来る探偵を指の先で嘲弄し、侮辱してやった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話口に向った時の頬や、唇や、鼻の頭、睫なぞの、電流に対する微妙な感じによって、雨や風を半日ぐらい前に予知する事も珍らしくなかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパクトを取り出して、鼻の頭をたたいた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其八　明日辰の刻頃までに自身当寺へ来るべし、予て其方工事仰せつけられたきむね願ひたる五重塔の儀につき、上人｜直接に御話示あるべきよしなれば、衣服等失礼なきやう心得て出頭せよと、厳格に口上を演ぶるは弁舌自慢の圓珍とて、唐辛子をむざと嗜み食へる祟り鼻の頭にあらはれたる滑稽納所。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも同じように肥って、同じように鼻の頭に汗をかいていた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の毛が余り縮れてもおらず、鼻の頭がすっかり潰れてもおらぬので、此の男の醜貌は衆人の顰笑の的となっていた。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　と小児が訊くと、真赤な鼻の頭を撫でて、「綺麗な衣服だよう。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まじまじと控えた、が、そうした鼻の頭の赤いのだからこそ可けれ、嘴の黒い烏だと、そのままの流灌頂。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、一際色は、杢若の鼻の頭で、「えら美しい衣服じゃろがな。",
              "citation": {
                "source": "茸の舞姫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから又、彼の鼻の頭が真黒で、猫のそれのように如何にも柔かそうで、一寸手を伸ばしていじって見たいように出来ていることも私を喜ばせた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の天辺に桃割を載せて、鼻の頭をチョット白くした小娘が、かしこまってお酌をした。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "町人や百姓と伍して食物を漁り合わねばならぬ、犬猫同然の国民平等の世界に、一日でも我慢が出来るか……とか何とか云って鼻の頭をコスリ上げている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ十歳未満の筆者が、座ったまま翁と応待していると、祖父が背後からイキナリ筆者の頸筋を掴まえて鼻の頭と額をギュウと畳にコスリ付けた事があった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
