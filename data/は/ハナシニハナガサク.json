          "literary": [
            {
              "text": "ちょうどあの時捜索に行った人の家であったので話に花が咲く。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高野に着いたその晩は、滝口入道の庵室で、よもすがら昔話に花が咲くのであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "くたびれて、石炭のうえにごろ寝する者もあるが、たいていは、昼休みの一時間、馬鹿話に花が咲く。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "主題が変りものだから話に花が咲く。",
              "citation": {
                "source": "変人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞やで夕刊配達まえなど、皆んなが店の間に集まって女の話に花が咲くとき、私も人後に落ちまいとして、「俺の女はいつだって、グウグウ鼾ばかりかいて、眠ってばかりいやがる。",
              "citation": {
                "source": "朴歯の下駄",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネてから打合せあり、ルパンへ行くと、田中三郎・内田・清水と会ひ、話に花が咲く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "池永浩久もゐて、話に花が咲く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
