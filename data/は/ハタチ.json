    "definitions": [
      {
        "index": 1,
        "gloss": "farmland",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "広々した畑地に霜解けを踏んで、冬枯れの木立の上に高い蒼空を流れる雲でも見ながら、当もなく歩いていたいと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お菓子を、あげますから」と言つて、せんべい一枚をヒユウと向ふの畑地へ投げてやります。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い夏山、山の中腹までは畑地である。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりきらきらする河原には私の搜すやうな畫題はなかつたので、河と此れに並行した丘との間の畑地を當もなく東へ歩いて行つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "又いくら廣くても其の面積は吾々の下駄ばきの足を容れる事を許さない爲に、なんとなく行き詰まつた窮屈な感じを與へるが、畑地ならば實際何處でも歩いて行けば行かれると思ふだけでも自由な舒びやかな氣がする。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある谷を下つた處で、曲りくねつた道路と、其の道傍に榛の木が三四本眞黄に染まつたのを主題にして、稍複雜な地形に起伏する色々の畑地を畫布の中へ取り入れた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど背中合わせに一軒の屋敷があるだけで、右も左も広い畑地であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日目に、彼は、津浦線ガードの東北の畑地で、新しく盛られた土饅頭の下から、埋められた惨殺体を発見した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば森と畑地との境のようなところですと、畑のほうが森よりも日光のためによけいにあたためられるので、畑では空気が上り森ではくだっています。",
              "citation": {
                "source": "茶わんの湯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘を下りて桜の咲き乱れた畑地の中の径をあるいた。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりきらきらする河原には私の捜すような画題はなかったので、川とこれに並行した丘との間の畑地を当てもなく東へ歩いて行った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいくら広くてもその面積はわれわれの下駄ばきの足を容れる事を許さないために、なんとなく行き詰まった窮屈な感じを与えるが、畑地ならば実際どこでも歩いて行けば行かれると思うだけでも自由なのびやかな気がする。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある谷を下った所で、曲がりくねった道路と、その道ばたに榛の木が三四本まっ黄に染まったのを主題にして、やや複雑な地形に起伏するいろいろの畑地を画布の中へ取り入れた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭はほとんど何も植わっていない平庭で、前面の建仁寺垣の向こう側には畑地があった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら他より観察して貰うにしても「この畑地には比較的野菜を蒔いた方が適するだろう」くらいのところまでしか助言を得られないでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔細はない、崖の総六が背戸の、日当の良い畑地に、二月の瓜よりもなお珍とすべき、茄子の実が生りました。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑地はずいぶん広い、とても全部へは手が届かないし、またそうする必要もない、その三分の二は雑草に委任、いや失地回復させてある。",
              "citation": {
                "source": "三八九雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それよりも、今日はあなたのその靴木履で、武蔵野の若草を踏んで歩く音をゆっくり聴かして頂くつもりです」　規矩男はわざと気取ってそういうのか、それとも繊細なこういう好みが、元来、彼に潜んでいるためか、探り兼ねるような無表情な声で云って、広い往還を畑地の中へ折れ曲った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑地には、ここらから搬出する晩春初夏の菜果が充ちていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会人のまちまちな嗜好を反映するように、これ等の畑地のなりものや野菜は一定していなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畦の玉蜀黍の一列で小さく仕切られている畑地畑地からは甘い糖性の匂いがして、前菜の卓のように蔬菜を盛り蒐めている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見廻す周囲は松林や市街のあふれらしい人家に取囲まれていて、畑地の中のところどころに、下宿屋をアパート風に改造した家が散在し、二階から人の頭が覗いていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その負担をのがれる為めと、やゝもすれば身辺に近づいて来る画像の誘惑から遠ざかる為めと、もひとつ彼の思ひつきの為めに彼は翌年の春の初、寺のうしろの畑地の隅に居を移した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑地は宗右衛門の所有地であつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、朝、昼、晩、みれんがましく、縁側に立って垣根の向うの畑地を眺める。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "出つ入りつする山と山の間の、土質の悪い畑地の中を緩やかに逶つて東に向つてゐた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポプラの梢を越して、多那川の灌漑地帯の田や畑地が見え、左寄りに東京から相模へ往来する電車の線路が見え、橋の両岸に町になりかけの人家が蝟っております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "川水に近くなって、畑地は終り、雑木と雑草とが茫々と藪になっている地帯があります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小合溜の近くになって道はまっ直ぐに畑地の部落と左へ尾根山へと岐れるところへ来て、啓司は常司と別れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手紙をともかく「手紙といふもの」と考へる限り、手紙の価値判断はたちどころに混乱して来るのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
