        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蒸し暑い日本の夏は少々ならず閉口であるが、それも大都会のビルやアスファルト道路の照り返しに自動車の排気ガスを脱れ出でて、青田に白鷺を見、蝉しぐれの緑陰に清泉を掬する日本の自然のなかに置かれた町や村の夏なら、緑陰に清泉の一掬に十分にしのぐこともできる。",
              "citation": {
                "source": "われらが四季感",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "オート・バイがやかましい音をふり撒きながらやって来、用談を済ませるとすぐに、またオート・バイのやかましい音と、青白い排気ガスをふり撒きながら去ってゆく。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "干いていく雨の香りのなかに、排気ガスとみやげ物屋の香りが混ざっていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまではワイキキから来た僕も、排気ガスの臭いがするはずだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "全員が制止したのに、マイケルはあの海に入ると言い張り、シュローダーはただ黙って見てたわ」　海から吹いて来る風に、カラカウア通りの排気ガスの臭いがからみあった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽ざしを照り返す道路の匂いのなかに、排気ガスが濃厚に立ちこめていた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "排気ガスのかたまりが、インタチェンジの底によどんだまま、動かない。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺のなかに排気ガスがびっしりと入りこみ、胸の底に重く沈殿している。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京で体のなかに吸いこんでためていたスモッグや排気ガスが、汗になって体の外に流されていくみたいだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮れの、かんばしい香りといっしょに、一日じゅう自動車がまき散らした排気ガスのにおいが、じっとしている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "排気ガスまじりでも、秋の夜の空気は、妙に軽くてすがすがしい。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
