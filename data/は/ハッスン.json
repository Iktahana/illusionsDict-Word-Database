    "definitions": [
      {
        "index": 1,
        "gloss": "distance of eight sun (approx. 24 cm)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自動車は、また、八寸置きに布片の目じるしをくゝりつけた田植縄の代りに木製の新案特許の枠を持って来た。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにも、かれ、蚊帳吊るため部屋の四隅に打ちこまれてある三寸くぎ抜かばやと、もともと四尺八寸の小女、高所の釘と背のびしながらの悪戦苦闘、ちらと拝見したこともございました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "長さが一尺八寸あるいは八分だから尺八だというというのはいかにももっともらしいが、これには充分疑う余地がある。",
              "citation": {
                "source": "日本楽器の名称",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "霜が深くて汚れるよ」なるほど径は霜柱が七八寸も立っていて、ざくりざくりと足が滅込むので長靴でなければ歩けないのだ。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒟蒻、蒲鉾、八ツ頭、おでん屋の鍋の中、混雑と込合って、食物店は、お馴染のぶっ切飴、今川焼、江戸前取り立ての魚焼、と名告を上げると、目の下八寸の鯛焼と銘を打つ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八寸ばかりのほのぐらい、が活けるが如き木彫である。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八寸釘を、横に打つようなこの拷掠に、ひッつる肌に青い筋の蜿るのさえ、紫色にのたうちつつも、お澄は声も立てず、呼吸さえせぬのである。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　目の下およそ八寸ばかり、濡色の鯛を一枚、しるし半纏という処を、めくら縞の筒袖を両方大肌脱ぎ、毛だらけの胸へ、釣身に取って、尾を空に、向顱巻の結びめと一所に、ゆらゆらと刎ねさせながら、掛声でその量を増すように、魚の頭を、下腹から膝頭へ、じりじりと下ろして行くが、「しゃッ、しゃッ。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯　一寸の虫にも五分の魂、其の幅八寸五分にして長八尺ばかりなるもの、これ蓋し女の魂なり。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本尊の観世音は行基僧正の作で、身長一尺八寸であるといふ。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足もすんなり伸びて、並んで立つと四尺八寸の義枝はあわれなほどひねしなびていた。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはちょうど貴様と同じ位の身体だからお前の身体に合う上等の着物と、それから五尺五寸の女の着物と、五尺八寸の男の着物と買って来い。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "剥げた八寸膳の上に薄汚ない茶碗が七ツ八ツ……それでも夏は海から吹き通しだし、冬の日向きがよかったので、街道通いの行商人なぞがスッカリ狃染になっていた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "壱尺七八寸の大脇指は、珍重珍重。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "千両の茶碗をも叩ッ壊した其政宗が壱尺七八寸の叩き壊し道具を腰にして居る、何を叩き壊すか知れたものでは無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「は、」　ただ伏拝むと、斜に差覗かせたまうお姿は、御丈八寸、雪なす卯の花に袖のひだが靡く。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺八寸、十三貫、すなわち痩せているせいで暑さに強い私は、裸で夜をすごすということは余りなく、どんなに暑くてもきちんと浴衣をきて、机の前に坐っているのだが、八月にはいって間もなくの夜明けには、もう浴衣では肌寒い。",
              "citation": {
                "source": "秋の暈",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ商売の林芙美子さんですら五尺八寸のヒョロ長い私に会うまでは、五尺そこそこのチンチクリンの前垂を掛けた番頭姿を想像していたくらいだから、読者は私の小説を読んで、どんなけがらわしい私を想像していたか、知れたものではない。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "人蔘の髯、七、八寸、家畜用だと人はいう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋の紋羽二重に紅絹裏のついた、一尺八寸の襦袢の片袖が、八つに畳んで抽斗の奥に突っ込んであった。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "七八寸ぐらいある傀儡のようなものがぐったりとなっていた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鯉は不忍の池から流れ出して、この川筋へ落ちて来たのを、土地の者が見つけて騒ぎ出して、掬い網や投網を持ち出して、さんざん追いまわした挙句に、どうにか生捕ってみると、何とその長さは三尺八寸、やがて四尺に近い大物であった。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一朱は廉いと思ったが、実はその処分に困っているところであるのと、一方の相手が旗本の息子であるのとで、みんなも結局承知して、三尺八寸余の鯉を一朱の銀に代えることになった。",
              "citation": {
                "source": "鯉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは長さが一尺四五寸、縦が七八寸ばかりの小さな光であった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の一人の指す所を見ると、成程、雪の上にはっきりと、直径七八寸もありそうな、猫のそれにそっくりな足跡が印されている。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "切先から※元まで八寸八分……一点の曇もない。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺七八寸位あったように思う。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "越前の千代鶴という鍛冶が作り出した太刀で七尺八寸あったと云われている。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが真柄の領内で、この太刀を担げる百姓はたった一人で、常に家来が四人で荷ったというから、七尺八寸という方が本当かも知れない。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは長さが一尺四五寸縦が七八寸ばかりの小さな光があつた。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
