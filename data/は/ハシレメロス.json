          "literary": [
            {
              "text": "（「走れメロス」その義、神に通ぜんとし、「駈込み訴え」その愛欲、地に帰せんとす。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「走れメロス」再読三読いよいよ、よし。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は四、五はい水を飲んで、さらにもう一冊の創作集を取り上げ、「走れメロス」という近作を大声で読んでみました。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東宝系は三船敏郎の『奇巌城の冒険』で、これは現代国語の宿題になった、『走れメロス』を映画化したものだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
