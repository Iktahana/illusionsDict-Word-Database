[
  {
    "uuid": "04071807-c731-5651-ac93-3a3978f6794b",
    "entry": "拝聴",
    "reading": {
      "primary": "はいちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
