      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "listening respectfully",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京に住む俗な友人は、北京の人の諤々たる時事解説を神妙らしく拝聴しながら、少しく閉口していたのも事実であった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に君が、僕の話を拝聴しにこうして度々やって来る。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ラヂオの放送で、久米正雄氏等の文芸講座を拝聴したが、久米氏もやはり、かうした文明的新事物は厭ひなさうである。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべくなら末席に坐り、周囲の議論を、熱心に拝聴し、いちいち深く首肯している姿こそ最も望ましいのだが、つい酒を過した時には、それもむずかしくなる。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホレーショーが、ウイッタンバーグ仕込みの名調子を聞かせてくれるというので、皆を連れて拝聴にまいりました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君から愛の哲理を拝聴しようとは、意外だね。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "授業がはじまる迄は、子供のおもちゃの紙飛行機をぶっつけ合ったり、すげえすげえ、とくだらぬ事に驚き合ったり、卑猥な身振りをしたり、それでいて、先生が来ると急にこそこそして、どんなつまらぬ講義でも、いかにも神妙に拝聴しているという始末。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕は、うつむいて二人の会話を拝聴していた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、演劇するものの覚悟などを、時たま拝聴に行く程度だろうと思いますけど、まず、どの劇団がいいか、そんな事も伺いたいのでしょう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もさっそく四人の大学生の間に割込んで、先生の御高説を拝聴したのであるが、このたびの論説はなかなか歯切れがよろしく、山椒魚の講義などに較べて、段違いの出来栄えのようであったから、私は先生から催促されるまでも無く、自発的に懐中から手帖を出して速記をはじめた。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、きちんと膝を折つて、かしこまつて拝聴してゐなければならぬのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チンダルから昨日手紙をよこして是非来年は拝聴に上るというのサ。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏れ多い話だが、玉音は録音の技術がわるくて、拝聴するのが困難であったが、アナウンサーのニュースを聞いているうちに、「あッ、戦争が終ったのだ！",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々会うて世渡りの秘訣を拝聴してゐますよ。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうどグレグソンの意見を拝聴していた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロス大佐は腕組みしながら背を反って帽子を目深にかぶり、私といえばこの探偵ふたりの対話を興味深く拝聴していた。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は先生の講義を拝聴いたしておった者でございます」　宮地翁はこの詞によって河野が聴講生であったことを知った。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "デュパンは自分のいつもの肘掛椅子のなかにじっと腰を下ろして、まるで拝聴というものの権化みたいであった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "山には雨が煙り、男女とりまぜて五百ちかい隊員が、雨に濡れながら立ってその話を拝聴しているのだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちの芝が人に踏まれても朝露によみがえるとかいう意味の、前にも幾度か聞かされた都々逸であるが、その時だけは、いつものような閉口迷惑を感ぜず、素直に耳傾けて拝聴したのだから奇妙なものだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宿に止宿してゐる小学校の先生二人、いま書いて下げた宿帳で我等が事を知り、御高説拝聴と出て来られたのである。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、先刻から貴君の御議論を拝聴していました。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいまの主任のお説はたいへん面白く拝聴しまして大いに参考になりましたが、一、二の点についてわたしには異論があります。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "就きましては一夕怪談会を催しまして、皆さまの御高話を是非拝聴いたしたいと存じておりましたところ、あたかもきょうは春の雪、怪談には雨の夜の方がふさわしいかとも存じましたが、雪の宵もまた興あることと考えまして、急に思いついてお呼び立て申したような次第でございます。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "山も木立も、それから鳥喰崎も……あいつの『郵便局』はその辺にあるんです」　と私の方をチラッと見て、「現に僕達は、先刻鳥喰崎の端っぽで早川氏の跫音を拝聴したんだ」　司法主任は直ぐに飛び出して行った。",
              "citation": {
                "source": "死の快走船",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなれば、貴方の御説を拝聴するより外に、途がなくなったんです」「そうですか」と丘助手は大きく肯いた。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、先刻から貴君の御議論を拝聴してゐました。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "後学のため話だけでも拝聴して帰ろうとようやく肚の中で決心した。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先日の御説確かに拝聴｜仕り候。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん科学者が物を言いかけたら、黙って拝聴するものだということさえ心得ていない人間に、仕事の邪魔をされたくなかったからでありました。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
