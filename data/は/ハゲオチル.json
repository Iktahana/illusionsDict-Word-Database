        "examples": {
          "standard": [
            {
              "text": "古い壁のペンキが、紫外線で剥げ落ちてきている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "何年も使ったマグカップの絵柄が、剥げ落ちてほとんど見えなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "放置された建物の屋根から、錆びた塗料がボロボロと剥げ落ちる音がした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だから一度顔面に貼り著ければ、容易すく剥げ落ちるやうな気遣ひはない。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ撫でるたんびにぷりぷりした寒天のようなものが剥げ落ちるように思えた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
