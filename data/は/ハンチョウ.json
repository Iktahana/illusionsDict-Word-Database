  {
    "uuid": "32e21918-9a6d-563f-bcd7-0389f2b028e9",
    "entry": "反跳",
    "reading": {
      "primary": "はんちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(physical) recoil",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "氣が張れば彈撥反跳の力は加はり、氣が弛めば其の力は衰へる。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "護謨球のやゝ古びたのは既に氣が足らなくなつて居るから、一時は温暖の作用によつて張つても、又頓て弛んで彈撥反跳の力は衰へるのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏み耐へんとせし貫一は水道工事の鉄道に跌きて仆るるを、得たりと附入る曲者は、余に躁りて貫一の仆れたるに又跌き、一間ばかりの彼方に反跳を打ちて投飛されぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ久しぶりにと大反跳にかれははずんだ。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
