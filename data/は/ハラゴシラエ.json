    "definitions": [
      {
        "index": 1,
        "gloss": "having a meal (before doing something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "腹ごしらえでもして、ゆっくり出かけましょう」「ちげえねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり一組の酔っぱらい客があり、どうせまた徹夜になるのでしょうから、いまのうちに私たちだけ大いそぎで、ちょっと腹ごしらえをして置きましょう、と私から奥さまにおすすめして、私たち二人台所で立ったまま、代用食の蒸しパンを食べていました。",
              "citation": {
                "source": "饗応夫人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹ごしらえも充分である。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら一つそこいらで腹ごしらえをしようということになった。",
              "citation": {
                "source": "ワルシャワのメーデー",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とにかく、一服して、腹ごしらえをしてからだ）　編笠から眺めると、土堤沿いの、大きい木蔭に、簾を立てて茶店があった。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦る心をおさえて、これからのアルバイトの準備にコッフェルで雪を溶かして充分に腹ごしらえをした。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃全軍は木蔭や藪蔭に休み、割籠をあけて腹ごしらえをしていた。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少し腹ごしらえに出かけましょうか。",
              "citation": {
                "source": "秦の憂愁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時頃、トウスト、紅茶で腹ごしらえをさせ、二時立つ。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺の方は腹ごしらえだ。",
              "citation": {
                "source": "裸木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左近のりこむ　翌朝、左近は二人が迎えにくる前に腹ごしらえをして出発した。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は食物を取り出して、腹ごしらえをすると、残りは洞穴の中にしまっておきました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんまり食べると流産するぞ」「馬鹿にするない馬じゃあるまいし」「馬だよこんなもの食う奴は」元気な笑いを爆発させて夜中過ぎまでかかる夜業の腹ごしらえだ。",
              "citation": {
                "source": "馬鈴薯階級の詩",
                "author": "中島葉那子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お得意さきをまわりおえると、ルカー・アレクサンドルィチは、ちょっと妹のうちへよって、そこでお酒を飲み、軽く腹ごしらえをした。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄粉でも食って、腹ごしらえをしておけ」　と言い捨て、表ノ間へ走っていって晴着の袖の着物に着換えた。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "体もあたたまり、腹ごしらえもできると、にわかに眠くなったんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "造作にあつかって腹ごしらえもできた。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羔羊の肉を食うのも、パンを食うのも、脱走のための腹ごしらえでありました。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "「腹ごしらえはどうした」　平次は訊きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "第廿七吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "作造にあずかって腹ごしらえも出来た。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼女は、まず支那そばやへ腹ごしらえに入った。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "――蓑賀殿から剥ぎ取った物は姐さんに召し上げられた、しかし弁当代だけは置いていってくれたので、腹ごしらえは出来た。",
              "citation": {
                "source": "三悪人物語",
                "author": "忍術千一夜　第二話",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹ごしらえを十分にして、さっそくエーランド島にむかって出発しました。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど腹ごしらえもまずできた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉次の仲間がいつも泊る家へ、馬を一頭取りにやったり、腹ごしらえや弁当など作らせている間に、夜立ちのつもりが、いつか夜明けの早立ちぐらいな時刻になっていた。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしているあいだにだんだんみえてくる……おッとこんなところで感心していたところでつまらない、はやく一つ腹ごしらえして金閣寺だの祇園だの、ゆっくり一つ見物してこよう」　ふわりと鷲を地へ舞わせて、南蛮寺の朱門へおりた蛾次郎。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ははあ、おれには朝飯だが、人には午飯だったのか」　夜どおし隣県から馬をとばしてきた刑事｜頭の何濤は、とにかくと、役署前の一軒へ入って、腹ごしらえにかかっていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋江と燕順が、とある道ばたの居酒屋で馬をつなぎ、腹ごしらえをしかけていると、「おやっ？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かしこまりました」　そして、また、「皆さま、腹ごしらえはいかがですか。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "足じたばたって　ことは　子どもは　生きてるって　ことだし、　あなぐまトミーも　はらごしらえしたばかり。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
