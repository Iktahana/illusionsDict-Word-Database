[
  {
    "uuid": "a04cbb36-6584-56d0-937a-cb33f60ad31b",
    "entry": "八丈",
    "reading": {
      "primary": "はちじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
