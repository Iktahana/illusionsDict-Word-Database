        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日は仕事が忙しいから、早飯で済ませよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "朝食は早飯で済ませて、すぐに出かける準備をする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "旅先では時間に追われ、いつも早飯だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
