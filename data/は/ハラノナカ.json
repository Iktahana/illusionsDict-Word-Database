        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、細君の大きな腹の中に七人目の子供を見た。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の腹の中では、百パーセントのアルコールよりも、「ききめ」のある、コレラ菌が暴れ廻っていた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さては米代を飲んぢまやがつたな」　と腹の中で云つて、私は首をすくめた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹の中で、「この平凡な若夫婦に、何であの福慈の女神のことなぞが判るものか」と想いながら、こういう言葉で姉娘に関る話は打切りにした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎は腹の中ではこう思った。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は興味本位の立場から色々な怪奇をも説いてはいるが、腹の中では当時行われていた各種の迷信を笑っていたのではないかと思われる節もところどころに見える。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若返りの博士はからだでする表情をもう少し腹の中へしまい込んだ方がこの映画の俳諧的雰囲気に相応わしいのでないかと思われた。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平然として人の腹の中に這入って行くのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "己の腹の中で思う事を、あの可哀らしい静かな声が言い現わしているのだな。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリストフは腹の中で恥かしがる。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "全體旅をしながら何物をも見ず、見ても何等の感興も起さず、起しても其を折角の同伴者と語り合て更に興を増すこともしないなら、初めから其人は旅の面白みを知らないのだ、など自分は獨り腹の中で愚痴つて居ると『あれは何でしよう、そら彼の山の頂邊の三｜角の家のやうなもの。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして腹の中で、「なるほど相変わらずだな」と思った。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "油を搾られたにもかかわらず、彼等は、腹の中から、おかしい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺れは、お前の腹の中を見すかして居るんだぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そこらにいる者をさげすむように、腹の中で呟いた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると人の腹の中を読みかねるような婦人ではない、たちまち様子を悟ったかして、（貴僧はほんとうにお優しい。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ン、これが別れ別れて両方｜後家になっていたのだナ、しめた、これを買って、深草のを買って、両方合わせれば三十両、と早くも腹の中で笑を含んで、価を問うと片方の割合には高いことをいって、これほどの物は片方にせよ稀有のものだからと、なかなか廉くない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方がないから割に高いけれども、腹の中に目的があるので、先方のいい値で買って、わが家へ帰ると直にこの話をした、勿論親父に悦ばれるつもりであった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏元はさてこそと腹の中でニヤリと笑った。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つは毛深い熊があと足を前に投げ出してすわっている、それが首と前足とを動かして滑稽な格好をして踊りだすと腹の中でオルゴールのかわいらしい音楽が聞こえて来るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の腹の中はまっくろだ。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山がだんだん衰へて、その腹の中まで冷えてしまふ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山がだんだん衰えて、その腹の中まで冷えてしまう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな顔をしてヌケヌケと人通りを行きながら、腹の中は言うに言われぬ地獄のようなタネ仕掛とカラクリばっかり。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "関門海峡を渡る時に、腹の中で赤い舌をペロリと出した。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから話して一時間も経つと又｜喫驚、今度は腹の中で。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから話して一時間も経つと又喫驚、今度は腹の中で。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は口に出してこそ申しませんが、腹の中は面白くなくって堪りません。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう政府の感情というものは実に雄弁に、今日の政府が民主的なすべての行為に対して抱いているこころもちを語っている、はらのなかから、本当に新しい日本の建設に歓喜したりしていない、ということをはっきり語っているのである。",
              "citation": {
                "source": "メーデーぎらい",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ　おまえたち、　のはらのなかや　こみちのさきで　あそんでらっしゃい。",
              "citation": {
                "source": "あなうさピーターのはなし",
                "author": "THE TALE OF PETER RABBIT",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
