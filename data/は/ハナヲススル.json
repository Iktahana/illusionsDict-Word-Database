        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、言う清葉より聞く方が、ものをも言わず、鼻をすする。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "うとうと眠りかけたお母さんは、しくしく鼻をすする音に、また眼をさまされた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つやもいつか葉子の気分に引き入れられて、鼻をすするまでに涙ぐんでいた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ席にいた鼻をすする娘さんも京都で降りてわたしの横を改札口の方へ歩いて行っている。",
              "citation": {
                "source": "田舎がえり",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、鼻をすする音がする。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し捜しては、時々鼻をすする。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとたん、すぐうしろで、くすんくすん鼻をすする音がした。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、間もなくそれが鼻をすする音に変り、そして、不意にククククククククククと、むせ返る様な声が起った。",
              "citation": {
                "source": "一寸法師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなだまりこんでしまって、シーンと静まりかえったやみの中に、篠崎君の鼻をすする音だけが聞こえていました。",
              "citation": {
                "source": "妖怪博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇中の人物に自己を投射しあるいは主人公を自分に投入することによって、その劇中人物が実際の場合に経験するであろうところの緊張とそれに次いで来るように設計された弛緩とを如実に体験すると同等の効果を満喫して涙を流しはなをすする、と同時に泣くことの快感に浸るのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
