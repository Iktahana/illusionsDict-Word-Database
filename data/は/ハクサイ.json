[
  {
    "uuid": "bf147f38-01d7-5381-bdac-150b80d4448c",
    "entry": "白菜",
    "reading": {
      "primary": "はくさい",
      "alternatives": [
        "ハクサイ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "napa cabbage (Brassica rapa subsp. pekinensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "清新そのものともいいたい白菜の塩漬もうれしいが、鼈甲のような大根の味噌漬もわるくない。",
              "citation": {
                "source": "漬物の味〔扉の言葉〕",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔬菜は小柄で、ちょうど白菜を中指の丈けあまりに縮めた形である。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食卓には、つくだ煮と、白菜のおしんこと、烏賊の煮附けと、それだけである。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は小さい時から、白菜のおしんこが一ばん好きだった。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜のおしんこさえあれば、他におかずは欲しくなかった。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄の勝つたのは白菜である。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花椰菜、千日大根、萵苣、白菜、パセリ、人蔘、穀物、豆類。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　籠に盛られた新鮮な白菜をみるとき、私はまず初冬の夜明の空気の冷さを感じ、葉っぱの縮緬皺にたまった露のかなしい重みを感じ、また葉のおもてをすべる日光の猫の毛のような肌ざわりの柔かさを感じるが、その次の瞬間には、すぐこの野菜が塩漬にせられた後の、歯ざわりの心よさを感じぬわけにゆかない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は直ぐにそれをつまんで白菜の畑のなかに投げ込んだ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は直ぐにそれを摘んで白菜の畑のなかに投げ込んだ。",
              "citation": {
                "source": "はなしの話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "参木と甲谷の周囲には、いつの間にか、薔薇や白菜が匂いを立てて揺れていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹明君来庵、香煎をすゝり、白菜新漬でお茶を飲んで別れる、めでたし／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜がおいしい、漬けて一等だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜一玉八銭、これも漬物にして天下一品。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "小蕪、白菜、醤油、等々、今日の庵は物資豊富である、ありがたう、すみません。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜二株七銭、これで当分おいしい菜漬が食べられる、菜漬はほんたうにおいしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　　――――――――――――――――――――――――――――白菜の新漬のおいしさ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の買物十八銭　　はぎ三十銭　　　密柑五四銭　　　湯銭六銭　　　豆腐一三銭　　　金盞花一把二十銭　　草餅十　　　合計金六十一銭也　　今日の三食　┌大根朝│　└漬物（白菜）　┌豆腐　│昼│　　　漬物　└海苔　│　┌汁　　│晩│　　　〃　└若布　お茶受　　　草餅、キヤラメル、密柑。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜二把六銭、すぐ洗つて漬ける。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜は一株について四十銭ですよ。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜を四｜糎位に型をくずさない様にぶつぶつ切りまして、三枚肉は普通に切ったのを一緒に水をたっぷり入れてはじめからあんまり強くない火で永い時間に煮ます。",
              "citation": {
                "source": "十八番料理集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜がすっかりやわらかくなった時白タキを入れても美味しゅうございます。",
              "citation": {
                "source": "十八番料理集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」というスローガンで市場へ売り出す白菜や南京豆の代りに、こういうものを作りはじめたんだ。",
              "citation": {
                "source": "飛行機の下の村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "微かに障子紙の匂いを感ずる――　食べたいものの第一は支那料理の白菜羹汁だ。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑を見まはる、楽しみこゝにあり、肥料をやつたので、ひよろひよろ大根がだいぶしつかりしてきた、白菜はもう一度間引しなければなるまい、ひともじの勢のよさ、何とほうれんさうが伸ぶことぞ、新菊は芽生える／＼。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩方、Ｊさんが白菜二玉持つてきてくれた、見事々々。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑にのびて来た白菜。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の色の乗り越えて来るような迅さで、鰈や烏賊、えい、ほっけを入れた笊籠はどこの家の板の間にも転がり、白菜の見事な葉脈の高く積っているあたりから、刈上げ餅を搗く杵音がぼたん、ぼたん、と聞える。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、塩鮭と白菜の漬物を茶ぶ台に揃へて、その前にきちんと坐つた。",
              "citation": {
                "source": "障子のある家",
                "author": "尾形亀之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "白菜の残りをつまみ、白い御飯の舌ざわりを空想するなり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
