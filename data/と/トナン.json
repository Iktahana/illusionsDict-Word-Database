      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the whole world",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "強いていおうならば北斗南面して看るという唐ようの古語にでも表現を譲るより仕方はあるまい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「青森県沿革」本県の地は、明治の初年に到るまで岩手・宮城・福島諸県の地と共に一個国を成し、陸奥といひ、明治の初年には此地に弘前・黒石・八戸・七戸および斗南の五藩ありしが、明治四年七月列藩を廃して悉く県となし、同年九月府県廃合の事あり。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂ニ自ラ号シテ斗南狂夫トイフ。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、その遺稿集は、『斗南存稾』と題されている。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この『斗南存稾』を前にしながら、三造は、これを図書館へ持って行ったものか、どうかと頻りに躊躇している。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、軽い罪ほろぼしの気持で『斗南存稾』を大学と高等学校の図書館に納めることにした。",
              "citation": {
                "source": "斗南先生",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金十郎が、どこの辺から出て来たのか、と声をかけると、もしや奉謝にあずかれるかと、おれは斗南から、わしはどこどこからとつぶやく、　そのなかに京なまりの女の声を聞きつけた。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口の米会所で昵懇だったのを思いだし、廻船の上乗りにでもしてもらって江戸へ帰ろうと、郭内のお長屋をたずねると、川村孫助はみすぼらしい金十郎の風態をそば眼するなり、ひとりでのみこんで、斗南の白並というところにある御船番所の御小人に推挙してくれた。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "海はなが身の鏡にて、はてなき浪の蕩揺に、汝はなが魂打眺む　海は汝が身の鏡にて、と云はれるとなんだか罪でも犯した気持になる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造はお金のことなんか忘れてゐる。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤もあなたが書いてるのは何時ものことなんだから。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自殺しない厭世論者の言ふことなんか、當になるものか。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが自殺しない厭世論者の言ふことなんか、皆ウソにきまつてゐるよ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまつさへ彼が反復した最後の言葉――自殺しない厭世論者の言ふことなんか、たれが本氣にするものか。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、ひとりの青年とは誰のことなんだとそのじぶん楽壇でひそひそ論議されたものだそうであるが、それは、馬場であった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正九年、露細亜詩人ベールィの作を雑誌で見かけて破格語法なぞといふことは、随分先から行はれてゐることなんだなと安心す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "読みさしの頁をみるとなんだか胸を蒸気で圧されるやうだつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ何と面倒臭いことなんだ！",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真逆に墓表とは見えずまた墓地でもないのを見るとなんでもこれは其処で情夫に殺された女か何かの供養に立てたのではあるまいかなど凄涼な感に打たれて其処を去り、館の裏手へ廻ると坂の上に三十くらいの女と十歳くらいの女の子とが枯枝を拾うていたからこれに上根岸までの道を聞いたら丁寧に教えてくれた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狸」でない子がわざとなんだか落着かないような様子をして天井を仰いでみたり鼻をこすってみたりして牽制しようとするなどはきわめて初歩であるので、その裏をかくつもりで「狸」自身がわざとそのような振りをすることもある。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眠っているような植物の細胞の内部に、ひそかにしかし確実に進行している春の準備を考えるとなんだか恐ろしいような気もする。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うとなんだか呼吸が苦しいようである。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、作りごとなんだから。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり日本アルプス探検などは好奇心のなすわざで、その紀行文を書くのは、つまらぬことなんだそうだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそう云やあ、此小僧っ子の云う事がほんとには、ほんとなんだがな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ、兄さん」「いつ小屋を葺くことなんか覚えたんだい、お前は？",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "偉くなることなんて。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国へ渡るとなんだか急に呑気になった、巡査を見ても牛乳屋を見ても誰を見ても一様に呑気な顔をしていた。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々考えが形而上的に走り、罷り違えば誇大妄想狂となんら選む所のないような夢幻的の思索に陥って、いつの間にか科学の領域を逸する虞がある。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は「サケ」と「シャケ」が間違ったら飛んでもない間違いを起しますが、アイヌ人は「サケ」も「シャケ」も音としては同じことなんです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
