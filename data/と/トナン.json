[
  {
    "uuid": "e9391386-1bfb-5513-b92d-a8f50921df5c",
    "entry": "斗南",
    "reading": {
      "primary": "となん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
