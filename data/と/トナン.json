    },
    "definitions": [
      {
        "index": 1,
        "gloss": "large undertaking attempted in a far-off land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "白金巾の洋傘に、見よ大鵬の志を、図南の翼を、などと書きましてね。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "図南の鵬翼既に成れり。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "図南の鵬翼いずれのときにか奮わん。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶長年間に到りては、徳川家康、帰化英人アダムスをして百二十｜噸の大船を造らしめ、太平洋を横断して、墨西哥と交通せしめ、伊達政宗は、図南の鵬翼を揮わんと欲して、その臣｜支倉六左衛門をして、墨西哥に径して、羅馬に使せしむ。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て阿媽港、呂宋を征せんと欲し、「図南の鵬翼何れの時にか奮わん、久しく待つ扶揺万里の風」と歌いたる独眼政宗も、今は「四十年前少壮の時、功名｜聊か復た私に期する有り。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤客遠游三保羅、偶逢邦友感懐多、豈図南米塵深処、日本店頭談大和。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長公の図南西覇の基点として、秀吉がその前駆をうけたまわるところのもの。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "海はなが身の鏡にて、はてなき浪の蕩揺に、汝はなが魂打眺む　海は汝が身の鏡にて、と云はれるとなんだか罪でも犯した気持になる。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
