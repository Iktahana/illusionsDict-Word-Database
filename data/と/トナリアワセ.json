        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふたりは隣り合わせの部屋で寝ており、キングのおかみがソーンダズの部屋へかけこんだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで髭のある人と隣り合わせになった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "立っていたのは、同じ番町で屋敷を隣り合わせて、水馬のときにも同じ二組で轡を並べて、旗本｜柔弱なりと一緒に叱られた仲間の柘植新兵衛だった。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは部屋を隣り合わせているというだけで、別に話をするでもなく、暮した。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに偉いけれどもそれが隣り合わせている。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の非常時は次の超非常時と隣り合わせであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "登美がその次で縫子は英輔と隣り合わせであった。",
              "citation": {
                "source": "縫子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八一（昭和五十六）年秋、サンフランシスコから成田行きの便のファーストクラスに乗り込んだ西は、隣り合わせた日本人と言葉を交わした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナカナカ機敏なものだが、扨馳け付けて来てドウするつもりか……となおも物蔭から様子を見ていると、若林は君の頭を散髪さして湯に入れて、堂々たる大学生の姿に仕立て上げてから、君の室と隣り合わせの六号室に入院している一人の美少女に引き合わせたろう。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのお邸を持っているという偶然の事実があの一年（いな、それよりももっと長い年月）以来荘厳な近寄り難いものとして来た和歌子と隣り合わせて、「ああ、お和歌さんかい」と言わしめているではないか。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、彼女たちの口利きで、裏口がすぐ隣り合わせになってる谷口家の、六畳の室を世話してくれた。",
              "citation": {
                "source": "祭りの夜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "滑稽と悲惨とが隣り合わせに棲んでいたことにはじめて気がつくような異常な光景だった。",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂は私の部屋と隣り合わせになっているらしい。",
              "citation": {
                "source": "旅の絵",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬と春とが、隣り合わせになって、もう間近にきていました。",
              "citation": {
                "source": "寒い日のこと",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と夫人は、さっき自分でもそう信じていた瞬間に、食卓で隣り合わせた婦人にいった。",
              "citation": {
                "source": "ある幸福",
                "author": "EIN GLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがビショップ夫人の家と隣り合わせだった。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢木城介は偶然加納と座席で隣り合わせていた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼等は遅れていったものだから、おのずから食卓では互いに隣り合わせに坐ることになった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「スープが冷めてしまいますよ」　二人の学生は隣り合わせに座った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の通路が偶然隣り合わせになったのだ。",
              "citation": {
                "source": "地獄風景",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベナの見るところ、この男は死と隣り合わせのようだった。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかし、垣一重の隣り合わせに住んでいた頃の往来も、こうだったのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "……したが、新田、足利は下野の領地を隣り合わせていることゆえ、なにせい、至極むずかしい立場にある」　いつか、屋根の夜雨の音は、やんでいた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術至上主義ととなりあわせて極めて卑俗な楽壇世渡り、社交性が、芸術家に必要な社会性とすりかえられて並んでいます。",
              "citation": {
                "source": "期待と切望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパの国々は、互に国境を地つづきの山や河、森の間にとなりあわせ、互の国語に共通な語源をもち、今日までの歴史のなかではヨーロッパのどの国もとなりの国におこる事件に対して、無関係ではあり得なかった。",
              "citation": {
                "source": "それらの国々でも",
                "author": "――新しい国際性を求めて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、ほかの若い妖女のひとりが、そばにとなりあわせていて、おばあさんのくどくどいうことばを、そっと聞いていました。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "客間ととなりあわせてドアのあけはなされている食堂の旅行用の立て時計をつや子が見に行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシ子ちゃんの寝室は西洋館の二階にあって、にいさんの丈吉君の寝室と、となりあわせになっていたのですが、白い幽霊が、ヨシ子ちゃんの手のひらに、３という字を書いていってから、二階の寝室はあぶないというので、ヨシ子ちゃんも丈吉君も、一階のおとうさんの部屋で、いっしょに寝ることになっていたのです。",
              "citation": {
                "source": "塔上の奇術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルースがもっとも単純でクラシカルがいちばん複雑で、両者はとなりあわせに存在している。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
