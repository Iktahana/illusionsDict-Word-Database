    "definitions": [
      {
        "index": 1,
        "gloss": "far away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "友よ、やさしく胡弓を摩り、遠くよりしも光を送れ。",
              "citation": {
                "source": "立秋",
                "author": "――大沼竹太郎氏ニ捧グル詩――",
                "note": "青空文庫"
              }
            },
            {
              "text": "訓導宮沢賢治早くもひとり雪をけりはるかの吹雪をはせ行くは木鼠捕りの悦治なり三人ひとしくはせたちて多吉ぞわらひ軋るとき寅は溜りに倒れゐし赤き毛布にくるまりて風くるごとに足小刻むは十にたらざる児らなれや吹雪きたればあとなる児急ぎて前にすがりつゝ一列遠くうすれ行く",
              "citation": {
                "source": "訓導",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔雲ふかく　山裳を曳けば〕宮沢賢治雲ふかく山裳を曳けばきみ遠く去るにかも似ん丘群に日射し萌ゆればきみ来り訪ふにも似たり",
              "citation": {
                "source": "〔雲ふかく　山裳を曳けば〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金鉱を発掘する人は、親や妻子より遠く、山中に分け入るのだ。",
              "citation": {
                "source": "詩論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手の籔が切れる所に来ると、右手の方に養漁場がみえ、その他は一面の田で遠く神田上水源の方の森並に縁取られてゐる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くに白い家と緑や赤の屋根がみえる。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯草は針金のやうに硬くて、トゲトゲとした檜か何かの森が遠くに見える。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その時はまだ、閉塞隊の沈めた船のマストが、海の上にのぞいてをつた」と、貧血した母の顔が、遠くの物でも見てゐるやうに、それでもそんな時にはなにか生々と、後年私の生後七ヶ月の頃のことを語つて呉れるたびに、私は何時も決つて右のやうな風景を心に思ひ浮べるのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもここにはなにがあるか、遠く都會をはなれたここの田舍には何があるか、ああ、ここには風がある、はてしもなくひろがつた大空がある、たかく盛りあがつた土壤がある。",
              "citation": {
                "source": "都會と田舍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春晝――敍情小曲――萩原朔太郎うぐひすは金屬をもてつくられしそは畔の暗きに鳴き菫は病鬱の醫者のやうに野に遠く手に劇藥の鞄をさげて訪づれくる。",
              "citation": {
                "source": "春晝",
                "author": "――敍情小曲――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も、一切の係累を捨ててしまつて、遠く南米の天地に移住したいと語つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たちまち、ざぶりと大波が押し寄せ、その内気な遭難者のからだを一呑みにして、沖遠く拉し去った。",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外電車の轍の音が、暗い、遠くの森の方でしてゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」父は遠くの木の葉でもみるやうな眼付をしていつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「御大事になさい……」　まるで遠くへ行く人への別辞だ、――Ｓ子はさういふなり下向いた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの点が、彼の句を枯淡な墨絵から遠くし、色彩の明るく印象的な西洋画に近くしている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西詩に多く見るところの、こうした「白愁」というような詩情を、遠く江戸時代の俳人蕪村が持っていたということは、実に珍しく不思議である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜の花や鯨も寄らず海｜暮ぬ　菜種畠の遠く続いてる傾斜の向うに、春昼の光に霞んだ海が見え、沖では遠く、鯨が潮を噴いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯の声遠き日も暮れにけり　春の暮方の物音が、遠くの空から聴えて来るような感じがする。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶頂の城たのもしき若葉かな　若葉に囲まれた山の絶頂に、遠く白堊の城が見えるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居鳥寺見ゆ麦林寺とやいふ　夏の日の田舎道、遠く麦畑の続いた向うに、寺の塔が小さく見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮒鮓や彦根の城に雲かかる　夏草の茂る野道の向うに、遠く彦根の城をながめ、鮒鮓のヴィジョンを浮べたのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その屋根の上から、刈入時の田舎の自然が、眺望を越えて遠くひろがっているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした初夏の野道に、遠く点々とした行路の人の姿を見るのは、とりわけ心の旅愁を呼びおこして、何かの縹渺たるあこがれを感じさせる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛尽す鳥ひとつづつ秋の暮　芭蕉の名句「何にこの師走の町へ行く鴉」には遠く及ばず、同じ蕪村の句「麦秋や何に驚く屋根の鶏」にも劣っているが、やはりこれにも蕪村の蕪村らしいポエジイが現れており、捨てがたい俳句である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広茫とした穂蓼の草原が、遠く海のように続いた向うには、甲斐の山脈が日に輝き、うねうねと連なっている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山脈の道を通って、駿河から甲斐へ運ぶ塩車の列が、遠く穂蓼の隙間から見えるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前途は遠く永遠であり、日は空に薄曇っていた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るき四月の外光の中嬉嬉たる群集の中に混りてふたり模擬飛行機の座席に乘れど君の圓舞曲は遠くして側へに思惟するものは寂しきなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はリキュール酒のようなあまさで、夜の街を覆うと、絢爛な渦巻きがとおく去って、女の靴の踵が男の弛緩した神経をこつこつとたたいた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
