[
  {
    "uuid": "b0bfc7bd-5102-5709-ad57-bf6e0b751de5",
    "entry": "当路",
    "reading": {
      "primary": "とうろ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
