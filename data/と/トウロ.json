    },
    "definitions": [
      {
        "index": 1,
        "gloss": "frozen dew",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いくら日本軍がやって来たって、今度の北伐軍の前には、牛車に向かうとうろうだよ、と笑った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざえもんは　くろいあたまをくうらりくらり、　とんびとうざえもんは　あぶら一｜升でとうろりとろり、　そのくらやみはふくろうの　いさみにいさむもののふが　みみずをつかむときなるぞ　ねとりを襲うときなるぞ。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「からすかんざゑもんは　くろいあたまをくうらりくらり、　とんびとうざゑもんは　あぶら一升でとうろりとろり、　そのくらやみはふくろふの　いさみにいさむものゝふが　みゝずをつかむときなるぞ　ねとりを襲ふときなるぞ。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅馴れぬ旅行者のように、早く駅前へ出ようとうろうろする許りである。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アッ……イカンイカン……行路病人だ……こりゃあ……」　とうろたえながら刑事らしい男は立ち上った。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私という若い渡り鳥が、ただ東から西、西から東とうろうろしているうちに老いてしまうという主題なのです。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから蝋燭のまわりをきょろきょろとうろついているばかりでありました。",
              "citation": {
                "source": "赤い蝋燭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の都を当てどもなくあちこちとうろつき廻る事である。",
              "citation": {
                "source": "殺人行者",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "房州石の安物のとうろうではあるが、一対こわれもせずにあった。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日はあれをその麓から仰いで来たに、とうろたへて中村君を呼び起したが、返事もなかつた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは彼は、昼間のうちは寝ていて、夜になるとうろうろ歩きまわるので挙動不審だというので宿の者が警察へそっと密告したためだったそうである。",
              "citation": {
                "source": "江戸川乱歩",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫かごにはまだ少し早いが、そのかわり軒端の先には涼しい回りとうろうがつるされて、いずこの縁台も今を繁盛に浮き世話のさいちゅうでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "なぞの八卦見",
                "note": "青空文庫"
              }
            },
            {
              "text": "表へ帰りませいッ」　不意を打たれてぎょッとうろたえ上がったのは、荒法師玄長でした。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日、一同の者の話とうろ覚えを総合して見ると、大体に気嫌の好い、愉快な、当り前の酔漢であつたらしい、殊に子供達から、絶大な賞讚を博されたことでも解る。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の中に四、五人の私服がはいりこんで、あちこちとうろうろしたり、僕が乗った二等の喫煙室に坐りこんだりしていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうろす・け・ばん！",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、陽はいま最も地上に近い――といった、心理的にも気象的にも殺伐な潮どきを見計らって、何も猫を殺したところで初まらないから、そこで大々的に牛を殺すことにしたのが、このいすぱにあ国技「こりだ・で・とうろす」だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして私は、東京の隅から隅へとうろつき歩いたのです。",
              "citation": {
                "source": "悪魔の弟子",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半生の希望と結晶を、一撃の下に粉砕しなければならなかった彼の、悲惨な姿を、私は長いことうろうろと探し求めた。",
              "citation": {
                "source": "脳波操縦士",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめんなさい」といいましたが、とうとうろう屋へつれて行かれました。",
              "citation": {
                "source": "花咲かじじい",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といいながら、そっとうろの中から顔を出してのぞいてみますと、まあどうでしょう、それは人ではなくって、ふしぎな化け物が、何十｜人となくぞろぞろ出てくるのです。",
              "citation": {
                "source": "瘤とり",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事にあちこちとうろつき廻る度びに、どこでも拒絶されて来たらしい旅客たちは、ただ街を流れ歩いているだけだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は三つの不幸の輪の中で血を流しながら頭を上げると、さてどつちへ行かうかとうろうろした。",
              "citation": {
                "source": "盲腸",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おときの所では一昨日上簇が済んで、今｜漸っとうろつき拾ひが片付いたところだと云って直ぐに来て呉れた。",
              "citation": {
                "source": "夏蚕時",
                "author": "金田千鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、矢張り果ない望みをかけながら、知人から知人へとうろつき廻っているのだろう。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い実のついている梅　かさだけ時代もので、胴がよせもののとうろう、　つつじ　杉、しゃぼてんの鉢　　　　　　　　　　――○――　かた木の庭木　大名竹　槇　周防の花　下ぬりのまま五六年たった壁。",
              "citation": {
                "source": "Sketches for details Shima",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳島の端午に作るやねこじき又は、だしと言はれてゐる作り物は、江戸の顔見世のとうろうなる屋根飾りと同様に、屋上に出すもので、依代が竿頭から屋根に降りて来た時機を記念するものである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同類の変形は、大阪新町・江戸新吉原のとうろうにも見られる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
