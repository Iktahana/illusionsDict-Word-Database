    "definitions": [
      {
        "index": 1,
        "gloss": "resident of Tokyo",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
