        "動詞-五段-ラ行-不規則"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "it says ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでその現状が、仮りに不安な現状であらうとあるまいと、学問、芸術の興隆に適してゐようとゐまいと、所詮致し方もないことである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度出来て来た詩集をみると「浚渫船」とある。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありとある微分値の間を駆け巡り、今日積分値にまで漸く辿りついてみると、案外に道は近きにあるに驚かざるを得ない。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なれば類推なるものは、先に云ふ「面白いから面白い境」にもともとあるものではないから、例へば詩に於ては語が語を生み、行が行を生まなければならぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある裏町に濁った溝川が流れている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雨の夜、父は他所の宴会に招かれて更けるまで帰らず、離れの十畳はしんとして鉄瓶のたぎる音のみ冴える。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある杉垣の内を覗けば立ち並ぶ墓碑｜苔黒き中にまだ生々しき土饅頭一つ、その前にぬかずきて合掌せるは二十前後の女三人と稚き女の子一人、いずれも身なり賤しからぬに白粉気なき耳の根色白し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寓所ハ牛込｜矢来町三番地｜字中ノ丸丙六〇号」とある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日」とあるのは七月二十三日だろうと思われるのは消印が二十四日のイ便であるのに「只今（九時）帰申候」とあるからである。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の袋町に○印をして「浅井」とあるのは浅井｜忠氏の家であろう。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の右方に鳥居をかいて「三島神社」とある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから下の方へ下がった道脇に「正門」とあるのはたぶん前田邸の正門の意味かと思われる。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上根岸百何番とあるからこの辺かと思うが何一つ昔の見覚えのあるものはない。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある横町を這入って行くと左側にシャボテンを売る店があった。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し行くと路地の角の塀に掛けた居住者姓名札の中に「寒川陽光」とあるのが突然眼についた。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "状袋の裏には、牛込区若松町百卅七田山花袋とある。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も横浜通の紫紅兄（山崎）の批評で凹んでいるとあるのも、横浜付近の誤謬記事を指摘されたことを、付随して言ったのだ。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬岳の又の名を越後方面では大蓮華山といっている、或人の句に「残雪や御法の不思議蓮華山」とあるからは、これも一朶の白蓮華、晶々たる冬の空に、高く翳されて咲きにおうから、名づけられたのかも知れない。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "文中に前穂高とあるは、御幣岳の北部より下れる一支峰にして、梓川に臨み、上高地温泉または河童橋より、最も近く望見し得らるる、三角測量標を有せる低山をいう。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政六年版の玉蘭斎貞秀画、富士登山三枚続きの錦絵には、「小御岳、花ばたけ、しゃくなぎ多し」とあるから、昔から多かったものと見える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも貞秀の錦絵に「牛が窪、四時雪あり」とあるから、昔ながらの雪と見えるが、今ではかえって、ここの万年雪を、人が言わないようだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "案内記に「四壁｜屋蓋畳むに石をもってし」とある通りで、奥宮を中心とする山の町である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文には書いてないが、辻村は病院生活、約一ヶ月後に、漸く退院したが、猶お歩行を禁ぜられ、其後、更に三週間を、とある湖畔に送って、九月二十五日に、伊太利ミラノに出て、マルセーユヘ陸行し辻村は香取丸に便乗、近藤氏は、倫敦からアメリカを通って、故国の土を踏むことが出来たのである。",
              "citation": {
                "source": "「続スウィス日記」発掘の始末",
                "author": "附「スウィス日記」の由来",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は昨年｜塩山の停車場で、白ペンキ塗の広告板に、一の宮郷銘酒「白嶺」と読んで、これは「雪の白酒」ではあるまいか、さぞ芳烈な味がすることであろうと思った、また他で製糸所の看板に、白嶺社とあるのを見て、この社の糸の光には、天雪の輝きがあろう、衣に織ったらばさぞ、と考えたことがある。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある横町をちょっと山の方へ曲り込んでみると、道に向って倒れかかりそうになったある家に支柱をして、その支柱の脚元を固めるためにまた別のつっかい棒がしてある。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで思い出したのは、関東大震災のすぐあとで小田原の被害を見て歩いたとき、とある海岸の小祠で、珍しく倒れないでちゃんとして直立している一対の石燈籠を発見して、どうも不思議だと思ってよく調べてみたら、台石から火袋を貫いて笠石まで達する鉄の大きな心棒がはいっていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶんは多くの同種類の云い伝えと同様に、時と場所との限られた範囲内での経験的資料とある形而上的の思想との結合から生れたものに過ぎないだろう。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、作者によってはその心像の顔が非常に近く明瞭に浮ぶのと、なんだか遠い処にぼんやり霞を隔てて見るように思われるのとあるように思う。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの中立地帯の産物はその地帯の両側にある二つの世界の住民から見るとあるいは廃頽的と見られあるいは不徹底とののしられるかもしれない。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
