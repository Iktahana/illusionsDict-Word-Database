    "definitions": [
      {
        "index": 1,
        "gloss": "speaking of ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なぜかと言えば第一胃が悪くなる、頭が重くなる。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北西の一峰を踰えたことを記憶している、そこに何があったかと言えば、白花の石楠花があったことだけが答えられる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとボーイは「何でもむかし東海道でよくお目にかかった作楽井の息子と言えばお判りでしょうと仰っしゃいますが」　主人は部屋へ通すように命じて私に言った。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故と言えば、余り深く一処、一物に執着して研鑽を積むという性質ではないからである。",
              "citation": {
                "source": "異性に対する感覚を洗練せよ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士道と言えば、女は眼中にないような風に言われながら、正妻となるとなかなか格式を与えて十分な権利を主張せしめている。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体ない、私のような者の子によくもそんな男の子が……と言えば「あなたの肉体ではない、あなたの徹した母性愛が生んだのです」と人々もお前も、なおなお勿体ないことを言って呉れる。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若侍が、Ｔ「日下部先生お出で　と知って、よう出て　来ぬとは大吉も　案外情けない奴」　と言えば、　進藤が、Ｔ「と思って居られる　から、御貴殿は　未だ若い」　若いと言われて若侍訝しそう。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵が今度は典六に、Ｔ「じゃわっしは　馴染みの町与力に　頼んでお上の手で　大吉の野郎を……」　と言えば典六「お頼み申す」　お光は独り不安な顔。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらかと言えば日本のように大陸の東側、大洋の西側の国は気候的に不利な条件にある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかと言えば人間と自然とを切り離して対立させない限り、主と客との対立的の差別はなくなってしまうからである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころの田舎の饗宴の照明と言えば、大きなろうそくを燃やした昔ながらの燭台であった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜと言えば、そういう宣伝は無制限に波及する気づかいがないからである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし現在の宣伝という言葉には、いつでも、どことなしにそういう「におい」があり「影」があると言えば、それはおそらく多くの人が首肯するであろう。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいと言えばおもしろいがそれは白日の夢のおもしろさで絵画としてのおもしろみであるかどうか私にはわからない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪之助がお類に、Ｔ「馬鹿を見たのは伊吉の奴さ」　と言えばお類も、Ｔ「きっと追ッ掛けて来るわ」　浪之助が笑って、Ｔ「思う壺さ」　お類も笑う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とその女を見返したのであるが、そのとき吉田の感じていたことはたぶんこの女は人違いでもしているのだろうということで、そういう往来のよくある出来事がたいてい好意的な印象で物分かれになるように、このときも吉田はどちらかと言えば好意的な気持を用意しながらその女の言うことを待ったのだった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その高い音と関係があると言えば、ただその腹から尻尾へかけての伸縮であった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、貴下から預かっているも同然な品なんだから、出入れには、自然、指垢、手擦、つい汚れがちにもなりやしょうで、見せぬと言えば喧嘩になる……弱るの何んの。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪のようだと言えばそんなに冷たいかとこたえ白うさぎのようだと言えばそんなに毛深い柔らかいのかと聞きかえした。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜかと言えば各民族の化け物にはその民族の宗教と科学と芸術とが総合されているからである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの発見の重大な意義はと言えば、それらのものの精密なる数値的決定より先にそれらのものが「在る」ということを確立することである。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の少青年時代に受けた文学的の教育と言えば、これくらいのことしか思い出されない。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の世界にあるものは義理と人情のほかのものと言えばそれの反映である。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人はこれを官衙の門衛のようだと言ったが、自分もどちらかと言えば多少そんな気がしないでもない。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学書では、どちらかと言えば近代の人気作家のものが多くてそれらが最も目につきやすい所に並んでいる。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもどちらかと言えばあらのない、すべっこい無疵なものばかりである。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルプスと言えば銀座にもアルプスができた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれよりも、もっと直接に自覚的な筋肉感覚に訴える週期的時間間隔はと言えば、歩行の歩調や、あるいは鎚でものをたたく週期などのように人間｜肢体の自己振動週期と連関したものである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、もう東京はいやだ、殺風景すぎる、僕は北京に行きたい、世界で一ばん古い都だ、あの都こそ、僕の性格に適しているのだ、なぜといえば、――と、れいの該博の知識の十分の七くらいを縷々と私に陳述して、そうして間もなく飄然と渡支した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵野といえば、ただちに独歩の名作が連想されるが、花袋も紀行文家として「野の人」であった、武蔵野の人であった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
