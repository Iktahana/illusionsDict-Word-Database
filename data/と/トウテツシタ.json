        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただちがふところは、ラムボオが透徹した知性人であつたに反し、中原君がむしろ殉情的な情緒人であつたといふ一事である。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの奇怪な『猫』の表現の透徹した心持は、幾度となく私の模倣したものであつたが物にならなかつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀で染めた髪と、眉の間に鼻眼鏡をかけたアウギュスト・ロダン氏は、妾の小さい手を芸術家らしい熱情をもってとると、不思議に透徹した眼光が妾を凝視しているのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は尻のところに縫模様のある緑色の部屋で踊子のベッドに寝ころんで天井に口汚く附着したシャンパンの斑点をみつめながら、病み果てた病人のように透徹した頭脳であわただしく過ぎて行った赤い歴史をめくるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもダーウィンの進化論や、アインスタインの相対性云々よりも、もっと深刻透徹した名原則をあらわす公式なのだからね。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の見るところでは、むしろ珍しいくらいいい透徹した頭脳をもっていたように思われる。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ参考としては、当時の国民実情に対する透徹した洞察あるのみであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の無関心な心、秋の透徹した気、午後三時頃の温かい光線が衰弱した神経の端々まで沁みわたって、最う社会もない、家庭もない――自分自身さえもなくなろうとする。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人は氏の自殺に対して、病苦、家庭苦、芸術苦、恋愛苦或いはもっと漠然とした透徹した氏の人生観、一つ一つ別の理由をあて嵌めた。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会児の洗練透徹した機智は生れ付きのものだった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は愛があるうちは愛の完全透徹した力を信じてゐた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら無言の石どもの間に坐って、その美しい結晶や正しい劈開のあとを見ていると、何か冷たい・透徹した・声のない・自然の意志、自然の智慧に触れる思いがするのである。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "へ……俗受けを棄てて純真へ……華麗から率直へ……客観から主観へ……最高の芸術的良心の表現へ……透徹した生命の躍動へと進化して行く。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "内面的に云えば在来の能の表現を一層求心的にしたもので、喜多流の能が完成すれば最も単純な、最も透徹した仮面舞台表現が出現する訳である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日透徹した空をぢり／＼と軋りながら高熱を放射しつゝあつた日も餘りに長い晝の時間に倦まうとして、空からさうして地上の凡てが漸く變調を呈した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根の葉は、一｜旦地上の緑を奪うて透徹した空が其の濃厚な緑を沈澱させて地上に置いた結晶體でなければならぬ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二六　翌朝万寿丸は、雪に照り映えた、透徹した四囲の下に、自分の所在を発見した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言つた賢明に捉へられるといふこと、それさへ除けば、あとは玲瓏透徹した一面の鏡であると言ひ得ると私は思ふ。",
              "citation": {
                "source": "正宗君について",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの谷を渉るには殊に玲瓏透徹した縦断の太い丈夫な綱が必要である。",
              "citation": {
                "source": "心理の縦断と横断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "また此処に至つて、始めて何物にも捉へられない玲瓏透徹した大慈悲心を持つことが出来た。",
              "citation": {
                "source": "心理の縦断と横断",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "拍子木が凍えた空氣にヒヾでも入るやうに、透徹した響を傳えると、道化した調子の口上が聞えた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "眞の朗らかさは、彼によれば、精神の深さや清らかさや透徹した感じと一緒でなければならなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダヌンツィオが飛行機で飛びまわってヒロイズムを発揮したような時代からこのかた、今日の世界の動きとその間に生きる作家の気持とは、いか程多角的に、観察と沈着と現実に対する透徹した洞察力を求めるところへ進んで来ていることであろう。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、我々は、その重大な一点に、絶えず聰明な、透徹した眼を据えなければなるまい。",
              "citation": {
                "source": "深く静に各自の路を見出せ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が現実を凝視するのはそれによって現実をはなれて私の標的を純粋にし、日々のこまかなことにまでアイデアリズムを透徹したいためでございます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして哲學者のうち嘗てへーゲルほど歴史的社會的存在に關して廣汎な、透徹した研究を爲し遂げた者はない。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい寂しい、空氣の澄んだ中で、丁度壜の中へ入れられた蟲が、人間の眼の働きを恐れるやうに、私達はこの明るい透徹した高原の大氣の中で、一種の恐怖を感じて身の周圍を見廻したくなる。",
              "citation": {
                "source": "霧の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の人間として、芸術家として、資本主義社会での現実の考えかた、観かたはいつも真に透徹した明晰さをかいていて、どこかに真実を歪めたりかくしたりする偽瞞をもっていること、詭弁から解放され得ないことを、ソヴェトのそとのヨーロッパ諸国の生活のあらゆる細目から感じた。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第九巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
