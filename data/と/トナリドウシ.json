    "definitions": [
      {
        "index": 1,
        "gloss": "next-door neighbors",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
