        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "では、これを重光さんのお肴にとっといて、またビールでも差上げましょう。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また上げますからとっといて下さいよ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "シイカが部屋をとっといてくれる約束だった。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桂がさきへ帰るからね、晩御飯に、さんま食べるって――浅漬もとっといておくれ。",
              "citation": {
                "source": "市川九女八",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角とっといて上げたのに読んだらいいじゃあないの」「読まないだっていい」「かわってる？",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女事務員たちは、そんなとき食券はとっといて「モーリ」で十銭の昼食をする。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ある」「とっといてや」　と、云って、走って、学校へ行ってしまうが、この焦げた飯を握ったのが、私の間食であった。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっといて貰うことにしてとなりのキノを見た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「床をとっといて下さい、すぐに寝るんだから。",
              "citation": {
                "source": "童貞",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人のあっし達はどうなるんで……」「あれは人質にとっといて今日から下水掃除をさせる。",
              "citation": {
                "source": "一九五〇年の殺人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから、大学の先生たち、あなたがたのどなたか、大学病院の産婦人科へ電話を掛けて、ご懇意の先生と連絡をとっといていただきましょうね。",
              "citation": {
                "source": "キャラコさん",
                "author": "新しき出発",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のために温かにして、とっといてやるとでも思っていたのかい？",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし昨日からとっといてあげたんだけど、あんたの帰りが遅いもんだから。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあなたご自分で、ご自分のものとしてとっといてください。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、お前にはなんにもとっといてくれないのかい。",
              "citation": {
                "source": "ユダヤ人のブナの木",
                "author": "山深きヴェストファーレンの風俗畫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから築地の瓢亭へ、座の新年会で行く、ジョニ・オカの黒をとっといて呉れた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月三十日（木曜）　十一時半から舞台けい古だが、とても時間通りに行く筈はない、電話で連絡とっといて、伊藤松雄のところへ「東京ちょんきな」作料として二百円持って行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
