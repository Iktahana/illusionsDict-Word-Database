        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」その人は、帽子をとりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の方の子供らが出て来るのは日曜日に限っていましたから私どもはどんな日でも初蕈や栗をたくさんとりました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中略）　この体相当以上弱ッとりますので以前のような悪友どものお交際が出来るか、どうか、このところ、もう大変な弱気です。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "耐らなくなった三次が群集の中から飛び出して、Ｔ「其処に落ちとりましたよ」　と言って件の紙入れを三四郎に渡す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は佐野の側に行って、彼の腕をとりました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は阿片を多量に喫して辛うじて睡眠をとりました。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾をとりまく事業と、企画とナナコと、妾の善良な夫のために妾はどんなことでもしてのけるわ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "天満天神に朝｜詣りした五花街の女たちが、ふたたび睡るころ、北浜｜界隈は車だまりから人力車が一掃されて、取引市場をとりまいた各商店では、踊子がつけた腰の鈴のように電話が絶えまなく鳴り渡った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この界隈の連合委員会の事業振興の決議案にもかかわらず、閑散とした取引市場をとりまいて、日一日と失業者と、彼らの飢えが生産余剰と反比例して街の広場に堆積して行った。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れて夢中で手と頭を振っとります。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもこゝは、大分以前からそういう臭いがしとりました。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺三郎は胸を一杯に張ってすまして餅を受けとりました。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷へ包んでサドルの後ろへ結えつけて戻って来たら、擦れとりましてな、これだけほどになっとった」　兄はその手つきをして見せた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「かい虫をわかしとりましたんじゃ」　――一つには峻自身の不検束な生活から、彼は一度肺を悪くしたことがあった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妄想で自らを卑屈にすることなく、戦うべき相手とこそ戦いたい、そしてその後の調和にこそ安んじたいと願う私の気持をお伝えしたくこの筆をとりました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうから隣の空室へ判事試補マイヤー君が宿をとりました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年間、その間に私は、二十も年をとりました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嫁に行けるような、ひとりまえのからだになった時、女は一ばん美しいと志賀直哉の随筆に在ったが、それを読んだとき、志賀氏もずいぶん思い切ったことを言うと冷やりとした。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうひとりまへだよ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、商売ものをもらっちゃすみませんな」その人は、帽子をとりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで山猫は、黒い繻子の服をぬいで、額の汗をぬぐいながら、一郎の手をとりました。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大王は大小とりまぜて十九本の手と、一本の太い脚とをもって居りました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」僕はたべる筈がないんだがと仔牛は思ひながら一つぶ口でとりました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日一杯畑の草もとりました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分がよくなったら一つひさしぶりで相撲をとりませうか。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、すまふをとりませう。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
