[
  {
    "uuid": "b0c8f70b-e1a0-5874-a728-a165a45c1787",
    "entry": "冬眠",
    "reading": {
      "primary": "とうみん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hibernation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうなればすべての活動は停止して冬眠の状態に陥ってしまうであろう。",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれら哲学者の植え付けた種子が長い中世の冬眠期の後に、急に復興して現代科学の若葉を出し始めたのは、もちろん一般的時代精神の発現の一つの相には相違ない。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬眠の状態にある蛙が半年の間に増大させるエントロピーの量は、覚醒期間のそれに比べて著しく少ないに相違ない。",
              "citation": {
                "source": "時の観念とエントロピーならびにプロバビリティ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなれば自身の寒がりのカメラもしばらく冬眠期に入って来年の春の若芽のもえ立つころを待つことになるであろう。",
              "citation": {
                "source": "カメラをさげて",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして、まるで冬眠でもしているように、そこに、じっとしていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓といふ窓をしめて、暗い家の中に、冬眠する蛙たちのやうに、ひつそりしてゐなければならない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、下界との一切の交通を絶ってしまった佐助は、冬眠中の蛇を掘り出して啖うと、にわかに精気がついたその勢いで、朝に猿と遊び、昼は書を読み、夕は檜の立木を相手にひとり木剣を振うている内に三年がたち、アバタの穴が髭にかくれるほどの山男になってしまった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬眠冬眠ねむれよ、やすらかに、冬のあひだ、まどろめよ、和魂の香にとろみて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬眠はつ冬住みついてゐても、はつ冬豆柿の点点に来る鳥のちひささ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "農夫は、朝早くから飛び起きて、長い間の冬眠時代を、償おうとするかのように働いていた。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬眠してるヘビの頭なんか、叩き割りたくないぜ」　と、山崎がいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　正統派文壇の新傾向　島崎藤村氏が、中央公論誌上に年四回の割合で、畢世の大作『夜明け前』を連載しはじめるという予告は、冬眠状態にあった正統派の文壇を一時｜聳目せしめた。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇や蛙其の他の動物が所謂冬眠を行ふことは周知の事実であるが、人類には本来かゝる能力は存在しない。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやうなことは無論誰でも行ひ得るといふ訳でなく、其の人の性質にも依り又練習にも依るであらうが、兎に角人間にも動物に見る如き冬眠状態の可能であることは疑ひ得ない。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間の冬眠から今さめようとしている町のけはいがその家並みのうしろにじいっとひそんでいた。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の衞生組合は長い間の冬眠状態から覺めて仕事を始めることになつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず約一〇万年の間人類は一種の精神的冬眠の状態にあったのでいかなる点でも現在の最未開な自然民俗に比べて相隔ることいくばくもない有様であった。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三は乾ききった心と衰えはてた肉体にはとても盛りきれないような青春を、今初めて感じたのだったが、そうしてぼんやり意識を失ったもののように、昨夜一夜のことを考えていると、今まで冬眠に入っていた情熱が一時に呼び覚まされて来るのを感じた――それに堪えきれない寂しさが、彼を悲痛な悶えに追いこむのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの可能性のような形で冬眠していたアカデミーの諸才能が、時を得て開花して未知の新しい実を結ぼうとしているらしいのが見られる。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり沢山売れるから本屋が沢山出したがるのであり、従って著者としては、冬眠していたアカデミーの才能を揺り動かして執筆の動員に参加したに過ぎない、と云うことも出来よう。",
              "citation": {
                "source": "友情に関係あるエッセイ",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の奥へと持って行って穴を掘って、蛇の先生、飲まず食わずでじいっ――冬眠してやがる。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い永い冬眠から、呼び覚まされた湖水の水は、しかしまだ何んとなく寝呆けていた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まこと、Ｋ――町に、あの爽やかな「夏」の象徴であるむくむくと盛り上った雲の峰が立つと、一度にワーンと蜂の巣をつついたような活気が街に溢れ、長い長い冬眠から覚めて、老も若きも、町民の面には、一｜様に、何となく「期待」が輝くのである。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月の風景　私は冬中をば冬眠中の蜘蛛の如く縮み上がって暮す。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして冬眠中に出来そうな仕事、例えばストーブの側で裸女を描くとか、あるいは公設市場で蔬菜静物を買い込んで来てテーブルへ並べてみるとか、あるいは子供の流感に喫驚して代診の如く体温計を持って走ってみたりなどするのである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでしたら、鍵盤のある刳り込みの天井には、冬眠している蝙蝠がぶら下っておりました。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうみんなあげました。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狼は、どうしたらいいか困ったというようにしばらくきょろきょろしていましたが、とうとうみんないちどに森のもっと奥の方へ逃げて行きました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうとうみんな風化かな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はお日さまがまっ正面なのですこしまぶしそうにしながら号令をだんだんかけて、とうとうみんなは昇降口から教室へはいりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
