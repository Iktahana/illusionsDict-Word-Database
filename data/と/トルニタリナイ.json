[
  {
    "uuid": "fe2ca706-718b-5029-b823-329a392fa5b1",
    "entry": "取るに足りない",
    "reading": {
      "primary": "とるにたりない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "形容詞"
      ],
