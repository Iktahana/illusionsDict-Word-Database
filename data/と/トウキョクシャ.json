[
  {
    "uuid": "2668fe71-143e-5f56-9ae0-d1d95be0f5d6",
    "entry": "当局者",
    "reading": {
      "primary": "とうきょくしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
