[
  {
    "uuid": "cb29ed61-b513-534b-96e3-49b15a1cc9b0",
    "entry": "都雅",
    "reading": {
      "primary": "とが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
