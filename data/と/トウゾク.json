[
  {
    "uuid": "da8f2f2d-76a0-540e-b203-2bbed1f2a39a",
    "entry": "盗賊",
    "reading": {
      "primary": "とうぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
