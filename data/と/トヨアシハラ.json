    "definitions": [
      {
        "index": 1,
        "gloss": "plains lush with reeds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
