        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただし上帝は随分人思いの親切者で天に引き上げた後山羊を降して告げしめたは、これから死というもの来て汝らを取り殺すが汝ら全く亡くなるでなく天に来りてわれとともに住むのだと。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその色魔坊主を取り殺すと呼んでいる。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは死んで取り殺すぞ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これというのも、みんな、あの広海屋の畜生のなせるわざ――あいつを、取り殺す！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く「この後女房を持てば七人まではきっと取り殺すからそう思え」。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "よってこの方をおかせば、必ず七人取り殺すゆえ七殺ともいう。",
              "citation": {
                "source": "迷信解",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり取り殺すことゝ存申候。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
