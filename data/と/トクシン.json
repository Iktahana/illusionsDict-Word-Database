[
  {
    "uuid": "2bdf2861-ec54-55d0-9c6b-4b4d42ff7ca2",
    "entry": "得心",
    "reading": {
      "primary": "とくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
