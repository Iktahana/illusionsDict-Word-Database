        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翁も例によって御供をして荒戸の埠頭から新造の黒田藩軍艦｜環瀛丸に乗り、十三日東京着。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもその支部長というのも、その地方ではかなり人望のある慈善家だそうであるが、その支部長の推薦を受けた、資格のある志望者は、例の三の字のマークを貰って、それを手荷物へ着け、東京着三時の三輛目へ乗って、上京しなければならないのであった。",
              "citation": {
                "source": "三の字旅行会",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "端書は、今日二時東京着、たゞちに表面へ投宿、取敢へず御報、明日午前｜会ひたし、と薄墨の走り書の簡単極るもので、表に裏神保町の宿屋の名と平岡常次郎といふ差出人の姓名が、表と同じ乱暴さ加減で書いてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ、廣太郎は、東京驛から、素直にふじ子のもとへ歸るのが億劫で、靜岡から、わざわざ八重子へ東京着の時間を電報で打つたりしておく勝手さもあつた。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十五日モスクワを立ち、十一月〔八〕日東京着。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "○九日午時過ぐる頃、東京着、直ちに鍛冶橋監獄に入る。",
              "citation": {
                "source": "鉄窓の歌",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "端書は、今日二時東京着、ただちに表面へ投宿、取敢えず御報、明日午前会いたし、と薄墨の走り書の簡単極るもので、表に裏｜神保町の宿屋の名と平岡常次郎という差出人の姓名が、表と同じ乱暴さ加減で書いてある。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度小林Ｙよりの電報をもって、小石川に行ったところの由、あしたの朝七時半東京着。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時四十五分東京着。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一時間余待って、夜中の〇時二分の特急ふじで十五日、きょうの午後三時二十五分東京着。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩本の小母さんが二十四日に来られ、私たちは二十五日の夜こちらを立ち、広島で「桜」にのりかえ（午後一時何分か）二十六日の午後四時四十分東京着です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京着六時四十何分。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時半寝台を出て、吉岡社長と話してるうち東京着。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時東京着、意外に出迎へ大ぜい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一時四十二分東京着、専務支配人樋口以下揃ってお迎へには恐入った、ルパンでのみ、スコットの洋食三品食ひ、くた／＼にねむくなり、帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜から奥村が乗り、実演大会の打合せしながら、東京着。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時半東京着、防空演習で、昼でもストップがあるといふ、高槻の迎へで、無事帰宅。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時二十何分、東京着。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰路を新田義貞の旧山河に向け、桐生、太田などを一巡して、夜おそく東京着。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
