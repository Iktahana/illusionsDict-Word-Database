[
  {
    "uuid": "4c307133-8ce1-5594-bd95-b589d5bf4cf3",
    "entry": "得になる",
    "reading": {
      "primary": "とくになる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
