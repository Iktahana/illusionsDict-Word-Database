    "definitions": [
      {
        "index": 1,
        "gloss": "to spring at",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（青年の血相が変り鬼畜の形になって蓮月に飛びかかる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、大きな音がして腹が裂けるとともに、その中から大きな蛸が出て来たが、それが猛烈な勢いで達磨の新公に飛びかかるなり、真黒い毒どくしい墨をぱっと吐いた。",
              "citation": {
                "source": "妖蛸",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛魔王急に大豹と化して虎を撃たんと飛びかかる。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして餌をねらう猛獣のような姿勢をして抜き足で出て来て、いよいよ飛びかかる前には腰を左右に振り立てるのである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芝を刈っているといつのまにか忍んで来て不意に鋏のさきに飛びかかるのが危険でしようがなかった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその脚の緒が厳重に縛られているので、かれは思うがままに飛びかかることが出来ないらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鷹のゆくえ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その隙をみて、二人は不意に飛びかかると、彼はもろくも其の場に捻じ伏せられた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前項に引いた、英国の『ジョー・ミラー滑稽集』にいわく、行軍中の軍曹に犬が大口開いて飛びかかると、やにわに槍先を喉に突き通して殺した。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の浪人は腰刀をぬいて飛びかかる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは新仏の墓をあらして、死骸をほり出して喰っていたが、それがだんだんに増長して、此頃は往来の人間にまで飛びかかるようになって来たので、村中は大騒ぎで、このあいだから二度も狼狩りを遣ってみたが、どうしても見付からない。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいよ　いえ、わたくしが一人に飛びかかると、ほかの二人はおどろいて逃げてしまいました。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして間もなく郵便屋に抱き起こされて胸の傷口へハンカチを押当られたままもうガックリなっている女を見ると、洋服の男は飛びかかるようにして、「あ、そめ子！",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　そこはともすれば潮のしぶきが飛びかかるほど、海に近かった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらから飛びかかるとなく、二人はつかみ合った。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当の相手がそこにのめのめとやにさがっているんだから、すぐにも飛びかかるだろうと思われたのが、意外にも右門はくるりひざをまくると、伝法に長火ばちのこちらへおおあぐらをかいて、同じく伝法に、不意と妙な啖呵をきりだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "右門よりもお駒があっとおどろいて、われ知らず声をたてながら飛びかかると、うろたえ青ざめながら、あわてて血の足跡をもみ消しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "やまがら美人影絵",
                "note": "青空文庫"
              }
            },
            {
              "text": "切出小刀を掴んで切腹しかけると、母が火のやうに怒って飛びかかる。",
              "citation": {
                "source": "焔",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その方向が容疑者の真正面に当りましたので、恰も一匹の白蛇が、彼に向って飛びかかるかのように見えたのです。",
              "citation": {
                "source": "三つの痣",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ときには、恐ろしく手の早い奴がいて、隙だと見たら何の躊躇もなく一撃のもとに飛びかかる。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人が通れば、俊夫君が合図することになっており、合図があれば私が飛びかかることになっております。",
              "citation": {
                "source": "現場の写真",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがいなかったらあなたがたは互いに飛びかかるようになりはしないかと思うと恐ろしい。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見るといきなり、マリーナ・イワーノヴナが飛びかかるように、「いかがです、貴下の五十三人目の恋人の御機嫌は」と云って笑い出した。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、どちらも不意に一間以内のところで出會ふと、おやぢもびツくりするのだらう、直ぐ後ろ足で立ちあがり、人に飛びかかる。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に飛びかかる蟒の胴を颯と斜めに切り付ける刹那、太刀は三段にバラバラと折れた。",
              "citation": {
                "source": "高島異誌",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千鶴子に闇中何者が飛びかかるか知れない危険を思うと、矢代も彼女の手を曳かずに歩いた自分の無謀を今さら恥かしく、もどかしく歎かれて来るのだった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その背後で痼疾に震えている宿禰の上へ飛びかかると、彼を真菰の上へ押しつけた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長羅は剣の尖で鹿の角を跳ねのけると、卑弥呼を見詰めたまま、飛びかかる虎のように小腰を蹲めて忍び寄った。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……飛びかかる……。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この蛙はとびかかるのが得意でありました。",
              "citation": {
                "source": "二ひきの蛙",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めの三行目から作者は自分の言葉で服装について一部のパリ人の抱いている常識を非難しながら、その男がやっととある玄関の前で馬車を下りると、もう直ぐそこでとびかかるようにパリの門番の本性について説明する。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
