        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "再び遠くから角笛の音、犬の遠吠えが聞えて来る。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い遠い所で遠吠えをする犬があった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ながい遠吠えやら、きゃんきゃんというせわしない悲鳴やら、苦痛に堪えかねたような大げさな唸り声やら、様様の鳴き声をまぜて騒ぎたてた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、夢の中で遠吠えする犬の聲が、それ自ら狼の鳴聲と同じであるといふことは、疑ひもなく犬の夢が、祖先の狼であつた時の、古い記憶を表象してゐるのである。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、犬が月におびえて遠吠えするくらいのものである。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下寺町から生国魂神社への坂道は人通りもなく、登って行く高下駄の音、犬の遠吠え……そんな夜更けの町の寂しさに、ふと郷愁を感じ、兄よ、わりゃ死んだナ。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以外に奈良原翁の人格を云為するものは皆、痩犬の遠吠えに過ぎなかった事実を見ても、容易に想像出来るであろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのように口やかましゅう遠吠えするものではない。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "サムといっしょに、ワラも「アウー」と狼の遠吠えをやる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さう云はれて私は振り返つて見ると、酒倉から母家へつゞく灌木の繁みを縫つて、右方左方に提灯が飛び交ひ犬の遠吠えの声に入れまぢつて、たゞならぬ人々の仰天の叫びが吹雪となつて飛び散つてゐた。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「狼の遠吠えぐらゐは聞えることはあるけれど、人家の近くへやつて来る気遣ひはなし、食ひ物だつて別段のこともなし、湯治へ行く位ゐならああいふところででもなければ落着けませんな。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく獅子の遠吠えが聞えたといふジヤングルに天幕の夢を結んでも、大鯨を獲り逃して残恨の胸を叩きながら酒場に酔ひ潰れても、おゝ、あれらの故山の、あれらの山々がそうしてゐる間にも刻々と切り崩づされるに随つて金貨を積んだ橇の音が次第々々に近づいて来てゐるのだといふ素晴しい夢に誘はれてゐたのである。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ここの漣は、圧制のもとに唸り、遠吠え、あきらめ、沈み、悵怏として悲しむ漣である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬の遠吠えがおそくまでも聞えてゐた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢靜まつた夜などはその遠吠えの音がきこえもする海の上を渡り、さへぎるもののない平地を走つてこの高臺の一軒屋にぢかに吹きつける二月の寒風である。",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何かけだものの遠吠えにも似たものであつた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何かけだものの遠吠えにも似たものであった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、一秒ほどおくれて、その犬がきっと遠吠えをはじめた。",
              "citation": {
                "source": "犬三態",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイレンの音よりちょっと高いだけで、終るのも、終りに近づいて音程の下ってゆく調子も、そっくりそのままに連れて、朝でも、夜でもサイレンの鳴る毎に吠え、人間はサイレンばかりをきくのとは又ちがった感情でその遠吠えを聴いているのであった。",
              "citation": {
                "source": "犬三態",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吠える声を聞くといつも遠吠えだ。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人の魂を動物の本能が感じて恐怖するという遠吠えだ。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワオーと、鼻にぬかして遠吠えする。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と訴えるように、人間じみた斑の顔を動かして吠える――遠吠えの短いのをする。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、斑犬の遠吠えを気にするのは外でもない。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此方で奇妙な不幸な境遇に置かれた犬が、冬の青空に向って遠吠えると、きっと暫くして、あの小窓の奥の女の人も吠え出す。",
              "citation": {
                "source": "吠える",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはちゃんとおぼえていたのです。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "川春の宇三郎は死罪、富蔵は吟味中に牢死、出前持ちふたりは追放だとおぼえています。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはたしか文化四年四月の申渡しとおぼえていますが、町奉行所の申渡書では品川｜宿旅籠屋安右衛門｜抱とありますから、品川の貸座敷の娼妓ですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、余計な前置きが長くなりましたが、これからお話し申そうとするのは、その日野家息女一件から五十幾年の後のことで、文久元年の九月とおぼえています」　八丁堀同心岡崎長四郎からの迎えをうけて、半七はすぐにその屋敷へ出かけて行った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "お放しなすって、え、どうしょうねえ」　とおぼえず、声を放ちたり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
