    },
    "definitions": [
      {
        "index": 1,
        "gloss": "special envoy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "＊　欽明天皇の十三年（皇紀一二一二西暦　五五二）百済の聖明王が、特使を我国に遣はして、仏像や経論を献じて来た。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "座長ハル博士「途中ですが、只今特使が私のところへ見えました。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは外ならぬソ連のハバノフ特使であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ときにちょっとここにお邪魔をしていいですか」　と、ハバノフ特使は傍の籐椅子を指さした。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハバノフ特使は籐椅子をリット少将の方へひきよせると、「ねえ、リット少将。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "講和特使として巴里に出かける西園寺侯に勧める。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「特使がつかわされたのだから早く行くがよい」　と源氏は許した。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気といっても何という名のある病をしているのでもないわけであるが、やましく思う点があるのであろうと、心苦しく思召して、特使をさえもおやりになって招こうとあそばされた。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "花ごとに仕える特使が派遣せられ、兎の毛で作ったやわらかい刷毛でその葉を洗うのであった。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "元軍の方でも東南を平定するに、蒲氏の助力を得るのが、第一の要件であることは夙に承知して、未だ行在の陷落せざる以前に、至元十三年の二月に、元の伯顏は特使を派して、蒲氏兄弟に投降を勸誘して居る。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "このヤヨイ号には、ある特別な用事をおびて、ヨーロッパへわたる特使団の一行がのっていた。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、機内は、寒さのため、のりこんでいる特使団の一行はもちろん、操縦士や機関士などの乗員ですら、非常なくるしさとたたかっているのであった。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "某大国の特使｜閣下を、金博士の許へ案内したのは誰あろう、かくいうわたくしであった。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、博士に会いたくて焦げつきそうな焦燥を感じていた某大国の特使閣下も、この噂に突き当られ、落胆のあまり今にもぶったおれそうな蒼い顔色でもって、上海の大路小路をうろうろしていたのである。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし特使閣下は、幸運だった。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあやあそこに渡らせられるは……」　と、わたくしがものをいいかけるうちにも、かの特使閣下はわたくしの姿を認め、手に持っていたステッキもウォッカの壜も、鋪道の上に華々しく放り出して、ものも得いわず、いきなりわたくしの小さい身体に抱きついたものである。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金博士が生きているということを証明してくれればね」　と、特使閣下は、腕の中のわたくしを、ぎゅっぎゅっと締めつけながら、声をひきつらせていったことである。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ君は、金を受取らなきゃ、喋りゃすまいから……」　十八万ルーブルは、相当かさばって、ポケットに入りにくいものだと感じながら、わたくしはぼつぼつネルスキー特使閣下の質問に答えていた。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あーら嬉しや、これでもう大願成就だ」　という次第で、この特使閣下を、わたくしが案内して、博士のところへ連れていってやったのである。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この特使閣下は、自国宰相の面影に生きうつしで、影武者に最適なりとの評判高き御仁で、そのままの御面相でうろつかれては、宰相と間違えられていつなんどき面倒なことが発生するやも知れず、かくてはわたくしが傍杖をくうおそれがあるので迷惑だから、道中だけを特に変装して貰うことにした。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで特使は、あの髭を反対の方向へカイゼル髭にぴーんとひねり上げたものである。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでないと、折角わしが特使に立った甲斐がないというものだ」　金博士は、後向きに椅子に腰をかけて、西瓜の種をポリポリ齧っている。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、わしが好んで特使に立ち、好んで味噌をつけるのだといわれるでしょうが、わしは自分の名声のために特使に立ったのではない。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、ネルスキー特使は、金博士の言葉をきいて椅子からすべり落ちた。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この太っちょの特使閣下が安定を欠いて椅子から滑り落ちるとは……」　金博士は、人のわるいことをいう。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金博士よ、乞う自愛せられよ」　有頂天になったネルスキー特使は、まことに現金なごまをする。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネルスキー特使が泣き言をならべていったように、今この土地は吹雪と厳氷とに閉じこめられている。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "宰相公室においては、例のネルスキー特使が、いかにも宰相らしく装って、大きな椅子に腰をかけていた。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから十三月というは、欧洲でいう一九四二年一月のことと思えばよろしいのである）――その十三月八日において、彼ルーズベルトは、彼の特使を、かの金博士に面会さすべく遂に成功したのであった。",
              "citation": {
                "source": "不沈軍艦の見本",
                "author": "――金博士シリーズ・10――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとくして、意識現象としての「いき」の客観的表現の芸術形式は、平面的な模様および立体的な建築において空間的発表をなし、無形的な音楽において時間的発表をなしているが、その発表はいずれの場合においても、一方に二元性の措定と、他方にその措定の仕方に伴う一定の性格とを示している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
