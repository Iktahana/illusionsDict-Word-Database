[
  {
    "uuid": "35208aee-6fd5-5714-bfb5-f6ebb06001af",
    "entry": "特使",
    "reading": {
      "primary": "とくし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
