[
  {
    "uuid": "d2cf553f-f2c6-51ea-aaaa-e1a05d5151c2",
    "entry": "遠のく",
    "reading": {
      "primary": "とおのく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
