    "definitions": [
      {
        "index": 1,
        "gloss": "sudden enlightenment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
