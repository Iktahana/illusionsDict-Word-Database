        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "トコトコと足音が後頭に響くと、先刻父と話してゐた弟が来て、トランプをしようと言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "言われるままに、僕は先へ立ってトコトコと窮屈な階段をのぼっていった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで幸い一つの階段を見出すと、それに足を掛け、トコトコと二階へ上っていった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度午後十一時半を打ったときに交番の前を、工夫体の一人の男がトコトコと来かかった。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコ、トコトコと聞こえているのは、岩から流れ落ちる清水であったが、洞窟の隅に石を畳んで、井戸のように湛えられてある。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコトコトコと滴たる音。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコトコトコ、トコトコトコトコ……岩壁から滴たる水の音。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコトコトコと水の音！",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……薬をお飲みなさいまし」　器物へ水薬でも注ぐらしい、トコトコという音がした。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の後からは、姉弟らしい十七八の娘さんと、十四五の少年が驢馬に乘つてトコトコ登つて來てゐました。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から來る驢馬の鈴がカラカラと鳴ると、私の驢馬も元氣づいて、トコトコ山を登つてくれる。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……コトコトコトコトコトコトと扉をたたく音…………。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "コツコツコツ……コトコトコトコト……コツンコツンコツンコツン……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコトコトコと泉の音が、微妙な音楽を奏している。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
