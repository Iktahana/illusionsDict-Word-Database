    "definitions": [
      {
        "index": 1,
        "gloss": "no sooner than",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "うるさい時代が過ぎて、二三日、ほっとしたと思ったら、また、うるさい時代がやって来ました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれの凄惨な一声で、この団欒が滅茶々々になるのだ、と思ったら喉まで出かかった「助けて！",
              "citation": {
                "source": "一つの約束",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "権威ある批評をしようと思ったら、まず、ご自分でも或る程度まで製作の苦労をなめてみる事ですね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "正確な時日に予報出来ないまでも、もうそろそろ危ないと思ったら、もう少し前にそう云ってくれてもいいではないか、今まで黙っていて、災害のあった後に急にそんなことを云うのはひどい。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとなでつけるのかと思ったら自分で新たに巻き直すと見える。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "豚のびっくりするような大きいチョコレート菓子可愛ゆい麦粉菓子のヒヨコ、馬鈴薯が本物かと思ったらやっぱり何かを練ってつくったお菓子なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんだうの花のコップが、湧くやうに、雨のやうに、眼の前を通り、三角標の列は、けむるやうに燃えるやうに、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もうそこに鳥捕りの形はなくなって、却って、「あゝせいせいした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう渦に入ったと思ひながらしっかりこの人たちをだいてそれからぼうっとしたと思ったらもうこゝへ来てゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったらあの赤帽の信号手がまた青い旗をふって叫んでゐたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒川が急に逆様に流れ出したと思ったら、コースがいつの間にか百八十度廻転して帰り路になっていた。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイレンが鳴ると思ったら眼が覚めた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝た部屋が真暗で、電燈をつけようと思ったら電球が外ずしてあったそうで、そのときに友人は天井から垂れ下がったコードを目撃したであろうし、またソケットに露出した電極の電圧の危険を無意識に意識したのではないかと思われる。",
              "citation": {
                "source": "夢判断",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が何かたいそう熱心に読んでいると思ったら大抵自分の書いたものだと云って家族達はよく笑った。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か書類のようなものを鷲握みにして読みはじめたと思ったらすぐ終った。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならその鎖国を実行しようと思ったら、出来るでしょうか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕はなるべく詳しく話すよ、おもしろくないと思ったら、遠慮なく注意してくれたまえ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　東京市電気局の争議で電車が一時は全部止まるかと思ったら、臨時従業員の手でどうにか運転を続けていた。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が読書している隣りの室で、八重子と宗二とがひそひそ話し合っては、宗二が何か半紙へ書いていると思ったら、それは八重子作の御伽噺を兄が筆記しているのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れるかと思ったら存外枯れもしないで、今年の春の日光を受けるとまた正直に若芽を吹き出して来た。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリンの美術館などの入口の脇の壁面に数寸角の金属板が蝋燭立かなんかのように飛出しているのを何かと思ったら、入場者が吸いさしのシガーを乗っけておく棚であった。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「めった、今度は去年あたりよりゃあいつらの景気がいいと思ったら、独逸が新しい武器を提供しとるそうじゃありませんか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただお父さんが可哀そうだったの、始めて済南へ連れて来る子供とそれから花嫁さんにまでこんなことをさせなけりゃならんかと思ったら、お父さんが可哀そうで、涙がこぼれたわ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それゃ、云うまでもないこっちゃが、支那人は金にさえなると思ったら、どんなありそうなことでもねつ造して持って来る奴なんだから。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人と思ったらドイツとのあひの子かい。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次々うつるひるのたくさんの青い山々の姿や、きらきら光るもやの奥を誰かが高く歌を歌いながら通ったと思ったら富沢はまた弱く呼びさまされた。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もう次から次から、たくさんのきいろな底をもったりんどうの花のコップが、湧くように、雨のように、眼の前を通り、三角標の列は、けむるように燃えるように、いよいよ光って立ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思ったら、もうそこに鳥捕りの形はなくなって、却って、「ああせいせいした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき俄かに大きな音がして私たちは水に落ちもう渦に入ったと思いながらしっかりこの人たちをだいてそれからぼうっとしたと思ったらもうここへ来ていたのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた親睦会というから大方演じゅつ会のような種のもんかしらとおもったら、なアにやっぱり品の好い寄席だネ。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
