  {
    "uuid": "1892d24b-2e57-5104-83dd-7e96150bb6da",
    "entry": "糖酸",
    "reading": {
      "primary": "とうさん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
