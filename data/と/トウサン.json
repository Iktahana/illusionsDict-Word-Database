    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sugar acid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「おとうさん、大きなどんぐり、こいも／＼／＼／＼／＼みんな大きなどんぐり」と小さい泥だらけの指先で帽子の中に累々としたどんぐりの頭を一つ一つ突っつく。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここのところをわが青海流では、死屍水かかずしてよく浮くといって、平泳ぎのこころだ」「それは、よくおとうさんがおっしゃる、あの渾沌未分の兄弟か何かなの」　小初は食後の小楊枝を使いながら父親を弥次った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも有りがとうさん。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の一番目の嬢さんがまだ子供の時分この半身像にすっかりラヴしてしまって、おとうさんの椅子を踏み台にしては石像に接吻したそうです。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その九歳の自分が「おとうさんはげじげじだよ、げじげじだよ」と言って出入りの人々をつかまえては得意らしく宣伝したものだそうである。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさん、ウム――と言っていると、あの蚊がみんなおりて寄ってくるのね」という。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして一等いい子になってもうけているのは世間の「父」の代表者であるところのおとうさんの村長殿である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもふたりのかみをかったのは、おとうさんか、おかあさんの手ににぎられたバリカンでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金平ちゃんのおとうさんのねむそうな声でした。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども虔十のおっかさんもおとうさんも仲々そんなことを虔十に云ひつけようとはしませんでした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかたのおとうさんはこんど会社のご用で上の野原の入り口へおいでになっていられるのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、あの人は高田さんのとうさんですか。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わき水のところで三郎はやっぱりだまって、きっと口を結んだままみんなに別れて、じぶんだけおとうさんの小屋のほうへ帰って行きました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええ、高田さんはきのうおとうさんといっしょにもうほかへ行きました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、おとうさんが会社から電報で呼ばれたのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんはもいちどちょっとこっちへ戻られるそうですが、高田さんはやっぱり向こうの学校にはいるのだそうです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども虔十のおっかさんもおとうさんも仲々そんなことを虔十に云いつけようとはしませんでした。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわかるとおばあさま一人ではだめだと思ったから、ぼくはすぐ部屋を飛び出して、おとうさんとおかあさんとが寝ている離れの所へ行って、「おとうさん……おかあさん……」　と思いきり大きな声を出した。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時おかあさんははじめてそこにぼくのいるのに気がついたように、うつ向いてぼくの耳の所に口をつけて、「早く早くおとうさんをお起こしして……それからお隣に行って、……お隣のおじさんを起こすんです、火事ですって……いいかい、早くさ」　そんなことをおかあさんはいったようだった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにおとうさんも走って来た。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはおとうさんにはなんにもいわないで、すぐ上がり口に行った。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさまも、おとうさんも、おかあさんも、妹や弟たちもどうしているだろうと思うと、とてもその先までどなって歩く気にはなれないで、いきなり来た道を夢中で走りだした。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋は焼けたけれども離れだけは残って、おとうさんもおかあさんもみんなけがはなかったから……そのうちに連れて帰ってあげるよ。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "離れに行ったら、これがおばあさまか、これがおとうさんか、おかあさんかとおどろくほどにみんな変わっていた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんは二、三日の間、毎日警察に呼び出されて、しじゅう腹をたてていた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくがおこしに行く前に、ポチは離れに来て雨戸をがりがり引っかきながら、悲しそうにほえたので、おとうさんもおかあさんも目をさましていたのだとおかあさんもいった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留地に住んでいるおとうさんの友だちの西洋人がくれた犬で、耳の長い、尾のふさふさした大きな犬。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにおとうさんもおかあさんも来た。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはおとうさんに手伝って、バケツで水を運んで来て、きれいな白いきれで静かにどろや血をあらい落としてやった。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
