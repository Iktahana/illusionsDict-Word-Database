[
  {
    "uuid": "b6da91c3-c0b1-59e2-bb6b-0f554be030d7",
    "entry": "豆腐",
    "reading": {
      "primary": "とうふ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
