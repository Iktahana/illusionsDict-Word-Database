      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tofu",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "街道を折れて、少し下り坂になる道をスタコラと歩いてゆくと、街道でしてゐた豆腐屋の喇叭の音は急に聞えなくなり、道の傍の、森の葉擦の音に私は淋しくなるのであつた。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、豆腐屋の硝子戸に寫る私の姿も、なんと、維新の志士のやうに見えた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな太平楽を言ふといで、今にＭさんは偉いもの、あんたは豆腐売になる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　祖母が私を噛むやうに何時もの豆腐売と湯屋の亭主を並べた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐売りのラッパが聞こえる、今夜は豆腐が要るのだからラッパが近づくのを待つて呼びとめる――それならば文句はない。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐売りのラッパに酔ふとしてまことに随一だが、それを呼びとめるとしていとも間抜野郎である。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷区役所がコンクリートの豆腐に変った。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日　豆腐屋が来た。",
              "citation": {
                "source": "窮理日記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お豆腐屋の笛が方々で聞えてゐたわ、あの電信柱が、夕空にクッキリしてて、――僕、つてあの人あたしの方を振向くのよ、昨日三十貫くらゐある石をコジ起しちやつた、つてのよ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでは、豆腐ん中に頭を突っ込んだ鰌見たいに、暴れられる丈け暴れさせとくんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のレジオン・ド・ヌウルはフランス政府が彼の東洋流の栄養法が人口の味覚を満足さした功労によって、エリゼェの大統領官邸で贈与された（彼は巴里で生物学を研究するかたわら党費を稼ぐために豆腐を製造販売していたので。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一ちょうの豆腐を十五銭に勘定した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆腐屋が変わったのか笛が変わったのかどちらだかわからない。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　与平という親仁は、涅槃に入ったような形で、胴の間に寝ながら、仏造った額を上げて、汗だらけだけれども目の涼しい、息子が地蔵眉の、愛くるしい、若い顔を見て、嬉しそうに頷いて、「晩にゃ又柳屋の豆腐にしてくんねえよ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うて筋違、角から二軒目に小さな柳の樹が一本、その低い枝のしなやかに垂れた葉隠れに、一｜間口二枚の腰障子があって、一枚には仮名、一枚には真名で豆腐と書いてある。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩行にも内端で、俯向き勝で、豆腐屋も、八百屋も黙って通る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "与吉は父親に命ぜられて、心に留めて出たから、岸に上ると、思うともなしに豆腐屋に目を注いだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "土間は一面の日あたりで、盤台、桶、布巾など、ありったけのもの皆濡れたのに、薄く陽炎のようなのが立籠めて、豆腐がどんよりとして沈んだ、新木の大桶の水の色は、薄ら蒼く、柳の影が映って居る。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「余計に悪くなって堪るもんか、この節あ心持が快方だっていうけれど、え、魚気を食わねえじゃあ、身体が弱るっていうのに、父爺はね、腥いものにゃ箸もつけねえで、豆腐でなくっちゃあならねえッていうんだ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "え、おかみさん、骨のある豆腐は出来まいか。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　与吉の真面目なのに釣込まれて、笑うことの出来なかったお品は、到頭骨のある豆腐の注文を笑わずに聞き済ました、そして真顔で尋ねた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が着かないようにして食べさせりゃ、胸を悪くすることもなかろうからなあ、いまの豆腐の何よ。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかしお好み別誂で以て、鳥のブツ切と、玉葱と、凍豆腐を大皿に積んだのを鉄鍋でね、湯を沸立たせて、砂糖と醤油をかき交ぜて、私が一寸お塩梅をして」「おや、気味の悪い。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが毎朝通る道筋の角に柳屋という豆腐屋がある、其処の近所に何時も何時も大きな犬が寐転んで居る。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろの新聞には、亭主が豆腐を一人で食ってしまって自分に食わせないという理由で自殺した女房のことが伝えられた。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌が豆腐屋のような角笛を吹いていたように思うが、それはガタ馬車の記憶が混同しているのかもしれない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉子豆腐の朱わんのふたの裏に、すり生姜がひとつまみくっつけてあったことを、どういうわけか覚えている。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食時に桂浜へ上がって、豆腐を二三丁買って来て醤油をかけてむしゃむしゃ食った。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まま母のままにしたさに粥殺し……とうふて近きは男女なりける……ふうむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「雨のびしよ／＼降る時には、油舐坊主だの、とうふ買小僧だのつて……あるだらう。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
