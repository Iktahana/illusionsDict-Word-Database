[
  {
    "uuid": "52571b4b-45ef-5158-a81c-be4f46aa4690",
    "entry": "得々",
    "reading": {
      "primary": "とくとく",
      "alternatives": [
        "トクトク"
      ],
      "is_heteronym": false
    },
    "grammar": {
