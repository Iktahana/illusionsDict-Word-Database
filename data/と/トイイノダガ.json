        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうだといいのだがな、と私はひそかに思つてゐます。",
              "citation": {
                "source": "あとがき",
                "author": "――『おぢいさんのランプ』後書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて月明かりでもあるといいのだが、あいにくに今夜は闇だ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気に入ってくれるといいのだが、いまのところ、なんともいえない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "桔梗の末花を徳利に※す、これが山桔梗だといいのだが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君の方から直接僕の親爺の方へ申込んでくれるといいのだが」「そうかしら」　そして三人ともほっとしたのであった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山者がいてくれるといいのだが、あるいは山番でもいい。",
              "citation": {
                "source": "氷河期の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまく欠員のある学校がみつかるといいのだが……」「はつきりした左傾の証拠はあるかね？",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは干ゼンマイにするといいのだが干し方がむつかしいし、山奥のでないと干すと糸のようにほそくなる。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでにどの地点かわかるといいのだが――」「はあ、それもやってみました」「やった？",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちっとも風がないな、一雨くるといいのだが、毎日降りそうになるけれど降らない。",
              "citation": {
                "source": "僕はこれからだ",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕んちにも、あんな赤ちゃんあるといいのだがな。",
              "citation": {
                "source": "ボールの行方",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「万年筆だといいのだがなあ……。",
              "citation": {
                "source": "青い石とメダル",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな用件で神月に逢うのかと、聞いてくれるようだといいのだが、お行儀のいいひとたちなので、中村のように立入った質問をしないので困る。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしがおまえだけに目が見えるといいのだがなあ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの所をこうしたのが、あれのいちばんの仕事であったというように、仔細に書いてくれる文学史があるといいのだが、日本にはそういう概観を扱った文学史がない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんの三味線があるといいのだが、質にはいっていたっけね。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "力を貸してあげられるといいのだが。",
              "citation": {
                "source": "衣裳戸棚",
                "author": "DER KLEIDERSCHRANK",
                "note": "青空文庫"
              }
            },
            {
              "text": "席を取って安心させてあげられるといいのだが。",
              "citation": {
                "source": "衣裳戸棚",
                "author": "DER KLEIDERSCHRANK",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも君の腹の中がこんなに見え透かないといいのだがなあ。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこにいても、私のこの手紙があなたがたの目に触れるといいのだが。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
