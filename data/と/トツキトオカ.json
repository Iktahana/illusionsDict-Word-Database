    "definitions": [
      {
        "index": 1,
        "gloss": "babies born on October 10, supposedly conceived on New Year's Day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、起稿後半月を過した十月十日頃に、私はともかくも三十｜餘枚の原稿を、書き上げてほつと一息ついた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に取巻の人々は十月十日を期して、小倉是阿弥の家に集まって仏事を営み、それから駒込願行寺の香以が墓に詣でた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　十月十日の水曜日の午前九時頃のこと。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年十月十日）　　　　　　　＊　友人の科学者で陶器を作るのを道楽にしている男がある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年十月十日）　　　　　　　＊　辻待ちの円タク、たとえば曙町まで五十銭で行かないかというと、返事をしないでいきなりそっぽを向いてしまうのがある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年十月十日）　　　　　　　＊　隣に栗の樹が一本ある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本日のメニュー　十月十日朝食　大根の味噌汁　　海苔　　タマゴ　　シャケ　納豆　　ご飯」　しけたメシだ、山奥の旅館じゃねえぞ、とヤジ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日終日一人楽清閑。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日の月がさえ／″＼とうつくしかつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　　　其中漫筆┌自己の生活認識└社会の現実認識　　　　　　　　　　┌知識　　　　　　　　　　└意識┌生活印象└時代感覚　十月十日　曇、やつぱり雨だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日　好い秋日和。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日　晴――曇――時雨。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本政府による検閲制度の廃止（九月二十四日）、言論に関する戦時取締法規の廃止（九月二十九日）、検閲取締機関の全廃（十月四日）、出版会の解散（十月十日）、日本出版文化協会による用紙統制の撤廃（十月二十七日）、情報局の廃止（十二月三十一日）等が実施された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして新しく民間団体として出版業者の日本出版協会が発足した（十月十日）。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日　甘粕事件　公判開始　十月二十日　白菊の盛、蠅多き秋○国男折角来たのに「居たって何にもなりゃしない」　翌年　仕事をし始める。",
              "citation": {
                "source": "「伸子」創作メモ（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日の朝、大樹に初霜が濃く置いてゐた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから二里ばかり來ると、人家や大豆小豆の耕地が多くなり、十月十日の午後、いよ／＼帶廣に着することになつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日　曇、福島町行乞、行程四里、志布志町、鹿児島屋（四〇・上）八時過ぎてから中町行乞二時間、それから今町行乞三時間、もう二時近くなつたので志布志へ急ぐ、三里を二時間あまりで歩いた、それは外でもない、局留の郵便物を受取るためである、友はなつかしい、友のたよりはなつかしい。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "追加二句・三日月のどこやら子供の声がある・夜なべの音の月かげうつる　十月十日今朝も朝寝だつた、といつても五時過ぎだつたが。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車は今のところ、大竹・安芸中野間を折返し運転しているらしく、全部の開通見込は不明だが、八本松・安芸中野間の開通見込が十月十日となっているので、これだけでも半月は汽車が通じないことになる。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車は今のところ、大竹・安芸中野間を折返し運転してゐるらしく、全部の開通見込は不明だが、八本松・安芸中野間の開通見込が十月十日となつてゐるので、これだけでも半月は汽車が通じないことになる。",
              "citation": {
                "source": "廃墟から",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日に浜松師範学校が静岡師範学校浜松支部と改称せられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月十日に旅から帰って見ると、森｜枳園の五日に寄せた書が机上にあった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "父四郎左衛門は明治三年十月十日に斬られたと云ふことである。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度十月十日の夜です。",
              "citation": {
                "source": "悪魔の弟子",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九六九（昭和四十四）年十月十日、ベ平連、全国全共闘会議、反戦青年委員会など新左翼系の四〇〇団体は、安保粉砕、佐藤訪米阻止などをテーマに、全国五三か所で統一行動を行った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タケシとともに十月十日のデモの隊列に加わったうたの会のメンバーは、その日の体験を取り込んで『しかし』の創刊号にこう記している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十月十日）　　　　　Butler の説　サムエル・バトラアの説に云ふ。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "女史の記録を読むと、明治廿四年――（一葉廿歳の時）十月十日に兄の家は財産差押えになるという通知をうけたくだりに、金三円｜斗りもあれば破産の不幸にも至るまいという書状から推しても、杖とも頼む男兄弟の、たよりにならなかったことがしれ、かえって妹たちの方が苦しいなかからその急を救った。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは私が去る明治四十年十月十日、始皇の驪山の陵を訪うた當時の紀行の一節である。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
