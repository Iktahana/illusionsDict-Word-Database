    "definitions": [
      {
        "index": 1,
        "gloss": "to be lit (e.g. candle, lamp, light bulb)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スウィッチを入れると数十の電燈が一度に灯ると同じように、この植物のどこかに不思議なスウィッチがあって、それが光の加減で自働的に作用して一度に花を開かせるのではないかと思われるようである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめ軒端を伝って、ちょろちょろ、まるで鼠のように、青白い焔が走って、のこぎりの歯の形で、三角の小さい焔が一列に並んでぽっと、ガス燈が灯るように軒端に灯って、それから、ふっと消える。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れて、車室の暗い豆電燈が、ぼっと灯る。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あたりが暗くなるにつれて群集は刻一刻と増して来て、街燈がすっかり灯るころには、二つの込合った途切れることのない人間の潮流が、戸の外をしきりに流れていた。",
              "citation": {
                "source": "群集の人",
                "author": "THE MAN OF THE CROWD",
                "note": "青空文庫"
              }
            },
            {
              "text": "上体を起こして「ああっー」と伸びをすると、心の闇の奥に出口の明かりがぽつんと灯るのが見えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（面白い、殺ってやれ）　秀三郎は、喫いかけたタバコをポンと地下室の向うに抛って、薄暗の中にポーッと赤い火の灯るのを見乍ら、卓子に手をついて、ウン、と寝椅子から起き上った時でした。",
              "citation": {
                "source": "足の裏",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中庭に灯る石燈籠、明滅をする燈の光、蛾がパサパサとぶつかるらしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の夕は何となしに空気も澄んで、街に灯る電燈も澄んだやうに光る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "野に火が上り、海に浮び、河に灯る。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第五巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……柵の傍に立つてゐる細い電柱の上の外燈と、もう一本の列車のための信号燈がポカリと灯る。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハツキリ記憶に在るだけでも、先づカバン屋、洋品店、文房具も売つている雑貨店、靴屋、昼間は薄暗い店先だが夜になると不意に「サツク及スキンいろいろ」と書いたネオンが灯る衛生器具屋、小さい炭屋、そこだけが此の一廓中で二階になつてゐる撞球場、その階下の小さい酒場が大通りの角店になつてゐる。",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから彼女が到着して一時間たち、ロウソクの灯る食堂のほの暗い板材を背景にして、快活な微笑、艶やかな黒髪、桑の実色の琥珀織りを羽織る若くすらりとした人影が見えた時、二人とも彼女の美貌に打たれた様子が見え見えだった。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方になっても同じ場所に同じ顔が見えたので、心配になり、ブレイクの部屋に明かりが灯るのを待った。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "「確かに、」私は述べた「部屋の中で光が灯るのを見ましたが、すぐに消えてただの煙になってしまいましたよ。",
              "citation": {
                "source": "夢日記",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこれだけが、天地の暗闇の中に灯る一点の灯火。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さくひとつ明かりが灯るかのように、日比谷には思い出すことがあった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝室に明かりは灯ることなく、暗いままだった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "男達が入った部屋の中からの声も聞こえず、また人の足音もしなかったが、彼はいきなり微かな明かりが三階に灯るのを見た。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、時を忘れていると、ちょうど明りが灯る頃。",
              "citation": {
                "source": "梅※の杖",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると小さな炎が明るい部屋の陽光にけおされて鈍く透明にともる。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八十｜糎ぐらいの太い竹の筒が台になっていて、その上にちょっぴり火のともる部分がくっついている、そしてほやは、細いガラスの筒であった。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "行燈は紙を四方に張りめぐらした中に、油のはいった皿があって、その皿のふちにのぞいている燈心に、桜の莟ぐらいの小さいほのおがともると、まわりの紙にみかん色のあたたかな光がさし、附近は少し明かるくなったのである。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へへえ、電気とやらいうもんはあかりがともるもんかと思ったら、これはまるで綱じゃねえか。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "電燈がともるようになれば、村人たちはみんなランプを、あの甘酒屋のしたように壁の隅につるすか、倉の二階にでもしまいこんでしまうだろう。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "※を抜けよはやも聴け、鐘鳴りぬ、わが子らよ、御堂にははや夕の歌きこえ、蝋の火もともるらし、※を抜けよ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯ぞともる、支那｜床の玻璃に人見え、あかあかと末広に光凍れば、古煉瓦うづだかき原のくまぐま、ほそぼそとこほろぎの鳴く音洩れぬる。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウィッチを入れると数十の電燈が一度にともると同じように、この植物のどこかに不思議なスウィッチがあって、それが光のかげんで自働的に作用して一度に花を開かせるのではないかと思われるようである。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて私は時々夕方の檢温の結果などによつて、氣に入つた讃美歌の一くさりを誦み、ぽつかりと音もなくともる電燈を見つめながら、ベツドの上に四肢をのばしてゐる。",
              "citation": {
                "source": "輝ける朝",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月といっても朝夕はまだ肌寒いのに、けさは細かい雨が一日しとしとと降り暮らして、影のうすい電灯がぼんやりとともる頃になっても、檐の雨だれの音はまだ止まない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、ランプがともると間もなく、性体なく寝込んで、朝は、一番馬（トロツコが通じてゐる山の中腹まで、板にされた製材を運び出す馬の一行）の鈴で目を醒した。",
              "citation": {
                "source": "山を越えて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
