      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "extra-large",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これを売っている露店商は特製特大の赤ん坊の頭ぐらいのを空に向けてジャンボンジャンボンと盛んに不思議な騒音を空中に飛散させて顧客を呼んだものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不精なお方だから、私が黙って揃えて置けば、なんだこんなもの、とおっしゃりながらも、心の中ではほっとして着て下さるのだろうが、どうも寸法が特大だから、出来合いのものを買って来ても駄目でしょう。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧文の書籍や雑誌には、章や節のはじまりに来る単語の一字目を、イニシャルと呼ばれる特大の飾り文字で組んだものがあります。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イニシャル用の特大の飾り活字を用意するか、いっそイニシャルを省くか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "チップ界の松田聖子とでも言えばいいのかな、とにかくはでなエピソードだらけのサンダース率いるＡＭＤは、これまで思わず大笑いの奇抜な広告や超特大クリスマス・パーティなんぞで話題を集めてきたが、基本戦略は地味にセカンド・ソースにおいてきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、倍でも三倍でも、ＳＯＬにしろＳＯＭＢＲＡにしろ、きょうのような年一度の特大闘牛になると、何でもいいから切符が手に入っただけで幸運に感謝しなければなるまい。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社は特大の活字もて、このめずらしき冒険少年の記事をかかげた号外を発行した。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴のまわり一｜米三、厚さ十｜糎というでかい蟒の胴を輪切りにした燻製が、常例ビフテキに使っていた特大皿から、はみ出しそうになっているのである。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は洋服をきる時にはズボンのポケットに麻の特大のハンカチを入れておく。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に特大の重箱にウナギの蒲焼がワンサとつみ並べて現れる。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十一年）馬場※一氏の書　馬場さんが大臣になられる二、三週間前のこと、私は大阪の勧業銀行に愛陶趣味の目の敵田辺加多丸支店長を訪れ、しばし、応接間に待つ中、ふと卓上に眼をやると、二寸に三寸もあろうと思われる特大型広告マッチがレッテルの魅力によって妙に眼を射る。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十七日（月）　どの新聞も、国民総蹶起せよといった意味のことを、特大ミダシで書いている。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、花柳界では客を招くといって、縁起に張り子の男根を神棚に飾ったもので、今使い奴が持ってきたのは、まさにその超特大製のシロモノだった。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "けっきょく標本を日本まで持って帰ることになり、特大の魔法瓶を用意し、その中に氷とドライ・アイスとを入れて、飛行機に積みこむことにした。",
              "citation": {
                "source": "白い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの超特大惨敗で、日本は第五十七等国へ下落するかもしれないけど、人間の素質にはなんの変りもない。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "特大のコッフェルで炊いたご飯が、ほんの申し訳ほど底に残っただけだった。",
              "citation": {
                "source": "キャラコさん",
                "author": "女の手",
                "note": "青空文庫"
              }
            },
            {
              "text": "評論雑誌の特大号が年四回なのも雑誌資本の年四回の回転率に基くという観察も、仲々警抜である。",
              "citation": {
                "source": "読書法",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "インクの匂いとともに、特大の活字で印刷されている数行が目を奪った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生や中学の低学年生たちの授業時間に、ぼくはだから玄関脇の小部屋から脱け出し、一人で屋上に出ると、その白い平面に特大のマッチのような形で突出した出入口の、それもやはり半分から上を黒く塗られている壁に、ボールをぶつけて遊んだ。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日後ニューヨーク各紙は特大見出しを打った。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな特大見出しを決めつつ、自らの死亡記事を考えていたころ、つま先が砂に着いた。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ蓄音機用の針たるや、市場に鬻がれているものは千差万別で、同一の会社からも、低音、半音、高音、特大音、或はクロミウム針、竹針、等々が売り出されている有様だから、これでは迷わないわけに行かぬであろう。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "半袖から突き出ている両腕が、特大のソーセージみたいだ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "特大のアンチョビー・ピザをひとつ取り、三人で食べた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（遠山茂樹著『明治維新』、滝川政次郎「皇室史の悲劇」「新潮」十月特大号）　この暗殺の事実については、維新史料編纂委員をしていた植村澄三郎という人が、私に「それはほんとうだよ。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも写真入りの特大記事だ。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても「天の火」とくだいたのは好い。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、もっとくだいた話をしてやろうか」　凄まじい面つきで岩井の方へ這って行く。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その厳粛な意味を、子へ、どう受けとらせるかに、思いを千々とくだいている母の無言なものが、日ごろ物臭な高氏をしても、この水垢離をとらせたといえようか。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
