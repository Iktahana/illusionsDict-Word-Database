[
  {
    "uuid": "395aca16-3437-59b9-9c93-2db33aa6975e",
    "entry": "特大",
    "reading": {
      "primary": "とくだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-の形容詞",
        "形容動詞",
