    "definitions": [
      {
        "index": 1,
        "gloss": "the greatest of the day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
