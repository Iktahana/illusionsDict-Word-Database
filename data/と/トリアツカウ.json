[
  {
    "uuid": "c005941e-9246-58ca-b27c-a8dfb76eeb1d",
    "entry": "取り扱う",
    "reading": {
      "primary": "とりあつかう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
        "動詞-他動詞"
