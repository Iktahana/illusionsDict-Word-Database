        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文祿元年の朝鮮陣には、長政が利安、友信を連れて渡り、孝高は跡から豐臣秀吉の使として京城に入つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甲子夜話」には、慶長十二年の朝鮮の使にまじっていた徳川家の旧臣を、筧又蔵だとしてある。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和三年の朝鮮滞在中もたべものに難儀した。",
              "citation": {
                "source": "明石鯛に優る朝鮮の鯛",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れでも自分は新しい年の朝に新しい仕事の幾分かに着手し得たと云ふ事だけで、何よりも嬉しく何よりも幸福であつた。",
              "citation": {
                "source": "新歸朝者日記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなふうにして、少年の朝の歴史は、あつけなく幕ぎれになつた。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "空閨十年の朝夕を通じ、心をしびれさせるものと云へば、この幻との束の間の抱擁であつた。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の朝顏は、去年のより、どう見てもひとまはり小さい」「嫌になるぜ、親分。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の朝顔は、去年のより、どう見てもひとまわり小さい」「嫌になるぜ、親分。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            }
          ]
        }
