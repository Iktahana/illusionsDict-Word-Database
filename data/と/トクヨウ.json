    },
    "definitions": [
      {
        "index": 1,
        "gloss": "intensive-care old people's home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "美しい女のその声に、この折から、背後のみ見返られて、雲のひだ染みに蔽いかかる、桟敷裏とも思う町を、影法師のごとくようやく人脚の繁くなるのに気を取られていた、松崎は、また目を舞台に引附けられた。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話帳に本名を出しとくような狐狸とは段違いの怪物だからウッカリした事は出来ないと思ったからだ。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にかけた人間を打っちゃらかしとくようなやつが、人のことがいえるかい。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、係員にそういって予定の時刻が来たから、早く気球の綱をとくようにいってくれたまえ」「へえ、やっぱり六条さんは、一人で上へあがるのですか」「さっきから幾度もそういっているじゃないか。",
              "citation": {
                "source": "空中漂流一週間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なあ、おい、イギリスにあザグヴォズキンみたいな変てこな奴あ一人だって居ないんだ……あすこじゃ一文の金だって循環してるんだぜ……そうとも……あすこじゃ銭函に錠を掛けとくような吝な野郎はいないんだ。",
              "citation": {
                "source": "マリ・デル",
                "author": "MARI D'ELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なぜかといつて、とくような殺人がないからじや」　フランボウはまつたくびつくりして口をつぐんだ。",
              "citation": {
                "source": "とけない問題",
                "author": "THE INSOLUBLE PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "カケるのは私が明日行ってカケるからね、それまで別々の箱に入れとくように。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君や弟の意向をきいとくように、佐々木に頼んで置いたが……」「それなら、まとまってかねが入るわけだから、遺族の人達も助かるだろう」　私はうなずきながら、何気なく、森山が座席へ置いた新聞をとりあげた。",
              "citation": {
                "source": "金山※話",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く、なわをとくようにいってください。",
              "citation": {
                "source": "怪人二十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はあなたの額にキスすることをあなたに言っとくようにと私に言うの、そして彼女はそのキスによって、いつだって幸福でいられる力をあなたに送りたいと言うのよ。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
