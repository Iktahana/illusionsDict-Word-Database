    "definitions": [
      {
        "index": 1,
        "gloss": "night duty (in an imperial court, public office, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）　そこで正直を申しますと、この小さな「イギリス海岸」の原稿は八月六日あの足あとを見つける前の日の晩宿直室で半分書いたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかり夜になつて、疲れ切つた、宿直の番に當つてゐない召使どもが眠らうとしかかる頃になると、クリストフ・デトレェヴの死は、突然、叫び出すのだつた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔話の綱や金時のやうに、頼光の枕もとに物々しく宿直を仕つるのはもう時代おくれである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿直室のほうで何かごとごと鳴る音がしました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か事故が起った時に事務所の宿直がアンナことするのよ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうかい、体はそれで可いとした処で、お前さんのような御身分じゃあ、鎖を下ろした御門もあろうし、お次にはお茶坊主、宿直の武士というのが控えてる位なもんじゃあないか。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "道人の曰く、君常に官に宿直の夜に當りては、奧方必ず斯の馬に乘つて出でらるゝなり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしいつはりと思はれなば、例の宿直にとて家を出でて、試みにかへり來て、密かに伺うて見らるべし、と云ふ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "令史、大に怪み、即ち其の詞の如く、宿直の夜潛に歸りて、他所にかくれて妻を伺ふ。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、学校の宿直室に樹明君を訪ねて暫らく話した、十一銭のお辨当を頂戴した、庵ほど御馳走のないところはないから、何を食べてもうまい。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕、樹明君に招かれて宿直室へ出かける、うまい酒うまい飯だつた、そのまゝ泊る、あたゝかい寝床だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は宿直室に樹明君を訪ねて御馳走になる、そして泊る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその暗黒の中心に在る宿直室のベッドの上に長くなって、隣室と境目の壁に頭を向けたまま、タッタ一人でスヤスヤと眠りかけている。",
              "citation": {
                "source": "ビルディング",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿直室を飛び出して、隣の室に通ずる、暗黒の廊下を突進した。",
              "citation": {
                "source": "ビルディング",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に今まで毎晩私と一緒に寝ていた帳簿方が結婚をして家を持ったので、私が常設の宿直になった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、保護室の隣りの宿直室で、寝ずの番をしていた年寄りのお巡りが、間のドアをそっとあけ、「おい！",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、わざとしおしおと宿直室にはいって行き、椅子に腰かけて火鉢にあたりました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿直の小使がいった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は学校の宿直室へ行きますし、妹は、あれは、東京へまた帰ったほうがいいだろうと思います。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "××県地図と笹の絵が、白い宿直室の壁に、何かさむざむとへばりついているのが、自分を暗示しているような気がしてならない。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、丙寅、和田平太胤長の屋地、荏柄の前に在り、御所の東隣たるに依りて、昵近の士、面々に頻りに之を望み申す、而るに今日、左衛門尉義盛、女房五条局に属して、愁へ申して云ふ、彼地は適宿直祗候の便有り、之を拝領せしむ可きかと云々、忽ち之を達せしむ、殊に喜悦の思を成すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はまだ独身で、小使室のとなりの宿直室で寝起きしていられたのである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "○私はとある田舍の小學校の宿直室にごろ／＼してゐる一人の年若き准訓導を想像して見た。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿直室に起臥してゐる校長が漸々起きて顔を洗つたばかりのところへ、二里の余も離れた処にある分校の目賀田といふ老教師が先づ来た。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と校長が宿直室から声を懸けた。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員室のせまい暗がりのなかでふと黒く蠢いたのは、たぶん宿直の駅員が終電車の著いた音で眼をさましたのであろう。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへけさになって、宿直の与力が出て、命乞いの願いに出たものがあると言ったので、佐佐はまずせっかく運ばせた事に邪魔がはいったように感じた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "永日和讚萩原朔太郎ひとのいのりはみなみをむき、むぎはいつしん、うをはいつしん、われはしんじつ、そらにうかびて、ゆびとゆびと哀しみつれ、たましひはねもごろにほとけをしたふ。",
              "citation": {
                "source": "永日和讚",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうふうな立場から見れば「花鳥諷詠」とか「実相観入」とか「写生」とか「真実」とかいうようないろいろなモットーも皆一つのことのいろいろな面を言い現わす言葉のように思われて来るのである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの玉虫の一例は、われわれがわれわれの現在にこびり付いた過去の一片をからだのどこかにくっつけて歩いているということのいい例証にはなるであろう。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
