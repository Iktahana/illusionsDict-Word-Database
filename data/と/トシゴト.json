    "definitions": [
      {
        "index": 1,
        "gloss": "every year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども常識は、十年ごとに飛躍する。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この地方に数年あるいは数十年ごとに津浪の起るのは既定の事実である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学位を受ける人の年ごとの数が大きいということだけでは少しも濫造の証拠にはならない。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大阪の市が南へ南へ伸びて行こうとして十何年か前までは草深い田舎であった土地をどんどん住宅や学校、病院などの地帯にしてしまい、その間へはまた多くはそこの地元の百姓であった地主たちの建てた小さな長屋がたくさんできて、野原の名残りが年ごとにその影を消していきつつあるというふうの町なのであった。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年ごとに来て喫うなる」というのは、噴火の間歇性を暗示する。",
              "citation": {
                "source": "神話と地球物理学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ごとに咲くや吉野の桜花　　樹を割りて見よ花の在所を　これも同じ心持ちを詠んだ歌であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは昔の元園町がありありと眼前に泛んで、年ごとに栄えてゆくこの町がだんだんに詰らなくなって行くようにも感じた。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "元園町は年ごとに栄えてゆくと同時に、獅子を呼んで小児に見せてやろうなどという悠暢した人はだんだんに亡びてしまった。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも日が暮れてから帰宅するので、この柳のかげに休息して凉風に浴するの機会がなく、年ごとに繁ってゆく青い蔭をながめて、昔年の凉味を忍ぶに過ぎなかったが、我国に帝国議会というものが初めて開かれても、ここの柳は伐られなかった。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂山に生え交る、茅、芒はやがて散り、はた年ごとに枯れ果てても、千代万代の末かけて、巌は松の緑にして、霜にも色は変えないのである。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "木之助が少年から大人へ、大人からやがて老人へと成長し年とっていったように、彼女は見る年ごとに成長し年とっていった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ごとに、御伴船、いや数殖えぬ、つぎつぎに、御従びと、またいや増しぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ごとに、御伴船、いや數殖えぬ、つぎつぎに、御從びと、またいや増しぬ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "榧と栗さびにさびつれ、なほし未だ花は咲きけり、年ごとに花はつけけり。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ごとに花はつけけり。",
              "citation": {
                "source": "観想の時",
                "author": "――長歌体詩篇二十一――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほよそ聖誕日と新年との間には、「サンタ、マリア、アラチエリ」の寺なる基督の像のみまへにて、童男童女の説教あること、年ごとの例なるが、我はことし其一人に當りたるなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ごとにジエンツアノにて執行せらるゝ、名高き花祭の期は近づきぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ごとにする驚きよさびしさよ梅の初花を今日見出でたり梅咲けばわがきその日もけふの日もなべてさびしく見えわたるかな梅の花はつはつ咲けるきさらぎはものぞおちゐぬわれのこころに　然し何と云つても春は櫻である。",
              "citation": {
                "source": "樹木とその葉",
                "author": "梅の花櫻の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一印象としての彼女の彼に對する不快は年ごとに深くなつて、事ごとに眼に見えぬ衝突が兩人の間に行はれてゐたのであつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "木槿の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その功徳で百年ごとに一年ずつ命が増す、人寿八万四千歳に上りそれより八万歳を減ずる時賢劫の第五仏｜弥勒仏が出る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "きさらぎは梅咲くころは年ごとにわれのこころのさびしかる月　私はちらりほらりと梅の綻びそめるころになると毎年何とも言へない寂しい氣持になつて來るのが癖だ。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "年ごとにする驚きよさびしさよ梅の初花をけふ見つけたりうめ咲けばわがきその日もけふの日もなべてさびしく見えわたるかな　これらは『砂丘』に載つてゐるので、私の三十歳ころのものである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "野蒜の花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも不思議にその谷間から仰ぎ馴れていた山ざくらに対してだけは寧ろ年ごとになつかしい追懐を深めてゆく傾向があるのである。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが次第に嵩ずるうちに、大名共、だんだんと狡猾になって、お墨付には別段音物付け届け手土産の金高質量を明記してなかったのを幸いに、いつのまにか千両は五百両にへり、五百両は二百両に減って、年ごとにその挨拶の相場が下落していったために、窮すれば人また通ず、甚だ小気味のいい妙計を案じ出したのが松平家です。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは昔の元園町がありありと眼の先に泛かんで、年ごとに栄えてゆく此の町がだんだんに詰まらなくなって行くようにも感じた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも日が暮れてから帰宅するので、この柳のかげに休息して涼風に浴するの機会がなく、年ごとに繁ってゆく青い蔭をながめて、昔年の涼味を偲ぶに過ぎなかったが、わが国に帝国議会というものが初めて開かれても、ここの柳は伐られなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえて、一方の富子は世間の人気を独り占めにして、その評判は年ごとに高くなった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わづか十二三年の違ひだが、操りが一年ごとに廢れて來るのがあり／＼と眼に見える。",
              "citation": {
                "source": "近松半二の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりの門の柿の実は年ごとに粒が大きくなって、この秋も定めて美事に熟れることであろうよ」「そうであろうのう」　ここの門に立った時に、千枝太郎もすぐに隣りの梢を仰いだのであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとしごとできると、こちらもむこうもいっしょになって、どぼんどぼんと池にとびこみ、いっしょに、水をぶっかけあって遊びました。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
