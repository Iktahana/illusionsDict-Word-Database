          "literary": [
            {
              "text": "問屋の菎蒻ぢやあるめいし、無價で蹈まれて間に合ふけえ』。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六番目は誰です」　「追分け三五郎」　「七番は」　「尾張の大野の鶴吉」　「八番は」　「尾張の桶屋の吉五郎」　「九番は」　「三保の松五郎」　「十番は」　「問屋場の大熊」　「十一番は」　「よせやい、爺っつあん。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中や表紙の図案を流用しながら、自分の意匠を加えて、画工に描き上げさせ、印刷屋に印刷させて、問屋の註文に応じていた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更中間のブローカー問屋や素人の父の型の極った意匠など必要はなくなった。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は元町通りの海外衣裳問屋で極彩色の身の廻りのものを二、三買ってチタ子に与えました。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "手拭には、どっかの村の肥料問屋のシルシが染めこまれてある。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "問屋と取引のある或る宿屋では内地米三十俵も積重ねる。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻からげをして、帯には肥料問屋のシルシを染めこんだ手拭をばさげて居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "波止場に入りし時、翁は夢みるごときまなざしして問屋の燈火、影長く水にゆらぐを見たり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮れて間もなきに問屋三軒皆な戸ざして人影絶え人声なし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰の舟ぞ」問屋の主人らしき男問う。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪問屋は、石炭問屋に変り、鶏買いは豚買いに変った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつまでも、薪問屋ばかりをやっている人間は、しまいには山の樹がなくなって、商売をやめなければならなくなっていた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薪問屋は、中間搾取をやる商売だ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の上下｜少の間は両岸とも材木問屋多ければ、筏の岸に繋がれぬ日もなし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "埃及、印度、支那、阿剌比亜、波斯、皆魔法の問屋たる国※だ。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家は、日本橋呉服問屋であって、いまとちがって、その頃はまだ、よほどの財産があったし、私はまたひとり息子でもあり、一高の文科へもかなりの成績ではいったのだし、金についてのわがままも、おなじ年ごろの学生よりは、ずっと自由がきいていた。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言うにもあの蔵元屋と言うのは博多切っての大金持の為替問屋。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "表向きは立派な為替問屋と質屋になっておりまするが、裏向きは筑前切っての大きな博奕宿で御座います。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか駅の構内で怒鳴りまわる貨物仲仕の声、魚市場の問屋のセリ声、物売の声、下足番の声、又は狂い飛ぶ火花と、轟々たる機械の大噪音の中に、一糸を乱さず、職工を叱※する錆びた声……なぞの中には、松籟、濤韻と対比すべき或るものを含んでいることを、よく気付かせられる。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺失した人は四谷区何町何番地｜日向某とて穀物の問屋を業としている者ということが解った。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺失した人は四谷区何町何番地日向某とて穀物の問屋を業としている者ということが解った。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "無益とは知りつつも、車を駆りて品川にゆき二郎が船をもとめたれど見当たらぬも理なり、問屋の者に聞けば第二号南洋丸は今朝四時に出帆せりとの事なれば。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "店と言っても家構えがあるわけでなく鮪や鮫を売る問屋の端の板羽目の前を借りて庇を差出し、其の下にほんの取引きに必要なだけの見本を並べるのであった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、荷嵩の割合に金目が揚がり、商品も小綺麗な代物なので、河岸の中でも羨まれる魚問屋の一軒だった。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前、仲之町の声妓で、お若と云った媚かしい中年増が、新川の酒問屋に旦那が出来たため色を売るのは酷い法度の、その頃の廓には居られない義理になって場所を替えた檜物町。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "問題に触れるのは、お桂ちゃんの母親で、もう一昨年頃｜故人の数に入ったが、照降町の背負商いから、やがて宗右衛門町の角地面に問屋となるまで、その大島屋の身代八分は、その人の働きだったと言う。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋の砂糖問屋の令孃が、圓髷に結つて、あなたや……鰺の新ぎれと、夜行の鮭を教へたのである。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "チキンサンドイッチが出るかと思えば玉子焼やら蒲鉾にきんとんやら、如何にも子供向きのご馳走が運ばれました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夜のように座ぶとんや夜具のすそをよごすのであった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
