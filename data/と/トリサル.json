[
  {
    "uuid": "233bb1f0-53e7-5788-befb-47a708dc5ca2",
    "entry": "取り去る",
    "reading": {
      "primary": "とりさる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
