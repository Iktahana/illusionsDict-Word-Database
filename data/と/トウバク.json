[
  {
    "uuid": "3f88d3e1-744e-55f5-9ee7-b3881bfc0985",
    "entry": "倒幕",
    "reading": {
      "primary": "とうばく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
