    "definitions": [
      {
        "index": 1,
        "gloss": "residence of a government official in the Ryukyu Kingdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち南風の平等は赤田に首里殿内を、真和志の平等は山川に真壁殿内を、北の平等は儀保に儀保殿内を建てさせました。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞得大君の下には前に申上げた三殿内（三神社）の神官なる大あむしられがあります。",
              "citation": {
                "source": "ユタの歴史的研究",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十七　世の果は何處とも知らざれば、亡き人の碑にも萬代かけし小松殿内府の墳墓、見上ぐるばかりの石の面に彫り刻みたる淨蓮大禪門の五字、金泥の色洗ひし如く猶ほ鮮なり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十日午前五時谷中天王寺町四五淨光院殿内墓標裏に、年齡五十歳位頭髮五分刈の女の屍體發見さる檢視の結果自殺と判明す身元不詳。",
              "citation": {
                "source": "古鏡",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘井岩之助のかたきうち○二条殿内の人にて、宮中につかハれこれありしむすめ、実に義のあるむすめにて、今でハ身をくがいにしづめこれある事。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月十六日　池内蔵太の母あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、尼僧達の動静に就いて云えば、盤得尼が自室に、普光は書院に、寂連は遙か離れた経蔵に、智凡は本堂の飾り変えをしていたと云うのみの事であって……、更に、事件を境にして夢殿内に起っていた変化と云えば、小窓が開かれていた事と、油時計が一時三十分を指して消えている――と云う二つに過ぎないのだった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巫女の家なる祝女殿内、一族の本家なる根所の殿、拝所になつてゐる殿、祭場ともいふべき神あしゃげ、皆火の神のない処はない。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の神と言ふ名は、高級巫女の住んでゐる神社類似の家、即、聞得大君御殿・三平等の「大阿母しられ」の殿内では、お火鉢の御前と言ふ事になつて居た。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵｜御嶽からは遠く、祝女殿内からは近い。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のやうな殿もあり、又、祝女殿内（ぬるどのち＝ぬんどんち）の様に、祝女の住宅を斥す事もある。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三平の大阿母しられの殿内即、南風の平には首里殿内、真和志の比等には真壁殿内、北の比等には儀保殿内なる巫女の住宅なる社殿を据ゑ、神々のおとほしとして祀つてある。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "南風の平等には首里殿内、真和志の平等には真壁殿内、北の平等には儀保殿内なる巫女の住宅なる社殿を据ゑて、三つの台地に集めた、三山豪族たちの信仰の中心にしてあつた。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、殿内々々には、聞得大殿同様の祭神を祀らして居た。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此等の殿内は皆、三山の主神の遥拝所として設けたのであらう。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三殿内には、真壁大阿母志良礼・首里大阿母志良礼・儀保大阿母志良礼を置いた。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜比等の殿内の下には、間切々々（今、村）、村々（今、字）の君並びに、のろたちが附属してゐる。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "又、自分ののろ殿内の宅つ神なる火の神に事へる。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何村何某妻何村何某妻うし何村何某母親などあるかと思ふと、何村伊知根神何村さいは神何村殿内神など言つた書き方も見える。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "のろ殿内に祀るのは、表面は、火の神であるが、此は単に、宅つ神としてに過ぎない事は既に述べた。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月には、村中のものがのろ殿内を拝みに行く。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "外間のろの殿内には、火の神さへ見当らなかつた位である。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから勿論市民達は神聖侵かす可からざる宮殿内で生仏たるところの喇嘛が行衛不明になったなどとは夢にも信ずることは出来なかった。",
              "citation": {
                "source": "喇嘛の行衛",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
