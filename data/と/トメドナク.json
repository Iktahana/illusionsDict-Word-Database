        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "悪事千里、というが、なまけ者の空想もまた、ちょろちょろ止めどなく流れ、走る。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "表扉は叩いても開けられることはなく、返事といえばただ向こうから止めどなくやってくる罵詈雑言。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術の進歩をあてにして良いのなら、話はさらに止めどなく広がって行きます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えへへへへへ、えへへへへへ」嘉平次は、おだて上げられて、いやしい嬉しそうな笑いが、止めどなく唇から洩れた。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "老媼は赤ただれした目に涙を止めどなく流し、私も袖で顔をおおいおおい話を聴いた。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風でいったん帰りは帰ったものの、縁先に座って、一人ぽつねんと山の上の月をながめていますと、もうじっとしていられないほど悲しくなって、涙がぼろぼろ止めどなくこぼれてきました。",
              "citation": {
                "source": "姨捨山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし涙が止めどなく出て仕方がなかったわ。",
              "citation": {
                "source": "ニッケルの文鎮",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間の暈くような激しさで、自分というものが橋桁で、下に急な流れをみおろしてでもいるような、止めどなく洗われている感覚に襲われることがある。",
              "citation": {
                "source": "杉垣",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　荻原はもうすっかり興に乗ってしまって止めどなくひとりで話しつづける。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ涙が、さんさんと止めどなく溢れ出した。",
              "citation": {
                "source": "自殺を買う話",
                "author": "橋本五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其が一旦開口すると、止めどなく人に逆ふ饒舌の形が現れた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "心はせかせかして足取りや姿は重く止めどなくあっちこっち歩き廻った、祖母もあんまりぞっとしない様な顔をしてだまって明るくない電気のまどろんだ様な光線をあびて眼をしばたたいて居た。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦、口がほぐれると、老女は止めどなく、喋り出した。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に止めどなくなるのが、「ひとり語り」の癖とは言へ、語部の古婆の心は、自身も思はぬ意地くね惡さを藏してゐるものである。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "一旦、口がほぐれると、老女は止めどなく喋り出した。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に止めどなくなるのが、「ひとり語り」の癖とは言へ、語部の古婆の心は、自身も思はぬ意地くね悪さを蔵してゐるものである。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に止めどなくなるのが、「ひとり語り」の癖とは言え、語部の古婆の心は、自身も思わぬ意地くね悪さを蔵しているものである。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見が止めどなく長談議をつぶやいていたうちに、娘の静代は梅の枝を剪って来て、しばらく弄んでいて、話の終るのを待ち構えていた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん／＼と止めどなく降つてくる雪は、膝を埋め、腰を埋め、胸を埋める深さにまで積つてきました。",
              "citation": {
                "source": "雪に埋れた話",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱き涙は止めどなく流れるのであった。",
              "citation": {
                "source": "愛か",
                "author": "李光洙",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の頬には未だに涙が止めどなく流れている。",
              "citation": {
                "source": "母を恋うる記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の頬からは涙がさめざめと、止めどなく流れ落ちて、冷めたい鉄棒を伝はつて、私の唇の中へ入つて行く。",
              "citation": {
                "source": "Dream Tales",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "興奮なんかしないつもりだつたけど、やつぱり、これだけ云ふのは、一生懸命なんだわ……」　自分でも何を云つたのか、恥も外聞もないつもりで、ただ云はずにはゐられないことを止めどなく喋つたのである。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その記念に対する美しい欲望の実相は、実にこの遊女によってみたしたところのものであったのかと思わざるを得ないことは彼の心を止めどなく傷つけ、暗くせずにはおかなかった。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私はとめどなくげらげら笑いながら、そのまま「いでゆ」から出てしまったのであるが、宿へ帰って、少しずつ酔のさめるにつれ、先刻の私の間抜けとも阿呆らしいともなんとも言いようのない狂態に対する羞恥と悔恨の念で消えもいりたい思いをした。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のように、ただ、とめどなく流れるたちの男では無かったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "良寛さんの眼からとめどなく涙が溢れ、平野の家々の灯はうるんで一つに見えた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、この、涙というやつは、まことにとめどなく出るものだね。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　そのような、頗る泥臭い面罵の言葉が、とめどなく、いくらでも、つぎつぎと胸に浮び、われながらあまり上品では無いと思いながら、憤怒の念がつのるばかりで、いよいよひとりで興奮し、おしまいには、とうとう涙が出て来た。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨハンネスは、寝台のまえにひざをついて、死んだおとうさんの手にほおずりして、しょっぱい涙をとめどなくながしていました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
