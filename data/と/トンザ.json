        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此処に芸術は一頓挫した。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間倦んじ疲れて、懈怠の心が起らうとする時、頭をもたげて燈光の中に先生の黒い痩せたお顏を瞥見すると、いまにも抑揚頓挫のある言葉で話しかけようとしてゐられるかの如く思はれる。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八七三年にレーリーが家督を相続した頃は農業も相当有利であったが、一八七四年に外国貿易の頓挫した影響から、引いて農民の窮迫を来し、従って地主の財政も極めて不利になった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが研究所での実験の一頓挫と同時に来た。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護員のその言語には、更に抑揚と頓挫なかりき。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の研究に一頓挫が来そうな気持がしだいに深まっていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これあるいはやがて起らんずる天変の大頓挫にあらざるなきか。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるほどに車体は一上一下と動揺して、あるいは頓挫し、あるいは傾斜し、ただこれ風の落ち葉を捲き、早瀬の浮き木を弄ぶに異ならず。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御度量のひろい将軍家に於いては、もちろん、御計画の頓挫をいつまでも無念がつていらつしやるやうな事は無く、あの、大かたり者の陳和卿に対してもいささかもお怒りなさらず、医王山ホド、ウマクイカナカツタヤウデス。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間、倦んじ疲れて、懈怠の心が起ろうとする時、頭をもたげて燈光の中に先生の黒い痩せたお顔を瞥見すると、いまにも、あの抑揚｜頓挫のある言葉で話しかけようとしていらっしゃるかの如くに思われる。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、私の結婚の話も、一頓挫のかたちであつた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが夜に差し掛かる頃、一本の試験管が割れ、実験が頓挫してしまった。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが最初に狙ったサービスの規模が機械の能力に比べて大きすぎたために、この計画が頓挫した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそれでも「自分で機械を独り占めする気分」という夢が忘れられない連中が、プロジェクトの頓挫で行き場の決まっていなかったミニコンピューターを使って、勝手な真似をはじめた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "教育用マシンとしての各社のＢＴＲＯＮ発売計画は頓挫した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "縱令中頃定家假名遣が出まして、一頓挫を來しましても少し荊棘が生えましても、荊棘を刈除いて、元との道を擴げて、國民が皆歩むやうな道にすると云ふことが、或は出來るものではないかと云ふやうな、妄想かも知れませぬけれども、想像を自分は有つて居ります。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし正しく之を解釈して見たならば、好んで為す場合にも努力が伴わない時はその進行は頓挫してしまう。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし逸る気で事を行う者の常として必ず疲労と躓きが出て、勇気は頓挫し萎縮し振わないようになるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "校舍將に成らむとして頓挫せるにや、ほんの數人の工人がこつ／＼働けるさまにて、いつ出來上ることやら、一見人をして氣の毒の念に堪へざらしむ。",
              "citation": {
                "source": "小日向臺",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　折角本道に立ち返つて一途の研究にたづさはり初めた私は、また頓挫した。",
              "citation": {
                "source": "熱い風",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一方には赤旗事件で金曜会の連中が一掃され、一方にはまた、電車問題の凶徒｜聚衆事件が確定して、西川、山口等、多くの同志が投獄され、その他の人々は手も足も出しようがなく、運動は全く頓挫の姿を呈した。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の印刷局長｜得能良介は鵜飼老人と心易くしていたので、この噂を聞くと真面目になって心配し、印刷局へ自由勤めとして老人を聘して役目で縛りつけたので、結局この計画は中止となり、高橋の志道軒も頓挫してしまった。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この頓挫が二葉亭の生涯の行程をこじらす基いとなったは争われない。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓挫しても新らしい文化の種子を播いたのは争えない。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすると、他人から毒殺されるほどにも恨みをうけるはずはないわけなんだから、自然ここで、右門の見込み捜査は一｜頓挫をきたすべきでしたが、しかし、いったん手を染めたとならば、毎度申しあげたように、そんなことでおめおめとたたらを踏む右門とは右門が違います。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく追いかけてきた肝心の秀の浦が行き先不明になったとしたら、当然の順序として、大手攻めの吟味方針は、ここに一｜頓挫をきたさなければならないはずでしたのに、ごく物静かにいったものです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "官位に付随する尊敬、煩瑣なる階級の差等、「御」とか、「せさせ給ふ」とかいう尊称語を除いてみれば、後世の型に囚われた文章よりも、この方が、よほど、今日の口語に近い語脈を伝えていて、抑揚｜頓挫などという規則には拘泥しない、自然のままの面白味が多いようだ。",
              "citation": {
                "source": "『新訳源氏物語』初版の序",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親は県会議員をした人だけあって、言葉の抑揚頓挫が中々巧みであった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、少くとも、かの女の芸術が一時そのために頓挫したのは争ふべからざる事実であつた。",
              "citation": {
                "source": "『水野仙子集』と其他",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その室に今つまれているふとんざぶとん家財類。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四五年（昭和二十年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
