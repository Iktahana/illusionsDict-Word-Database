        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "笠井さんは、流石に少し侘びしく、雨さえぱらぱら降って来て、とっとと町を急ぐのだが、この下諏訪という町は、またなんという陰惨低劣のまちであろう。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諒安はとっととかけ下りました。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はとっとと新井田氏の家の方を指して歩いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやは、とっとと走って行って裏門の扉につかまって停った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小柄でいながら確りした肉付の背中を持っていて、稍々左肩を聳やかし、細そりした頸から顔をうつ向き加減に前へ少し乗り出させながら、とっとと歩いて行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友達と簡単な挨拶を交して、とっとと家路へ急ぐ、むす子の後姿が向うに見えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子はかの女と連れ立って歩くときに、ときどき焦れて「遅いなあ、僕先へ行きますよ」と、とっとと歩いて行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子は稍々内足で学生靴を逞しくペーヴメントに擦り叩きながら、とっとと足ののろい母親を置いて行く。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを持ってとっとと帰れ！",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　耳もとで囁き、大きい黒揚羽の蝶が、ひたと、高須の全身をおおい隠し、そのまま、すっと入口からさらっていって、廊下の隅まで、ものも言わず、とっとと押しかえして、「まあ。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」興奮して蒼ざめ、ぶるぶる震えている熊本君の片腕をつかんで、とっとと歩き出した。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "静かだなあと思って木之助はとっとと歩いた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "讓は早く帰って下宿の二階で己の帰りを待ちかねている女に安心さしてやりたいと思ったので、爪さきさがりになった傾斜のある路をとっとと歩きだした。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「往きましょう、おいでなさい」「すみませんね」　讓はもう歩きだしたがはじめのようにとっとと歩けなかった。",
              "citation": {
                "source": "蟇の血",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の男は怒って、「この乞食坊主、とっとと往かないと、ひどい目に逢わすぞ」　と言って罵った。",
              "citation": {
                "source": "種梨",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと仕事を片付けろ！",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うう」「ううなんて、ほんとに邪慳よ」　広巳はとっとと往こうと思った。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後はとっとと、『パソコン創世記』という材料を料理して、本の未来像を具体的に描いてみれば良かったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "では御機嫌よう、左様なら」　そう云い捨つると、彼の挨拶を聞き流して私はとっとと掌を立てた様な急坂を湯元温泉の方へ馳け降り始めた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小道具に使ってしまえばもう用はねえからね、口もとの明るいうちにとっとと帰ってくんな！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑う暇があったら、だんなこそとっととらちをあけりゃいいんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと恐れ入っちまいなよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとと歩きな」　名人の気炎、当たるべからずです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうっ岸までとっとと出しなよ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっととみこしをあげたらいいじゃねえか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、おかしな鼓の隠し芸があるっていうんで、証拠呼ばわりをして突きつけたあの祝儀袋に、きっと何かふらちな細工がしてあるにちげえねえから、とっとと洗いにいってきな」「なるほどね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっととしたくしな」「ウへへ……うれしいね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっとといってくりゃいいんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっととしろい」　自身番の小者たちもてつだって、たちまち取り降ろしの用意がととのいました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちらへとっととおどきめされッ」　寄ってはならぬといったものでしたから、聞くやいっしょで、湯煙たてながらしゃきり出たのは、だれでもない向こうっ気の伝六です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
