          "literary": [
            {
              "text": "文人風や遠州好みの床飾りもやはりそうである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛き、凄まじき、種々で、ちょいとした棚の置物、床飾り、小児の玩ぶのは勿論の事。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "らんまの彫刻、ちがひ棚、書院窓、その小障子、天井造り、床飾り、何しろ、これでもか、これでもかの數寄好みである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後は薬研堀の不動、植木市というほど盆栽の陳列、初春の床飾り、松竹梅に福寿草、当時は篠づくりの梅が流行で飛ぶように売れた。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
