[
  {
    "uuid": "a2d27c2e-36b8-50da-b622-8f67db47299a",
    "entry": "酉の市",
    "reading": {
      "primary": "とりのいち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
