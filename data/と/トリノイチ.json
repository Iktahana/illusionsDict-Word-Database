    "definitions": [
      {
        "index": 1,
        "gloss": "tori-no-ichi (held at Ōtori Shrine on each day of the Rooster in November)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京の酉の市というのをかねて話には聞いていながら、まだ一度も見たことがない。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早手廻しに、もうその年の酉の市を連れて歩行いた。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んでも一年中でこの酉の市ほど甚い雑踏はないのだから、実に無量雑多な人間が流れ込んで来る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "熊手を拵えて売ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は、もう、ぞろぞろと浅草一帯は酉の市の帰りの客で賑わい、大きな熊手を担いだ仕事師の連中が其所らの飲食店へ這入って、熊手を店先に立て掛け上がったりしている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "熊手を拵えて売ったはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "歳の市の方は酉の市とは違い、景気附け一方でする気合い商売でないからです。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "歳の市のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の移り變りを畫いたものに、「べつたら市が來た」「あやしき形に紙を切りなして胡粉ぬりたくり彩色の田樂みるやう裏にはりたる串のさまもをかし」酉の市の仕度をこんな風にかいてある。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "酉の市の今昔談が一と通り済んで、時節柄だけに火事のはなしが出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今その上さんが熊手持って忙しそうに帰って行くのは内に居る子供が酉の市のお土産でも待って居るのかとも見えるがそうではない。",
              "citation": {
                "source": "熊手と提灯",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ人達が寄つてたかつて、太神樂の道化役にも使ひ、酉の市の熊手のかざりにまで引張り出す。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな縁起棚の傍には、つい三四日前の酉の市で買って来た熊手などが景気よく飾られて、諸方からの附届けのお歳暮が、山のように積まれてあった。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はある晩酉の市から歸つて來てから、別れるといふことを眞面目に話し合つた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば酉の市は先様がとりの市、こっちはとられまちで、どの道金に縁の薄い江戸ッ児には、宵越しをさせたくもこの始末なので及びもつかぬこと、それでも一かどの福運を得る気で、眼前とられにゆくを甘んずるなどはとうてい江戸ッ児以外の人には馬鹿気切ってて嘘にも真似の出来たものではない。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "余事なれど酉の市とは、生たる鶏を売買せし也。",
              "citation": {
                "source": "江戸の玩具",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "酉の市は明後日でござい。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鷲神社の傍の田甫の白鷺が、一羽｜起ち二羽起ち三羽立つと、明日の酉の市の売場に新らしく掛けた小屋から二三｜個の人が現われた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふ此頃の酉の市に参りて、エンギを申候ものにこの意義ありや、この愛敬ありや。",
              "citation": {
                "source": "もゝはがき",
                "author": "斎藤緑雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "年季職人の隊を組みて夜を喧鬨の為めに蟻集するに過ぎずとか申せば、多分斯の如き壮快なる滑稽は復と見る能はざるべしと小生は存候（一七日）　　　　　　○往還よりすこし引入りたる路の奥に似つかぬ幟の樹てられたるを何かと問へば、酉の市なりといふ。",
              "citation": {
                "source": "もゝはがき",
                "author": "斎藤緑雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三の切」は、暗い便りない時雨の日がつづいて、今年もそこに十一月が來た、酉の市が來た。",
              "citation": {
                "source": "貝殼追放",
                "author": "「末枯」の作者",
                "note": "青空文庫"
              }
            },
            {
              "text": "四谷の須賀神社の祭礼と神輿、山の手方面ただ一つの酉の市、等についても語りたかったがもう紙数がつきた。",
              "citation": {
                "source": "四谷、赤坂",
                "author": "宮島資夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "繭玉系統の作り枝が社寺から出されるのは、依代に宿つた分霊を持ち帰つて祀る意味で、此点に於て削り掛け・ほいたけ棒・粟穂・稲穂・にはとこ・幸木なども皆同種のもので、延いては酉の市の熊手も、御服の餅花から菖蒲団子と反対に向いて、大きくなつたものと思はれる。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鷲神社の傍の田甫の白鷺が、一羽起ち二羽起ち三羽立つと、明日の酉の市の売場に新らしく掛けた小屋から二、三｜個の人が見われた。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "篇中の事件は酉の市の前後から説き起されて、年末の煤払いに終っている。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "酉の市の晩には夜通し家を開け放ちにして通りがかりの来客に酒肴を出すのを吉例としていたそうである。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度東京の酉の市の賑いだ。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ人達が寄つてたかつて、太神楽の道化役にも使ひ、酉の市の熊手のかざりにまで引張り出す。",
              "citation": {
                "source": "婦人の笑顔",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "酉の市に売れ残る熊手のお亀が、早く売れるものより出来がわるいと、定った訳はない。",
              "citation": {
                "source": "心づくし",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鷲神社の傍の田甫の白鷺が、一羽起ち二羽起ち三羽立つと、明日の酉の市の売場に新らしく掛けた小屋から二三｜個の人がは見はれた。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "篇中の事件は酉の市の前後から説き起されて、年末の煤払ひに終つてゐる。",
              "citation": {
                "source": "里の今昔",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ひとりのいちょうの女の子が空を見あげてつぶやくようにいいました。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々も酉の市をとりのいち、歳のいち（市）と混じて怪しむものなく、遂に「とりのまち」引いては「二のまち」などのこの土地の言葉は衰亡せしものと考へる。",
              "citation": {
                "source": "東京の風俗　序",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
