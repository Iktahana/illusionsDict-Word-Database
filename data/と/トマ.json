    "definitions": [
      {
        "index": 1,
        "gloss": "woven mat (of sedge, hay, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "市の中學から恐らく一週間ぶりに歸つた子供は此一夜を父母と同じ苫の下で明かさうとするのであらう。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しとしとと来た雨の夜泊の船中で、寝ねがてた苫の雫の音を聞いていると翁の胸はしきりに傷んだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫に当る雨音を聞きながら一夜を寝苦しく船中に明した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりを見廻すと、幸い、苫で四方を包んだ船がある。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭青年は苫を破り分けて早百合姫をその中へ入るよう促しました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくの生飯も、昭青年は苫船の中の美しい姫にやってしまうので、淵の鯉は、いつも待ち呆けです。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隙を覗い折を見ては苫船へ通います。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎ、昭青年は姫に生飯を持って行って食べさせたあと、二人は川へ向いた苫を少し掻き分けて、対岸の景色を眺めていました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉時雨は、一しきり盛りになって山の翠も揺るるかと思われる喧ましさ、その上、あいにくと風がはたと途絶えてしまったので周囲を密閉した苫船の暑さは蒸されるようです。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さすがに僧たちも、裸の姫には手を触れかね、躊躇している暇に姫はびっくりして苫船の中へ逃げ込み、着物を冠って縮んでいました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那風の苫船が、白柳の葉影につないであつた。",
              "citation": {
                "source": "橋上",
                "author": "――詩壇の議論家に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は膽振の國の苫小牧に住む妹夫婦の家を訪ふべく、初めての北海道の旅路についた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京を立つてから山形、船川港、弘前、青森、津輕海峽を越えて室蘭と寄り道しながら、眼差す苫小牧へと着いたのが七八日頃、それから九月へかけてのまる一ヶ月ほどを妹夫婦の家に暮した。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫小牧は製紙工場のあるだけで知られた寂しい町で、夏ながら單調な海岸の眺めも灰色で、何となく憂欝だつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほど希望に全身を刺戟されてゐた處女作はとうとう一枚も書き上らないままに、苫小牧滯在の一月ほどは空しく過ぎてしまつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "希望に變る失望、樂しさに變る寂しさ、さうした氣持を抱いて、私は九月十日過ぎに妹を伴ひながら苫小牧をあとにした。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出發前、その旅先の苫小牧でと計畫してゐた處女作「雪消の日まで」は可成りな苦心努力にも拘らず、遂に一部分をさへ書き上げることが出來なかつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから吉浜まで海岸の雨の山道を、験潮器を背負って、苫をかぶってあるいていると、ホトトギスが啼いた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トシエの親爺の伊三郎の所有地は、蓬や、秣草や、苫茅が生い茂って、誰れもかえり見る者もなかった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "津軽海峡、トラピスト、函館、五稜郭、えぞ富士、白樺、小樽、札幌の大学、麦酒会社、博物館、デンマーク人の農場、苫小牧、白老のアイヌ部落、室蘭、ああ僕は数えただけで胸が踊る。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草がくれの艫に、月見草の咲いた、苫掛船が、つい手の屆くばかりの處、白砂に上つて居て、やがて蟋蟀の閨と思はるゝのが、數百一群の赤蜻蛉の、羅の羽をすいと伸し、すつと舞ふにつれて、サ、サ、サと音が聞こえて、うつゝに蘆間の漣へ動いて行くやうである。",
              "citation": {
                "source": "十和田の夏霧",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苫を且つ覆うて、薄の穗も靡きつゝ、旅店の午は靜に、蝉も鳴かない。",
              "citation": {
                "source": "十和田の夏霧",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "颯と風が吹いて來る、と、いまの天氣を消したやうに、忽ちかげつて、冷たい小雨が麻絲を亂して、其の苫に、斜にすら／＼と降りかゝる。",
              "citation": {
                "source": "十和田の夏霧",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その渋色の橋を渡ると、岸から板を渡した船がある、板を渡って、苫の中へ出入をするので、この船が与吉の住居。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あい、」といって苫を潜って這うようにして船から出た、与吉はずッと立って板を渡った。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "市の中学からおそらく一週間ぶりに帰った子供はこの一夜を父母と同じ苫の下で明かそうとするのであろう。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――深々と苫屋を伏せて、屋根より高く口を開けたり、家より大きく底を見せたり、ころりころりと大畚が五つ六つ。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一　さてこの丘の根に引寄せて、一｜艘苫を掛けた船があった。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍なる苫屋の背戸に、緑を染めた青菜の畠、結い繞らした蘆垣も、船も、岩も、ただなだらかな面平に、空に躍った刎釣瓶も、靄を放れぬ黒い線。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜干に敷いた網の中を、ひらひらと拾ったが、朝景色を賞ずるよしして、四辺を見ながら、その苫船に立寄って苫の上に片手をかけたまま、船の方を顧みると、千鳥は啼かぬが友呼びつらん。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
