        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "バラリ取り囲む一同。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同大吉を取り囲む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家臣等はグルッと取り囲む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあげく五月雨の降る或る夕方のこと、手に手に棒千切を持った十四五人が「金貸し後家」の家のまわりを取り囲むと、強がりの青年が三人代表となって中に這入って、後家さんに直接談判を開始した。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山も峰も、雲深くその空を取り囲む。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱心者よと押取り囲む毬棒、刺叉を物ともせず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "クルックスベリの丘の肩あたり、道の盛り上がったところからは、おどろおどろしい館が取り囲む楢の老木から突き出しているのが見て取れる。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "館を取り囲む低木のあたりまで来ると、ホームズが立ち止まる。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い路地を出ると、敷石で舗装された四角い広場があって、取り囲むようにむさくるしい建物が立っていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪群来って中を取り囲むと、狼、群を飛び越ゆる。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　美奈子等の自動車の着くのを、先刻から待ち受けていたかのように、駅の群集の間から、五六人の青年紳士が、自動車から降り立ったばかりの、瑠璃子夫人の周囲を取り囲むのであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイヒイルばかりを穿きつけてゐたので、はじめのうちは何だか急に丈が低くなつて、足枷でもつけられたやうに情けなかつたが、もうすつかり慣れてしまつて、この頃では、ぽか／＼と霜を踏んで池のふちに駆けつけると、鵞鳥達もこの足音を聞き覚えて、忽ち吹雪のやうな羽ばたきをたてゝあたしを取り囲むのである。",
              "citation": {
                "source": "鵞鳥の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、きらびやかな行列を取り囲む群集の和讚である。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡検は数十人の兵を率いて、夜半にその家を取り囲むと、それは村内に知られた富豪であるので、夜なかに多勢が押し寄せて来たのを見て、賊徒の夜襲と早合点して、太鼓を鳴らして村内の者どもを呼びあつめた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂は母屋から十間以上もはなれた大きい桐の木の下に建てられて、その立木があたかもその三方を取り囲むように植えつけてありました。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　美奈子等の自動車の着くのを、先刻から待ち受けてゐたかのやうに、駅の群集の間から、五六人の青年紳士が、自動車から降り立つたばかりの、瑠璃子夫人の周囲を取り囲むのであつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "カントの説によれば、モーゼの書の第一巻すなわち創世記に『天蓋の下なる水』と記されているのは、多分地球を取り囲む、あたかも土星の輪のごとき『水蒸気』の環状分布を指すものである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後を取り囲む黒い雲が、今にも逼つて来はしまいかと云ふ心配は、陰ではいざ知らず、代助の前には影さへ見せなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし夜が明けると、射し入る光とともに、また病院の生活の眼ざめとともに、またしても様々の印象が大波をなして彼を取り囲むのだった。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者たちは、毎週土曜日の夕方になると決まって現われ、彼らを取り囲む人の数もしだいにふえ続けていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥穂高岳三月三十一日　晴後雪　柏矢町六・三〇　山番小屋八・五五　常念小屋三・一五　中山峠五・三〇　一ノ俣の小屋八・三〇　一ノ沢を取り囲む山は二月よりはズッと雪が少なくなっていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこれがもっと下等な生物になるともっと明瞭に現われて来るので、朝顔の蔓が眼も何もないのに竹の棒を探り当て、銀杏の根が密封した死人の甕を取り囲む。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "存在するものはただ、われわれの周囲を取り囲む、一つの世界あるのみである。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその樹木が一度地上に伸び出せば、それを取り囲むものは現代である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "前後を取り囲む黒い雲が、今にも逼って来はしまいかと云う心配は、陰ではいざ知らず、代助の前には影さえ見せなかった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒渉して来た川の方角へ引き返す代わりに、振り返ると彼を取り囲む暗い森の中へと進んで行った。",
              "citation": {
                "source": "チカモーガ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にさしかかると、海はますます青くなり、島々の周囲を白波が取り囲む。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同、それを取り囲む。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "年若くして逝つたものの傳説が、夭折者のまはりをとりかこむ人言が、彼等を覆ひかくすほどの長い歎きが、彼等を呼びかへさうとする聲、自然のなかにまで彼等を求めてやまない古代的な叫びが、――その歌のなかに彼等は一しよに入れられながら、互の姿を見ることのないあのリノス挽歌が。",
              "citation": {
                "source": "モオリス・ド・ゲラン",
                "author": "「そしてこの稀有で、偉大で、しかも果敢ないもの、一個の詩人」",
                "note": "青空文庫"
              }
            },
            {
              "text": "海はいつも異人の眼のやうに、やさしく碧くたたへられ、陽は入江や、入江をとりかこむ丘の上にみち溢れた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
