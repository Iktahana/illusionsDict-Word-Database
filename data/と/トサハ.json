[
  {
    "uuid": "180b650c-94a1-5650-b6f0-b68ecd4f65c8",
    "entry": "土佐派",
    "reading": {
      "primary": "とさは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
