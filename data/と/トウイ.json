  {
    "uuid": "d4b9aca3-6645-500d-b82c-57930cfb08ee",
    "entry": "頭囲",
    "reading": {
      "primary": "とうい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
