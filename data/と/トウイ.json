    "definitions": [
      {
        "index": 1,
        "gloss": "cephalic presentation (of the fetus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
