        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつも何かと言うと私の知恵袋にしておったアンタを、直接に松倉｜様に引合わせて、私とも膝をば突合わせたなら、三人寄れば何とやら、よい知恵が出まいとも限らぬ……と言う私の一生涯の知恵を絞ったドンドコドンのドン詰めの思い付きじゃが、ドウかいな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "板戸一つが直ぐ町の、店の八｜疊、古疊の眞中に机を置いて對向ひに、洋燈に額を突合はせた、友達と二人で、其の國の地誌略と云ふ、學校の教科書を讀んで居た。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と角目立ってあられもない、手先の突合いが腕の掴合いとなって、頬の引掻競。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の端の薄に顱巻を突合せて、あの親仁はまた反った。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雀同志は、突合って、先を争って狂っても、その目白鳥にはおとなしく優しかった。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姉さん、」　と、お蔦は俯向いた小芳を起して、膝突合わせて居直ったが、頬を薄蒼う染るまでその半襟を咽喉に当てて、頤深く熟と圧えた、浴衣に映る紫栄えて、血を吐く胸の美しさよ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、へい、五体が満足な彫刻物であつたらば、真昼間、お前様と私とが、面突合はせた真中に置いては動出しもすめえけんども、月の黄色い小雨の夜中、――主が今話さしつた、案山子が歩行く中へ入れたら、ひとりで褄を取つて、しやなら、しやならと行るべい。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "板戸一つが直ぐ町の、店の八畳、古畳の真中に机を置いて対向いに、洋燈に額を突合わせた、友達と二人で、その国の地誌略と云う、学校の教科書を読んでいた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これこれこう、こういう浴衣と葛籠の底から取出すと、まあ姉さんと進むる膝、灯とともに乗出す膝を、突合した上へ乗せ合って、その時はこういう風、仏におなりの前だから、優しいばかりか、目許口付、品があって気高うてと、お縫が謂えば、ちらちらと、白菊の花、香の煙。",
              "citation": {
                "source": "葛飾砂子",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "太神楽が、黒木綿の五紋の着流しで鳥打帽を被った男と、久留米絣にセルの袴を裾長に穿流した男と、頬杖を突合って休んだのを見ました。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一日おいて、また薄暮合、おなじ東の縁の真中の柱に、屋根の落葉と鼻を突合わせて踞んで、カーン、あの添水を聞き澄んでいたのです。",
              "citation": {
                "source": "菊あわせ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七畳の室に二十余人、その間に幼いもの三人ばかりを寝せてしまえば、他の人々はただ膝と膝を突合せて坐しおるのである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七疊の室に二十餘人、其間に幼いもの三人許りを寢せて終へば、他の人々は只膝と膝を突合せて坐し居るのである。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか彼とか弁解をする奴を相手の女学生と突合わせると、流石に両方共一度に屁古垂れてしまった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーリング海峡を距てて右の方を見ると、そこに海亀の頭のようなアラスカの突端が鼻を突合したように迫っていた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入生の一人々々を、学齢児童調書に突合して、健はそれを学籍簿に記入し、孝子は新しく出席簿を拵へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい五分心の吊洋燈二つの下に、入交りに男女の頭が両方から突合つて、其下を白い手や黒い手が飛ぶ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい五分心の吊洋燈二つの下に、入交りに男女の頭が兩方から突合つて、其下を白い手や黒い手が飛ぶ。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "新入生の一人々々を、學齡兒童調書に突合して、健はそれを學籍簿に記入し、孝子は新しく出席簿を拵へる。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同様にしていつか一度はこれより大規模な銀河系も衝突合体してそうして新たに作り直されるであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ小父さんの肥った身体が入ると皆膝と膝を突合せた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "立てば頭のつかへるほどな低い船室で、乗客は互に膝と膝を突合せて行つた。",
              "citation": {
                "source": "突貫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車が浅間の麓を廻るにつれて、乗客は互に膝を突合せて震えた。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸本は全く見知らぬ仏蘭西人と三等室に膝を突合せて気味悪くも思わないまでに旅慣れて来たことを感じながら、汽車の窓に近く身を寄せて秋のまさに過ぎ去ろうとしている仏国中部の田舎を見て行った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ自分の力と工夫で、ＷとＭを突合わせて、何もかも泥を吐かせてしまいたい。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど来合せた呉羽嬢と笠支配人にも突合わせてみたが、どちらも初めてと見えて何の感じも受けないらしい。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の事はない饗応の主人と客とマダ顔も合わせぬ先きに角突合いになって居るから可笑しい。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事実がないからないと云って、それが通用しないのなら、出鱈目を云っている人間と突合わして貰えるところまで押してゆくしか仕様がない」　こういう威嚇ばかりでなく、警察では例えば拘留がきまると親族に通知して貰えるキマリである。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "与次郎は、むろんぼくの意見であって、協会の意見であるとつごうのいいことを答えた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時将軍家のおなぐさみ用として用意してあったお鷹べやは、東狩りのときのご用のこの吉祥寺裏と、西狩りの場合のご用の大久保とつごう二カ所あったもので、この二カ所に飼育されている鷹が六十六羽。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
