[
  {
    "uuid": "84997420-e337-5356-a489-dfa727b7388d",
    "entry": "徒渉",
    "reading": {
      "primary": "としょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
