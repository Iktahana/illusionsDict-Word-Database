      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wade across",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この谷を一回、大きい徒渉をやる、つづいて二回の小徒渉をやる。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小渋川よりも、川幅が狭くて、谷地が、かえって濶いだけに、徒渉の回数は少い、深山の渓流としては、先ず安楽な方で、小渋川や、槍ヶ岳の蒲田谷などとは、深さと、急と、嶮しさとにおいて、到底、比べられない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、二回の徒渉をして、広河内へと達した。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速、焚火にかかって、徒渉に濡れた脚絆を乾すやら、大鍋を吊して湯を沸かしたりする。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "川楊の大木が、嵐にも洪水にも抵抗し抜いて、力も何も尽き果てたというように、ぐったりと根こそぎに、岸から川の中へ打ち倒れているのを、橋代りにして渡ったが、向う岸に着くまでには、三度ばかり冷たい水の徒渉をしないわけには行かなかった。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚破と、母屋より許嫁の兄ぶんの駈けつくるに、讀みさしたる書伏せもあへず抱きて立てる、栞の萩も濡縁に枝を浪打ちて、早や徒渉すべからず、あり合はす盥の中に扶けのせつゝ、盪して逃るゝ。",
              "citation": {
                "source": "婦人十一題",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "約一｜哩、干潟の徒渉。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、最も近い徒渉場たる十二ヶ瀬を渡ろうと急ぐや、越の殿軍甘粕近江守は川辺の葦間から一斉に鉄砲の雨をあびせたので、甲州兵悩まされながら、川の上下、思い思いに雨の宮の渡猫ヶ瀬等から川を渡り北進した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "数十頭のヤク牛が重い荷を負わされて雪解けの谿流を徒渉するのを見ていたら妙に悲しくなって来た。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあたり豐川ももうほんの溪谷となり、下駄ばきのまゝ徒渉出來るのであつた。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "草鞋も脚絆もとつて危ぶみながら徒渉して見ると水は漸く膝のあたりまでしかなかつた。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒渉して見たのが何となく嬉しかつた。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の漁村についてすぐに徒渉しえらるゝ程の小川があつて形ばかりの橋が架つて居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒渉して左岸に移り、石柱の下をつたう。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "徒渉して右峰に移る。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾度も忠別川を徒渉せざるべからざるが、ともかくも道路あり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝより溪を上に徒渉して、數十丈の絶壁の間を二三町も行けば、川水一落して、僅に五六尺の飛流となる。",
              "citation": {
                "source": "赤城山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあそこはことに由ると、橋が落ちてゐて、徒渉しなけれはならぬかも知れない。",
              "citation": {
                "source": "行つて見たいところ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、水でも出てゐると、何と言つても鬼怒川の本流だから、とても徒渉が出来なくなつて、そこから引返さなければならないかも知れないが、兎に角あそこの路は面白い。",
              "citation": {
                "source": "行つて見たいところ",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその湯檜曾の邊でも、銚子の河口であれだけの幅を持つた利根が石から石を飛んで徒渉出來る愛らしい姿になつてゐるのを見ると、矢張り嬉しさに心は躍つてその石から石を飛んで歩いたものであつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその湯檜曾の辺でも、銚子の河口であれだけの幅を持った利根が石から石を飛んで徒渉出来る愛らしい姿になっているのを見ると矢張り嬉しさに心は躍ってその石から石を飛んで歩いたものであった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなおりに、思いがけなく川に出水があって、徒渉りがしにくいと、この仙人は手にさげた折畳み式の馬に水を吹きかけます。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時の河であるから知れたものだと、多寡をくくって徒渉を試みると、案外に水が深く、流れが早く、あやうく押し流されそうになったことも再三あった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして徒渉りの者をみると、必ずそれを背負って南へ渡した。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の淺い時は、山の人たちは、徒渉るのと見えて大きな岩が川の中に並んでゐる。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "またの名を白足和尚と呼ばれただけあつて、足の色が顔よりも白く滑らかで、外を出歩く時雨上りの泥水の中をざぶざぶと徒渉りしても、足はそれがために少しも汚されなかつたといふことだ。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ上野から出たので、折角の和田峠へ差しかかつたのはすでに夜で、翌日は今にも降出しさうな空合だつたけれど、快晴を待つ訳にもいかないので更にある地点まで（下諏訪から東｜餅屋まで）道をダブつて、そこから鷲ヶ峰、霧ヶ峰への徒渉を始めたので、結局あたら第一日の好晴を汽車とバスに徒消したことになつた訳である。",
              "citation": {
                "source": "霧ヶ峰から鷲ヶ峰へ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの若侍に目が付いたか」「眼が付かいで何としょう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "斬んなさったか」「斬らいで何としょう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "小用を足して来てから――楽寝としょうか。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
