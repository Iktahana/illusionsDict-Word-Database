    "definitions": [
      {
        "index": 1,
        "gloss": "adds vagueness and indirectness to the word or phrase it is used with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
