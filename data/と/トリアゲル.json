    "definitions": [
      {
        "index": 1,
        "gloss": "to pick up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが溝の崖のずつと下の方に引つかゝつて容易には取り上げる事が出來ないので、其儘にして歸つた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年はなぜこれが早く判らなかったのだろうという顔つきをして、嬉しそうに箸を取り上げる。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "床几の上に残って居た進藤の大刀を大吉が取り上げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれ取り上げるの、年貢をあげるので、すったもんだ云わんだけでも、なんぼよけりゃ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方が妾をお呪咀いになるためにドンナ作りごとを仰言っても取り上げる人はおりませんからね。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが溝の崖のずっと下のほうに引っかかって容易には取り上げる事ができないので、そのままにして帰った。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、これがなかったら、われわれは食膳に向かって箸を取り上げることもできないであろうし、門の敷居をまたぐこともできないであろう。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が卵を食うと自分も卵を取り上げる。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡瀬が酔ったまぎれに「おぬいさんに惚れろ」といい続けた時、園はそういう問題を取り上げる気持は少しもなかったが、その後四五日経ってから、どうした機会だったか、園はふとおぬいさんに対する自分の心持を徹底的に決めておかなければならぬという強い要求を感じ始めた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞよろしく」　勃凸はそれを取り上げると蟆口の底の方に押し込んだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁のある人が避け難き運命の下に、恋愛に遭遇して、止むを得ず取り上げるようにしてはじめて必然性が見出されます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄斎も立ち上りかけて、先刻武士が置いて行った縁先きの金包みに気が付き、手に取り上げる。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は何故これが早く判らなかったのだろうという顔つきをして、嬉しそうに箸を取り上げる。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「失念った※」と叫んで暫時我を忘れて茫然としたが、たちまち気を取り直して、側に放げ棄てておいた自分の鉄砲を取り上げるや否や、駆け出そうとすると、何物にか躓いてばったり仆れた。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大将の靴ドロドロだっせ」　三郎がブラシを取り上げると、亀吉は、「阿呆！",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから杉折りを取り上げるとペキンペキンと押し割って薪のように一束にして、戒名と一緒に奉書の紙に包んだ上から黒水引きでグルグル巻きに縛った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら兄さんでも、半分宛わけて貰ったこの国を取り上げるようなことを云うのは乱暴だ。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに積んであった薪を片づけて、分捕りスコップ（日露戦役戦利｜払下品）を取り上げると、氷のような満月の光を便りに、物音を忍ばせてセッセと掘り初めたが、鍬と違って骨が折れるばかりでなく、土が馬鹿に固くて、三尺ばかり掘り下げるうちに二の腕がシビレて来たので、文作はホッと一息して腰を伸ばした。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お金を下さってよろこばせて、そうしてすぐにまた取り上げるとは、あんまりですわねえ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "會計をさせられる樣になるかも知れないが、お母樣が樂にしてお出なさるものを、無理に取り上げるには及ばない。",
              "citation": {
                "source": "半日",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら兄さんでも、半分｜宛わけて貰ったこの国を取り上げるようなことを云うのは乱暴だ。",
              "citation": {
                "source": "奇妙な遠眼鏡",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、美沢の手から団扇を取り上げると、ストンと脚を投げ出し、横坐に坐った。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、云いながら細いきれいな指で無造作に、その封筒を取り上げると、舞台から持って来たような眼顔で会釈をして、ハンドバッグの中に収めた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、紀久子はふたたびストーブの前へ駆け戻って、そこにある腰掛けを取り上げるとそれでストーブをぐいっと押し倒した。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれはまだピストルを取り上げる前に、ホームズの武器に狙われてしまった。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そういって、鉄の火掻き棒を取り上げると、ぐいと力を入れて元の通りまっすぐに伸ばした。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　友人は二通目の手紙を取り上げる。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り上げると、その下に挟まっていた四角い小紙片がひらりと地面に落ちる。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "この問題をふたたび取り上げる初めに、検死をした外科医のいまわしい報告についてちょっと言うことにしよう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇〇四年一一月二六日の第四回小委員会からはいよいよ、法改正に向けて、何を優先して取り上げるかに関する論議が始まった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
          ]
        }
