    "definitions": [
      {
        "index": 1,
        "gloss": "to fly about",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "潮｜退きて洲あらわれ鳥の群、飛び回る。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "船客の飼っている小鳥が籠を放れて食堂を飛び回るのをつかまえようとして騒いでいた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど世界のコンピューターを居ながらにして飛び回るのは、やはり面白い体験です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラウンドに現れた選手は身振りよろしく空を蹴つて、グルグルと飛び回る、ボールを奪ひ合ふ様がある、一勢に脚をふまへて縦にそろつて、脚から脚の間を球をうけ渡して行く様がある――それツ！",
              "citation": {
                "source": "舞踏学校見物",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎が群れをなして猫に似た声でなきながら、船のまわりを水に近くのどかに飛び回るのを見るのも、葉子には絶えて久しい物珍しさだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツのタウベ飛行機が、夏の空高く、黒い十字を描いた翼を閃しながら、ワルシャワの街の上を飛び回ることがあった。",
              "citation": {
                "source": "勲章を貰う話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究会の末席に加えてもらうようになった僕が、学費と生活費にきゅうきゅうとしてアルバイトに飛び回るのを見て、雑誌を起こしていたリーダーが「うちで働くか」と声をかけてくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全米を飛行機で忙しく飛び回るエグゼクティブ向けのポータブル機」というアイディアに、ローゼンは興味を示したが、それだけでは満足しなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが試作した端末が機能することを確認すると、ウォズニアックの興味は、この端末を使って、すでに運用が始まっていた研究者用のコンピューターネットワークを飛び回ることに移った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "はえしげる草木、飛び回る禽獣、さては女のめでたさ、子供の愛らしさ、あゝわしは生きたい生きたい。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方にでもなると街道から遠く望まれる恵那山の裾野の方によく火が燃えて、それが狐火だと村のものは言ったものだが、そんな街道に蝙蝠なぞの飛び回る空の下にも子供がいた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ穴からはいだして、思いきって古いからをぬぎすてた時は、まだ高い声で鳴くことも知らず、木と木の間を飛び回ることも知りません。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはみんな一緒になり、ぐるぐる飛び回る。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "西は松原のつづきで、松の木陰をもるる太陽の光線が白壁へ映って、ちょうど首なしの人形のようで、それが颯々風の吹くたびに動くので、飛び回るように見えるのだ。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の幻想の中を縦横に飛び回るそのイメージは目覚めている間に古文書と現代の囁きから演繹した最悪のものに比べても千倍も不愉快だったのだ。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まで見たこともないような蜘蛛の類の、そこかしこに掛けられた巣にも目が留まり、巨大な蝙蝠の骨張るグロテスクな翼を広げ先も見えない暗闇を飛び回る様子もありました。",
              "citation": {
                "source": "錬金術師",
                "author": "THE ALCHEMIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄輪をグライダーで飛び回るなど危険極まりない、というのがその表向きの反対理由だったが、そんなものは「別府に相応しくない」というのが本音らしかった。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "親指をちょこちょこやりながら鍵の上をできるだけ早く飛び回ることや、二本の隣りの指の間にぎごちなくこびりついてる薬指をしなやかにすることだった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "音もなく飛び回る蝙蝠、また、古い家の内部に動めいてるのがよくわかる恐ろしい怪物、大きな鼠や毛の生えた大｜蜘蛛など、それから、何を言ってるのか自分でもよくわからない、寝台の足もとでの祈祷、尼たちの就寝時間を告げる近くの僧院の小さい鐘の急な音。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、夢想の群れが心の中であまりに騒々しく飛び回るとき、頭がふらふらするとき、彼女はピアノについて、低音の鍵にとりとめもなく指を触れながら、音響の和やかな光明で、生活の迷夢を包み込むのであった……。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽がはえて空中を飛び回る代物である。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから自分のベンチの方へ戻って腰を掛け、小道のうちを無遠慮な雀が飛び回るのをながめ、自分が嘲られてるような気がしながら、四時間もじっとしていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を打つ鞭としては確かに困窮を持っており、飛び回る翼としては確かに快活を持っていた。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは祖父が夢想したような空色の祝典ではなく、新郎新婦の頭上に天使や愛の神が飛び回る夢幻的な祝いではなく、門の上に美しい彫刻帯をつけるのにふさわしい結婚ではなかった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は再び漕ぎ始め、黒く長い翼の鳥が水面近くで飛び回るのを見つめていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "トビウオが次々と海面から跳ね、鳥がむなしく飛び回る様子を、老人はじっと見ていた。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はぶんぶん蜜蜂が飛び回るこの巣の上に、まるで前もって蜜を吸ってしまいかねないような視線を投げかけた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金の時間がめくるめく過ぎて、至福の刹那はまるで浮かれた蝶々が花々を飛び回るかのようで、しめて一時間が過ぎた。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、雪の中で冬を過し、夏、道路に棄てられた馬糞が乾燥してほこりになり、空中にとびまわる、それを呼吸しているうちに、いつのまにか、肉が落ち、咳が出るようになってしまった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　妻は、とびまわる子供にきつい顔をして見せた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
