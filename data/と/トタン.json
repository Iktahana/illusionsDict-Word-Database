    "definitions": [
      {
        "index": 1,
        "gloss": "corrugated iron",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのほか寿司の屋台が出てゐる日があり、今日はそれは見えなかつたが、四五本の柱にトタン屋根を張つた、一時拵への氷店が出来てゐた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにフケが落ちる、　　　秋の夜に、雨の音はトタン屋根の上でしてゐる。",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の車庫のトタン屋根に雀が二羽、一羽がちょんちょんと横飛びをして他の一羽に近よる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴後の茶漬も快く、窓によれば驟雨沛然としてトタン屋根を伝う点滴の音すゞしく、電燈の光地上にうつりて電車の往きかう音も騒がしからず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロレタリアの群居街からは、ユラユラとプロレタリアの蒸焼きの煙のような、見えないほてりが、トタン屋根の上に漂うていた。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "永い間雨曝しになつて居るらしい鐵の構造物はすつかり赤錆がして、それが青いトタン屋根と美しい配合を示して居る。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しいことには、古来の屋根の一型式に従ってこけら葺の上に石ころを並べたのは案外平気でいるそのすぐ隣に、当世風のトタン葺や、油布張の屋根がべろべろに剥がれて醜骸を曝しているのであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治大学前に黒焦の死体がころがっていて一枚の焼けたトタン板が被せてあった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、土方風の男が一人縄で何かガラガラ引きずりながら引っぱって来るのを見ると、一枚の焼けトタンの上に二尺角くらいの氷塊をのっけたのを何となく得意げに引きずって行くのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車から見た青森市の家はほとんど皆トタン葺またはコケラ葺の板壁である。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに汚ない話で失礼。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の眼のさきの、マッチ工場のトタン塀に添うて、並んでいるアカシヤは、初々しい春の芽を吹きかけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの僅かの一部分だけは、トタン塀が張られていなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタン屋根を撲つ音。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝トタン屋根に足跡が印されてあった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、寝床のなかで行一は雪解の滴がトタン屋根を忙しくたたくのを聞いた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一段高まる経の声、トタンにはたたがみ天地に鳴りぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る間に水を離れて、すれ違って、背後なる木納屋に立てかけた数百本の材木の中に消えた、トタンに認めたのは、緑青で塗ったような面、目の光る、口の尖った、手足は枯木のような異人であった。",
              "citation": {
                "source": "木精（三尺角拾遺）",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と一斉に声を合わせるトタンに、故郷も、妻子も、死も、時間も、慾も、未練も忘れるのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに框の取着の柱に凭れた浅黄の手絡が此方を見向く、うら少のと面を合わせた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに向うざまに突出して腰を浮かした、鋸の音につれて、又｜時雨のような微な響が、寂寞とした巨材の一方から聞えた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに、其の衣絵さんの白い幻影を包むで隠さうとしたのである。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根のトタンにも石にも一面に名前や日付が刻みつけてあります。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に奥様にでもお代を頂戴に行こうかと思っておりますところへ、今日ヒョックリ先生がお見えになる……トタンに今の夕立で御座いましょう。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに……それをキッカケにしたように四つの夜具が一斉に跳ね返された。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに東京が底の知れないほど恐ろしくなった。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに明るい往来一面にホコリが立つ。",
              "citation": {
                "source": "塵",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トタンに私は酒が飲みたくなった。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗けたのか」　と頬を膨らましてスゴスゴ引き退るトタンに大爆笑と大拍手が敵味方から一時に湧き返るという、空前絶後の不可思議な盛況裡に、無事に予定の退却となった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い間雨ざらしになっているらしい鉄の構造物はすっかり赤さびがして、それが青いトタン屋根と美しい配合を示している。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
