        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西那須からは三島｜通庸君が栃木県令時代に俗論を排して開いた名高い三島道路。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ道は最も奥で、山は就中深いが、栃木峠から中の河内は越せそうである。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦になって、何が何やら、ただへとへとに疲れて、誇張した言い方をするなら、ほとんど這うようにして栃木県の生家にたどりつき、それから三箇月間も、父母の膝下でただぼんやり癈人みたいな生活をして、そのうちに東京の、学生時代からの文学の友だちで、柳田という抜け目の無い、なかなかすばしこい人物が、「金はある。",
              "citation": {
                "source": "女類",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州赤城の麓で育った安宅先生は、栃木県下で女学校の体操教師をしているときに、スキー場で学園創立以前の校長先生と知合いになり、その人格材幹を認められて、校長先生の出資により、スポーツの国フヰンランドに留学をした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは栃木県の某温泉場で、下には澄みきったＫ川の流れがあって、対岸にそそりたった山やまの緑をひたしていた。",
              "citation": {
                "source": "藤の瓔珞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは栃木県のもので、有一館時代に知りあいになったものである。",
              "citation": {
                "source": "雨夜続志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "名にし負ふ栃木峠よ！",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そら、そういった工合で、東京中は喰い詰める――し、勿論何でさ、この近在、大宮、宇都宮、栃木、埼玉、草加から熊ヶ谷、成田、銚子。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は兼次の叔父が聟に行つて居る栃木の在へ辿りついた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜木林を借りて木の根を掘り起してそこへ作つた陸稻をたべた口には栃木在の米は實にうまい。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は栃木県の或る町で空腹に襲はれた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "當年知事たりし三島通庸は、山形縣に、福島縣に、栃木縣に、到る處新道を開けり。",
              "citation": {
                "source": "鹽原新七不思議",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎左衛門には栃木の町に許婚の娘があったが、そんなわけで破談となった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「大錦と栃木は強いな。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすれば、世界にもめづらしいと言はれてゐるあの阿蘇の噴烟も、あの宮地にある阿蘇神社も、その火口瀬である数鹿留の瀑も、戸下温泉も、栃木温泉も、皆なその行程の中に入つて行つた。",
              "citation": {
                "source": "女の温泉",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山の尾根は上州と野州との國境をなすところで、頂上の路ばたには群馬縣栃木縣の境界石が立つてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "背伸びをしながら其處の落葉の中に腰をおろすと、其處には群馬栃木の縣界石が立つてゐた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "背伸びをしながら其処の落葉の中に腰をおろすと、其処には群馬栃木の県界石が立っていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この都賀山、安蘇山は、鹿沼からも入つて行ければ、栃木からも入つて行けた。",
              "citation": {
                "source": "日光",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは栃木県のもので、久しく宇都宮に教鞭をとっていたが、一昨年埼玉県に来るようになって、ちょっと浦和にいて、それからここに赴任したという。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "茨城、千葉、栃木、群馬、の近県は勿論のこと、九州、越後、奥州、までのして歩いたよ。",
              "citation": {
                "source": "本因坊と私",
                "author": "関根金次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾年かむかし、栃木山と一緒に附出しとなつて初めて土俵の砂を踏んだ力士が十幾人かある。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかで、づば抜けて出世をしたのが栃木山で、それに次いでは東の幕下十枚目に羽州山がゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "栃木山が幕下から初めて幕内へ飛び上つて来た時、彼は贔屓客に貰つた御祝儀のなかから幾らかを無雑作に包んで羽州山の前に出した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "栃木山はその後｜鰻上りに三役に入つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして栃木の出世にあやかるやうにと言つて、鱈腹飲んだり、食つたりした。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆は蛙のやうに膨らまつた腹を抱へて、栃木の前途を祝福した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蔭で栃木は今度いよ／＼横綱を張る事になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の切り株　栃木県の矢板のステーションのすぐそばの杉林の一部が思い切り長く切りはらわれて居た。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本名勇造、山本有三は一八八七年、明治二十年に、栃木町に生れた。",
              "citation": {
                "source": "山本有三氏の境地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
