    "definitions": [
      {
        "index": 1,
        "gloss": "to light (a candle, lamp, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "戀々として、※徊し、漸くにして里に下れば、屋根、廂、時雨の晴間を、ちら／＼と晝灯す小き蟲あり、小橋の稚子等の唄ふを聞け。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の小さきものとは違いて、夏の宵、夕月夜、灯す時、黄昏には出来らず。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一つひとつ染め抜きたるを、夥しく釣して懸け、夕暮には皆｜灯すなりけり。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "貰ひものなれども余の陋室に灯す術もなからむ。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "水車小屋の二階では灯すわけには行かなかつたので、僕は古くからの愛用の台ランプを仁王門の離室へ預けて置いた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "・空梅雨いちにち、どなられてぶたれて馬の溜息・空は空梅雨の雨蛙なくとても・その竹の子も竹になつた、さびしさにたへて・もう死んでもよい草のそよぐや（帰庵病臥二句）・死ねる薬はふところにある草の花・灯すよりぶつかつてくる虫のいのちで（改作）　七月十五日今日も曇つてゐるが、降りさうでなか／＼降らない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯すものはなくなつたが、月があかるい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋のおさらいは昼よりも灯する頃より夜と共に興｜闌なるがつねだ。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは蝋燭を灯すに用い多く会津で出来た、いわゆる絵ローソクを使ったもので、今日でも東本願寺など浄土宗派のお寺ではこれを用いている。",
              "citation": {
                "source": "亡び行く江戸趣味",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、その部分を洗ったにした所で、後で蝋燭を鉄芯の間際迄灯すから、尖鋭な槍先から下の不自然な部分が流れる蝋ですっかり隠されてしまう。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車は走り出したが、魚籃のところで東京地区の警報発令、車内は全部消灯する。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の隅には、危険信号用の旗がある、昼はこれを掲げるか、又は棒の先に着物をつけて、一分｜毎に上げ下ろしする、夜は備付けのランターンを灯すことになっているが、然しここは、村からは見えないし、いざとなった時、信号が役に立つかどうか、頗る疑わしいと思う。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う語り終つたお嘉代は、亡夫の望を果し得なかつた腑甲斐なさと、十五年間の爪に灯すやうな苦心を思ひ起して、たゞさめ／″＼と泣くのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "縞の財布",
                "note": "青空文庫"
              }
            },
            {
              "text": "――父は口癖のやうに、――私は百姓の子に生れて、中年から江戸に出たが、一生｜爪を灯すやうな辛棒をしても、たつたこれだけの身代を拵へるのが關の山であつた。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘と二千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう語り終ったお嘉代は、亡夫の望みを果し得なかった腑甲斐なさと、十五年間の爪に灯すような苦心を思い起して、たださめざめと泣くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "縞の財布",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪に火を灯すと言ひませうか、三度の物も二度にして、十年越し、浴衣一枚買つたことも御座いません」　お濱は一生懸命さの中にも顏を赧らめました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "九百九十兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪に火を灯すような、江戸第一番の吝ん坊の鳴子屋は、いかにもそれくらいのことがありそうです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪に火を灯すと言いましょうか、三度の物も二度にして、十年越し、浴衣一枚買ったこともございません」　お浜は一生懸命さの中にも顔を赧らめました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "九百九十両",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の曇り　かつ／″＼そよぐ稲の　短きにはかに征ちゆきて　兄ははろけきに、二十日がほどを　雨多く　すぐ田も　川も　水荒れの痕いちじるしく、汽車　海沿ひとなりて来にけり軒ふかくとざす夜霧に　灯す山。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓掛を下ろし蝋燭を持つて來て灯すばかりにしておいた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の灯が白くなる冬になると、河豚屋のかんばんが食通横丁に俳味を灯す。",
              "citation": {
                "source": "河豚",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――――――――　十二月五日――盗聴者の一件以来、寝室に常夜燈を灯すようになり、睡眠は妨害されなくなった。",
              "citation": {
                "source": "盗聴者",
                "author": "Ａ. ブラックウッド　A. Blackwood",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の盆にはかならず舞子があの灯籠に蝋燭を灯すはずだ、と僕は思った。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋に明かりを灯す頃、彼女は普通と変わりのない状態になり、趣味の手芸を始めたりする。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "必要なときにどちらかでも灯すなら、庭は充分に明るくなるのだった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いストップ・ランプが点灯する。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "以後幾日かは、城外盛り場の灯すらともらず、沼のような凄気が昼も冷たく吹いていた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁村の灯すら見えない大風の晩である。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちの用意がよかったら御苦労だがまたいつもの所まで送って貰おうか」「それじゃすぐにお出かけなさいますか」「ウム、明りを灯すにも及ぶまい」　膝の傍の大刀を寄せて、腰にたばさむと、あたりの物を片づけて、静かに、そこを立上がった様子です。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かじかむ手、白い息、みずから灯す燈明の虹の中に彼はふと耳をすまして、頼春頼春、と二た声ばかり呼んだ。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
