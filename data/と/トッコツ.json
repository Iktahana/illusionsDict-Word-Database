        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "即ち実に多くの新奇な流派が簇出したのであつて、その多くのものは間もなく廃たれ、ジイドは突兀として残つてゐるのである。",
              "citation": {
                "source": "アンドレ・ジイド管見",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君はこの空ら風の中を突兀として、忙しそうな往来の人を眺めて歩く。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平地に突兀として盛り上る土積。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まわりの円味がかった平凡な地形に対して天柱山と吐月峰は突兀として秀でている。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び石のそばに突兀としてそびえた楠の木のこずえに雨気を帯びた大きな星が一ついつもいつもかかっていたような気がするが、それも全くもう夢のような記憶である。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして右をふり仰ぐと突兀たる小浅間の熔岩塊が今にも頭上にくずれ落ちそうな絶壁をなしてそびえ立っている。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の南側は、太古の大地変の痕跡を示して、山骨を露出し、急峻な姿をしているのであるが、大垣から見れば、それほど突兀たる姿をしていないだろうという事は、たとえば陸地測量部の五万分一の地形図を見ても、判断する事ができる。",
              "citation": {
                "source": "伊吹山の句について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河中に岩石｜突兀として橋を架ける便宜が無いのと、水勢が極めて急激で橋台を突き崩して了うのとで、少しく広い山河には一種の籠を懸けて、旅人は其の両岸に通ずる大綱を手繰りながら、畚に吊られて宙を渡って行く。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "対岸の平沙の上にＭ山が突兀として富士型に聳え、見詰めても、もう眼が痛くならない光の落ちついた夕陽が、銅の襖の引手のようにくっきりと重々しくかかっている。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二等よりもより雑然たる諸相の中から、湧き出る、溢れ出る、転がり出る、飛び出る、それらの如く、蠢々として、哀々として、莞爾として、突兀として、二人三人五人の青年たちがむくりむくりと起き上って来た。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇岩｜突兀として聳え立つその頂上に近代のホテルを建て更に岩石層の縦の隧道をくりぬき、しんしんとエレヴェーターで旅客を迎える計画だそうである。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "削壁突兀として青松其間を綴る。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は下り、向ひて高低ある石突兀として頗る惱む。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に至りて鐵面子を待つ馬は、急坂突兀たるを以て注意して下る故に遲々として進まず、久うして至る。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "突兀と秋空を劃る遠山の上を高く雁の列が南へ急ぐのを見ても、しかし、将卒一同｜誰一人として甘い懐郷の情などに唆られるものはない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道の左側には、巨大な羊歯族の峡谷を距てて、ぎらぎらした豊かな緑の氾濫の上に、タファ山の頂であろうか、突兀たる菫色の稜線が眩しい靄の中から覗いている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実にかくの如く突兀・奇峭にして、又絢爛を極めた言葉の豪奢な織物でなくては、とても、氏の内なる美しい幻想を――奇怪な心象風景を――写し出すことは出来ないのである。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻が赤く、苺のように点々と毛穴が見え、その鼻が顔の他の部分と何の連絡もなく突兀と顔の真中につき出しており、どんぐりまなこが深く陥ち込んだ上を、誠に太く黒い眉が余りにも眼とくっ附き過ぎて、匍っている。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我目前には猶突兀たる山骨の立てるあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "突兀たる岸の巖には波がだん／＼強く打ちつけて小船が更に動搖する。",
              "citation": {
                "source": "鉛筆日抄",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を渡ると海中には突兀として岩石が峙つて居る。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "仰げば、金洞の三山、突兀として高い哉。",
              "citation": {
                "source": "妙義山の五日",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の突兀として聳えた形にあるのである。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に見た耶馬渓ではなくて、奇岩突兀とした耶馬渓であつた。",
              "citation": {
                "source": "耶馬渓の一夜",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇岩突兀として聳つその頂上に近代のホテルを建て、更に岸石層の縦穴をくりぬき、しんしんとエレベーターで旅客を運ぶ計画ださうである。",
              "citation": {
                "source": "白帝城",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が下には隱家もなくなつて、今｜現身の英傑は我が目前咫尺の處に突兀として立ち給うたのである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "天が下には隠家もなくなつて、今｜現身の英傑は我が目前｜咫尺の処に突兀として立ち給ふたのである。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士の随伴と見える両人の婦人は、一人は今様おはつとか称える突兀たる大丸髷、今一人は落雪とした妙齢の束髪頭、孰れも水際の立つ玉｜揃い、面相といい風姿といい、どうも姉妹らしく見える。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "三層五層の楼閣は突兀として空を凌ぎ、その下層はかへつて崖低く水に臨む処にあり。",
              "citation": {
                "source": "四百年後の東京",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寺の建築は小き者なれど此処の地形は深山の中にありてあるいは千仞の危巌突兀として奈落を踏み九天を支ふるが如きもあり、あるいは絶壁、屏風なす立ちつづきて一水｜潺々と流るる処もあり、とにかくこの辺無双の奇勝として好事家の杖を曳く者少からず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
