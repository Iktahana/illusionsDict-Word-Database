    "definitions": [
      {
        "index": 1,
        "gloss": "to jump out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今にも席から飛び出すかと思われたが、そうもしなかった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんべんも考えて見たが……おっ母ァ一人残してうちを飛び出す事は俺には出来ねえ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝三次宅　素早く手襷、鉢巻の三四郎、　おっ取り刀で飛び出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「待ってたんだ」　と云って五六歩、後退り、へへへと笑い、Ｔ「馬鹿野郎の　飛び出すのをなァ」　と云う。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその代の更り目には、赤や青の煙の塊が飛び出すのであった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ飛び出すんだよ。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾たびも飛び出す樫鳥は、そんな私を、近くで見る大きな姿で脅かしながら、葉の落ちた欅や楢の枝を匍うように渡って行った。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあたかも蛇の皮を脱するごとく、物体の表面からはがれて、あとからあとからと八方に飛び出す。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん初めに高所から見たパリの市街が現われ前景から一羽のからすが飛び出す。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その效果を凡そかうであらうと推察したとたんに、また新しい效果が飛び出す。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田島は、一足さきに外に飛び出す。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちの仕事はな、地殻の底の底で、とけてとけて、まるでへたへたになった岩漿や、上から押しつけられて古綿のやうにちぢまった蒸気やらを取って来て、いざといふ瞬間には大きな黒い山の塊を、まるで粉々に引き裂いて飛び出す。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちの仕事はな、地殻の底の底で、とけてとけて、まるでへたへたになった岩漿や、上から押しつけられて古綿のようにちぢまった蒸気やらを取って来て、いざという瞬間には大きな黒い山の塊を、まるで粉々に引き裂いて飛び出す。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のダルマさんが向う鉢巻でタワシ細工の熊に乗っていの一番に飛び出す。",
              "citation": {
                "source": "キューピー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とまで云われて私も急に力が着きましたから、『よろしい、それではともかくも一応叔母と相談して、叔母が承知すればよし、故障を言えばお前のいう通り、お幸と二人で大阪へでも東京へでも飛び出すばかりだが、お幸はこれを承知だろうか』『ヘン！",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "半日も下宿に籠って見厭きた室内、見厭きた庭を見ていると堪えられなくなって飛び出す。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スワ何事の出来と、四人一度に飛び出す。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いふことも慌てながら戸外へ飛び出す。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ぐら／＼と來るか、おツと叫んで、銅貨の財布と食麺麭と魔法壜を入れたバスケツトを追取刀で、一々框まで飛び出すやうな卑怯を何うする。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいて表へ飛び出すと、町内の家具屋が燃えてゐるんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼まれて、よっしゃ、今ないけど直ぐこしらえて来たる、二時間だけ待っててくれへんかと言って、教室を飛び出すものの、じつはあの人には金策の当てが全くないのだ。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「素姓みたいなもン知るもんか」　豹吉はペッと唾を吐いて、「――女に惚れるのに、いちいち戸籍調べしてから惚れるくらいなら、俺ははじめから親の家を飛び出すもんか」　古綿をちぎって捨てるように言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、家を飛び出すだけあって、あんたも随分おつな科白が飛び出すわね。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらッ」　その声を背中にきいて、小沢はその家を飛び出すと、その足で渡辺橋までかけつけた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "小沢は宿屋を飛び出すと、雪子の行方を探して歩いた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼け出された様な火夫の服のまゝではいくら何でも帰れないと、家を飛び出す時に着ていた着物を新聞紙に包み、何喰ぬ顔で船から降りようとすると船長が怪しんでそいつは何だ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "39　青年は周章てて船室を飛び出す。",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん赤くなって、しまいには当り前の鉄と同じように美しい火花がパチパチと飛び出す位柔らかに焼けて来ました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の頭を鉄鎚で殴ると眼が飛び出すって聞いていたが本当か知らん。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "錠をおせば、このトランクは、たちまちとびだすしかけになっていたのでした。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
