[
  {
    "uuid": "8e5d281a-a051-5a18-afb0-39bda4719d4b",
    "entry": "東南",
    "reading": {
      "primary": "とうなん",
      "alternatives": [
        "ひがしみなみ"
      ],
      "is_heteronym": false
    },
    "grammar": {
