    "definitions": [
      {
        "index": 1,
        "gloss": "constable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "棚倉が、Ｔ「盗人で御座る」　と呼んで捕方と共に追う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋表　棚倉一味と捕方が、Ｔ「確にこの長屋だ――」　と叫ぶ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋の外　捕方の一人が、Ｔ「もう袋の鼠だ」　と云う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋　棚倉等と捕方が協力して長屋を一軒一軒調べる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛初め捕方連が長うなって倒れて居る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）左衛門宅大広間の次の室には　ふんぞり七兵衛の率いる捕方が合図如何と待ちかまえる。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左衛門が右手を上げると、　襖を開いて数十の捕方。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛が、Ｔ「なりひら小僧御用だ※」　せせら笑ったなりひらが、Ｔ「そう来るだろうと思ったよ」　左衛門の命に捕方がじりじり迫る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "検視の捕方と仕出し若干、死体を取り巻いて立って居る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "４６＝本堂　和尚が今度は男達に、Ｔ「拙僧が今、御教え致しました室に」　と云って、Ｔ「貴女の想う御婦人が、貴下の来るのを待って居られます」Ｔ「御仏が御許しなされたのです」Ｔ「勇敢に御進みなさい」４７＝門前　伝六の率いる捕方の一隊ひしひしと詰めかけた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時６１＝玄関　雪崩れ込む捕方の一隊、寺中は大混乱の巷と化します。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "46＝本堂　和尚が今度は男達に、Ｔ「拙僧が今、御教え致しました室に」　と云って、Ｔ「貴女の想う御婦人が、貴下の来るのを待って居られます」Ｔ「御仏が御許しなされたのです」Ｔ「勇敢に御進みなさい」47＝門前　伝六の率いる捕方の一隊ひしひしと詰めかけた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時61＝玄関　雪崩れ込む捕方の一隊、寺中は大混乱の巷と化します。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも、その屍体は捕方の手に依つて、三條縄手の三縁寺境内へ運ばれて、棄てゝ置かれた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地の者はその飴屋を隠密だとか捕方だとか云っているそうだが、よもやそんなことはあるめえな」　隠密や捕吏が何かの恨みを受けた為に、或いは何かの犯罪露顕をふせぐ為に、闇討ちに逢うようなことが無いとは云えない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代でも捕方に助勢して首尾よく罪人を取り押えたものにはお褒めがある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋川の橋は、捕方が固めていたので、一里ばかり下流を渡った。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕方の総攻めを喰ったときは、二十七人しか残っていなかった。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時のごとく目にはいったものは、町々つじつじを堅めているものものしい捕方たちの黒い影です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいていの捕方だったら、品物が品物だからおそらくたんすか長持ちといったような貴重品の入れてある家財道具に着目すべきところを、右門は例のごとくその逆のからめてをたどって、なるべくなんでもなさそうなところ、くだらないちょっとしたところというような個所にばかり、鋭い視線を働かせていきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「無手なら草香流、得物をとらば血を見ないではおかぬ江戸まえの捕方じゃ、それでも来るか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをお母様がお作りになったらどんなにか綺麗だろうと思っておりましたが、お母様は案外にも、そんな絵の中から八犬伝の中で犬塚信乃と犬飼現八と捕方三人を描いた五枚続きのをお選り出しになりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかんは不安らしく表をのぞいてゐると、路地の口より石子伴作は捕方の者ふたりを連れ、雲哲と願哲を先に立てて出づ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）伴作　（捕方をみかへる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（捕方は駕籠の垂簾をあけて、勘太郎をひき出す。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕方　えゝ、立て、立て。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（伴作は先に立ち、捕方は無理に勘太郎を引立てて下のかたに去る。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人の友達のうちに町奉行所の捕方すなわち岡っ引の一人があったので、それからいろいろの捕物の話を聞かされたと云うのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、それから、急き込んで、駅長へ、「Ｎ駅へその男の逮捕方を打電して下さい。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は新たに、この幼なきものゝために、山の如くつまれた雑務をとりかたづける為めに起き上った。",
              "citation": {
                "source": "かなしみの日より",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
