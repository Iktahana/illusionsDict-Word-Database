        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎晩毎晩、酔っては討論会を初めますわ！",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴室では神崎、朝田の二人が、今夜の討論会は大友が加わるので一倍、春子さんを驚かすだろうと語り合って楽しんで居る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "依りてある寺を借り受けて教場を開き、夜は更に昼間就学の暇なき婦女、貧家の子弟に教え、母上は習字を兄上は算術を受け持ちて妾を助け、土曜日には討論会、演説会を開きて知識の交換を謀り、旧式の教授法に反対してひたすらに進歩主義を採りぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの芝居は幕間が長いから、こんな討論会にはおあつらえ向きです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてついには、いわゆる講義や演説が壇上の人と壇下の人々との対話になって一種の討論会が現出する。",
              "citation": {
                "source": "新秩序の創造",
                "author": "――評論の評論",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説会は討論会じゃないという。",
              "citation": {
                "source": "新秩序の創造",
                "author": "――評論の評論",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の左まわり右へは、さき頃のラジオ討論会、「宗教と科学は両立するか」の時の話し方で聴取者の腹の底までしみ渡りました。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場の労働者クラブでは、毎晩のように選挙についての討論会が行われる。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソヴェト選挙もここでやるし、新経済年度の真面目な討論会も各坑の代表が集ってここでやる。",
              "citation": {
                "source": "ドン・バス炭坑区の「労働宮」",
                "author": "――ソヴェト同盟の労働者はどんな文化設備をもっているか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "プログラムの新企画として、「先週の国会から」、「放送討論会」、「街頭録音」、「ラジオ探訪」などが行われている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送討論会は第一回総選挙を機会として開始された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に供出に関する討論会などは、自然で単純な大衆的ディスカッションではなかった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方で行われた供出に関する討論会は、政府の強制供出方針の宣伝的討論であった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近行われた日本の新しい祭日を決める討論会においては、衆議院議員馬場秀雄、民主的な立場をもつ歴史家羽仁五郎と、シントーイストであって出雲大社東京分祠長千家尊宜等が登壇し、大衆の中に少くない数の学生が見られた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この討論会においてアナウンサーが自分の感情と見解から思いついた質問を羽仁五郎に向って与え、アナウンサーとしての義務の範囲を超えた態度を示したことも注目された。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送討論会でも日本映画の将来については大衆の熱心で支持的な発言があった。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃアどうでもえいことで、作者としては問題でない」「ところが、わたくしにはどうでもいいわけに行かないのです」と、彼は自分もいよいよ討論会の仲間入りをでもしているかのごとく少し膝をにじりだして、天神さまの意見に反対するのであった。",
              "citation": {
                "source": "猫八",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政談演説会や討論会もよく開かれた。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから討論会です。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎週二度、木曜と日曜には討論会を開いて、歴史や科学および修身の題目をとらえて議論をたたかわすこと、風なき日には湖畔を散歩し、あるいはランニングの競争をやること、などもきめた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあいだにもゴルドンは例の日課の勉強だけは一度も休まなかった、一週に二度の討論会もつづけた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "討論会ではいつもドノバンが能弁をふるって一同をけむにまいた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月二十三日夜八時半に作家クラブでリビディンスキーの「英雄の誕生」についての討論会があるので出かけたら中止。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "放送委員会　世論委員会　放送討論会研究、徳田、大野、氏家等来る。",
              "citation": {
                "source": "日記",
                "author": "一九四八年（昭和二十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」六月三日　作家クラブにリビディンスキーの「英雄の誕生」のための討論会があるというので出かけたところ、何もなし。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "春山糸子は理論と弁論に長じ、討論会の花形として小学時代から高名があった。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「主張と感情」といふ題で、日比谷公会堂で行はれた放送討論会に出席した時の感想が述べられてゐる。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、労働戦線の統一を妨げてゐるのは、各派の主張の相違といふよりもむしろそれぞれの感情の対立にありはせぬかといふ論旨で、それは別にとりたてて言ふほどのことはないが、私が特にこゝで引用したいのは、当日の討論会を通じてかういふ印象を受けたこの青年が、最後に附け加へてゐる一言である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
