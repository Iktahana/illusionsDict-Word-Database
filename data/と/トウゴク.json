[
  {
    "uuid": "ba163f17-dab1-5552-939e-b2a72174bc91",
    "entry": "投獄",
    "reading": {
      "primary": "とうごく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imprisonment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所が、男は一年たたぬうちに再び投獄された。",
              "citation": {
                "source": "実感",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたちになるやならずの頃に、既に私たちの殆んど全部が、れいの階級闘争に参加し、或る者は投獄され、或る者は学校を追われ、或る者は自殺した。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志たちは次々と投獄せられた。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほとんど全部、投獄せられた。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メチルとは知らずに売ったが、それでも人が死ねばやはり過失致死罪なのだろう、やがて投獄される憂目に会うたが、今はそれに脱走という罪が二重に重なって、おまけに拾った財布の金を無断で使っている。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、投獄された酋長達が毎日｜笞打たれているという噂もあった。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも前記の乱の鎮定後明治政府に対して功績を挙ぐるに汲々たる県当局では、残酷にも健児社に居残っている少年連を悉く引捉えて投獄した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ一足で目指す薩摩の国境という処まで来ていたが、そこで思いもかけぬ福岡の健児社の少年連が無法にも投獄拷問されているという事実を風聞すると天を仰いで浩嘆した。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若いときには軍人であり、泥坊もやって数回投獄されたことがあるが、一八〇九年以来探偵となり、のち、パリ警視庁の探偵部長となった。",
              "citation": {
                "source": "モルグ街の殺人事件",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで一方には赤旗事件で金曜会の連中が一掃され、一方にはまた、電車問題の凶徒｜聚衆事件が確定して、西川、山口等、多くの同志が投獄され、その他の人々は手も足も出しようがなく、運動は全く頓挫の姿を呈した。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北方のともしび」（今泉運平）は、日本の野蛮な治安維持法が、リアリズム綴方、生活教育という今日では常識としてたれ一人疑わない方法を主張したような教員まで投獄した時代の記録であり、検事の調べぶりや、出獄してゆく仲間のあとにとりのこされたときの気持など、相当実感をもって描かれている。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無邪気によい教育をする先生でありたいと思う心からの動きを投獄というおどかしでねじ伏せたところが過去の治安維持法の非人道的ないわれである。",
              "citation": {
                "source": "選評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて「白夜」を書いたこの作者は「思想関係の事件で起訴されたり投獄されたりの間の、自分の意志でどうともならなかった心の動きの秘密を知りたいという慾求」から「自分の血統に傾ける心」を持って「自分の一族」の経歴を溯っている。",
              "citation": {
                "source": "ヒューマニズムへの道",
                "author": "――文芸時評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ブルジョア、地主の悪法「治安維持法」というものは、それをキッカケに階級的に目ざめた大衆をかたっぱしから投獄するよう、わざわざ制定されてあるものです。",
              "citation": {
                "source": "ますます確りやりましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪辣きわまるその「わな」とも闘い抜いて私は八十日の後自由をとり戻したのですが、みなさん忘れてならないことは現在十数人のわれわれの同志たちが日本プロレタリア文化連盟から奪われて投獄されているという事実です。",
              "citation": {
                "source": "ますます確りやりましょう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日本においても、労農大衆の投獄、拷問、虐殺を行いつつある天皇と、その憎むべき反動的手先に、革命の制裁を与えねばならぬ）三月十六日、革命の進展におされて、ニコライは遂に退位した。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルジョア・ジャーナリズムがわが陣営の作家を恐怖し、有能な作家が投獄されている時、われらは全力をつくし、どの一部を切ってもピチピチとそこだけで叫ぶべきことを叫び得るようなボルシェビキ的作品を創作してゆかなければならぬ。",
              "citation": {
                "source": "文学に関する感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その組織後間もなく、例の赤旗事件のために、僕等日本の同志の大部分が投獄され、そしてそれと同時に和親会の諸同志の上にも厳重な監視が加えられて、会員のほとんど全部は日本に止まることができなくなってしまった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話がよほど進行している間に、しかもその教授の運動の結果を聞きに行く筈の日の数日前に、電車事件で投獄された。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの事件の投獄とともにその後の運命はきまってしまった。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "一冊の雑誌、一冊の本、風呂屋、理髪店での世間話さえ、それが戦争についての批評めいたものだと密告され、捕縛され、投獄された。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の治安維持法が昭和三年に制定されて、昨二十年の秋廃止されるまでの十七年間に、ものを考え、日本の未来について憂慮する人々を約十万人も投獄した。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナチスは、ユダヤ人をいためつけたばかりでなく、そういう行為は人道にもとることを発言するすべてのドイツ人を投獄し、あるものは殺した。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "法学博士で大臣だった三土忠造でさえ、一九二九年か三〇年ごろ涜職事件で検挙投獄され、公判廷で奮闘して無罪を証明したあとで『幽囚記』という本をかいた。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府は不手際な強制供出方法によって供出を拒んだ農民は投獄されなければならない規定までこしらえた。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから投獄されてもしかたがないと。",
              "citation": {
                "source": "世紀の「分別」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんそれぞれの作品には、出来、不出来もあり、むらもあるけれども、それらを一貫して明瞭な階級性があるから、度重る検挙投獄と執筆禁止を蒙ったと思います。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、一九三一年十月入党後、前後五回の検挙投獄を経験しました。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし組織の秘密は守られ、屈服しなかったために、一九四一年十二月九日、太平洋戦争とともに戦争に非協力な共産主義者として投獄されました。",
              "citation": {
                "source": "文学について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人である壺井繁治さんが、プロレタリア文化運動のために投獄されていた留守のころ、何かの雑誌で栄さんの書いた短篇をよんだことがあった。",
              "citation": {
                "source": "壺井栄作品集『暦』解説",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
