          "standard": [],
          "literary": [
            {
              "text": "ついこなひだまで雛児だつたのに、もう時を告げるやうになつて……」　家の者は寝呆声でこんなことをいつたやうだが、その次の瞬間には、すぐにまた寝ついたらしく、すやすやといふ寝息の音が微かに聞えて来た。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝあんな時もあつた、こんな事もあつたと、蒲團に腹這ひになつて、煙草を一服つけながら、間をおいては、時を告げる鷄の聲に耳をかたむけてゐる氣分は何とも云へなかつた。",
              "citation": {
                "source": "崩浪亭主人",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆吉は、また、明日から．鷄の時を告げる聲をきかなければならないだらう。",
              "citation": {
                "source": "崩浪亭主人",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか遠くで鶏の羽ばたきと、時を告げる声が聞こえた。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早、暁方の様子になつて、西へ傾いて、男と別れなければならない時を告げる鐘の音が、聞えてゐる。",
              "citation": {
                "source": "地唄",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "灯火の数も少く、時を告げる役人の声すら、ここでは聞くことがない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ネロとパトラッシュは、ほとんどの生涯を、時を告げるもの悲しい鐘の音が聞こえる場所で一緒に暮らしていました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、村に帰りついたときには、四時を告げる鐘の音が鳴っていました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A Dog of Flanders",
                "note": "青空文庫"
              }
            },
            {
              "text": "――土塀の先は石垣で、土地が低くなっており、そこに時を告げる鼓楼があるのだが、ここからは見えなかった。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯時を告げるのであった。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
