    "definitions": [
      {
        "index": 1,
        "gloss": "bonito-flavored vinegar dressing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
