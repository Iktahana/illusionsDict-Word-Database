    "definitions": [
      {
        "index": 1,
        "gloss": "person skilled (in the art of doing something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当局でも当業者も、無論そんなものはまだあるまいと云った。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は各所で熱心な当業者に会うことが出来た。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよき指導者の必要を切に感じないわけにゆかない、すべての当業者は腕を有っている、仕事は続けたいのである。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も当業者の商売が不振でなければ決してこういう当局の方針も発生しないのだが。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁では万才の台本を検閲しようと企てているのであるが、当業者は万才の特殊性を挙げて万才が決して画一的に予定のコース通りに行くものではないので、検閲は困難だという意見であった。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "既得権を有っている当業者は組合大会を開いて之に反対したが、他の方面の文化統制に忙しい当局は、まだ美容院乃至床屋の文化的作業の検閲にまで必要を感じなかったので、床屋は自由にどこにでも開業出来るということになって了った。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが電気会社当業者にいわせると、農村の自家用発電は、設備費の割合に電力消費量が少なくまた季節的なムラが甚だしく、それに水力の不平均や技術家の薄遇等々の理由によって、いずれも経営困難に陥っているというのである。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
