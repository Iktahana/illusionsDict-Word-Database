    "definitions": [
      {
        "index": 1,
        "gloss": "whitish gentian (Gentiana algida)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
