[
  {
    "uuid": "9dff21d2-1465-5dc1-90e9-2d63cd729296",
    "entry": "投書家",
    "reading": {
      "primary": "とうしょか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "contributor (e.g. to a newspaper)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "歴史家も日本人なら、この投書家も日本人である。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれが、地方雜誌のスレからした投書家などにありがちな、野卑な厭味とキザとで芬々たる臭氣を放つてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん君は、依然として粗野であり、依然として垢ぬけない田舍の投書家臭味をもつてゐた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「少年倶楽部」や「蟻の塔」を愛読し、熱心なその投書家であつた私は、それらの雑誌の発売日が近づくと、私の応募した笑話が活字になつてゐるかどうかをたしかめるために、日に二度も三度もその本屋へ足を運んだものである。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "△成石平四郎　高木顯明、峰尾節堂、成石勘三郎、崎久保誓一、何れも大石の親近者にして牟婁新聞の投書家或は記者なり、牟婁新聞は毛利柴庵の經營するものにして、管野すがも曾て在社したり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "△松尾卯一太　新美卯一郎、佐々木道元、飛松與次郎等は何れも熊本社會主義者の中樞にて、熊本評論の記者或は投書家なり、松尾は目下入獄中なり。",
              "citation": {
                "source": "日本無政府主義者陰謀事件經過及び附帶現象",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤字や假名違ひは何百といふ投書家の中に隨分やる人がある。",
              "citation": {
                "source": "歌のいろ／＼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし同氏は尋問によって十分に無罪であることが証明されているのであるし、この投書家たちの議論は熱心なだけで考え深いものでないと思われるから、これらは公表しないほうがよいと考える」――『朝刊新聞』六月二十八日。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田金重の『再度の上京』と投書家らしい若さを取れば取るのだが――。",
              "citation": {
                "source": "三月の創作",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭株の数人を除いたら手もなく「親釜集」連で、今なら葉書集の投書家程度であった。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、投書家として栄えたことを、一かどの作家でもあったように幻想して、楽しんでいる吉野君に対して、俺は気の毒のような淋しいような気がした。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は、投書家からいろいろな原稿を、読まされるのに飽ききっているはずだ。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説作家のように物凄い材料を作品の上では取り扱いながら、批評の上では、御座なりな、少年雑誌の投書家のようなほめ言葉を交換しあっているということは、お上品でよいのかもしれないが、もし、率直で、辛辣な批評が、ここで排斥されるとするなら、探偵小説は、ついに温室の中で枯死するより他はないであろう。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでお貞さんは巧に躍進していつの間にか女子文壇を去り博文館の文章世界の投書家となつてしまつた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでも忽ち群をぬいて投書家の中で優秀組、今の東寳社長秦豊吉氏だの川浪道三氏だのといふ人々と新進若手として時には本流文壇の人々の批評にものぼるやうな進歩のあとを見せてゐた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十二年二月の文章世界は投書家の優秀な者に新作を掲載させた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お初ちやんはやはり少女界から女子文壇に移つて行つた投書家仲間の一人であつたが、美しい娘でさきに一寸書いたやうに、「二つとや……二つ二葉屋のお粂さん……お粂さん、赤い襷で砂糖かけ……砂糖かけ」といふ町の唄にもうたはれた程であつた。",
              "citation": {
                "source": "水野仙子さんの思ひ出",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、投書家｜交際をすることが好きで、地方文壇の小さな雑誌の主筆とつねに手紙の往復をするので、地方文壇｜消息には、武州行田には石川｜機山ありなどとよく書かれてあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『文新』『働く婦人』等への投書家、読者、通信員へのソシキ的働きかけを忘れることなく、しかも最も直接的に、即刻なされねばならない。",
              "citation": {
                "source": "メーデーに備えろ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」氷峰は慰める樣に、「本道で何かすると云つても、知つてる人が多い方がよからう――こないだの時は餘り忙しかつたから、何とも仕やうがなかつたが、今囘は一つ歡迎會をやるつもりぢやから――それも、中學生や青年雜誌の投書家の樣なあんこ供は別にして、新聞記者を中心として集つて貰ひたいのぢや。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「投書家って、よく何か知っているものね。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は作者の外に投書家というものがあって、各新聞に原稿を投じていた。",
              "citation": {
                "source": "明治十年前後",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、投書家でもよいものは作者と同じように、原稿料をとっていたように記憶する。",
              "citation": {
                "source": "明治十年前後",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までとまるで違った顔ぶれで、吉屋信子氏丈がもう投書家の域を脱した様な体裁で、「赤き世紀の人々」を出して居た。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "岡田三郎氏は、まだ投書家的臭味を持って居る。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰も「文章世界」の投書家の小説を評して、「大正の花袋」だと云ふのと同じ程度のものであつた。",
              "citation": {
                "source": "貝殼追放",
                "author": "泉鏡花先生と里見※さん",
                "note": "青空文庫"
              }
            },
            {
              "text": "發行部數の多い婦人雜誌や投書家相手の雜誌に寄稿しない爲めもあつたらうが、彼の筆名｜樟喬太郎は、十年間文壇に介在しながら、大多數の人には新しい印象を與へた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
