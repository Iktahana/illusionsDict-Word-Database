    "definitions": [
      {
        "index": 1,
        "gloss": "turning upside down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "忠僕某は、マリア夫人の兼ねての命令の通りに、城外で櫃を受け取り、直ちにこれを船に乗せて、運河の便を借りて、ゴルクム町に運送しようという考案で、船頭に対って充分の注意を与え、櫃を倒置したり、投げ出したりすることを禁じて、丁寧にこれを取扱わしめた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なるほど、なるほど――」と彼は更に錯覚を深めるように云った、「即ちこれが、エアヒ川とでも申そうか――すると城地はどちらにござろう――童児のころもなつかしまれます」　倒置したこの地形に郷里の風景を描きだしていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "余輩の考ふる所によれば、卑彌弓呼は卑弓彌呼の倒置にて、hikomikoto の省略なり。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして「かね」を使ふ場合は、それ以下の文句を省いてゐるか、前の方へ跳ね戻る――句の倒置――かゞ常である。",
              "citation": {
                "source": "古代民謡の研究",
                "author": "その外輪に沿うて",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、沖繩語普通の倒置修飾格と考へる事が出來るから、「親しい母」と言ふ位の意を持つ。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "streitig machen ＝ anzweifeln, in Frage stellen. ６．ihm geschieht nichts ＝ es geschieht ihm nichts に對する倒置形。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔館は台地のはななれば〕宮沢賢治館は台地のはななれば鳥は岬の火とも見つ香魚釣る人は藪と瀬を低くすかしてわきまへぬ鳥をまがへる赤き蛾は鱗粉きらとうちながし緑の蝦を僭しつゝ浮塵子あかりをめぐりけり",
              "citation": {
                "source": "〔館は台地のはななれば〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした放課后みなさんとうちへ遊びに来てくださいね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "否さまでならず、ただ去年のものにはすこしく優れりとうち消すようにいうは老婦なり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "窒素工場の火の映えは、　　　層雲列を赤く焦き、鈍き砂丘のかなたには、　　　海わりわりとうち顫ふ、さもあらばあれ啜りても、　　なほ啜り得ん黄銅の月のあかりのそのゆゑに、　　こたびは牛は角をもて、柵を叩きてたはむるゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした放課後みなさんとうちへ遊びに来てくださいね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとうちがあるから、お前あるけるかい。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとうち解けて呉れてもよいと思つた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カムパネルラはみんながそんなことを言うときはきのどくそうにしているよ」「カムパネルラのお父さんとうちのお父さんとは、ちょうどおまえたちのように小さいときからのお友達だったそうだよ」「ああだからお父さんはぼくをつれてカムパネルラのうちへもつれて行ったよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした放課後みなさんとうちへ遊びに来てくださいね」　そう言いながら博士はまた、川下の銀河のいっぱいにうつった方へじっと眼を送りました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちあるいてあるいて、東から二十日の月が登るころやっとうちに帰って寝ました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「カムパネルラのお父さんとうちのお父さんとはちやうどおまへたちのやうに、小さいときからお友達だつたさうだよ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした放課後みなさんとうちへ遊びに來てくださいね。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とうちの中でお母さんが叫んでいます。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その児が途で私を見るときっとうちに遊びに来いと言うのです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから弟子が六人で、兵隊たちの顔から生えた灰いろの毛をとるために、薬の袋とうちはをもつて、ソン将軍を追ひかけた。",
              "citation": {
                "source": "北守将軍と三人兄弟の医者",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか男のような恰好だけれど、泣いてる声をきくとうちの子のようだ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風呂の中でハモニカを吹いたり、鼻歌をうたつたりするやうなもんは、きつとうちの屋台骨をまげるやうになる」とおとうさんはいつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の姉も亦きりやうがわるいとうちの人たちからいはれいはれしてゐたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ共にふるさとの家へ歸つて來て、私たちは先づ臺所の石の爐ばたに向ひあつてあぐらをかいて、それからきよろきよろとうちの中を見わたしたのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてとうとうちょうちょうがたくさんいるじゃがいも畑まで、流れてきました。",
              "citation": {
                "source": "木の祭り",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その咏風に大方は誰と知らるゝが多かれど、時に予想外なるがありて、こは君なりしかとうち驚かる。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっとうちにも抱かしとくなはれ」　赤ん坊を抱かせてもらった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年七月　　樅のふたもとうちけぶる樅のふたもと。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "』とわが憎悪心むらむらとうちふるふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
