        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "貴きわたりに交らひ給ふ殿達は、定めて金多く費し給ふならん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あんなお可愛い男のお子がお生れあそばしたのに……殿達といふものは……』『女は何うせおもちやにされてゐるのですから……だから、呉葉、この間もそちには打明けなかつたが、つくづく思うた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子を餓えさせて置くやうな殿達もございますまいほどに……。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿達に取つては、坊の小路は此上もない歡樂の庭であるらしかつた。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "子を持てば女子の姿はあさましくなると言はれて、好色の殿達はそれをひとつの邪魔者のやうに、また子の愛に執着してそれから離れて來られない女子はもはや色戀の對照ではないといふ風に思はれてゐるのに、それを平氣で對屋で養つてゐるので、それで殿は來られなくなつたのではあるまいか。",
              "citation": {
                "source": "道綱の母",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が、径の真中で「御貴殿達へ申し入れる。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "やらやら尽くしで殿達は、近来の大騒ぎ。",
              "citation": {
                "source": "移民学園",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            }
          ]
        }
