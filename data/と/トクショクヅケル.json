[
  {
    "uuid": "4d1777eb-3dae-534d-a557-7ec9da92cdb4",
    "entry": "特色づける",
    "reading": {
      "primary": "とくしょくづける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
