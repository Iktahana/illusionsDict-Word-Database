[
  {
    "uuid": "3df16297-37ba-5fea-8963-89dacf5b1dd3",
    "entry": "とっくの昔",
    "reading": {
      "primary": "とっくのむかし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
