    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being on duty",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "当番の給仕男が同僚たちに客に対すると同様に仕付けよく給仕していた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで働いている炊事当番の皮膚の中へまでも、それ等の臭いはしみこんでいるようだった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当番卒がきめられる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "炊事当番がきめられる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　炊事当番はシャツの上に胸掛前垂をあてゝ、テンテコまいをしていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当番卒が背中を流すけはいがする。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みにやはり『灰汁桶』の巻について点検すると、なるほど前句「摩耶」の雲に薫風を持って来た上に「かますご」を導入したのは結構であるが、彼の頭にはおそらくこの「夕飯のかますご」が膠着していてそれから六句目の自分の当番になって「宵々」の「あつ風呂」が出現した感がある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日、癸酉、昵近の祗候人の中、芸能の輩を撰びて結番せらる、学問所番と号す、各当番の日は、御学問所を去らず参候せしめ、面々に時の御要に随ふ、又和漢の古事を語り申す可きの由と云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は当番の看護婦が、交代に二人ずつ附添うので、ただ（御気分はいかがですか、お大事になさいまし、）と、だけだけれども、心優しき生来の、自から言外の情が籠るため、病者は少なからぬ慰安を感じて、結句院長の廻診より、道子の端麗な、この姿を、待ち兼ねる者が多い。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関には下の塾から交代の当番で、弁持十二が居るのさ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらび荒んだ生活の中に、たった一つの慰めは、奥の当番に当って奥の御用を足す間に、たま／＼先代の御新造さんから労って貰うそのことであった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御新造さんにそれがして貰い度さに奥の当番が来る日には、わざと袖の脇の糸をほぐして行ったりした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「蓄音機は司令部へ行ったぜ」　と、若い当番兵が答えた。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては、その本陣の詰所を土地の庄屋または大百姓の家に置き、当番の組々がひそかにめいめいの持場を固めることになっていた。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも旦那さまの御当番のときには姿を見せねえので困る。",
              "citation": {
                "source": "鷲",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良原到が飯爨当番に当ると、塾の連中が長幼を問わず揃って早起をした……というのは、飯の準備が出来上るまで寝床に潜っていると、到少年がブスブス燃えている薪を掴んで来て、寝ている奴の懐中に突込むからであった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "隔日の御番（当番）出仕で、夜半二時迄の不寝番をつとめた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平、ふと廊下の壁の黒板に、「日曜日、日直当番、小谷初枝訓導」と書いてあるのを見て、おやっと思い、引きかえす。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まずは始まりの始まりで、おれの当番は夜の十時から朝の六時までなんでして。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから今度は、六月二十三日、月曜日の朝、艀の船夫が拾い上げたが、死骸の発見される前に、艀事務所から当番の役人の知らぬ間に舵を残して持ち去られたあのボートを捜してみよう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔『馬酔木』明治三十六年十一月十三日〕　明治三十五年七月初旬の頃である、看護当番として午後二時少し過たと思う時分に予は根岸庵に参った、今日はどんな様子か知らんと思う念が胸に満ているから、まず母堂や律様の挨拶振りでも、その日の先生の様子が良かったか悪かったかということがすぐに知れる。",
              "citation": {
                "source": "竹乃里人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれから少時そこらを猟っていたが、ほかにはなんにも新らしい発見もなかったらしく、泥によごれた手先をふところの手拭で拭きながら、もとの自身番へ引っ返してゆくと、与力はもう引き揚げて、当番の同心三浦だけが残っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい当番たりとも在宿して火の用心を怠らぬようにいたせというのが一つ。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "また馬廻りの子で近習を勤めていた某は、阿部の屋敷に近く住まっていたので、「火の用心をいたせ」と言って当番をゆるされ、父と一しょに屋根に上がって火の子を消していた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "のちにせっかく当番をゆるされた思召しにそむいたと心づいてお暇を願ったが、光尚は「そりゃ臆病ではない、以後はも少し気をつけるがよいぞ」と言って、そのまま勤めさせた。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オーイ、行くぞーっ」と、当番のコーターマスターがブリッジから怒鳴った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "当番のコーターマスターは、梯子をのぼり切ると、すぐに、小倉を取っつかまえた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫では、波田、コーターマスターでは小倉が、今夜の当番であった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
