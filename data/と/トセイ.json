[
  {
    "uuid": "a5da7f33-9bdc-559e-a1a1-ac87cb522f95",
    "entry": "渡世",
    "reading": {
      "primary": "とせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "making one's way in the world",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "おいぼれとただ呼ばれる老人は鋸を曲げながら弾いていろいろなメロディを出す一つの芸を渡世として場末のキャフェを廻っていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡世人らしい旅人が一人休んで居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姐さん草鞋があるかい」　「え、御座います」　「そうかい、じゃ一つくんな」　「はい」　その時、通りかかった……これも渡世人の旅人が三人。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お侍の果し合か」　「ううん」　「じゃ渡世人か、其奴ァ面白え」　石松、起き上って表へ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと名のある渡世人に違えねえと俺ァ思うんだ」　「誰だろう？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "源兵衛が、　「清水の次郎長さんとか仰言いましたが、お前さん、やくざ渡世の人だろう」　「そうだ、爺つあん」　お静戻って来て　「はい、縫いますわ」　「あ、こりゃどうも済まない」　源兵衛が、　「失礼だが、此処は堅気の年寄りの住居だ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "儂ァたった一人の伜をやくざ渡世にしたくねえからな……」　凝ッと聴いていた次郎長、　「爺っつあん、草鞋を一足頂けませんか」Ｓ＝表　石松、隣りから薬持って帰って来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも森の源兵衛と云やァ渡世人仲間じゃ少しは人に知られた男だった」　「矢張りそうだったのか。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "また此外に矢張りこれも同級の男で野崎というのがありましたが、此野崎の家は明神前で袋物などをも商う傍、貸本屋を渡世にして居ました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は博多｜竪町の荒物屋渡世……当年五十六歳で……ヘエ……」　と淀みなく言ううちに涙ぐんだ赤んべえ面を上げて水洟を一つコスリ上げた。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは役柄をもって相尋ねるが、その方は只今も申す通りズット以前は博多の荒物屋渡世。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売｜冥利、渡世は出来るもの、商はするもので、五布ばかりの鬱金の風呂敷一枚の店に、襦袢の数々。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭髪を長くして、きちんと分けて、額にふらふらと捌いた、女難なきにしもあらずなのが、渡世となれば是非も無い。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "綾子は少しく乗出だし、「他に渡世の道が無いでもあるまい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが金魚を、一つ十両で平然と買って行く人もあり、また一方では、その餌のぼうふらを売って、ほそぼそと渡世している人もある。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲か、役者か、渡世人か、いきな処で、こはだの鮨は、もう居ない。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前も門跡様がお着きになると云う日は、朝から渡世を休んで、鈴ヶ森の手前まで往って待ち受けておりました。",
              "citation": {
                "source": "尼になった老婆",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の西応房は尾州中島郡一の宮の生れであったが、猟が非常に好きで、そのために飛騨の国へ往って猟師を渡世にしていた。",
              "citation": {
                "source": "女仙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、「その方は、自分一人の渡世のために、数知れぬ鳥や獣の命を奪っておるが、それでは罪業を増すばかりである。",
              "citation": {
                "source": "女仙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡世は猟師に限るまい、何か他の事をするがよい」　西応房の猟師は家へも帰らず、其の足で飯田在へ往って、其の両親と云う者に逢って、仙女の云った事を確めてみると、寸分の相違がなかった。",
              "citation": {
                "source": "女仙",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しいのは、池の端へ越した爺いさんの身の上で、これも渡世に追われていたのが、急に楽になり過ぎて、自分でも狐に撮まれたようだと思っている。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某年来｜桑門同様の渡世致しおり候えども、根性は元の武士なれば、死後の名聞の儀もっとも大切に存じ、この遺書｜相認置き候事に候。",
              "citation": {
                "source": "興津弥五右衛門の遺書（初稿）",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらは江戸の四谷｜忍町の質屋渡世、近江屋七兵衛とその甥の梅次郎、手代の義助であった。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここいらの宿屋の亭主には渡世人上りが多いという話を……。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "月代の伸びた荒くれ男どもは本職の渡世人らしく、頬冠りや向う鉢巻で群がっている穢苦しい老若は、近郷近在の百姓や地主らしい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "棒手振が渡世で夜でないと家にはいなかった。",
              "citation": {
                "source": "山姑の怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも感慨無量で折角飲んだ酒も醒めて来るが、暫くするとまた飲みたくなりゃこそ酒屋が渡世が出来る理窟故ますます感心する。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "居士油を売って渡世するを譏ったのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月の厳寒に、多くの人が鳶口で筏を引いて水中を歩く辛苦を傷み尋ねると、この働き、烈しく身に障り、真砂という地の男子ことごとく五十以下で死するが常だが、故郷離れがたくて、皆々かく渡世すと答えた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『摩訶僧祇律』三にいわく、過去世に婆羅門あり銭財なき故、乞食して渡世す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
