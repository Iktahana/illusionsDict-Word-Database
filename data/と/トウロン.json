    "definitions": [
      {
        "index": 1,
        "gloss": "debate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "討論の結果、これは今でこそほとんど食えないような装飾物であるが、ずっと昔これらのものが非常に珍しいうまい御馳走であった時代があったので、その時代にこれらのものが特別なとっときの珍肴として持出され、そうして賞味され享楽されたものであろうという臆説が多数の承認を得たようであった。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この討論は到底相撲にならないで終結したらしい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで大勢のギリシア学者が寄合い討論をして翻訳をした、その結果が「ロイブ古典叢書」の一冊として出版され我邦にも輸入されている。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「題は僕自身がつける、あえて諸君の討論をわずらわさんやだ、僕には僕の題がある。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと言って、いつまでもなんらかこの種の方法をとらなければ、独断と独断との間の討論の終結する見込みは立たないように思われるのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩毎晩、酔っては討論会を初めますわ！",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "浴室では神崎、朝田の二人が、今夜の討論会は大友が加わるので一倍、春子さんを驚かすだろうと語り合って楽しんで居る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "法の討論より餅の方が大事というのか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は猶北方憂うるに足らずとして意を文治に専らにし、儒臣｜方孝孺等と周官の法度を討論して日を送る、此間に於て監察御史韓郁（韓郁｜或は康郁に作る）というもの時事を憂いて疏を上りぬ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあの街頭の討論を終えて、ほっとして汗を拭き、それから急に不機嫌な顔になってあのひとの役所に引上げる。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "討論の現場に居合せたもうひとりの下僚は、「いえ、いえ、どうして、かいとう乱麻を断つ、というところでしたよ」　とお世辞を言う。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この下僚は、少しも楽しみだと思っていないし、実際その放送の夜には、カストリという奇妙な酒を、へんな屋台で飲み、ちょうど街頭討論放送の時刻に、さかんにげえげえゲロを吐いている。",
              "citation": {
                "source": "家庭の幸福",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くて長谷場純孝氏の提議にて討論終結の動議成立し、杉田議長採決を宣したるに出席總數三百四十五票中決議案を可とする者　百六十八票否とする者　　　　　百七十七票にて戰は僅々九票の差にて政府黨の勝利に歸し申候。",
              "citation": {
                "source": "雲間寸觀",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーニングの夫は眉を動かして、「結構な天気じゃないか、奥」　そして彼はあらゆる問題に五分から二十分間位討論する用意は持って居る。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "愈々大津の息子はお梅さんを貰いに帰ったのだろう、甘く行けば後の高山の文さんと長谷川の息子が失望するだろう、何に田舎でこそお梅さんは美人じゃが東京に行けばあの位の女は沢山にありますから後の二人だってお梅さんばかり狙うてもおらんよ、など厄鬼になりて討論する婦人連もあった。",
              "citation": {
                "source": "富岡先生",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "座談会の出席者は、討論の相手とマイクとどちらの方へ話しかけていいのかうろうろ迷っているし、共産党員は威勢ばかりで懐疑のない声だ。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らはいずれも自己の性向、世界観に絶対に固執していて、他との討論の結果、より高い結論に達するなどということを知らなかった。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は二者間にある各種問題の最終討論にあたって、しばし僕に便宜を図ってくれている。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "依りてある寺を借り受けて教場を開き、夜は更に昼間就学の暇なき婦女、貧家の子弟に教え、母上は習字を兄上は算術を受け持ちて妾を助け、土曜日には討論会、演説会を開きて知識の交換を謀り、旧式の教授法に反対してひたすらに進歩主義を採りぬ。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "学僧だけを選んで討論をさせて聞いたりした。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "試みに一人の専門に洋傘を製造してゐる職人、或は皮革製品の専門職人と、デパートのその売場専門の係員へと専門商品に就いて討論さしてみたまへ。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "石投げのやうな喧嘩腰の討論が續く。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの芝居は幕間が長いから、こんな討論会にはおあつらえ向きです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いがけないワーナー団長の冒険計画についての是々非々の討論が活発に展開していった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日Ｄ十五号だけがあのとおりひどくやられて他の艦船が大した損害を受けなかったことを君は不思議に思わんかね」　ホーテンスは、闘志満々たるところを示して、この期になお同業者と討論を持ちかける。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
