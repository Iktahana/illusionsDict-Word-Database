[
  {
    "uuid": "30ead4b2-ade8-5583-a913-4e37bb599b4e",
    "entry": "時とともに",
    "reading": {
      "primary": "ときとともに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
