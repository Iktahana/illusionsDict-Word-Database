  {
    "uuid": "309a1d29-a81c-5ab1-805f-043e538600c5",
    "entry": "東雅",
    "reading": {
      "primary": "とうが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
