    "definitions": [
      {
        "index": 1,
        "gloss": "goddess of (lucky) directions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
