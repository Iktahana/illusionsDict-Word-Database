    "definitions": [
      {
        "index": 1,
        "gloss": "ton (esp. a metric ton, i.e. 1000 kg)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
