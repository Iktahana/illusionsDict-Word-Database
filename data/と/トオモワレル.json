[
  {
    "uuid": "4e670fe5-9c96-5823-b049-e220716b5305",
    "entry": "と思われる",
    "reading": {
      "primary": "とおもわれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
