[
  {
    "uuid": "6b44f90c-6e04-5361-b5ff-53f02b38b5bd",
    "entry": "常世",
    "reading": {
      "primary": "とこよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
