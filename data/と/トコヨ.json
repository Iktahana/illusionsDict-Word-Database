  {
    "uuid": "5efe6219-09b9-5ae2-bf07-0f6233af18ce",
    "entry": "常夜",
    "reading": {
      "primary": "とこよ",
      "alternatives": [
        "じょうや"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "perpetual night",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "落葉もせず、常夜燈の光｜幽に、梟。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは夜天の空に輝やいてる、無數の星屑が照らすところの、宇宙の常夜燈の明りであつた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋葉さんの常夜燈の下でしていた。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "林太郎はにやにや笑って常夜燈にもたれてみている。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たびたび常夜燈の下の広くもない地びたを眼にうかべた。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝起きるとすぐ私は常夜燈の下へいってみた。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び相手がなくてひとりさびしくいるとき、常夜燈の下にツルのかくしたその花があるという思いは私を元気づけた。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が例のように常夜燈の下をすみからすみまでさがしまわっていると、いつのまにきたのか林太郎が常夜燈の石段にもたれてとうもろこしをたべていた。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからのち、常夜燈の下は私にはなんの魅力もないものになってしまった。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "林太郎が私に真実を語らなかったら、私にはいつまでも常夜燈の下のかくされた花の思いは楽しいものであったかどうか、それはわからない。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "常夜にてれるともし灯。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "常世は常夜で常世とは別なり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに今かく常夜往時に集えて鳴かせし鳥たるを以て後に負わせし称なるを、その始めへ廻らしてかくのごとくいえるなりと。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "手塚の頭のうえで、ナイフの刃先が常夜灯の光を反射する。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　消灯もなにも、常夜灯しかついていない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、深い眠りから揺り起こされた慶一は、常夜灯のあかりのなかで、不思議そうに高志を見つめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "常夜灯のかすかな光のなかで、慶一は途方にくれて立ちつくした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "常夜燈を消して置いたのも染吉の仕業で、何分あたりが暗いので、そこらに染吉の隠れていることは一向気が付きませんでした。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらもあからさまに口へ出して言えることではありませんから、お互いにまあいい加減な挨拶などをしているうちに、お照がなにか鏡のようなものを袖の下にかくしているのを、常夜燈のひかりで染吉が見付けたのです。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お照も早く常夜燈を消しておけばよかったのでしょうが、年が若いだけにそれ程の注意が行き届かなかったので、たちまち相手に見付けられてしまったのです。",
              "citation": {
                "source": "鴛鴦鏡",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "処々の常夜燈はそろそろ光を放ち始めた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内の処々に立てられた硝子燈は光を放って、その表面の常夜燈という三字がはっきり見える。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この常夜燈という三字、これを見てかれは胸を衝いた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女を得なければ寧そ南洋の植民地に漂泊しようというほどの熱烈な心を抱いて、華表、長い石階、社殿、俳句の懸行燈、この常夜燈の三字にはよく見入って物を思ったものだ。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "常夜の長鳴鳥といふものの聲が闇の空を破つて遠くにも近くにも起つたが、そこいらはまだ暗かつた。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "古風な常夜燈はよろしいな、町標はくづれてしまつてゐる。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "パリの華麗なシャン・ゼ・リゼのつき当りの凱旋門の中に、夜毎兵士に守られて燃えつづけていた戦死者記念常夜燈に、平和は求め叫ばれつづけていた。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祕密の山に常夜の燈なければ、あなたの木の根、こなたの岩角に膝を打ち足を挫きて、仆れんとする身を辛く支へ、主從手に手を取り合ひて、顏見合す毎に彌増る太息の數、春の山風身に染みて、入相の鐘の音に梵缶の響き幽なるも哀れなり。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしらのとこよりいいところなんて、どこにもあるはずがない。",
              "citation": {
                "source": "幸福な一家",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾もアンタがその気ならと思っていたとこよ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
