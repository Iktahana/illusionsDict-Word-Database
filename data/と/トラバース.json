    "definitions": [
      {
        "index": 1,
        "gloss": "traverse (in mountain climbing or skiing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
