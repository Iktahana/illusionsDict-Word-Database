              }
            },
            {
              "text": "だがあれはほんとうかい。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「つまりベースボールがやれる広い場所さ」「へえ、ほんとうかい。",
              "citation": {
                "source": "骸骨館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「政ちゃん、ほんとうかい。",
              "citation": {
                "source": "ペスをさがしに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「徳ちゃん、ペスが帰ってきたって、ほんとうかい。",
              "citation": {
                "source": "ペスをさがしに",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それは、ほんとうかい。",
              "citation": {
                "source": "高い木とからす",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、なにか畑の中にあったものを見て、空想にふけったことをまことしやかに、友だちに話すと、つまらなそうな顔つきをしていた友だちらが、急に目を輝かして、近くそばへ集まってきて、「君、ほんとうかい……。",
              "citation": {
                "source": "その日から正直になった話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善ちゃん、ほんとうかい。",
              "citation": {
                "source": "高い木と子供の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「耳をかしな」「こうか」「――」「ふふ、ほんとうかい。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それァほんとうかい」「おれにくれないか。",
              "citation": {
                "source": "春の山",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞くと、台所にいたお蓮さま、何を思ったか濡れ手をふきふき、ころがるようにそれへ走り出て、「お美夜、おまえそれはほんとうかい？",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男の足はまっ黒なんだ」「ほんとうかい？",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれは、ほんとうかい。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            }
          ]
