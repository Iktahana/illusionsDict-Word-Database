    "definitions": [
      {
        "index": 1,
        "gloss": "ipecac (species of shrub, Cephaelis ipecacuanha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ダイオウ（rhubarb）粉、吐根の粉、アンチモニー粉（James's powder）、その他の効力が強い単純および複雑な医薬品の贋物が驚くべく大量に邪悪な商売で売られていることもまた、悪評がある。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は半スクループルの吐根（ipecacuanha）を摂ることができて、これにより嘔吐をし、間もなく回復した。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の方の國で取れる吐根などはその一つだが、なか／＼手には入るまいよ、――だが、こいつは内證にして貰ひたい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には萬兵衞が呑んだと思はれる吐根も、佐太郎を殺したと思はれる砒石も交つてゐたことはいふまでもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の徳利はなんにも入つてゐないが、酒を呑む前に、萬兵衞はうんと吐根を呑んでゐた、――二本目の酒――毒の入つたのは佐太郎一人で呑んだかな。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "南の方の国で取れる吐根などはその一つだが、なかなか手には入るまいよ、――だが、こいつは内証にして貰いたい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中には万兵衛が呑んだと思われる吐根も、佐太郎を殺したと思われる砒石も交っていたことはいうまでもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の徳利はなんにも入っていないが、酒を呑む前に、万兵衛はうんと吐根を呑んでいた、――二本目の酒――毒の入ったのは佐太郎一人で呑んだかな。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "棟梁の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何いふものか癖になつてゐる、「English at the Commercial School」といふ文句を矢鱈に原稿紙の上に並べてゐる中にポツとこんなことを思つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めてこの阪のやもりを見た時、自分はふとこんな事を思い出した。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に一二度見ただけだから、もう大部分は忘れてしまったが、夢のような記憶の中を捜すとこんな事が出て来る。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から考えるとこんなことを聞くのが如何な非常識であったかがよく分るのであるが、その当時自分と同様の質問を車掌に持出した市民の数は万をもって数えられるであろう。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし吾々船に弱い者から見るとこんな厭なものはない。",
              "citation": {
                "source": "汽船の改良",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもどこにか不安な念が潜んでいると見えて、時々「ほんとうの肺病だって、なおらないときまった事はないのでしょうね」とこんな事をきいた事もある。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、ラ――ラ――ラ――とこんな調子にやったならば。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎はチラっとこんな念におそわれて少し不快を感じたが、万事につけて村上の心もちを呑込んでいる山崎はそんなことくらいを深くとがめる気にはならないですぐあっさり忘れて、その日は夕方まで敏子を中心に面白く話し合った。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「浮世の風」となるとこんな二つや三つくらいの因子でなくてもっと数え切れないほど沢山な因子が寄り集まって、そうしてそれらの各因子の結果の合成によって凪になったり風になったりするものらしい。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "顛覆した列車の窓からとび出た時の、石のような雪の感触や、パルチザンの小銃とこんがらがった、メリケン兵のピストルの轟然たる音響が、まだ彼の鼓膜にひゞいていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まアザッとこんな苦しいわけで……けれどつかい込みの一件は、ごく内密にお願いします」と言って立ち上がり、石井翁が何も言い得ぬうちに、河田翁は辞儀をペコペコして去ってしまった。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょうど若い師匠の一周忌ですからね」「きっとこんなことになるだろうと思っていましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが帯取りの池ということを承知の上で、世間の人を騒がすためにわざとこんな帯を投げ込んだものであろうとのことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、キッコのよろこんだことこんないい鉛筆をもっていたらもう勉強も何もいらない。",
              "citation": {
                "source": "みじかい木ぺん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今この考えを逆に持って行くとこんな考えも起こし得られる。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもセザンヌが同じ「静物」に百回も対したという心持ちがどうも自分にはわかりかねていたが、どうしてもできあがらぬ自分の自画像をかいているうちにふとこんな事を考えた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "金銭の罪を犯す人の身のまわりには、きっとこんなたちの女が坐っているのだろうと思いました。",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこんどは、杉作ばかりでなく、克巳までがいっしょに、「よいとまァけ。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこんどは、急にもっとくらくなりました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子はだまって受けとって脇にはさんでのそりのそりとこんどは自分が見まはりに出ました。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三時間目になるとこんどは二年生と四年生が国語で、五年生と六年生が数学でした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとこんどは白象が、片脚床にあげたのだ。",
              "citation": {
                "source": "オツベルと象",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
