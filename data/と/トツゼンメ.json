    "definitions": [
      {
        "index": 1,
        "gloss": "somewhat sudden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
