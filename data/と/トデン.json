    "definitions": [
      {
        "index": 1,
        "gloss": "metropolitan tramway",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "都電に乗ると、隣に坐っていた男が、「やあ、暫らく……」　と、声を掛けた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "都電に乗ろうとして、姉の遺骨を入れた鞄を下げたまま駅前の広場を横切ろうとすると、学生が一団となって、校歌を合唱していた。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　道子はそう呟くと、姉の遺骨のはいった鞄を左手に持ちかえて、そっと眼を拭き、そして、錬成場にあてられた赤坂青山町のお寺へ急ぐために、都電の停留所の方へ歩いて行った。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "東芝でさまざまな家電製品の開発に携わってきた山田正吾さん語り下ろしの「家電今昔物語」によれば、電気釜への初のチャレンジは、一九一五年頃、京都電灯によって行なわれたという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして電気コンロや電気鍋、電気ストーブに電気座布団と家庭に電力を売り付けるためにさまざまな製品が開発されていくことになるが、京都電灯はまず営業用に電気飯炊き器を開発し、続いて家庭用にも着手した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、彼は多摩川へ行ってみようと思いたつと、すぐ都電に乗った。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤めにゆくため、学校へゆくため、是非乗らなければならない省線、都電、バスなど、交通費もみんな三倍になりました。",
              "citation": {
                "source": "幸福のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時期に、都電が故障した偶然から、神明町のわきの本屋へ入った。",
              "citation": {
                "source": "春桃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで二人は都電で六本木まで行くことにしたが、栖方は、自動車の番号を梶に告げ、街中で見かけたときはその番号を呼び停めていつでも乗ってくれと云ったりした。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "風邪ひいてしまふわ……」「赤坂へ出て、あすこから、渋谷へ都電で出てみるのもいいぜ」「えゝ。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町角や都電停留場や店先や焼け跡の木蔭でなどで、或はその瞼の大きなふくらみを眺め、或はその下唇のたるみを眺め、或はその左の眼が物を見つめて細くなるのを眺め、或はその皮膚の薄い滑かさを眺めました。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯都電運転系統は現在左の通り動いている。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉川電車を渋谷で下りて、都電に乗ろうとして、渋谷から天現寺、四の橋行きはありますかと聞いたところ、今はやっていないとの事、なるほどそうであったかと、新橋行で行くことにする。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時過ぎたとき、誰かがもう失礼しないと都電がおしまいになるのではないかといった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ八時過ぎたばかりで、都電の赤電がある筈はあるまいと思っていると、岡東が時計を見て、ああ、そろそろ急がなくては……という。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当かいと聞けば、この頃の都電は八時半頃で終車となる由。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ごろ玉川線が十時半終車になったので、甚だ早すぎると思ったが、都電が八時半位で赤電になるなら、玉川線はまだましの方だ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃字をきき、新聞をすこしよむ、「都電でスられる」なんて、何だか可笑しいね（ごろが）と云って笑う。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月五日（金曜）　きょうから都電が系統制になって一系統十銭。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏川が都電を降りると、ヒロシが近づいてきて、ナアさん、お帰りなさいまし、と言ふ。",
              "citation": {
                "source": "母の上京",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電、都電にも近く、ドロボー君のアジトとしては日本有数の好点。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "山下から都電が岐れて、一本は池の方へまがろうとするところに共同便所がある。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、公園入口にぶらぶらむれている百人あまりの男娼パンパンがいわゆる一般人士に名の知れたノガミで、共同便所から池の端の都電に沿うた一帯の暗黒地帯は、ピストルの護衛がないと、とても常人は踏みこめない。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その日の行程を果した私が、都電向島終點近くの居酒屋で疲れた足をやすめてゐた時だ。",
              "citation": {
                "source": "露伴忌",
                "author": "心猿",
                "note": "青空文庫"
              }
            },
            {
              "text": "都電で雷門まで行き、此の前とは異つた別の映画館に這入つて、矢張其日と同じ頃に外へ出るが否や、友田は「何か一口食べて行きませう。",
              "citation": {
                "source": "男ごゝろ",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二場都電南千住涙橋附近の横町。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "空巣だと思って、材木座の派出所へ電話をかけたので、ああいう結末になった」　三原橋の近くまで来ると、エンジンをかけたまま十字路の角でパークし、運転手が、都電の線路ごしに、築地のほうから木挽町の通りへはいってくる車を、熱心にながめだした。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "中村の車は、都電の線路を横切って後を追っていたが、汐留の長いコンクリートの塀のあたりで、並行して走りだした。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "金吾　へえ、いいえ――警備員二　第一、省線も停まっちゃったし、都電もまだ動いちゃいないよ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「われわれが注意しはじめてから、雨の日も風の日も、休まずに、もう三週間もつづいているんですがねえ」　柚子は麻布霞町の家から都電で品川まで来て、川崎行のバスに乗るから、当然、大森海岸で降りるわけで、これにはふしぎはないが、四十分もそんなところに立っているというのは尋常でない。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
