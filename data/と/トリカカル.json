    "definitions": [
      {
        "index": 1,
        "gloss": "to begin (doing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
