          "literary": [
            {
              "text": "蛙料理は上等のバタでフライにしてトマトケチャップをかけて食べる。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私それをゆで、二人でトマトケチャップでたべる。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿では、板前がいろ／＼気を使ってるらしいのだが、何んなものにもトマトケチャップがかゝってゐる、新婚の花嫁が毎朝トマトケチャップを食はせるといふユモア小説を書きたい位だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
