          "literary": [
            {
              "text": "早く帰って闘球をしに来ませんか？",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし君のところの細君は闘球盤なんか絶対に駄目だよ。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お友達の家で闘球をして遊んで、夕ぐれになって帰るとき、これならば、心から笑って話せると思った。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘球台のでてゐる部屋の白壁には落花ふり切る淫祠の前の大銀杏のほとり何をか額き祈つてゐる雛妓の極彩色の日本画が掲げられてあつた。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕一路へ寄り、コーヒー飲み、橘の家へ、女房・清も行ってた、さて時節柄雀をすることも出来ず、闘球盤など一寸やってみたが、つく／″＼つまらん。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘球盤を買ふつもりが、小さいのしかないので、止めて、四階の新を呼んで食堂で冷コーヒー、伊東屋へ寄って、カルムを買って、本社へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
