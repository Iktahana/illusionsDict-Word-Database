        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木乃伊取り木乃伊となり、勅使の大臣は質に取られる事　こちらは、旅僧｜魯智深と、行者すがたの武松との二人。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、とりきんで足袋を引っぱったら、私はからだの重心を失い、醜くよろめいた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニはそれにうつとりきき入つてをりました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、「浜のゆうれい」のほうは、旅人が海べを、ひとりきりで歩いていると、そのあとをつけてきます。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根川のほとりきのふまた身を投げんと思ひて利根川のほとりをさまよひしが水の流れはやくしてわがなげきせきとむるすべもなければおめおめと生きながらへて今日もまた河原に來り石投げてあそびくらしつ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしを罵りわらふ世間のこゑごゑだれひとりきて慰さめてくれるものもなくやさしい婦人のうたごゑもきこえはしない。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし或るとき、酒に酔つてゐて牛と角力をとるんだとりきんできかない男を妻子が泣きながらひきとめてゐるのを見て、酒といふものも、はたして人のためになるかどうか、あやしいと思ひました。",
              "citation": {
                "source": "鳥右ヱ門諸国をめぐる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんひとりきりのときには、なるべく二階の室から出ないやうにつとめた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりきりの秘密を、たくさんたくさん持つようになりました。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗い八畳間の片隅に、紺絣を着た丸坊主の少年がひとりきちんと膝を折って坐っていた。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おひとりきりでおいでなさいね。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺太阿倍比羅夫楯つきなめ、艤ひゆきしかばふと、鰭つ物いむれてあれど、我獲ねば人とりき。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は失恋したときは、けっしてひとりきりにならないものだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ頃からはじまった事か、それはわからぬけれども、まさかここの場長がとりきめたものではなかろう。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりきりで、案内がわからなくつて困つて了ふつて言つてゐるもんですから」「それで行くところはわかつてゐるんですか？",
              "citation": {
                "source": "犬",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それ程さとりきっている僕でも、新聞の探訪記者という職業だけは、つくづくいやになっちまうことがある。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんぐり眼でしゃちこばっているやつらが今もあそこに何百匹並んでいるか知らねえが、用だ、あいきた、あっしでしょうねと、目から腹へ話のできる者ア、はばかりながらこの伝六様ひとりきりなんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "いってみりゃつまりそれなんですが、どうもいろいろとおかしい節がごぜえましてね」「どのようなことじゃ」「第一はお湯殿でごぜえますが、男の子ならなにもそんなまねしなくてもいいのに、どうしたことか陽吉さんは昔からひとりきり、別ぶろへへえりなさるんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかに力となるものとては、おじいさまおばあさまのおふたりがあるばかり、そのふたりもあいにくと善光寺参りに出かけまして、るすを預かっているのはたよりにならぬばあやがひとりきり、困り果ててこのように泣き乱れておりましたのでござります」「そうでしたかい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご免なんし――」　通りすぎて程たたぬまに、またひとりきょときょとしながら坂を降って来ると、同じように青ざめながら、ぶしつけに言いました。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべもやはりひとりきりで厶りました」「そう喃。",
              "citation": {
                "source": "老中の眼鏡",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「てまえに、家内、それから娘、それから――いいや、いいや、それだけじゃ、ことし十九になる娘がひとりきりでござります」「しかとそのお三人か！",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "道理で、さきほど家族しらべをしたおり、ほかに子はない、この娘ひとりきりじゃと、しどろもどろにいった様子がちとおかしいとにらんでおったが、やっぱり隠し子がありましたな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そこでまたあっしどもを門前に待たしておいて、米屋さんたったひとりきり――」「鍬と小判を持って境内へはいったか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、わたしの妻とは、彼女の父がとりきめた約婚者であつたのだが、民蔵（父）が昔の恩をかさに、あまり頻繁に金のゆう通ばかりを命ずるので遂に喜太郎氏は愛想を尽かして、「あんな横着者の娘などを貰つたら、到底ウダツのあがりつこは無いから、逃げるよ。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の教　　　　　アンリ・ドゥ・レニエいづれは「夜」に入る人のをさな心も青春も、今はた過ぎしけふの日や、従容として、ひとりきく、「冬篳篥」にさきだちて、「秋」に響かふ「夏笛」を。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛の教いづれは「夜」に入る人のをさな心も青春も、今はた過ぎしけふの日や、從容として、ひとりきく、「冬篳篥」にさきだちて、「秋」に響かふ「夏笛」を。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな出かけてしまつて、やがてそこには僕ひとりきりになつてしまつた。",
              "citation": {
                "source": "熱い砂の上",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "とくに、総領の息子、あるいは家督をとる一人の娘というような場合、これらの誕生の不幸な偶然にめぐり合った人々は、今もって家のために、親を養い、その満足のために、結婚がとりきめられ、そこでは家の格式だの村々での習慣だの親類の絆だのというものが、二重三重に若い男女の心の上に折り重ってかかってくる。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
