[
  {
    "uuid": "30b19cf9-d6b8-51a9-8b6a-3be5e78047b6",
    "entry": "尖る",
    "reading": {
      "primary": "とがる",
      "alternatives": [
        "とんがる"
      ],
      "is_heteronym": false
    },
    "grammar": {
