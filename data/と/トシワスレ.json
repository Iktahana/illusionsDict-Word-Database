    "definitions": [
      {
        "index": 1,
        "gloss": "forgetting the hardships of the old year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕と民子との関係も、この位でお終いになったならば、十年忘れられないというほどにはならなかっただろうに。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐かせようとして抱きかかへると、ぷんと腋臭めくにほひがしたが、それは永年忘れてゐたわが子のにほひだつた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お聞き及びでございましょうが、この十九日の晩に具足町の和泉屋で年忘れの素人芝居がございました」「そう、そう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚きと怖れとのうちに今夜の年忘れの宴会はくずれてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら御主人でももう堪忍ができないような気になって、わたしは気が狂ったのかも知れない……今度の年忘れの芝居をちょうど幸いに、日蔭町から出来合いの刀を買って来て、幕のあく間ぎわにそっと掏り替えておくと、それが巧く行って……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "長年忘れていた大掃除をするように、掃除を終った店からまた開業をやっていく。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑平老から年忘れの一封を頂戴した、すみません、すみません。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり気が沈むから二三杯ひつかける、そして人が懐かしうなつて、街をぶらつき、最後にＳのところで夜明け近くまで話した（今夜は商店はたいがい徹夜営業である）、酔うて饒舌つて、年忘れしたが、自分自身をも忘れてしまつた。",
              "citation": {
                "source": "行乞記",
                "author": "三八九日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、三日飼われてその恩を三年忘れない犬と反対に、猫は三年飼われてその恩を三日にして忘れる。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "云いかえれば、三年飼われてその家を三日にして忘れる犬と反対に、猫は三日飼われてその家を三年忘れないとか。",
              "citation": {
                "source": "猫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かねがね山田宗※のところへ弟子入りをしている脇屋氏（大高源吾のこと、京都の富商脇屋新兵衛と称して入りこむ）から、吉良邸では来月の六日に年忘れの茶会があるという内報もあった。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "土用時分になると、毎年忘れずに、向いの家からその実を貰いに来たものだ。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "運座はいい加減にして間もなくお酒がはじまり、歌えよ踊れよの年忘れ、到底稽古どころではなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "金太郎武蔵の旦那が御朋輩と年忘れにきておいでなさる、すぐ飛んできて貰いたいというのだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘイ圓朝、年忘れのお見舞いにうかがいました。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより圓太郎、私アお前に昨日越中島の養老院の年忘れに落語をやってきておくれとお頼みしたンだよ。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ近江様へ年忘れの芝居噺のお座敷にゆくンだ。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶりで私は年忘れをした満足をしみじみと味わわされた。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてまえのものは「丁度時候も十二月、年忘れの茶番をする気で、一狂言おれが書いた」とその後の幕ではッきりそう河内山のいっているのに徴して季節は冬である。",
              "citation": {
                "source": "上野界隈",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年忘れ老は淋しく笑まひをりうち笑める眉目｜秀でゝマスクかな十二月二十日　大崎会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今十四日、吉良邸で年忘れの茶会が催された事は、もう確実で一点の疑いもない。",
              "citation": {
                "source": "新編忠臣蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
