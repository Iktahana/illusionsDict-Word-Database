[
  {
    "uuid": "0c52fbdc-ced9-5f60-b9a3-50bd757b2936",
    "entry": "と言うことは",
    "reading": {
      "primary": "ということは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "副詞"
      ],
      "ctype": null,
