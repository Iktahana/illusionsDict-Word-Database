        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "特許料を期限内に納付しないと、権利が失効する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "特許料の減免措置について、特許庁に問い合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "特許料の支払いが、発明者にとって大きな負担となることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すると特許料など、他よりやすくしているのですか。",
              "citation": {
                "source": "名士訪問記",
                "author": "――佐野昌一氏訪問記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに現在日本国内での生産のために、外国へ支払っている特許料は、おびただしい額に上っている。",
              "citation": {
                "source": "科学と国境",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなくても資本による特許権の独占は排他的なのだから、外では特許料を払わない限りわざわざより未発達な・より原始的な・より非技術的な・技術を用いてしか、同じ生産を行なうことが出来ない。",
              "citation": {
                "source": "技術の哲学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
