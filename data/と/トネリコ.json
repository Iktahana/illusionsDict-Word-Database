      {
        "index": 1,
        "gloss": "Japanese ash (Fraxinus japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
