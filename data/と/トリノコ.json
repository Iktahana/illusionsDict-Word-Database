[
  {
    "uuid": "57b58d75-96fb-56e2-b360-8c8987244e60",
    "entry": "鳥の子",
    "reading": {
      "primary": "とりのこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
