    "definitions": [
      {
        "index": 1,
        "gloss": "bird's egg (esp. a chicken egg)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その原稿と色や感じのよく似た雁皮鳥の子紙に印刷したものを一枚一枚左側ページに貼付してその下に邦文解説があり、反対の右側ページには英文テキストが印刷してある。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物の大きさは三二×四三・五センチメートルで、用紙は一枚漉きの純白の鳥の子らしい。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもその鳥の子ははなしませんでした。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっかさん、僕ね、もじゃもじゃの鳥の子のおぼれるのを助けたんです」とホモイが言いました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎のお母さんは箱から万能散を一服出してホモイに渡して、　「もじゃもじゃの鳥の子って、ひばりかい」と尋ねました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……「ひどい墨だな、あやしい茶人だと、これを鳥の子に包むんだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生｜漉の鳥の子で四五帖分はある。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め筒鳥の子鳥が啼いてゐるのかと思つたが、よく聞けば全く異つてゐる。",
              "citation": {
                "source": "山寺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥絵具は絹や鳥の子にはかえって調和しないで、悪紙粗材の方がかえって泥絵具の妙味を発揮した。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾通かの手紙の一番最後に置かれていた鳥の子の立派な封筒を取り上げて、ふと差出人の名前に、目を触れたとき、彼女の視線はそこに、筆太に書かれている四字に、釘付けにされずにはいなかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚漉きの鳥の子紙に、どうしたことか裏にも表にも変な文句が書いてあるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾通かの手紙の一番最後に置かれてゐた鳥の子の立派な封筒を取り上げて、ふと差出人の名前に、目を触れたとき、彼女の視線はそこに、筆太に書かれてゐる四字に、釘付けにされずにはゐなかつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奥様」「――あけておはいり」　書生は鳥の子の襖を肩幅だけ開けて、一つの到来品を書状ぐるみさし出した。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種の実はこべらの実も食はずなりぬ親鳥も頼め子安の観世音竹の子も鳥の子も只やす／＼と糞づまりならば卯の花下しませ　晩飯は午飯とほぼ同様。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の子の飛ぶ時親はなかりけり（五月二十八日）十七○甲州の吉田から二、三里遠くへ這入つた処に何とかいふ小村がある。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "或日この子は大きな鳥の子の紙をどこからか買って来て、綺麗にボール紙に貼りつけて、四十八に割った細い罫を縦横に引いて、その一つ一つの目に、十二カ月の花や木の細かい画を上手にかきはじめました。",
              "citation": {
                "source": "祖母",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い鳥の子紙に、墨色も濃く、難破船を救助したことは奇特の至りだという褒め言葉が書いてありました。",
              "citation": {
                "source": "少年と海",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷹揚に肥満した背の高い兄と並び、クリーム色に山査子の花を泛べた千鶴子の服が、鳥の子の襖いちめんにぼうッと光圏を投げ拡げ、灯を映したその華やいだ色の中から、千鶴子は首を縮めてちょっと矢代を見ると眼を落した。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼓の音に乗り、鳥の子の襖を背に淀みなく廻っている金扇の流れを見ていても、矢代には、ともすると、それがＡとＢとの定律の舞いのように見えたりした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛鳥の子を養ひ、地を走る獣の子にせめられ候事、目も当てられず、魂も消えぬべくおぼえ候。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年の私は、孵ったばかりの千鳥の子を追って、石に躓き生爪を剥がして泣いたことも、二度や三度ではない。",
              "citation": {
                "source": "利根の尺鮎",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥の子神社というのである。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鳥の子、つまり卵だね」　と村長が云った。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハアハアハ」　私は鳥の子神社を見物に行った。",
              "citation": {
                "source": "安吾新日本風土記",
                "author": "第二回　富山の薬と越後の毒消し≪富山県・新潟県の巻≫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、昔、かごから逃げていなくなった鳥の子孫らであります。",
              "citation": {
                "source": "めくら星",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾き上がると、今度はその上へ上等の鳥の子を貼った。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその見えない天の川の水をわたって、ひとりのこうごうしい白いきものの人が手をのばしてこっちへ来るのを二人は見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もしも連れてまいらぬときは、よいか、宮中の役人どもは、夕食のあとで、ひとりのこらず、腹をぶつことにいたすぞ」「チン、ペー！",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "この広間に、宮中のお役人が、ひとりのこらず集まりました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、ひとりのこらず、頭にはかぶとをかぶり、手にはやりと、たてとを持っています。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            }
          ]
        }
