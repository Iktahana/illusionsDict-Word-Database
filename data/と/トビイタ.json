          "literary": [
            {
              "text": "追いかけっこをする一年坊主どもの甲高い叫びや、飛び板を踏みならす騒々しい音をぬって、遠い打球音がきこえてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾幅が十六センチしかないホワイトジーンズを脱ごうとして、高志は片足で立ち、二、三歩バックステップを踏んで、飛び板に背中をぶつけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎつぎと、飛び板ジャンプの絵がつながって出てくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
