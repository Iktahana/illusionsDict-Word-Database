[
  {
    "uuid": "da73c115-61ba-5947-b89e-31057c62a76b",
    "entry": "取り次ぐ",
    "reading": {
      "primary": "とりつぐ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ガ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to pass on (a message, thoughts, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最初の火花に相当する流言の「源」がなければ、流言蜚語は成立しない事は勿論であるが、もしもそれを次へ次へと受け次ぎ取り次ぐべき媒質が存在しなければ「伝播」は起らない。",
              "citation": {
                "source": "流言蜚語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の汚れているお前のような者に祈祷は無用であると、式部は行者の口上を取り次ぐようにして断わった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の宣旨が応接に出て取り次ぐ言葉を待っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "朝顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつものとおり一種の粘り強さをもって葉子の言伝てを取り次ぐ岡に対して、激しい言葉でその理不尽な狂気じみた葉子の出来心をののしったに違いない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "判事は女中の取り次ぐのも待たずに席を立って教授にちょっとことわって室を出てゆき、玄関で何やら低声で話していたが、すぐに引き返してきて語りつづけた。",
              "citation": {
                "source": "予審調書",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は貴女がたの不要品をいただいていって、それを金にかえて、困っている者に取り次ぐだけです。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶつぶつと言い通しだった伝六が、真に意外なる来訪者を取り次ぐことになりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お庄は時々、こんな電話を向島の方の妾宅から受け取って、それを奥へ取り次ぐことがあった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生に取り次ぐから――。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らが取り次ぐと言ったら、ともかくその用というのを話したらいいじゃないか。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大人などには話さないで、そっと女王さんに私の言ったことを取り次ぐのだよ」　と返す返す宮は仰せられた。",
              "citation": {
                "source": "源氏物語",
                "author": "紅梅",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれも皆恥じて取り次ぐことのできないふうであるのを見て、大姫君がまたつつましいふうで自身で言った。",
              "citation": {
                "source": "源氏物語",
                "author": "橋姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "男も女も、襷がけでクル／＼と郵便配達の周囲を廻つてゐるけれども、お客の方に夢中で、誰れ一人女主人の為めに、郵便配達の手から厚い封書を取り次ぐものはなかつた。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "男も女も、襷がけでクル／＼と郵便配達の周圍を※つてゐるけれども、お客の方に夢中で、誰れ一人女主人の爲めに、郵便配達の手から厚い封書を取り次ぐものはなかつた。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "一體わが國の學者の多數は、西洋人の所説を其の儘取り次ぐか、若くは多少之を敷衍するか、然らずとも彼等の暗示によりて研究の題目を得るといふに過ぎぬ。",
              "citation": {
                "source": "那珂先生を憶ふ",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、さあ心配だぞ）　クーパーはパイクソンとマルラにこの話をして、またそのことで電話がかかってきたらすぐ取り次ぐようにといった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に半蔵らが奉行の屋敷に出た日には、徒士目付が応接に出て、奉行へは自分から諸事取り次ぐであろうとの話があった末に、今度三人の庄屋を呼び出した奉行の意向を言い聞かせた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "オランダ人からの進物を将軍に取り次ぐことも、あるいは将軍の言葉を彼らに取り次ぐことも、それらはみなこの牧野老中がした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "異人の言葉を取り次ぐことも、旅の案内をすることも、すべて通弁がした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "この飛騨行きについては、恭順はただ不二麿の話を取り次ぐだけの人だと言っているが、それでも半蔵のために心配して、飛騨の水無神社は思ったより寂しく不便なところにあるが、これは決して左遷の意味ではないから、その辺も誤解のないように半蔵によく伝えくれとの不二麿の話であったと語ったりした。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "来客があれば取り次ぐ前に玄関でこっそり口止めを頼む。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い客　　取り次ぐ奴がゐるからいけないんだ。",
              "citation": {
                "source": "風俗時評",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "物もいえぬ」「だから取り次いでおくんなせえまし」「取り次ぐことは罷りならぬよ」「ではどうしても出来ねえだか」「さようどうしても出来ないな」「ではしかたがねえ、帰るべえ」「その方がいい。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "張帥に面会を求める客の名刺を秘書官へ取り次ぐ役目なのだが、それだけで年に二万元近くの役得があるといふ噂を聞いた。",
              "citation": {
                "source": "南京六月祭",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔いろを変えた与吉が、おののく手で各務房之丞の肱をつかみ、何ごとか二、三声ささやくと、ウムそうかと眼を見はった房之丞、おおきくうなずきながら首領月輪軍之助の耳へ取り次ぐ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は階子段の途中で薬局生の面倒臭そうに取り次ぐ「津田さん電話ですよ」という声を聞いた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても中へ入って取り次ぐ人の必要があった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は笹沼がさう云ふ性質の、殊に分不相応の金を、融通する筈がないことを知つてゐたから、一往取り次ぐことは取り次いだけれども、さう熱心には口説かなかつたし、又笹沼も始めから取り合はなかつた。",
              "citation": {
                "source": "青春物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺がそいつを、取り次ぐだけの話なんだ。",
              "citation": {
                "source": "仁王門",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言方の勤める「間語り」なども、もどきの口まねから出て、神などに扮した人の調子の低いはずの詞を、大きな声でとりつぐ様な役が分化してゐた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
