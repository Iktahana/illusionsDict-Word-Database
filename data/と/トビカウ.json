    "definitions": [
      {
        "index": 1,
        "gloss": "to fly about",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、その夕、電燈｜煌々として自動車の目まぐるしく飛び交う賑やかな町中で、一枚の号外を握って、地質時代の出来事であるところの、氷河退却時代が、眼のあたりに見られるのだと思った。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰来した燕は、その麦の上を、青葉に腹をすらんばかりに低く飛び交うた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外は真昼のような良い月夜、虫の飛び交うさえ見えるくらい、生茂った草が一筋に靡いて、白玉の露の散る中を、一文字に駈けて行くお雪の姿、早や小さくなって見えまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝樹の枝から枝へと飛び交うて居る、色々様々な諸鳥は、白｜鵠、孔雀、舎利、伽陵頻迦、共命などの鳥であろうと思った。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "はては任天堂がどうしたこうしたとキーワードが飛び交う中で、オレがウイルス頭を抱えてパネラー席でぼんやり考えていたのは、コンピューターの使いこなしにおける『世界観』だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "声ばかり飛び交うているかのように、闇のなかに千鳥が、ちちと鳴きしきっていた。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、群青色にはろばろと続いている太平洋の上には、信天翁の一群が、飛び交うているほかは、何物も見えない。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に接している砂浜は金色に輝き、飛び交うている信天翁の翼から銀の光を発するかと疑われ、いつもは見ることを厭っていた硫黄ヶ岳に立つ煙さえ、今朝は澄み渡った朝空に、琥珀色に優にやさしくたなびいている。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "拳骨がぶつかり合い、馬車から降りた婦人はたちまち、拳や杖の飛び交う喧噪の渦の中へ巻き込まれてしまった。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の町では燕の巣のある家が多く、夏には街の空を燕が縦横に飛び交うていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び交う数字と一種名状すべからざる緊張した熱意で飽和している空気の中をそっと、一人の婦人党員が舞台から日本女のところへきた。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親も油井もいやで、がっかりして、風も身に沁みる、空の高さも、そこに飛び交う蜻蛉も身に沁みる。",
              "citation": {
                "source": "未開な風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕の群が中流の上を飛び交うている。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "……しかし時々青い火花が、パッパッパッパッと飛び交うそうで。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に藤の花も散り、あのじめじめとした悒鬱な梅雨が明けはなたれ、藤豆のぶら下った棚の下を、逞ましげな熊ン蜂がねむたげな羽音に乗って飛び交う……。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎のゆるく飛び交う水面を拡がる水脈のような甘美な愁いがいっぱいに流れわたった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨を鳴らせて飛び交う鳩の身体からうす冷たい風が立ち耳の根をひやりとさせた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼ざす私の舞台は漠として分らなかったが、それは今日の農会の人の集りのようでもあれば、強盗横行の東京のようでもあり、そのどちらでもない、荒れ狂った濁流の世の若さが、今見る雪の飛び交うさまに見えたりしているようでもあった。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、投げ槍の飛び交う下で、鉾や剣が撒かれた氷のように輝くと、人々の身体は手足を飛ばして間断なく地に倒れた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆はどよめいて、囁きが飛び交うた。",
              "citation": {
                "source": "十姉妹",
                "author": "山本勝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りは質屋とみえて新しく壁を塗つた倉があり、夜露のぎらぎら光つた屋根瓦に雀が忙はしく飛び交うてゐた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊代は出窓の上の、馬穴の上に飛び交う蠅を見ていた。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横無尽に行き交い飛び交う。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "観客で埋まったスタンドで四方を囲まれ、走り廻る選手や飛び交うボールの間をぬって、無心そうにひらひらと飛んでいる。",
              "citation": {
                "source": "ジャングル頭",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は身をかがめながら、苔蒸した井筒に溢れる水を素焼の甕へ落していたが、ほかの女たちはもう水を汲み了えたのか、皆甕を頭に載せて、しっきりなく飛び交う燕の中を、家々へ帰ろうとする所であった。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼等は倭衣の肩を並べて、絶え間なく飛び交う燕の中を山の方へ歩いて行った。",
              "citation": {
                "source": "素戔嗚尊",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまた飛び方が両方へ表紙を開いて、夏の夕方に飛び交う蝙蝠のように、ひらひらと宙へ舞上るのです。",
              "citation": {
                "source": "魔術",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇内を、ひゅうんと呻ってすごい速力で飛び交う塵塊があった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっ外して外して」は底本では「ひっ外して」］右へ小一郎が、飛び交うのを追っかけた吉次の、その素早さ、どうでも妖怪、二本足のある人間より、遙かに遙かに遙かに早い。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子　（機を織りつつ歌う）美しき色ある糸の綾を織る人の一生、五色の色のさだめは苧環の繰るにまかせて、桧の梭の飛び交うひまに、綾を織る罪や誉や。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
