        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "侍女四　（同じく公子の背後に）鮟鱇五十袋、虎河豚一頭、大の鮹｜一番。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち名古屋河豚（小斎河豚）、目赤、虎河豚、黄金河豚、銀河豚、北枕、篭目河豚などが普通知られている。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私らが、料理屋で食うのは虎河豚、名古屋河豚、世間では金河豚といっている黄金河豚であるが目赤と北枕、篭目は猛毒の持主で、食えば大概極楽行きである。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番人に歓迎されるのが虎河豚で、漁も沢山ある。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎河豚のように皮膚に刺はなく肌に黄金色の艶が出ているのである。",
              "citation": {
                "source": "海豚と河豚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
