    "definitions": [
      {
        "index": 1,
        "gloss": "stop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして電車の音も止まり近所の大工の音も止み、世間がしんとして実に静寂な感じがしたのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神もおはしまさば我家の檐に止まりて御覽ぜよ、佛もあらば我が此手元に近よりても御覽ぜよ、我が心は清めるか濁れるか。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車で街を縦走して、とある辻から山腹の方へ広い坂道を上がって行くと、行き止まりに新築の大神宮の社がある。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その止まり方がまた実に突然で今までの活劇がまるで嘘であったように思われた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に事柄を簡単にするため、地殻の弱点はただ一箇所に止まり、地震が起るとせば必ずその点に起るものと仮定せん。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神もおはしまさば我が家の軒に止まりて御覧ぜよ、仏もあらば我がこの手元に近よりても御覧ぜよ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故にまた室生のやうな坂道がなく、いつでも同じやうな地點に止まり、仕事を投げ出しては退屈に寢ころんでゐる。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦慄から、私は殆んど息が止まり、正に昏倒するところであった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝道――大吉と半次の立廻り　半次が一人踏み止まり、大吉は逃げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お殿様は橋の袂に、何かを見て、お止まりなされた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　そのうちに私の方に向つて歩いてくる人々の異常な擧動が、突然、私の目に止まりました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に、カッフェの店先を掃除してゐた、一人の給仕は、手を休めながら、物珍らしさうに、身體を不意にゆすぶり、立ち止まり、それからぴよんぴよん跳びながら、再び歩き出してゆくその通行人を眺めました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は立ち止まりました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "）出來れば、私はもつと此處に止まりませう。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "また何のためにそんなに大勢のしかかつて來たのか分らないが、何しろ重さで息が止まりさうに苦しいのと、大波が眞向から押しかぶさつてくるやうな恐ろしさとだ。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田は、南京袋のような臭気を持っている若者にねじ伏せられて、息が止まりそうだった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は八幡宮の石段を数えて登り、一、二、三と進んで七つと止まり、七つだよと言い聞かして、さて今の石段はいくつだとききますと、大きな声で十と答える始末です。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十二年一月『中央公論』）　　　　　　四　切符の鋏穴　日比谷止まりの電車が帝劇の前で止まった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "店にあらん限りの古い帳面を調べても三十年前が行止まりであつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今にも襟髪を掴むか、今にも崖から突き落とすか、そんな恐怖で息も止まりそうになっているんです。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が見ている秒針の動きは止まりはしなかった、確実な歩調で動いていた。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い木霊はギクッとして立ち止まりました。",
              "citation": {
                "source": "若い木霊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わずヨロヨロとよろめいて、漂い砕くる波の泡の中に落ち込みそうになりましたが、やっとの思いで崖の端に踏み止まりました。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての生きた芸術、技術、修養の行き止まりである。",
              "citation": {
                "source": "能ぎらい／能好き／能という名前",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "筑紫野を見晴らす大根畠と墓原の間の小径の行止まりに、万延寺の本堂と背中合わせにして一軒の非人｜小舎がある。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその虚無はあらゆる哲学、宗教、道徳、芸術の行き止まりに存在するものでなければならぬ。",
              "citation": {
                "source": "実さんの精神分析",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にも知らぬ鵙はいつもの通り遠方からキイキイ啼きながら飛んで来ていつも止まる木の一番高い処に止まりますと、コハ如何に、足がピタリと吸い付きました。",
              "citation": {
                "source": "鵙征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山鳩一羽いずこよりともなく突然｜程近き梢に止まりしが急にまた飛び去りぬ。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場まで来ると汽車はいま出たばかりで、次の田端止まりまでは一時間も待たなければならなかった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあすこの福和戸のやうながらんどうの温泉、普通の駅路の両側に家が並んだやうな温泉は、どこか埃くさい気がするのと、まとまりのない不安な気がするので、とても落付いた気分になれない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
