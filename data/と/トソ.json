    "definitions": [
      {
        "index": 1,
        "gloss": "spiced sake (served at New Year's)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "以上は新春の屠蘇機嫌からいささか脱線したような気味ではあるが、昨年中頻発した天災を想うにつけても、改まる年の初めの今日の日に向後百年の将来のため災害防禦に関する一学究の痴人の夢のような無理な望みを腹一杯に述べてみるのも無用ではないであろうと思った次第である。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし当りさわりがあったら勝手ながら屠蘇のせいと見遁してもらいたい。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この屠蘇の盃が往々甚だしく多量の塵埃を被っていることがある。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も屠蘇そのものが既に塵埃の集塊のようなものかもしれないが、正月の引盃の朱漆の面に膠着した塵はこれとは性質がちがい、また附着した菌の数も相当に多そうである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屠蘇と一緒に出される吸物も案外に厄介なものである。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば一軒の家庭に在っては、主人が正月、家族一同に屠蘇の盃を与える場合であります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三つうけて屠蘇を祝ふ。",
              "citation": {
                "source": "熱海の春",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯朶活けて五十二の春を迎へた　お屠蘇は緑平老から、数の子は元寛坊から、餅は樹明居から頂戴した。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "年増の福太郎と春次は銀子と連れ立ち、出の着附けで相撲の娘の小福を初め三人のお酌と、相前後して座敷に現われ、よそ座敷に約束のある芸者も、やがて屠蘇機嫌で次ぎ次ぎに揃い、揃ったかと思うと、屠蘇を祝い御祝儀をもらって後口へ廻るものもあった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうは、お雑煮を食べたり、お屠蘇を飲んだり、ちょいちょい起きて不養生をしていましたね。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも拘らず、書いてる事が何処となく屠蘇の香を帯びているのは、正月を迎える想像力が豊富なためではない。",
              "citation": {
                "source": "元日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃いのように紅白のだんだら幕で、柳の根方に店囲いを作り、羽子板店に紙鳶店はもちろん、神棚の祭具を売る店、餅網、藁のお飯｜櫃容れを売る店、屠蘇の銚子や箸袋を売る店、こういう正月向きの売店が賑々しく普通の売店に混り、普通の売店も負けず劣らず飾り立てゝ、もはや春が見舞って来た景気です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "屠蘇を飮ましながら、言葉靜かに言つて聞かした教訓は決して珍らしい説ではなかつたのです。",
              "citation": {
                "source": "日の出",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その正月に西岡は叔父のところへ年始に来て、屠蘇から酒になって夜のふけるまで元気よく話して行った。",
              "citation": {
                "source": "離魂病",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚六の家では屠蘇を汲み雑煮を祝おうとしたところで、持仏堂の中が怪しい音を立てて鳴りだした。",
              "citation": {
                "source": "一緒に歩く亡霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶がすんで、屠蘇が出て、しばらく話しているうちに、その子はつかつかと縁側へ立って行った、と思うといきなりそこの柱へ抱きついて、見る間に頂上までよじ上ってしまった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新の元旦には母など一向に父を相手にしませんので、父は私を相手に『元日』の屠蘇を祝ひました。",
              "citation": {
                "source": "樹木とその葉",
                "author": "故郷の正月",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御馳走は……しかも、ああ、何とか云う、ちょっと屠蘇の香のする青い色の酒に添えて――その時は、筧の水に埃も流して、袖の長い、振の開いた、柔かな浴衣に着換えなどして、舌鼓を打ちましたよ。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに御祝儀の屠蘇が出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲仕――権三といわれていた――は、特別の賃銀を支払われると言う約束で、明日のお屠蘇の余分の一杯をあてにしてやって来たのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから『荊楚歳時記』から引いた元旦の式を述べた上文、〈以て山※悪鬼を辟く〉の次に、〈長幼ことごとく衣冠を正し、次を以て拝賀し、椒柏酒を進め、桃湯を飲み屠蘇を進む云々、各一鶏子を進む〉とあって、註に『周処風土記』に曰く、正旦まさに生ながら鶏子一枚を呑むべし、これを錬形というとある。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝暗いうちに自宅で屠蘇を祝つて、五時沼津の狩野川河口を出る汽船に乘るのです。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "内膳正は屠蘇を汲み乾すと、立ちながら、膳を踏み砕いて、必死の覚悟を示した。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "くす師ふりはへて屠蘇白散酒加へてもて來たり。",
              "citation": {
                "source": "土佐日記",
                "author": "紀貫之",
                "note": "青空文庫"
              }
            },
            {
              "text": "お定まりの屠蘇や重詰物もならべられて、主人も客もその顔をうすく染めていた。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　初対面の挨拶が型の通りに交換された後に、わたしも主人から屠蘇をすゝめられた。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずおめでとうございます」　いつもの座敷へ通されて、年頭の挨拶が式のごとくに済むと、おなじみの老婢が屠蘇の膳を運び出して来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三河万歳",
                "note": "青空文庫"
              }
            },
            {
              "text": "いま初夏きたる、野に山に、榮光榮光、榮光いんよくの主とその僕にあれ。",
              "citation": {
                "source": "初夏の祈祷",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜石よりの帰り宮沢賢治かぎりなく鳥はすだけどこゝろこそいとそゞろなれ竹行李小きをになひ雲しろき飯場を出でぬみちのべにしやが花さけばかうもりの柄こそわびしきかすかなる霧雨ふりて丘はたゞいちめんの青谷あひの細き棚田に積まれつゝ廐肥もぬれたり",
              "citation": {
                "source": "釜石よりの帰り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔霜枯れのトマトの気根〕宮沢賢治霜枯れのトマトの気根その熟れぬ青き実をとり手に裂かばさびしきにほひほのぼのとそらにのぼりて翔け行くは二価アルコホール落ちくるは黒雲のひら",
              "citation": {
                "source": "〔霜枯れのトマトの気根〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
