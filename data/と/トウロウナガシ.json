    "definitions": [
      {
        "index": 1,
        "gloss": "ceremony in which paper lanterns are floated down a river",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
