          "literary": [
            {
              "text": "四　私と同級生で特待生のＭが私の内に十二指腸で入院した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて自分が中學の特待生でもあつたら可かつたらう。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学期毎に試験の点数を争って、特待生を狙う勉強家ではない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "官立學校の特待生で幅を利かしてゐる人の中には、澤山さういふのがある。",
              "citation": {
                "source": "當流比較言語學",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常なるトルストイアンで特待生である吉田は芝居のプログラムばかりが散乱して英語の本など読みもしないやうな私の机のまはりを苦々しく見廻して、お前は好くそんな態度で生きて居られるな！",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは何よりもその特待生が嫌いなんだ。",
              "citation": {
                "source": "一利己主義者と友人との対話",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして私は音楽学校の四年間、特待生として数々の思い出を残して、明治三十七年七月に本科を卒業いたしました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の人は此の度二年になる時に特待生になった方です。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校で特待生になったからその褒美に下すったんだ。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が特待生になったんだと。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "特待生になったんだね。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三學年に仙臺に歸つて片平町小學校に復校し、同校卒業後宮城女學校に入學、五ヶ年の課程を了へ、同校音樂專攻科第二學年に特待生として入學を許されました。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "各学年に数名の程度であって、日本の昔の特待生みたようなものである。",
              "citation": {
                "source": "ピーター・パン",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "在学中の成績で、月給が違うというようなことがあり、大学で特待生だった松本烝治だけが五十円、私が四十五円で、他の人たちが四十円というような扱いを受けた。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "特待生です」「一番ですか？",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "級長の立花君は特待生という都合上、自分一人｜善い子になりたがって、これを奇貨とする傾向がある。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
