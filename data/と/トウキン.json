    "definitions": [
      {
        "index": 1,
        "gloss": "on-the-spot payment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まだそのほかに話がまとまり次第、一種の支度金のような意味で当金百両出そうという条件まで付けて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのも彼女もまた場末とはいいながら、ひとかどの芸者の抱え主として、自身はお化粧｜嫌いの、身装などに一向｜頓着しないながらに、抱えのお座敷着には、相当金をかける方だからであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の馬が売れないのに配当金いずれにありやと訊いて見たくなる。",
              "citation": {
                "source": "我が馬券哲学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせご番所のお手当金をいただくんだもの、足代ぐらいはしみったれなくたっていいじゃござんせんか」「だから、おめえなんざいつまでたっても出世しねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "居士号大姉号をつけてあるところは相当金持ちだな」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸野はその外に拓殖銀行から株の配当金を受取る。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず陸軍大臣が保健省設立を提案するという興味ある形で今日とりあげられている青年男女の体格低下の問題や、婦人労働者の退職手当金の問題、又頻々たる心中事件の意味など、恋愛論が、恋愛論の枠の中を廻っていただけでは解決し得ぬ先行的事情が、附随してとりあげられなければ、実際性は稀薄なのである。",
              "citation": {
                "source": "もう少しの親切を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "各箇人としては充分に資料も持って居るのに、其を集めて博物館とする迄に到らない原因、確に永山氏の説かれる通り、長崎人の伝統的な気質――会所からの配当金で楽々生活して居た時代から、あくせく知らず――が重大な関係をもって居るだろう。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ではまだ敵討の願を出したばかりで、上からそんな沙汰もないうちに、九郎右衛門は意気揚から拵附の刀｜一腰と、手当金二十両とを貰って、姫路を立った。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "道中御手当金二十八両一分一朱と銭五百三十三匁受取。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業的に慣れた彼の目で一ト目見ると、屋主の老人が重要書類を入れてある用箪笥や、金が蔵ってあるに相違ない櫃の在りどころや、その他寝台が凹間の中にあること、硝子戸のついた抽斗沢山の大きな衣裳戸棚にも、相当金目のものが入っているらしいということまで、残らず見極わめることが出来たのだ。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君に逢ひに行くには、相当金がいるのかね？",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧は、廊下へ立ったまま、出て来た女中に「山内が、その辺に居らぬか、お捜し下さるよう」　女中が、去ると「牧殿、これへ、御手当金を、置いておきますぞ」　と、云って、金包を出して、畳へ置いて、押えつけた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "町会でも、兎角感情の衝突が頻発するようになり、あぶらやでは相当金を撒いているとも言われた。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "百両の家作料と三カ年の手当金百五十両を給した。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、依田氏はなお声をひそめて、自分が出かけていっては工合がわるいことがあると弁解し、個人にせよ会社にせよ、時として秘密な窮地に立つことがあるものだと云い、この商事会社の立前として無抵当金融は絶対に謝絶しているので、秘密を守るためには君より外に使者がないと云うのだった。",
              "citation": {
                "source": "死の前後",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後、家の人たちは知人のところに同居しているが、彼女は以前の奉公先からの多額な手当金をもとでに、或る家の階下を借りて酒場を初めた。",
              "citation": {
                "source": "紫の壜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月の末、私は退職手当金のわずかと、その月の給料をもらい、社長以下にぺこぺこ別れの挨拶をして会社をやめた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は体格のガッシリした遊び人風の若い男だが、洋服は上物で、相当金のかかった服装だ。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "別当金剛院小名浦嶋ニ住メリ。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その所為か登山道も、日向大谷（明神社別当観蔵院、当山派修験）からの表口の外に、浦島（権現社別当金剛院、本山派修験）から両見山に上って、長い尾根を西に伝い、二子山、三笠山などを経て表口に合するもの、白井差から登って、三笠山の西で表口と浦島口とに合するもの、及び中津川道などがある。",
              "citation": {
                "source": "奥秩父",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、上海あたりで、ホテルのボーイでもしてゐれば、相当金がはひりさうなもんぢやないか。",
              "citation": {
                "source": "ガンバハル氏の実験（ラヂオドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて仏蘭西に相当金を貢いで、復興を図る事は、何等支障が無いと云ふのが、亜米利加辺りの観察であります。",
              "citation": {
                "source": "最近欧米に於ける財政経済事情",
                "author": "井上準之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん初めは相当金をかけたのであろうが、これだけもてば安いものである。",
              "citation": {
                "source": "ウィネッカの秋",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あさくさ瓦町の家から、泰軒、栄三郎をつけて来た弥生と豆太郎、つかず離れず見え隠れにこの別当金剛院のお庭へはいりこんで、ふと気がつくと、今まで先方をズンズン歩いていた栄三郎と泰軒が仔細ありげにぴたッと足をとめているから、こっちもあわてて樹陰の闇黒に身をひそめてじっとようすをうかがうと――。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、しかる上は健三離縁本籍と引替に当金――円御渡し被下、残金――円は毎月三十日限り月賦にて御差入のつもり御対談｜云々と長たらしく書いてあった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月欠かさず母の許に送られてきた、手当金もぱったり途絶えた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後、陸軍の用地だった方々の土地の払い下げ問題の世話焼きと言うか、そう言う事の委員やなんかやって、相当金ももうかるようで、その金を土台にして、もとの軍人などを集めて一種の国民運動組織のようなものを拵えているようでした。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりに政府の方からも幾分の手当金があって大分に品格が違って居ります。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
