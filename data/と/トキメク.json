[
  {
    "uuid": "e01c0895-c89d-576b-9b89-4b8ccb8ff75d",
    "entry": "ときめく",
    "reading": {
      "primary": "ときめく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-カ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to beat fast (of one's heart)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木遺男の勇者等も仕事師ばらの援軍もいま力戰の眞最中やたち上りたる、もうぢんの中に交りて一しきり陣鼓ときめく凄まじさ。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにもその男が、世の中から正当に言われていない場合には、いっそう胸がときめくのである。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "青草の景色もあれば、胸のときめく娘もいた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああこのわかやげる思ひこそは春日にとける雪のやうだやさしく芽ぐみしぜんに感ずるぬくみのやうだたのしくうれしくこころときめく性の躍動。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして走つてゐると彼は何となく胸のときめくのを禁じえない。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで三度も、そのやうな胸のときめく風の便りを受けとつた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いままで三度も、そのような胸のときめく風の便りを受けとった。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちまいの襖をするするあける度毎に、彼のよごれた胸が幽かにときめくのであつた。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山荘の人のことを絶えず思いやっている源氏は、公私の正月の用が片づいたころのある日、大井へ出かけようとして、ときめく心に装いを凝らしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、こうした秋晴の朝は、今日の裡に何かよい事が自分を待っているような気がして、何となく心がときめくのを覚えるのであった。",
              "citation": {
                "source": "死者を嗤う",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自からときめく胸を抑へてわたしは其処へ行つた。",
              "citation": {
                "source": "木枯紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "村川は年若い処女の好意のシンボルそのものといったようなその肱附を、ちょっとときめく心で取上げた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子が、夫に扶けられて、自動車から宏壮な車寄に、降り立った時、遉にその覚悟した胸が、烈しくときめくのを感じた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの鉄の三層の階段を、どんなに急いで駆け上ったか、そして、どんなにときめく心と険しい目付とをもって Fine Arts――Sculpture の項を、探ったことだろう。",
              "citation": {
                "source": "出世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして静かな中にじいっと一つ物を見つめて居る事は今になってさえ止まない私の気持の良い胸のときめく様な気のする事である。",
              "citation": {
                "source": "Ｍ子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子が、夫に扶けられて、自動車から宏壮な車寄に、降り立つた時、遉にその覚悟した胸が、烈しくときめくのを感じた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忘れがたみ一こよひ天なる花苑の美し黄金のおばしまに、夜すがら君や立すらめ、すずろに胸のときめくは。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　滝は、どうもそれらしいと思はれて来ると、次第に、新しく胸のときめく悪びれを覚えるのです。",
              "citation": {
                "source": "舞踏会余話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は蚊が腹に妻の血を蓄へて飛んでゐるのを見ると、妻の死骸よりも、蚊の腹の中で、まだ生きてゐる妻の血に胸がときめくのを感じた。",
              "citation": {
                "source": "蛾はどこにでもゐる",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "カラ　ああ、私の冷かな鉛の乳房も激しい期待でときめくようだ。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今庸三は文字どおり胸のときめくようなある一夜を思い出した。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "身ぶりの端々にときめく心を目ざまされている。",
              "citation": {
                "source": "日本の秋色",
                "author": "――世相寸評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "優婉な紫の上が光君と一緒に、周囲の女性たちにおくる反物を選んでいるところはあるけれど、落窪物語はやはり王朝時代に書かれた物語ではあるけれども、ここに描かれている人たちは源氏物語のように時代にときめく藤原の大貴族たちではない。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "心のときめくかくれ場所はもう一ところあった。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――純白な紙、やさしい点線のケイの中に何を書かせようと希うのか深みゆく思い、快よき智の膨張私は　新らしい仕事にかかる前愉しい　心ときめく醗酵の時にある。",
              "citation": {
                "source": "初夏（一九二二年）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心は珍しいことにときめく」　ひたひたと寄り添ってこんな戯れを源氏は言うのである。",
              "citation": {
                "source": "源氏物語",
                "author": "蛍",
                "note": "青空文庫"
              }
            },
            {
              "text": "使いを受けた中将は心のときめくのを覚えた。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の日の女のゆびこの　ぬるぬるとした空気のゆめのなかに、かずかずのをんなの指といふ指はよろこびにふるへながら　かすかにしめりつつ、ほのかにあせばんでしづまり、しろい丁字草のにほひをかくして　のがれゆき、ときめく波のやうに　おびえる死人の薔薇をあらはにする。",
              "citation": {
                "source": "藍色の蟇",
                "author": "大手拓次",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、何かもっと美しい、心のときめくようなものでも見せて貰いたいねえ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
