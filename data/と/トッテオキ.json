    "definitions": [
      {
        "index": 1,
        "gloss": "reserve",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし、もっとよけい、二円でも三円でも、取れるだけ取っておきたい。",
              "citation": {
                "source": "選挙漫談",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隊を指揮する、取っておきのどら声で怒なりつけようとした。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで子供らは、そういういくつかの取っておきの話の中から、あれをこれをと注文して話させては笑いこけるのであった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもアメリカトーキーだとここでなんとか一つ取っておきのせりふを言わせて、そうしてアメリカ語のわかる観客だけをどっと笑わせないと気がすまないであろう。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所も私の無理が通りまして、一番見いいところを取っておきました。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御免なせえ……お香のものと、媽々衆が気前を見せましたが、取っておきのこの奈良漬、こいつあ水ぽくてちと中でがす。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「エンリョはいりません」など取っておきの日本語を出したりした。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のうちに取っておきましょうから、おいでなせえまし」　いざなっていった所は、広縁側の柱の蔭の、いかさま見張るには恰好な場所でした。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "写真は護身のために取っておきます。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十二　晩飯の時、叔母は叔父の好きな取っておきの干物などを炙り、酒もいいほど銚子に移して銅壺に浸けて、自身｜寝室へ行って、二度も枕頭で声をかけて見たが、叔父は起きても来なかった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり年を取らないうちに、そんな写真も取っておきたいじゃないの。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや実はネ、それについて一つ、取っておきの因縁ばなしがあるんですがネ、今日は思い切って、そいつを御話してしまうことに致しましょうか。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十六歳と云う女の年齢が胸の中で牙をむいているけれども、きんは女の年なんか、長年の修業でどうにでもごまかしてみせると云ったきびしさで、取っておきのハクライのクリームで冷い顔を拭いた。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "拾得が食器を滌いますとき、残っている飯や菜を竹の筒に入れて取っておきますと、寒山はそれをもらいに参るのでございます」「なるほど」と言って、閭はついて行く。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけの見識をそなえたものならば知らず、あまりよい名は――つまり名妓をだしたのを誇りにして、取っておきにする例がある。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　貞子は礼子を寝かしつけると、取っておきの電車代をそっとつまんで、「啓ちゃんバットを一つ買っていらっしゃい。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時には黙って受取っておきながら今更そんな事を云っては困る。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……けれども万一、あの曲馬団がやられる時に、どさくさに紛れて外の人間の手に渡って反古にされるような事があったら大変と気が付きますと、何でも自分の手に奪い取っておきさえすれば安心と思いましたから、直ぐ狭山さんにお手伝いをお願いして取りに行ったのです。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "七瀬は、それを深く、強く、自分の眼の底に、胸の奥に、懐の中に取っておきたいように、感じた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも手付は四千円取っておきましたがね。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど僕は金を取る訳がないんだ」「そんな解らない事を云わずに、まあ取っておきたまいな」「僕はやるんだよ。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら学校にいるうちもっと勉強して好い成績でも取っておきそうなものだのに、そこが浪漫家だけあって、学課はなるべく怠けよう怠けようと心がけて通して来た結果、すこぶる鮮やかならぬ及第をしてしまったのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その骨や頭を水から三時間ほど煮てスープを取っておきます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでいよいよ取っておきの話をするが、実はカフェ・ネオンの惨劇の犯人と目される春吉と鈴江の関係について、僕が知っていることがある。",
              "citation": {
                "source": "電気看板の神経",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "産の始末がすっかり済んでしまってから、彼は産婆と助手と一緒に、取っておきの鮨を茶の間で食べた。",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷口が痛そうな振りもせず、とっておきの壁の青い別室に坐りこんでいた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイ子に名前をいわれたので、慶一はおどろきのあまり、紹介されたら披露しようと思っていた、とっておきの微笑を引っこめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっておきの靴をはいて、初夏らしい帽子をかぶり手に袋など持って、のんびり散歩している。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄金虫だの、いろんなものが中へ落ちていましたがね、そういうごみはわしがとっておきましたでな、今は綺麗なもんでがす。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢は人間とっておきの自由だ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
