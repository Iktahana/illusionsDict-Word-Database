    },
    "definitions": [
      {
        "index": 1,
        "gloss": "winter sky",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "老ゆれば白毛が出ていわゆる蘆花を成し、枯残せる冬天の蘆葦は帰雁に伴うて大いに詩情をそそるものである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八字の斜線が、無限を思わす大弧を、冬天へ一気に引き放つ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
