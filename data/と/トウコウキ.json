    "definitions": [
      {
        "index": 1,
        "gloss": "floodlight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヘリ止め金は左手から棺に向って注がれて居る一台のプロジェクトル〔投光器〕の煌々たる光の下でよく光って居た。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それをどう思う」「ヘエ」「店の者のいないところで、ゆっくり話を聴きたいが――」　平次は四方に眼を光らす手代や丁稚たちの顔を見渡して、とうとうこうきり出さなければなりませんでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
