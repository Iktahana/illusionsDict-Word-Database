        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鶏冠山砲台を、土台ぐるみ、むくむくっとでんぐりがえす処の、爆破力を持ったダイナマイトの威力だから、大きくもあろうか？",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈の伸びたのが前は鶏冠のごとくになって、頸脚へ撥ねて耳に被った、唖か、白痴か、これから蛙になろうとするような少年。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見馴れねえ旅の書生さんじゃ、下ろした荷物に、寝そべりかかって、腕を曲げての、足をお前、草の上へ横投げに投出して、ソレそこいら、白鷺の鶏冠のように、川面へほんのり白く、すいすいと出て咲いていら、昼間見ると桃色の優しい花だ、はて、蓬でなしよ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人魚だなんて、子供のお伽噺ではあるまいし、いいとしをしたお歴々が、額にはくれないの鶏冠も呆れるじゃないか。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば矮鶏の尾羽の端が三｜分五分欠けたら何となる、鶏冠の蜂の二番目三番目が一分二分欠けたら何となる。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "五｜分刈の伸びたのが前は鶏冠の如くになつて、頷脚へ刎ねて耳に被つた、唖か、白痴か、これから蛙にならうとするやうな少年。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其に不思議は無いが、如何に人を恐れねばとて、直ぐ其の鶏冠の上で、人一人立騒ぐ先刻から、造着けた躰にきよとんとして、爪立てた片脚を下ろさうともしなかつた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏冠や、猛猛し眼の稜稜、尾羽、翼、はららぎぬ、はたはた、ああ、はたはた、岩根の、白羽蟻の吹雪と舞ふ柱を。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "白須賀は旧街道、朱の鶏冠ふりたてて軍鶏の居れども。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "折からや苫をはね出て、舟縁の霜にそびえて、この朝の紅き鶏冠の雄の鶏が、早やかうかうと啼き出けるかも。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬ながら、その屯、ほのなごむ家がまへ、ここ過ぎて、きびしくも、おもほえず、寒しとも、白須賀は旧街道、朱の鶏冠ふりたてて軍鶏は居れども、そは暮のひとあかりのみ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "八尺なす桶のここだく、新しぼりしたたる袋、庭広に干しも列ぬと、咽喉太の老いしかけろも、かうかうとうちふる鶏冠、尾長鳥垂り尾のおごり、七妻の雌をし引き連れ、七十羽の雛を引き具し、春浅く閑かなる陽に、うち羽ぶき、しじに呼ばひぬ。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇異な赤い鶏頭、縁日物ながら血の如な鶏冠の疣々が怪しい迄日の光を吸ひつけて、じつと凝視めてゐる私の瞳を狂気さす。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "くすんだ灰色の毛と、黒い鶏冠を持った怪鳥――「だからワトソン――」とホームズが突然口を開く。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かびくさい卵と、鶏冠の焼いたのが一とうのごちそうでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して之を与えればその鶏冠は著しく鮮紅または殷紅となりその行動は活発となるのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子珍考えて、玄石が言うたところの白衣は白鶏の毛、紫巾を戴くとは鶏冠、跣足とは鶏の足、左の眼｜潰れたるは我が射｜中てたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "バシリスク一名コッカトリセは、蛇また蟾蜍が雄鶏が産んだ卵を伏せ孵して生じ、蛇形で翼と脚あり、鶏冠を戴くとも、八足または十二足を具え、鈎ごとく曲った嘴ありとも、また単に白点を頂にせる蛇王だともいう。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからコックス・コーム（鶏冠）はきざにしゃれる奴の蔑称で雄鶏が冠を聳てて威張り歩くに象ったものだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "件の鰭を頭巾に巻き付けた体が馬鹿に鶏冠に似ているので、洒落た風をする男をコックス・コームと称えたそうだ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この名もコック（雄鶏）から出たらしく（『大英百科全書』十一板六巻六二二頁）、第三図イの通り鶏冠によく似たから付けた名と見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなだれていた彼女の鶏冠は、だんだん元のように、立ち直り始めた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等のなかを、監督は鶏冠を立てた牡鶏のように見廻った。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俺アずるけてサボるんでねえんだど」「それだら、そんだ」「…………」　その日、監督は鶏冠をピンと立てた喧嘩鶏のように、工場を廻って歩いていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "その札には、白い羽と赤い鶏冠をもった矮鶏の絵が描いてあった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間を一羽の牡鶏が、鶏冠を振り振り、まるで聴耳でも立てるように時々首を横へ向けながら規則ただしい足どりで歩きまわっていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒙古かぜ大連を吹き海暗しかかる日人に別れんとする大石橋附近の娘娘廟の大祭旅順東鶏冠山砲台の廃墟に於ける一行（向つて左より西田君・伊藤君・晶子・寛）　夜更けてホテルに帰り、明朝の行李を妻と共に整理して寝についた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅順では、駅長の伊藤眞一さんが待受けて、共に馬車を駆つて、東鶏冠山砲台の敗墟を案内せられた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "トカトントン、トントントカトン、とさかんに打ちます。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　撥を片手で引つかむと、恐る恐る差出した手を素疾く引込め、とさかをはらりと振って行く。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
