[
  {
    "uuid": "7200435b-70bf-5dc9-a491-9a869a0e5b32",
    "entry": "と思しい",
    "reading": {
      "primary": "とおぼしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
