  {
    "uuid": "3b5408d1-ce0e-59be-980e-05a781282d74",
    "entry": "トラ",
    "reading": {
      "primary": "トラ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trouble",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何のことはない妄想家流であつて、ジャズだつてオネガだつてアッターベルヒだつてラヴェルだつてシトラウスだつてマーラーだつて、妄想家流――といつて妥当でなければ幻想家流である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは恰度、音楽に鈍感な女の人が、オーケストラを聴いてゐて、フリュートなぞが単独に吹奏される部分でだけ、音そのものの物理的な快味にだけ感じ入るのに似てゐて、私は明治以降の殆んど全ての文学者が、外国文学の作品を読む時も、そんなやうなものであつたと云つても、強ち過言とは思はないのである。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚の上もトランクや土産物で一杯である。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きいトランクを二つ持つて、お土産物も沢山棚に積んでゐる此の男は、神経が太くて、まづまづ彼の親戚間では成巧者であるのに相違ない。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "行つて見るとまだ叔母は朝御飯が漸くすんだばかりで、ゆるゆるとお茶を飲みながら近所の人とトラックの話をしてゐるのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラック一台に積めるかどうかといふ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事にトラックも一台で難なく積めると、引越す先は鍋屋横丁を這入つて左に曲つて、も一度左に曲つて一寸行つた右側であるさうな。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたトラックに一緒に乗つて行つて荷物を運び入れてゐて頂戴、そのうち私も行くから」と云ふ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタガタ／＼トラックの荷物の中に挟まつて揺られながら、僕は久々で午前の西武電車の沿線といふものを眺めたのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ軽蔑のされ方ならその叔母のみならず毎度のことで、そんなことで腹が立つのでもなかつたが、何がなし癪に障つて、トラックの上にゐて顔に当る朝風は自分の一切合切をみる／＼削り減らしてしまふやうに感じられる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういへば先刻トラックに積み込む時、先生の物らしい物がないとは一寸思つた所だつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは鷲にならうとして沒落したツァラトストラの人間悲劇にたとへられる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺によつて、彼は藝術の完成境――美のツァラトストラ――に達しようとした。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたび私は、すごすご出発点に引返して、全身くたくたに疲れ、ぜいぜい荒い息を吐きながら、スタートラインに並んだ。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と断じて、悠然と引上げ、「ああ、やっぱり、ヒットラーに限る！",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコトコと足音が後頭に響くと、先刻父と話してゐた弟が来て、トランプをしようと言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何、ダウン、兄さんはダウンとトランプはしないことにしたぞ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　※　扨我等の生活はとみるに、　活動か、寄席か、酒か女か玉突か、トラムプか、棋か、どれにしたもんだらう……部屋の中でジツと話してれあいいんだけれど、どうもそれもパツとしないしなあ……読書か、あれはあんまり興味もないが、さうも云つてゐられんしなあ……困つたなあ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "科學精神の熱意されるところには、いつも一方に童話精神が熱意され、科學とお伽話とが、辨證法的コントラストの止揚によつて對立してゐるのが、どこでも文明國の常態である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ芭蕉の句が、一般に観念的と言われる理由で、この点蕪村の印象的、客観的の句風に対してコントラストを示している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この橋のあるあたりの小高い崖の上に、湯元ホテルとかいふ木造のホテル兼レストランがある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色の液体を二種混合するとたちまち赤や黄に変り、次に第三の液を加えるとまた無色になると云ったようなのを幾種類か用意してもらって、近所の友達を集めては得意になって化学的デモンストラチオンをやって見せたのであった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、肉桂酒、甘蔗、竹羊羹、そう云ったようなアットラクションと共に南国の白日に照らし出された本町市の人いきれを思い浮べることが出来る。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄上の峻嚴と竹内俊吉氏のなごやかさは、縣會に於いて、よいコントラストをなしたであらうに。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサデス　ツユノ　ヒカルミチコブヲ　トラレタ　オヂイサンツマラナサウニ　ホホヲ　ナデオヤマヲ　オリテ　ユキマシタ　瘤は孤獨のお爺さんにとつて、唯一の話相手だつたのだから、その瘤を取られて、お爺さんは少し淋しい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩は鋼鉄のように硬くなりながらも、イワベンケイ、ミヤマダイコンソウ、ムカゴトラノオなど、黄紫のやさしい花を、点々とその窪洞に填めながら、ギザギザに尖っている輪廓を、無数に空に投げ掛けている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、私が思い浮べたのは、北米ポートランド市の、シチイ・パークから遠望した、フッド火山の、においこぼるる白無垢小袖の、ろうたけた姿であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして直ぐ連想したことは、ポートランド市民の、フッド火山におけるよりも、または、タコマ市や、シャトル市の人々が、日本人によってタコマ富士と呼ばれているところの、レイニーア大火山を崇拝しているよりも、この東京が、かつて江戸と呼ばれたころには富士山が「自分たちの山」として崇められていたことであった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京市の大きい美しさは、フッド火山を有するポートランド市の如く、レイニーア火山を高聳させるシアトル市の如く、富士山を西の半空に、君臨させるところに存すると考えられる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "――滅茶苦茶に手前等は儲けやがって、俺たちを搾りやがるから、いずれストライキだよ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
