        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スズナ　カブすなわち蕪菁を七種に用うる時の特称。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "スズシロ　ダイコンすなわち蘿蔔を七種に用うる時の特称。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　鮭の特称　以上わ、鮭の一般的な名称である。",
              "citation": {
                "source": "和人わ舟お食う",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮭にわ、以上の他に種々の観点から、種々の特称が附せられている。",
              "citation": {
                "source": "和人わ舟お食う",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して、雌魚の大小に関してわ、別に特称わなく、普通に「ポろ　オ」〔小さい・雌魚〕と説明的に呼んでいる。",
              "citation": {
                "source": "和人わ舟お食う",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            }
          ]
        }
