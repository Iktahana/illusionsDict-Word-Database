[
  {
    "uuid": "e2e1dbd1-dc2d-5101-b366-75fad4072240",
    "entry": "海馬",
    "reading": {
      "primary": "とど",
      "alternatives": [
        "トド"
      ],
      "is_heteronym": false
    },
    "grammar": {
