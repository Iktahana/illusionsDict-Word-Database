        "examples": {
          "standard": [
            {
              "text": "ブロックの凸型になっている部分を、もう一方の凹型に合わせてはめ込んでいく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この印鑑の文字は凸型に彫られており、朱肉をつけて紙に押し付けると鮮明に写る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い建物の屋根には、凸型の装飾が施された瓦が並べられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "醜悪な巨石時代様式に則った暗い花崗岩の石組が、凸型に湾曲した頂面の上に凹型の底面がぴったり嵌る形で上に延びていた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の大岩と異なり、これは完璧な方形に切り出され、凸型の面も凹型の面もなかった。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "はるか彼方の一つ星、あの星ひとつがたのみの夢よ――たしかさうつづくのだつたと思ふが、歌詞は殆んど気にしたことがないので何遍聞いても忘れて了ふ。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
