          "literary": [
            {
              "text": "列車名、発車時刻、そして到着時刻などを、優子は手帳に写した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "にぎやかにおしゃべりしていたが、到着時刻が近づくと、会話が途絶え、期待と興奮を隠し、重大事が差し迫っていることをうかがわせた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
