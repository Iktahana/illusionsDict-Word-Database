[
  {
    "uuid": "0a274f01-6596-5de9-8559-3ea6cb96ee8e",
    "entry": "弔う",
    "reading": {
      "primary": "とむらう",
      "alternatives": [
        "とぶらう"
      ],
      "is_heteronym": false
    },
    "grammar": {
