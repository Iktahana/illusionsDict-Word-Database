    "definitions": [
      {
        "index": 1,
        "gloss": "suicide by throwing oneself to one's death",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三原山の投身自殺でも火口の深さが千何百尺と数字が決まれば、やはり火口投身者の中での墜落高度のレコードを作ることになるかもしれない。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタ今大金を呉れた人が投身自殺した騒ぎを「オヤ。",
              "citation": {
                "source": "私の好きな読みもの",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そのために、俊子の縁談がこわれてしまって、彼女は房州の海岸で投身自殺をしてしまった。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は或る甚だ面目ないことを仕でかし、面目なさにシオらしく、ドボーンと投身自殺を果したとする。",
              "citation": {
                "source": "十年後のラジオ界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふらになりながら列に押され、列をくぐり抜け、どうにかかうにか、今突進してくる急行列車目がけて投身自殺を試みる。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼は飽迄も日本軍への敵意を棄てず、ぼくたちが黄河河畔の絶壁の上を喘ぐように行軍していた際、突然、荷物を棄てると、その絶壁から投身自殺した。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌記者津村がこの発見をした時と殆ど同時に、新聞記者村井は二木検事に、洋装の女が投身自殺を遂げた浦部俊子の妹らしいと云う推測を告げていた事を、読者諸君は承知せられている筈だ。",
              "citation": {
                "source": "殺人迷路",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村井は既に久しい以前から、星田を浦部伝右衛門から五万円の金を騙り、その後に彼の娘俊子は投身自殺し、伝右衛門自身は発狂するに至った、実は山川牧太郎と云う悪漢だと深く疑っていたのだ。",
              "citation": {
                "source": "殺人迷路",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別段、書置きも何もないが、壁にかけてあつた彼女の古い雨外套のカクシを探ると、ある男へやる、打合せの手紙の書きかけが丸めて入れてあつて、それを讀み解くと、冬子は、けふの丁度いまごろの時間に、函館海峽で、投身自殺をしてゐるのだ。",
              "citation": {
                "source": "傘",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉県から出て来た十三歳になる少年が、大川端から投身自殺――はて、おかしいぞ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大川端から、投身自殺をはかった年若い婦人があるのを、交番へ知らせるとともに、自分も飛込み、巡査と協力して助けた。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "石をしょわずに――わかい女教師の自殺村山俊太郎１　昭和二十二年七月二十日の朝、Ｔ村小学校のわかい女教師が、通勤の途中にある淵に投身自殺をした。",
              "citation": {
                "source": "石をしょわずに",
                "author": "――わかい女教師の自殺",
                "note": "青空文庫"
              }
            },
            {
              "text": "「投身自殺ッて、とてもスポーツの要領でやるもんですッて。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男が、七つになる女の子を道連れにして、千葉の海岸で投身自殺をした。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉の海岸で投身自殺をした男は、妻の霊がはげしい出かたをするときは、かならずあの世へ来てくれないかと泣くので、弱るといっていた。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにかあったんですか」「投身自殺です」「こんなところで」「昨夜からずっとそのベンチにいたんですがね、さっきツイと立って行って、舷墻に凭れたと思ったら、見ている前でヒョイと飛びこんじまって」「男ですか、女ですか」「白い口髭をはやした六十歳ぐらいのひと……松代とかいう」「松代？",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、冬期の投身自殺はよくよくのことで、死ぬのに嘘真個というのも変なものだが、これにはふとした一時の出来心や、見せつけてやろうという意地一方のものや、狂言なぞというのは絶えてありえない。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "うし紅珊瑚",
                "note": "青空文庫"
              }
            },
            {
              "text": "同日、十時ごろ、石倉から、大池さんは湖水に投身自殺されたらしいという報告を受けた……だいたい、こんなところだ」　そういうと、畳紙の写真挟みから手札型の写真を出して久美子に渡した。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、船はシンガポールに着き、そこから郵船会社の欧洲航路の船に乗り換えた勝田さんが、香港へ着く前夜、遺書も残さず、謎の投身自殺を遂げたという報導がありました。",
              "citation": {
                "source": "消えた霊媒女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが屋上からおばさんの真上に投身自殺をしたものがあって、それにつぶされておばさんも死亡したのだという。",
              "citation": {
                "source": "宝くじ・その後",
                "author": "始めてから十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨーロッパ大戦がはじまり、ロンドン空襲があってのち、投身自殺をした。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、彼の気の小さい、善良な性格を知っている同僚たちは、彼が投身自殺をしたことを信じて疑わなかった。",
              "citation": {
                "source": "霧の蕃社",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
