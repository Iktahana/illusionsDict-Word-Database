        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのト書きに於て、諸天善神と呪いの魔の眷属の働きを、それは闘争にも見え舞踊にも受け取れると書いた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はチョット書き添えたい事があるから、手許に引取っている迄の事さ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）此等のト書きの指定は、大体今も守られてゐる。",
              "citation": {
                "source": "夏芝居",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とノート書きがしてある。",
              "citation": {
                "source": "「光線の圧力」の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、そんな騷ぎも何かのト書きの一つだらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人肌地藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、そんな騒ぎも何かのト書きの一つだろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人肌地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おや、おや、その代り、いやなト書きが附いて居る。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に限らず現在の社会に於けるこの切実で愚劣な大きな悲喜劇のト書きを暴露するのは、吾々にとって、極めてツマラない併し又極めて重大な義務にもなるのだ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "経盛の登場、経俊の退場がト書きに明示されておらず、経盛だとすると、この一文は非常に唐突であること。",
              "citation": {
                "source": "人柱築島由来",
                "author": "藤野古白",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこの事にいくらかの関係のある事で、フンマンにたえなかった事がこの間あったので、それをチョット書きましょう。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァラエティ風のものはセリフが無く、ト書きばかりなので頗るむづかしい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "書き癖をつけようと「あまカラ」への食書ノート書き、三月号を十枚、つゞいて、四月号へ又十枚、疲れもせずに書けた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどこの時、船長は、そのマストがきれいになり、サイドが化粧し、うまい具合に満船したという報知を、チーフメーツから受け取って、彼女と、酒を飲んでいた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "セットがきたないことは仕事の神聖感を傷つけ、緊張をそこね、そこで働く人たちを容易に倦怠に導く。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＷＣＣＦのレポートがきっかけとなって編集部にコネクションを持った古川は、『ＡＳＣＩＩ』に連続して原稿を寄せるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューター産業において、マイクロソフトがきわめて大きな成功を収めている以上、取材者の関心は当然、同社とビル・ゲイツに集まってくる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう集団農場なんてのは、いやだナア」　坊主は、プロレタリアのサヴェートがきらいだ。",
              "citation": {
                "source": "ペーチャの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "創作のヒントがきゝたいものぢやないか」「すべてインスピレーションは偶然でさア。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんはじめにきたのは、フクロウで、そのつぎがカラス、いちばんおしまいにハトがきました。",
              "citation": {
                "source": "白雪姫",
                "author": "グリム",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ長崎の港に着いたかと、重吉は舷に凭れて酔ったように港の岸を眺めていると、エベットがきて、陸へ上がる仕度をせよという。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "健康で大学に通っている素子の方が、スケートをはじめ、そのスケートがきっかけとなって大使館専用のスケート場へ行く。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッチボールのパスボールを取ってきてくれるのは大変便利であるが、歌笑が連れて神宮外苑の野球場に中等学校の試合があったときに、外野で例の通り綱をつけずに見ていたが、センターへヒットがきたのをグランドへ飛び降りてそのボールをくわえてしまった。",
              "citation": {
                "source": "犬",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「最初のショットがきまれば、それは撮ります。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段を降りる動きにつれて、ゆったりした長めのスカートがきれいに動いた。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "街上のスピーカー、「こちらは芸術座でございます、よいお席がございます」といふアナウンスメントがきこえる、不景気だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "領主がいないから、スライトがきっと歓迎してくれます」第六十章　公表　長い間、全員でバラ園に座り、静かに公園を眺めていた。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
