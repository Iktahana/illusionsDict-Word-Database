    "definitions": [
      {
        "index": 1,
        "gloss": "to take out",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それでは一つ貰いましょうと云って、財布を取り出すために壷を一度棚に返そうとする時に、どうした拍子か誤ってその壷を取り落した。",
              "citation": {
                "source": "ある日の経験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚倉腰の印籠を取り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚倉三次に近寄って、印籠の薬を取り出す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "畫集の重たいのを取り出すのさへ常に増して力が要るな！",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画集の重たいのを取り出すのさえ常に増して力が要るな！",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "精妙ないいものの中から、そのいいところを取り出すにはやはりそれに応ずるだけの精微の仕掛けが必要であると思った。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧箱の表面は一面に柔らかい凝霜でおおわれていて、見ただけではどれがなんだかわからないが、糧食係の男は造作もなく目的の箱を見いだして、表面の凝霜をかきのけてからふたを開き中味を取り出す。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂敷の中から讚美歌集を取り出す音が暫くざわ／＼と聞えた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、突然Ｉが袂の中のハンケチを取り出す間もおそしと眼がしらに持つて行つた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠に現実生活の中には立派に理想が含まれているのですから、たとい不平、不幸、残酷にさえ見える私たちの毎日の生活に対しても、決して恐れず逃避せず、その根本理由を見究め、まっしぐらにこれに割って入り、本当に価値のある理想を刻々に取り出すのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（懐より餅を取り出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（梓の弓を取り出す。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その為め取り出すときに一枚切手が剥げて居て函の中に落ちてあり、も一枚はかばんへうつすとき剥げた。",
              "citation": {
                "source": "公判",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ見れば有り触れた木魚であるが、その口から何物かを※し込めば、底蓋の上に落ちて自由に取り出すことが出来るようになっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲居さんは、あの人が財布の中のお金を取り出すのに、不自然なほど手間が掛るので、諦めてぺたりと坐りこんで、煙草すら吸いかねまい恰好で、だらしなく火鉢に手を掛け、じろじろ私の方を見るのだった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――会うか会うまいか」　大橋の袂に佇んで、鶴雄はハムレットのように呟いていたが、やがて何思ったのか、ズボンに手を突っ込んで、小さな象牙のサイコロを取り出すと、「偶数が出れば東だ！",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角御足労を掛けたんだから」　弓子はズボンの中から百円紙幣を取り出すと、鶴雄の前に置いた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、廊下伝いにしょんぼり自分の部屋にはいると、ごろりと仰向けに寝転んで、そのままじっと天井を睨んでいたが、やがてポケットから煙草を取り出すと、火をつけた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしゲルダが、自分で雪の女王のところへ行って、カイのからだから、ガラスのかけらを取り出すことができないようだったら、わたしたちではどうすることもできないね！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子がどれ程深く喰い入りそこから取り出すであろう芸術も、それをあの賢夫人やその他多くの世間人達がむす子に予言するような、いわゆる偉い通俗の「出世社会」に振りかざし得ようとの期待は、親もむす子も持たなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　Ｋは、三種類の外国煙草を、ハンドバッグから、つぎつぎ取り出す。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、恐らく老人は金庫を開いて證文を取り出すでせう。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、胸のポケツトから金の飾鉛筆を取り出すと、給仕女の差し出した紙片に何かを認めた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　兵児帯のまま腹ばいになって、夜具の裾の方に投げ出してあったハンドバッグを、素足の先につまんで、ひょいと肩越しに枕元へほうり上げ、その中から煙草を取り出すと、「火貸してちょう……。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが白い麻の支那服を著て、一等の談話室の、ラジオの黒い喇叭が二つ背中合せに立っている緑の大卓を前に控えて、ポケットから大きな眼鏡を取り出すと、白髪頭をひと振り振って両耳へ掛ける。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はポケットからドロップの紙袋を取り出すと、少しずつみんなの掌に配った。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と準之助氏は、袂から白い封筒を取り出すと、圭子の顔を見ないように、卓子の上をすべらせた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから Geld Suchen im Mehl というのは、洗面鉢へ盛ったメリケン粉の中へ顔を突っ込んで中へ隠してある銀貨を口で捜して取り出すのである。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞紙で包んだものを取り出すのを見ると、この家庭芸術家三人の作品のたぶん代表的なものであろう、分厚で長方形のシガレットケース――これは科学者の作、それから半月形の灰皿――これは美しい令夫人の作、それから手どくで白釉に碧緑の色を流した花瓶――これは母堂の作である。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくひとつを取り出すと、しわを伸ばしてから、ふたつに開き、次の記事を読み上げた。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
