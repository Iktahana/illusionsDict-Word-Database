[
  {
    "uuid": "cd7798ce-669a-5040-b9e4-3d5f9a312de2",
    "entry": "兎肉",
    "reading": {
      "primary": "とにく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rabbit meat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兎肉とキヤベツと玉葱と胡瓜。",
              "citation": {
                "source": "行乞記",
                "author": "大田",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎肉の能毒について『本草綱目』に種々述べある。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶弘景は兎肉を羹とせば人を益す、しかし妊婦食えば子を欠唇ならしむと言うた。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はプルタルコスのいうところによれば、たぶん兎肉の常用によって家族の健康を保ったのである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "水無瀬は何となく生きて行くことにくさくさして来た。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり飮酒の習慣からして、次第に神經が圖太くなり、物事に無頓着になり、詰らぬことにくよくよしなくなつて來るのである。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂の一とこが円くぽとっとぬれたように見えてそこに指をあててみますとにくにく寒天のようなつめたいものでした。",
              "citation": {
                "source": "サガレンと八月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから、冬は、春・夏・秋という、長い長い昼のあとにくる、夜みたいなものです。",
              "citation": {
                "source": "年とったカシワの木のさいごの夢",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時など、新次はことにくらくされた。",
              "citation": {
                "source": "鍛冶屋の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとにくちをきくには、もっとていねいにいうものだというのに。",
              "citation": {
                "source": "王さまと靴屋",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつほんとにくいしんぼうだから。",
              "citation": {
                "source": "空気ポンプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし命は、それらの賊たちよりも、もっともっとにくいのはおあにいさまの命のお命を奪った、あの鳥見の長髄彦でした。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、朝になった頃には、もうへとへとにくたびれてしまって、死ぬよりほかには仕方がないと思っていました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも大きなブルドッグが、それがまあなんとにくらしい、くいつきそうな顔をしていたでしょう。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚容の学問を頭から軽蔑して、魚容が「大学の道は至善に止るに在り」などと口ずさむのを聞いて、ふんと鼻で笑い、「そんな至善なんてものに止るよりは、お金に止って、おいしい御馳走に止る工夫でもする事だ」とにくにくしげに言って、「あなた、すみませんが、これをみな洗濯して下さいな。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "八幡のことにくわしい人に聞いておいて、御師という者の中に、昔親の少弐が知っていた僧の残っているのを呼び寄せて、案内をさせたのである。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとにくやしくなるじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その面がさえざえとした朱色一つのつぶし彫りになって、その朱の中から、目と鼻と口が、いともみごとにくっきりと浮き上がっているのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女にはなんの責任もないのは、はじめからちゃんとわかっていたが、駅からずっと、たかが数万の人間に寝床を与えるために、あの山と田んぼを失ったことにくすぶりつづけていた慶一の心は、瞬時に発火点に達してしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "清三はだんだん近所のことにくわしくなった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙波は人間の解剖をたえず見ていたので、自然殺伐な性質が養われたわけですが、いかに人体の内部のことにくわしくても、箕島の体内にはいったダイヤモンドを取り返す妙案は浮びそうにもありません。",
              "citation": {
                "source": "稀有の犯罪",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、要するに、書いていてまことにくだらない。",
              "citation": {
                "source": "私は懐疑派だ",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも最後の日には、さすがにみな日燒けと脂燒けとにくすんだ顏を晴々とさせて、昨日まではだらけたやうな身のこなしにも、生々と力が入つて見えた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と味噌汁を口もとにくつつけて、それがそのまま乾いて了つてゐる男の子が、洟をすすりすすり訊いた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてアサの時代は婦人労働者が未組織だったのだということを考え、同時に、現在は組織されていてもまだめいめいの個人生活の苦痛は、個人的な解決にまかされている部面の余り多いことにくらべて、はるかに社会保障の大きい社会主義の社会を思いくらべずにいられないだろう。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次大戦の歴史のなかで、日本の婦人の立場は、日本婦人自身にとってほんとにくやしく切ないものであった。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨子は全くそれと反対の天性で「ノラ」の稽古について語っているところでも「東儀先生の落付き払った金貸振りに、私はほんとにくやしくなって思わずのり出して読む」自分を示している。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "呪ふべき焼酎よ、お前と私とはほんとにくされ縁だねえ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼方の床の間の鴨居には天津の肋骨が万年傘に代へてところの紳董どもより贈られたりといふ樺色の旗二流おくり来しを掛け垂したる、そのもとにくだりの鉢植置き直してながむればまた異なる花の趣なり。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる都人に教へられてかといとにくし。",
              "citation": {
                "source": "かけはしの記",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
