    "definitions": [
      {
        "index": 1,
        "gloss": "capsicum (Capsicum annuum, esp. the cultivated chili peppers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大風の朝も赤し唐辛子　暴風雨の朝、畠の作物も吹き荒され、万目荒寥として枯れた中に、ひとり唐辛子の実だけが赤々として、昨日に変らず色づいているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村外れの茶店で昼飯を食った時に店先で一人の汚い乞食婆さんが、うどんの上に唐辛子の粉を真赤になるほど振りかけたのを、立ちながらうまそうに食っていた姿が非常に鮮明に記録されている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか有田の乞食婆の喰っていたあの唐辛子のかかった真赤なうどんと、ポツオリの旗亭のトマトのかかった赤いスパゲッティとの類似のためであろうとも思われない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平然と立ち上つて、狸の火傷にれいの唐辛子をねつたものをこつてりと塗る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸汁の運命から逃れて、やれ嬉しやと思ふ間もなく、ボウボウ山で意味も無い大火傷をして九死に一生を得、這ふやうにしてどうやらわが巣にたどりつき、口をゆがめて呻吟してゐると、こんどはその大火傷に唐辛子をべたべた塗られ、苦痛のあまり失神し、さて、それからいよいよ泥舟に乘せられ、河口湖底に沈むのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "納豆屋の「ナットナットー、ナット、七色唐辛子」という声もこの界隈では近ごろさっぱり聞かれなくなった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七味唐辛子を売り歩く男で、頭には高くとがった円錐形の帽子をかぶり、身にはまっかな唐人服をまとい、そうしてほとんど等身大の唐辛子の形をした張り抜きをひもで肩につるして小わきにかかえ、そうして「トーン、トーオン、トンガシノコ」と四拍子の簡単な旋律を少しぼやけた中空なバリトンで歌い歩くのがいた。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きなまっかな張り抜きの唐辛子の横腹のふたをあけると中に七味唐辛子の倉庫があったのである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、廂に唐辛子、軒に橙の皮を干した、……百姓家の片商売。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "忿怒の面相、しかし威あつて猛からず、大閻魔と申すより、口をくわつと、唐辛子の利いた關羽に肖てゐる。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間ものの、ぼたん、ばらよりして、缺摺鉢、たどんの空箱の割長屋、松葉ぼたん、唐辛子に至るまで聲を出せば節になる。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……恐しい利く唐辛子だ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、上方筋の唐辛子だ、鬼灯の皮が精々だろう。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸汁の運命から逃れて、やれ嬉しやと思ふ間もなく、ボウボウ山で意味も無い大火傷をして九死に一生を得、這ふやうにしてどうやらわが巣にたどりつき、口をゆがめて呻吟してゐると、こんどはその大火傷に唐辛子をべたべた塗られ、苦痛のあまり失神し、さて、それからいよいよ泥舟に乗せられ、河口湖底に沈むのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其八　明日辰の刻頃までに自身当寺へ来るべし、予て其方工事仰せつけられたきむね願ひたる五重塔の儀につき、上人｜直接に御話示あるべきよしなれば、衣服等失礼なきやう心得て出頭せよと、厳格に口上を演ぶるは弁舌自慢の圓珍とて、唐辛子をむざと嗜み食へる祟り鼻の頭にあらはれたる滑稽納所。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天才」といふ言葉が、唐辛子のやうに私の頭を熱くした。",
              "citation": {
                "source": "いろ／＼の言葉と人",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その腸を二升瓶に貯える、生葱を刻んで捏ね、七色唐辛子を掻交ぜ、掻交ぜ、片襷で練上げた、東海の鯤鯨をも吸寄すべき、恐るべき、どろどろの膏薬の、おはぐろ溝へ、黄袋の唾をしたような異味を、べろりべろり、と嘗めては、ちびりと飲む。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "指で挟んだ唐辛子でも構わない。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "有明の海の泥に匍う小蟹を生けるまゝ臼で搗き潰し、強い塩とたくさんの唐辛子を加えて馴れさす一種の塩辛です。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "野鼠は唐辛子でも食うとよ」「仕方がない、山椒の葉を摘んで来よう」　花田は女の子に烏の叩き肉の番をしておれと命じて、山椒の葉を摘みに出かけました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鶴はんはな、お初つぁんと一緒に夜店へ七味唐辛子を売りに行ったはるねんぜ」「えっ？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰るなら帰ると……」　お鶴の髪の毛は、油気もなくばさばさと乱れて、唐辛子の粉がくっついていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐辛子の刺戟がぷんと鼻に眼に来て、他吉は眼をうるませた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "３　翌日から、他吉がひとりで夜店へ出て、七味唐辛子の店を張った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "場割りの親方が、他吉を新米だと思ってか、「唐辛子はバナナ敲きの西隣りや」　と、いちばんわるい場所をあてがうと、他吉はいきなり「ベンゲットの他あやん」の凄みを利かせて、良い場所へ振りかえて貰ったが、「ああ、七味や、七味や、辛い七味やぜ、ああ、日本勝った、日本勝った、ロシヤ負けた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れぬ風土の寒風はひとしおさすらいの身に沁み渡り、うたた脾肉の歎に耐えないのであったが、これも身から出た錆と思えば、落魄の身の誰を怨まん者もなく、南京虫と虱に悩まされ、濁酒と唐辛子を舐めずりながら、温突から温突へと放浪した。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは、ふくろうがお前さんに、とうがらしを持って来てやったかい。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの形、とうがらしや、臼や、鋏や、赤や白や、実にさまざまの学生のばけものがぎっしりです。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとるにしたがって、みょうが、とうがらし、しょうが、ふきのとうが好きになるように、茶の木が、茶の花が好きになる。",
              "citation": {
                "source": "草木塔",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうがらし　青紫蘇、ねぎ、春菊、茗荷、菜っ葉――そういったもののみが取り残されて、申し合せたように青い葉の色で畑の健康を維持しているなかに、一株の唐辛が交って、火のしずくのような赤い実を点在させているのが眼についた。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
