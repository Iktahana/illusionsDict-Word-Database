[
  {
    "uuid": "0a3637d6-74ee-531b-9ee9-972c4ad14549",
    "entry": "討議",
    "reading": {
      "primary": "とうぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "debate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "喋り好きの彼等が長時間討議し合ってやっと一つの決議が纒った。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハリコフでの国際革命作家拡大プレナムの決議は日本のプロレタリア文学運動が、シッカリと大衆の中に根を張り、国際的な連関において前進して行くために、もっとも重要な、さしあたって第一番に議題として我々が討議し、具体化しなければならない幾多の貴重な提案をなしている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていよいよ当日の講演会に出て講演したり討議したり、たとえ半日でもとにかく平生とは少しちがった緊張興奮の状態を持続したあとでは、全く「頭がかたくなった」といったような奇妙な心的状態に陥ってそれが容易には平常に復しないで困ることがある。",
              "citation": {
                "source": "映画と生理",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの言葉の内容が細かに分析されるようになり、「併行モンタージュ」「比喩モンタージュ」等種々の型式が区別されるようになってからはこれらモンタージュの理論的の討議がいろいろと行なわれるようになって来た。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、男ってものは矢張り偉いのねえ」　これには流石にむす子の鋭い小さい眼も眩しく瞬いて、「こりゃどうもそう真面目に来られちゃ挨拶に困りますねえ」と、冗談らしく云って、この問題の討議打切りを宣告した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の子供たちは煖炉を取り囲んで大人びた形で勿体振った討議を致します。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がしかし事件は寛大に討議されたのだったけれど、今から三十年前の法律は、今日より遥かに惨刻なもので、私は廿三才の誕生日の日、重罪犯人として捕縛され、他の三十七人の罪人と一しょにグロリア・スコット号にのせられてオーストラリアに送られることになったのだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからやつにはもっともな理があったようだが、評議会での徹底討議ではドレッバーの連中が優位でな、そこで預言者は女をやつに引き渡したわけだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして無着は「社会科で求めているような本物の生活態度を発見させる一つの手がかりを綴方に求め」、「現実の生活について討議し、考え、行動までも推し進めるための綴方指導」に乗り出していったのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、御婦人方も参加して、すべての人々は討議に加はつて下さい、（低い、間をのばして）提案といふのはかうです。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "且文芸上の作品の価値は区々の秤尺に由て討議し、又選票の多寡に由て決すべきもので無いから、文芸審査の結果が意料外なるべきは初めから予察せられる。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "会の取り扱うべき事柄についてもいろいろ討議する。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か別な討議がされた後らしい。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼等が色々な問題について、工場の全部にわたって充分に討議する「機関」を持っていないところから来ていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより彼は自分がこの重大な問題の討議に與らうとも、また與り得るとも思つてはゐない。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には農村保健の最も根本的な仕事として、姙産婦と乳幼兒保護の問題が討議された。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお、今度のような重大な問題の討議にあたつて、一度も、そして一人も従業員代表が加えられていないことをだれも怪しみもせず不当とも感じていないらしいのは、はなはだ不可解であるが、私はそれを憤るよりもまえに、むしろ、反対に従業員側の反省をうながしたい気持ちである。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "間接には、「文戦」内左翼作家の発展的前進、「文戦」からの分離の動因ともなったハリコフ会議、一九三〇年十一月に、ウクライナ共和国首府ハリコフで行われた国際革命文学書記局第二回世界大会の日本のプロレタリア文学運動に関する決議が、この大会で一九三一年度の「ナップ」活動方針に具体的に討議されるはずだった。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本プロレタリア芸術運動が、国際組織に加盟するために必要な、いろいろな問題が大衆討議されるべき、画史的意味があったのだ。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "官憲が「ナップ」の国際的同盟加入に関して、その討議さえ禁止した事実は、そのままのこってわれわれの将来の活動を現実に掣肘する。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "討議は正味八時間余ブッ通して行われ、日本プロレタリア作家同盟は第三回大会で、内容的に、一歩、確然たる前進をした。",
              "citation": {
                "source": "文芸時評",
                "author": "――「ナップ」第三回大会にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "当惑と一種の焦慮とをもって問題はおこっていて、一つこの矛盾を大いに克服しようではないか、そのためにはわれらの置かれている現実をまず分析しよう、討議しよう、さあ……諸君！",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは彼らによって討議された文学における行動性、指導性、民族性の問題にふくまれている危険であるが、この座談会で、ただ一つ文学にとって積極的なモメントとなり得る諸氏共通な欲求が認められた。",
              "citation": {
                "source": "一九三四年度におけるブルジョア文学の動向",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "討議（ディスカッション）という意見の発表と研究の方法を日本の人民は学ぶべきであるといわれはじめてから、まだ五年しかたたない。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五年後のきょうの実状をみると、日本の一般には開放的でまた探求心のつよい討議の習慣がつくられるよりも早く、過去の半封建的日本のモラルの標準語であった善とか悪とかいう表現での片づけかたが、流布しそうである。",
              "citation": {
                "source": "地球はまわる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "口角泡をとばして列強航空力の優劣を討議し、つねに正確に悲憤｜慷慨におわる。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十五年二月には婦人参政建議案が衆議院で可決され、昭和二年の全国高等女学校長会議で、婦選問題が討議されたという事実は、今日の議事題目とくらべて何というちがいであろう。",
              "citation": {
                "source": "女性の歴史の七十四年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究し、討議され、なっとくを深める機会を得ずにきている。",
              "citation": {
                "source": "作家の経験",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
