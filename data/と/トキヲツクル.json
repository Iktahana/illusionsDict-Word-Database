[
  {
    "uuid": "d0590e3c-8add-5e2b-8436-5a7b6b25df62",
    "entry": "時を作る",
    "reading": {
      "primary": "ときをつくる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ラ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to crow at the break of dawn (of a rooster, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それも時を作るのぢやあない、物に驚いたやうに鳴いて騒ぎ出したんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も元旦にその鶏がここで時を作るという。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "星や、日、月、雲などについて種々の卜占法の口伝があるように、鳥類のある物たとえば烏などについては特殊の口碑があって、その啼き音に吉凶の意味ある物と考えられて居るが、鶏のみはこの種の口伝を持たぬとあって、あるアイヌ人が鶏の宵啼きや、牝鶏の時を作るを忌むを不審した由を記された。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏犬の声は平和のシムボルでありますけれど、鶏は時を作るものだが、犬は時間を知らせるものではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわとりがときをつくるような音を出すこともできる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶏も鳴かぬ中に、出来あがりさうになつたのを見たばんじようは、鶏のときをつくる真似を、陰に居てした。",
              "citation": {
                "source": "河童の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き残った雄鶏が元気なときをつくると、やがて夜はほのぼのと明け放れました。",
              "citation": {
                "source": "崩れる鬼影",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄鶏がときをつくる時のように、上を見上げて意気揚々としてダンスを踏みました。",
              "citation": {
                "source": "オカアサン",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭には今しもときをつくる若い雄鶏もなく、クックッという雌鶏もいない。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の回りの場所の記憶だけがぼくのそのときをつくる。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
