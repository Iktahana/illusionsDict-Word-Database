        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ふらふら調室から出ると、暗い廊下に、あの青年が立つてゐた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界に二つと無い物で、もう盗まれてから大ぶの年が立つ。",
              "citation": {
                "source": "橋の下",
                "author": "フレデリック・ブウテ　Frederic Boutet",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し年が立つと、別な気になる。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐそばに、一人の青年が立つてゐる。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り返ると、庭には下男の庄吉の外に、尾崎友次郎より二つ三つ若からうと思ふ塾生と、もう一人十七八の少年が立つて、不安さうに見送つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "軍學者の妾",
                "note": "青空文庫"
              }
            },
            {
              "text": "余程年が立つてから、セルギウスはその娘に再会した事がある。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "はて何が一体そんなにまで幼な子の心を強く捕へたのかと私は心穏かでなく幼な子の視線を辿るといふと、席の横にひとりの背の低い青年が立つてゐてその男の顔を瞠めてゐることが分つた。",
              "citation": {
                "source": "かなしみ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
