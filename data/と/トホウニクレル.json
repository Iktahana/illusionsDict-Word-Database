[
  {
    "uuid": "531da2ce-1ef1-5ed8-8e95-64f1808c2a61",
    "entry": "途方に暮れる",
    "reading": {
      "primary": "とほうにくれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
