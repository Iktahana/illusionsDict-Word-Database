        "examples": {
          "standard": [
            {
              "text": "彼は生まれつきの突顎を気にしており、いつか矯正手術を受けたいと考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "横顔をスケッチした際、モデルの突顎が力強い個性を生んでいることに気づいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "突顎の傾向がある人は、噛み合わせの問題から肩こりや頭痛を引き起こしやすいと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "突顎の看護人アルバートはハンプトン大佐を解放すると、拳銃を手にした女に向かって飛びかかった。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして均勢のひとつがくづれると、やにはに一人の狂つた男の血を吐くやうな悲鳴が起る思ひがして痛々しい。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戸ひとつがくろがねの――容易に開けられる障子ではない。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
