  {
    "uuid": "4c2a0b86-e676-563a-9ffa-40b2c32c2e68",
    "entry": "等量",
    "reading": {
      "primary": "とうりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
