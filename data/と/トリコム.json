[
  {
    "uuid": "5d236e4a-2021-54b6-8c92-0748b3b85438",
    "entry": "取り込む",
    "reading": {
      "primary": "とりこむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
