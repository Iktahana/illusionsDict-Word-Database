[
  {
    "uuid": "80431d13-1154-577a-94b3-78fb18fa0401",
    "entry": "途中",
    "reading": {
      "primary": "とちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "on the way",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然しかうして今私は峠の途中に蹲んでゐて、まことにしみじみとした気持だし、それとなく此の世の、何といはうか哀愁が思ひ遣られもするのだ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく寒い朝だつたよ、三月になつてはゐたが、来る途中、日の当らない所は凍つてゐた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京から藤澤へ行く途中、自動車で寄り道をしたのださうである。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その人とは、口をきいたこともなかつたが、それでも、校長の官舍と、私の下宿とは、つい近くだつたので、登校の途中、ちらと微笑をかはすことがあつて、この人は、その、校長追放の騷ぎの中で、氣の毒であつた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、その男が私の親しい友であつたことゝ、私がその夕行かなければならなかつた停車場までの途中に、女の行く新しき男の家があつたことゝは、何かのために附けたして言つて置かう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れて来て途中から聞いた者は尚更さうであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長の去つた後で、途中から来た者と初めからゐた者とは話合つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそれは途中のことだ。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母が死んだ子を褒めて耕二を悪く母に言つてゐたのであらう、そして父が母を呼んだのはその話の終り切らない時だつたのだらう、兄が自分の部屋にゆく途中、茶の間を通ると祖母にその話の余波をまはされたから。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あゝ、いや夜間のことはチヤンと承知だつたから、俺は途中でランチで済ませて来たんだ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ「惡靈」だけは、どういふものか興味がないので途中で止めた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊香保の浴客にとつて、日課的の散歩道となつてゐるのは、崖に沿うて湯元へ通ふ十数町の道であるが、その途中に橋があつて、そこから榛名へ登ることができる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎を立って時津に向かう途中でロシア人専門の遊廓だというところを通ったら二階から女どもが見下ろして何かしら分らないことを云って呼びかけた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下から中央階段を降りようとする途中で窓越しに東を見ると、地下鉄ビルの照明が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニラの帰休兵とかで茶色の制服に中折帽を冠ったのがここばかりでない途中でも沢山見受けた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京に入りて息子とかの宿に行くまでの途中いさゝか覚束なく思わるゝは他人のいらぬ心配かは知らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃、寒月の冴えた夜などに友達の家から帰って来る途中で川沿いの道の真中をすかして見ると土の表面にちょうど飛石を並べたようにかすかに白っぽい色をした斑点が規則正しく一列に並んでいる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある豪家の老人が死んだ葬式の晩に、ある男は十二分の酒を飲んで帰る途中の田んぼ道で、連れの男の首玉にかじりついて、今夜ぐらい愉快に飲んだ事は近来にないという事をなんべんもなんべんも繰り返しながらよろけ歩いていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椎茸少々｜宜しからぬ事があって途中から免職になったのはよかったが、その後任の爺さんがドーモ椎茸でなかったので坊チャン一通りの不平でない。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "キツトその蘭人があれから先づ己の国に帰つて又日本に来る途中で自分の戦勝を聞き、取り敢へず祝の品を持つて来たのだらうと思つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "など、のんきな事を考へながら山を降りて來たら、途中で、野良へ出かける息子の聖人とばつたり出逢ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　裾野の水車　本年の富士登山二回の中、第一回は大宮口から頂上をかけて、途中で泊らず、須走口に下山、第二回は吉田口から五合目まで馬で行き、そこの室に一泊、御中道を北から南へと逆廻りして、御殿場に下りた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "太刀持つ童、馬の口取り、仕丁どもを召連れ、馬上｜袖をからんで「時知らぬ山は富士の根」と詠じた情熱の詩人｜在原業平も、流竄の途中に富士を見たのであった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから精進口の登山新道、三合目へ下りることが出来て、途中に中庭、奥庭などを通過するそうだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの線が一度はどこかの郵便局へ束になって集められ、そこで選り分けられて、幾筋かの鉄道線路に流れ込み、それが途中で次々に分派して国の隅々まで拡がってゆく。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中ところどころ家の柱のゆがんだのや壁の落ちたのが眼についた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で待っていたお客に対して運転手が一々丁寧に、どうも気の毒だが御覧の通り一杯だからと云って、本当に気の毒そうに詫言を云っている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、未だ見ぬ遠い彼方の別世界へこれから分けのぼる途中の嶮しさを想はせるのであつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中で乗客が減つたのでバスから普通の幌自動車に移された。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その脇に沿うて略同じ勾配の道路をつけるから、自然に途中で道と河の高度差の最大な処が出来るのであらうかと思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
