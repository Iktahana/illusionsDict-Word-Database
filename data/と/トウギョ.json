[
  {
    "uuid": "1fb737b0-5510-588b-bb7d-791ae1c85065",
    "entry": "統御",
    "reading": {
      "primary": "とうぎょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
