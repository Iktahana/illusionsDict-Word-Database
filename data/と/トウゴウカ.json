          "literary": [
            {
              "text": "日本ＩＢＭにとっても、全世界的な製品の統合化は大きな課題である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本能的生活によって智的生活は統合化されなければならぬ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パーソナルコンピューターが端末として強く機能する社会、タケシにはそれが、個々人の統合化が進んだ全体主義的な社会に思えてならなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
