  {
    "uuid": "96a8cb16-c4b6-5cb7-b434-da882fda1589",
    "entry": "特区",
    "reading": {
      "primary": "とっく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "special ward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼よりもとっくに先きへ馳け抜けて、彼の追襲を街の同胞に訴えた。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、そんな風な生活は、もうとっくに因襲になってしまっているじゃあございませんか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "預金はとっくの昔に使いつくし、田畑は殆ど借金の抵当に入っていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、その生きている頭蓋骨をとっくにどこかの病院に百円とかで売ってあるのだという話もあった。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大井商事は、とっくにこれに眼をつけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人ならとっくに頸が飛んでいるところだろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっくに分別のできた大人が、今もなお熱心に――厚紙でサンドウィッチのように挾んだうえから一思いに切ってみたら？",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とっくからさよう思うて御覧じておりましつろう」「ハイ……まことに不思議な事と存じてはおりましたが……どうして又そのような事まで……」「ハハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉ちゃんはもう、とっくに風邪なおって起きちまってるのに見舞いに来るなんて」「でも、来てやったんだい」　蓑吉は、こまごましたおもちゃを並べるのに余念が無い。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこをとっくり胸に入れて、大事な品物を預ったつもりになりなさい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの内にある人格完成の電球と、外にあって私たちの人格を完成させようとする電気の導線とは実はとっくの昔から設備が出来ておるのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそうでなかったら、とっくの昔に病気になり、死んでしまっていたでしょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の時間はとっくに来ているのに、眼鏡を掛けたあの人はなかなかやって来なかった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガマン（刺青）の針助はとっくにつかまったんだから」　と、小沢は普通の調子で言った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも自作を無断で改訂されたことでとっくに傷ついている自尊心だった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――足許はとっくに暗えや、日が暮れてるぞ！",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころになると、とっくに本郷の店も人に譲り、マダムの常子も春日町の借家を一軒立ち退かせ、そこで小綺麗に暮らしていたが、もう内輪同様になっているので、気が向くと松の家へ入りこみ、世間話に退屈を凌いだ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から倉持も宿坊にしている銀子の入りつけの家で、二た座敷ばかり廻っているうちに、女中からもそのことを言われて、町中みんながとっくに知っており、知らぬのは当の自分だけだと感づき、客たちの目にさえそれがありあり読めるように思えて来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらしは、とっくにすぎさっていて、お月さまが、窓から、ヨハンネスのところまで、明るくさしこんでいました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は俺の子だけあって鼓のいじり方がもうとっくにわかっている。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……この家にこの鼓が御座いますことは、とっくに承わっておりましたが、その鼓に呪われてこのような淋しい身の上になりまして……その上にこのような不思議な……御縁になりましょうとは……」「わかりました」と私は自分の感情に堪え得ないで、それを打ち切るように云った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう……暑さも寒さも感じなくなって、白昼の幽霊のようにうなだれたままフラフラと向うの方へ行くばかりで、それを立ち止らせようという意志さえも、とっくの昔に彼の肉体から消え失せていた。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敏感な私の神経はこの令嬢が昨日、電話で私に笑いかけた声の主である事を、とっくの昔に直覚していたのであったが、しかも、そうした私の直覚と、眼の前にしおらしく伏し眼になって羞恥んでいる美少女の姿とは、どう考えても一緒にならないのであった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとっくに出来ています。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根のチリ鍋は、とっくに煮詰って、鍋底は潮干の潟に芥が残っているようである。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人と人との言葉は警句ばかりとなり、それも談話としてはほんの形式だけで、意味は身振りや表情でとっくの先に通じてしまう。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてカテリイヌは、もうとっくに死んじゃったわ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、いとま乞いに来たから、もうとっくに出発したものとばかり思っていた。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
