    "definitions": [
      {
        "index": 1,
        "gloss": "particularly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特に彼の人種の事までも取り立てて考えるほどの事ではないと思われる。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしの方でも取り立ててこうというほどの種は挙がりませんが、唯ひとつ、妙なことを聞き出しましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを取り立てて特別心を惹くようなところはなかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような事は別に取り立てて言うほどでないかもしれぬがしかしこの主観を無視する程度は人間の文明の程度によってだんだんに変化して来るものである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この性欲の根本使命は、種の保存、子孫繁栄にあるようですから、これを今さら取り立てて説明研究する必要はありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高ぶったとか勿体ぶったとか云う悪評のなかから、不思議な程かやを大切にすることばかりを婆やはたった一つ取り立ててひとから褒められて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから長篇ものに所々此趣味が散点して居ても、取り立ててこれが作者の趣味だと言い切る訳には行かない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もっと地味に、決定的に、質実に、その本質を指定することも出来ない組み合せになって相当、年月を経た男女――少なくとも取り立てて男女などと感じなくなった自分達だけは、子の前などでは尚更「夫婦」なんてぷんぷんなまの性欲の匂いのする形容詞を着せられるのは恥かしい。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田家、上杉家等の貸附はほぼ取り立ててしまい、家に貯えた古金銀は概ね沽却せられたそうである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、はじめのうちはべつに取り立てて彼女ひとりに憧れていたわけではない。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青年ロナルド・アデイアは、貴族階級の中に往来し、見受けるところ、別に敵と云うようなものもなく、また取り立てて、不徳義であると云ったようなこともないようであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、近所の評判を聞くと、万次郎という奴はもちろん褒められてもいねえが、取り立てて悪くも云われねえ、世間に有りふれた次三男の紋切り型で、道楽肌の若い者というだけの事らしいのです」「大津屋の重兵衛はどうだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの洋行帰りは、希望に輝く顔をして、行李の中から道具を出して、何か新しい手品を取り立てて御覧に入れることになつてゐた。",
              "citation": {
                "source": "妄想",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "嵯峨帝のお伝えで女五の宮が名人でおありになったそうですが、その芸の系統は取り立てて続いていると思われる人が見受けられない。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "女御も更衣も御在位の時のままに侍しているが、東宮の母君の女御だけは、以前取り立てて御｜寵愛があったというのではなく、尚侍にけおされた後宮の一人に過ぎなかったが、思いがけぬ幸福に恵まれた結果になって、一人だけ離れて御所の中の東宮の御在所に侍しているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の通し狂言のなかに一幕はさみ込まれたもので、取り立ててこれぞというほどの筋のあるものではないらしい。",
              "citation": {
                "source": "小坂部伝説",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が少年のころ食べ馴れたのは、自分たちが小舟に乗って、村はずれの池から採って来た普通の菱の実で、取り立てて言うほど味のいいものではなかったが、いかつい角を生した、その堅苦しい恰好がおもしろい上に、歯で噛むと、何とも譬えようのない仄かな匂が、ぷんと歯ぐきに沁み透ったものだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十一年も終り、十二年となり、これといって取り立ててはなしもないが、絶えず勉強はしておりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "東雲師逝去のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事に貸し分取り立てて見するかな」「御念までもござりませぬ。",
              "citation": {
                "source": "旗本退屈男　第五話",
                "author": "三河に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ここに取り立てて云うのは、こんな出版物ではない。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "前口上はこれ位にしておいて、実地の使用法を取り立てて御覧に入れる。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あったとしても取り立てて騒ぐ必要もありはしまい。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスでちっとばかり買って来ましたけれど、取り立てて申し上げるほどのものではありません。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに彼の慧しげなのを見て、泰親は叔父夫婦にも子細をうちあけて、彼を自分の弟子として取り立ててみたいと言った。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "左大臣の野心はとうに見え透いているものの、これぞと取り立てていうほどの証拠もないのであるから、迂闊にここで事を起こすと、理を以って非に陥るおそれがないでもない。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間は三造を馬鹿にしてはゐない、寧ろ三造を喜んでゐる、しかしとりたてて尊敬してもゐはしない。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより酒席の出來事であり、根も葉もないその場限りの一些事で、とりたてて言ふほどのことでもないが、とかくかういふことはゴシツプ的に誤傳されて、意想外な風聞を立てられたりするので、逆にこつちから手※しをして、ありのままの事實を報告しておかうと思ふ。",
              "citation": {
                "source": "中央亭騷動事件（實録）",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おれはいま何をとりたてて考える力もない。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは、いくら町民から税金をとりたてても、きりがない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの条件ではいずれもとりたてて異常なところはなく、これまでの経験と一致していました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
