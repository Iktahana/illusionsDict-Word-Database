    "definitions": [
      {
        "index": 1,
        "gloss": "place",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は此所に立つてをります！",
              "citation": {
                "source": "我が祈り",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな月が出てゐるにはゐたが、それでも木の繁つた所は暗かつた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに正しく神経衰弱が原因だつたとしても、単純な受験生のそれではあるまいし、その神経衰弱の因つて来た所を考へてみたくなる。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに牧野さんが酔ふと発しはじめるのなぞは、当人に自制力がないよりも、周囲が彼にとつてはあまりに不真面目に見える所から起るのであつたと考ふべき点もあるのであるから、さういふ定説が呑気に繰返されることは辛かつたのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "分類が終るや能事足れりとなす所に、現代インテリの過ちがあり、恐らくこの過ちが彼を不幸にした大きい理由であつたと云へよう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聴いて感じられるものは、はや気分でさへない、云つてみれば気分の暈縁くらゐな所かもしれない。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つてセンチメンタリズムに堕することからあぶない所で脱かれてゐる。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊岡久利の詩が、記憶を可なり無雑作に書き付けてゐる場合にも、猶一貫した流れを見せる所以のものは、彼のその克己が、彼の遠近法を乱すことがないからである。",
              "citation": {
                "source": "菊岡久利著「貧時交」",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて暫く案じた揚句、大抵はお断りすることとなるのでありますが、今もよつぽどお断りしようかと思つた所でありました。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし相手がやはり詩人である場合は、随分容易に話が通じ、又互ひに利するのかも知れませんが、今の所私は、詩論といふものは殆んど無益だと諦め切つてゐる有様です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "超現実派の詩論なぞも読んでをりますが、そして所々非常な卓見にも遭遇しますが、要するに読んだ後では「今時誰も結論には到達しないのだ」といふ何時も乍らの呟きを繰返さなければならない始末です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、新精神の、精神してゐる所はよく分るつもりであります。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の所猶概して印象の羅列以上のことを為し得てゐるとは思へませんが、あれらの努力が何時の日か一個完成したものに迄到達しないものではありますまい。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮りに何方かに決つた所でそれで何か出て来るといふわけのものでもありますまい。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もこんなに抽象的になつてゐることの一つの理由は、外国はいざ知らず我が国では、お互ひが痛い所に余りに触れなさすぎたからではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しもはや其処をさへ跳越えて、インテリ自身が、衣食住だけ足りればいゝ人達の人生観、所謂「ホガラカ」を以て、自分を律しようとするやうにさへなつてゐるのである。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何冊か買つて、友人の所へ持つて行つたのであつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂文壇交游がなかつたためであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその現状が、仮りに不安な現状であらうとあるまいと、学問、芸術の興隆に適してゐようとゐまいと、所詮致し方もないことである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、勉強といふことは、要素々々の注入といふこととも云へようが、その注入が目的ではなく何もひつくるめて出来る次なる統一が芸術活動をなすわけであるから、要素々々のことは所詮個人々々の楽屋内での問題に過ぎない。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所が今年になつて「新生」を受取るやうになつてから、漸く出たなとおもつた。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なぞまだ何処にも発表しない頃のことだし、何れ高森の方が早く所謂詩壇に出るのであらうと思つてゐたが、游牧記の後では、石川道雄主宰の半仙戯、其の後は友野代三主宰の童説といつたあまり世間の表てに顔を出したがつてゐない雑誌に発表するだけで、一向に其の他に発表はしたがらないのであつた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎監になつたが、夜になると時々寄宿生の誰かが便所へ行く音がするきり何にも聞こえないと此の間の手紙には書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本へ出張して一と晩久しぶりで旅人の気分で歩いたが、熊本といふ所はいい所です　火山地方特有の落付がありますとも書いてゐた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕さむしい Hotel の臺所で、のすたるぢやのメリイが泣いて居る、ほんのり光る玉菜のかげから、ぜんまい仕かけで、鼠がひよつくり顏を出した。",
              "citation": {
                "source": "玩具箱",
                "author": "―人形及び動物のいろいろとその生活―",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜景萩原朔太郎高い家根の上で猫が寢てゐる猫の尻尾から月が顏を出し月が青白い眼鏡をかけて見てゐるだが泥棒はそれを知らないから近所の家根へひよつこりとび出しなにかまつくろの衣裝をきこんで煙突の窓から忍びこまうとするところ。",
              "citation": {
                "source": "夜景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論其処にもその原因の説明に役立つ材料はあるかも知れぬが、根本原因はそんな所にはない。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなむしろ邪魔されて欲しいくらゐのところへ、この挨拶は、一寸ツカないものであつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
