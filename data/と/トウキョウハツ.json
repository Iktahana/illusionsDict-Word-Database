        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京発の早朝の急行列車が数分後には到着するはずである。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "家乗には「七月廿一日東京発、八月十八日福山著、廿四日執政を罷め、波平行安作刀一振を賜ふ」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして本日十三時に東京発の成層圏航空株式会社の『真珠姫』号に乗りこんでニューヨークへたつこととなった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝目白から九時半ごろかえり、〇時五十五分東京発太郎を国府津につれてゆく。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月九日さよなら　幸恵より　愛する御両親様　　　　　　　　御前に伊藤元子宛（北海道・名寄）大正十一年五月頃（東京発信）御タヨリヲ下サイマシテ、ホントウニ有難ウゴザイマシタ。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "知里高吉・波子宛大正十一年五月十七日付（東京発信）　五月十七日愛する御父様とお母様に……。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十七日午後一時半さよなら　　御両親様　　　　　　御許に知里高吉宛大正十一年六月九日付（東京発信）親愛なる御父様御母様、ほんとうに久しぶりで手紙を書く事が出来て嬉しう御座います。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら　　　九日幸恵より　愛する　　御父上様　　御母上様　　　　　　御両所へ知里高吉・波子宛大正十一年七月四日付（東京発信）愛する御父様御母様、此の間はお手紙を誠にありがたうございました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "知里高吉・波子宛大正十一年七月十七日付（東京発信）愛する御父様と御母様、お手紙を誠にありがたく頂戴致しました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら　　御父上様　　御母上様　　　　　　御もとに知里高吉・波子宛大正十一年八月一日付（東京発信）（書き出し数行分欠落）真志保も帰省のよし、当人は勿論の事、ふちたちや御両親様の御喜悦如何ばかりかと、遙々推察致し、独りほゝえみを禁じ得ません。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛する御父様　　愛する御母様　　　八月一日夜十一時十五分書終る知里高吉・波子宛大正十一年九月四日付（東京発信）先達は御手紙をありがたう存じました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "さよなら幸恵より　愛する　　御父上様　　御母上様知里高吉・波子宛大正十一年九月十四日付（東京発信）愛する御両親様、おいそがしいなかをお手紙を下さいまして誠にありがとう存じました。",
              "citation": {
                "source": "手紙",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京発行の選手名鑑の選手の実力鑑定はいい加減で、関西や九州四国など東京人の知らない土地の選手については特にいい加減であるが、東京附近の選手でも、手近かな資料だけで大ザッパに間に合せたやッつけ仕事、手をつくした努力の跡はミジンもない。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の汽車だね」「午後一時、東京発。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、あなたの東京発の時間を、誰か知っていたでしょうか」「そうですなア。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬居の方からは手代の松島が来、王様の方では湯治と見せかけて八時の東京発で熱海へ行く。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理するな」「いくよ」「午後一時三分、東京発大阪行き」「プラットフォームで待っている」「母親が来るよ」「お母さんはひとりになるわけだ」　岡部孝雄が三歳のとき、彼の父親は死亡した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時半、東京発、熱海へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時二十分の東京発で道子と修善寺へ向ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京発声の「冬の宿」これも感心した。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤松雄来訪、東京発声の重宗所長が僕に挨拶したのに、こっちが挨拶しなかったと怒ってゐる由、覚えがないが、そんなことを言ふ奴とはつきあひたくないと言ってやる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "生駒・関・井口・徳川も来り、面白くなりかゝったところへ、先日来インネンつけてゐた東京発声の重宗社長がこっちの部屋へアバレ込み、めちゃ／＼にされてしまひ、クサリ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十四年十二月十二月一日（金曜）　七時半起き、今日は東京発声のスタヂオで撮影、砧と違って寒々としてゝ淋しい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ルソオ――三月七日　東京発十二時四十分、熱海行。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
