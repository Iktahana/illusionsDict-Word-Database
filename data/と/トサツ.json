[
  {
    "uuid": "cbc2e154-f919-5e55-b691-5cef2c034348",
    "entry": "屠殺",
    "reading": {
      "primary": "とさつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
