      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "slaughter (of animals for meat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幹太郎は王の眼から、眉間を打たれた瞬間の屠殺される去勢牛のように、人のいい、無抵抗なものを感じた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして無産者は、屠殺場の如き戦場へどん／＼追いやられるだろう。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄昏花さけるねむの林を、　　　　さうさうと身もかはたれつ、声ほそく唱歌うたひて、　　　屠殺士の加吉さまよふ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白熊は、自分の毛皮から放射する光線が遠方のカメラのレンズの中に集約されて感光フィルムの上に隠像の記録を作っていることなどは夢にも知らないで、罪のない好奇と驚異の眼をこの浮き島の上の残忍な屠殺者の群れに向けているのである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたはなぜ私たち二人を、一思いに屠殺して下さらないのですか…………。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "近づいて見ると屠殺場だつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶、蜻蛉、蟻、蚯蚓、目を遮るに任せてこれを屠殺したが、馴るるに従うて生類を捕獲するすさみに熟して、蝙蝠などは一たび干棹を揮えば、立処に落ちたのである。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の意味からいふと、風早學士は、屠殺者の資格も備へてゐると謂はなければならぬ。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには縣立畜獸屠殺所といふ大きな看板が掛かつてゐました。",
              "citation": {
                "source": "ちるちる・みちる",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は池のほとりを静かに歩きながら、屠殺場の場面を種々に頭の中に描いて見た。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺もこのまま就職口が見つからなかったら、屠殺場に行って豚殺しをやる気になるだろう……と彼は思った。",
              "citation": {
                "source": "首を失った蜻蛉",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査十四、五人、屠殺人、消毒の人夫、かれこれ四十人ばかりの人たちが、すこぶるものなれた調子に、撲殺の準備中であった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面にはその明りで屠殺にかかろうというのである。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "評価には一時四十分間かかったが、屠殺は一時二十分間で終わってしまった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その湖の岸の北側には屠殺場があって、南側には墓地があった。",
              "citation": {
                "source": "死屍を食う男",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と飼主に訴へますと、飼主も急に悲しさうな顔になつて　――お前達は、可哀さうだが、夜があけると屠殺場におくつてしまふのだ。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御主人さま、屠殺場といふのはなにをする処でございませう。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まあ、たとへばお前達を、その屠殺場といふ、街端れの黒い建物の中にひつぱり込んで、額を金槌でぽかりと殴りつけるのだ、すると額からは、血といふ赤いものが流れだして。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫婦牛は、足をふんばつて、屠殺場へ行く途中、さんざん駄々をこねて、飼主をたいへん困らせましたが、飼主はいつもより、太い鞭を、ちやんと用意して来てゐて、ぴしぴし続けさまに、尻を打ちましたので、牛は泣く泣く屠殺場へ行かなければなりませんでした。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "屠殺場の男が、白い刃物を光らして、婆さん牛の、その赤い衣装をはぎだしましたが、ちやうど官女の十二｜単衣のやうに、何枚も何枚も、赤い着物を重ねてゐました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛はさんざん暴れ廻つて、逃げようとしましたが、とうとう捕まつて、この爺さん牛も、婆さん牛と同じやうに、黒い屠殺場の建物の中で、額を力まかせに金槌で殴りつけられて、ひつくり返されてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とさつき田舍者と言はれた鬱憤をここに於いてはらして、ちよつと溜飮がさがつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこんなしづかな場所で、遠くから私の考へを人に傳へる實驗をしたいとさつき考へてゐた。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とさつき田舎者と言はれた鬱憤をここに於いてはらして、ちよつと溜飲がさがつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうするとさつき自分がはひつた襖を開いて來た人がある。",
              "citation": {
                "source": "竹の里人〔二〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君さへ好かつたら……」「学生時分とさつぱり変らないことになつてしまふね、試験勉強気分だね。",
              "citation": {
                "source": "晩春日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも分岐点には道標が立つてゐたので、迷ひもせずにやつとさつき遠くでみた森の所まできた。",
              "citation": {
                "source": "小川芋銭",
                "author": "山村暮鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて泥棒達は風呂敷に包めるだけ品物を包んでしまふとさつさと出て行かうと致しました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のゐない時には、用達だけ済すとさつ／＼と帰つてしまふ。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと狹い所になるとさつさつと眞菰の中を押分けて進むのである。",
              "citation": {
                "source": "水郷めぐり",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
