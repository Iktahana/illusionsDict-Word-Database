        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　ふと房前の柱にかかった対子を読むと、甲谷はお柳の背中の蜘蛛の色を思い出した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　甲谷の頭の中で、対子の詩文が生き生きとして来るにしたがって、二人の身体はだんだん礼節を失った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの小心で、羞かみやで、いつもストイツクに感情を隱す男が、その時顏色を變へて烈しく言つた。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はエピクロスを知り、老子を知り、そして尚且つストイツクの本来の意味さへ解つた。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの小心で、羞かみやで、いつもストイツクに感情を隠す男が、その時顔色を変へて烈しく言つた。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――永年の間彼は、女房にストイツクな精神生活を吹き込んだつもりだつたが、他合もないことで斯んなにも空々しく逆戻りしてしまふのかしら？",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上デ私ノ言イ分ハホボ尽キタワケデアルガ、シカシコノヨウナコトヲ書イタカラトイツテ私ガカタカナ運動デモ開始シタヨウニ思ワレテハ迷惑デアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、幕切れは、もつと、ストイツクな幕切れであつて欲しいね。",
              "citation": {
                "source": "戯曲二十五篇を読まされた話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し、ストイツクな半面が出せたら申分なかつたらうと思ふ。",
              "citation": {
                "source": "“にんじん”を観て",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「にんじん」が、彼の少年時代を苦き回顧の情を以て綴つたものとすれば、「葡萄畑」は、よりストイツクな心境を透して、人生と自然とに慎ましい微笑を送つてゐることがわかる。",
              "citation": {
                "source": "「葡萄畑の葡萄作り」後記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ大ざつぱないひ方しかできぬが、それは、文学者として「現在の危機」と戦はうとする一種ストイツクな犠牲的相貌である。",
              "citation": {
                "source": "今月の感想",
                "author": "――文芸時評",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出てゐる飛行機が還つて来るまで、気が揉めるつちやないよ」　さもあらうと、たゞ聞き流した私の耳は、彼のストイツクな沈黙に恥ぢねばならぬ。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」トイツテ、ソヽツカシイカエルサンハ高イ木ノ枝カラ、ポント土ノ上ヘ飛ビオリマシタ。",
              "citation": {
                "source": "カヘルサント、コホロギサン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三オ友達　ノ　オ猫サン　ガハサミ　デ　切リナサイ　トイツタノ。",
              "citation": {
                "source": "カハイイ　山羊サン",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナゼトイツテ、モンコチヤンハマダ九ツデ、イタツテ小サイ子ダツタシ、ボンコチヤンハナルベク、セイノタカイ人ノアタマニノツカリタカツタカラデス。",
              "citation": {
                "source": "バウシ　ノ　ユクヘ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソノマヒゴノヤウスノヘンテコリンナコトトイツタラ※　水ノ中ニムヤミト長クツカツテヰタトミヘテ、アタマノ毛ハ一本、一本、サカダチ、カホモカラダモマツサヲ、クチビルハムラサキ色。",
              "citation": {
                "source": "ウミベノマヒゴ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コノウサギハアル人ガ「オヂヤウチヤンニサシ上ゲマス」トイツテ、モツテキテクレタウサギデス。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ハ「ソンナラ私ガ立テテ上ゲヨウ」トイツテ、手デ立テテヤリマシタガ、手ヲハナスト、スグマタパタリトタオレテシマヒマシタ。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「君ト一緒ダトイツモ興奮サセラレル」「アンナ顔ヲ見テ興奮スルコトハナイデショウ」「アノ顔ヲ見タ上デ君ノ顔ヲ見ルト、溜ラナク興奮スル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『物類称呼』は安永年間の書物であるが、あの中には関東で「一筆啓上せしめ候」、遠江国においてはツントイツツブニシュマケタというとある。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野鳥雑記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
