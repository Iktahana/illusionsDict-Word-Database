[
  {
    "uuid": "c3af5905-005a-5205-be0b-1a135790533d",
    "entry": "登録",
    "reading": {
      "primary": "とうろく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
