    "definitions": [
      {
        "index": 1,
        "gloss": "bucket used for cleaning oneself in a bathhouse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
