[
  {
    "uuid": "0b987421-95fd-5a4e-9d66-35669899f258",
    "entry": "兜率",
    "reading": {
      "primary": "とそつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Tusita (heaven, pure land)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それで西方｜兜率天か何処か知らぬが遠いところへ移転したきりというのが定まりであるが、寂心の事を記したのは、それで終っていない。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばその第四の兜率天という慾天の如きは、手を執り合うだけでその充足を得る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく不埒千万な野干も七日不食十善を念じ兜率天に生まれたと『未曾有経』に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "牙の六つある大白象の背に騎して、兜率天よりして雲を下って、白衣の夫人の寝姿の夢まくらに立たせたまう一枚のと、一面やや大なる額に、かの藍毘尼園中、池に青色の蓮華の開く処。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三度の飯を四度食べても、毎日一度は探偵小説を読まねば気が済まぬという自分に、「二銭銅貨」のような優れた作を見せて下さった森下さんは、その功徳だけでも、兜率天に生れたまうこと疑なし。",
              "citation": {
                "source": "「二銭銅貨」を読む",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に兜率天から劫火が下って薬師如来の断罪があるだろう――とそう云う疑念を、鋭敏な膜の様に一枚残しただけで、胎龍の精神作用を司どる瀕死の生体組織共が、一斉に作業を停止してしまったのだ。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彩畫の上に湧き上つた宮殿樓閣は、兜率天宮のたゝずまひさながらであつた。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彩画の上に湧き上つた宮殿楼閣は、兜率天宮のたゝずまひさながらであつた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、彩画の上に湧き上った宮殿楼閣は、兜率天宮のたたずまいさながらであった。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私が見た上での一家言でなくって、不風流なチベット人も十五日の供養は兜率天上弥勒の内縁に供養したその有様をこのラサ府に現じたのであると、彼らは諺のようにいうて居る。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "千手丸はおり／＼深い溜息をつきながら、兜率谷の底から立ちのぼる朝靄の、尾上の雲にながれて行くさまを、一心に視つめて居たが、ふと、「そなたはさぞ、ちかごろの麿の様子を不審に思って居やるだろう。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――わしはお前の信仰を賞づる餘り、普賢菩薩の使者となって兜率天から降りて来たものだ。",
              "citation": {
                "source": "二人の稚児",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ特に私が宇都野さんに望む所は、時々はもう少し不用意な、読みっ放しの云わばもっとそつのある歌をよんで見せて頂きたいと思う事である。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　ルウ・アンドレアス・サロメに一九〇三年七月十六日、ブレェメン郊外ヴォルプスヴェデにて　愛するルウよ、巴里は私には、あの幼年學校時代とそつくりな經驗だつたと言つてもいいかも知れません。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "小菅が藝術をいささかでも畏敬してゐるとすれば、それは、れいの青い外套を着て身じまひをただすのとそつくり同じ意味であつて、この白晝つづきの人生になにか期待の對象を感じたい心からである。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とそつくりおなじ男がゐて、この世にひとつものがふたつ要らぬといふ心から憎しみ合つたわけでもなければ、その男が私の妻の以前のいろであつて、いつもいつもその二度三度の事實をこまかく自然主義ふうに隣人どもへ言ひふらして歩いてゐるといふわけでもなかつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清作はびつくりして顔いろを変へ、鍬をなげすてて、足音をたてないやうに、そつとそつちへ走つて行きました。",
              "citation": {
                "source": "かしはばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏の大尉は夜間双眼鏡を手早く取つて、きつとそつちを見ました。",
              "citation": {
                "source": "烏の北斗七星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がいま少しすべてにあつかましかつたら、いよいよ此の貴族とそつくりになれるのだ、と思つた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（君曰く、ああ僕とそつくりだ！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせゐもあつたのかも知れないが、たけは、私の思ひ出とそつくり同じ匂ひで坐つてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは一昨日訪ねて來た時とそつくりそのままではないか？",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敬愛する牧師殿よ、こゝに、顔形から立居そぶりまで、まるで双子と言つてもいゝくらゐ、私とそつくりそのまゝの、あはれな一人の遊牧民上りの、つんぼの唖の乞食がゐます。",
              "citation": {
                "source": "勇士ウ※ルター（実話）",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お高、」「源ちやん、」　源吉は扉に触つて音を立てないやうにとそつと中へ這入つた。",
              "citation": {
                "source": "海異志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南瓜は晝間見て置いて夜になるとそつと蔓を曳いて所在を探すのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れは鍋割れとも、それから芒が白いので白芒とも云ふのであつたが勘次は「此は白坊主」とそつけなくいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "三犯目の年貢を収めて、彼はつい昨日刑務所を出た許りであつた、彼の刑期中に誰の手からともなく、彼の考案とそつくりのブリキの舟が縁日に売り出されてゐるのを、彼はいま発見したのである。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "線の発展の追究的なところも、五雲の態度とそつくりなのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、あなたのお手とそつくりのやうでございますね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これでようごすか、もちつとそつとやツりやすか？",
              "citation": {
                "source": "醉ひたる商人",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
