        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あんな奴と喧嘩したら、倒立ちしたってこっちが負けだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな奴と喧嘩したら、倒立ちしたつてこつちが負けだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に、仕事の邪魔どころか、私は目がくらんで矢庭に倒立ちでもしたい気持でした。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒雲空を蔽ひて、海面には暗緑なる大波を起し、潮水倒立して一條の巨柱を成せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸を噬む水は、石に觸れて倒立し、鹹沫は飛んで二人の面を撲てり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸を出でゝ覗へば、彼の激浪倒立すること十丈なる岸頭に、一群の女子小兒の立てるあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "――龍二は、十二階段の頂上に駆けのぼつて、倒立をした。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――茶の間では上向きに寝転んで脚は恰度倒立ちをしてゐる見たいに高く、柱に立てかけてゐる林が、「一体何時頃なんだらう？",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青白い棚雲の下に箒を倒立てたやうな枯木が懸つてゐて、それがつぎつぎに闇の底に倒れて行つた。",
              "citation": {
                "source": "ある時刻",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人が一銭を水中へ投げると海女は巧に拾うのだ、その時海女は倒立ちとなって汚水から二本の青ざめた足を突き出した、その足の裏は萎びて、うすっぺらで不気味で、青くて、堅くて動物的で、実用で、即ち人間の立つ台の裏という感じなのであった。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスのある学者が『若し倒立して歩くことが「流行」となつたとしたら、欧羅巴の婦人は些の躊躇もなく、みなそれを真似るだらう』と言うたことがあるが、これは多少皮肉ではあるが、西洋婦人の流行を追ふ心理状態を巧みに言ひ現はした言葉だと思はれる。",
              "citation": {
                "source": "東西ほくろ考",
                "author": "堀口九萬一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は学校から帰って来ても、屡々自分の家の後庭に設けられた機械体操場にやって来て、一時間も二時間も独りで遊び興じながら、倒立ちをしたり、宙返りを打ったり、殆ど倦む事を知りませんでした。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄棒が済むと今度は階段の頂辺から倒立ちをして飛び下りたり、一丈に余る竹竿を杖に庭の松の樹の梢より高く跳ね上ったり、………その Jumping の見事な有様は、誰が見ても人間業とは思われません。",
              "citation": {
                "source": "金色の死",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
