          "literary": [
            {
              "text": "インキはなくなるのがつとめじゃない。",
              "citation": {
                "source": "ペンとインキ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことのないようにするのが」と、お袋は僕に向った、「芸者のつとめじゃアございませんか？",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば丹下左膳より乾雲丸を奪還し、この坤竜とともどもに小野塚家の当主弥生殿の前にそろえて出すのは、弥生どの……というよりも、左膳の刃におたおれになった鉄斎先生への何よりの供養――義理だ、つとめじゃ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで俺あ、――わしあそれで、喜んでそうしたいんじゃから、それがわしのつとめじゃから。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「疲れたろ姉やん、姉やんは昼夜のつとめじゃったせにな」　ここ二三日、ほとんど徹夜なことに思いやりをこめて、実枝はクニ子のそばへ並んで横になった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬力の六も出入りさしとめじゃ」　事件の少いこの村にとっては、お浜が妊娠している、という噂は大きなニュースであったが、このニュースに最も恐慌をきたしたのは、馬力の六やんをはじめ平素、遊び手として定評のある人たちであった。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが仲居のつとめじゃないか」　はいはいと仲居は花王｜石鹸のマークみたいな顎をひいて、「腕とお金次第……」「よーし、はりこもう」　これでもう話はきまったようなものだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
