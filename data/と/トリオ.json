        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地理学書でもまた物語でも読んで知っていたアトリオ・デル・カヴルロとかソマムとか、こういう名前も何となく嬉しく、また地質学者から教わる色々の岩石の名前も珍しかったと見えてよく覚えている。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八八四年カナダのモントリオルで大英学術協会が開かれたときにレーリーが会長に選ばれた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いてみるとそれはハイドンのトリオであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、この夏の夜の武蔵野で聞いたトリオ以来、ラジオに対する恐怖に似た心持だけは消えてしまったようである。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーヴに暖められ、ピアノトリオに浮き立って、グラスが鳴り、流眄が光り、笑顔が湧き立っているレストランの天井には、物憂い冬の蠅が幾匹も舞っていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリオの部分は概して水平な短い直線の断片が現われてそれがちょうど編隊飛行の飛行機が風に吹き散らされてでもいるような運動をする。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩はちょうどトリオでチャイコフスキーの秋の歌などもあった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲が静かであるためか、それとも器械がいいのか、こちらの頭がどうかしていたのか、そのトリオだけはちょっとおもしろく聞かれたので、階段の上に腰かけておしまいまで聞いた。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリオやカルテットの仲間がよくできては解散し、解散してはまた別の組ができるのであるが、事情を聞いてみると皆仲間の間の個性の融和がつきにくいのに帰因するようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリオやカルテットぐらいならば別に指揮者を必要としないが、少し楽器が多くなって管弦楽の形をとるようになれば、もはやそれは一人のちゃんとした指揮者なしには進行することができなくなる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアノトリオ位で非常に優れた室内音楽でも附属しているのは決して悪いものではないとしても、併し「演出効果」なぞと云う大掛かりな仕掛けは実際邪魔になり過ぎる場合がある。",
              "citation": {
                "source": "牛込館",
                "author": "映画館めぐり（十）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「カトリオーナ」（デイヴィッド・バルフォアの改題）の方が不評で、あんな作品の方が売れるなどとは、皮肉だが、兎に角余り絶望しないで二番芽生を待つことにしよう。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "之は、最低の見積りによっても、「カトリオーナ」より上に位するものとなろう。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "左は海に向へる青野のあなたに、チルチエオの岬（プロモントリオ、チルチエオ）の隆く起れるあり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "古ギリシアの名妓ラミアは、己の子ほど若い（デメトリオス）王を夢中にしたほど多智聡敏じゃった。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それもキラいじゃないけど、ブラザース・フォアとか、キングストン・トリオとか」「ラジオで聴いたことある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん、キングストン・トリオ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十九日の昼休み、慶一、高志、ワラ、というＫＷＴＳトリオと、柾生、山崎の五人は、校舎の前庭の日本庭園にある、紫陽花に囲まれた東屋で、丸太のベンチに寝ころがったり、ベンチに足をのせ、背板に腰掛けたり、てんでんばらばらのかっこうで、ビートルズの話をしていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "35老いた孤独なギター弾きと帰郷した女王にとっていったいそれにどんな意味があるというのか〈デイドリーム・ビリーヴァー〉ジョン・ステュワート（キングストン・トリオ）　弦の張り替えは、通常、だれにでもできる作業といってよい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブルガトリオをまつしぐら、ゆけ、パライソへ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽部は、太郎のオルガンと、ケラア先生の手風琴と、太郎の若い母親の月琴から成立つたトリオであつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は何かしらトリオらしい室内楽の美しい旋律のなかから、自身の夢想を引き出そうとするように耳を聳てていたが、楽器の音を聴いていると、少し頭脳が安まるくらいの程度であった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化勲章受領者で、云わば必要にして充分という感じを与えるものは、自然科学者のトリオである。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり三人とも物理学者乃至物理学的工学者であるが、この世界ではこのトリオは極めて尤もらしいのだ。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "方言が相当板についた（と思われる）点、勘次とおつうと爺とのトリオの優秀な点、云われている通りだ。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時レコードはショパン独特のあの婉麗極まりなきトリオの部分を奏ではじめている所だつたが、私はいそいでアームをあげてそれから廻転を止め、そのまままた応接間に戻つた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして僕の記憶にして誤りなくんば、君がここへかけつけた頃、このレコードのパデレヴスキー氏は、例のトリオの部分をかなり進んでひいていたように思うがね」　私はあの咄嗟の際の藤枝の観察の鋭いのに感心した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほらいつか僕らがどこかでこのレコードをきいた時君が、どうもパデレヴスキーのよりパハマンの方がいいと云つたことがあつたな、あのトリオの所だよ」「ところが、今われわれはパデレヴスキーに感謝しなければならん。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが音楽趣味に感謝す、さつき僕はここん所をきいたと思うよ」　彼はこういうと、口笛でショパンの葬送行進曲のトリオの部分をふいていたが、ふと振り返つて窓を見た。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕べ君に示した通り、あのレコードは知らない人が見ると、トリオの部分まで行かぬ所で君が針をあげてしまつたことになつている。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
