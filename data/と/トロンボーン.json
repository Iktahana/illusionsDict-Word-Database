        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正装をしたセッション・ミュージシャンたちが、テナーサックス、トランペット、トロンボーン、ヴァイオリン、チェロをかかえて、準備をしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "振り廻されるトロンボーンとコルネット。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓、笛、トロンボーン、ギター、バラライカ、などが片づけてある。",
              "citation": {
                "source": "ソヴェト同盟の音楽サークルの話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてクリストフは、昏迷のうちにもがきながら、無意味な文句を口にして、想像の管弦楽を、トロンボーン、トランペット、シンバル、チンパニー、バスーン、コントラバス……などを指揮し演奏し、熱狂的にひき吹き打ちたたいた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、灌漑用水を流し、花綱を飾り、トロンボーンやオーボエで踊らねばならない。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら第一トロンボーンを吹くのね」「グレン・ミラーを気取ってたのです」「音大を出てるのよ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄さんが、日本のジャズ・トロンボーンではまずこの人、と最初に名前があがるほどのかたなの」「それは知りませんでした。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二一年の生まれだからスイングの時代に育ち、音楽的な教育は高く、本来はクラシックのトロンボーン奏者だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
