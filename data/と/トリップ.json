          "standard": [],
          "literary": [
            {
              "text": "それからフレップという紅い実やトリップという紫の実のいっぱいに生った広い広い野っ原もあるそうです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地帯には俗に樺太葡萄と称する紅い果のフレップと紫の果のトリップとが一円に野生していて、自由に人の来て摘むに任してある。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレップもトリップも躑躅によく似た葉の細い小さい灌木である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはフレップを摘み、トリップを探してまた心ゆくままに味い、かつ夢みた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこのフレップ・トリップは主として樺太における収穫である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレップ・トリップ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伸子」からはじまる続篇を貫いて志向されているのは、ストリップ・ショウ風ののたうちはないといえ、つまりは日本の社会の一つの時期に生きる人間、女の、意識の覚醒の課題であり、それは、とりも直さず個人と集団を貫くコンプレックスの発見とそこから解放されようとする物語ではないだろうか。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三三年に石坂洋次郎が、左翼への戯画としてかいた「麦死なず」と、一九五〇年に三好十郎が書いた「ストリップ・ショウ・殺意」とを見くらべれば、現代文学の傾斜が明瞭にわかる。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "郊外のトリップ　電車の中。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Stilling 教授が挙げているトリップリンと云うワイマアルの役人の実例や、彼の知っている某Ｍ夫人の実例も、やはり、この部類に属すべきものではございませんか。",
              "citation": {
                "source": "二つの手紙",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての男性が家庭的で、妻子のことのみかかわって、日曜には家族的のトリップでもするということで満足していたら、人生は何たる平凡、常套であろう。",
              "citation": {
                "source": "愛の問題（夫婦愛）",
                "author": "――生命の法に随う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦後は諸事解禁で、ストリップ、女相撲は御承知のこと、その他善男善女の立ち入らぬところで何が行われているか、何でもあると思うのが一番手ッとり早くて確実らしいというゴサカンな時世でしたが、明治維新後の十年間ほどもちょうど今と同じように諸事解禁でゴサカンな時世でした。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は南蛮渡来のストリップのモデルがなかったせいか、または西洋音楽も楽隊も普及しておらぬせいか、ハダカの西洋踊りは現れなかったが、今のストリップと同じ意味で流行したのが女相撲であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストリップ的にうけている見せ物だから、花嵐の怪力の実績だけではうけなかったのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二は、巌壁の外で、大衆が、神集いにつどい、大論争をし、ついに、衆議一決、天鈿女の命というアフロディテをして、ほとも露わに、ストリップの大騒ぎをすることにするのである。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは今のストリップを見るのを嘆く、道学者と大して異なるものでなく、また、遠くその代表者となっているのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子大学の演芸会でストリップを演じて同性を悩殺して以来肉体に自信を持ち、折あればハダカになって人間をウットリさせたいという野心をいだくに至った。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯上りの素ッ裸でせきこんでるわよ」「ストリップですな」「ひどいわね」　そのとき呼鈴が鳴って、安川久子が訪れたのである。",
              "citation": {
                "source": "正午の殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ストリップだしたら、もうかるべい」　という意見が圧倒的であったが、かの苦行僧はこれを静かに制して、「いけません。",
              "citation": {
                "source": "文化祭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "現今のダラクした世相に乗じ、たとえばストリップと同じように法の処罰をまぬかれているにすぎないのです。",
              "citation": {
                "source": "お奈良さま",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の男子はこれを軽蔑してまだ見ることすらも知らないけれども、実は歌舞伎もこれに及ばず、ストリップもこれに及ばない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下日本の女の子は人殺しとストリップにおいてもっぱら天分を発揮しているにすぎないが、亭主をバラバラにしたり、ズロースをかなぐりすてて天下の野郎どもを驚倒させるのは、女の子なら誰でもできる下の下のことと心得るべきである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の便所にくらべれば、ストリップの方がどれくらい清潔だか知れやしない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸体画というものがあって、女の裸体は美の普遍的な対象だと思いこんでいたせいで、ストリップに女のお客さんもたくさん居るだろうと軽く考えていたのがカンちがいというわけだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の場末の小屋のショオには大根足の女の子が足をあげて手を上げたり下げたりするだけの無様なものであったが、それにくらべると、今のストリップは踊りも体をなしているし、そろって裸体が美しくなってることは確かであるが、裸体美というものはそう感じられない。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストリップが同じことで、裸体の魅力というものは、裸体になると、却って失われる性質のものだということを心得る必要がある。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストリップとても同じことで、舞台で停止した裸体の美はない。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸体の色気というものは芸の力によって表現される世界で、今のストリップは芸を忘れた裸体の見世物、グロと因果物の領域に甚しく通じやすい退屈な見世物である。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台の上で、一人の女に誕生すること、それは芸術の大道で、ストリップも例外ではない。",
              "citation": {
                "source": "安吾巷談",
                "author": "ストリップ罵倒",
                "note": "青空文庫"
              }
            }
          ]
        }
