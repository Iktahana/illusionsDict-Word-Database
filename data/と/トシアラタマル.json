          "literary": [
            {
              "text": "年改まるごとにいま母に対するの観念と、および実行が幼少のときの思想とどれほど一致するか。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "年改まるごとに、今日のわがなすことが、この点においてどうであろうと対照してみる。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い海の彼方なる常世の国に鎮る村の元祖以来の霊の、村へ戻つて来るのが、年改まる春のしるしであつた。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
