[
  {
    "uuid": "85245c33-bcf3-5995-9fff-6e819a460ea5",
    "entry": "答弁書",
    "reading": {
      "primary": "とうべんしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
