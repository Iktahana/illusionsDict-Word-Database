[
  {
    "uuid": "49213d5a-5cbd-5138-bc84-69f98284a6f5",
    "entry": "飛ばす",
    "reading": {
      "primary": "とばす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
