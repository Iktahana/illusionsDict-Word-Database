[
  {
    "uuid": "3cd5877a-c029-5d5c-8dcb-61479abe27ee",
    "entry": "逃竄",
    "reading": {
      "primary": "とうざん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "act of fleeing into hiding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "総代輩困却して逃竄し、その後召喚するも出頭せず。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "トスカは逃竄の貧士に食を与え、三千歳は無頼漢に恋愛の真情を捧げて悔いなかった。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "二箇処の雉子の声はだん／＼に接近して、大抵は蹴合ひになり、且つ一方の逃竄を以て終るらしく、勝つたものが其分野を支配し、残れる雌雉をして次々にあの粗雑な巣を営ましめるのである。",
              "citation": {
                "source": "家を持つといふこと",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国に分布した逃竄説話の一つで、多くは陀羅尼の功徳により、耳だけ切り取られて助かったことになっているが、山の神や路の神その他怖ろしい神が盲人の目に見えぬに乗じて近々と現われ来り、歌曲を所望したという点はいずれも同じである。",
              "citation": {
                "source": "雪国の春",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "目をかけていたゞきとうざんす」　長範はゴリラの熊蔵と将棋をさしていた。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
