[
  {
    "uuid": "0ffe91d6-8f9c-52a1-9d81-22a3a6674478",
    "entry": "戸惑い",
    "reading": {
      "primary": "とまどい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
