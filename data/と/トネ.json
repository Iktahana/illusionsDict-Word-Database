    "definitions": [
      {
        "index": 1,
        "gloss": "priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "広野の中に刀禰の大河が流れていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前には刀禰の大河が溶漾と流れていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀禰の流れは銀色を帯び、渡って来た、秋鳥も瀬の面に浮ぶようになった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その岸に寝た刀禰の川水がうねうねと白く光って通っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は郡山藩の柳田徳蔵、今一人は尾州藩の鹿島復之丞、跡の二人は皆｜十津川の人で、前岡｜力雄、中井｜刀禰雄と云つた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "とねりは、をさと同じ語原のとね即、外根からの刀禰と、「折り」か「坐り」の融合したものらしい。",
              "citation": {
                "source": "小栗判官論の計画",
                "author": "「餓鬼阿弥蘇生譚」終篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "平安時代の者は、官人或は刀禰たちの仮装に過ぎないで、山人自身意義も知らなかつたであらう。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとのとも、刀禰などのとで、神の配下の家の意であらうか。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、宮廷以外の邑落に於いては、男の場合に刀禰と言つてゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "和女はよも忘れはせまい、和女には実の親、おれには実の夫のあの民部の刀禰がこたび二の君の軍に加わッて、あッぱれ世を元弘の昔に復す忠義の中に入ろうとて、世良田の刀禰もろとも門出した時、おれは、こや忍藻、おれは何して何言うたぞ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこそ今日までも休まず、夫と聟とは家にはおらぬが、おれが矢の根を日々磨ぎ澄まして、おなじ忠義の刀禰たちに与うるのじゃ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "門出の時、世良田の刀禰が和女にこを残して再会の記念となされたろうよ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見たらよしない、女々しい心は、刀禰に対して出されまい。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が立ち去った跡で忍藻は例の匕首を手に取り上げて抜き離し、しばらくは氷の光をみつめてきっとした風情であったが、またその下からすぐに溜息が出た，「匕首、この匕首……さきにも母上が仰せられたごとくあの刀禰の記念じゃが……さてもこれを見ればいとどなお……そも刀禰たちは鎌倉まで行き着かれたか、無難に。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎の刀禰は、そうよ、父上もそこを逃れなされたか。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "秩父刀禰とはかねてより陣中でしたしゅうした甲斐に、申し残されたことがあって……」「申し残された」の一言が母の胸には釘であった。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがこれから鎌倉へ行こうぞと馳せ行いた途、武蔵野の中ほどで見れば秩父の刀禰たち二方は……」「さて秩父たち二人は」「はしなくも……」「もどかわしや。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "大聖威怒王も、ちぇイ日ごろの信心を……おのれ……こはこは平太の刀禰、などその時に馳せついて助…助太刀してはたもらんだぞ」　怨みがましく言いながら、なおすぐにその言葉の下から、いじらしい、手でさしまねいで涙を啜り、「聞きなされ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫や聟は死に果てたに……こや平太の刀禰、聞きなされ、むす…むすめの忍藻もまた……忍藻もまた平太の刀禰……忍藻はまた出たばかり……昨夜……察しなされよ、平太の刀禰」「昨夜、そもいかになされた」　母は十分に口が利けなくなッたので仕方なく手真似で仔細を告げ知らせた。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和主はそもいかにして忍藻の※帷子を……」「※帷子とは何でおじゃる」「何でおじゃるとは平太の刀禰、むすめ、忍藻の打扮じゃ。",
              "citation": {
                "source": "武蔵野",
                "author": "山田美妙",
                "note": "青空文庫"
              }
            },
            {
              "text": "『坊目考』に籠の坂の語を解して、京終郷俚諺に云所の春日奴婢刀禰と称するもの、往年七人有て、奈良七郷を常に沙汰せしむと云云。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "永承三年の関白頼通『高野参詣記』に、検非違使右衛門｜志村主重基奉仰、仰淀・山崎刀禰散所等、令造板屋形。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀・山崎の刀禰とは、その地方の長とあるもので、ここに刀禰散所とあるのは、刀禰及び散所の謂いであると解する。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに里長とは『高野参詣記』に刀禰とあるもので、その里長に命じて瓜盗人の制止を加えしめるについても、桂辺には散所雑色が多いから、それらをして警戒せしめたいとの意と解せられる。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　常識主義者が考へるとするとねえ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し厭き気味になると父上に謡をうたえの話をせよのとねだっているうちに日が西に傾く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "我武者羅に押通さうものなら、默つて聽いてはゐるが、『さういふけどなあ』とねちねちやつて來る。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはわが、したしさにはあらんとねがへばなが心、かたくなにしてあらしめな。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとね、あの人あたしの目をジッとみるのよ、怒つてるやうなのよ、まあ……あたし怖かつたわ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "○「お習字、生花、お琴、おどり――こういうものに却ってモダニティを感じ、習い度いと思うことはあるけれど、さて、いざとなって見るとね。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
