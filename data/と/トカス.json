  {
    "uuid": "cfdc79b7-2af7-5cf4-b960-9d148a549fd7",
    "entry": "熔かす",
    "reading": {
      "primary": "とかす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
