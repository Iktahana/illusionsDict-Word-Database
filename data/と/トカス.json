    "definitions": [
      {
        "index": 1,
        "gloss": "to melt",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "忠直卿は、祖父の家康から日本｜樊※と媚びられた名が、心を溶かすように嬉しくて堪らなかった。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "げに人の世は荒金のさびをし溶かす窯なりや、眞金のつやを見まくせば、底の熱をあたためよ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "焔の色の薔薇の花、強情な肉を溶かす特製の坩堝、焔の色の薔薇の花、老耄した黨員の用心、僞善の花よ、無言の花よ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、流場の笊の下とか、敷板の下などを点検し、蛞蝓は火箸で摘んで、塩で溶かすのであった。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なく眞水の方で石鹸を溶かす、それを身體になすり附けると又かゝり湯が要つて、甚だ水の濫費になる。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそるべき病菌がほんの一夜のうちに、古賀の兩眼の角膜をとろ／＼と溶かすがごとくに破壞し去つてしまつたのである。",
              "citation": {
                "source": "盲目",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体手といふものは、よく汚れるもので、マコウレエの談話によると、英吉利のある鍛冶屋は、泥棒に頼まれて金物の贓品を火に溶かす折には、手で触つては汚れるからといつて、態と長火箸を使つたといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷を溶かすには、さしあたり火をおこすより仕方がなかつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "マツチは義歯の凍つたのを溶かすに役立つのみならず、寝起きに喫みたくなる煙草にも火をつけることができる。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　スーラーブは、なにか黎明の日の光に似た歓ばしい期待が、そろそろ心を溶かすのを感じた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭のなかの海、くらい怒りを溶かす海、大きな大きなあまりにも大きなものにむかつて睡り込んでゆかうとする、ぎしりぎしりと頭のなかに渦巻く海。",
              "citation": {
                "source": "災厄の日",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん」　だんだん胸がせまって来るのを、涙に溶かすまいとすると、お茂登の声と眼とは、おこったような力みを帯びた。",
              "citation": {
                "source": "その年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、ある特殊な油を使って溶かすと、Ｘ塗料となるのだった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋はすべてを溶かす。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも園長の身体を焼くとか、溶かすかしなければ出て来ない終身の認識標なんです」「そんな出鱈目は、よせ！",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "奇妙な毒物なんだが溶かすと無味無臭で、誰も毒物が入っていると気がつかない。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも太陽が霜を溶かすようにいつの間にか人心の内部にしみ渡る。",
              "citation": {
                "source": "永遠の感覚",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年前『群書類従』の古本に売る値段は紙屋に硫酸で溶かすために売る値段と余り違わず、日に日に焼けていったのであった。",
              "citation": {
                "source": "図書館法楽屋話",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでも水に溶かすという話を聞いたから、わたしは一つ煮て見ましたよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "傅彩画面の半ばにも至らぬころ、ポツリポツリと雨は落ちて来て、手にせるパレットの紅を散らし紫を溶かす、傘をかざしてやや暫くは辛抱したが、いつ歇むとも思えぬ空合に、詮方なく宿に帰った。",
              "citation": {
                "source": "白峰の麓",
                "author": "大下藤次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　いま一つの※話は、昌造の事蹟のうち今日も有名な語りぐさであるが、あるとき昌造は、購入した蘭活字の少しばかりを鍋で溶かすと、腰の刀をはづして目貫の象嵌にそれを流し込んでみた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "溶かすべき物質の分子量の数だけの瓦数を一｜立の水に溶かしたもの。",
              "citation": {
                "source": "墨流しの物理的研究",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば水に砂糖や塩を溶かすと甘い水や、からい水が出来るのは誰でも知っているでしょうが、その際には砂糖の甘味や塩の辛味は水に溶けてもそのまま残っているのです。",
              "citation": {
                "source": "ロバート・ボイル",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の水　降ったばかりの雪は空気が接触しないようにして溶かすと空気をほとんど含んでいない。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "一定量の水を蒸発させて乾かし、残った塩分を蒸留水に再び溶かす。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲料に適した水によっては鉛を溶かす能力が異なっている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の葉のような植物物質が水の入った鉛の水槽に落ちると、その水は自然状態では持たないかなり強い鉛を溶かす作用を持つようになる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミョウバンは粉の形で、水によって前もって液体ペーストにした一定量の小麦粉と良く混ぜ、次にドー（パン生地）に入れるか又はドーを作るために使う全量の小麦に混ぜる水にミョウバンを溶かすか、どちらかである。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "硫酸鉄は坩堝内の残渣のあいだに残り、水に溶かすことによってその塩の成分すなわち鉄と硫酸を分析することができる。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも硝酸で酸性にした水を坩堝に注いでこの塊を溶かすと、その溶液に刺激性の臭いが明らかになる程度のアンモニア水を加えると、銅の存在が判るだろう。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
