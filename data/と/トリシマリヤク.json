    "definitions": [
      {
        "index": 1,
        "gloss": "company director",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あなた二人は職をさがしている私の友達で、何かに使ってもらおうと思って専務取締役に引き合せるためにつれて来た、と云うこれより自然な方法はないでしょう？",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこの床の上には、上衣やチョッキがぬぎすててあって、そしてドアの背後についている鉤金に、フランス中部鉄器株式会社の専務取締役が、自分の首の廻りに自分のズボンツリをまきつけてブラさがっていた。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "実弟のハリー・ピナーが発起人で、分担額に従い社長として取締役会に参加しており、自分がこちらへ渡っているのを知ってましたから、いい人間を手頃に見つけてくれと。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "パフォーマーは、同社の関澤義専務取締役。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊関澤義専務取締役はその後、一九九〇年六月に富士通の社長となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで西に「今入社すれば取締役にしてやるけれど、二年後にはお前の席はないぞ」と殺し文句をかまされ、同社の八番目の社員となった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九八六年三月、アスキーとマイクロソフトが独占代理店契約を打ち切り、新たにマイクロソフトの日本法人が設立される中で、アスキーの開発本部担当取締役を務めていた古川は、新会社の社長へと一大転身をはかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も一貫して情報処理部門を歩み常務取締役まで上り詰めてから、広範な人脈を持つ御大はアメリカ生まれのベンチャーの日本法人のトップへと転じた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが発表から半年ほどの一九九一年十月に、言いだしっぺのコンパックの社長ロッド・キャニオンが取締役会で突然解任されたあたりから、あれよあれよの腰砕けとなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "取締役の指圖で、同心が一人長太郎の手から書附を受け取つて、縁側に出した。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "取締役はそれを披いて、いちの願書と引き比べた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文壇の警官　阿部氏の頽廃取締役　▼改造新年号の『文化時評』で阿部知二氏が事変下に於ける国民の『頽廃、享楽面』を取締る政府のやり方に就いて意見を述べてゐる。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度去年の正月頃から来出した客で、下谷に富山銀行といふのが御座います、あれの取締役で」「え※　何……何……何ですか！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の父は、今迄多くの事業で失敗し、未だ余憤が消えてゐなかつた為か、忽ち形もなひ製薬株式会社の社長になつたり、東北銀行創立、専務取締役になつたりした。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二人は警官の身体検査をうけてぷりぷりしながら出てゆく）　客乙――日鮮漁業会社専務取締役篠原順平夫妻。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社の工場に勤めている私のお父さんは、気が進まないけど、新高さんを可愛がっている会社の専務取締役の人が仲に立っているのでイヤとは言えないのだが、お前はドウかって尋ねられた時に、妾はすぐに承知してしまいました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　松木久作の証言　○○製菓会社常務取締役松木久作は、年齢五十歳のでっぷり太った紳士で、つい一ヶ月前から、東京キネマの重役某の紹介で山上みさをのパトロンとなっていたのである。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦力頭は軍隊使用の苦力らの取締役のようなもので、胸には徽章をつけ、手には紫の総の付いている鞭を持っている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の歌舞伎座株式会社の専務取締役は井上竹二郎氏で、春興行には菊五郎が毎年出勤するのであるが、病気で出勤もむずかしいことになったから、若手ばかりで開場しなければならない。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見つけ次第に取りおさえてくれ」　その当時の市中取締役は庄内藩の酒井左衛門｜尉である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房の通弁３・11（夕）　森村商事会社の取締役村井｜保固氏は、なが／＼米国へ渡つてゐて、那地で会社の地位を据ゑたのは、全くこの人一人の骨折だと言はれてゐる男である。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ氏は火災保険会社や、銀行の取締役として聞えてゐると同時に、能楽や義太夫の達者としても、相応に名を売つてゐる人である。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡邊君は岡田汽船會社の專務取締役でもあり、同じ囘漕店の支配人でもあり、境の港町の町會議員をも兼ねてゐるやうな人で、最初私は同君からおそろしく長い肩書の名刺を貰つた時、これはどういふ人かと思つたが、だん／＼言葉をかはして見てゐるうちにその男らしい容貌と態度とに心をひかれるやうになつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来の専門は造兵科で造兵の教授であり、腔外弾道学の大家だという話しだが、今日では理化学研究所の所長で理化学興業会社取締役で、農村工業化論の中心頭脳である。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し敏感な教養のある観察者なら日下部太郎が彼のＮ会社の専務取締役という職業にも似合わず相当に洗煉された趣味家であることをも、服装や話題から発見し得ただろう。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら彼はこの瞬間、Ｎ会社の取締役としての日下部太郎でもなければ、高畠子爵相談役としての彼でもなかった。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは、辯護士、道會議長、某會社の取締役の某氏を批評した物、一つは、北海道で有名な人々の逸事を書いた物だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "『マイコン入門』（廣済堂出版）の著者であり、〈ミスター半導体〉の大内淳義副社長や、わが国コンピュータ研究開発の草分けで、ソフトウエア技術の第一人者、水野幸男取締役らも、このマイコン勉強会で若い女性講師の『マイコンの動かし方』『プログラムの作り方』といった実技指導、講義の聞き役に回る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七四年に取締役、一九七八年に常務、一九七九年に専務取締役と階段をかけ上ってトップを極めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
