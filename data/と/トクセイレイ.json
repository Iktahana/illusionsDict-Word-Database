      {
        "index": 1,
        "gloss": "debt cancellation order issued by the Emperor or the Shogun (during the Muromachi and Kamakura periods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
