[
  {
    "uuid": "3d5bd745-1a32-5606-96fb-b984f484d729",
    "entry": "取り組む",
    "reading": {
      "primary": "とりくむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to grapple with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しばらく、明暗が渦雲のように取り組む世の中に眺められる。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが一番人生で、値打ちがあると信じたことに向っては、万事を放擲して目的に取り組む。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕らの今取り組むべき問題は、どのような道を経て、物色された宝石箱という始点から、トテナム・コート通りの鵞鳥の餌袋という終点に至ったかだ。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒルトン・キュービットの広い背中が扉の向こうに消えると、すぐさまホームズは机に走り寄り、例の踊る人形の紙を自分の前に並べて、込み入った計算にじっと取り組むのであった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "春のさわやかな希望と、我々の取り組む重い使命とのあいだに、私は妙な対比を感じずにいられなかった。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "とはいっても、どうなるにしても、お金をもらいましたし、仕事に取り組むことにしました。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            },
            {
              "text": "一通目に取り組むあいだ見向きもされず卓上に置かれていたものだ。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この案件に対して貴殿が取り組むさまをながめるのは、これまで知的娯楽でもあったのだが、忌憚なく言うならば、こう過激な手立てを講じるのは、予としても実に心苦しい。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私には、これに取り組む力が出せませんでした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩野さんと進めることになった独立の計画は、本格的にこれに取り組むチャンスに思えました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "公有作品の再利用にあたっては、この記録を残すことのみを求め、その他には一切、条件を付けないという案を軸に、青空文庫ファイルの利用規定をまとめる作業に取り組むことにした。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じく無力をさらす結果にはなっても、戦争の放棄という世界史的課題に取り組むと宣言した国なら、非軍事的な解決策を求めて徹頭徹尾あたふたと動き回り、ともかくも交渉のパイプを付けようとあがいてみせるのが筋ではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あくまで標準に沿うことを大原則としながら、自ら新たな標準の確立に向けて技術開発に取り組む」　こうした基本戦略にしたがって、その後サンはソフトとハードの両面から爆弾提案を行なった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな錯乱のさなかの一九九一年四月九日、コンパックとマイクロソフト、そしてＵＮＩＸで勝負をかけるサンタクルズオペレーションを始めとする二十一社が、新しい先進的プラットフォームと銘打った、ＡＣＥ（アドバンスト・コンピューティング・エンバイロメント）構想に取り組むと発表してオレの錯乱に拍車をかけた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく自分で納得のいく目的があること、それがマイクロコンピューターに取り組む人の備えなければならない最低条件になるのではないでしょうか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "回路の設計に取り組むと、一つ決定版を作ればよいはずのものを、あらゆる可能性を論理的に詰めていくことに興味を引きつけられ、スケジュール無視で没頭してしまう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの道に踏み込んだ以上は、できてもできなくても人類の意志と取り組む覚悟をしなければならなかった。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い入った決心を眉に集めて、日ごろの楽天的な性情にも似ず、運命と取り組むような真剣な顔つきで大事の結着を待つ木村の顔。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永田靖氏は幕の内の連中の批評は聞くが、一般の批評を聞いて取り組むという気がないと率直に語っておられます。",
              "citation": {
                "source": "一つの感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間的な気持ちを持っていた人たちが、なぜあのような大量破壊兵器の開発に全力で取り組むことができたのか」　監督のジョン・エルスはそう問題を設定し、ねじ込むように対象に迫っている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく自分で納得のいく目的があること、それがマイクロコンピュータに取り組む人の備えなければならない最低条件になるのではないでしようか。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかには一度もマイコンにさわったこともない幹部もいるとかで、事前に手渡された『マイコン操縦法入門』と題するテキストをみながら、実際に社内のマイコンを動かし、予習に取り組む姿がチラホラ目立ち始めている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆にいうと、私たちがマイコンに取り組む上で、『何をするのか』という『目標』を常に持っていることが大切なのです。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "選りすぐりの人材を一本釣りしていったテイラーは、取り組むべき課題は研究者の自由裁量に任せた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立の名門男子校のレイクサイドスクールは、一九六八年春、いち早くコンピューター教育に取り組むことを決めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コピーを無断で配付することはソフトウエアの開発者から盗むことであり、こうした振る舞いが横行すれば誰も労力と経費をかけて開発に取り組むことなどできなくなる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ目は、コンピューターの専門部隊である情報処理事業グループがあらたに取り組む、一六ビットの事務用機。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九八〇（昭和五十五）年十月、彼らはアプリケーションの開発と販売部門を独立させてアスキーコンシューマープロダクツを設立し、この分野に本格的に取り組む体制を固めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが信州精器のハンドヘルドコンピューターや、アルトの流れを汲むＰＥＲＱ、そしてスター越しに時代の風を感じた西は、アラン・ケイがダイナブック実現のための課題と想定した二つの要素に取り組むマシンを、ＩＢＭ ＰＣの次のターゲットとして同時に選び取っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがＰＣ―８８０１の互換機を、マイクロソフトの協力なしで独力で開発するとなれば、プロジェクトを組織して可能な限りの強力なチームを作り上げ、全力で取り組むしかない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
