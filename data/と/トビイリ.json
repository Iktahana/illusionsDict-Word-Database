    "definitions": [
      {
        "index": 1,
        "gloss": "taking part on the spur of the moment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
