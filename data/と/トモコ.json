        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "喫茶店ロスアンゼルスの友子という少女と決めて、そして、ぽかんと穴のあいてしまった様な自分が賭けに勝つことによって充実されるだろうという愚かしい希望を抱いて、ロスアンゼルスに通った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日目の白昼、活動へ連れて行った友子にいきなり、ホテルへ行こう。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年経ち、ひょっくり友子に会った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "豹一は友子と結婚した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の秋、友子は男の子を産んだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前は豹吉とつけようと友子がいったが、彼は平凡に太郎とつけ、皆んなに笑われた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎から帰って来いと迎えが来ると、お君は、また来まっさ、さよならと友子に言って、雨の中を帰って行く。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "余が倫敦に居るとき、忘友子規の病を慰める為め、当時｜彼地の模様をかいて遙々と二三回長い消息をした。",
              "citation": {
                "source": "『我輩は猫である』中篇自序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "うわさに聞けば、友子づれで、吉原の河岸をせせって。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は友子といい、美貌だったが、心にも残らなかった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、三月ほどして戎橋筋を浮かぬ顔して歩いていると、思いがけず友子に出会った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたを探していたのだと、友子は顔を見るなりもう涙を流していた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "友子は白粉気もなくて蒼い皮膚を痛々しく見せていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の近くに二階借りして、友子と暮した。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "美貌を買われて、婦人呉服部の御用承り係に使われ、揉手をすることも教えられ、われながらあさましかったが、目立って世帯じみてきた友子のことを考えると、婦人客への頭の下げ方、物の言い方など申分ないと褒められるようになった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の秋友子は男の子を産んだ。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎から、はよ帰ってこいと迎えが来ると、お君は、また来まっさ、さいならと友子に言って、雨の中を帰って行った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "民友子｜先つ頃「俗間の歌謡」と題する一文を作りて、平民社界に行はるゝ音楽の調子の低くして険なるを説きぬ。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "民友子は時勢を洞察して、歎慨の余りに此語を吐けり、われは日本の文学史に対してこの一種の虚無思想の領地の広きを見て、痛惻に勝へざるなり、彼等は高妙なる趣致ある道徳を其門に辞み、韻調の整厳なる管絃を謝して容れず、卑野なる楽詞を以て飲宴の興を補ひ、放縦なる諧謔を以て人生を醜殺す。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人哲学者は無論ヒユーマニチーの観察者ならずんばあらず、然れども吾人は恐る、民友子の「観察論」の読者には、或は詩人哲学者を以て単に人性人情の観察者なりと、誤解する者あらんことを。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "民友子の「観察論」を読みたる人は必らず又た民友子の「インスピレーシヨン」を読まざるべからず。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らずんば吾人民友子に対する誤解の生ぜんことを危ぶむなり。",
              "citation": {
                "source": "内部生命論",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "民友子大喝して曰く、「砂丘の上にベベルの高塔を築かんとするは誰ぞ」と。",
              "citation": {
                "source": "頑執妄排の弊",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間は霊質二界に棲む者なり、と「現金世界」に於て言はれたる民友子の金言、吾人之を記憶す、民友子は霊界を非認する人にあらざる事知れてあり、その質界を非認する人にあらざる事も知れてあり。",
              "citation": {
                "source": "人生の意義",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "星氏より見れば民友子は一個の白面書生なり、即ち事業を以て民友子を視るの標率とするが故なり。",
              "citation": {
                "source": "賤事業弁",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔いざ渡せかし　おいぼれめ〕宮沢賢治「いざ渡せかし　おいぼれめいつもこゝにて日を暮らす」すぱとたばこを吸ひやめて何を云ふともこの飯の煮たたぬうちに　立つべしや芋の子頭白髪しておきなは榾を加へたり",
              "citation": {
                "source": "〔いざ渡せかし　おいぼれめ〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくともこれによつて、日本語はずつと「音樂性」を豐富にし、純正詩歌の表現に適するやうになるであらう。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこう言った雪の美しさだけなら、何も高山に限らず、寒帯地方で、もっと大規模に見られるかも知らぬが、高山特得ともいうべきは、空の濃碧であること、色彩の光輝あること、植物の変化と豊饒なることなどが、その背景になっていることで、北寒地方の雪といえども、これらには辛うじて匹敵し得られるに過ぎまい。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "火山の中は凡べてが「大きな単純」であるから、注意して観察すれば、風の描いた紋も解るのである、もっともこういう現象は、火山とのみ限られることではないが、火山のような柔らかい印象を受けやすい皮膚であればこそ、それを劃然と、鮮明に残しているのである。",
              "citation": {
                "source": "日本山岳景の特色",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともこの中立地帯の産物はその地帯の両側にある二つの世界の住民から見るとあるいは廃頽的と見られあるいは不徹底とののしられるかもしれない。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
