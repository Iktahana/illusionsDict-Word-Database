    "definitions": [
      {
        "index": 1,
        "gloss": "trouble",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "つまり、そのような事件は、たしかに夫にとって大いなるショックであっても、しかし、それは「ショック」であって、いつまでも尽きること無く打ち返し打ち寄せる波と違い、権利のある夫の怒りでもってどうにでも処理できるトラブルのように自分には思われたのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルベルト・オイレンベルグさんは、そんな愚かしい家庭のトラブルなど惹き起したお方では無いのであります。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ささやかなトラブルの思い出として残るだけのことだ。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどそんなトラブルを繰り返しながらも、私はしだいに、この世界の仕組みになじんでいきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "地雷でも踏んだように突然トラブルが発生し、せっかくそこまで作ってきたものが何度かおしゃかになりました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきりとオープンＵＲＬの意味をつかむには、『ヒロシマ・ナガサキのまえに』のトラブルを必要としました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいこりゃなんだとしばらくは途方に暮れていたが、二度三度と似たようなトラブルを体験したところではたと膝を打った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マシン・トラブル以外にはミスもない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一と高志にとってのトラブルは、ほとんどが、たとえば、昼夜つづけて嫌いな食べ物が食卓にのってしまうといった、この寮にはつきものの、ごくささいな日常的問題だった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "起床というのは、多くの寮生にとって、それ自体すでにトラブルだが、妙な音楽で起きるというのは、ほとんど拷問に近い。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前この北備の二つの中学は野球の対校試合をして、後で争闘となってトラブルを起したので以後三次中学の方で対校試合は拒絶していたのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は実に両親の不断のトラブルです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄原より）　　　お絹さんとのトラブル　庄原を出発してから一度も便りをいたしませぬゆえ、私の身の上を案じていて下さいますことと存じます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にもかかわらず、何のトラブルもなしに往生し遂げた。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かトラブルがあって解決してくれるように頼むときに、出来の悪い日本人のボーイが日本語以外には分からないような場合を除けば、尋ねるべき人もいません。",
              "citation": {
                "source": "手紙",
                "author": "一八九三年七月二二日付　チェンバレン　宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "さだ子を自分の家に入れた時、伊達正男を養育しはじめた時、必ずや夫人との間にトラブルがあつたにちがいない。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同室の人間とも、サッカー部の連中ともトラブルはなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのままにしておけばトラブルの原因になりかねないものにも、平気で目をつぶる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集者とのトラブルに関しては、筆者も人のことを言えた義理ではない。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下で遊んでいた子供がコードにつまずいてせっかく入力したデータが一瞬に飛んでしまうトラブルはあったが、三〇分後には準備を完了した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気にとって、事は一小型コンピューター部門のトラブルにとどまらなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "システム１００の面目一新にあたって採用された対話型の操作環境を支えるＩＴＯＳは、当初は問題点を数多く残したまま出荷されたために全国でトラブルを引き起こした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―ＤＯＳと並んでＣＰ／Ｍ―86がＩＢＭから供給されることになるにあたっては、デジタルリサーチとＩＢＭのあいだで事前にトラブルがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その古山の個性は、ＩＴＯＳの一大トラブルに際して、存分に発揮された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがモジュール同士をつなぐところに、トラブルの種が数多く残っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "バグをほとんど取りきり、約束していた機能をすべて備えた３・５版は、トラブル発生から約一年を経て出荷することができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＩＴＯＳのトラブルが日本電気のオフィスコンピューター事業を崖っぷちまで追いつめたのは、それゆえだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "基本ソフトウエアのトラブルは許されないとはいえ、納入先がはっきりしているオフィスコンピューターならまだしも責任の取りようがあった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
