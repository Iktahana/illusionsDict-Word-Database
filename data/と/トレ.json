        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この私の弱い骨を、暖いトレモロで満たして下さい。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌リュテースを編輯してゐたレオ・トレズニカは、アムール・ジョーヌと『歎き』（ラフォルグの詩集）の作者との明らかな類縁に驚いて、コルビエールに肩を持ちながら両者を比較してラフォルグを荒だてたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール・カリグに手解されてゐたトレズニカ独り、良心を以てコルビエールを読んでゐたのである。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同時にまたボトレエルの如き冥想の詩人でもない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄門という言葉は明治時代の隅田川のボートレースと土手の桜を思い出させる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄門が無くなって、隅田堤がコンクリートで堅まれば、ボートレースの概念もやはり変って来る。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどボートレースに、櫂からの雫が、河面にポタポタして、小さな円い輪を描いたのに似ている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランスではコトレツ・ミラネーズと云い、ドイツではウィンナー・シュニッツレルと云う。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人はその名の示すようにこの料理を伊太利ミラノのコトレツと考え、ドイツ人は墺太利の首府ウィーンの料理と考えているらしい。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コトレツ・ミラネーズとウィンナー・シュニッツレルの異るところは前者は伊太利風のマカロニかスパゲチを付け合せとして居り、後者が馬鈴薯を主な付け合せとしていることで、そこに両本家の特色を表わしている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも最も簡単なるデモンストレーション的実験においてすら、用意の周到ならざるため、条件のただ一つを看過すれば実験の結果は全く予期に反する事あるは吾人の往々経験する所なり。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プトレミー派の学者は地球を不動と考えて、太陽は勿論其の他の遊星も皆その周囲を運行するものと考えた。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日ではある簡単な問題を考える場合には依然としてプトレミーの考えを使用して怪しまない。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその二つの世界の限界を定めようとする時にドーミエーやゴヤやロートレークの或る作物をいずれの領分に配していいかを決定するのに迷うのである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても古代に溯りたいなら、せめてサイラスやアルタセルキセスなどは節約して、文化に貢献したアルキメーデス、プトレモイス、ヘロン、アポロニウスの事でも少し話してもらいたい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オングストレームの太陽スペクトルの図版もこれで取ったのであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月十五日『東京朝日新聞』）　　　　　　　　　二十　　　　　　ボートレースに無線電話　今年の七月、北米の大湖エリーの水上で端艇競漕のあった時、その時々刻々の景況を陸上に報ずるためテルマと名づくる小蒸気船に無線電話機を載せて現場に臨ませた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この緑色をそのままに保存する法については色々試験をした人がある中に、数年前トレール博士は次の法を発表した。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてボオドレエルのあるポートレイトにどこか似てゐるやうに思つた。",
              "citation": {
                "source": "淺見淵君に就いて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪え切れなかった侮辱のため投げられたガウントレットを拾い上げたのだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "この西班牙への旅--殊にトレド一帶の何か不安を帶びた風物――は、詩人にはいたく氣に入つたやうに見える。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその地方、――殊にトレドは、ドゥイノ及びヴェニスと共に、晩年のリルケの胸奧にもつとも深く鳴りひびいた三つの大きな諧調ともなつたのである。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のトレドがリルケの生涯にはじめて現はれたのは、おそらく一九〇八年の秋ロダンに宛てた次ぎの手紙（丁度「マルテの手記」に筆を下ろさうとしてゐた時分である）で、それもトレドの畫家エル・グレコの鬼氣を帶びた筆を通してであつた。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九〇八年十月十六日、巴里ヴァレンヌ街七十七番地ロダン樣　私は展覽會でグレコの「トレド」の前に一時間ばかり過して歸つて參りました。",
              "citation": {
                "source": "トレドの風景",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウルスガァルに於ける侍從クリストフ・デトレェヴ・ブリッゲの死。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、氣むづかしげな顏をした、栗毛の犬だけが主人の傍に坐つて、その幅のある、毛深い前肢の一つを、クリストフ・デトレェヴの大きな灰色の手の上にのせてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その聲はクリストフ・デトレェヴにではなく、クリストフ・デトレェヴの死に屬してゐたからである。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
