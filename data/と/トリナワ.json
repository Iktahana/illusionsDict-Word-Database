  {
    "uuid": "54b6cce7-1b69-5b92-b3a7-5af9668d7bd8",
    "entry": "捕り縄",
    "reading": {
      "primary": "とりなわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
