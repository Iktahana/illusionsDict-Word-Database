    "definitions": [
      {
        "index": 1,
        "gloss": "box (built-in) for containing shutters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
