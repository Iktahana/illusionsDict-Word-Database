    "definitions": [
      {
        "index": 1,
        "gloss": "outer bamboo layer of a bow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
