    "definitions": [
      {
        "index": 1,
        "gloss": "to be called ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自作を語れ、と言われると、どうして私は、こんなに怒るのだろう。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちの魯迅先生が、いま生きていたら、何と言われるでしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、あんなのが世間から人並の男と言われるのだろう。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ芭蕉の句が、一般に観念的と言われる理由で、この点蕪村の印象的、客観的の句風に対してコントラストを示している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村が「絵画的詩人」と言われるのはこのためであり、それは正しく芭蕉の「音楽的詩人」と対照される。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺はことし六十五であるが、穂高山の主と言われるくらいな山男で、何でも二十五、六歳のころ、旧の師走であったが、三人連れで、この温泉の上まで、猟にやって来たとき、雪崩れに押し流されて、一里も下まで落っこち、左の脚を折ったということで、もし自分一人であったら、到底命は助からなかったろうと、物語った。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると、文芸家仲間から、映画作家には自己内容が貧困していると言われる。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、文芸家の作品を映画化することになった場合、「原作のままで行ってほしい」と言われる場合がある。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより「誰ぞをお呼びやおへんのどしたら、帰っとくれやす」と言われる方が、と喬は思うのだった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし結局、彼はそんな人びとから我が儘だ剛情だと言われる以外のやり方で、物事を振舞うすべを知らなかったのだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "義母などの信心から、天理教様に拝んでもらえと言われると、素直に拝んでもらっている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、もし昔の化け物が実在でないとすれば今の電子や原子も実在ではなくて結局一種の化け物であると言われる。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも、一方に結晶体の原子格子の一小部分を考え、他方に液体の分子集合の緩舒な状態を考えれば、ある度まではあたっていると言われる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死後に行くと言われる地獄は、実は目前の欲の世界である。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、たとえば海門岳が昔は開聞でヒラキキと呼ばれ、ヒラキキ神社があるなどと言われるとちょっと迷わされるが、よくよく考えてみるとむしろカイモンが始めであろうとも考えられる節があり、千島のカイモンと同系と考えるほうがよさそうにも思われ、少なくも両方に同等の蓋然性がある。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴォルタの電盆や電堆、ガルバニの細君の発見と言われる蛙の実験いずれも質的なる画期的実験である。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい人間の顔は時々刻々に変化しているのをある瞬間の相だけつかまえる事は第一困難でもあるし、かりにそれを捕えて表現したとしても、それはその人の像と言われるだろうか」というような意味であった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たださえ忙しい県庁のお役人様はこの上に山火事の調査まで仰せつかっては困ると言われるかもしれないが、しかしこれも日本のためだと思って、もう少しめんどうを見てもらいたいと思うのである。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五唱　嘘つきと言われるほどの律儀者　まちを歩けば、あれ嘘つきが来た。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と笑いながら言って、記者たちは、もうそろそろ太宰も酔って来た、この勢いの消えないうちに、浮浪者と対面させなければならぬと、いわばチャンスを逃さず、私を自動車に乗せ、上野駅に連れて行き、浮浪者の巣と言われる地下道へ導くのでした。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう笑いの中で最も純粋で原始的だと言われるのは、野蛮人でも文明人でも子供でもおとなでも共通に笑うような笑いでなければならない。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうやり方は言わばアカデミックなオーソドックスなやり方であると言われる。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、案内者が「この川を渡る橋がない」という意味で、渡れないと言ったのを船で渡っておいて「このとおり渡れるではないか」と言われるのはどうもしかたがない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭脳の働きが外方へ向くのを止められているので自然に内側へ向かって行くせいだと言われる。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人からあんなつまらないことと言われるような事がらでも深く深く研究して行けば、案外非常に重大で有益な結果が掘り出されうるものである。",
              "citation": {
                "source": "時事雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君、服を新調したから一つ見てくれ」と言われるようなこともあった。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虞美人草」を書いていたころに、自分の研究をしている実験室を見せろと言われるので、一日学校へ案内して地下室の実験装置を見せて詳しい説明をした。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これを小説の中へ書くがいいか」と言われるので、それは少し困りますと言ったら、それなら何か他の実験の話をしろというので、偶然そのころ読んでいたニコルスという学者の「光圧の測定」に関する実験の話をした。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなやさしい問題ができないのは実に不思議だと言われるのであった。",
              "citation": {
                "source": "田丸先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ世間でお雛さまのようと言われる美しい夫婦の顔を向き合って菓子位つまむだけだ。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
