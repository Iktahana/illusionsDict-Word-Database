    "definitions": [
      {
        "index": 1,
        "gloss": "Amur stickleback (Pungitius sinensis)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とみよしや、おぬゐ。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むまのこくに、おのみちに、つき、とみよしやに、とまる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とみよしやに、ねたりける。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とみよしやにて、むかいびきをする。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がひとり低いソフアに坐つて、そのうしろに叔母とみよが同じ脊たけぐらゐで並んで立つてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私とみよ子とは、いつから知り合ったともなく、親しくしていました。",
              "citation": {
                "source": "幻の園",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とみよ子は云いました。",
              "citation": {
                "source": "幻の園",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の父とみよ子の父とが一緒に町へ出かけますと、私たちは同じようにおみやげを買ってきて貰いました。",
              "citation": {
                "source": "幻の園",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私とみよ子とは、その中で取組み合って笑いこけました。",
              "citation": {
                "source": "幻の園",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　富士男は声をたよりに巻きろくろとみよしのあいだにあゆみよった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣裳をまとうとみよし屋の方へ、娘は走って行ってしまった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、かりに私とみよ子との間が、お酌と接客との間のようなものだったと仮定しても、あなたのその評価は全然あべこべだったろう。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとみよはふいに眼を覚して泣き出した。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父さんに酒を飲むなとは云わないが、良助とみよとが大きくならないうちは決して死んではいけないって。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして貧しい中に良助とみよ子とを育てていたんだ。",
              "citation": {
                "source": "田原氏の犯罪",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　妹の自分にさへ分つてをるのに、兄に分らぬ筈があらうか……とみよ子はなほも微笑をつゞけてゐる。",
              "citation": {
                "source": "父の帰宅",
                "author": "小寺菊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はくな／＼と膝を折り、幾年の監禁に苛めつけられた痛々しい頬に、ニヤリと佗しげな微笑をのせて、しよんぼりとみよ子の前に坐つた。",
              "citation": {
                "source": "父の帰宅",
                "author": "小寺菊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安之助が六歳になるとみよは付近の禅寺へたのんで学問をはじめさせた、寺僧は由ありげな母子のひとがらに同情したとみえ、――いっそ寺へお預けなされたらおまえさまもお身軽になれましょうが。",
              "citation": {
                "source": "日本婦道記",
                "author": "箭竹",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
