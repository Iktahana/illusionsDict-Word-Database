        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "逸詩に、君子に君たればすなわち〈正しく以てその徳を行う、賤人君たらば、すなわち寛にして以てその力を尽す〉という事じゃと、『呂覧』愛士篇に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら触覚というものは音のしないものだから、不良でない立派な紳士が応用していても一向発見されずにすむから、どうも触覚なるものはこっそりと不徳を行うためには便利なものである。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは何というにしても、徳を行う場合でさえ、人々の目指す最後の目標は快楽なのだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
