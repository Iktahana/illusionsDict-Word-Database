          "literary": [
            {
              "text": "その他にありませんか」「その他には、この近所にはないね」「この頃盗電はありませんか」「あるよ。",
              "citation": {
                "source": "贋紙幣事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗電があって困っているんだ」　工夫はびっくりしたように森君の顔を眺めながら答えた。",
              "citation": {
                "source": "贋紙幣事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを読み終つた時、ふと同君の名作「盗電」の美しい場面を思ひだした。",
              "citation": {
                "source": "戯曲二十五篇を読まされた話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古雑感岸田國士「盗電」の舞台監督を引受けた時、すぐ作者の金子洋文君に会つて、いろいろ相談したいと思つたが、生憎金子君は旅行中だといふことで、止むを得ず、自分だけの解釈に従つて稽古を進めた。",
              "citation": {
                "source": "稽古雑感",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "世耕情報、尺祭り、節電盗電、日本は目下、あげて道化芝居である。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
