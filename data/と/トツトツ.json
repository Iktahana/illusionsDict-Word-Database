[
  {
    "uuid": "2e205ea9-ae81-500a-ab1c-2ca87af3ff9b",
    "entry": "咄々",
    "reading": {
      "primary": "とつとつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
