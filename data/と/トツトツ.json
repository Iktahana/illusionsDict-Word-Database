      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "clicking (of the tongue)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　咄々迫る百人長は太き仕込杖を手にしたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者もその男の咄々と吐き出す肺腑の声に動かされて胸が一パイになって来た。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と咄々人に迫り来る。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "客を送り出でて満枝の内に入来れば、ベッドの上に貫一の居丈高に起直りて、痩尽れたる拳を握りつつ、咄々、言はで忍びし無念に堪へずして、独り疾視の瞳を凝すに会へり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その算へざりし奇遇と夢ざりし差別とは、咄々、相携へて二人の身上に逼れるなり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒に踵を回して急げば、行路の雲間に塞りて、咄々、何等の物か、と先驚かさるる異形の屏風巌、地を抜く何百｜丈と見挙る絶頂には、はらはら松も危く立竦み、幹竹割に割放したる断面は、半空より一文字に垂下して、岌々たるその勢、幾ど眺むる眼も留らず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "咄々怪事もあるもので。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に又賊軍討伐の任に當れる官軍が、却つて良民を執へ、之を金に換へて賊軍の糧食に資するが如きは、支那以外の他國では、到底見當らぬ咄々怪事と思ふ。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "金枝玉葉の身で、かかる嗜好を有するとは、眞に咄々怪事でないか。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ひ見よ、幾千の山法師が、日吉権現の神輿を擁して、大法鼓をならし、大法螺を吹き、大法幢を飜し、咄々として、禁闕にせまれるの時、堂々たる卿相の肝胆屡※是が為に寒かりしを。",
              "citation": {
                "source": "木曾義仲論（東京府立第三中学校学友会誌）",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、今は黒煙をはき、白波をけり、砲門を開きて、咄々来たってわれに迫らんとするさまの、さながら悪獣なんどの来たり向こうごとく、恐るるとにはあらで一種やみ難き嫌厭を憎悪の胸中にみなぎり出づるを覚えしなり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、金博士は、商人に買収されて、あんな警告文を出したのにちがいないと思うが、どうだこの見解は……」　不断から冷静を自慢している一人の男が、咄々として、こんな見解をのべたのであった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルの近所の家は、全部立ち退きをしないと大危険だねえ」　彼は、驚駭のあまり、歯の根もあわず、がたがたと慄えだしたが、そのとき咄々先生はからからと笑って、「やあ、なにを騒ぐぞ。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあ、皆、こっちへ戻れ、不発弾が、なに恐ろしい、戻れというのに……」　と、エディ・ホテルの前で、不発論を守って、逃げ行く不甲斐なき民衆を呼び戻しているのは例の咄々先生であった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや金博士の手製になるあやしき爆弾が、十五年間もじっと正しき時を刻んで、正確なる爆発を……」　残念ながら、咄々先生の言葉は、これ以上録音することが不可能の事態とは相成った。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなれば、咄々先生の舌が、一抹の煙と化してしまったからである。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん舌ばかりではない、咄々先生の躯ごと煙となって、空中に飛散してしまったのであった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "咄々先生が背にしていた礎石は、正直に大爆発を遂げたのであった。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかりしこうして商業の進歩はひとりこれらの現象にとどまらず、さらに一の咄々驚くべきの現象を発出したり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればかの迂儒の眼中より見ればほとんど理由もなく因縁もなく、他人の疝気を頭痛に病むの類たるがごとく、実に咄々怪事のごとしといえども、決してしからず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの千古の奇男子たるビーコンスフィールド侯をして神出鬼没の政略を採り、欧州政治の大舞台において咄々驚くべき怪しむべきの奇舞を演ぜしめたるゆえんのものはこの旧分子の力なり。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "不平等主義ひとたび横行するときにおいては忽然として貴族的の社会を幻出し、咄々怪しむべき貴族的の現象を生じ来たるやもとより論をまたず。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は人類を軟骨動物と思做し、全く誠信なく、全く忠誠なく、心宮中に横威を奮ふ一種の怪魔が自由に人類を支配しつゝありて、咄々、奇怪至極の此社界かなと観念し来りて、之を奸猾なる健介に寓し、之を窈窕たる美形美禰子に箝め、之を権勢者なる世々良伯に寄す。",
              "citation": {
                "source": "「油地獄」を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだに覚えている、『儒教デモ善ト云フモ悪ニ対スルホドニ善ト悪トナイゾ、中庸ノ性ト云フタゾ』などと、幼な心に何の事とも分らず聞いておったあの咄々とした御音声が、いまだに耳の中で聞えている。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまだに覚えてゐる、『儒教デモ善ト云フモ悪ニ対スルホドニ善ト悪トナイゾ、中庸ノ性ト云フタゾ』などと、幼な心に何の事とも分らず聞いてをつたあの咄々とした御音声が、いまだに耳の中で聞えてゐる。",
              "citation": {
                "source": "雪の宿り",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "咄々、酔漢｜漫りに胡乱の言辞を弄して、蹣跚として墓に向う。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "饅頭虎が、咄々と嗄れ声で物を言うのに対して、指無しの権は、ねっちりした、しかし、突き刺すような皮肉な言葉をつかった。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛び退って、槍を下段に構え直して、ヤ、ヤヤ、と言って、口から咄々と火を吐くような息を吐いて、もう一寸も進みませんでした。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿のめぐりはだんだんゆるやかになり、みんなは交る交る、前肢を一本環の中の方へ出して、今にもかけ出して行きさうにしては、びつくりしたやうにまた引つ込めて、とつとつとつとつしづかに走るのでした。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、この作者と知つてゐるわけではないのですが、斯ういふはなしといふものは普段でも読むと見えて、やはりこの前、この雑誌に載つてゐた、題は忘れましたが、田舎の医者のことを、とつとつと書いたものを思ひ出しました。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
