          "literary": [
            {
              "text": "虎頭を料り虎鬚を編む。",
              "citation": {
                "source": "令狐生冥夢録",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くより虎賁などいう武官職名もあり、虎符を用いた事もあるから件の牌には虎頭を鐫り付けたのだろう。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "また楊豊虎に噛まる、十四になる娘が手に刀刃なきに直ちに虎頭を捉えて父の難を救うたとある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎隊裏の「虎頭」となつて、筆を載せて行つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎頭燕頷の羅漢は暫く問はず、何びとも多少はヒステリツクである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬武は彼自身、某今在這宜秋山虎頭寨。",
              "citation": {
                "source": "支那人間に於ける食人肉の風習",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "――先なる一壮漢は、狭霧の薄戦衣に、虎頭を打ち出した金唐革の腹巻に、髪止めには銀のはちまきを締め、おぼろめく縒絨の剣帯へ利刀を横たえ、騎馬｜戛々、ふと耳をそばだてた。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
