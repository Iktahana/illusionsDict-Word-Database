[
  {
    "uuid": "88f90167-76c4-5c0a-be6c-a37b14f516ac",
    "entry": "捕り物",
    "reading": {
      "primary": "とりもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
