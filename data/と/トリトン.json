        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夫人はバルベリニ広場の「貝を吹くトリトン」を童話のようだと面白がった。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上にトリトンに牽かして行く貝殻型の車駕に御して海神が嘯いている。",
              "citation": {
                "source": "噴水物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『俺達の笛は、此處にゐる男が吹いて、壞してしまつたんだよ』　そして彼はトリトンのやうな顏をした一人の水夫を指した。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリトン（海の神）は先に駆けりつ、法螺の貝もて人皆を歓喜せしむる楽を奏しぬ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
