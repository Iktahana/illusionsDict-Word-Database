    "definitions": [
      {
        "index": 1,
        "gloss": "truss",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "科學精神の熱意されるところには、いつも一方に童話精神が熱意され、科學とお伽話とが、辨證法的コントラストの止揚によつて對立してゐるのが、どこでも文明國の常態である。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ芭蕉の句が、一般に観念的と言われる理由で、この点蕪村の印象的、客観的の句風に対してコントラストを示している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄上の峻嚴と竹内俊吉氏のなごやかさは、縣會に於いて、よいコントラストをなしたであらうに。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対する向い側の壁に大分猛烈な絵が並んでいるので、コントラストの作用で一層この人の絵が静かに上品に見える。",
              "citation": {
                "source": "二科会その他",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人の小説家は、氣質のいろいろな點で反對して居り、見方によつては地球の兩極を代表するコントラストであるけれども、しかも文學の或る本質的な一點で、全く立場を一にしたものがある。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの批評は、僕と室生とのコントラストでは、最も面白い觀察である。",
              "citation": {
                "source": "室生犀星君の人物について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はどんな宇宙の對照からも、君と芥川君とにおける如き、それほど鮮明なコントラストを見たことがない。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "關東人である僕の性急と、東北人たる福士君の大陸的悠長とは、殆んど耐へがたきコントラストだ。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからストラスブルクを見て、ニュルンベルクへ参りました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはコントラストのせいであろう。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上記の点で著しく対蹠的のコントラストを形成するものは、日本の剣劇映画における立ち回りの場面である。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に登場する寺子屋の寺子らははなはだ無邪気でグロテスクなお化けたちであるが、この悲劇への序曲として後にきたるべきもののコントラストとしての存在である以上は、こうした粗末な下手な子供人形のほうが、あるいはかえって生きたよだれくりどもよりよいともいわれる。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに両方が正反対で、著るしいコントラストをしているかが解るだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあらゆる著るしいコントラストで、芸術の南極と北極とを対照した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　和歌と俳句とは、日本の詩に於ける二つの代表的な形式であり、かつ最も著るしいコントラストである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての詩を愛する日本人は、この二つの詩に於ける特殊のものを、対照のコントラストに於て知っているだろう。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（支那人はこの点で、日本人と最も著るしいコントラストである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトラスの忍耐、プロメテの忍苦、そのようなかなり永続的な姿であらわされる徳のように思われる。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきり立つた先生と、糞落ち着きに落ち着いた上村とのコントラストはまるでポンチ繪だつた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとよりニセ物のビザンチン石彫の破片やエトラスカの土焼皿などもあって外人相手の店には違いないがその列んだ品物のなかにこの葡萄の蔓模様の鉄の取手があったのに加奈子は心をひかれた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨幹と数知れぬ其の従者共（気根）とは、地球を担うアトラスの様に、怪鳥の翼を拡げたるが如き大枝の群を支え、一方、枝々の嶺の中には、羊歯・蘭類がそれぞれ又一つの森のように叢がり茂っている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "些くとも鼻の表現の研究上、かのスフィンクスと相対して、最も奇抜な、そして興味津々たるコントラストを見せている事を否定する訳に参りませぬ。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その日の夜にはふたりしてブリュッセルまで行き、そこで二日過ごしてから、三日目にははるばるストラスブールへ移動した。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストラスブールの食堂の席に着きながら、この件を半時間語り合ったが、その晩には二人旅を再開、順調に道行きを進めてジュネーヴへと至った。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば或日の晝すぎ、トラステヱエル（テヱエル河の右岸なる羅馬の市區）なる友だちを訪はむ、とのたまひしは、我がためには祭に往くごとくなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍らしき樂土鳥の羽、組緒多くつけたる白き「アトラス」の衣はこれに一層の美しさを添へたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "矧や「カピトリウム」に登り、「トラステヱエル」（河東の地なり、テヱエル河の東岸に當れる羅馬の一部を謂ふ）に渡らんこと思ひも掛けざりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "硝子の器を載せた春慶塗の卓や、白いシイツを掩うた診察用の寝台が、この柱と異様なコントラストをなしていた。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其ノ外國同業者トノ競爭能力等ハ「トラスト」「カルテル」ヨリ推論シ得ベク、以下ノ各省皆同ジ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "工業ノ「トラスト」的「カルテル」的組織ハ資本乏シク列強ヨリ後レタル日本ニハ特ニ急務ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
