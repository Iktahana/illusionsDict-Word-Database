    "definitions": [
      {
        "index": 1,
        "gloss": "kanji \"strike\" radical at right (radical 66)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
