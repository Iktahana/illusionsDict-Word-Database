    "definitions": [
      {
        "index": 1,
        "gloss": "being produced in a particular region",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
