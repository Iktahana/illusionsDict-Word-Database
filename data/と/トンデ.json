        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もうそろそろ空にも昼の明りが消えて了はうとしてゐて、電燈をめがけて飛んでくる虫も増していつた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで勃然として床を蹴り、一直線に私の所へ飛んで來たのだといふ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかに腹立しく、私が飛んでもない間ちがひをしたことだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は移り、風雪は空を飛んでる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは折々フットボールが飛んで来て窓硝子が割れるので、校長の考案したことであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は此の頃、道を歩いてゐて秋津が自分の近くに飛んで来ると、それが親戚の人か何かのやうに思はれるのだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "その山麓の小家の周囲を、夏の羽蟻が飛んでるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空では高く、閑居鳥が飛んでるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には白い雲が浮び、鳥は高く飛んでるけれども、時間は流れて人を待たず、自分は次第に老いるばかりになってしまったという咏嘆である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『やつちまへ』『疊ん仕舞へ』彌次馬の聲援、畢竟は我が味方と、芳は勇み立つて、無手と對手の襟髮を掴むや、馬手の下駄は宙を飛んで、その頬桁を見舞はんとす。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙に生温かい、晴れるかと思うと大きな低い積雲が海の上から飛んで来てばらばらと潮っぽい驟雨を降らせる天候であった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電柱の雀がからたち寺へ飛んで行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "烏はいつの間にか飛んで行っていた。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江上油のごとく白鳥飛んでいよいよ青し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに鴎が飛んでいたと書けば都合よけれども飛魚一つ飛ばねば致し方もなし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢魂いつしか飛んで赴く処は鷹城のほとりなりけん、なつかしき人々の顔まざ／＼と見ては驚く舷側の潮の音。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を拍ちて床をのべさせ横になれば新しき浴衣の肌さわりも快く、隣室の話声遠きように聞えし後は魂いずこへか飛んで藻ぬけの殻となり電燈消しに来し事もいつか知らず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "円かなる夢百里の外に飛んで眼覚むれば有明の絹燈｜蚊帳の外に朧に、時計を見れば早や五時なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時鼠骨氏が色々面白い話をした中に、ある新聞記者が失敗の挙句吾妻橋から投身しようと思って、欄干から飛んだら、後向きに飛んで橋の上に落ちたという挿話があった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも運命の環は急加速度で縮まって行って、いよいよ矢頃はよしという瞬間に、要太の突き出した叉手網はほとんど水平に空を切って飛んで行く。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜めに来る光がこの饅頭笠をかぶった車夫の影法師を乾き切った地面の白い上へうつして、それが左右へゆれながら飛んで行くのが訳もなく子供心に面白かったと見える。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道に沿うた松並木の影の中をこの椎茸がニョキ／＼と飛んで行くのがドンナに可笑しかったろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの樹の実を尋ねて飛んで来る木椋鳥の大群も愉快な見物であった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには蒲や菱が叢生し、そうしてわれわれが「蝶々｜蜻蛉」と名付けていた珍しい蜻蛉が沢山に飛んでいた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな競爭して飛んで行きます。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝙蝠が、はたはたと木の虚から飛んで出た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雀が、いまお婆さんの退場後に、はたはたと軒下から飛んで來て、お爺さんの頬杖ついてゐる机の端にちよんと停る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　はたはたとお鈴さんは奧の間に飛んで行き、さうして、間もなく、稻の穗を口にくはへて歸つて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡り鳥、まあ、例へば鶴などが飛んで行くとする。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
