[
  {
    "uuid": "3b468c51-5bfd-5814-b1e0-86ddba270c1d",
    "entry": "都県",
    "reading": {
      "primary": "とけん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
