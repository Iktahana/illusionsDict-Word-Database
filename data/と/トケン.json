      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "prefectures (of Japan, excl. Kyoto, Osaka and Hokkaido)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大蛟　安城平都県の尹氏の宅は郡の東十里の日黄村にあって、そこに小作人も住んでいた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、なによりもそのへんのところをよく観ておかねばならぬと気づき、いろいろ研究の結果、先づ、江都県楊州の警備隊本部を訪れた。",
              "citation": {
                "source": "私の従軍報告",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争の道義化について　江都県城楊州の周囲は内城と外城とがあつて、外城の方は延長十支里に亙り、その昔倭寇に備へるために築かれたものだといふことである。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それに、君には、新野の地にもまだ日浅く、周囲には荊州の武弁、都県の俗吏しか近づいていませんから、ご存じないのは当然です」「その人と、ご辺との縁故は」「年来の道友です」「経綸済世の才、ご辺みずから、その人と比しては？",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時弁公はいきなり文公に、「親父は車夫の野郎とけんかをして殺されたのだ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが第三楽章の十二句になると、どうもだいぶ気が軽くなり行儀がくずれてはれた足を縁へ投げ出したり物ごとにだだくさになったり隣家とけんかをしたり雪舟の自慢をしたりあばたの小僧をいやがらせたり、どうもとかくスケルツォの気分が漂って来る場合が多いようである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平の机も箪笥とけんどんの間へ押しこまれ、本箱も縁側で着物の入っている幾つかの茶箱や、行李のなかに押しこまれ、鼓や太鼓がその上に置かれたりした。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いけない、これは――支配人とけんかだ。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は、ゲルダのこしのまわりに手をかけて、「あたい、おまえとけんかしないうちは、あんなやつらに、おまえをころさせやしないことよ。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいはぎのむすめは、しげしげとゲルダを見て、かるくうなずきながら、「あたいは、おまえとけんかしたって、あのやつらに、おまえをころさせやしないよ。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳輔はほとんど他人とけんかするごとき語気と態度で反抗した。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐおじさんとけんかして出てしまいますわ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――先生はふだんから、貧乏な可哀相な人は助けてやらなければならないし、人とけんかしてはいけないと云っていましたね。",
              "citation": {
                "source": "級長の願い",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人同士は、けろりとけんかも忘れ、睦じく抱っこ寝んねしている間に、傍のおみささんは娘の手を引っぱって逃げ歩き、とばちりを受けて私まで（たれにもいいこそしないが）一晩中まんじりともしなかったとは！",
              "citation": {
                "source": "田舎風なヒューモレスク",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつの理想主義、革命的社会思想、階級意識、戦争と力への反撥――そういったものを取材とする絵が芸術であっていいかどうかは第二の問題として――かれの絵は最も端的にそれを摘出し、議論し、口角泡をとばして、画室へ這入るとけんけんがくがくの声が四方の壁に沸き立っているような気がする。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "とさげすまれまい努力　一、高貴な人というものに対する原始的な崇敬　一、熱情的愛ウタリー　　　　　○八重の経歴一、八重の父　七つ位で死ぬ一、母の姉のところに養女にやられたが、和人の夫とけんかをして出て来る。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身は二十歳すぎから櫛巻のぐるぐるまきにして今まで来ているのを想うと、自分の髪はたなへあげて置いて、ひとの髷となるとけんめいになって研究する――考えてみるとおかしな話である。",
              "citation": {
                "source": "髷",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年はごんぺいじいは去年の冬さむさまけから病気になって死に、あのにくいにわとりは犬とけんかしてくいころされたとの事、三年の年月は〔以下欠〕",
              "citation": {
                "source": "三年前",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売を粗末にする者は、家に置いとけんさかいな、ちやツちやと出ていとくれ。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "商賣を粗末にする者は、家に置いとけんさかいな、ちやツちやと出ていとくれ。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "時ちゃんは文学書生とけんかをしていた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お江戸離れて南へ三十里潮の花咲く椿島野増村から戀人の手紙ゆかぢやなるまい一とまづは歌ひ終ると、「聲が惡るいからね」とけんそんしてゐましたが、澄んだ素朴な聲でした。",
              "citation": {
                "source": "大島行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのとけんかして、凧にひっかかったのかもしれないよ。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはね、目は見えなくても、君たちの声はちゃんとおぼえていたし、それにＸ号が、君たちがこの研究所に来ていることを話してあったから、君たちがこの部屋へはいって来たときには、ちゃんとけんとうがついたんだよ」　サルは怒ったようだった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食後寝床の中でうつらうつらとしてゐると急に花の香が匂つて来るので、眼をあけて見るとけんどんの上に秋花が持つて来てくれてあつた。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兼　それで猟を始めたり、鶏をつぶしたり、百姓とけんかしたりするのでございますよ。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」生の彼岸のことを問うた訪問者に彼は「一度には一つの世界」と答え、「神と和解したか」との問に対しては「彼とけんかしたことはない」と答えた。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "訳者の言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらつしやるから」「なさるから」に当るのが、「すけん」なので、まづすとけんは必しも密著してはゐない。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がｍとけんかして、又折れ合った。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "銭はつかう、悴とけんかまでする、そのあげくにゃ鬼婆のごと言わるる、得のいかン※御じゃってな、山木さん――。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
