[
  {
    "uuid": "7e1f9f4f-2c62-5291-a32a-5476a977a9b1",
    "entry": "吐瀉",
    "reading": {
      "primary": "としゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "vomiting and diarrhea (diarrhoea)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は、吐瀉しながら、転げまわりながら、顔中を汚物で隈取りながら叫んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐瀉の是れだけあると云ふことが、せめてもの望みだつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞんぶんに吐瀉したので、身心清浄になつたやうに感じる、そして飲食物に対して恬淡になつたやうにも感じる。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の吐瀉以来、私の胃は小さくなつたやうだ、食気が薄くなつた、とにかくそれだけ私の身心は安らかになつたのである。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔母はなにかの食あたりであったらしく、一時はひどく吐瀉して苦しんだ。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "急激の吐瀉でもちろん疲労しているが、もう心配することはないと医者はいった。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所というのは「トイレ」で通じるのかなと朦朧とし始めた頭をふりふりたずねあてて便座に腰を下ろすや、腹はナイヤガラの滝のように下るわ、イエローストーンの間欠泉のように吐瀉物は口から吹きだすわ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども途中幾度か激しい吐瀉に見舞われた豚は、自動車のある処まで来るととうとう動かなくなってしまいました。",
              "citation": {
                "source": "とむらい機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "季参の持って来た紅茶の中に毒でも這入っていたと見えてそれを飲んだ晩に吐瀉したなどと左様云ったような話であった。",
              "citation": {
                "source": "温室の恋",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは夜半から吐瀉をはじめて、明くる日の午後に死んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、胸先きに込みあげて来るものをおさへながら、やつと舟舷にたどり着くと喉を鳴して凄まじい吐瀉をした。",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "綿は彼らの周囲で、今は始末のつかぬ吐瀉物のように湿りながら、いたる所に塊っていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佐々木はあの夜家に帰るなり、はげしい吐瀉を始めて三時間たたぬうちに死にましたわ。",
              "citation": {
                "source": "死の接吻",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日尾道を出発したところ、広島への途中汽車中にて妹ともはげしい腹痛が起こり広島に着いた時は吐瀉はげしくやむをえず広島の親戚に三日間苦しい、いらだたしい日を送りました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "喰わず飲まず吐瀉や呻きの中で三日を過ぎ、真暗な夜中に荷物のように投げ出されたのが、又北九州沿岸の方角も名も知らない山際だったそうである。",
              "citation": {
                "source": "玄海灘密航",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐瀉を催して、自分たちは味気ない表情を見交した。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、その明け方に、蚊帳の中で、いきなり吐瀉を始めたさうである。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、先生の吐瀉したのは、豆と水とに祟られたので、コレラではなかつたが、この事があつたために、先生は人間の父たるもののエゴイズムを知つたと話してゐた。",
              "citation": {
                "source": "続野人生計事",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは日本を除いた他の国のどこにも網の目のように張りめぐっていて、吐瀉、腹痛の起るのを思うと、つまりは、この国境の間の五里の空間も、それに似た未来の渦の巻き立つ場所かとも思われた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレベーターは吐瀉を続けた。",
              "citation": {
                "source": "七階の運動",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "天神髯の斎藤さんが、恐ろしく苦悶し初めてスバラシク吐瀉し続けて人事不省に陥った。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議だ不思議だといううちに県の衛生試験所へまわった斎藤さんの吐瀉物について大変な報告がＢ町の警察署に来た。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吐酒石酸というのは毒薬自殺や何かの時に重宝な薬で、この薬をホンノちょっぴり人間に服ませると、忽ち胃袋のドン底まで吐瀉して終うから毒がまわらないうちに助かるんだ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛馬が毒草を喰った時なんかにも同じ理屈で使用される薬なんだが、その代りに分量を誤ると、実に急劇、猛烈な吐瀉を起すために体内の水分がグングン欠乏する。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その――てっきり海獣を思わせるような屍体は、同じく宮廷楽師の衣裳を附けていて、胸のあたりがわずかに吐瀉物で汚されている。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その後四五日すると、甚太夫は突然真夜中から、烈しい吐瀉を催し出した。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし吐瀉は止まなかった。",
              "citation": {
                "source": "或敵打の話",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、はげしい吐瀉が始まった。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「吐瀉ぽいといっていたから……。",
              "citation": {
                "source": "櫛",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "家内は、落ちついてじっとしゃがみ、悟ったような顔して眼をつぶっている。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
