    "definitions": [
      {
        "index": 1,
        "gloss": "to sharpen (e.g. pencil)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
