        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その間の渓流の中に、孤巌頭を出し、その巌尖に一蛇とぐろを巻く。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は比古君の好意で、琴人君に案内されて、カフヱーヴヰナスにとぐろを巻く、酔つぱらつて比古居には帰れなくなつたので、裏町の宿屋に泊つた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに、酒の酔いと夢と哲理とがとぐろを巻く。",
              "citation": {
                "source": "蛸の如きもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "とぐろを巻くのは攻撃態勢というものらしい。",
              "citation": {
                "source": "山の秋",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの無気味さ、畳の上へほうると、ゾロリととぐろを巻く凧糸の輪がねた一とかたまりは、糸目から外して、二度人の命を狙った兇器だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "凧の糸目",
                "note": "青空文庫"
              }
            },
            {
              "text": "曇天を背景に、とぐろを巻く南向きの小路の輪郭をなす茶色の屋根の列から頭抜けて立っていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
