    "definitions": [
      {
        "index": 1,
        "gloss": "to take back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつもの不機嫌そうな表情を、円滑に、取り戻すことができたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸国を旅してみてもいったん売った電車切符をまた取り戻すような国は稀であった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれも一日経ったらすぐ馴れてしまって日本人の吸う敷島の味を完全に取り戻すことが出来た。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、人間は昔の完全な身体の機能を取り戻すために、時々獣類のように動くことを稽古しなさい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月の起きて居る姿を見て躊躇し引返しかけたが、また勇気を取り戻すに努める様子。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はや僕は己惚れを取り戻すのである。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は自分の変化をかの女に気取られたのを知って、ちょっとしまったという様子を見せ、指を旧式な「髷なし」という洋髪の鬢と髱の間へ突込んで、ごしごし掻きながら、しとやかな夫人を取り戻す心の沈静に努める様子だったが、額の小鬢には疳の筋がぴくりぴくり動いた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うということは失った真面目さを取り戻すことよ。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもの不機嫌さうな表情を、圓滑に、取り戻すことができたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今日の童話は、物語性を取り戻す事に努力を払わねばならない。",
              "citation": {
                "source": "童話における物語性の喪失",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんや阿呆らしいと思ったが、しかし毛布を取り戻す勇気は出なかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んや阿呆らしいと思ったが、しかし毛布を取り戻す勇気は出なかった。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴三「しっかり働いて、今日休んだ分を取り戻すんだぞ、判ったか」新吉（飯を頬張りながら）「うん、判った」汽車が停る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達「先生、さよなら……」清子、初枝「はい、さよなら」瞬間、二人の顔は明るさを取り戻す。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを夫の叫び声で知った彼女は、夫と協力して赤ん坊を取り戻すべく逃げ出してきたのだった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、私たちの大部分は、私たちの自由を取り戻すことの出来るのを喜んではいたが、しかし人殺ろしをすることを望んではいなかった。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "弾が額を割っており、意識を取り戻すにはしばらく時間がかかるそうだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の元へ駆けつけましたが、意識を取り戻すことなく亡くなりました。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンタは何か強い薬品のために昏睡しているのが明らかで、まったく気を取り戻す気配もないためそのまま寝かせておいて、厩務員二名と女性二名とで、行方知れずの人と馬とを探しに飛び出した。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こちらの警部殿も考えうる限りの手を尽くしておいでですが、気の毒なストレーカの仇討ちのため、かつは馬を取り戻すため、あらゆる石を起こしてでもと思いました次第で。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "数分のあいだ立ち尽くしたあと、私は自分を取り戻す。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "その感傷性は老い先の短かい人間が、感情の余燼としてやつとの思ひで取り戻すことができた、感情の小さな興奮なのである。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "王の智力もて夫人を取り戻すは成らぬ事にあらずというに答えて、ついには取り戻し得べきも、その間にわれも夫人も花の色の盛りを過ぎては面白い事も出来ぬでないかと羅摩の述懐もっとも千万に存ずる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "拐引で訴えれば、一文もいらずに取り戻すことが出来るかも知れないが、そんなことに暇取っているうちに、お種さんのからだに何かの間違いがあっては取り返しが付かない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私のセンチメンタルなしぐさを紛らすやうに道子は無造作に私の手から石を取り戻すと、それでお手玉を取りました。",
              "citation": {
                "source": "砂浜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」実はもう角力を取るのは厭だつたが、一寸白けた其場の空気を取り戻す為に、虚勢を張つて彼は云ひ放つた。",
              "citation": {
                "source": "眠い一日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあの世へ行って、わたしが遠い昔に失ってしまった純潔さを取り戻すか。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「絵のやうだね、――まづ一番、禅ニ安ンジテ毒竜ヲ制スの概で、狼退治を決行しようか、そこで先づ評判を取り戻すか。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、浜のゆうれいを教会の墓地に連れていって、お墓をほってやり、そうすることによって、魂の全部をとりもどすということでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、ランプの家来だけが、御殿をとりもどす力を持っているのでございます。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
