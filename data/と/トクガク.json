[
  {
    "uuid": "f39cf009-f287-5095-b764-f40f29e061d4",
    "entry": "篤学",
    "reading": {
      "primary": "とくがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "love of learning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "故人北原多作氏のごとき少数な篤学の官吏の終生の努力と熱心によってようやく水産に聯関した海洋調査がやや系統的に行われるようになりはしたが、自分の知る限りでは時々の政府の科学的理解のない官僚の気まぐれなその日その日の御都合による朝令暮改の嵐にこの調査の系統が吹き乱される憂いが多分にあった。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学士ではなかったがしかし非常に篤学な人で、その専門の方ではとにかく日本有数の権威者だという評判であった。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、大坂に下河辺長流、釈契沖のやうな古典古語に通じた篤学の人々があつて、はやくも光圀の物色するところとなつた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "性質は豪放であったが、もともとぼんやりであったから、篤学の士であったけれども人に名を知られていなかった。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、つい最近も、「この国の読書人、印刷人が、なぜ執拗に明朝体の漢字（中略）にこだわるのか、つねずね疑問に思っていた」　と、篤学の（私などとはちがう）活字研究家、片塩二朗氏が「文字の風景」（『印刷雑誌』一九九五年五月号）という文章で書いていた。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曽子の日頃の篤学力行は、既に物事にも道理にも十分に充実して、しかも満足することなく、先王の教・孔子の道の奥義を究めようとしている。",
              "citation": {
                "source": "一貫章義（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さばかり彼の愛せらるるを見て、彼等は貫一をば娘の婿にせむとすならんと想へる者もありしかど、当時彼等は構へてさる心ありしにはあらざりけるも、彼の篤学なるを見るに及びて、漸くその心は出で来て、彼の高等中学校に入りし時、彼等の了簡は始めて定りぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貫一は篤学のみならず、性質も直に、行も正かりければ、この人物を以つて学士の冠を戴かんには、誠に獲易からざる婿なるべし、と夫婦は私に喜びたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言った末吉氏は純粋の琉球人、篤学の士、予氏より未聞を聞く事多い。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、少年の筆らしくない該博の識見に驚嘆した読売の編輯局は必ずや世に聞ゆる知名の学者の覆面か、あるいは隠れたる篤学であろうと想像し、敬意を表しかたがた今後の寄書をも仰ぐべく特に社員を鴎外の仮寓に伺候せしめた。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その篤学の評判に対しても、かなり敬意を払っていた。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は良沢の人となりとその篤学に、心から尊敬を払っていた。",
              "citation": {
                "source": "蘭学事始",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に、つい最近も、「この国の読書人、印刷人が、なぜ執拗に明朝体の漢字（中略）にこだわるのか、つねずね疑問に思っていた」　と、篤学の（私などとはちがう）活字研究家、片塩二朗が「文字の風景」（『印刷雑誌』一九九五年五月号）という文章で書いていた。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "身方の親戚知友はもとより新夫人の両親骨肉｜及「鷹の宿」の隣家に住める医師、兼、弁護士の免状所有者にして、篤学の聞え高きランドルフ・タリスマン氏迄も招待して、盛大なる華燭の典を挙げ、附近住民をして羨望渇仰の眼を瞠らしめぬ。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術に趣味を持つ医学士だと予ねて聞いてゐたので、そしてその手紙の文中には何時も多くの憂鬱な古典語が用ひられたりしてゐるところから私は、篤学の蒼ざめた青年を空想してゐたのである。",
              "citation": {
                "source": "交遊秘話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三期は励精なる者、篤学なる者に非れば入る能はず。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究活動の参加者も少数ではあるが、みな篤学・熱心の徒であり、漸次充実した研究を進めようとしている。",
              "citation": {
                "source": "〔付〕唯物論研究に就て（戸坂潤手記）",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本文学史全巻を担当される近藤忠義が、篤学、正確な視点をもたれる学者であることは、読者にとっての幸運であるし、同時に今日の文学の諸相のみを扱う私にとって一つの幸な安心である。",
              "citation": {
                "source": "意味深き今日の日本文学の相貌を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳者頃日伊沢辞安の事蹟新聞紙に御連載相成候由伝承、辞安の篤学世に知られざりしに、御考証に依つて儒林に列するに至候段、闡幽の美挙と可申、感佩仕候事に御座候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "原文は「東洋文庫」の「アラビア」の部の｜Ｚの百三十八号文書にありますから、篤学のかたは読んで御覧なさい。",
              "citation": {
                "source": "結婚難並びに恋愛難",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来この斎藤先生と申しますのは、この大学の創立当初から勤続しておられたお方で、現在、この部屋に在ります標本の大部分を、独力で集められた程の、非常に篤学な方で御座いましたが、殊に非常な熱弁家で、余談ではありますが、こんな逸話が残っている位であります。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけではまだ十分な説明が出来ないであろうところの精神病関係、もしくは心霊に関する各種の怪奇、不可思議現象に就て、首をひねっている篤学の士が居るかも知れない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ口が旨いから、空疎な講義の内容も、十分｜胡麻化されるし、学者仲間には兎も角、世間に対しては、いかにも学殖のある篤学の士のように見せかける事は、易々たる事である。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、算哲の身辺事情中には、全然動機の所在不明にして、天寿の終りに近き篤学者が、いかにしてかかる愚挙を演じたるものや、その点すこぶる判断に苦しむところと云うべし――。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八二六年、ロンドン大学が創立され、初めて法理学の講座が設けられることになった時、篤学なるオースチンは、聘せられてその講座を担任することとなった。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "（モリエエルは例外である）もちろん文壇に篤学の士が多いから、中には Cent nouvelles Nouvelles du roi Louis しているような作品は見えない。",
              "citation": {
                "source": "仏蘭西文学と僕",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、篤学なる化学者だ。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、ギゼーの此附近で、金字塔に関する考古資料を、発掘蒐集するために、地中海を通って杳々と、英国から渡って来たのであって、篤学の博士はその途中でも、モーソラスの霊廟や、ローズ島の立像や、アレキサンドリアの燈台などで、多少の発掘はしたものの、その本当の目的はギゼーの金字塔にあるのであった。",
              "citation": {
                "source": "木乃伊の耳飾",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
