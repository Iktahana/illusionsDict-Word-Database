[
  {
    "uuid": "3c64e764-f1c3-5b6e-963a-f66b93d5e1af",
    "entry": "撮り直し",
    "reading": {
      "primary": "とりなおし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "retake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十勝のロケーションも一週間ばかりでとにかく済んで、また低温室へ戻って人工雪のカットを少し撮り直し、結局前後四十日ばかりかかって、どうにか予定の場面だけは撮ることが出来た。",
              "citation": {
                "source": "映画を作る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今までの実験の急所々々をこの水晶蛍石レンズで撮り直し、これでやっと三千枚の写真が生きることになった。",
              "citation": {
                "source": "写真と暮した三十年",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "砧村、青路の家の声の悪かったところの撮り直しから始まる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　校長はぎくっとしたが気をとりなおしてこう云った。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと気をとりなおして、そこらの人にクーボー博士の学校へ行くみちをたずねました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくのあいだ、すべての人々は恐怖のために麻痺したようになった、――が急ぎの場合でそうもしていられないので間もなくみんなは気をとりなおした。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "（与五郎は刀をとりなおして玉琴の胸を刺し、返す刀にてわが腹に突き立て、引きまわして倒る。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、カンカンに灼けついていたポストの鉄の肌にハッとなって気をとりなおした時には、もう老配達夫は秋森家の表門へ向って馳け出していた。",
              "citation": {
                "source": "石塀幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼はすぐに気をとりなおした。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけていいか」　気をとりなおして、高志は包みを受けとり、ていねいにリボンをほどき、テープをはがした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも『もう済んで了ったことだ、これからは気をつけなさい』と父は気をとりなおして云ってくれました。",
              "citation": {
                "source": "虫干し",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官達は直ぐに気をとりなおして、再び調査にとりかかった。",
              "citation": {
                "source": "銀座幽霊",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く鋪道の端れの一箇処で羽毛飾が揺れると見ているうちに、再び、気をとりなおしたように、痛々しく帽子の大きな縁をかしげて群集の間を新たな力で溯り始めるのだ。",
              "citation": {
                "source": "小景",
                "author": "――ふるき市街の回想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、気をとりなおし、ギーウに新な酒を勧めた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みや子は、うっかり黙り込んだ自分を見出し、元気をとりなおして新たに話の緒を見出した。",
              "citation": {
                "source": "伊太利亜の古陶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはそれでも気をとりなおした。",
              "citation": {
                "source": "鎮魂歌",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに木沢氏はすぐに気をとりなおして駿三の胸の所をあけて耳をつけていたが、「駄目です。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また気をとりなおして童話の続きにかかる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は、もう一度、気をとりなおして一緒にならないかと云つたけれど、わたしは厭だと云つた。",
              "citation": {
                "source": "淪落",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東助とヒトミは、ようやく気をとりなおして、左右にはなれた。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしすぐ気をとりなおして、力いっぱい博士とたたかおうと思った。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "カモシカ中尉は、塹壕の斜面に、伏せをしたまま化石のようになっていたが、やっと気をとりなおし、やはり傍に伏せをしているモグラ一等下士を、防毒衣のうえから叩いて、（おい、こっちへ寄ってこい）　と、合図をした。",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからようやく気をとりなおして、じっと向こうを見やりました。",
              "citation": {
                "source": "夢の卵",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が気をとりなおして、「まあ、機嫌をなおして、私のいうことも聞いてもらわなくっては困るね。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともすれば沈み勝な心をとりなおして、我れと我身を奮ましながら、恐ろしい負債を是非とも消却しなければならぬと考えた。",
              "citation": {
                "source": "頸飾り",
                "author": "モウパンサン",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれもピストルをとりなおして怪物群をぱんぱんとうった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅は手に持っていた洋杖をとりなおして、そこについていた釦を押すと、把手のところからサッと一｜道の光が流れだした。",
              "citation": {
                "source": "地球盗難",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャンウーは残念そうに、黄金メダルの半ペラを見つめていたが、また思いなおしたように、鉛筆をとりなおして、翻訳をつづけていったが、そのとき、店のほうで人の足音がした。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐の失望は大きかったが、気をとりなおし、「レーダーで探してみられなかったですか」と聞いた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「待てッ」　三根夫は、このとき、やっとそのお面が、作りもののお面ではなく、生きている動物の顔であることに気がついたので、腹をたてて、長く伸ばした折り尺をとりなおして、ぷすりとお面ではない、その怪物の顔をついた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
