  {
    "uuid": "159eb1da-ea2f-5eb3-a77d-18db3f2ce738",
    "entry": "糖度",
    "reading": {
      "primary": "とうど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
