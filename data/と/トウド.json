    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sugar content (e.g. in degrees Brix)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "のみならず二人の男の子も健康に故障があって旅行はあまり望ましくなかったので、とうとうどこへも行かない事にきめた。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると楢夫がしばらく口をゆがめて変な顔をしてゐましたがたうとうどうしたわけかしくしく泣きはじめました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面くらいやアがってつかまる処をな、金満の奴さん恩儀を思って、無性に難有がってる処だから、きわどい処を押隠して、ようよう人目を忍ばしたが、大勢押込んでいるもんだから、秘しきれねえでとうどう奥の奥の奥ウの処の、女の部屋へ秘したのよ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その中にとうとうどこへか往ってしまった。",
              "citation": {
                "source": "唖の妖女",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "げんに私が、その大泥靴の夢を見ながら、誰も私に警報して呉れぬものだから、どうにも、なんだか気にかかりながら、その夢の真意を解くことが出来ず愚図愚図まごついているうちに、とうとうどろぼうに見舞われてしまったではないか。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "面くらいやアがつてつかまる処をな、金満の奴さん恩儀を思つて、無性に難有がつてる処だから、きわどい処を押隠して、やうやう人目を忍ばしたが、大勢押込むでゐるもんだから、秘しきれねえでとうどう奥の奥の奥ウの処の、女の部屋へ秘したのよ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いやあ、たうとうどうも、相濟みやせんな』　彼はひどく調子づいて來た。",
              "citation": {
                "source": "醉ひたる商人",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちへ行っては石に引っかかり、こっちへよろけては樹にぶっつかり、ヒョロヒョロして行くうちに、とうとうどこだかわからぬ処でバッタリ行きたおれてしまいました。",
              "citation": {
                "source": "虫の生命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の姿を見かけたものは一人もなかったので、この衣裳のお手本の正体ばかりは、とうとうどこにあるのかわからず仕舞いになってしまいました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "野には明るい日が照り、秋草が咲き、里川が静かに流れ、角のうどん屋では、かみさんがせっせとうどんを伸していた。",
              "citation": {
                "source": "『田舎教師』について",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "怺えに、怺えに、怺えて見たが、とうどう怺え切れなくなッて、「して見ると、同じように苦しんでいるかしらん」、はッと云ッても追付かず、こう思うと、急におそろしく気の毒になッて来て、文三は狼狽てて後悔をしてしまッた。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食は酒一杯とうどん一杯、むろん千人風呂には入つた、これが目的の大半だから、――温泉はほんたうによい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "□炬燵と濁酒とうどんとカレーライス！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮れてから農学校の宿直室へ、酒とうどんの御馳走になる、樹明君はあまり飲まない、私ばかり頂戴する、酒三杯、うどん三杯、大きな胃の腑ではある！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "買物がてら街を散歩したのは近来にない失敗だつた、一杯一杯また一杯、たうとうどん底に落ちこんでしまつた、私の苦悩は詮方ないが、Ｎの主人には申訳がない、あゝ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――――――――――――――――――――――――　とうとうどうにか書き上げたぞ。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その広場を囲んで、露店のうどん屋が鳥のように並んで、仲士達が立ったまま、つるつるとうどんを啜っていた。",
              "citation": {
                "source": "風琴と魚の町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうですねえ、お蕎麥か、親子丼ぐらゐのとこでしたら‥‥」「ぢやア、親子丼とうどんかけを一つづつ取つて下さいませんか」　女中が階下へおりてゆくと、ふじ子は暑いので帶をといた。",
              "citation": {
                "source": "濡れた葦",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中を脱けつ潜りつ虎蔵は、寒い寒い北海道の山の中を馳けまわる事一箇月あまり……とうとうどこがどうやら解からなくなったまま、人を殺しては飯を喰い、食料品を奪っては兇器を振廻わして来た。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本を売り、着物を入質し、女の物を売り、貸間へ落ちとうとうどん底へ来てしまつた。",
              "citation": {
                "source": "貧乏一期、二期、三期",
                "author": "わが落魄の記",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは天理教祖は、非常に偉い人であると思いますが、「とうどこの度胸のうち澄みきりましたが　ありがたい」ということがある。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、麺包とうどんはおまけみたいに、なってしまいます。",
              "citation": {
                "source": "うむどん",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "男と二人で欧羅巴にいることはたしかだが、所在をつかむことも相手をつきとめることも、とうとうどちらも成功しなかった。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇を箸に、蕎麦とうどんの挟み分け方も難かしければ、いろいろのたべ物のたべ分け方もまた大へんだった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼の妻はその騒ぎが我慢しきれなくなってとうとうどなった、「あんたのお蔭で目が覚めちまったわ。",
              "citation": {
                "source": "マリ・デル",
                "author": "MARI D'ELLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と袋をかぶつて踊つてゐる姿を認めて、ノコノコ近付いて来て見てゐる）あれえ、こん爺さんだよう、篠町からこつち車の後さぶら下つちや、賃金半額にしろと云ひ通してとうどう乗らんかつた人！",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は十四年以来の仲ですからね、あの人がここの先の黒田敏行という人に取り入って、とうどうセメント会社を乗取って、今じゃその敏行という人はすっかり落ちぶれているそうよ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや俺やな、あんた方を探しに、四、五日前に信州から出て来て、銀座へ行ったが誰もいねえし、そいから市川へ行ったり、保土ヶ谷へ行ったりしても、あんた居ねえしな、いくら探しても見つからねえもんで、とうどう、とにかく一度、信州に帰るべえと思ってね、そいでここに来て並んでたとこだ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（聞こえたか聞こえぬのか返事も、身じろぎもせぬ）※せめて恨みて玉章と、薄墨に書く雁の文字、女子の念も通し矢の、届いていまは張り弱く、いつか二人が仲の町に、しつぽりぬるる夜の雨……」仙太　（ひとり言のように）……とうどう、それじゃ、長五郎も抜刀隊にやられたか。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、話が養鶏の方にきまるのを心ひそかに望んでいたが、とうとうどちらともきまらないままにみんな帰っていってしまった。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
