        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頓首貴方のライネル　マリア　リルケ＊　「La Plume」（美術雜誌）は一九〇〇年にロダン號を出した。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命がけで、描いて文部省の展覧会で、平つくばって、可いか、洋服の膝を膨らまして膝行ってな、いい図じゃないぜ、審査所のお玄関で頓首再拝と仕った奴を、紙鉄砲で、ポンと撥ねられて、ぎゃふんとまいった。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕の諸将｜是に於て頓首して王の神算及ぶ可からずと賀す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王辞すること再三、諸王｜羣臣、頓首して固く請う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "衍｜頓首して謝し、尋で卒すと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首」　御用のため、江戸表へ急の旅立と偽って桝形門を抜け、石堂川を渡って、街道を東へ東へと急いだ平馬は、フト立止まって空を仰いだ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命がけで、描いて文部省の展覧会で、平つくばつて、可いか、洋服の膝を膨らまして膝行つてな、いゝ図ぢやないぜ、審査所のお玄関で頓首再拝と仕つた奴を、紙鉄砲で、ポンと撥ねられて、ぎやふんとまゐつた。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊主は身も世もあらぬ思いに腰全く抜け、どうぞ命をと叫びながら四つ這いで出るを見て夫婦も尻餅、平素畜生を灰色坊主と呼んだ故、灰衣托鉢僧団の祖師フランシス大士が立腹と早合点で、地にひれふし、大士と弟子たちの宥免を願い奉ると夫婦｜叩頭、坊主も頓首し続けて互いに赦しを乞う事十五分間とは前代未聞の椿事なり。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同拍手頓首し、一々御酒を頂戴して退く。",
              "citation": {
                "source": "箱根神社祈願の記",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁堀同心近藤右門の口は金鉄にござそうろうあいだ、おん秘密にすべきお喜久の方様のご条々は生々断じて口外いたすまじく、さればこれなる下人一匹、些少ながらご進物としてさし上げそうろうまま、一服盛りにでもご手料理くだされたくそうろう頓首再拝」　したため終わると、伝六、辰に命令一下。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "――支那大陸紀元八十万一年重陽の佳日、中国軍政府最高主席委員長チャンスカヤ・カイモヴィッチ・シャノフ恐惶謹言頓首々々恭々しく曰す。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣誠惶誠恐稽首頓首。",
              "citation": {
                "source": "日本文化の獨立",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "草々頓首」（四月二十八日）（『映画春秋』創刊号・昭和二十一年八月）",
              "citation": {
                "source": "戦争責任者の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍功を記して天下に表彰する従軍記者が将校下士の前に頓首して食を乞ひ茶を乞ひただその怒気に触れんことを恐るるが如き事実の明治の今日に存せんとは誰も予想外なりしなるべし。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十四年十二月草莽ノ微臣田中正造誠恐誠惶頓首頓首　※",
              "citation": {
                "source": "直訴状",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何かまだ申上度儀御座候やうながら、あまり長事故、まづ是にて擱筆、奉待後鴻候頓首。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首々八日花押坂本龍馬村田巳三郎様直陰足下",
              "citation": {
                "source": "手紙",
                "author": "文久三年七月八日か　村田巳三郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れ近日、先は早々頓首。",
              "citation": {
                "source": "手紙",
                "author": "慶応元年十月三日　池内蔵太あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿四日朝頓首望月清平様才谷拝机下",
              "citation": {
                "source": "手紙",
                "author": "慶応三年六月二十四日　望月清平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "草々、奉対早々頓首。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月十六日　陸奥宗光あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "不一　宜敷　頓首／＼／＼　十八日龍馬望月清平様龍机下",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月十八日　望月清平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のよふ御用心、先は早※頓首。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年十月二十二日　陸奥宗光あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "推定、慶応三年三月）坂本龍馬-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）何：入力者注　主に外字の説明や、傍点の位置の指定（例）四日草々頓首。",
              "citation": {
                "source": "続　手紙",
                "author": "伊藤助太夫あて（年月未詳、四日。推定、慶応三年三月）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十九年七月二十六日尾崎秀実頓首再拝　竹内老先生　玉案下追白、一番暑熱の必要なこの頃、この涼しさはお米のことが心配になります。",
              "citation": {
                "source": "遺書",
                "author": "尾崎秀実",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭三も最早争うまいと思つたが、「だってお父様、こんな拝啓とか頓首とかお定り文句ばかりですもの、いくら長々と書いてあっても何にも意味のないことばかりですから、そんなことを一々説明してもお父様には分らんと思ってあゝ言ったのですよ。",
              "citation": {
                "source": "恭三の父",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ月日がたってゆくのには閉口｜頓首。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然から湧いて来る体験、そンなものにほとほと閉口｜頓首、男といっしょにいるのも厭、夜の酒場勤めも長続きするものではないとなれば、結局は女中にでもなるより仕方がないけれど、これも私の柄にはあわない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓首　敬白　　　大正七年十月十三日午後七時半　　　　　本郷菊坂ホテルにて認め終る。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
