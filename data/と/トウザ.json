[
  {
    "uuid": "037a5f6d-7adf-5bf3-ab5e-eabc3ef2086b",
    "entry": "当座",
    "reading": {
      "primary": "とうざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
