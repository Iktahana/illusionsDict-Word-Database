[
  {
    "uuid": "a1638bc0-6448-5bc6-b427-d29b7d9943bb",
    "entry": "年神",
    "reading": {
      "primary": "としがみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
