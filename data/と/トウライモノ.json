    "definitions": [
      {
        "index": 1,
        "gloss": "present (received from someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
