          "literary": [
            {
              "text": "トリミングによって、巧い画面を構成することはできない。",
              "citation": {
                "source": "ディズニーの人と作品",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでどうしても、トリミングをして、巧い構図にする必要がある。",
              "citation": {
                "source": "ディズニーの人と作品",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリミングして良くなるものは、すべてそうした。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その写真を僕は一眼レフのファインダー視野でいろんなふうにトリミングしながら、複写遊びをした。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
