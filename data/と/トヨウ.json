    "definitions": [
      {
        "index": 1,
        "gloss": "crossing the ocean",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
