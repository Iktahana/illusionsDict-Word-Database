          "literary": [
            {
              "text": "「さてこれからまた取っ組むかな。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも知らず、品川表の出があんまり大きすぎたんで、尾州様を相手に取っ組むからにゃ、いずれ大名だろうと早がてんしたのが、おれにも似合わねえ眼の狂いだったよ」「いかさまね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "黙々と機械と取っ組む一人の技師の姿を、君は、弱い生き方だと思うだろうか。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸か不幸か日本の飜訳家は創作家とちがって、より高次な文学と取っ組むという身の程しらずな任務を背負わされている。",
              "citation": {
                "source": "飜訳遅疑の説",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あなたみたいに、馬鹿正直に貧乏と取っ組むひともないもんだわ。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども取っ組むまでにはならなかった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん取っ組むとかれらは決してはなれず、木切れのうえで絶えまなくたたかい、組み打ち、ころげまわった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "マングースもいよいよ鰐と取っ組むときには、その身のまわりをちょうど鎧を着るように、よくこねかえした泥ですっかり塗り固める。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは直接取っ組むことを避ける。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはわたしの存在が真に必要とする事情のために、運命と取っ組むだけでたくさんである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちで取っ組む、こっちで掴みあう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "前もってこんな事になろうかと油断はしていませんでしたが、さて実際にこうなってみると、かれもあわてて取っ組むように、金吾のうしろへかぶりついて、「ばッ、ばかなまねをしなさんな。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
