[
  {
    "uuid": "e4c41864-0c93-54e4-8c1d-64cbf5e1da70",
    "entry": "統帥",
    "reading": {
      "primary": "とうすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
