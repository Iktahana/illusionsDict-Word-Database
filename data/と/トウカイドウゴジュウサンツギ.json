    "definitions": [
      {
        "index": 1,
        "gloss": "fifty-three stations on the Tōkaidō (Edo-Kyoto highway in Edo-period Japan)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
