          "literary": [
            {
              "text": "おれは君たちが成人の地球人だとばかり思って話をしていたが、まだ年端もいかない少年だとは思わなかった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "年端もいかない男の子の顔で、疑いなく敬虔な父親の息子と思しき者に属するが、本質的な部分で汚らしいものどもの縁者だった。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃から編み始め、年端もいかないうちに経糸や編み物に指がうずうずしました。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
