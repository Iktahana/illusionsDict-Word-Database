    "definitions": [
      {
        "index": 1,
        "gloss": "game of chance similar to rock, paper scissors, where the different hand gestures symbolize a fox, a hunter and a village head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酔ってる、酔ってる、全くもって、山高帽の、モウニングの、また麦稈の背広の、眼鏡の、ホワイトシャツの、藤八拳の、安来節の、わいわい騒ぎの眼と鼻と口との連中が、不意にその前途を塞がれたので、停ると、いきなり、「こりゃ、やい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮色と同時に藤八拳も始まった。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると櫛の歯のように並連ったそれらの桟橋へと二梃艪いそがしく輻湊する屋根船猪牙舟からは風の工合で、どうかすると手に取るように藤八拳を打つ声が聞えて来る。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊三味線手品声色藤八拳客の望むものは何でもやれる程結構なり。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それよか、善光寺の境内に元祖｜藤八拳指南所という看板が懸っていたには驚ろいたね、長さん」「這入って一つ遣って来やしないか」「だって束修が要るんだからね、君」　こんな談話を聞いていると、健三も何時か昔の我に帰ったような心持になった。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "金五郎が、三菱の甲板番と、藤八拳を打っていると、仲居がそっと袖を引いた。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「藤八拳をやらない？",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
