[
  {
    "uuid": "293e54cf-6800-5f03-9eb9-cc867740f5ba",
    "entry": "綴じる",
    "reading": {
      "primary": "とじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to bind",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "初めて小謡を習いに行くと、翁は半紙を一帖出して自分で紙縒をひねって綴じる。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸でかがり合せるのでなく、針金で綴じるのであるが、ぞんざいなやり方の場合は、釘を表裏から打ちつけて固定する。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうするのかと聞いたら、田舎の親に見せるのだといったそうですが、また器用な人で、表紙を附けて綴じるのなどが楽しみでもあるらしく、「そんなことはよしたらよかろう」と、何度いってもやめなかったとの事です。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時の書籍の一体裁として綴じるのに絹糸を以てする綴じ方の本がありましたがその「釈元恭」なる本もそういう体裁を持っていました。",
              "citation": {
                "source": "雑草一束",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中の広告文の印刷してない、裏側の方が真白な紙をえらんで、裏側を表に二つ折りにしたやつを三拾枚なり四拾枚なりまとめて綴じると、定数台帳が一冊分出来上るのである。",
              "citation": {
                "source": "おじさんの話",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "全部で五十ページほどあるが、筆者は綴じる作業をしていない。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の諸門をとじる合図の鐘は二時間も前に鳴ったので、コルソに集って売買に忙がしかった村の人々の声高な騒ぎも聞こえず、軒なみの店ももう仕舞って寝しずまったらしい。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、靴をぬいで腰掛の上に坐り、車窓にもたれて眼をとじると、いつの間にか、人相の悪い人のことなど忘れてしまって、頭は母のことで一ぱいになった。",
              "citation": {
                "source": "猫と村正",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四二年にその長い生涯をとじるまで、晶子は文学活動においても母としても実に多産であった。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は再び目をとじると譫言のように呟いた。",
              "citation": {
                "source": "光の中に",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「追憶」をかきあげてとじる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十一日（日曜）　今日午後出来上ってとじる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "母様と一緒に一通り見なおしてとじるともう五時過ぎて居たけれども、車で一寸坪内先生の所へ御覧いただきに行く。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いさゝか恐怖に目をとじる。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、要所要所に電話をかけて、入口をかたくとじるように注意をあたえた。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長ノルマンは、倉庫の入口を自らぴたりととじると、大きな錠をかけた。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず針のようなもので――と云うよりも、原稿などをとじる時に使用する千枚とじと称するものがあるが、あれに似たようなもの（煙千子と称するものだそうだが）その先へ小壺に這入っている阿片をつけて煙灯の火であぶり、又、小壺の中の阿片をつけて煙灯の火であぶる。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ケチンボーが食う物も食わず、お金をためて、貯金通帳をだきしめながら、栄養失調で生涯の幕をとじる。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし読書して眼をとじると、涙がにじみ、眼の焼けつくような痛みが分ってくる。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "フタをとじるのはピカピカの侵入をふせぐためと、ゴロゴロの音を小さくするための最上の策だ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十一　稲妻は見たり",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを観念の目をとじると云うのであろう。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて　目を　とじる　あなぐまトミー。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通は三、四時間水を流すと、畝の下まですっかり水が浸みるので、水門をとじることにしている。",
              "citation": {
                "source": "コロラド通信",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして目をとじるとどんなに起してももう眼はさまさなかった。",
              "citation": {
                "source": "わが愛する詩人の伝記（三）",
                "author": "――萩原朔太郎――",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日になってもう大丈夫と思うと、今度は「イースター・モンデー」だというのでまた店をとじる。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を青くしたキングは、あわててメモ帳をとじる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜太郎はソルベットを啜りながら、自分の最後の瞬間を味わうために、眼をとじる。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "竜太郎は、車窓の窓掛をひき、固い隔壁に凭れて眼をとじる。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　眼をとじると、鶴がかすかにうなずいた。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈逃走中の黒色ギャング、大阪第八銀行襲撃事件の主犯｜中村遼一（三六）は今夜十時半、新宿三丁目を徘徊中を発見され、正当防衛によって射殺された〉　久我は首をたれて、ちょっと眼をとじると、しずかにそこを離れ、葵と肩を並べて甲州街道へはいって行った。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
