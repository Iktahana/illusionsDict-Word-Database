    "definitions": [
      {
        "index": 1,
        "gloss": "to act as a go-between (for)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なんだか雨男になつたみたいですなと私は苦笑して、返すために持つて行つた傘をその儘また借りて帰つたが、その傘を再び返しに行くことはつまりはその町を訪れることになるわけで、傘が取り持つ縁だと私はひとり笑つた。",
              "citation": {
                "source": "木の都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし来た、むっちりした柔い白い腕へプスリ……、これがそもそも馴れ染めで、ヒロポンが取り持つ縁でさアね」「じゃ、あんたのヒロポンは承知の上じゃないか」「そうなんですよ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "火事が取り持つ縁とは、とんだ八百屋お七だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人のために村長が小作田を取り持つといふことはどうもなあ。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、彼は自己の欲望よりも、彼女を社長に取り持つというほうに重きを置いていた。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "松山さんは、殊の他、御機嫌で、「村の祭が、取り持つ緑で――」という、卑俗な歌を、口ずさんでいましたが、ぼくの寝姿をみるなり、「オリムピックが取り持つ縁で、嬉しい秋ちゃんとの仲になり」と歌いかえてから、沢村さんと顔見合せ、ゲラゲラ笑いだしました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし岩殿に霊があれば、俊寛一人を残したまま、二人の都返りを取り持つくらいは、何とも思わぬ禍津神じゃ。",
              "citation": {
                "source": "俊寛",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから却って、正吉の歿後五十日のこの宴席を取り持つのは、当り前だと言えないこともありませんでした。",
              "citation": {
                "source": "乾杯",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫は――やつと白玉を取り持つた。",
              "citation": {
                "source": "死者の書",
                "author": "――初稿版――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かみさんを力にして、酒の席を取り持つ客商売から時々息抜きにやって来るような芸妓もある。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒宴の席を取り持つのは洞院左膳と鳰鳥とで執事の筆頭甚五衛門は、あの夜以来ご勘気を蒙って自家に籠っているのであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とこう云ったら何んの事やら恐らくお前にも解るまいが、実は粂太郎の白痴を見込んでそういう約束をしたというものさ――年頃お前が恋しているあの美しい芳江姫をお前の女房に取り持つ故、吟味所の中へ忍び入り、設計図を盗んで持って来いと――で、その言葉を真に受けて、盗み出したというものさ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肌の流しが取り持つ縁で二人はいつしか割りない仲となり、久松留守の札で良人の不在を知らせては、幸七を忍ばせて、おみつは不義の快楽に耽っていたのだったが、昨夜も昨夜とて――。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "三つの足跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こうやって必然性と偶然性は取り持つ端もなく機械的に対峙して了う。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリが取り持つ縁で、家主と間借人の仲になるなんて、まことに面白く浪曼的なことで、小説のタネにでもなりそうな話ですな。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女等は芸者と呼ばれ、奥さんや令嬢達があらわれぬ宴会で、席を取り持つことをつとめとする。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにモード嬢をとても気に入ったから、はしなくも断言することに、もしあの二人の間を取り持つことが出来なくても、トリボース地区セントミンバー教会のわたくしの落ち度ではないとか。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もちろん私の方から名古屋へ行く折もなければ、先方がわざわざ訪ねて来るほどの用件もありませんから、そんな訪問がお互いの疎遠の仲を取り持つはずもなく、また二年三年は夢のように過ぎ去ってしまいました。",
              "citation": {
                "source": "棚田裁判長の怪死",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから此方、義兄は雪子の縁談には懲り懲りした形で、他人が持って来てくれる話には喜んで耳を傾けるけれども、自分が積極的に取り持つことや、先に立って良い悪いの意見を述べることは、出来れば避けたいと云う風に見えた。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし二人を取り持つについて、彼女と木村との間にあらかじめどれだけの連絡があったのかは、いまだに私によく分らない。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その両極を取り持つのは、卵とパイナップル・ジュースだ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでついまた、お厄介を重ねていたところでございます」「では、瘧が取り持つご縁だったか」「襟首の蝋燭焼きなんてものは、瘧に効くもンでございましょうかね」「ほ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし犠牲を捧げざれば、お通はもとより汝もあまり好きことはなかるべきなり、忘れてもとりもつべし。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に、シベリアで知り合った日本人の女房でロシア人、亭主より先にかえって来た、女の友達でフーシェ嬢という女の拳闘家あり、そんな男つまらぬと云って、同じ仲間のボクサーをとりもつ。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "分別男の誇張して両方をとりもつた話ぶりに連れて、からだ中の神経が強ばつて行くやうに思はれた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何かてえと友の恋をとりもつてえことですよ。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑煮、それでも色彩だけは仰山な口とりもつけて出した。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田利家といふ人は、秀吉が木下藤吉郎といふ足軽時代からの親友で、その頃から女房をとりもつたりとりもたれたりの間柄。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、すこしびっくりしたことには、ふとふりかえってみると、家来に、ひとりもついてくるものがないのです。",
              "citation": {
                "source": "眠る森のお姫さま",
                "author": "ペロー　Perrault",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人……大事にとりもつのはいいが……思い込むなんて、お前さんにも似合わない。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
