    "definitions": [
      {
        "index": 1,
        "gloss": "indicates word or phrase being defined",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
