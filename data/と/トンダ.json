        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "路次｜角の電柱に懸かつた医者の広告板なのだが、その姓をどう読んでいいか分らなかつた、そのまはりに蛾が沢山、それを照明してゐる電燈のまはりにも、とまつたり飛んだりしてゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時鼠骨氏が色々面白い話をした中に、ある新聞記者が失敗の挙句吾妻橋から投身しようと思って、欄干から飛んだら、後向きに飛んで橋の上に落ちたという挿話があった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭人二人の首は飛んだ。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車は驀然と闇を切り裂いて飛んだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "光を求めて、虫は飛んだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の事はない、脱線して斜になった機関車が、惰力で二十間も飛んだ、と云った風な歩きっ振りであった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年の暮にサント・ジュモンが始めて成効した時に飛んだ距離はわずかに二十五メートルであったが、この頃ファーマンやドラグランジュの飛行した距離は二万メートルに近く、すなわちわずか二年の間に飛行距離は八百倍になった訳である。",
              "citation": {
                "source": "「万年筆」欄より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んだ間違った方向へ応用されると、却て家庭を害するような結果がないとは云えぬ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子も可哀相だしお母さんも可哀相だし、飛んだことになってしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇敢にも、過去の一切を投げ出し、鷲のやうに空を飛んだ。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の近づくのを少しも知らないと見えて、「なんだってお前は鳥のまねなんぞした、え、なんだって石垣から飛んだの？",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "……だって先生がそう言ったよ、六さんは空を飛ぶつもりで天主台の上から飛んだのだって。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村も同じ心、後になり先になり、二人で歩いて居ると、時々は路傍に腰を下ろして鉛筆の寫生を試み、彼が起たずば我も起たず、我筆をやめずんば彼も止めないと云ふ風で、思はず時が經ち、驚ろいて二人とも、次の一｜里を駈足で飛んだこともあつた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "志村も同じ心、後になり先になり、二人で歩いていると、時々は路傍に腰を下ろして鉛筆の写生を試み、彼が起たずば我も起たず、我筆をやめずんば彼もやめないという風で、思わず時が経ち、驚ろいて二人とも、次の一里を駆足で飛んだこともあった。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "空を眺めているうちに時々流星が飛んだ。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それどころか、飛んだことになってしまった」　手足の泥を洗って、湿れた着物を着かえて、藤吉はさも疲れ果てたように長火鉢の前にぐったりと坐った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも飛んだことになった」「だからさ、その飛んだ事というのは……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々も褒めておやりなされ、この高山も褒めてやるぞと、飛んだ陣屋の盛綱を気取って、扇をあげて褒めそやすと、ほかの連中も偉い偉いと扇をひらいて煽ぎ立てる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "御留川の夜釣りも畢竟はそういう金の要り途があるからで、女房の手前は毎晩夜釣りに行くように見せかけて、三度に二度はその女のところへ飛んだ夜釣りに出かけていたんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "迂濶にそれを否認して、飛んだ揚げ足を取られるのも口惜しいと思ったからであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ間違った日にゃあ本人は勿論のこと、かかり合いの人間はみんな飛んだ目に逢わなけりゃあならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも飛んだことが出来ましたね」「ああ、神田の親分でしたか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お化け師匠と札付きになっているのに付け込んで、師匠をそっと絞め殺して、その蛇を死骸の頸へまき付けて置いて、娘の執念だとか祟りだとか、飛んだ林屋正蔵の怪談で巧く世間を誤魔化そうとしたんだろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売上で少し筋の悪い品を買って、飛んだ引き合いを食いそうになったから、ちっとの間どこかへ姿を隠すんだと云うから、一昨々日からこうして隠まって置いてやると、そりゃあ丸で嘘の皮で、市ヶ谷の女と心中しそこなったんだということを今初めて聞いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、突然に飛んだことを云ひ出して、兄の松村をおどろかした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白づくで飛んだことを引受けたといふ後悔の念も萌して來た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飛んだことをしたと後悔して、お道は早々に彼の草雙紙を返してしまつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それがねえ、」と狸は口をゆがめて、「パチパチのボウボウ山とかいふきざな名前の山に踏み込んだばつかりにねえ、いやもう、とんだ事になつてねえ、おどろきましたよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかり「地震による碑石の廻転について」といったような論文の材料にでもして故事付けの数式をこね廻しでもすると、あとでとんだ恥をかくところであった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も科学者の中には往々そういう大事な根本義を忘れて、自分の既得の知識だけでは決して不可能を証明することの出来ない事柄を自分の浅はかな独断から否定してしまって、あとでとんだ恥をかくという例もあえて稀有ではない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
