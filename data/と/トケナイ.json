        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何か思っているらしく、少しも打解けない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、科学はマテリアリズムに導く、という一般的｜謬見を排し、計算や実験では解けない“higher mysteries of being”のあることを暗示した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一つの古い謎は、千古にわたってだれも解けない。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしなぜ尾長鶏がそんなに悲惨なものとＢ教授に思われたか、これが今日までもどうしても解けない不思議ななぞとして自分の胸にしまい込まれている。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "探究の鶴嘴がよしやこの樋を碎いて、なかに流れてゐる水が光のなかへ曝されようと、この神祕は解けないのだ。",
              "citation": {
                "source": "闇への書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際感情を害することもあれば、用事がひどくこんがらかって、おしまひはいくら禿鷲コルドンさまのご裁判でも、解けないやうになるのだったと申します。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他人が殺して古井戸に投げ込んだのか、何かの仔細で四人が同時に身を投げて自殺したのか、それは誰にも容易に解けない謎であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きているものならきっと何処かで見付かります」「そうでしょうか」と、平助はまだ打ち解けないような眼をしていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」其は永遠に解けない宇宙の謎でもあるかのやう。",
              "citation": {
                "source": "虚弱",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしても解けない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "進は、ろくに受験勉強もしていなかったようですから、あなたにも解けないようなむずかしい問題は、やはり解けないでしょうよ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう考へても、わけが分らないんだ……」　暫くうつむいて考へ込んでゐたＳ中尉は、やがて思ひ出したやうに身を起すと、どうしても解けない謎を持ちあぐんだやうにかう云ひました。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の中に、何か、ある、解けそうで解けないものが引掛っているような風である。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船舶課の側へずり上ったところで、何だかお役所風で話が堅くなるし、中央は占領されているし、たまには例の白髪の、牧畜家の、活気縦横な和製タゴール氏と対い合になることもあるが、まだまだ十分には双方からうち解けない。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあまり怪談などというものに興味をもたない人間で、他人からそんな話を聴こうともせず、自分から好んで話そうともしないのですが、若いときにたった一度、こんな事件に出逢ったことがあって、その謎だけはまだ本当に解けないのです。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局その謎は解けないままで、経師屋の家では寝てしまった。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポリネシア人の仮面――全く之は白人には竟に解けない太平洋の謎だが――が斯くも完全に脱棄てられたのを、私は見たことがない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで船頭は舟を出そうとしたが纜の結び目が解けないので、とうとう僕といっしょにおることにした。",
              "citation": {
                "source": "竹青",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはまさしく、彼の心がまだ解けない証拠なのだ。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶としてはよくありません、こんな単純な問題を僕に解けないと言うなんて。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪事には強い同族的類似性があってね、一〇〇〇の事件の詳細を自家薬籠中のものにして、一〇〇一番目の事件が解けないとすれば、それこそ奇妙な話。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな下らないことが私を困らせるということを、どんなに利口な彼でもどうして最初にとにかく見つけたかということは、私になんとしても解けない疑問である。",
              "citation": {
                "source": "ウィリアム・ウィルスン",
                "author": "WILLIAM WILSON",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はすぐ、これは単純な種類のもの――だが、あの船乗りの頭には、解がなければ絶対に解けないと思われるような、そんな程度のもの――だと心を決めてしまったんだ」「で君はほんとうにそれを解いたんだね？",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の知恵を適切に働かしても解けないような謎を、人間の知恵が組み立てることができるかどうかということは、大いに疑わしいな。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "お千代も省作に向って、「省さんも御承知ではありましょうが、斎藤の一条から父はたいへんおとよさんを憎んで、いまだに充分お心が解けないもんですから、それはそれはおとよさんの苦労心配は一通りの事ではなかったのです。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一件と鶏とを結び付けて考えれば、なにかの謎が解けないでもなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "この理窟が考え出せない以上は、謎はやはりほんとうに解けないのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の旅絵師は奥州の春をむかえて、今年ももう二月になったが、ここらの雪はまだちっとも解けないで、うす暗い寒い日が毎日つづいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "旅絵師",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいよさんは正月の上旬に霜の解けないうちといつて未明に人力車で出て行つた。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なぞがうまくとけない場合は、たいへんでして、その人は、その場で首をくくられるか、切られるかしてしまうのです。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
