        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのうちに十二時の鐘が鳴りました。",
              "citation": {
                "source": "犬のいたずら",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "欄干にもたれて何かしんみりした話でもしている時、程近い時の鐘が重々しいうなりを伝え伝えて遠くに消えることもあった。",
              "citation": {
                "source": "イタリア人",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時のときの鐘よりは八時の鐘は、わたくしの耳に慣れて来た。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時の鐘は少し冴え返って聞えた。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "下町、山の手、昼夜の火沙汰で、時の鐘ほどジャンジャンと打つける、そこもかしこも、放火だ放火だ、と取り騒いで、夜廻りの拍子木が、枕に響く町々に、寝心のさて安からざりし年とかや。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い、湿地の彼岸花、午後の三時の鐘が鳴る。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の鐘など聞えないので、今が何どきであるか判らないが、もう真夜中であろうかと思われる頃に、僧はにわかに立上がって、叔父の寝息を窺うようにちょっと覗いて、やがて音のせぬように雨戸をそっと開けたらしい。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機のダイナミックコーンからはジャズや流行小唄が飛び出しておりからの鐘楼の時の鐘の声に和している。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴なきお夏さんは、撞木なき時の鐘。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてへ帰った波田は、西沢に、八時の鐘がなったら、ともの倉庫で、相談があるから、わからないように抜けて来て、くれるようにといった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子は何時の鐘だと考えてみる事もしないで、そこに現われた男の顔を見分けようとしたが、木村に似た容貌がおぼろに浮かんで来るだけで、どう見直して見てもはっきりした事はもどかしいほどわからなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いんにこもってボーンボーンと時の鐘が打ちだされたのを耳にするや、物静かに手をたたいて呼び招いたのは、さきほどからの青道心でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その時の鐘が鳴り終るや殆んど同時です。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは修禅寺で五時の鐘をつき出すのを合図のように、町の電燈が一度に明るくなるからである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "宵っ張りの私もここへ来てからは、九時の鐘を聴かないうちに寝ることにした。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "九つの時の鐘きこゆ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "時の鐘、薄く雨の音きこゆ。",
              "citation": {
                "source": "箕輪の心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは修禅寺で五時の鐘をつき出すのを合図のように、町の電灯が一度に明るくなるからである。",
              "citation": {
                "source": "春の修善寺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "三｜井寺では汽車の都合があるからといつて、態々頼んで十五分程早目に時の鐘を撞いて貰つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――時の鐘は誰が発明したものか知らん。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時の鳴るが合図であると、殆ど競馬の馬が出発の号砲を待つ様に、余は張り切って緑盤の許に行き、今にも一時の鐘が鳴るか、今にも一時の鐘が鳴るか、今にも緑盤が動くかと、見詰める目に忽ち留る一物は、緑盤の縁に介まって食出して居る絹の切れで有る、見紛う様もない日影色の地合は確かに秀子の着物である。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野の十時の鐘が聞える。",
              "citation": {
                "source": "夏の夜の音",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時の鐘午前零時より二時迄起き居る間に　鼠の音一度聞きしのみ。",
              "citation": {
                "source": "夏の夜の音",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く立って眺めているうちに、公園で十一時の鐘が鳴った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
