[
  {
    "uuid": "6878f9b9-37cb-5207-87f4-9caeb3a7c0b6",
    "entry": "刀子",
    "reading": {
      "primary": "とうす",
      "alternatives": [
        "とうし"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
