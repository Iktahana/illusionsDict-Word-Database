[
  {
    "uuid": "24aa9d27-c16c-5ac5-85c4-f5cc6065230b",
    "entry": "飛び乗る",
    "reading": {
      "primary": "とびのる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
