[
  {
    "uuid": "065adcc0-f22a-54ce-9284-d5f03a401dea",
    "entry": "取り柄",
    "reading": {
      "primary": "とりえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
