        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちっとも手むかいせずに、こっちの殴った手へべっとりくっついて来る」急に真剣そうに声をひそめて、「あいつ、菊の手を平気で握りしめたんだよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風にあたつても、雨にふられても、うちへうちへと、しつとりくぼめの抑へをひきしめて、一緒に泣いてでも呉れるやうな、なさけはちりめんの着物よりほか持つてゐません。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂の入口ちかくのテエブルにへ號室の大學生が、からになつたスウプの皿をまへに置き、ひとりくつたくげに坐つてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、まあおとりください。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか、まあおとりください」　青年は一つとってジョバンニたちの方をちょっと見ました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとりください」　ジョバンニは坊ちゃんといわれたので、すこししゃくにさわってだまっていましたが、カムパネルラは、「ありがとう」と言いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまたの子供のなかにひとりくらいの馬鹿がいたほうが、かえって生彩があってよいと思っていた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとその言葉がいまはじめて皮膚にべっとりくっついて思い出され、苦笑した。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はわざといやなものを自分に見せつけるいこぢな習癖がここに起るときに、その手首を眼の前でひねくつて、ひとりくつくつと笑つた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ひとりくらいは、この世に、そんな美しい人がいる筈だ、と私は、あの頃も、いまもなお信じて居ります。",
              "citation": {
                "source": "きりぎりす",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちつとも手むかひせずに、こつちの毆つた手へべつとりくつついて來る。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "睦子さんひとりくらいは立派に私が引受けて見せます。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "清庵も、たびたびの迷惑、つくづく呆れながらも、こいつ洒落た男で、「親戚にひとりくらい、そのような馬鹿がいるのも、浮世の味。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お政が心底をしんに解した人は、お政の父ひとりくらいであったろうけれど、それでもだれいうとなく、お政さんはかしこい女だという評判が立った。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもどこをどう歩いても、材木がほうり出してある、石が積んである、新しい家が往来から二、三間引っ込んでいる、古い蔵が半分とりくずされて心細く前の方に残っている。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっちこっちと江戸のうちを売り売り捜しているうちには、ひとりくらいうり二つという町人衆が見つかるだろう。",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私たちが芭蕉に感じる尊敬と感興は、十七世紀日本の寂しさと現代の寂寥の質の違うことを確りと感情において自覚しつつ、従って表現の様式も十七字から溢れていることを知りつつ、猶芭蕉が自身の芸術にとりくんだ魂魄の烈しさによって、今日と明日の芸術の建設のための鼓舞を感じるところにあると思う。",
              "citation": {
                "source": "芭蕉について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイは、自身の全存在をかけて雄渾に且つ悲劇的に自身の懐疑ととりくみ、そのことに彼流の矜恃をも感じているのである。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを愚かしくもこちらが敵だと思ってひとりくよくよしていた自分の格好を考えると、私は私自身が気の毒でならなくなった。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実の社会悪ととりくんで、悪の中から一つ一つと、社会と人間のよりよい変革のための方向をひき出してゆく、善意の実感の美しい生きた力を欠いていることの証拠です。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大地」で阿蘭をやったときルイズ・レイナーは随分本気でとりくんでいたし、彼女の持っている聰明さ、内面の奥ゆきというようなものが省略された動作のかげに声をのんだ声として多くのものを語る力となっていた。",
              "citation": {
                "source": "映画女優の知性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九の少女は、自分の日々がその中で営まれている環境の内部にある複雑な家族関係とその感情、弟の短い生涯を悲劇的にした家族制度の因習ということには、とりくむ実力をもっていなかったことが、この短篇に語られているのである。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第一巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こしらえた気取りは一つもないが、描こうとする一つ一つの対象にたいして、作者の内面的全構成が統一をもってまともにとりくみ、深められるだけ深くひろく考え、眺め、皮相的に反映するのではなく、自分をとおして文学の現実として再現しようとしているから文章に気品を生じています。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの不幸な人々は、自身の不幸についてさえまともな人生問題、社会問題として正面からとりくむ態度を、いわゆる流行小説の手法にはぐらかされている。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伸子」をかいたときの作者は、全く自然発生にテーマにとりくんだのだった。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたしのみならず、多くの人々が、この年々に、一番多くの血を費したのは、この問題とのとりくみであった。",
              "citation": {
                "source": "人間性・政治・文学（１）",
                "author": "――いかに生きるかの問題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いるに早い日本の文学者たちが、六十歳にも近づけば、谷崎潤一郎の「細雪」のようにきょうの一般の現実には失われた世界の常識にぬくもって、美文に支えられているとき、野上彌生子が、「迷路」にとりくんでいることは注目される。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "多面的な日常生活の困難ととりくみながら、家庭の主婦であり、小さい子供の母である早船ちよが、「峠」「二十枠」「糸の流れ」「季節の声」「公僕」など、次々に力作を発表しはじめている。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにとぞ飲食をおとりください。",
              "citation": {
                "source": "俊寛",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
