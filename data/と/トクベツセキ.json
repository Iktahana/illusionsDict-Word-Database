        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特別席をとって置きますから、面白いんですよ。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "映写の始まる前に観客席を見回していたら、中央に某外国人の一団が繩張りした特別席に陣取っていた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御仮屋は新しい平張で、正面に紫の幕、緑の机掛、うしろは白い幕を引廻し、特別席につづいて北向に厩、南が馬場でした。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "源も馬を競馬場の溜へ繋いで置いて、御仮屋の北側へ廻って拝見すると、郡長、郡書記なども「フロック・コォト」の折目正しく、特別席へ来て腰を掛ける。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から押される苦痛に、源は人を分けて特別席の幕外へ出ました。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は倦んで了って、特別席にかしこまる官吏の影も見えません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯科医専の学生である、その甥の友人は、その部屋の特別席にあたるテーブルでいつも石膏いぢりをやる。",
              "citation": {
                "source": "火の踵",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "マニュファクチュアー的な昔の新聞でも、藤村や、漱石や、鴎外の特別席だけでは、事足りなかつた。",
              "citation": {
                "source": "百万人のそして唯一人の文学",
                "author": "青野季吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の新聞からは、その特別席も消えた。",
              "citation": {
                "source": "百万人のそして唯一人の文学",
                "author": "青野季吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この通俗小説は、寛、有三、国士、鉄兵などを経て発展したもので、昔の新聞小説の特別席と追ひ込み席を統一し、乃至は、双方を吸収したもののやうに観られたりする。",
              "citation": {
                "source": "百万人のそして唯一人の文学",
                "author": "青野季吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「驚くなよ、わざわざ手紙で招待して、特別席からの活劇をお目にかけたんだ。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは立派な晩餐のための特別席で、『御料理』という看板が出ていた。",
              "citation": {
                "source": "青玉の十字架",
                "author": "THE BLUE CROSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "役目の人は知らず、こうして非人がアリャアリャと都合三十槍突いたのを矢来の側の特別席とでもいったところに立っていて、最後まで眼をはなさずに見届けていた者に、お銀様がありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが今事實十五歳だとすれば特別席につけ參らすることは何でもない。",
              "citation": {
                "source": "女子文壇の人々",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別席は宝石がきらきら。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別席の角から、ムーアは劇の進行を見守った。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別席の棚に広げて、ムーアの眼前にある。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一幕が下りると、前列の特別席や、後列の農夫・小作人どもから、やんやの拍手喝さいがあった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば特別席なら一オンス（約三十一グラム）、以下客席次第。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴染みの顔触れが特別席に陣取り、少数派の人々は隅にかたまっている。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠緒さんに至っては、まるでもう、殺されるには誂え向きの特別席に寝ていたようなものですもの。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物席は板をはった上にござをしいて、見物はその上にすわっているのですが、正面の見物席のうしろの一だん高くなったところに、幕でかこった特別席が、ずっとならんでいます。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その特別席の前には、すわっている見物のあたまが、ずっと、まんなかの演技場まで、いっぱいならんでいるのです。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "特別席の中ほどのすぐ前のところに、おとうさんと、おかあさんにつれられた、ひとりの小学生がすわっていました。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井も、左右も、幕でしきられた箱のような特別席が、ずっとならんでいます。",
              "citation": {
                "source": "サーカスの怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
