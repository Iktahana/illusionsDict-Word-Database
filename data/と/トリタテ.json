    },
    "definitions": [
      {
        "index": 1,
        "gloss": "collection (of a debt, rent, taxes, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "特に彼の人種の事までも取り立てて考えるほどの事ではないと思われる。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしの方でも取り立ててこうというほどの種は挙がりませんが、唯ひとつ、妙なことを聞き出しましたよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　村役場から、税金の取り立てが来ていたが、丁度二十八日が日曜だったので、二十九日に、源作は、銀行から預金を出して役場へ持って行った。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこを取り立てて特別心を惹くようなところはなかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような事は別に取り立てて言うほどでないかもしれぬがしかしこの主観を無視する程度は人間の文明の程度によってだんだんに変化して来るものである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この性欲の根本使命は、種の保存、子孫繁栄にあるようですから、これを今さら取り立てて説明研究する必要はありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高ぶったとか勿体ぶったとか云う悪評のなかから、不思議な程かやを大切にすることばかりを婆やはたった一つ取り立ててひとから褒められて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒟蒻、蒲鉾、八ツ頭、おでん屋の鍋の中、混雑と込合って、食物店は、お馴染のぶっ切飴、今川焼、江戸前取り立ての魚焼、と名告を上げると、目の下八寸の鯛焼と銘を打つ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし春次に言わせると、お神の勘定高いにはほとほと呆れることばかりで、銀子を見に行った時も、春次はお神に誘われ、松島見物でもするつもりで出かけたのだったが、帰って来ると、往復の汽車賃や弁当代までを割勘にし、毛抜きで抜くように取り立てられたのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもだと後家さんは、収穫後の金取り立てで忙しいのであったが、今年はそんなもようがないので、借りのある連中は皆喜んだ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから長篇ものに所々此趣味が散点して居ても、取り立ててこれが作者の趣味だと言い切る訳には行かない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧藩閥の明治の功傑たちは、新政府に従順だつた幕府方の旧権臣の家門を犒ふ意味から、その後嗣者を官吏として取り立てた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "相州さまがその年来の郎従の中で、特に功労のあつたものをこんど侍に取り立てたい、それに就いておゆるしを得たく参上いたしましたと気軽に将軍家へ申し上げたところが、将軍家はにつこりお笑ひになつて、考ヘテミマシタカ「え、何事でございませう。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの人に説教させ、群集からこっそり賽銭を巻き上げ、また、村の物持ちから供物を取り立て、宿舎の世話から日常衣食の購求まで、煩をいとわず、してあげていたのに、あの人はもとより弟子の馬鹿どもまで、私に一言のお礼も言わない。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もっと地味に、決定的に、質実に、その本質を指定することも出来ない組み合せになって相当、年月を経た男女――少なくとも取り立てて男女などと感じなくなった自分達だけは、子の前などでは尚更「夫婦」なんてぷんぷんなまの性欲の匂いのする形容詞を着せられるのは恥かしい。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前田家、上杉家等の貸附はほぼ取り立ててしまい、家に貯えた古金銀は概ね沽却せられたそうである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人の先天的もしくは後天的の性格と鼻の恰好との間にはこれと云って取り立てる程の関係はない。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人が勝手に人民から税を取り立てるのは不法である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでの日本の政治は、臣、連、国造、県主など、勢力のある氏の長が、土地人民を私有してゐたので、天皇は、氏の長を率ゐて居られるだけで、直接の御領地以外は、人民全体から、税なども、お取り立てになることはなかつたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって、はじめのうちはべつに取り立てて彼女ひとりに憧れていたわけではない。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いよいよ取り立てることになると、段当たり七十銭の小作料としても、七百五十町歩だから 750×7 が五千二百五十円。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になると、貸し付けてあった食糧費をぴしぴしと取り立てた。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今年からはいよいよ小作料をも取り立てると提言して、それの実行に取り掛かった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作料の取り立ては厳しく実行された。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貸し付けてあった開墾中の費用の取り立てにも彼は決して手を緩めなかった。",
              "citation": {
                "source": "熊の出る開墾地",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この青年ロナルド・アデイアは、貴族階級の中に往来し、見受けるところ、別に敵と云うようなものもなく、また取り立てて、不徳義であると云ったようなこともないようであった。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "忰は稼いでるし、稲荷町の差配は店賃の取り立てにやあ歩行かねえッての、むむ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、近所の評判を聞くと、万次郎という奴はもちろん褒められてもいねえが、取り立てて悪くも云われねえ、世間に有りふれた次三男の紋切り型で、道楽肌の若い者というだけの事らしいのです」「大津屋の重兵衛はどうだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠之はそれを近習に取り立てゝ、次第に任用して、短い月日の間に、秩祿を加へられる度數の多いので、心あるものは主家のため、領國のために憂へ、怯懦のものは其人を畏れ憚り、陋しいもの、邪なものは其人にたよつて私を濟さうとするやうになつた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間は三造を馬鹿にしてはゐない、寧ろ三造を喜んでゐる、しかしとりたてて尊敬してもゐはしない。",
              "citation": {
                "source": "青年青木三造",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
