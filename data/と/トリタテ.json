[
  {
    "uuid": "66686e20-5b36-55e3-a231-5373598f4578",
    "entry": "取り立て",
    "reading": {
      "primary": "とりたて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
