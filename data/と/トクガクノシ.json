        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "性質は豪放であったが、もともとぼんやりであったから、篤学の士であったけれども人に名を知られていなかった。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言った末吉氏は純粋の琉球人、篤学の士、予氏より未聞を聞く事多い。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけではまだ十分な説明が出来ないであろうところの精神病関係、もしくは心霊に関する各種の怪奇、不可思議現象に就て、首をひねっている篤学の士が居るかも知れない。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ口が旨いから、空疎な講義の内容も、十分｜胡麻化されるし、学者仲間には兎も角、世間に対しては、いかにも学殖のある篤学の士のように見せかける事は、易々たる事である。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（モリエエルは例外である）もちろん文壇に篤学の士が多いから、中には Cent nouvelles Nouvelles du roi Louis しているような作品は見えない。",
              "citation": {
                "source": "仏蘭西文学と僕",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "専門のことは私にはよくわからないが、Ａはずつと以前から老齢期特有の病気に興味をもち、小児科に対して、老人科とでも称すべき医学の新分野を開拓しつゝある篤学の士である。",
              "citation": {
                "source": "老病について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に、演劇年譜であるが、少壮篤学の士中田耕治君に、非常に骨の折れる草案を作ってもらい、山田肇君に校訂をおまかせした。",
              "citation": {
                "source": "『演劇』あとがき",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗣子伊三郎は篤学の士で藩中の者から尊敬せられていた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか篤学の士だな」　すると、大里町子は首をちゞめて笑つた。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜尾先生は篤学の士を熱愛した。",
              "citation": {
                "source": "浜尾新先生",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
