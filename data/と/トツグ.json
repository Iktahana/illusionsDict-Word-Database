    "definitions": [
      {
        "index": 1,
        "gloss": "to marry (of a woman)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第三六課　ハムレット　ハムレットは、叔父に父を殺され、殺した叔父に母は嫁ぐ。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "衛に嫁ぐ以前の南子と醜関係があったことは、霊公以外の誰一人として知らぬ者は無い。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衞に嫁ぐ以前の南子と醜關係があつたことは、靈公以外の誰一人として知らぬ者は無い。",
              "citation": {
                "source": "盈虚",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼女は、再び以前の職業に戻って、生活費を嫁ぐ傍らに、肉体の恢復に努めようと計画したのであった。",
              "citation": {
                "source": "機関車",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小紋の小袖に丸帯と思えば、寺には、よき人の嫁ぐならいがある。",
              "citation": {
                "source": "夫人利生記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく一人承知した女ありてこれに嫁ぐ。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天国に嫁ぐためにお前は浄められるのだ」そういう声が聞こえたと思った。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日こそは出家して基督に嫁ぐべき日だ。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ荘田家へ嫁ぐのなら、息子さんよりも、やっぱりお父様のお嫁になりたい。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "呉れなければその令嬢の嫁ぐ先々に或る手段を施して呪う、場合に依っては死ぬ迄結婚させぬ――なぞいう威し文句を送る。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "家の事情から止むを得ず、ある男のところへ嫁ぐのだと聞かされた。",
              "citation": {
                "source": "滑走",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が嫁ぐとき持って来た品々は、まだその土蔵の長持の中に呼吸づいていて、それが私の嘆きを新たにした。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ荘田家へ嫁ぐのなら、息子さんよりも、やつぱりお父様のお嫁になりたい。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この話のほうは生まれながらにそうなれとの因縁でもって山河の主に嫁ぐということである。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡てを概括した上で、平岡は貰ふべからざる人を貰ひ、三千代は嫁ぐ可からざる人に嫁いだのだと解決した。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千代が平岡に嫁ぐ前、代助と三千代の間柄は、どの位の程度迄進んでゐたかは、しばらく措くとしても、彼は現在の三千代には決して無頓着でゐる訳には行かなかつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "必竟は、三千代が平岡に嫁ぐ前、既に自分に嫁いでゐたのも同じ事だと考へ詰めた時、彼は堪えがたき重いものを、胸の中に投げ込まれた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち明けるならば三千代が平岡へ嫁ぐ前に打ち明けなければならない筈であつた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "撮影所は美しい※垣の多い静かな屋敷町にあったが、葉子はかつての結婚式に着たことのある、長い振袖に、金糸銀糸で鶴や松を縫い取った帯を締め、近いうち台湾にいる理学士のところへ嫁ぐことになっている妹も、同じような式服で、写場へ乗りこんだものだった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹が近々｜許婚の人のところに嫁ぐために、母に送られて台湾へ行くことになったことだの、母の帰るまでゆっくり逗留していてかまわないということだの――。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにして、岡崎に嫁ぐよう告げられると、お芳がきっと抵抗するに違いないと思っていたおタマは騙された格好であった。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに、本人の同意なしに老人の元へ嫁ぐことに決まったうら若い婚約者に掛けられるようなありふれた慰めの言葉に加えて、おタマは岡崎を思い通りに操る方法についてもお芳にいくつかの貴重なアドバイスもした。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の家が貧乏なために、叔父さんのサシガネで、ある金持ちの病身の息子と強制的に婚約をさせられ、その男の家から学費を出してもらって女学校に通って、卒業後の暁はその家に嫁ぐべき運命を持っていた女。",
              "citation": {
                "source": "ふもれすく",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年の暮、ただ一人の私の姉は嫁ぐことになりまして、何かとそれまで我儘に暮しました私は、母と二人きりになったのでした。",
              "citation": {
                "source": "昔尊く",
                "author": "二千六百年を迎えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が初めて東京へ行きましたのは、三十二か三の時分で、平和博覧会に、鏑木清方さんが〈嫁ぐ日〉を描かれたのを拝見する為に上京したのが初めてでございます。",
              "citation": {
                "source": "想い出",
                "author": "絵の道五十年の足跡を顧みて",
                "note": "青空文庫"
              }
            },
            {
              "text": "義兄の深切で嫁ぐまでをその家でおくることになったが、姉夫婦は鄙少女の正子を都の娘に仕立ることを早速にとりかかり、気の強い彼女を、温雅な娘にして、世間並みに通用するようにと、戸板裁縫女学校を選らまれた。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもじの母のドラは、ベーリングの従妹とか言うたが、ステツレルに嫁ぐまえ、ベーリングと懇ろにしおったのであろう。",
              "citation": {
                "source": "紅毛傾城",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハーゲンに殺された夫ジーグフリードの幻を、胸に抱きしめて、クリームヒルトは匈牙利王エッツェルの許に嫁ぐ。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　左門へ嫁ぐ前、可成り親しかったお俊と甚七は、二人とも御互によく心を知合っていた。",
              "citation": {
                "source": "新訂雲母阪",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、嫁ぐ話のきまった時「それでは、一生嫁をもちますまい。",
              "citation": {
                "source": "新訂雲母阪",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
