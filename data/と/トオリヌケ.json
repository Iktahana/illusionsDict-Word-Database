        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は、瀬戸内海を傍若無人に通り抜けた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々仲間でその支柱の仕方が果してどれだけ有効であろうかといったようなことを話し合っていたら、通りかかった人足風の二人連れが「アア、それですか、僕達がやったんですよ」と云い捨てて通り抜けた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな役であってもやはり舞台へ出る前には何遍も鏡を見て緊張し、すうと十秒くらいの間に舞台を通り抜けてしまうとはじめてほっとして「試験」のすんだのどかさを味わうであろう。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「上野の山の腹わた」を通り抜けると、ぱっと世界が明るくなる。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年団の人達と警官の扱いでようやくこの時ならぬ関所を通り抜けて箱根町に入った。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "茄子畑というは、椎森の下から一重の藪を通り抜けて、家より西北に当る裏の前栽畑。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで停車場の改札口のような処を通り抜けて、恐ろしく長い廊下のような処に出た。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "完全に裸体で豊満な肉体をもった黒髪の女が腕を組んだまま腰を振り振り舞台の上手から下手へ一直線に脇目もふらず通り抜けるというものすごい一景もあった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがその日に限って、ふと知らない横丁を通り抜けた。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通り抜けて停車場の方へと裏町を歩いていると家々からラジオが聞こえ、それが今聞いた市役所の庭の合唱そのままである。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、そこから、浸点作業へ通り抜けた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と曖昧に塩入れ場の前に六尺の天秤棒や、丸太棒やを六七本立てかけてある方に顎をちょいと突き出して搾り場を通り抜けて行ってしまった。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林を通り抜けると、そこが嘉ッコの家の豆畑でした。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く通り抜けようとしてゐる。",
              "citation": {
                "source": "柳沢",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な戦慄が私を通り抜けました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通り抜けて、一畳｜幅に五畳か六畳を長く敷いた入側見たような薄暗い部屋を通ったが、茶の間でもその部屋でも処※で、足踏につれてポコポコと弛んで浮いている根太板のヘンな音がした。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "独り荷物をかついで魚臭い漁師町を通り抜け、教わった通り防波堤に沿うて二町ばかりの宿の裏門を、やっとくぐった時、朧の門脇に捨てた貝殻に、この山吹が乱れていた。",
              "citation": {
                "source": "嵐",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして星がちょうど糸を通過する瞬間を頭の中の時のテープに突き止めるのであるが、まだよく慣れないうちは、あれあれと思う間に星のほうはするすると視野を通り抜けてしまってどうする暇もない。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただもう一息という肝心のところをいつでも中途半端で通り抜けてしまうのが物足りなく思われる。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分自身の苦しさばかり考えて、ただ真直を見て、地下道を急いで通り抜けただけなんです。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」やや元気が出て来て、森を通り抜け、石段を降り、池のほとりを歩いた。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてお二人は町の広場を通り抜けて、だんだん郊外に来られました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして燈火も何もつけない短かい廊下を通り抜けると正面の真暗な室のマン中に立たされた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分が何かの問題にまともにぶつかって、そのほうの必要からこれらの知識を通り抜ける時に、すべての空虚な知識が体験の糸に貫ぬかれて始めて生きて連結して来る。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、これによって、生きている人をそのままに透明な幽霊にして壁へでもなんでもぺたぺたと張り付けあるいは自由に通り抜けさせることができるのである。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドック近くの裏町の門々にたたずむ無気味な浮浪人らの前をいばって通り抜けて川岸へくると護岸に突っ立ったシルクハットのだぶだぶルンペンが下手な掛け図を棒でたたきながら Die Moriat von Mackie Messer を歌っている。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではお気味が悪くって、さっさと通り抜けておしまいなされましたか。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとロザーロがだまってしずかにおじぎをして私の前を通り抜けて外へ出て行きました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳底に女の好物でものこるように、交響楽によって嗜色人の踊がはじまると、軍隊的な組織も粋な衣服にかくれて、部屋にいる人間の甘い唾液のなかを、安南の××がとおりぬけるのだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その毒蛇も竜も、日中一ばん暑いときに三時間だけ寝ますから、そのときをねらって、こっそりとおりぬければ大丈夫です。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
