  {
    "uuid": "0ec73213-c2e5-596e-8156-c2c7ea00c84c",
    "entry": "都庁",
    "reading": {
      "primary": "とちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
