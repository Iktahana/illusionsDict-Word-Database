    "definitions": [
      {
        "index": 1,
        "gloss": "Tōtōmi (former province located in the west of present-day Shizuoka Prefecture)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは本居宣長翁の弟子の石塚龍麿という遠江の学者であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「時間で見ると、すつかり明くなるのは、遠江國濱松だ。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と退屈だし、一つ遠江國と念を入れた。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠江国日坂の宿に近い小夜の中山街道の茶店へ、ひとりの女が飴を買ひに来た。",
              "citation": {
                "source": "小夜の中山夜啼石",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日、戊辰、霽、伊豆国の飛御参ず、申して云ふ、去る六日、戌剋、入道遠江守時政、北条郡に於て卒去す、日来腫物を煩ひ給ふと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊亀元年五月には、遠江国に大地震があって、山が崩れて※玉河を壅いだが、続いてそれが決潰したので、敷智、長下、石田の三郡の民家百七十余区を没した。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同七年八月には、伊勢、遠江、駿河、甲斐、相模、伊豆の諸国に大地震があって、海に臨んだ国には海嘯があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また遠江の地が陥没して浜名湖が海と通じた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十七年二月にも、駿河、遠江、三河にまた大地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九年の地震は、薩摩、大隅、土佐、遠江、伊勢、紀伊、伊豆、上総、八丈島などで、海には海嘯が吼えた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞保二年九月には周防、長門、同三年八月には遠江、三河、山城、元禄七年五月には羽後の能代、同十年十月には相模、武蔵に、それぞれ地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛永四年十月には、山城、大和、河内、摂津、紀伊、土佐、讃岐、伊予、阿波、伊勢、尾張、美濃、近江、遠江、三河、相模、駿河、甲斐、伊豆、豊後の諸国にわたって大地震があって、人畜の死傷するもの無数。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして土佐、阿波、摂津、伊豆、遠江、伊勢、長門、日向、豊後、紀伊などの海に面した国には海嘯があったが、そのうちでも土佐などは海岸の平地という平地は海水が溢れて被害が大きかった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国は信濃よ三河遠江、水は天竜の流、水上よ、下り下りに春うらかすむ。",
              "citation": {
                "source": "黒檜",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこぞ遠江灘、潮見坂ほどちかくて、薄ら曇る低き空を風も来ず。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこぞ遠江灘、潮見坂ほどちかくて、薄ら曇る低き空を風も來ず。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづこぞ遠江灘、灘見坂ほどちかくて、薄ら曇る低き空を風も来ず。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "簑田は曾祖父和泉と申す者｜相良遠江守殿の家老にて、主とともに陣亡し、祖父｜若狭、父牛之助｜流浪せしに、平七は三斎公に五百石にて召し出されしものに候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼は、自分の分国の諸将が動揺するのを見、憤激して、天正二年正月美濃に入って明智城を攻略し、同じく五年には遠江に来って、高天神城を開城せしめた。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌三年十月、武田信玄は大挙して上洛を志し遠江に侵入し、徳川家康を脅かしたが、翌天正元年四月、疾を得て「明日旗を瀬多に立てよ」のうは言も悲しく陣歿した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "真淵は遠江浜松の新宮の禰宜岡部定信の二男で、享保十八年三十七歳で京都に出て、荷田春満の門に入つた。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは頼家が生れて間もない時のこと、政子には継母に当る遠江守時政の後妻｜牧の方から頼朝の行に就て知らして来た。",
              "citation": {
                "source": "頼朝の最後",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣座峠は遠江と三河との國境に當つて居る。",
              "citation": {
                "source": "梅雨紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸参勤中で遠江国浜松まで帰ったが、訃音を聞いて引き返した。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲斐の武田勝頼が甘利｜四郎三郎を城番に籠めた遠江国榛原郡小山の城で、月見の宴が催されている。",
              "citation": {
                "source": "佐橋甚五郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は餘り知らぬ事だが、本邦でも上述の英國のパウリーや露國のドモヴ※イに似た奧州のザシキワラシ、三河遠江のザシキ小僧、四國の赤シャグマ等の怪がある。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は二の擬定地あり、一は遠江國磐田郡鹿苑神社の所在地なり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "間智は宇麻志麻遲命の麻遲に同じく、荒木田守良が鹿龜雜誌富岡氏藏本に麻遲の名の古書に見えたるを擧げて、宇麻志麻遲命の外に神名帳の遠江國佐野郡｜己等能麻知神社、近江國高島郡麻知神社、及び中臣壽詞に麻知弱韮由都篁生出とあるを引き、其の釋義は明かならずといへり。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "また陸奥国八戸の城主｜南部遠江守信順と越前国｜鯖江の城主｜間部下総守｜詮勝とから五人扶持ずつの俸を受けていた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
