[
  {
    "uuid": "57bafc4f-08a5-5c06-a76e-330b5a1b298f",
    "entry": "徒党",
    "reading": {
      "primary": "ととう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
