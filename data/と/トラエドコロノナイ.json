[
  {
    "uuid": "78286e01-95b9-5ea8-beb3-fe3e9dc21bd0",
    "entry": "捉えどころのない",
    "reading": {
      "primary": "とらえどころのない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
