        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あなたのそのフィルムと、わたしのとこっそり取り替えっこしときましょうや。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際この頃では、老人の方が若者より千倍も快活で、まるで老人と若者が持役の取り替えっこでもしたようである。",
              "citation": {
                "source": "大ヴォローヂャと小ヴォローヂャ",
                "author": "ВОЛОДЯ　БОЛЬШОЙ　И　ВОЛОДЯ　МАЛЕНЬКИЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のこの絵と取り替えっこしないかね？",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どれ、見せてごらんなさい」　お互いに取り替えっこをして、見比べたが、すっかり同じ型のピストルであることがわかった。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは語と語の取り替えっこである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "往々にしてますますわからない語との取り替えっこである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、いいかげんなころを見はからって、ご自分の方が先におあがりになり、ごじょうだんのように建の太刀をお身におつけになりながら、「どうだ、二人でこの刀のとりかえっこをしようか」とおっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次から次と、船がつく港で、持って行った品物を売ってお金にしたり、また、あちらの品物ととりかえっこをしようと思ったからです。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、その牝牛と、とりかえっこしようかね。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャックは、その男のいうなりに、牝牛と豆の袋ととりかえっこしました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、いきなりそういって、だいとくいで、牛と豆のとりかえっこした話をしました。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれを、ただぼんやり、ふしぎだなあとおもってながめたなり、すぎてしまえば、とりかえっこした牝牛は、よし手にもどることがあるにしても、あなたたちは、あいかわらず貧乏でくらさなければならない。",
              "citation": {
                "source": "ジャックと豆の木",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥打帽はとうとうとりかえっこに、自分が空罐かぶって、髯長に本をもたせて、鳥打帽をかぶせちまった。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか物資をとりかえっこしたいというんだろう。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりかえっこ　その怪外人は、じつにいばっています。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お休み時間には、鉛筆だの、ガラス玉だの、紙人形やなにかと、とりかえっこするの。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと、とんぼととりかえっこをしようよ。",
              "citation": {
                "source": "きれいなきれいな町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「じゃ、とりかえっこしてあげよう。",
              "citation": {
                "source": "きれいなきれいな町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二人は、絵本ととんぼととりかえっこをしました。",
              "citation": {
                "source": "きれいなきれいな町",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃアまあそういったようなものだが――」「だから、でございますよ、弥生さんの所在ととりかえっこに、ひとつ丹下様に働かせてみちゃアどうでございます？",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしリザヴェータと十字架のとりかえっこをしたんですの。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭からはいってきた、こじきむすめと、服のとりかえっこをしたのよ。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな気まぐれをおこして、服のとりかえっこをしたばっかりに、おそろしいめにあわなければならない。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "光子というのは銀一の姉ですが、その光子が、じぶんとよくにたこじきむすめと、服のとりかえっこをしたというのです。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろめがねは、つれていた女の子と、おとこのもっていたはことをとりかえっこしました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
