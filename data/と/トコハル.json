    "definitions": [
      {
        "index": 1,
        "gloss": "everlasting spring",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "風はそよとも吹かず、日熱からず、四方のけしきのどかに見わたさるるに時じくに鶯鳴くも二荒のおくなる里は常春にして舟、菖蒲が浜に着く。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦蘿に包まれたる水道の址とこれを圍める橄欖の茂林とは、黯澹たる一幅の圖をなして、わが刻下の情にの如きありて、常春藤と石長生とは其壁を掩ひ盡せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "この末黒野のゆふぐれ、二月寒のさびれに、よろづの實母おほみ慈悲のふところ深く隱れて、やがても往かむ彼方の常春あけぼの望み得るぞ、吾世の祕密、――憂身の光や、日も夜も醉ひてあらめ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうなると極寒の海に俄然常春が訪れるじゃないか、漁業や交通やその他いろいろの事業に関して……」「ほう、これは面白い想定だ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "初びかり、げに常春のかなた見て、躍りぬ、胸の聖ごころ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "常春藤の葉５・27（夕）　西部戦線の聯合軍を援けに、最近本国から巴里へ渡つた米国青年士官の二人があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこに常春藤が植わつててよ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "常春藤の葉つ葉は、小さければ小さい程｜愛情が深いんですつて。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　娘はかう言つて、幾度か常春藤の葉の小さいのを捜したらしい眼を細めて、眩しさうに二人の顔を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "手には素晴しく大きな常春藤の葉を摘むでゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は　常春藤の籠にもり或時は　石蝋の壺に納め心　はるばると、祈りを捧げる　神よ、四時の　ささやかな人間の寄進を　納め給え、と。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは言うまでもなく空色の部屋で、長椅子と橢円形のテーブルと、常春藤をからませた衝立まで具わっていた。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反してお庭の隅の常春藤に蔽われたバンガロー風の小舎には燈火がアカアカと灯って、しきりに人影が動いている。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそこが食物の豊富な常春島であれば……。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼の家の煉瓦塀が、何歩か先に黒々と、現われて来たからばかりではない、その常春藤に蔽われた、古風な塀の見えるあたりに、忍びやかな靴の音が、突然聞え出したからである。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "常春藤の簇った塀の上には、火の光もささない彼の家が、ひっそりと星空に聳えている。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳は思わず塀の常春藤を掴んで、倒れかかる体を支えながら、苦しそうに切れ切れな声を洩らした。",
              "citation": {
                "source": "影",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の愛情は、常春藤のように、時と共に成長したものであって、相手が友人として適当だというわけではなかった。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔だに見ば、問うべき事を問い、言うべき事を言いて早帰らんと思いし千々岩は来たらず、しきりに波立つ胸の不平を葉巻の煙に吐きもて、武男は崖道を上り、明竹の小藪を回り、常春藤の陰に立つ四阿を見て、しばし腰をおろせる時、横手のわき道に駒下駄の音して、はたと豊子と顔見合わせつ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "早々香港に赴きて、金博士に談判し、シベリアを常春の国まで引きかえさせるべし。",
              "citation": {
                "source": "地軸作戦",
                "author": "――金博士シリーズ・９――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ときをり私は、常春藤の群でもつてこの古い館を攻撃してゐる、急勾配をした庭園の中に、拔け出すことを許されます。",
              "citation": {
                "source": "リルケ年譜",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ風の建て方であるから、料理はすべて下から運び上げるのである、入口には絡みつけた常春藤の青い房が垂れてゐた。",
              "citation": {
                "source": "龍土會の記",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "常春の島に来て人生の秋を知る。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "消え失せた沙漠――大島の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一翼は明かに極めて古い時代のもので、どつしりした石の圓柱を持つた弓形張出窓には常春藤が這ひ纏はり、葉の茂みの間で小さな菱形の窓硝子が月影に煌めいた。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐が報ぜられて間もなくわたし達の着いた饗應の室は樫材で造られてゐて、鏡板は蝋で光澤をだし、周圍の壁には家族の肖像が掛けてあつて、柊と常春藤で飾られゐた。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧しく言ひ爭つて、やれ柊人形、やれ常春藤人形と、夫婦して自分の方に花を持たせようと言い張りあふ。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
