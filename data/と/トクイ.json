    },
    "definitions": [
      {
        "index": 1,
        "gloss": "satisfaction",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こうした手紙の中に、ヘルンの大得意な満悦さが現われている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前は私も、たいへん画が好きで、画家の友人もたくさんあって、その画家たちの作品を、片端からけなして得意顔をしていた事もあったのですが、昨年の秋に、ひとりでこっそり画をかいてみて、その下手さにわれながら呆れてそれ以来は、画の話は一言もしない事にきめました。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに衣食住に凝って得意顔の人は、私には、どうしてだか、ひどく滑稽に見えて仕様が無いのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、達沢が教頭席に腰を下した儘、前方のゴタゴタした一群れ――それは何か分らぬ――に向つて、その太い腕を得意気に振廻してゐる光景のみが、彼の目に見えてゐた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、日本の文学者等は、彼等の翻案化された似而非の自然主義文化や、似而非のレアリズム文学を以て、自から外国思潮のそれと同列させ、資本主義末期の近代文学を以て自任しつつ、笑止にも得意でゐるからである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻眼鏡でぬうっと澄ましていて、そうして何でも実によく知っているルーベンスの傍に、無邪気で気軽く明るいプランクがいて、よくわれわれでも知っているような実験的の事実を知らないで質問する、若い連中が得意になってそれを説明するのを感心して謹聴していた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上野へ入れば往来の人ようやくしげく、ステッキ引きずる書生の群あれば盛装せる御嬢様坊ちゃん方をはじめ、自転車はしらして得意気なる人、動物園の前に大口あいて立つ田舎漢、乗車をすゝむる人力、イラッシャイを叫ぶ茶店の女など並ぶるは管なり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は西洋人も婦人まで草鞋にて登る由なりなどしきりに得意の様なりしが果ては問わず語りに人の難儀をよそに見られぬ私の性分までかつぎ出して少時も饒舌り止めず、面白き爺さんなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色の液体を二種混合するとたちまち赤や黄に変り、次に第三の液を加えるとまた無色になると云ったようなのを幾種類か用意してもらって、近所の友達を集めては得意になって化学的デモンストラチオンをやって見せたのであった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後自分の書いたものについて、夏目先生から「今度のは虚子がほめていたよ」というような事を云われて、ひどく得意になったりしたこともあった。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の得意はもうその絶頂に達して居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが日本人のお得意の哲學である。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言へば、鬼たち、得意さうにわつと歡聲を擧げる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と得意滿面、このたびの大厄難突破の次第を、唾を飛ばし散らしながら物語る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに衣食住に凝つて得意顏の人は、私には、どうしてだか、ひどく滑稽に見えて仕樣が無いのである。",
              "citation": {
                "source": "無趣味",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが六百尺であることが恰もその事掌のせゐでもあるかのやうに何となく、得意気に聞こえて面白い。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、土方風の男が一人縄で何かガラガラ引きずりながら引っぱって来るのを見ると、一枚の焼けトタンの上に二尺角くらいの氷塊をのっけたのを何となく得意げに引きずって行くのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが六百尺であることがあたかもその車掌のせいででもあるかのように、何となく得意気に聞こえて面白い。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから後も、男は、得意の弓矢の業をもって、麓に住む荒い獣を半殺しの程度にして狩り取り、湧玉の水のほとりに待受けていて、女を見ると、屠り殺した。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりゃ偉いわねえ」「おら貰うべえ」四郎は得意な顔つきをした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはいいわね」　四郎は得意になった。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人は子音の重なるのは不得意だから st がｓになることは可能である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば極めて平凡下劣の家庭に安じたのである、或一種の考から其の下劣平凡の家庭を却て得意とした時代もあった。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーはこういう計算はあまり得意でなかったのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみれば常識的聰明といふこと（今の小説家等が唯一の得意とするのはそれである。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は得意になつて大道を闊歩した。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば名詩集「ゆく春」の詩人泣菫は、後に「白羊宮」や「二十五絃」のやうな駄詩集――熱も色氣もないペダンチツクな駄詩集――を出して得意で居るし、神祕冥想の偉才詩人三木露風も、最近羅風と改名してからロクな詩は作つて居ない。",
              "citation": {
                "source": "名詩集「思ひ出」の眞價",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次がソッと五郎蔵に囁く、Ｔ「もてますね」　「いや、其れ程でもない」顔の相を崩して得意がる五郎蔵の助平面がジロリと横目で睨んだ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次尚も、Ｔ「演じまするは　これ北辰一刀流　名代の踊り手　此村大吉が得意の壇上」　拍子木をガチャガチャガチャ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主は宿帳をつくづく見て、Ｔ「この宿帳は　永く当家の家宝として　子々孫々に伝えます」　と押し戴いたので、　団九郎先生益々得意然として居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
