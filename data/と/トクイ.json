[
  {
    "uuid": "60e1c030-c681-5c65-bf4e-2e40e8606f75",
    "entry": "得意",
    "reading": {
      "primary": "とくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
