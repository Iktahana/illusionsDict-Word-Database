[
  {
    "uuid": "582c89fd-a85c-574a-b603-f8e81e23e8e7",
    "entry": "とは言え",
    "reading": {
      "primary": "とはいえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接続詞"
