          "literary": [
            {
              "text": "近頃少女の洋服に共布で、バンド代りに結んで下げるあの紐も、たしかに日本からいつた逆輸入で、あれが新流行だからをかしい。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "共布のベルトを結んでいた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄い生地を体の前で合わせ、体の右側で共布の紐を結ぶという、簡素な作りの服だ。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の蓮っぱな娘たちが、前かけや、羽織裏などのともぎれで作っては、人知れずお供えするからである。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
