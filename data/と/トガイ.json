[
  {
    "uuid": "f9fd96e5-a172-554b-96e0-4abc3bebae33",
    "entry": "都外",
    "reading": {
      "primary": "とがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
