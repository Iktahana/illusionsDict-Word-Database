        "index": 1,
        "gloss": "(written) address",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また取りあえずの所書きももらって置きたい。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の所書きも渡したい。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「え、所書きがあつた筈よ。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして所書きの辺まで来ると、仕事が余り難しいので、もじもじするらしく見えたが、それでもまた一字一字ぼつぼつと写し出した。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "所書きには、書き誤りが一つ消してあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれこんなことにもなろうと思って、ふところ日記にちゃんと所書きも名まえも書き止めておいたんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　順吉は行李の底から取出した手紙の束をほどいてたんねんによみかへし、差出人の所書きを手帳にうつしたりするのだつた。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いったい、この本郷云々という所書きは何でしょう？",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶色クローズの表紙で鼠色紙の扉にノート風の細かいペン字で、　　（１）　大学図書館ヲ公開スル事　　（２）　東洋美術発行ノ事とあり、別行に、これは鉛筆で「電燈タングステン燈よろし」続けて、「木彫専門」「襖紙一式」等各建築関係専門店の名と所書きが並べられている。",
              "citation": {
                "source": "父の手帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私を戸口から押し出して、『住所書きをおいて行け。",
              "citation": {
                "source": "無駄骨",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろんな知人の住所のなかには、上海にゐたもんの所書きもあれば、工藤の住所もひかへてあつた。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作法通り、立ち退き先の所書きは、座敷の壁に貼ってある。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "弔電や宿所書きを一つにする。",
              "citation": {
                "source": "葬儀記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "滋さんの所書き日本へ忘れてきたから、うとうにもうちようがないじゃないの」「でも、あなたのほかに誰が電報をうつというの」　やすもへんだと思ったか、解けきらない顔で、「マルセーユじゃ、ちっとも心細い思いなんかしなかったのよ。",
              "citation": {
                "source": "ユモレスク",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただ請求せよ、宿所書きを送れ」と。",
              "citation": {
                "source": "共産食堂",
                "author": "ピョートル・アレクセーヴィチ・クロポトキン　Pyotr Alkseevich Kropotkin",
                "note": "青空文庫"
              }
            },
            {
              "text": "この所書きのところでいいんだね」　ちり紙を細長く切って自分で書いて持っていった名札へ目を落として、おしまいに支配人は言った。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "滋さんの所書きを出るとき忘れてきたもんだから、打ちたいにも打ちようがなかった」「でも、あなたのほかに、誰が電報を打つというの」　安もへんだと思ったか、解けきらない顔で、「マルセーユじゃ、ちっとも心細い思いなんかしなかったのよ。",
              "citation": {
                "source": "野萩",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "手にとると、反物の板紙で無器用につつんだ女文字で、やつと所書きをかいたらしいおすゑからの小包であつた。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスク※では何よりむずかしいとされている室さがしを伸子たちにたのまれたマリア・グレゴーリエヴナはは、何かのつてでやっと手に入れた所書きだけをたよりに、自分でも先方のことは知らないまま、伸子と素子とを連れて見に来たのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日のおそい午後、伸子たち三人は、所書きをたどってその一つの横丁の、ひどく高い茶色の石壁のわきにある袋小路を入って行った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｏは自分の住所書きを手渡したりして、「とにかく事件は済んだのだから安心したまえ。",
              "citation": {
                "source": "或る少女の死まで",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして互いに現住所の所書きを交換し、再會を約して外に出た。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴島の手紙には所書きは書いてない。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目の人は所書きがありましたが（大森）、そこへ行つて見ましたら、その番地の附近一面が燒野原になつていて、そこらの人にたずねても交番で聞いても、以前の住人のことなど、まるきりわかりませんでした。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二番目は名前だけで所書きはありません。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、山梨縣にいる久子と言う人があり、その住所書きは、あなたから作つていただいたリストには書いてありませんけど、立川景子さんから聞いて書きとめてあります。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しまい忘れということをやったのね、隆治さんの所書き式に。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "がついにある日、彼女からもらった住所書きを見出して、彼は思い切って訪問した。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手帳には、住所書きとかいろいろ文字が書いてあって、後になるほど乱れて判読できなくなっている。",
              "citation": {
                "source": "赤い駱駝",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『それに、なんだっておれはあの女に所書きなんか渡したんだろう？",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
