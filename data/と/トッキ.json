[
  {
    "uuid": "383da52a-66c2-56df-abcf-2a1df0779df2",
    "entry": "特記",
    "reading": {
      "primary": "とっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
