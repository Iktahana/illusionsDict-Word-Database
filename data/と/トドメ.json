    "definitions": [
      {
        "index": 1,
        "gloss": "finishing blow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "度々のことで面倒だから、今度から止めにして、先へ勝手に寝ることにしろと何度も言うが、妻は婦道に背くと言い、なかなか承知しないので困っている云々（大意）と。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「まあさうまで言はれるのに私が止めるわけにも行かないが、それやああなたの御志は立派だが、併しそれであなたの一生涯が潰れるつてことになると………私も………。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が御飯の間に這入ると父と母はしてゐた話を急に止めた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がたつた一膳で止めて立たうとすると、祖母が腹でも悪いのかと言ひ出した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私はまだ母が言はうとするのを口止めして置いて言つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がそれを目配せして止めた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもまた祖母と祖母との争ひなどが起つたり、母がそれにキン／＼しだすと不可ないといふ心配もあつたし、それに私の喋舌り出すと止められない、つまらないことにでも力を入れたりする質が却々そこを退かうともした私を許さなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、もう止め止め。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども（義理の）祖母の手前何時も母は「それだけはお止しなさい」と言つて今迄止めて来てゐるわけだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は弟に断つて止めようとした。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんなら傭入の方は当分止めるだらうに、――いゝえその方は相変ず従前通といふ仕末であつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ「惡靈」だけは、どういふものか興味がないので途中で止めた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の再建される文壇は、再度もはや過去のやうに、流行のハシリを追ふ稚態を止め、正しい認識によつて外國の古典文學を讀むべきである。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば菓子屋、植木屋、吹屋、射的場の前には、今一客を止めず。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中は縁側の戸を一枚々々としめて行って残る一枚を半ばで止め、暗い庭の方をじっと見ている。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は将軍のビオルン（熊）に「鋼鉄のかみつけないこの犬（フンド）はお前が仕止めてくれ」と言った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "震災に焼けなかったお蔭で、ぼろぼろにはなったが、昔の姿の名残を止めている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も陳列所前の砂道を横切って向いの杉林に這入るとパノラマ館の前でやっている楽隊が面白そうに聞えたからつい其方へ足が向いたが丁度その前まで行くと一切り済んだのであろうぴたりと止めてしまって楽手は煙草などふかしてじろ／＼見物の顔を見ている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅員の不機嫌顔甚だしきも官線はやはり官線だけの権力とか云うものあるべしと、かしこみて願い奉りようよう切符を頂戴して立ちいずれば吹き上ぐる朝嵐に藁帽飛んでぬかるみを走る事｜数間、ようやく追い付きて取止めたれど泥にまみれてあまり立派ならぬ帽の更に見ばえを落したる重ね／＼の失敗なり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は西洋人も婦人まで草鞋にて登る由なりなどしきりに得意の様なりしが果ては問わず語りに人の難儀をよそに見られぬ私の性分までかつぎ出して少時も饒舌り止めず、面白き爺さんなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな取止めもない事では雑誌に載せて頂くのは如何かと存じますが御返事までに申上げます、どうか悪しからず願います。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それだけにまた、自分にとっては三十余年前の冬のある曇り日のこの珍しい体験が、過去の想い出の中に聳え立った一里塚のように顕著な印象を止めているものと思われる。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような取り止めのない妄想に耽っている間に、老人の淋しい影は何処ともなく消え去った。",
              "citation": {
                "source": "凩",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "惜しい事には歳が歳であったから見もし聞きもした場所も事実も、二昔も程遠き今日からふりかえって考えてみると夢のような取り止めも付かぬ切々が、かすかな記憶の糸につながれて、廻り燈籠のように出て来るばかりで。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し快くなる頃はもう外へ遊びに出ようとする、それを引き止めるための玩具がまた増した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源はフト郭光との話を止めて上機嫌で「アヽそうか、すぐこれへ」と口ばやに言つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に倉橋君が来る、晃平を殿として、一行が揃う、こう霧がひどくては、方角も何も解らない、晃平は荷を卸して、路を捜索に出たが、無益に戻って来た、岩の間を点接して、トウヤクリンドウ、ミヤマキンバイ、ミヤマウスユキソウ、チングルマなどがあったが、風と霧と雨の中で、一々眼に止めていられない。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今川家御朱印（天文二十四年）にも、村山室中で魚を商なってはならぬとか、不浄の者の出入を止めろとか禁制があって、それには、この村山なる事を明示している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "境内は、塵一つとどめず掃き清められていた。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
