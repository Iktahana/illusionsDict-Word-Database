    "definitions": [
      {
        "index": 1,
        "gloss": "worthy of special mention",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
