[
  {
    "uuid": "840d1d76-e9e5-5c93-98e4-13a1307dc235",
    "entry": "飛び越す",
    "reading": {
      "primary": "とびこす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
