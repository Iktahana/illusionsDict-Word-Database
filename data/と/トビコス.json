    "definitions": [
      {
        "index": 1,
        "gloss": "to leap over",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "よいしょ、と小さい声で言ってみて、路のまんなかの水たまりを飛び越す。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川を躍り越せば女も飛び越す。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであっしが追っかけて行き、キューッとしぼったは中条流、ピョイと飛び越すと朱舜水様葵のご紋もおいでなさる。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ものに溺れやすい安知には、そんな銭勘定を飛び越すくらゐは何でもなかつたのです。",
              "citation": {
                "source": "利休と遠州",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "行動主義と自由主義については、その前に飛び越すわけには行かぬ民族の問題があるから、今は一先ずこれにはペンをつつしもう。",
              "citation": {
                "source": "純粋小説論",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "心にこれだけは云ってはならぬぞと、云いきかせた二人の慎しみの裂け口を飛び越す思いであった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "スウェターに首を突込んで、靴下を穿いて、帽子を引っ掴むと、梯子段の途中に引っかかっている女将の巨体を飛び越すようにして上り框から半靴を突かけると表の往来……千代町の電車通りに飛出した。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は猶予なく三尺ばかりの亜鉛壁をヒラリと飛び越すと、恰も係りの者であるかのように落ち着いた態度で、馬をいじり初めた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵ありと知った後の二人が、踵を返して逃げようとするのを追い縋って横撲り、一人の両足を払って置いて、倒れるのを飛び越すと、最後の一人を背中から田楽刺しに貫いた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをピョンと飛び越すのである。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを復ピョンと飛び越すのである。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをピョンピョン飛び越すのである。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう其頃には人間の方も、それを平気で飛び越す程の力量が備わっているのである。",
              "citation": {
                "source": "鵞湖仙人",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "針箱と糸屑の上を飛び越す樣に跨いで茶の間の襖を開けると、すぐ座敷である。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の女になるには坊主になるよりもつと苦しい一線を飛び越す必要がある。",
              "citation": {
                "source": "エゴイズム小論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "統一も連絡もなく各々の道を走つたが、鉄砲を知らぬ朝鮮軍は単に屍体を飛び越すだけの邪魔となつたにすぎなかつた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "苔のない柔い地面から匐い出している蚯蚓を、庭下駄に踏み潰すまいとしてひょいと飛び越すと、すぐ眼の前の茂みから、親指大の赤い椿の蕾が覗いていた。",
              "citation": {
                "source": "人の国",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀右衛門はもと丹後の小野木縫殿助の家来で、忍びの名人として天下に聞こえ、大力の上に早業をよくし城の塀など飛鳥のように飛び越す武人であったが、小野木家滅後細川家へ仕えたのである。",
              "citation": {
                "source": "酒渇記",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の上を飛び越すのです。",
              "citation": {
                "source": "相川おけさ",
                "author": "村松おけさ、佐渡牛などのこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤より樺、樺より黄、黄より緑と、順々に移り行くだけで、急に段が付いて、一の色から他の色に飛び越すごとき所はどこにも見つからぬ。",
              "citation": {
                "source": "境界なき差別",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼と同じ年ごろの子供たちが、土手へはい上がったり、茶の木の蔭にかくれたり、みぞをおもしろそうに飛び越すのなどを、そばでぼんやりとながめながら、「おれも、あんなようにして遊びたいものだな。",
              "citation": {
                "source": "高い木と子供の話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その割れ目は、飛び越すことも、また、橋を渡すこともできないほど隔たりができて、しかも急流に押し流されるように、沖の方方へだんだんと走っていってしまったのであります。",
              "citation": {
                "source": "黒い人と赤いそり",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "小出しに嘘をつかずに一ぺんでそれを飛び越すには、断乎たる手段をとらなければならぬ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と仰天し、手負いの馬子を飛び越すと、街道を向こうへ突っ切ろうとした。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幅は五、六尺に過ぎないが、平滑なる表面には手掛りも足掛りもなく、向う側はまた岩壁であるから一思いに飛び越す訳にも行かぬ。",
              "citation": {
                "source": "八ヶ峰の断裂",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽根の落ちたのを一本拾うために、小川を七度飛び越すくらいの娘でなけりゃ、お嫁に行けないというくらいです」――フィリップが言う。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "超えてはならない階段を無躾に飛び越すようにも思われた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "針箱と糸屑の上を飛び越すように跨いで、茶の間の襖を開けると、すぐ座敷である。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕われたものは徒に人屋の軒から、故郷を慕って、両の臂を開いて歎くのに、放たれたものは8625羽が生えたように、どんな艱難をも飛び越すのではありませんか。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき、そりがとびあがるのは、生がきや、おほりの上を、とびこすのでしょうか、カイはまったくふるえあがってしまいました。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
