          "literary": [
            {
              "text": "『程氏遺書』に曰く、犬屠人を吠ゆ、世に伝う、物ありこれに随うとは非なり、これ正に海上の鴎のごときのみと。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際に疲労で眼だけではなく、皮膚も乾いていて、横になるとじんじんと血が廻るのが判った。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごめんだよう、とじんの悲鳴が聞える。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにってやんだい、くそばばあ、とじんは嘲笑する、へっへっへだ、死んじまえ――。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
