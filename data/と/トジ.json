    "definitions": [
      {
        "index": 1,
        "gloss": "lady",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かんこちりめんといふ、これは苦労して働いた家刀自の愛のやうな感じのちりめんで、やはりその頃母の古着のなかにあつたやうに覚えてます。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶寮には灯のはひり、石いくつ水うつあひだ、彼方見て、もの言ひてます物ごしのあはれ、よくぞ似る妻が母刀自、子らにもけだし。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "南湖院｜潮騒ひくし春もやや闌けにつつありて人は果てたり臨終まで我をたのめと沙汰せよと待ちまけし君をひとり死なしぬ死顔の神さぶ見れば灯をつけて揺るるコードの影か隈だつ電気火葬仏は義妹富子の母刀自、落合火葬場にて。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風の寒く吹くなべ竹籃にひしこ持ちて來とほき濱びゆ髪十月の末母の命によりて成田山にまうで毛綱を見て作れる歌并短歌母刀自の依しのまにま。",
              "citation": {
                "source": "長塚節歌集　上",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、各の引退き、戸を閉た後ち、其役目の刀自が來て、指もて手際よく嫁の素を破り、布に其血を受て、其婦徳に過ち無りしを壻に示す。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として、壻が刀自に信頼せず、自ら之を行ふ事あり。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "九歳十歳の女は、刀自之を破り、十三歳の女は壻に破らる。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し、男精と女血の混ずるを忌むにより、刀自二人男の側にあり、事畢るに臨み、男を曳き退け外に泄さしむと。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも白山へ来訪をうけた尼｜刀自へ返礼に出向いたいのに、いつわりはないのですが、そんな事はどうでもいい。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と尼刀自が洒落れた。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "古くさい書物｜棚から、唐守、藐姑射の刀自、赫耶姫物語などを絵に描いた物を引き出して退屈しのぎにしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "蓬生",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十位の中老の刀自が熱心な熱心な敬神家で、この勤行のさまは、人の心を動かすに足りるものがあつた。",
              "citation": {
                "source": "初冬の記事",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "九十の老齢で今なお病を養いつつ女の頭領として仰がれる矢島楫子刀自を初め今は疾くに鬼籍に入った木村｜鐙子夫人や中島湘烟夫人は皆当時に崛起した。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、先日来、大隈未亡人｜綾子刀自が御重体であると新聞紙上で承り、昔、お見知りの人のことで、蔭ながらお案じしていた次第であったが、今朝（大正十二年四月二十九日）の新聞を見ると、お歿なりになったそうで、まことに御愁傷のことである。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにつけて、この頃、綾子刀自の素性のことについて、いろいろ噂を聞いたり、また新聞などで見たりしますと、元、料理屋の女中であったなど、誰々の妾であったなどというようなことが伝えられているが、そういうことは皆間違いで一つも拠処がない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "という訳は、その因縁を話しませんと分りませんが、実は、私は、昔、綾子刀自の娘盛りの時代を妙なことで能く知っている。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事を話せばおのずから綾子刀自の素性が明らかになることで、何時か、この事を何かのついでに話して置くか、書き留めて置きたいと思っておったことであったが、今日はちょうどよい折とも思いますから一通り話しましょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が綾子刀自について知っている因縁ばなしというのはこれだけのことで、そのほか何もありません。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は、刀自が初縁の際の見合いに仲介人の師匠のお伴までしてその席を実見したほど、その時代のことを能く知っており、正銘疑いなしの話である。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、大隈家へ再縁されたと申しても、事情は前申す通りの訳で、一向処女というに変りはないことで、刀自の身上に何ら潔白を傷つける次第でもありませんが、御当人、およびその御良人の存生中は善悪ともに他人のとかくをいうべきはずもないことと、実は口を緘しておったわけであります。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大隈綾子刀自の思い出",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それまで蒼求の火を消さないで持つて歩いたといふお話でせうね」とこの話をきいた友達がある時言つたが、蒼求の火はもとより、その時の道伴れであつた家刀自はもはやない。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く赴いて、早く引捕えられるものなら、帯刀自身で出馬してもらいたいものであると思った。",
              "citation": {
                "source": "くろがね天狗",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは広岡浅子｜刀自で、刀自は日本服などは賢い人間の着るべきものでないといふので、始終洋服ばかりつけてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃のやうな寒さには、刀自は護謨製の懐中湯たんぽを背中に入れて、背筋を鼠のやうに円くして歩いてゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮川氏が素晴しい雄弁で日本が明日にも滅びてしまひさうな事を言つて、大きな拳骨で卓子を一つどしんと叩くと、刀自は感心の余り椅子に凭れた身体にぐつと力を入れた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮川氏のお説教を聴きながら、自分ひとり洋服のまま天国に登つた気持で居た刀自は、吃驚して立ち上つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "刀自は宮川牧師を振り向いて言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の寒さに早稲田の応接間で、口を歪めて縮かまつてゐる大隈侯の夫人綾子｜刀自である。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡広岡浅子夫人１・23（夕）　広岡浅子｜刀自が亡くなつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一ばん大事のことじゃないか。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
