    "definitions": [
      {
        "index": 1,
        "gloss": "mountaineering boots",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
