[
  {
    "uuid": "b2c70a8b-676b-58e2-b0f5-2289c23f41a3",
    "entry": "都鄙",
    "reading": {
      "primary": "とひ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
