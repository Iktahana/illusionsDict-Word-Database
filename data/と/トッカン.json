[
  {
    "uuid": "df3baba0-ae64-5f65-8312-af61b63a7a3f",
    "entry": "突貫",
    "reading": {
      "primary": "とっかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "charging (at the enemy) with a shout",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "『ほれ喧嘩だ』と、云ふとドツと一時に動搖めいて一崩れ、ばたばたと男の後を追うて、津浪が押し寄せた樣、逸早く合點した連中は、聲を擧げて突貫した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「突貫」　楢夫は愕いてしまいました。",
              "citation": {
                "source": "さるのこしかけ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひい、と泣いて雲に透る、……あはれに、悲しげな、何とも異樣な聲が、人々の耳をも胸をも突貫いて響いたのである。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "署長はまるで突貫する兵隊のやうな勢でその奥の室へ入った。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たちの起した戦争の中へはいってわれらの敵国を打ち亡ぼせと云って鉄砲や剣を持って突貫しますか。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後からゆっくり来いというので、一同疲れし膝栗毛に鞭を加え、力声を揚げてぞ突貫する。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "横断隊は未醒子、髯将軍、衣水子、木川子、これから日本海沿岸まで山中の突貫旅行をやるのである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "剛健強勇を生命とする快男子は、須らく太陽に向かって突貫し、その力ある光勢を渾身に吸込む位の元気が無ければ駄目じゃ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩の今回の旅行はこれで終ったが、横断隊は勇気｜勃々として突貫旅行を続けている。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は熱海の駅で汽車を待っているあいだに、休み茶屋へ飛び込んで、ビール一本と何だかの罎詰一本、まさかに喇叭は遣らないけれども、息もつかずにぐっと聞こし召して、その勢いで猛烈に、かかる山路へ突貫して来たのよ。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんのアア王と弟のサア王はこれを見ると、「それ、あいつを弓で射ち殺せ」「刀でたたき殺せ」　と云いましたので、両方の兵隊は一時に岩の下へ突貫して来ました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしは、突貫しますよ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "直さそこに、すくすくと山の形さあらわれて、暗の中｜突貫いて大幅な樹の枝が、※のあいだに揺ぶれてな、帆柱さ突立って、波の上を泳いでるだ。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………）「焼火箸を脇の下へ突貫かれた気がしました。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の屋根を突貫いた榎の大木が、大層名高いのでございますが、お医者はどういたしてかちっとも流行らないのでございましたッて。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば小樽の人の歩くのは歩くのでない、突貫するのである。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の歩兵は突貫で勝つ、しかし軍隊の突貫は最後の一機にだけやる。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から晩まで突貫する小樽人ほど恐るべきものはない。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "小樽人とともに朝から晩まで突貫し、小樽人とともに根限りの活動をすることは、足の弱い予にとうていできぬことである。",
              "citation": {
                "source": "初めて見たる小樽",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "狩野派、土佐派、何々流式の線や色の主張も、飄逸も、洒脱も、雄渾も、枯淡も棄て、唯一気に生命本源へ突貫して行く芸術になってしまった。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お綾が、つかつかと屋根へ出て、狼狽えてその少年の下りる処を、ぐいと突貫いたが、下腹で、ずるり腸が枝にかかって、主は血みどれ、どしんと落ちた。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひい、と泣いて雲に透る、……あわれに、悲しげな、何とも異様な声が、人々の耳をも胸をも突貫いて響いたのである。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八方塞がりになったら、突貫して行く積りで、なぜ遣らない。",
              "citation": {
                "source": "かのように",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "個性の緊張は私を拉して外界に突貫せしめる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "云う迄もなく震災後には特別に繁華になったので、雨天の時なぞ、こんな自動車が警察｜除け（これは自動車のタイヤの横に警察の命令で取り付けたハネ押えの異名で、何の役にも立たぬが多いから、運転手仲間でこう名付けている）をふりまわしながら、電車と一所に泥煙を揚げて群衆に突貫して行く光景は、壮観？",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
