[
  {
    "uuid": "6f681224-7b8b-5279-a35c-c896b535a5c9",
    "entry": "蕩ける",
    "reading": {
      "primary": "とろける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
