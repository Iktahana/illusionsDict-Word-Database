    "definitions": [
      {
        "index": 1,
        "gloss": "it is written that ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（間）女　（男の机の上をみながら）あの手帖あなたの日記ね――「退屈者の手帖」と書いてあるぢやないの？",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん目に止るのは足の方の鴨居に笠と簑とを吊して笠には「西方十万億土順礼　西子」と書いてある。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白いことは横町の入口の両脇の角に「ユヤ」「床ヤ」と書いてある。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人の家にありたきは、梅櫻松楓、それよりは金銀米錢ぞかし、庭山にまさりて庭藏の眺め、」と書いてある。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨牌のような札の片側には「自」反対の側には「他」と書いてある。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸子へ参りました」　なるほど障子に名物とろろ汁、と書いてある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジョバンニは、白鳥と書いてある停車場のしるしの、すぐ北を指しました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『春色梅暦』では、丹次郎を尋ねて来る米八の衣裳について「上田太織の鼠の棒縞、黒の小柳に紫の山まゆ縞の縮緬を鯨帯とし」と書いてある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば「大蛇」というような場合に『古事記』では「遠呂智」と書いてあり『和名抄』では「乎呂知」と書いてある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずいつでも「己」であるという訳には行きませぬが、尠くも一方「遠能」と書いてあるものとは同じ語ではないということは言える。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ししこ」と書いてあるのは「死にし子」で、「し」は過去を表わす助動詞、「死にし」が音便で「しんじ」となったものと思われます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「日記」を「にき」と書いてあるのも、これはすこぶる疑問でありまして、文字通り「ニキ」であったか「ニッキ」であったか、「ニッキ」というような促音は、これを書きあらわす方法がなかったものでありますから「にき」と書いていたのか、これは大分疑問だと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに関するレーリーの手紙に「スペクトロスコピーの泥沼に踏込むことになっても困るが」と書いてある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が洋行の際に持って行って帰った記念品で、上面にケー・ナツメと書いてあるのを、新調のズックのカヴァーで包み隠したいかものであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また小さいことではあるが「けちな放蕩」と書いてある。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度広げてある一冊の中には ｜PLATON, SYMPOSION と書いてある。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "その図には「父よ、彼等に免し給へ」云々と書いてある。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "その表紙には『忘れ得ぬ人々』と書いてある。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見ると一と息で登れそうな気がするが、上り口の立て札には頂上まで五時間を要し途中一滴の水もないと書いてある。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の音がどんどんと響くからどんどんというので、江戸の絵図には船河原橋と書かずにどんど橋と書いてあるのもある位です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯には深川船宿｜於加田と書いてある。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うて筋違、角から二軒目に小さな柳の樹が一本、その低い枝のしなやかに垂れた葉隠れに、一｜間口二枚の腰障子があって、一枚には仮名、一枚には真名で豆腐と書いてある。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "現にある学者の書には、明らかにマライと邦語の関係はたいしたものでないと書いてある。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか聞きとれない言葉が出て来たので帳面を見せてもらうと‘fitots’‘stats’と書いてある。",
              "citation": {
                "source": "異郷",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この新聞記事を読んだ人は相当な人でも、あたかも「椿の花の落ち方を見て地震の予知ができる」と書いてあるかのような錯覚を起こす。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物理学の初歩の教科書を見ると、地球重力による物体落下の加速度は毎秒毎秒九・八メートルであると書いてある。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――処へ、土地ところには聞馴れぬ、すずしい澄んだ女子の声が、男に交って、崖上の岨道から、巌角を、踏んず、縋りつ、桂井とかいてあるでしゅ、印半纏。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮田からだと思って、裏を返すと村川生とかいてある字が、鋭い短剣のように、京子の眼を突き刺した。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、そのノートの表紙に、ペンで青木淳とかいてあるらしいのを見ると、ハッと思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "H Nev とかいてあるらしいが、この「エッチ・ネブ」という綴りを上の「デズ」に加えてみると俄然、DEZHNEV となって、それで一つまた解けた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
