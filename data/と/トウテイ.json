[
  {
    "uuid": "4565451b-78e6-5f02-9051-a8ee1cfa0e26",
    "entry": "到底",
    "reading": {
      "primary": "とうてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
