          "literary": [
            {
              "text": "南ア興業銀行が取り付け騒ぎを起こしている。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、同行は取り付け騒ぎになっており、いますぐ二百万ポンド欲しい。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっきりしたのはどの銀行もあすは同じ取り付け騒ぎの目に会うはめか。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方銀行も多数取り付け騒ぎがあった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあしたイングランド銀行が取り付け騒ぎにでもなったら」「考えもつかなかったぜ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀行の取り付け騒ぎが容赦なく始まった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、大国立銀行が取り付け騒ぎ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "イングランド銀行が取り付け騒ぎだ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世の語り草として、イングランド銀行の取り付け騒ぎを見たとなろう。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
