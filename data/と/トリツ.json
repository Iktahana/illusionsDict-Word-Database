        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "京都立命館中学に転校す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "繁ちゃんは六年生、浩ちゃんと善ちゃんは都立×中の一年生、巖ちゃんは××商業の一年生である。",
              "citation": {
                "source": "おにおん倶樂部",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの都立の産院だか、病院だかで、捨子公認所をつくったそうだが、こういう工夫をいろいろとやる方に頭を使うべきである。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯晴彦は去る九日首尾よく都立十二中（千歳中）の入学試験に合格した。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十九日（水曜）　京都立。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "都立日比谷図書館の場合、図書は一三万冊で、一日の入館者はおよそ二〇〇〇人だと言う。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神病者を対象にして儲けようなんて、怪しからん」　赤木医師が推挙したのは、都立のＭ病院です。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで馬を止め、「やよ船田ノ入道、朝敵退治の都立ちには古例がある。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "同日から三日おくれの都立ちで、尾張黒田から東山道をとって下って行った別手の搦め手軍もあった。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、三軍の総帥としては、勅を拝しながら、その都立ちも遅れてはいた。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして馬場のひとりごととは千里万里もかけはなれた、つまらぬ感傷にとりつかれていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り片附きすぎてとりつき端がなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女が化粧えば一層の匂いを増し醜女がとりつくろえば、女性らしい苦労が見えて、その醜なのが許される。",
              "citation": {
                "source": "女性の不平とよろこび",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一生けん命で甲板の格子になったとこをはなして、三人それにしっかりとりつきました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木にとりつくと弾ね返ってうしろのものを叩くというのだろうか。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製板の小屋の中は藍いろの影になり、白く光る円鋸が四、五｜梃壁にならべられ、その一梃は軸にとりつけられて幽霊のようにまわっていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはいまにだんだん深い処へさえ来れば、兵隊たちはたてがみにとりついて泳ぎ出すだろうと思って待っていました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬の横腹から頬の辺まで、雨上がりの泥濘がべっとりついて塗り立ての泥壁を見るようである。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とにかくあいつら二人は、おれにたべものはよこすが、時々まるで北極の、空のような眼をして、おれのからだをじっと見る、実に何ともたまらない、とりつきばもないようなきびしいこころで、おれのことを考えている、そのことは恐い、ああ、恐い。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは豪雨のときに氾濫する虞れの多い溪の水からこの温泉を守る防壁で、片側はその壁、片側は崖の壁で、その上に人々が衣服を脱いだり一服したりする三十畳敷くらいの木造建築がとりつけてあった。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日暮々々に水そゝげば此草とりつく便あるに任せて蔓をのばし、はや六月の初め、ひと花咲きそめて白きひを洗ひ捨てゝ四方山を見るに、さりとは口惜しや一銭つかはで是ほど面白く風情ありしことを知らず、もたれたる遊びに金銭を費して無益の年月を送りけるよと、今ぞ心のほこりを掃ひける。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたものが自分の皮膚にとりついていると想像すればぞっとするのは当然かもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうたくさん、なんて断っているお嬢さんや何か、あれは、ただ、色気があるから体裁をとりつくろっているだけなのよ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木にとりつくと弾ね返ってうしろのものを叩くといふのだらうか。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "製板の小屋の中は藍いろの影になり、白く光る円鋸が四五｜梃壁にならべられ、その一梃は軸にとりつけられて幽霊のやうにまはってゐました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちはいまにだんだん深い処へさへ来れば、兵隊たちはたてがみにとりついて泳ぎ出すだらうと思って待ってゐました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブン蛙とベン蛙がくるりと外の方を向いて逃げようとしましたが、カン蛙がピタリと両方共とりついてしまひましたので二疋のふんばった足がぷるぷるっとけいれんし、そのつぎにはたうとう「ポトン、バチャン。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "上を見ると、まるで小さな円い空が見えるだけ、かゞやく雲の峯は一寸のぞいて居りますが、蛙たちはもういくらもがいてもとりつくものもありませんでした。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもお前はかまはず僕の足さきにとりついたんだよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりついたんぢゃないよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
