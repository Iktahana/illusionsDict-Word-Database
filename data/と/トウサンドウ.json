[
  {
    "uuid": "97fcadc1-8f45-5e7f-a9be-ba539accc16f",
    "entry": "東山道",
    "reading": {
      "primary": "とうさんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
