[
  {
    "uuid": "089dff98-dcfa-50bc-82ed-1ed675c1e68b",
    "entry": "登壇",
    "reading": {
      "primary": "とうだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
