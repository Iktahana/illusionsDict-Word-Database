    "definitions": [
      {
        "index": 1,
        "gloss": "far",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "牧野さんといふ人は、恋愛に殉じる態の純情家といふものとは遙かに縁遠いと思はれるからだ。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の遠い祖先のスペインの血は、その顔にも現れて、はげしい苦闘的なものを印してゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この侘しく灰色なる空の下に私たちの心はまづしく語り　孤獨になやみて重たくよりそふ少女よあの遠い空の雷鳴をあなたは聽くかかしこの空にひるがへる浪浪の高いひびきをあなたは聽くか。",
              "citation": {
                "source": "眺望する",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは日本でもない、支那でもない、大層遠い遠い見知らぬ国へ、長い旅をした夢であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の国々を漂泊して、ついに心の郷愁を慰められなかった旅人ヘルンは、最後にまたその夢の中で漂泊しながら、見知らぬ遠い国々を旅し歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつかの坂を越えて、遠い「時代の旅人」はそこを登るであらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな遠い思ひ出になりました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな遠い思い出になりました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのなあ、遠い親類の主人が死んだんださうだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「誰の遠い親類か――分るやうに言へ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し斯の如き間抜野郎によつて、実感は実践的意味といふものから可なりに遠いであらう。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故かというに、俳句の一般的特色として考えられる、あの枯淡とか、寂びとか、風流とかいう心境が、僕には甚だ遠いものであり、趣味的にも気質的にも、容易に馴染めなかったからである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一言にして言えば、それは時間の遠い彼岸に実在している、彼の魂の故郷に対する「郷愁」であり、昔々しきりに思う、子守唄の哀切な思慕であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の咏嘆しているものは、時間の遠い彼岸における、心の故郷に対する追懐であり、春の長閑な日和の中で、夢見心地に聴く子守唄の思い出である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の詩情には、古い故郷の家を思わせるような、あるいは昔の祖母や昔の家人の、懐かしい愛情を追懐させるような、遠い時間への侘しいノスタルジアがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論現実的の憂愁ではなく、青空に漂う雲のような、または何かの旅愁のような、遠い眺望への視野を持った、心の茫漠とした愁である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村はいつも、寒夜の寝床の中に亡き母のことを考え、遠い昔のなつかしい幼時をしのんで、ひとり悲しく夢に啜り泣いていたような詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飄々として唸りながら、無限に高く、穹窿の上で悲しみながら、いつも一つの遠い追憶が漂っている！",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村特有の人情味の深い句であるが、単にそれのみでなく、作者が自ら幼時の夢を追憶して、亡き母への侘しい思慕を、遠い郷愁のように懐かしんでる情想の主題を見るべきである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば藪入やよそ目ながらの愛宕山藪入のまたいで過ぬ凧の糸　など、すべて同じ情趣を歌った佳句であるが、特にその新体風の長詩「春風馬堤曲」の如きは、藪入の季題に托して彼の侘しい子守唄であるところの、遠い時間への懐古的郷愁を咏嘆している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句に主題されている詩境もまた、前の藪入の句と同じく、遠い昔の幼い日への、侘しく懐かしい追憶であり、母のふところを恋うる郷愁の子守唄である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち蕪村は、その藪入りの娘に代って、彼の魂の哀切なノスタルジア、亡き母の懐袍に夢を結んだ、子守歌の古く悲しい、遠い追懐のオルゴールを聴いているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポオの無韻詩「大鴉」の表現効果は、あのねえばあ・もうあとか、れのああとかいふ言葉の、寂しく遠い、墓場の中から吹いて来る風のやうな、うら悲しくも気味の悪い音韻の繰返す反響にある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の遠い先祖は、冬の来る前に穴を掘り、熊や狐やの獣と共に、小さくかじかまつて生きたへて居た。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の日本は、太平の世を去る事あまりに遠い。",
              "citation": {
                "source": "喫茶店にて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎年夏始めに、程近い植物園からこのわたりへかけ、一体の若葉の梢が茂り黒み、情ない空風が遠い街の塵を揚げて森の香の清い此処らまでも吹き込んで来る頃になると、定まったように脳の工合が悪くなる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋の煙突から吹き出る真赤な焔が黒い樹に映えて遠い森の上に青い月が出ている絵も欲しかったが、何となく静かなこの「森の絵」にきめた。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と空の深い透明な色を見ていると、何かしら遠いゆかしいような想いがするのを喜んで買った。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音楽の布いて行く地盤の上に、遠い昔の北国の曠い野の戦いが進行して行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　マギイ婆さんとおいぼれがやって来た。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
