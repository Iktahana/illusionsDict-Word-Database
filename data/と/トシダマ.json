    "definitions": [
      {
        "index": 1,
        "gloss": "New Year's gift",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
