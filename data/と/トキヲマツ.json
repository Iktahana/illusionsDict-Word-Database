[
  {
    "uuid": "4bb2af35-e19c-596f-aa97-64b2e476c106",
    "entry": "時を待つ",
    "reading": {
      "primary": "ときをまつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "Godan verb with 'tsu' ending"
      ],
      "ctype": null,
