        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○竹屋の渡場は牛の御前祠の下流一町ばかりのところより今戸に渡る渡場にして、吾妻橋より上流の渡船場中最もよく人の知れるところなり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊女の句に名高き○駒形の駒形堂を右に見、駒形の渡船場を過ぎ、左には長屋｜越に番場の多田の薬師の樹立を望みて下ること少許すれば○厩橋に至る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "○百本杭は渡船場の下にて、本所側の岸の川中に張り出でたるところの懐をいふ。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船場の下数町にして○新大橋あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台堀入口より中洲へ渡るの○中洲の渡船場あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船場の下一町余にして復小渠の東南に入るあり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船場より下、町余にして二水の北西より来るを見る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "船松町佃島の間には渡船場あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に久慈川のとある渡船場付近では、見上ぐる前方の絶壁の上から、巨巌大石の夥しく河岸に墜落しているのを見る。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この渡船場で滑稽な事があった。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずつと見通しの、油堀から入堀の水に、横に渡した小橋で、それと丁字形に、眞向うへ、雨を柳の絲状に受けて、縱に弓形に反つたのは、即ち、もとの渡船場に替へた、八幡宮、不動堂へ參る橋であつた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さあ、あの渡船場に迷つたのだから、よくは分らないが、彼の邊だらうね。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永喜橋――町内持ちの、いましがたの小橋と、渡船場に架けた橋と、丁字形になる處に、しばらくして私たちは又たゝずんで、冬木の池の方を振返つたが、こちらからは、よくは見通せない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道開通以来、土地の人が頑固で、折角の停車場の設置を肯ぜなかったばかりに、木曾下流の渡船場として殷賑であったこの笠松街道もさっぱり寂れてしまったということであった。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "折ふし向岸の諏訪下の渡船場より早船にて、漕ぎ渡し来る数十人の捕吏の面々を血刀にてさし招きつゝ、悠々として大文字山に登り隠れ、彼の大判小判の包みと、香煙の器具一式とを取出して身に着け、鞘を失ひし脇差を棄てゝ身軽となり、兼ねてより案内を探り置きし岨道伝ひに落ち行く。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに山崎の家のある所へ出るには、どうしても手塩川を渡らなければならないので、河｜彼方にある渡船場の人を呼ぶには、よほど大きな声を出さなければならなかった、それに手塩川はこの辺に来てかなり河幅を増していた。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合馬車の御者ヴァランス（原注一二）もまた、今度証言したところによると、彼はマリー・ロジェエが例の日曜日に、セーヌ河の渡船場を顔色の浅黒い若い男と一緒に渡って行くのを見た。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは到頭渡船場まで來た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘作はこの河ではないかと思って、渡船場におりようとする河土手になった林の中を注意して歩いていた。",
              "citation": {
                "source": "ある神主の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「渡船場だべ、こゝ？",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角、私達は峠を下りて、磯の近くにある渡船場の方へと行つた。",
              "citation": {
                "source": "ある日",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここではかみさんがわざわざ通りに出て渡船場に行く路を教えてくれた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日ばかりの月が向こう岸の森の上に出て、渡船場の船縁にキラキラと美しく砕けていた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "成善がその駕籠に乗って、戸田の渡しに掛かると、渡船場の役人が土下座をした。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "独乙に有名なウヰーランドという文学者がいたが一日ネーカーの渡船場を渡ろうとする時かつて同行した二友のことを思い起した。",
              "citation": {
                "source": "イエスキリストの友誼",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "拓くと中に北川氏の「渡船場附近」という短篇が見えてゐる。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡船場で、人を轢き殺して来た大群集のまん中を通るのは、かういう妙音でなければ渡れない。",
              "citation": {
                "source": "詩集『花電車』序",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手に友太郎の手を索いて、程近い渡船場｜際の医者の家へ辿り付いたものだが、その苦心といったらなかったよ。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日月島の渡船場で一緒に乗ったよ。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
