    "definitions": [
      {
        "index": 1,
        "gloss": "it is not possible (to, that)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「別にどうと言うことはない。",
              "citation": {
                "source": "雪の日",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "「死ぬまでは休息と言うことはない。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、えらそうに「人間」などと言うことはない。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたんだと聞いたら、従兵はすこし気味悪そうな顔をして、どうと言うことはないが何となく変だ、と答えた。",
              "citation": {
                "source": "赤い駱駝",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし元来「詩」というものは、和歌も俳句も新体詩も、すべて皆ポエジイの本質において同じであるから、一方の詩人は必ず一方の詩を理解し得べきはずであり、原則的には「専門」ということはないはずである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふた親は、自分たちのことに就ては「わたし達は、何ということはない平凡なものさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も靴下もポケットに入っているし必ず下らなければならないということはない、けれどもやっぱりこっちを行こう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「政夫さん……私野菊の様だってどうしてですか」「さアどうしてということはないけど、民さんは何がなし野菊の様な風だからさ」「それで政夫さんは野菊が好きだって……」「僕大好きさ」　民子はこれからはあなたが先になってと云いながら、自らは後になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民さん、なんです、そんなにひとりで笑って」「政夫さんはりんどうの様な人だ」「どうして」「さアどうしてということはないけど、政夫さんは何がなし竜胆の様な風だからさ」　民子は言い終って顔をかくして笑った。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな小さい花でございまして、どれもぱっと開いてしまうということはないのでございます。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "面白くないということはないが、さりながら娯楽の目的には、ちと叶わないようなものである。",
              "citation": {
                "source": "夜の隅田川",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的がなくて学者が旅行をするということはない、必ず目的があるのだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほんとかって、あなたがそれを知らんということはない、だけれども知らなかったらそれまでの話です、もうあなたも知ってみればこの後の方法をつけんじゃア』『どうすればええだろう？",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "雫は一ぱいにたまって全く今にも落ちそうには見えましたしおまけに二度あることは三度あるとも云うのでしたから少し立ちどまって考えて見ましたけれどもまさか三度が三度とも丁度下を通るときそれが落ちて来るということはないと思って少しびくびくしながらその下を急いで通って行きました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟愛の発露を控目にしてよいということはないのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の悪口ということはない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにも、あいつらの思いどおりになっていなければならないということはないのだから）　正勝は黙々として、妹の蔦代をいかにして逃がしてやるかについて考えつづけた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の妹を他人の家に預けておいて、妹がいくらかでも世話になっていると思ったら、黙って逃げていったというのに兄たるおまえが一言の挨拶もしないということはないじゃないか？",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけはどんなことがあっても、ただの星とちがって、手の下からすべって消えていくということはないからな。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭だよ、どこの誰に憚って秘すッということはないけれども、そりゃ不可いや。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の親を思う情だからって何だからって、いたわってくれるということはない。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "死の因、死の縁は種々無量であるが器分の破壊欠損なしに死ぬということはない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは一ツの例えに過ぎないが、聖賢伝来の教は稼業の道などで述べ尽くすことが出来ないは勿論であるが、例えて言えば、何時いかなる処にも道が無いということはない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかこちらの好意がむだになるということはないはずですよ」　老いた女どもはそう決めてしまった。",
              "citation": {
                "source": "源氏物語",
                "author": "末摘花",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪しげな宗教がひろまるのはいつもこの手なんだが、群集というものは、信ずるか信じないかのどちらかで、批判するということはないものだ。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の下をとおり、本棟うらの土手下を抜ける道は、べつにどうということはない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの市民がちゃんと家賃を払って生活しているのに、お前たちだけ出来ないということはない。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんということはない。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、どんなに勉強しても、勉強しすぎるということはないのです。",
              "citation": {
                "source": "『火星兵団』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は心理学上より見て、思惟も純粋経験の一種であることを論じたのであるが、思惟は単に個人的意識の上の事実ではなくして客観的意味を有っている、思惟の本領とする所は真理を現わすにあるのである、自分で自分の意識現象を直覚する純粋経験の場合には真妄ということはないが、思惟には真妄の別があるともいえる。",
              "citation": {
                "source": "善の研究",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
