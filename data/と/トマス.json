    "definitions": [
      {
        "index": 1,
        "gloss": "kanji radical 68 at right",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此時三つ斗りなる兒の、小く太りたるが、大きなる大人の下駄を引きずりて、縁先近く參りたる、覺束なき足もとなり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも机の抽斗には小さな鏡が入れてあって、時によると一時間もランプの下で鏡を睨めている事がある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表装でもしておくといいと思いながらそのままに、色々な古手紙と一しょに突込んであったのを、近頃見せたい人があって捜し出して書斎の机の抽斗に入れてある。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白花という名を冠らせるくらいだから白くはあるが、花冠の脊には、岩魚の皮膚のような、薄紅の曇りが潮し、花柱を取り巻いた五裂した花冠が、十個の雄蕊を抱き合うようにして漏斗の鉢のように開いている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いていおうならば北斗南面して看るという唐ようの古語にでも表現を譲るより仕方はあるまい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外を歩いてゐると、いつの間にか曇り出し小さいつむじ風が舗道の散らしビラを漏斗型に捲き上げる。",
              "citation": {
                "source": "風と裾",
                "author": "――何人か良案はないか？――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と畳みかけて仰する時我が腸は断ゆる斗に成りて、何の涙ぞ睚に堪へがたく、袖につゝみて音に泣きしや幾時。",
              "citation": {
                "source": "雪の日",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熨斗目」の腰に織り出してある横縞や、「取染」の横筋はいずれも宝暦前の趣味である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れの最も強い下流の方には方々直径七、八｜間ほどの漏斗形の大渦巻が出来ます。",
              "citation": {
                "source": "瀬戸内海の潮と潮流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人が一斗笊｜一個宛を持ち、僕が別に番ニョ片籠と天秤とを肩にして出掛ける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "斗賀野　「ツク」上方に拡がる「ヌ※平原丘。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にあのアラビア人のような名前のついた一団の自由自在に跳躍する翻筋斗の一景などは見るだけで老人を若返らせるようなものである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月號に於て同人淺沼の評論、金斗熔氏から頂いた原稿が載せられなかつたことを遺憾に思ふ。",
              "citation": {
                "source": "編輯後記（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家絵具入の抽斗を抜き出す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "（抽斗にある艶拭巾を二枚｜出して投げ遣る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、艶拭巾を取りて、絵具箪笥の抽斗の、まだ開けある中にしまい、忙がわしく上着を着る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから忙しげに、なんの必要もない抽斗なぞを開け放して、品物を取り出しては、又元の位置に戻したり何かした。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は三面鏡の抽斗から、煉白粉をとりだすとマリの鼻を厚化粧してしまった。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場から配布される自治案内に、七分搗米に麦をまぜて食えば栄養摂取が十分になって自から健康増進せしむることができると書かれてあって、微苦笑を催させずに措かなかったのはこの二月頃だったが、産業組合購買部から配給される米には一斗に二升の平麦が添加されることになった。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまもなく、内地米一斗に外米四升が添加されるようになって麦の混食には平気だった者も外米のバラ／＼してかたくて口ざわりの悪いのには閉口した。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旱魃を免れた県には、米穀県外移出禁止というような城壁が築かれてはいるが、表門は閉っていても、裏のくゞり戸があいているので、四斗俵ならぬ三斗五升いりの袋ならその門を通過させてもらえるのだと笑っていた。",
              "citation": {
                "source": "外米と農民",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、臼の漏斗に小麦を入れ、おとなしい牛が、のそのそ人の顔を見ながら廻っているのを見届けてから出かけた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろもその当座は気が転倒しているもんですから、なんにも気が付かなかったんですが、きのうの朝、長火鉢のまん中の抽斗をあけようとすると、奥の方に何かつかえているようで素直にあかないんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "乾燥室から運ばれる頭付軸木を手ごころで一定の分量だけ掴んで小函の抽斗に詰め、レッテルを貼った外函にさす、それを、手を打ち合わす、拍手のような動作のように、一瞬に一箇ずつ、チャッ、チャッとやってのけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹吉は、去年あたりから、やっと四斗俵がかつげるようになったばッかしじゃもん。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母の夫は、足駄をはいて、両手に一俵ずつ四斗俵を鷲掴みにさげて歩いたり、肩の上へ同時に三俵の米俵をのっけて、河にかけられた細い、ひわ／＼する板橋を渡ったりする力持ちだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とますます私を極め付ける。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "紹介状を書いていただいて、おいとまする時、津田さんが、玄関まで見送って来られて、「四十になっても五十になっても、くるしさに増減は無いね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の夏みたいに、やっぱり二、三時間で、おいとまするような事になるんじゃないかな。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見るとますますにがにがしい。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
