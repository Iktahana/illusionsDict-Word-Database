  {
    "uuid": "f76196fa-6596-5ade-a36d-682d9ee56c30",
    "entry": "斗",
    "reading": {
      "primary": "とます",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
