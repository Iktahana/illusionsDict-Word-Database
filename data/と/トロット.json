  {
    "uuid": "1d4a9c1b-17d6-5387-9bbd-4e63b946f7c8",
    "entry": "とろっと",
    "reading": {
      "primary": "とろっと",
      "alternatives": [
        "トロッと",
        "トロっと",
        "とろーっと",
        "トローっと",
        "トローッと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thickly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ほんのとろっとしただけだったが。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろへ腰掛けてこぼこぼはっていく温い水へ足を入れていてついとろっとしたらなんだかぼくが稲になったような気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだんひるになって暑くなる、海は油のようにとろっとなってそれでもほんの申しわけに白い波がしらを振っている。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね、とろとろっとすると、夢でおれをひっ叩きゃあがるんだよ、まったく！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかにとろっとしたと思うと起こされた。",
              "citation": {
                "source": "帰途",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "陶器のそのとろっとした肌を頬につけてしばらくそれを愛撫しました。",
              "citation": {
                "source": "落ちてゆく世界",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか化学的な変化でも起こすのではないか、舌ざわりがとろっとしてくる。",
              "citation": {
                "source": "美味放談",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中の十二時に、家畜が眼を覚ますので、わたしは、それまでに、とろとろっとするばかりです。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜はとろっともしないんだよ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍甕をぶちまけたような大川の水が、とろっと淀んで、羽毛のような微風と、櫓音と、人を呼ぶ声とが、川面を刷いていた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "悲願百両",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともあの柔らかい、とろっとした、表面の心持ちだけでも貴兄の注意を惹くには十分だと思えるのですが。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんは日あたりのいい小屋の入口に腰を下して、ネルロとパトラッシュがいそいそと畑の木戸をくぐり、やがて、その姿が遠くへ消えてしまうまで見送り、とろとろっと居ねむって、短い夢さえみる。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の毛を剃りおとした頭部が小さくみえるためか、その裸の肉躰の逞しさは不均衡であり、眉毛のないとろっとした眼や、いつもむすんだまま動くことのない唇など、見る者に異常な、非人間的な印象を強く与えた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "睫毛に白い粉がたまり、瞼の赤くただれた、とろっとした眼で、訝しげに彼を眺め、それが新しく来た彼であることを認めると、無感動に眼をそらす、というようなことがあったが、彼がようやく仕事を覚え、肌も茶色にやけてくると、まったくなかまに溶け込んでしまい、もはや彼に注意するような者は一人もいなくなった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とろとろっとしたと思ったら、また唐紙が開かれて、重箱面がはいってきた。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
