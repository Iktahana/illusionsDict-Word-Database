    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "支那のフオックス・トロットが劇場の地下室の踊場から聞えてきた。",
              "citation": {
                "source": "スポールティフな娼婦",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はパートナアの金髪の波をかきわけてフォックストロットの足並を揃える。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が電話の気分を出そうためにいたずらにフォックス・トロットをかけている。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "プログラムを見ると、第五番「アメリカのフォクストロット」。",
              "citation": {
                "source": "踊る線条",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、……チ・フォックストロット――」「そうだ。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もうひとつの方は、マーチ・フォックストロットだ――ところで、君は、時々ダンスを嗜まれる様だが、その踊り方を知ってるかね？",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、マーチ・フォックストロットと言奴をだね」　秋田は、図星を指されて急に顔を赤らめた。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋田は、それを一寸見ていたが、直ぐに、幾分得意然として、「――判ります、つまりこれが、そのマーチ・フォックストロットのステップの跡、と言うか、足取りの跡を、先生が図にしたものなんでしょう」　すると大月は笑いながら、「――ウッフッフッフッフッフッ……まあ、そうも言える。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時は猫も杓子も有頂天になって、場末のカフェでさえが蓄音機のフォックストロットで夏の夕べを踊り抜き、ダンスの心得のないものは文化人らしくなかった。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあの詩の続きが、遥かの彼方から響く様子なので、畦道に逼ひあがつた私達が河童のやうに首をあげると、メイ子を擁して、おぼろな月の光りを浴びながら堤の上を引きあげて行く業慾連のシルエットがフオックス・トロットの脚どりのやうに軽やかに踊つて見えた。",
              "citation": {
                "source": "武者窓日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前に一度、ふと舞踏場で、庸三は彼女と逢って、一回だけトロットを踊ってみた時、「怡しくない？",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は靴底のざら／＼するタタキを気にしながら、二回ばかりトロットを踊つてみたが、その娘さんは略二流どころのダンサアくらゐには附合つてくれた。",
              "citation": {
                "source": "町の踊り場",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォックストロット、ジダンダ、ステップせよ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも早く御飯の支度をして頂戴……お腹がペコペコになって死にそうだから……」　妾のお腹の虫が、フォックス・トロットとワルツをチャンポンに踊っていた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲がタンゴでもブルースでもかまわず、トロットのボックスを踏んでいればよい怪しいダンス。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめてミストロットと云う人に教わったが、大変に面白い人だと思う。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミスボイドと、ミストロットはまるで大変に違う。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて少し平たい道になると、青楓君の馬は口綱をはづして逸早くトロットをやり出した。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう皆んな馬上の高さに慣れて、兩足の内腿で鞍を締めつけるやうにして馬の歩行のリズムにつれて腰を浮かす調子が幾らかわかつて來たから、（口綱はもう皆んなはづしてゐた、）時時トロットをやつて見ようとしたが馬はいふことをきかなかつた。",
              "citation": {
                "source": "湖水めぐり",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな音をきくと私はねむれなくなり、ガチャガチャうるさいトロットなどのジャズバンドの陰なら私は安心してねむくなるたちであった。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は老人諸君と違ってジンフォニーを聞いても、ブルーズやフォックス・トロットを聞いても安心して私共のニッポン音楽を聞くつもりでおります。",
              "citation": {
                "source": "ニッポン音楽",
                "author": "――音楽学校の邦楽――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのトロットの具合、あの走る姿、それから例の跳躍ぶり――全國どこの生籬だつてバンタムに飛越せないところはないのだ。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャズのホックストロットさ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も古風で正式で、欧米の杜交界に於てホックストロットが猛威を逞しゅうせずワルツが全盛を極めていた頃に、そのワルツ界の王座を占めていたボストンワルツというやつ、そのボストンワルツへタンゴのステップとマズルカのステップとを出鱈目に加味して作り上げた「国枝式ワルツ」なのだ。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に踊ったのはトロットで次にタンゴを踊った。",
              "citation": {
                "source": "赤げっと　支那あちこち",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清乃　はあ、とても人の良さそうな――で敏ちゃんにそう言ったら、敏ちゃん飛びあがるようにして一緒に裏から出かけたんですから、公園の方へでも行ったんじゃないでしょうか――音楽（昭和十年ごろのフォックス・トロットのレコード曲。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さア、踊りましょうよ、滅茶滅茶に」　電気蓄音機が再び獰猛にフォックス・トロットを唸って、女中は忙しく盃を運び代えます。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶えず彼は借りた――兄の金を、母の金を、トロット氏の金を。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "照明のはっきりしないカフェーのなかで、レコードの廻転度数をおとしたようなフォックストロットがもの憂げに鳴った。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "トロットやルンバのとき彼女は先立って席へかえった。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
