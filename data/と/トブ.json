    "definitions": [
      {
        "index": 1,
        "gloss": "to fly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「議論するなら勝手にしやれ、あとでゲンコの雨が飛ぶ」――茲に、低俗プラグマチックの、象徴がありはしないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒点誰でも太陽をジツと視た者は目の前を、自分の周囲を空気の中を鉛色の斑点が飛ぶのをみる。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ更衣野路の人はつかに白し絶頂の城たのもしき若葉かな鮒鮓や彦根の城に雲かかる愁ひつつ岡に登れば花いばら甲斐ヶ嶺や穂蓼の上を塩車　俳句というものを全く知らず、いわんや枯淡とか、洒脱とか、風流とかいう特殊な俳句心境を全く理解しない人。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽炎や名も知らぬ虫の白き飛ぶ　この句の情操には、或る何かの渇情に似たところの、ロマンチックの詩情がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "某氏初期の新体詩に若草｜萌ゆる春の野にさまよひ来れば陽炎や名も知らぬ虫の飛ぶを見てひとり愁ひに沈むかな　と言うのがある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前出の「愁ひつつ丘に登れば花｜茨」や、春の句の「陽炎や名も知らぬ虫の白き飛ぶ」などと共に、西欧詩の香気を強く持った蕪村独特の句の一つである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミネルバの梟は、もはや暗い洞窟から出て、白昼を飛ぶことが出来るだろう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もなんだか嬉しくなって口笛をピュッ／＼と鳴らしながら飛ぶようにして帰った。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛ぶがごとく駈け寄った要太の一と捻りに、この小さな生命はもう超四次元の世界の彼方に消えてしまったのであった。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は飛ぶが私の兄は、この地方に於いて最も注目されてよい人物の一人かもしれぬ。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの空を、飛ぶ鳥もいたいけな情け、みちてます。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "白芥子の花のような日光がちらり落ちる、飛白を水のおもてに織る、岩魚が寂莫を破って飛ぶ、それも瞬時で、青貝摺の水平面にかえる、水面から底まではおそらく、二、三尺位の深さであろうが、穂高岳を畳んで、延ばしたり、縮めたり、自在にする、水の底に白く透いて見えるのは、石英が沈んでいるのだ。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ノ池の方に廻る、池には石が座榻のように不規則に、水面に点じている、岸には淡紅の石楠花が水に匂う、蛇紋が掻き破られて、また岩魚が飛ぶ、石楠花の雫を吸っている魚だから、腸まで芳芬に染まっていないかとおもう。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧は、頻に、頭の上を飛ぶ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、眼の前に、ふわりと、雪の粉が落ちる……七月末の炎天である……直ぐ、水に吸い込まれて消える……また、頬を掠めて、ふわりと飛ぶ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶺鴒が、もの忘れから気が注いたといった風に、石の上から、ついと飛ぶ。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に四時四十七分、東方より金芒爛として飛ぶ、槍も穂高も、半肩以上は微黄となり、以下は大天井岳をはじめ、その一帯山脈の影が、かぶさるので闇い衣を被ている、日の昇るに伴れて、附近の大山岳、幾百の頭臚皆起って舞う。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬が来た、冬が来た、木はその葉を振い、飛ぶ禽も翼を縮めるべき冬が来たのだ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い吹雪が大原の中を、点々と飛ぶ、大きく畝ねる波系が、白くざわざわと、金剛杖に掻き分けられて、裾に靡く、吹雪は野菊の花で、波系は芒の穂である。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもしその唄が時の巴里の物足りなく思っている感情の欠陥へこつりと嵌まり込めばたちまち巴里じゅうの口から口へ移されて三日目の晩にはもうアンピールあたりの一流の俗謡の唄い手がいろいろな替唄までこしらえて唄い流行らしてくれるし譜本は飛ぶように売れ始まる。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、彼は、矢張り空飛ぶ鳥であったか。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜だかが思い切って飛ぶときは、そらがまるで二つに切れたように思われます。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛ぶんだぞ霧の中をきいっとふっとんでやるんだなどと頭の奥で叫んでゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは橋の袂から飛ぶやうに下の広い河原へおりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『万葉集』巻十二に「いぶせくも」という語を「馬声蜂音石花蜘※」と書いてあって、「馬声」をイに宛て、「蜂音」をブに宛てたのをみれば、当時の人々は、蜂の飛ぶ音をブと聞いたと共に、馬の鳴声をイの音で表わしていたのである。",
              "citation": {
                "source": "駒のいななき",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階の窓から狂風に吹き飛ぶ雲を眺めながら考えるともなく二十年前に見たベルリンのメトロポール座のレビューを想い出していた。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また彼はプノンペンから自動車に搭乗して国境のゴム園に車をカンボジヤの原野、白鷺の飛ぶ直線道路を、水田に遊ぶ水牛のなかを疾走させた。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅長宮沢賢治ことことと行く汽車のはて温石いしの萱山の上にひとつの松ありてあるいは雷にうたれしや三角標にまがへりと大上段に真鍮の棒をかざしてさまよへりごみのごとくにあきつとぶ高圧線のま下にて秋をさびしき白服の酒くせあしき土木技手いましも汽車を避け了へてこなたへ来るといまははた急ぎガラスを入りにけり",
              "citation": {
                "source": "駅長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸外は――地面は半ば乾いてあつたかい、空を風は、目標ありげにとぶ、梅雨期の或る一日だ。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛蟻とぶや富士の裾野の小家より　広茫たる平原の向うに、地平をぬいて富士が見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
