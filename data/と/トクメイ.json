[
  {
    "uuid": "a0398120-954a-5277-b07e-9fc000cf8764",
    "entry": "匿名",
    "reading": {
      "primary": "とくめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
