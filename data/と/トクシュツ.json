          "literary": [
            {
              "text": "尤も漢代には特出せる評論家があつた。",
              "citation": {
                "source": "支那古典學の研究法に就きて",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻承り候□此処ニて金特出候事と存候。",
              "citation": {
                "source": "坂本龍馬手記",
                "author": "イロハ丸航海日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテ・グリで武藤・古賀・京極で食事、古賀が全然藤山を容れず、九月藤山特出なら作曲しないと言ふ、武藤もこれには弱って、何とか仲直りさせたいと話しつゝ帰る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年からの加入は山野、特出はタップの稲葉実だけ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "特出の高杉妙子、急性盲腸炎で今朝入院、久米夏子が代役した。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の特出に頼みしミス・コロは会社がＯ・Ｋしないらしいとのこと。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
