    "definitions": [
      {
        "index": 1,
        "gloss": "passing by",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私を通りすがりに、自動車に援け乗せて、その邸宅に連れて行ってくれる、小説の美しいヒロインも、そこには立っていなかった。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、私は釣りの帰りに、硝子のない硝子戸から、その家の有様を通りすがりに眺めた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りすがりの旅人が金閣寺を見物しようとするには案内の小僧は甚だ重宝なものであるが、本当に自分の眼で充分に見物しようとするには甚だ不都合なものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばたの敬四郎と子分の松公が通りすがりに之を見る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、その路へは大っぴらに通りすがりの家が窓を開いているのだった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来に涼み台を出している近所の人びとが、通りすがりに、今晩は、今晩は、と声をかけた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋸は又動いて、（左様だ、今頃は弥六親仁がいつもの通、筏を流して来て、あの、船の傍を漕いで通りすがりに、父上に声をかけてくれる時分だ、）　と思わず振向いて池の方、うしろの水を見返った。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色の額縁にをさめられてある鏡を通りすがりにちらと覗いた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金色の額縁におさめられてある鏡を通りすがりにちらと覗いた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船の外でも西洋小間物屋の店先や、居酒屋の繩のれんの奥から聞こえて来るのが通りすがりに聞かない事はなかった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥った身体を通りすがりの人にこづかれながら、手真似をまじえて大きな声になった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "己れにした処がまあカチヤには何よりべらべらしたものを着せて、頬っぺたの肉が好い色になるものでも食わせて、通りすがりの奴等が何処の御新造だろう位の事を云って振り向く様にしてくれりゃ、宿六はちっとやそっとへし曲って居ても構わ無えと思う様になるんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やつぱり朝はおみおつけがどうしたつて要りますなあ」だの、「扇子といふやつはよく置忘れる代物ですなあ」とか云つてれあともかく活々してる奴等が、現代だの犯罪心理なぞとホザき出すので、通りすがりに結婚を申込まれた処女みたいなもんで、私は慌ててしまふんだ。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋸は又動いて、（左樣だ、今頃は彌六親仁がいつもの通、筏を流して來て、あの、船の傍を漕いで通りすがりに、父上に聲をかけてくれる時分だ、）　と思はず振向いて池の方、うしろの水を見返つた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その香の好さと申したら、通りすがりの私どもさえ、寐しなに衣ものを着換えましてからも、身うちが、ほんのりと爽いで、一晩、極楽天上の夢を見たでござりますで。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お通りすがりが、何とも申されぬいい匂で、その香をたよりに、いきなり、横合の暗がりから、お白い頸へ噛りついたものがござります。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉街道よりはわきへそれ、通りすがりの打見には、橿原の山の端にかくれ、人通りしげき葉山の路とは、方位異なり、多くの人は此の景勝の霊地を知らず、小生も久しく不心得にて過ぎ申候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りすがりの婀娜者は歩みを停めて、「ちょいと小僧さん、石動までいくら？",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ旅に出ようか、普通通りすがりの旅客として水辺の旅館に滞在するならば、なんの絆も出来るわけはない。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし長次も親譲りの負けぬ気性、湯加減を偸んで名刀の名を馳せし刀鍛治左文字の故事を学ぶの最後の智慧を以て、或日は薄暮、或日は暁暗、亦時として通りすがりの様を装つて、新八、太七の工場の前を窺つては中の様子にそれとなく注意を払ふのであつたが、却※にその効もなく、そのまゝ日数を経て行つた。",
              "citation": {
                "source": "名工出世譚",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りすがりに考えつつ、立離れた。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十六「何にいたせ、私なぞが通りすがりに見懸けましても、何んとも当りがつかぬでございます。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々、廊下を往通ふ女中が、通りすがりに、『何う遊ばしたのでございませう、』『うむ、』『御心配でございます。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の家は道路に面して鉄柵を張った前庭を置き暗褐色のどっしりした玄関が冷淡に控えて居るが、一寸横へ廻って見ると、この邸内は斜めに奥へ拡がり、四季咲きの紅白の蔓薔薇に取り囲まれた二百坪ばかりの緑の芝生の裏庭に向う室は軽快なサンルームとなって、通りすがりの男女にちょっと盗見したい気持を起させる。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞳を一ミリと動かさずに通りすがりの男の消費価値を値踏みするこの種の女の何れもが持ち合して居る眼だ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それおやじのかい」　離れから廊下を歩いて来た陸郎は、通りすがりにちらと横目に見て訊いた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ若い車掌が、切符改めの通りすがりを、赤い顔して、引き留められて、克明にハッと頭をさげた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、孫恪は、「通りすがりに入ってきた者だ、尊門を汚して相済まん」　と言って、みだりに門内に入った罪を謝した。",
              "citation": {
                "source": "碧玉の環飾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは乱歩氏の作品に限らず、ほかの小説でも同様で、調べること嫌いの私は「猟奇」とか「探偵」とかいう名目すらも、ツイこの五六年前までは、赤の他人の名前と同様に、通りすがりに記憶しているくらいの事でした。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのひとが　にわの　いりぐちのわきに　かごを　おいておくと、　はこびやさんが　とおりすがりに　ひろっていく　というわけで。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
