        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は部屋から飛び出してお茶を取りに階下へ降りた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――彼女は飛び出して来た。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこへ母が倉から手燭を持つて飛び出して来た。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫が仰向いて長火鉢の上の柱時計をみながら飛び出した喉豆に掛けた声で「七時かあ」と云つた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "『なぐれ』『たため』『しめろ』雜然たる叫聲の中、殺氣は既に滿ち渡つて、氣早の若者は行成横合から飛び出して、思ひ切り芳の天窓を擲つた、續いて何處よりともなく、拳の雨は彼の頭上に降り注いだのである。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹村君は小僧が皿を包むのをもどかしそうに待っていたが、包を受取ると急いで表へ飛び出した。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バッタが驚いて足下から飛び出した。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎も少しだれ気味で網を高く上げて振るとバタ／＼と一羽飛び出して堤を越して見えなくなった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要太郎の指をさす通りにグサ／＼と下駄の踏み込む畔を伝って土手へ上ると、精の足元からまた一羽飛び出して高く舞い上がった。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば、彼の神経は彼の体の外側へ飛び出して、彼の眼を透して、彼の体の中を覗いているのだった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "無邪気な、詰らない疑問が飛び出して、私を煩さがらさなかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "今電灯を点ずると、灼熱した炭素線から陰電気を帯びたいわゆる電子と称する微細なものが飛び出して金属筒に附着する。",
              "citation": {
                "source": "無線電信の近状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜だかは巣から飛び出しました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして巣の中をきちんとかたづけ、きれいにからだ中のはねや毛をそろえて、また巣から飛び出しました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」二人は一度にはねあがってドアを飛び出して改札口へかけて行きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを読んでしまうかしまわないうち、私たちは一ぺんに飛び出してイギリス海岸へ出かけたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "林檎畑の案山子は、樹の頂上からぴょこんと空中へ今正に飛び出した所だと云ったような剽軽な恰好をしている。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また光というものでも、昔は人の眼から何物か飛び出して物体に当るから見えると思った時代もある。",
              "citation": {
                "source": "研究的態度の養成",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お父さん大へんです、奈々ちゃんが池へ落ちて……」　それやっと口から出たか出ないかも覚えがなく、人を押しのけて飛び出した。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物や植物には百千年の未来の可能性に備える準備が出来ていたのであるが、途中から人間という不都合な物が飛び出して来たために時々違算を生じる。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の出し得る極度の大きな声を出しているという事は、その顔色が紫がかる程に赤く光沢を帯びて、眼球が飛び出しそうな程に眼を見開いている事からもおおよそ察せられた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へばまた、彼はかつて僕の敍情詩「郷土望景詩」に感激し、朝早く寢衣のままで家を飛び出した。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は幕末の革命に飛び出したり、時には辻斬強盜などもやる方だが、犀星のは本當の古武士であつて、君主の前で禮節正しく構へてゐる。",
              "citation": {
                "source": "室生犀星に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎じ詰めた、而も、たまらなく美感と滋味のこもった言葉が小癪なほど豊富に飛び出し、而もそれ等が一つ残らず（画面）の底にとけて流れて行く。",
              "citation": {
                "source": "気まま者の日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "耐らなくなった三次が群集の中から飛び出して、Ｔ「其処に落ちとりましたよ」　と言って件の紙入れを三四郎に渡す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし豚は棒を持った男が近づいて来ると、それまでおとなしくしていたやつまでが、急に頭を無器用に振ってはねとびだした。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さっきの木のとなりからすぐまた一本の柏の木がとびだしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清作はもうとびだしてみんなかたっぱしからぶんなぐってやりたくてむずむずしましたが、画かきがちゃんと前へ立ちふさがっていますので、どうしても出られませんでした。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さっきのとなりから、また一本の柏の木がとびだしました。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
