          "standard": [],
          "literary": [
            {
              "text": "ほら、あれを御聞きなせえまし、夜業でもしておりますものか、あの通り槌の音が聞えますゆえ、棟梁達の首は大丈夫でごぜえます」　権次の言葉に耳を澄まして見ると、いかさましんしんと冴え渡る夜気を透して、幽かに裏口のあたりからトントンカチと伝わって来たものは、まさしく大工達の槌の音でした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからヘッピリ腰で欄間へあがると、またしても不器用な手つきで鉄槌を握って、今度は立木や灯入りの月や両袖などをトンカチンと打ちつけた。",
              "citation": {
                "source": "圓太郎馬車",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは、まあそのくらいのつもりだったらしいが、だんだん面白くなったらしく、仕舞には、ブルージンをはいて、トンカチをもって出かけて行き、ごっそり石ころを持って帰るようになった。",
              "citation": {
                "source": "娘の結婚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし照彦様は『十番ならおトンカチのとんがりで十だぞ』とおっしゃいました」「なんのことだろう？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それではお母さんはおトンカチってものをご存じですか？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなもの存じませんよ」「かなづちのことです」「へええ」「そのおトンカチで正三は頭をぶたれるんです」「ばかなことをいうなよ」　とお父さんが取りあげなかったので、祐助君は正三君の立場を説明した。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「光っているおトンカチです」「おトンカチというと？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これをきみにあげる」　と照彦様はイライラしながら舶来のおトンカチを本箱のひきだしから取りだした。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おこらない」「そうですか」「その証拠にこれをきみにあずける」「それじゃおあずかりいたします」　と正三君はおトンカチを受けとった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまかすとおトンカチだぞ」「時間があれば皆出す気ですが、時間がないから、その中四、五題出すんです」「そんなことはきみに聞かなくてもわかっている。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お肝試しの会さ」「僕はバットを持ってゆきます」「僕はおトンカチを持ってゆく。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "照彦様あなたも何かおかくしになっていらっしゃいますな」「おトンカチです」「いけません」「黒須さん、この二人は小さいからかわいそうです。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おトンカチをおとしてきた」「黙っていて明日の朝拾ってくればいいです。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「若様もけっしてお強くありませんぜ」「困ったな」「おトンカチをおとしていちもくさん」「もういいよ」「あれもかくしてあります。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の悪口をおっしゃると、あのおトンカチとバットを出しますよ」「ごめんだごめんだ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだい」「お肝試しの会で安斉先生にほめられましたけれど、杉山君がバットやおトンカチのことを話すと困りますね」「僕もそれを考えていたところだ。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕たちがバットとおトンカチをなくしてきたことを皆知らなかったもの」「とにかく、探してまいりましょう。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おトンカチとバットは薮の中にあった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれ妖怪ござんなれ」　と照彦様はおトンカチをふりあげた。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈夫な奴だよ」「それはよかったですな」「しかしあいつはいかん」「なぜですか」「僕たちのことを女中たちにしゃべった」「おトンカチとバットの一件ですか？",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はおこって、「おい、泣くな」　とおトンカチでなぐった。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラインド・カーブで追いこしかけてセンター・ライン割る薄らトンカチが、どこにいるかってんだ」　スライスにかかっていたレモンが、すっぱい。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とどなり込むと、セイ公いきり立って、トンカチを持ち「ロッパが何でえ！",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            }
          ]
        }
