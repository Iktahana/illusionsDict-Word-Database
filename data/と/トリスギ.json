[
  {
    "uuid": "36abb6f1-a78e-5c79-a49c-681bd6394d98",
    "entry": "取り過ぎ",
    "reading": {
      "primary": "とりすぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
