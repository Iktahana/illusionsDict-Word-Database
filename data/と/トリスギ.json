    },
    "definitions": [
      {
        "index": 1,
        "gloss": "excessive intake (e.g. coffee)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その際往々森の中から野象を連れて来る事があるが、大抵もう年を取り過ぎていて馴らしにくいものが多いそうな。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つはなはだしく不満に思われたのは、せっかくの実写に対する説明の言葉が妙に気取り過ぎていて、自分らのような観客にとっていちばん肝心の現実的な解説が省かれていることであった。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "安二郎はお君の仕立賃のほか、最近は豹一がお君に渡す月給の幾割かをも右左にまきあげていたので、正直な計算によれば、もはや取るべきものはすっかり取ってしまったどころか、取り過ぎている勘定になっているのだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺激物を取り過ぎて、精神不安で恨みや憂いや恐れや危ぶみなどの状態に捉えられて困っている人もある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、木彫りは一度肉を取り過ぎると、それを再び附け加えることは出来ない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "脂土や石膏に心を惹かれたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢くなるには余りに齢を取り過ぎてゐたから。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って見たいような商売を始めるには、資本が不足だし、躯を落して働くには年を取り過ぎていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二違ひで少し年を取り過ぎてゐるが、道臣もまだ男盛りであつた。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも航路をズッと北に取り過ぎて、晩香坡とは全然方角違いのアドミラルチー湾に深入りして雪を被った聖エリアスの岩山と、フェア・ウェザー山の中間にガッチリと船首を固定さしているのには呆れ返った。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッハハハ泥棒にしちゃあ少し年を取り過ぎていらあ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十や十五の子供ではなし、迷児になったのではあるまいが、それにしても少し手間取り過ぎるよ」「それに旅人の鈴の音が、小山の向こう側で聞こえております」「もう一人物見にやってごらん」「北条氏北条氏」呼ぶ声に連れて、北条という若い武士が、すぐに後列から走って来た。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は唯一人の弟の好意を拒む理由も持たなかったし、又「神を試みる」には年を取り過ぎて居たので云う言葉通りに守って居たと云う事がある。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もずっと以前ならば、惚れた女の抱えられている家へ入り込んで行くくらいのことをしかねない人間ではあったが、どこまでも自分の顔を悪くしないで手際よく事を運びたいとあまり大事を取り過ぎたのがいけなかった。",
              "citation": {
                "source": "霜凍る宵",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "年を取り過ぎたものに味があろうはずがない。",
              "citation": {
                "source": "季節の味",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今もっと若ければ復たび万難を排して仕事にかかるけれど、なにを言え少し年を取り過ぎた。",
              "citation": {
                "source": "私の信条",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が今もっと若ければふたたび万難を排して仕事にかかるけれど、何をいえ少し年を取り過ぎた。",
              "citation": {
                "source": "牧野富太郎自叙伝",
                "author": "第二部　混混録",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日お千代は重吉に新聞の広告を見てもらって、銀座｜通の或カッフェーに行って見たが、最初の店では年が少し取り過ぎているからといって断られた。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い頃は、お嫁に行くなんてことを忘れてゐたんでございませうか、それに気がついた時は、もう、年を取り過ぎてをりましたんです。",
              "citation": {
                "source": "顔",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "久慈　　いや、それはつまり、僕んとこの女房が年を取り過ぎてゐるからです。",
              "citation": {
                "source": "隣の花",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒性は弱いし、必須元素であるが、サプリメントや鉄剤の取り過ぎ、鉄鍋の使用、鉄分の多い赤ワインやビールの飲酒、などを原因とする鉄蓄積症が知られている。",
              "citation": {
                "source": "食品の混ぜ物処理および調理の毒物（1820）",
                "author": "A TREATISE ON ADULTERATIONS OF FOOD, AND CULINARY POISONS",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取り過ぎたといっても、虚栄心が祟ったといっても同じでしょうが、私のいう気取るとか虚栄とかいう意味は、普通のとは少し違います。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "1545一体己は当のない遊をするには、もう年を取り過ぎた。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の蒐集は不完全であるが、それでも全部を列記すると紙面を取り過ぎるので、たゞ二三の例を掲げるに止める。",
              "citation": {
                "source": "祭禮名彙と其分類",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸娘の粹と言つたお秀は年こそ少し取り過ぎましたが、隨分思ひも寄らぬ罪を作つてゐさうな美しさでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青い帶",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸娘の粋といったお秀は年こそ少し取り過ぎましたが、ずいぶん思いも寄らぬ罪を作っていそうな美しさでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "青い帯",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋風や眼中のもの皆俳句　これは当たり前だという人と、気取り過ぎているという人と両方があろうと思います。",
              "citation": {
                "source": "俳句の作りよう",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四角な頭、短く刈った褐色の髪、痘痕のある無髯の顔、太い眼、太い鼻、太い唇、二重｜頤、短い首、恐ろしく大きな背中、樽のような腹、胴体から分かれ出てる腕、馬鹿に大きな手足、食物とビールとを取り過ぎて変形した巨大な肉塊、それはあたかも、煙草の鑵のような人間だった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の夜は気取り過ぎるし「夜」ではあまり個性がなさ過ぎるので自分は「歯車」と云ふ題を薦めて見た。",
              "citation": {
                "source": "芥川龍之介を憶ふ",
                "author": "佐藤春夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのため、その芸術をレコードする機会が、甚だしく遅れ、幸いにしてＨＭＶ及びポリドールに吹き込んだ時は、フレッシュ自身、やや年を取り過ぎた憾みがないとは言えなかったのである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しばかり年齢をとりすぎてしまいましたが、それでもいろいろな意味で最も評判のよい女優でした。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
