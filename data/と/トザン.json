    "definitions": [
      {
        "index": 1,
        "gloss": "mountain climbing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "登山やハイキングなぞの流行といふこともそんな風なことかも知れぬ。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "風があまりに強いために他の乗客は皆登山を断念して引返したので結局この二人の日本人だけが登ることになった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣りに坐りし静岡の商人二人しきりに関西の暴風を語り米相場を説けば向うに腰かけし文身の老人御殿場の料理屋の亭主と云えるが富士登山の景況を語る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹木の幹に「登山記念、何月何日、何某」とナイフで彫つてある文字を見かけることさへあるが、私には笑へない。",
              "citation": {
                "source": "貪婪禍",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋本君は、東京から山王山まで通って、登山仕立ての私を描いてくれた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺で高頭君は、歩度測量計を失くしてしまい、私たち一同人夫と共に、附近の偃松を捜索したが、見当らずにしまった（後にこの歩度メートルは、登山家某君に発見せられて、上高地温泉宿に委托せられ、無事に持主の手に戻った）。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい石祠がある、屋根には南無妙法蓮華経四千部と読まれた、大日如来と書いた木札が建ててある、私たちの一行より、二十日も前に登山した土地測量技師や、昨年登山した東京の人たち、山麓｜蘆安村でよく聞く名の森本某、名取某の名刺が散らばっている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "市民の生活といっても、当時交通不便にして、富士登山が容易でなかったために、旧暦の六月｜朔日には、市中と郊外にある富士山の形に擬えた小富士や、富士権現を勧請した小社に、市民が陸続参詣した。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰朝以来の第一登山に、いずれの山谷を差しおいても、富士山へ順礼する心持になれたのも、「私たちの山」への親しみの伝統があったからである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　裾野の水車　本年の富士登山二回の中、第一回は大宮口から頂上をかけて、途中で泊らず、須走口に下山、第二回は吉田口から五合目まで馬で行き、そこの室に一泊、御中道を北から南へと逆廻りして、御殿場に下りた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮口は、富士登山諸道の中で、海岸に近いだけに最も低い。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中の一行は、明朝の登山を控えて、「この雲では山は雨かな」と心配すれば、「なあに、雲は低いですよ、すっぽり抜けると、上はカラカラの上天気ですよ」などといい合った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝の登山準備を頼んで、宿の浴衣を引っかけたまま、細長い町を散歩する。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学生の登山隊が、百人ほど、町の宿屋にいるのだそうで、チンチクリンの男の浴衣を、間に合せに着て、歩いているのもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに上吉田は、明藤開山、藤原｜角行（天文十年―正保三年）が開拓して、食行身禄（寛文十一年―享保十八年）が中興した登山口だけあって、旧｜御師町らしいと思わせる名が、筆太にしたためた二尺大の表札の上に読まれる、大文司、仙元房、大注連、小菊、中雁丸、元祖｜身禄宿坊、そういった名が、次ぎ次ぎに目をひく。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和大峰いりのほら貝は聞えないが、町から野、野から山へと、秋草をわたり、落葉松の枯木をからんで、涼しくなる鈴の音は、往さ来さの白衣の菅笠や金剛杖に伴って、いかに富士登山を、絵巻物に仕立てることであろうか。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、同じ登山口でも、御殿場は停車場町であって、宿場ではない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "登山者の眼中には、金剛不壊の山の本体の前に、永久性の大鳥居がただ一つあるばかりだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の登山諸道に、壮麗な神社があるのと対照して、これはこれ、あれはあれでいいと思う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のような裾野となって、富士の登山が一しお悦ばれるのは、絨氈を布く緑青の草と、湿分を放散する豊富な濶葉樹林とにあろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人がアンデスの登山を悦ぶのは、麓が永久の春であるからだそうだが、山の天国は、発達した裾野を有するところの、富士火山帯に多くあらねばならない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは大宮口こそ、富士のあらゆる登山道で、もっとも古くから開けた旧道むしろ古道であることだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "我祖先が、始めて神秘な山へ印した足跡を、大切に保存しないということは、永久に続く登山者をも、やがて忘却してしまうことだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵の登山者は、ここで一息いれる、水を飲む、床几にごろりと横になるのもある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政六年版の玉蘭斎貞秀画、富士登山三枚続きの錦絵には、「小御岳、花ばたけ、しゃくなぎ多し」とあるから、昔から多かったものと見える。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた、私はこのたびの登山が、七月から八月へかけてであったことを悦んでいる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから精進口の登山新道、三合目へ下りることが出来て、途中に中庭、奥庭などを通過するそうだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし元来、御中道めぐりは、信神の道者を主とするので、近来盛んになった女人の登山も、ここへはほとんど影を見せず、森林と絶壁と深谷とで、四周を切り離されているから、山中の室としてのさびが、心ゆくばかり味わわれる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は登山すべく、あまりに老いたとは思っていないが、まだ登るべき多くの山を控えているから、恐らく生涯に二度とここまで来なかろうと思う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　富士春が、弾き出すとざんば岬を、あとに見て袖をつらねて諸人の泣いて別るる、旅衣　と、益満が、唄い出した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
