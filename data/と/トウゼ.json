        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その限り一応党是に服し党の指導方針を尊重すべきであるのは、常識である。",
              "citation": {
                "source": "社大党はファッショ化したか？",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会大衆党は北支事変勃発と共に軍事行動に対して最も積極的な参加を党是として決定した。",
              "citation": {
                "source": "一九三七年を送る日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼は又旧ホイッグ党党是の無条件な信奉者であり、民衆的な衡平の反対者なのであった。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこういうプリンシプル（政党ならば党是という処）に基いて暴力団の各種の観念的な組織が出来上る、道徳や習慣が出来上る、そして夫が歴史にさえ伝承される。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世論」の尻馬に乗って国体明徴の提案を党是として朗読演説をやったのは政友会総裁鈴木喜三郎氏であった。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府が政友会を恐れるの余り、何とか政友と渡りをつけようとする内閣審議会を、徹底的にブッタタいてやろうと思っていた処、水野錬太郎や秋田清の諸氏が、党是を無視して審議会委員となって了う。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのは、六月初旬に鈴木総裁を訪問した氏は、重臣に見放されたからと云って総裁を更迭するのは本末を転倒したもので、寧ろ退嬰消極悉く政友会の党是に反するこの重臣ブロックこそ排撃されるべきだ、という進言をしたのである。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "政友会の党是が着々として効を奏しつつあったわけだ。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "元日、とうぜんとしていたら、鴉が来て啼いた。",
              "citation": {
                "source": "雑記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうぜん生えなければならないひげが生えないのは、これも病気なんでしょう。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、ここまで話がすすんでくれば、ただ「モノとしての本」について語るだけではすまなくなるのはとうぜんだろう。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非お話したいことがあったもんですから」　何もかもぶちまけて言えば、私は、四年間別れていた恋人同士の間にとうぜん期待される場面を今日の会見に期待していたのだ。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうぜん勝手がかわらざるを得なかったに相違ない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一二　文学者の貧化　円本の濫出、出版資本の集中は、ついに、出版恐慌を現出し、それはとうぜん作家にも影響して、人気作家の独占的傾向が濃厚になってきた。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、過去の因は、とうぜん現在の結果によって知られるのです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて替え玉だとしてみると、その男こそ先生を殺した犯人だということが分かり、同時にとうぜん斎藤が共犯者でなくてはならぬと思ったのです。",
              "citation": {
                "source": "髭の謎",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼうぜん、あんぜん、そしてゆうぜん、とうぜん。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が温泉を好むのは、いはゆる湯治のためでもなく遊興のためでもない、あふれる熱い湯に浸つて、手足をのび／＼と伸ばして、とうぜんたる気分になりたいからである。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうぜんとして飲み、とうぜんとして酔ふ、さういふ境涯を希ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はゆうぜんとして飲み、とうぜんとして酔ふ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "村のデパートで一杯また一杯、とうぜんとしてもどる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "△酒と人とが、とうぜんとして融けなければ本当でない。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうぜんとっぴょうしもない出来事をおこさせるおどけ者の運命は、案外わたくしたちの身近に、うろうろしているのだ。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械の間から青い火花が散ったり、絶縁物がぼうぼうと燃えだしたり、とうぜん油がふきだしたり、にぎやかなことであった。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こう申せば、諸君、とうぜん、ここに一つの疑問を持たれるであろう。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロバート大佐は、不快をしのんで、それはとうぜん弁償されるでありましょうと答え、そしてこのギンネコ号が現場へきて何を見たかについて話してくれるよう頼んだ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの憲法は、いま申しましたように、民主主義を根本の考えとしていますから、主権は、とうぜん日本國民にあるわけです。",
              "citation": {
                "source": "あたらしい憲法のはなし",
                "author": "文部省",
                "note": "青空文庫"
              }
            },
            {
              "text": "日華事変の直後、〈昭和十六年作戦〉の大計画にもとづいて陸軍が厖大な戦争資材の買付と蓄積をはじめたとき、とうぜん日米戦争にまで発展することを見抜き、戦争が勝っても負けても、自分らのような金利生活者はみな根だやしになると、何年も前からちゃんと覚悟していた。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "北村　同じように働いている者どうしが、だって、お互いに助け合うのは、とうぜんじゃないか。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄きみたいなキチガイ野郎を、みんなが憎むのは、とうぜんだ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
