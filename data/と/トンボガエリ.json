        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "オベリスクやエッフェル塔が空中でとんぼ返りをしたりする滑稽でも、要領がよいのでくすぐりに落ちずして自然に人のあごを解くようなところがある。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台では、長髯の豪傑が四つの金襴の旗を背中にさして長槍を振りまわし、また、半裸体の男が幾人もそろって一斉にとんぼ返りを打ったり、小旦が出て来て何か甲高い声で歌うかと思うと、赤い薄絹を身にまとった道化役が、舞台の柱にしばられて胡麻塩髯の老人に鞭でひっぱたかれたりするのだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その船首で、とんぼ返りをして景気をつける男。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くるみ割はとんぼ返りをうちますし、石筆は石盤の上をおもしろそうにかけまわりました。",
              "citation": {
                "source": "しっかり者のすずの兵隊",
                "author": "DEN STANDHAFTIGE TINSOLDAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "丹精して仕込まれただけあって、蛙は飛ぶ事がひどく得意で、この男の指が一寸お尻をこづくと、ゴム鞠のように跳上って、機みがよかったら途中で二三度とんぼ返りまでして見せました。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとり者はさびしい裏庭の茶の木が目につくと、自分の好みにそっくりな好い友だちが見つかったように、いきなり飛んでいって、厚ぼったい葉なみを潜りぬけたり、小枝につかまってとんぼ返りをうったりする。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや、或る作家が、マルクス主義的藝術團體に加盟したら、その作者の前日までの作品はすべてブルジョア文學作品であつたのが、その翌日からとんぼ返りして、悉くマルクス主義的文學作品になるなどと考えるのは全く子供らしい考えかたである。",
              "citation": {
                "source": "政治的價値と藝術的價値　マルクス主義文學理論の再吟味",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "況んや、或る作家が、マルクス主義的芸術団体に加盟したら、その作者の前日までの作品はすべてブルジヨア文学作品であつたのが、その翌日からとんぼ返りして、悉くマルクス主義的文学作品になるなどゝ考へるのは全く子供らしい考へかたである。",
              "citation": {
                "source": "政治的価値と芸術的価値",
                "author": "マルクス主義文学理論の再吟味",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人に蔑まれまい為には、男子といふ男子は、蛙の様にとんぼ返りまでもするものである。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の眼には、山がお玉杓子のやうにとんぼ返りをしたり、港が巾着のやうに拡がつたり縮まつたりした。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘗て純文学の精神の守護であった芸術性はとんぼ返りをうって、鬼面人を脅かす類のものに転化したのである。",
              "citation": {
                "source": "文学精神と批判精神",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新劇では隈取りもしなければ、とんぼ返りもやらないらしい。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "その合間には、しゃちほこ立ちをしたり、とんぼ返りをしたりしました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は一つお辞儀をして、とんぼ返りをしたかと思うと、立派なお婆さんの姿になってしまいました。",
              "citation": {
                "source": "狸のお祭り",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイバーンに奪ひとられた後、彼の手に殘つてゐた寶石の半分餘が、彼がとんぼ返りをした時にポケットから振り飛ばされて、再び地面に落ちて光つてゐるのであつた。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は一番深い吹溜の中へとんぼ返りを打って見たり、われわれがさっきこのバークシア地方の山々がやっているように想像した雪投げをしたりして、とっくに吹雪とは仲よしになってしまった。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "小猫は別にそれを取ろうとするでもなく、身体を横にしたり、とんぼ返りをしたりしてそれに戯れついていた。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼が細い糸の上に皿を置いて、その上でとんぼ返りをするところを見ました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ピョンとひとつとんぼ返りを打ったチョビ安、大道に四つんばいになって、泥棒猫のかっこうよろしく、おかしなようすでしきりにお美夜ちゃんの足もとをはいまわる。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人芝居の真最中でとんぼ返りを打って、たちまち我れに帰った。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "のめったと思う途端に、重い俵は、とんぼ返りを打って、掘子の手を離れた。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその状態がいつまでも進行して、奮興の極度に達すると、やはり二様の作用が出る訳だが、とくに面白いと思うのはその一つ、――すなわち積極の頂点からとんぼ返りを打って、魂が消極の末端にひょっくり現われる奇特である。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "短刀は二三度とんぼ返りを打って、静かな畳の上を、久一さんの足下へ走る。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーミ　海んなかでとんぼ返りよ。",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海んなかでとんぼ返りよ！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "破産と支払拒絶とは、そこからわれわれの文明の多くがとんぼ返りをうつ跳躍台である。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから突然停まって、世界のすべての眼が自分にそそがれているといったような、おどけた表情と意味のないとんぼ返りとをする。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは越後から来た｜角兵ヱ獅子で、昨日までは、家々の閾の外で、逆立ちしたり、とんぼがえりをうったりして、一｜文二｜文の銭を貰っていたのでありました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは、お礼に、とんぼがえりを七へん、つづけざまにやって見せました。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきもここで、とんぼがえりをうってみたの」　お千代さんは、いつも正坊を、ほんとうの弟のようにかわいがっているのでした。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
