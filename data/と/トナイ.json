    "definitions": [
      {
        "index": 1,
        "gloss": "within the (Tokyo) metropolitan area",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
