    "definitions": [
      {
        "index": 1,
        "gloss": "roundabout (e.g. expression)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
