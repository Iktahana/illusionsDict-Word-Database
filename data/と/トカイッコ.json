        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この美少年は不良を衒っているが根が都会っ子のお人好しだった。",
              "citation": {
                "source": "桃のある風景",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏は都会っ子的な上皮の強がりは大分ありますがなかなか憶病でも気弱でもあります。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これというのもこの学園へ来る男女の子弟たちは多く山の手生れの都会っ子の為めなのでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは月並なものと思っているこれ等のものが、さすがに都会っ子のわたくしに、こういう場合は何か勇気附けるものがあると見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ表面はごく捌けた都会っ子で、偏屈な妹には薬になるかも知れない。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、都会っ子ねえ、そうでしょう」　私は、私も田舎育ちであり、そこも又、白砂だったことを告げた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
