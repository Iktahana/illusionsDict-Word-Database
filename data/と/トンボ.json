  {
    "uuid": "34dd5b40-f8aa-57e5-b2f5-a66b066bb0d4",
    "entry": "トンボ",
    "reading": {
      "primary": "トンボ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(color) registration mark",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "舟をこしらえたり、家をこしらえたり、トンボや、飛行機や、いたちや、雉を捕るわなをこしらえたり、弓で海の中に泳いでいる魚をうったり。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒い毛氈の上に、明石、珊瑚、トンボの青玉が、こつこつと寂びた色で、古い物語を偲ばすもあれば、青毛布の上に、指環、鎖、襟飾、燦爛と光を放つ合成金の、新時代を語るもあり。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "くるみわりがトンボ返りをうつかと思うと、石筆は石盤の上をはねまわります。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふざけんぼうのイルカは、トンボ返りをうっていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことにでもなれば、きっと、みごとなトンボ返りをやってのけるでしょうからね。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばあさんは、トンボ返りを打っています。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまりうれしすぎて、つい、トンボ返りをうちました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人たちは、きのう、王さまがなさったように、きょうは、みんなで、トンボ返りをうちました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争が終って間もなく、ある野外音楽会の実況放送があったが、紹介の放送員はさすがに戦争中と異った型を出そうとしたらしく、「ここ何々の音楽堂の上の青空には、赤トンボが一匹スイスイと飛んでおりまして、まことに野外音楽会にふさわしい絶好の秋日和でございます」と猫撫声に変っていた。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は世の中も変ったものだと感心しながら聴いていたが、その放送中赤トンボが三度も飛ばされたのには些か閉口した。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、あとでその時の音楽会に出演した人にきくと、その日はどんより曇っていて、赤トンボなぞ一匹も飛んでいなかったということである。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "同様にその飛びまわりつつ描く直線曲線が、全然無意味なままに相似ていて、バッタの一足飛びや、トンボの飛行機式なんぞとは比べものにならない程、美的なリズムに満ち満ちているところを見ると、蝶には他の翅虫たちよりも遥かに勝れた美意識があるように見える。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "尻切れトンボの二つ目の理由が気になって、ファウンデーション・シリーズの第一作、『銀河帝国の興亡１』を読み直してみました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、もつと長い方が好いと思はれ、これでは冒頭の感想に照らして尻切れトンボではないかといふ気がした。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものの一丁もあろうという河原から、丁場のウインチへ、「トロがトンボ（転覆）したから、捲くのを待て」というような場合、腹一杯喚かなければ、用が足りないのである。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「階段の飛び降りとか、機械体操のトンボ返りぐらひなら子供の時分は巧かつたが、あんな単調な運動には愛想が尽きてゐるのさ。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮮かなトンボ返りを打つて見物の同情を惹くことが出来ない――）　人形は、灰色の服を着てゐた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高志なんか、成田でぼくを無視して、一所懸命うしろのほうを見てたんだから」「あんな、蚊トンボみたいな奴が、こんなに膨らむとは思わないだろうが！",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蚊トンボって、なに？",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶するつもりなのだろう、ワラは口のなかで、蚊トンボ、蚊トンボとくりかえしてから、慶一を見た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのテイルのデッキに列車のライフ・ガードが引っかかって、逆トンボ返りにハネ飛ばされて、タイヤを上にして堤の下へ落ちていたって言う話よ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日と、赤トンボの流るる東京郊外から、牛込の宿まで帰りながら考えた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれからもう既に六十日にちかい月日が経つて、蝉の声はすつかり止絶えて、わづかばかりの赤トンボと秋型の黄蝶がちらほらとしか飛んでゐない頃となつた。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "川トンボの模様が薄墨色で描かれ、水のすがたが乙字型に流れてゐる。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな声が、やはり花片のやうに四方から降りかゝり、何方が海で、何方が陸か、不図見当がつかぬやうな錯覚に打たれた――と思つたが、それは僕がもう二三間で波打ちぎはにたどりつかうといふところで、勢ひをつけ、トンボ返りをした刹那の、耳に散り散りに残つてゐた、さつきからの彼等の嘲笑だつたのだ。",
              "citation": {
                "source": "熱い砂の上",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼はさう嘆声を挙げると感極まつた如く麗かに四肢を延して天を仰ぎ、忽ち翻つてピヨンと鮮かなトンボ返りを打つた。",
              "citation": {
                "source": "渚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "樽野はハーモニカなどが鳴つてゐるパラソルの傍を飛鳥の如く駈け抜けて屹度波打ちぎわで鮮やかなトンボ返りを打つてから波の底にもぐるのが習慣だつた。",
              "citation": {
                "source": "鶴がゐた家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「トンボ踊りは御免ですよ。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "トンボ踊りといふのは、滝野が酔つた時自分で出たらめに名付けた出たら目の踊りで、口笛を吹いて、両腕を延して、爪先で立ちあがり、漫然と部屋のなかを彼方此方に浮遊する割合に静かな遊戯だつた。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
