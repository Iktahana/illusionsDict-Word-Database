    "definitions": [
      {
        "index": 1,
        "gloss": "nearby mountain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジル・マルシエツクスの告別演奏會が公會堂にあるので皆で出掛け、其處で外山楢夫先生、外村完二氏にお會ひした。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺骸を郊外山腹にある先祖代々の墓地に葬った後、なまなましい土饅頭の前に仮の祭壇をしつらえ神官が簡単なのりとをあげた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると柿色の囚人服を着た外山直堂であつた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "話が自分の経歴見たようなものになるが、丁度私が大学を出てから間もなくのこと、或日外山正一氏から一寸来いと言って来たので、行って見ると、教師をやって見てはどうかということである。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで兎に角やって見ようと思ってそういうと、外山さんは私を嘉納さんのところへやった。",
              "citation": {
                "source": "処女作追懐談",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの陳和卿はその後、生死のほども不明でございまして、まさか、日野外山に庵を結んで「方丈記」をお書上げになつたといふやうな話も聞かず、やつぱり、ただやたらに野心のみ強く狡猾の奇策を弄して権門に取入らんと試みた、あさはかな老職人に過ぎなかつたやうに思はれます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台とか云う外山に向いて、）……と云うんですから、今の月見堂の事でしょう。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ十里ほども北へたどると、外山村に着く。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらは鮎が名物で、外山から西根尾まで三里のあいだに七ヵ所の簗をかけて、大きい鮎を捕るのである。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして雑木林よりはよほど高い、外山の頂とも言うべき所に来た。",
              "citation": {
                "source": "山椒大夫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "右　勝卜部兼直しぐれつる雲を外山にわけすてて　　雪に越えゆく足柄の關左前中納言爲相女足柄の山のあらしの跡とめて　　花の雪ふむ竹の下道花を踏むも、雪を踏むも、風情にさばかりの優劣はなけれど、嵐のあとをさぐるよりは、時雨の雲をわけつる方が、細工の痕なくて、自然の詩趣を得たり。",
              "citation": {
                "source": "足柄の山水",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五年前には外山博士が大批評家であって、博士の漢字破りの大演説が樗牛のニーチェ論よりは全国に鳴響いた。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "外山博士一流の「死地に乗入る六百騎」的の書生節とは違って優艶富麗の七五調を聯べた歌らしい歌であったが、世間を動かすほどに注意を牽かないでしまった。",
              "citation": {
                "source": "美妙斎美妙",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、一人、外山長蔵という同業の人たちも寄り合い、相談をした席で、金田氏のいうには、「それについて、私が思い附いた面白いことがありますが、一つ皆さんへ申し上げて見ましょう。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫工会の成り立ちについて",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大学の先生になったのですからフロックコートを一着持って居らねばなりません』と申しますと『ノウ、外山さんに私申しました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで宣しいですと外山さんが約束しましたのですから、フロックコートいけません』と云うのです。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸中遠野郷小友村字高柴の千眼城山の権現は元｜外山という所にいたのであったが、あるときの山火事のときに現在の所に飛んできたのだという。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその二階は図書室と学長室などがあって、太いズボンをつけた外山さんが、鍵をがちゃつかしながら、よく学長室に出入せられるのを見た。",
              "citation": {
                "source": "明治二十四、五年頃の東京文科大学選科",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　被告外山勝将（二五）、もと運転手、同分会執行委員「被告に対してもあらゆる方法をもっておどかし、例えば町のゴロツキの如くお前は検察庁に喧嘩をうるつもりか。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同じ日の法廷で被告外山も「残念ながらとうとう最後までがんばれなかった一人」として次のことをのべた。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "この事件には外山、田代、伊藤、清水も――あとから飯田も共同謀議に参加している』といいました。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "」天野検事が、横谷、外山、清水、宮原、伊藤、田代の名をあげる。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　第二回公判は、このような起訴状の朗読と被告飯田、外山、清水の起訴事実否認で閉廷された。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治初年の思想家で、哲学およびその他精神科学に関係のある主なる人々を挙ぐれば、まず西周を筆頭とし、西村茂樹、加藤弘之、外山正一、中江篤介などであった。",
              "citation": {
                "source": "明治哲学界の回顧",
                "author": "序論",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通選挙論では外山正一が福地に応援して、「毎日記者は盲目蛇におじざるものだ」といった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、少々｜病膏肓に入つたかなとやましくなると、なあに運動のためだといふ風に自分で自分にいひ譯してゐた。",
              "citation": {
                "source": "文壇球突物語",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さは云へまことやまつつじ、　　日影くもりて丘ぬるみ、　　ねむたきひるはかくてやすけき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一度、きっとやましい処はないか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お嬢さんはどういう方」　するとやまは難かしい試験の問題のようにしばらく考えて、「さあ、どういう方と申しまして……あれきりの方でございましょう」　私はこのませた返事に微笑した。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう一度、屹とやましい処はないか。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
