[
  {
    "uuid": "c4fc76f7-e8a1-5eeb-9203-bed124efb35a",
    "entry": "刀痕",
    "reading": {
      "primary": "とうこん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
