    "definitions": [
      {
        "index": 1,
        "gloss": "old (person)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヴェスヴィオの麓までの馬車には年取った英国人の夫婦と同乗させられた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取った祖母と幼い自分とで宅の垣根をせせり歩いてそうけ（笊）に一杯の寒竹を採るのは容易であった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の堂内には年取った婦人が大勢集まって合唱をしていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の子供等が今の自分ぐらいの年配になる頃には、ことによるともう正月に雑煮を喰うという習慣もおおかた忘れられて、そうしてその頃の年取った随筆家が「雑煮の追憶」でも一九六五年あたりの新年号に書くことになるかもしれない。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分に姉の家に庫次という眇目の年取った下男が居た。",
              "citation": {
                "source": "ＫからＱまで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取った鮮人と、私とが二人きりで、部屋の中に残された。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある朝当時自分の勤めていたＲ大学の事務室にちょっとした用があってはいって見ると、そこに見慣れぬ年取った禿頭のわりに背の低い西洋人が立っていて、書記のＳ氏と話をしていた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和六年六月『家庭』）　　　　　　こわいものの征服　ある年取った科学者が私にこんな話をして聞かせた。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年取った、そして、少しばかり風変りな科学者のこの話は、子供を教育する親達にも何かの参考になりそうである。",
              "citation": {
                "source": "家庭の人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の科学と芸術とは見たままに描けと命ずる一方で、なんだか絵として見た時に不自然ではないかという気もするし、年取った母がいやがるだろうと思ったので、とうとう右衽にごまかしてしまったが、それでもやっぱり不愉快であった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家伝の名灸でその秘密をこの年取った奥さんが伝えていたのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってこの年取った子供のこの一夕の観覧の第一印象の記録は文楽通の読者にとってやはりそれだけの興味があるかもしれない。",
              "citation": {
                "source": "生ける人形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年取った方は、前庭の乾いた土に筵を敷いて、背むきに機台に腰かけたが、トンと足をあげると、ゆるくキリキリと鳴ったのである。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも年取ったよ」　京吉はふと女の顔を覗きこんで、ほう、ちょっといけるな――。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、あんな年取った王さまが、あの若い美しい王女をお嫁にしようとなさるのだから、王女がおいたわしくてたまらない。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は棄てッ鉢に飲んだ酒が十分まわって来たので、張りつめていた気も急にゆるみ、厭なにおいも身におぼえなくなり、年取った女がいるのは自分の母のごとく思われた。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "会堂の窓からのぞいて見ると若いのや年取ったのやおおぜいのシナの婦人がみんなひざまずいてそしてからだを揺り動かして拍子をとりながら何かうたっている。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取ったふとった案内者の顔はどこかフランスの大統領に似ていたが、着ている背広はみすぼらしいものであった。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、もしあの学生が「藪柑子集」を読んだとしたら、その内容から自然に想像するであろうと思われる若い昔の藪柑子君の面影と、今ここで、水ばなをすすりながら「性的犯罪考」などをあさっている年取った現在の自分の姿との対照を考えると、はなはだ滑稽でもあり、また少しさびしくもあった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "功名心の盛んな趙は、すぐ上京したいと思ったが、年取った母親のことも気になれば、愛卿を遺して往くことはなおさら気になるので、躊躇していた。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに年取った怪物がいた。",
              "citation": {
                "source": "太虚司法伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の一方の扉が開いてずんぐりした年取った女が入ってきた。",
              "citation": {
                "source": "陳宝祠",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年取った男はと見れば、まだ法衣を羽織っていたが、私がまだかつて耳にしたことなどはないような、呪詛の言葉を放ちながら、ピストルを取り出して向けようとした。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう大体の見当はついたが、――またこの電信でどうしようと云うことも、まあ想像は出来るが、しかしこうして待っている間に、君の知ってるだけのことを話してもらってもいいね」　その年取った法衣姿の無頼漢は、無茶苦茶な悪口罵詈を浴びせかけて来た。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　年取った法衣姿のごろつきが悪口雑言をまくし立てる。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "年取った親たちだけをたよりにして、いつ人並みの娘のような幸福が得られるものとも知れなかった過去は、今に比べて懊悩の片はしも知らない自分だった。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある若者、その師より戒められたは、妻を娶るは若い娘か後家に限り、年取った娘や、嫁入り戻りの女を娶るなかれと。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い娘と後家はこの事を秘したが、年取った娘と、嫁入り戻りの妻は大秘密と印した状を各母に送ってこの事を告げたので、明日たちまち市中に知れ、ついに王宮に聞えた。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（年取った乞食のような恰好）これ良ろし。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへん年取った老人らしい。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
