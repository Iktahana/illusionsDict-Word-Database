        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新幹線に乗るには、乗車券と特急券の両方が必要です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "指定席の特急券は売り切れていたが、自由席ならまだ買えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駅員に特急券を提示して、ホームへ向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "名古屋で下車して帰りの特急券を買うために方々うろつく。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "多賀子はとなりの部屋で虹ヶ浜駅へ特急券をかいにゆく仕度をしていて、富雄さんは昼寝にかえって来ているところ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夕方の六時過ぎに、神戸の大丸や元町あたりの商店の包紙に包まれた物を一杯提げて帰って来て、「これ買うて来た」と、帯の間から翌朝の「ふじ」の特急券を二枚出した。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
