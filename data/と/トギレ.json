        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "神主の祝詞が「聞こし召せと、かしこみ、かしこみ」と途切れ途切れに聞える時には、素朴な板葺のかけ茶屋の前を通って、はや小御岳神社へと詣でるころであった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "参拝者の来るのが始めのうちは引切りなしに続いてくるが三十分もたつと一時まばらになりやがてちょっと途切れる。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は一寸途切れてしまった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "互に途切れ途切れに話しをしている。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お前の歌聲は直ぐに途切れた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "途切れた隙に私は思はず息を呑んだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それに第一、私達四人は昨日から何にも食べませんの……」と、女は啜り泣きをこらへながら、途切れ途切れに答へ返した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、途切れに小隊の後を追つて漸くもとの隊伍に歸つた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉はそれなりに途切れて、青木さんは庭の暗やみの方に眺め入り、奧さんは針の手を再び動かしはじめた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま暫らく詞は途切れた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉はまた暫らく途切れた。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして詞も途切れ勝ちになつて、二人は俯いたまま足早に歩いた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "厭世家と云ふものは一種のイゴイストですから……」　聲が途切れると、またしんとなる。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　耳にしながら看護員は、事もなげに手に取りて、海野が言の途切れざるに、敵より得たる感謝状は早くも衣兜に納まりぬ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十二年から四年へかけて西洋へ行っている間だけがちょっと途切れてはいるが、心持ちの上では、この明治三十二年以後今日まではただひとつながりの期間としか思われない。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの……蔵元屋の……アノ博多小町……」　そんなヒソヒソ話が急に途切れて皆、一時にバラバラと逃出しそうな身構えになった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもそのうちに下り列車が、二人の鼓膜を震憾して通過したので、やっと話が途切れた。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「話が途切れましたが、……僕は今学校の鐘の音に聞きとれていたもんですから……あれを聞くと僕は自分の家のことを思いだします。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "深い綿雲に閉ざされた闇の中を、霰の群れが途切れては押し寄せ、途切れては押し寄せて、手稲山から白石の方へと秋さびた大原野を駈け通った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話題が途切れると、園は静かな口調で、今まで読んだところを人見に話し始めたが、人見にとっては初耳で珍らしい事実が次から次へと語りだされるのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話柄が途切れて閑とすると、暑さが身に沁みて、かんかん日のあたる胴の間に、折り重なっていぎたなく寝そべった労働者の鼾が聞こえた。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の話は又暫く途切れた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勃凸との話が途切れるとおんつぁんはぐつたりして客車の天井を眺めてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の途切れるのをおとなしく待ちつけて、「これが二番目にきれいな薔薇なの、パパ」　と言いながら柔和な顔をして貴女を見た。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋になつてから、山から里の方に下つて來たかけすが百舌鳥よりも鈍い、然しある似よりを持つた途切れ／＼の啼聲を立てゝ、その黒い枝から枝へと飛び移りながら、人眼に遠い物蔭に隱れてゆく。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病らしい蟋蟀の声が土台の下で途切れ途切れに啼き出して、遠い裏門の辺には、野帰りらしい百姓の、太い空咳などが聞えた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は大隅君の土産話のちょっと、とぎれた時にそう言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてこのあはれなる木は、粗硬な樹皮を、空と風とに、心はたえず、追惜のおもひに沈み、懶懦にして、とぎれとぎれの仕草をもち、人にむかつては心弱く、諂ひがちに、かくてわれにもない、愚事のかぎりを仕出来してしまふ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もしない者、何も知らないそうだ」　田川は唸く声の間から、とぎれとぎれに繰りかえした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、とぎれ、とぎれに、遠く、駅前通りの方にまでつゞいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
