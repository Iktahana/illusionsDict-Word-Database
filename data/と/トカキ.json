        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サッとかき曇った空模様は、何かのたたりを暗示するように思わせた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、火山の爆発だけは、今にもう少し火山に関する研究が進んだら爆発の型と等級の分類ができて、きょうのはＡ型第三級とかきのうのはＢ型第五級とかいう記載ができるようになる見込みがある。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田策さんて言えよ」　小田は髪の毛をクシャクシャとかきわけながら、怪しげな笑いを笑って、「――追い出されたよ」　ひとごとのように言った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」女優は、いきなり青年の肩をしっかりとかき抱いて、幾度も幾度も接吻しながらさて小さい声で囁くようにこういいました。",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘はうるしをぬった、色どり美しい箸で、水の中をそっとかきまわしていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か物思いにしずんでいましたので、ほんとうに、ほんとうにゆっくりとかきまわしていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのわけも、日記の「あとかき」として申し上げる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとかき　どうであったろうか。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは子供の時分から、菖蒲の花とあやめの花とかきつばたの花の区別が、どうしてもつかんのですが、こりやどうしたもんでござりませう。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それでまだ菖蒲とあやめとかきつばたの区別のつかんのは、だね。",
              "citation": {
                "source": "百姓の足、坊さんの足",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "簡単にあとかきます。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、かわいいお坊っちゃん、お拭きしましょかなも」「いやだ」という裸のを、きゅっとかき抱くようにする。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊さんは帳面へ、そのまま「ウイリイ」とかきつけました。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、ここへぐるりとかきをこしらえて、そのかきへ、八ところに門をあけよ。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字春は両袖をしっかりとかきあわせて、自分の下駄の音にもおびやかされながら、小股に急いで来ると、暗い中から駈けて来た者があった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お起きにならないと横浜のほうがおそくなるわ」　倉地はやはり物たるげに、袖口からにょきんと現われ出た太い腕を延べて、短い散切り頭をごしごしとかき回しながら、「横浜？",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はやせ細った肩を単衣物の下にとがらして、神経的に襟をぐっとかき合わせて、きちんと膳のそばにすわって、華車な団扇で酒の香に寄りたかって来る蚊を追い払っていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとももう一度名前を呼んだら、線香の上にたまった灰が少しの風でくずれ落ちるように、声の響きでほろほろとかき消すようにあのいたいけな姿はなくなってしまうのではないだろうか。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと村……とかきかけても、どうしてもその後がかけなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九に点を与えるときには滑稽が下卑であるから五十とか、諧謔が自然だから九十とかきめなければならぬ。",
              "citation": {
                "source": "作物の批評",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまだできていないの」とかきかけを三四郎の方へ出す。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ法律家が何とかきめるだろう。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄人でいた頃、あの二人が張り合っていたそうでござりましてな、売ったお武家さまは、腰本治右衛門とかおっしゃるお歴々、売られたお方は湯島とやらの町絵師とかききました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "禄高はたしか五百石取り、三品流の達人とかききましたよ」「つらに覚えはねえか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良少年の職業は、警視庁や、その他市内の各署で昨年の冬まで捕まったのが統計に出来ているとかきいたが、その方は調べ得なかった。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭の日、むつかしき言のかずかず挨拶ひ、父は笑ましき、禿頭するするとかきあげながら――われもまた爲ではかなはじ、かのごとも大人とならば。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "師走の夜の寒さが身にしみるのか、なにか深い物思いに沈んでいるのか、お鉄は両袖をしっかりとかき合わせて、肩をすくめながらおとなしく付いて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草好きの佐山君は一本の煙草をすってしまって、さらに第二本目のマッチをすりつけた時に、釣竿を持った一人の男が蘆の葉をさやさやとかき分けて出て来た。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
