      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "perversion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女性には、このような肉体｜倒錯が非常にしばしば見受けられるようである。",
              "citation": {
                "source": "女人訓戒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しみと恋が倒錯したのだと思います。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、あの自尊心の倒錯である。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬愛の念が、ぎくしゃくと奇妙に倒錯して、ついに、仙台あなどるべからず、とでもいうような「張り合う」気持などが出て来て、あんなまずい手紙を書いてしまったのではあるまいか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、これらのお慈悲、ひねこびた倒錯の愛情、無意識の女々しき復讐心より発するものと知れ。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりの恐怖に、奇妙な倒錯が起ったのである。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名の無い形と色と匂と動作とが、距離や時間の観念の奇妙に倒錯した異常な静けさの中で、彼の前にたちまち現れ、たちまち消えて行く。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは自分の心の中の邪悪と、倒錯観念の交響世界で実に不可思議な苦痛深刻を極めたものでした。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして半年ばかり経過するうちに、栄養が十分に付いて来て、云う事がイクラカ筋立って来た頃を見計って、なだめつ賺かしつしながら色々と事情を聞き訊してみますと……色情倒錯どころの騒ぎではない。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神田で雑誌を出している友人の元へ、弄花に往くと云う細君と伴れ立って家を出て、二三日横浜あたりを遊び歩いて帰った日の細君の倒錯的な癖を彼は思いだした。",
              "citation": {
                "source": "文妖伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うめえ、うめえ、うめえ、うめえ、うめえ、うめえ」「まあ、ずいぶんね、え」　天風の頭にはまだ細君の倒錯的な性癖があった。",
              "citation": {
                "source": "文妖伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところが君、ブルジョアはそれ以上の高利貸的官能のために、あるいはまた倒錯症的欲望のために、食わせないこと、と、生殖させないこととで蠢動してるんじゃないのかい」といって小倉は大声立てて笑ったが、フト気がついたように、ボーイ長の方を見やって口をつぐんだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一度倒錯した価値観は封建時代からずつと現代にまで根を引いているのであるが、それが本来の大和心からどんなに遠いものかは今さら言うまでもないことである。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋文明の没落という現代の挽歌的ミトスが、このような説にエキゾティシズムか倒錯した郷愁かの響きを与える。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "却って倒錯した歴史観を産むものが、文献学主義であり教学主義なのだ。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "誇張していえば、あの戦争でぼくは余りにも度々、親しい人たちに冷たい「さようなら」をしてしまったので、別離の悲哀に無感覚になったばかりか、緊張病の狂人が自分の糞尿を愛惜するような倒錯心理に似て、自分にいちばん苦痛を与える別離の悲しさを、苦しい故に反って愛するようになったともいえるのだ。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは自分の妻子や同胞、人間に対する愛情が、戦争の血に汚されてきた為か、ともすれば不信から憎悪に変ずるのをどうしようもなく、再び裏切り者、罪人の意識のほうが快ろよい倒錯心理で、党から離れ、暫く落着き場所のないまま、妻子のもとに返っていた。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "神聖冒涜の近代人の病的な倒錯心理かもしれぬ。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "春婦の肉体を神聖と思いこんだのも既に倒錯心理とすれば、二重、三重のぼくの偏執や倒錯。",
              "citation": {
                "source": "さようなら",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽のもとでは、さぞ酷らしいであろうその屍体が、このぼーっ、ぼーっと照しだされる蛍火の下では、どうしたことか却って、夢に描かれたように、ひどく現実離れのした倒錯した美しさを見せるのであった。",
              "citation": {
                "source": "鱗粉",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "撲りながら、自分が情けなくなつたのも事実であるが、このやうな彼の倒錯した気持は、この後もずつと続いてゐる。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから今一つ、今も申します通り、その構想の不可思議さが又、普通人の所謂、推理とか想像とかを超越しておりまして、読んでいるうちにこちらの頭が、いつの間にか一種異様、幻覚錯覚、倒錯観念に捲き込まれそうになるのです。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に生まれる色々な錯覚や、幻覚、倒錯観念の魅力でもって、読者のアタマを引っぱって行くのが、探偵小説の身上じゃないか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ無暗矢鱈に奇抜突飛な、幻覚、錯覚、倒錯観念の渦巻きのゴチャゴチャだけしか感じられない……かも知れないというのが、トップのトップを切った脳髄小説のミソなんだからね。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
