          "literary": [
            {
              "text": "文庫版の著作権表示欄には富田倫生の表記がないため、こちらと本書との記述を読み比べられた方は、盗作の疑いをより強く持たれるだろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は先人の仕事を盗作することに疑問を持たなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議なことにブラウン学説をドイツに広げたのは盗作者によるものであった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
