        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "表紙についている引っかけ式の留め具は、いわば本にかける鍵なのでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "目指すものを取り出した後、下に降ろすのは困難だろうが、可動式の留め具を外套のカラーに引っ掛ければナップザックのように運べるだろう。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞんざいに自分の体と今よじ登っている書棚の表面との間にそれを挟み、留め具を手探りして、ついにフックを外した。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとためらった後、棺の蓋の留め具を外した。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにか知らねど萩原朔太郎なにか知らねど泣きたさにわれはゆくゆく汽車の窓はるばるときやべつ畑に日は光り風見ぐるまきりやきりりとめぐる日にわれはゆくゆく汽車の窓なにか知らねど泣きたさに",
              "citation": {
                "source": "なにか知らねど",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お濠をぐるっとめぐって、参謀本部のとこから、日比谷へ出て、それから新橋駅へ出て、赤羽は、その裏じゃないか。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪より悪へとめぐることぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪より悪へとめぐることじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い娘の行衛を心配して探しに来た母親や伴の者とめぐり合ったので、慧鶴は無事に娘をそれ等の手に引渡した。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな風に端のない絲をたぐるやうに考へがぐるぐるとめぐつてあるくのであつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "またしても、お小夜とお里と、それに時たまの例となつて、死んだお辻さへ異形のなかの一例となつて宗右衛門の眼前をぐる／＼とめぐつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は道が岩山をぐるっとめぐってついてあるのを了解した。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さむざむし池の面や、行けば行き、とめぐればただめぐりて。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌大御代の多摩の酒屋の門櫓酒の香さびて名も古りにけり西多摩の山の酒屋の鉾杉は三もと五もと青き鉾杉餅搗きの歌武蔵野や多摩のみなかみ、御嶽道払沢の口、春浅き日南のそとに、餅搗くや爺は杵とり、臼のべや婆は手に捏ね、ぽたらことのどに対ひぬ、ぽたらこよゆるにとめぐる。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌大御代の多摩の酒屋の門櫓酒の香さびて名も古りにけり西多摩の山の酒屋の鉾杉は三もと五もと青き鉾杉餅搗きの歌武蔵野や多摩のみなかみ、御嶽道払沢の口、春浅き日南のそとに、餅搗くや爺は杵とり、臼のべや婆は手に捏ね、ぽたらことのどに対ひゐ、ぽたらこよゆるにとめぐる。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい五六人で組をつくつて、ありとあらゆるさま／″＼の蛇のはいつた、籠や袋や箱をかついで、町から町へとめぐつて歩き、人どほりのおほい広場や空地で、人をあつめて見せるのです。",
              "citation": {
                "source": "蛇つかひ",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはただおのおの右手にあいての婦人の指をつまみて、この間をひとめぐりするなり。",
              "citation": {
                "source": "文づかい",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜にふた晩泊って、三日目に江戸へ帰るというのが最初からの予定であるので、きょうは朝のうちに見残した所をひとめぐりして、神奈川の宿まで親類の者に送られて、お峰とお妻の親子は駕籠に乗った。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "磯へつくと船はぐるつとめぐされて艫が波打際まで突きあがる。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "石臼は其儘幾つかごろ／＼とめぐして此れで蕎麥挽はやめた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "若党の平造はどうなったか判りませんが、身分の軽い者でございますから、おそらく無事に逃げ延びたものであろうと存じておりますと、昨年の六月、両国の広小路でふとめぐり逢いましたのでございます。",
              "citation": {
                "source": "平造とお鶴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから京の町をひとめぐりしたが、きょうも都の人はちっとも彼に商売をさせてくれなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の葬いのことや、千葉から広島へ引あげる時のこまごました情況や、慌しく変ってゆく周囲のことを、丹念にノートに書きつづけているうちに、あの惨劇の日とめぐりあったのだった。",
              "citation": {
                "source": "遥かな旅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう時代になったら、火星と地球との間を、一週間で往復することが出来るかもしれないし、それとともに、大宇宙に棲む他の高等生物とめぐり合って、奇妙な交際が始まるかもしれない。",
              "citation": {
                "source": "成層圏飛行と私のメモ",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲掴みにしたのに何の不思議があらう、勝負附の星は一度取逃がしても、また取返す時機があるが、褌担ぎの身には三十円は一度取落したが最期、二度とめぐり会ふ折があらうとも思はれなかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、ここにこれが、とめぐり合いのよろこばしい感じで心を打って来る刹那の瑞々しさは、作品の世界の一般に欠乏している。",
              "citation": {
                "source": "人生の共感",
                "author": "――求められる文学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうひととめぐり合えたことをも、根本に溯ってみれば階級のもつ積極的な人間関係の可能性の現れであると思い、私は単なる友情のよろこびより以上のものを感じている。",
              "citation": {
                "source": "窪川稲子のこと",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦場で、父とめぐり合うということは、彼が空想で描いたほど真直に工合よくは行かないらしいことが明かになって来た。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっとめぐりあってうれしい自分たちの夫婦にあるものは、ともどもの生活難であることを知っている妻たちは、帰った日に発揮される良人たちの人民としての権利を新しい思いでみたのであろう。",
              "citation": {
                "source": "肉親",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、たとえ彼の骨が同じ墓地に埋められるとしても、人間の形では、もはや妻とめぐりあうことはないであろう。",
              "citation": {
                "source": "死のなかの風景",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
