[
  {
    "uuid": "c3600406-135e-59ee-a0a0-81d42591b647",
    "entry": "渡御",
    "reading": {
      "primary": "とぎょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
