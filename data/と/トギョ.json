    },
    "definitions": [
      {
        "index": 1,
        "gloss": "transferral of a sacred object from its place of enshrinement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこに神輿が渡御になる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日、癸巳、将軍家、広元朝臣の家に渡御、相州、武州等参らる、和歌以下の御興宴に及ぶと云々、亭主三代集を以て贈物と為すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿一日、戊申、将軍家、三浦三崎に渡御、船中に於て管絃等有り、毎事興を催す、又小笠懸を覧る、常盛、胤長、幸氏以下其射手たりと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日、丙午、天霽、申剋、将軍家前大膳大夫広元朝臣の亭に入御、是去る二日、御所焼失せるに依るなり、御台所、又南御堂より其所に入御、尼御台所、本所に渡御。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿五日、戊※、御台所厳閤の薨去に依りて、信濃守行光の山庄に渡御、密儀なりと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十三日、丁亥、将軍家海辺の月を御覧ぜんが為、三浦に渡御、左衛門尉義村殊に結構すと云々。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな君枝の心は、しかし他吉は与り知らず、七月九日の生国魂神社の夏祭には、天婦羅屋の種吉といっしょに、お渡御の人足に雇われて行くのである。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "生国魂はんのお渡御の中にはいるもんが、斃れたりするかいな、ちゃんと生国魂はんがついてくれたはる――ああ、今年もベンゲットの他あやんが来とるなあ言うて、守ってくれはるわいな」　心配しな、心配しなと、矢張り他吉は鎧の方に廻るのだった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "種吉は丁度生国魂の祭で例年通りお渡御の人足に雇われたのを機会に、手を引いた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "西瓜の顔を見ると、庖丁を取りだしてくる筈の種吉は、他吉といっしょにお渡御に出かけて、まだ帰っていなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸を抱くようにして呟いているところへ、お渡御が済んだらしく、他吉と種吉がとぼとぼ帰って来た。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　お渡御に出て、すっかり疲れ切っていたが、しかし、他吉は夜が明けて路地の空地で行われる朝のラジオ体操も休まなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二月七日辰刻、将軍家｜渡御中泉｜先献御膳｜暫有於奥之間大御所御対面本多佐渡守｜同上野介召御前｜御密談移刻」　四月初旬には、多くの諸侯に、出征準備の内命を発している。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな君枝の心は、しかし他吉は与り知らず、七月九日の生国魂神社の夏祭には、お渡御の人足に雇われて行くのである。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その日は公休日で、よりによってこんな日にぶらぶらしていることが、君枝はなにか済まぬ気がして、お渡御など見る気がせず、家を出た足でせかせかと下寺町の坂を降りると、自然千日前の電気写真館の方へ向いた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎は写真に凝っていて、今夜じゅうにあのマラソン競争の記念写真を引伸して持って来てやると約束したと、いそいそと下駄をはいているところへ、お渡御が済んだらしく、他吉がとぼとぼ帰ってきた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも如何に思わるるは、皇祖神武天皇を古く奉祀せる渡御前の社をも合祀し、その跡地なる名高き滝を神官の私宅に取り込み、藪中の筍を売り、その収入を私すと聞く。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうん、どうん――カツ、カツ、カツ……どうん、どうん……」　目醒しい物音は、森を飛び、丘を越えて、八方に、神輿の渡御を知らしむると、待ち構へてゐる村人達は、「それ、天狗様のお通りぢや／＼！",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "新町はお祭、四十八瀬川のほとりに組み立てられたバラツクへ御神輿が渡御された、私も参拝する、月夜、瀬音、子供の群、みんなうれしいものだつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――但し、日枝神社の祭礼が前にいった六月十五日で、一月飛んだ八月十五日が深川八幡、その翌月の九月十五日が神田明神という順序で、余なるは住吉神社の祭礼に神輿の海中渡御があるのと、三社の祭りに花川戸の兄哥たちが、自慢の神輿を吉原五花街へ担ぎ込むのとが、一風変ったおかしみがある。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「将軍家（源頼家）駿河国富士の狩倉に渡御す。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは神輿渡御の間は、町中が一点の燈火も残さず消して真の暗闇にするために、その間において、町の女達はいうまでもなく、近郷から集って来ている女達が、喜んで神秘のお蔭を蒙りたがるという、噂の虚実を確めずに、その実地を探りにと出掛けたのであった。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日には大神事として、八基の神輿が暗闇の中を御旅所に渡御とある。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍ハ当時ハ病気にてけしてきづかハしき事なけれども、文などしたゝめ候ハ、誠にいやなれども鳥渡御咄申上候。",
              "citation": {
                "source": "手紙",
                "author": "文久三年六月十六日　池内蔵太の母あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "時計を見ますと、そんな時刻でしたから、鳥渡御様子を見に参りました」「その前に誰も部屋に這入らなかった？",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはかつて、祇園の信仰でもち歩かれた一つの神輿、又はそれに類似のものが渡御になる道の楽です。",
              "citation": {
                "source": "無頼の徒の芸術",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪天満の天神祭りに船渡御があつて、御迎へ船が出ることなども、祭りの際に、神は他所に降つて、其処から祭場に臨むといふ暗示を含んでゐるのである。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡御に一旦他所に降臨して、其処から祭場に臨まれる事を示すのである。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月三十日（昔は大祓の日）には、堺の宿院の御旅所へ住吉の神輿の渡御がある。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたびごとに廊下でだれかが「マアきれいな花ですこと」とぎょうさんにほめる声が聞こえた。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
