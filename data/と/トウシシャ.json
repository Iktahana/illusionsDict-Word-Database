  {
    "uuid": "f59a5df5-637f-5232-8fea-a17b9496ab15",
    "entry": "投資者",
    "reading": {
      "primary": "とうししゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
