  {
    "uuid": "93a41b82-b7b2-5e7d-8b26-a8e647a1cc88",
    "entry": "取り組み",
    "reading": {
      "primary": "とりくみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
