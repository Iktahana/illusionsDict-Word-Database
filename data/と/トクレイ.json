[
  {
    "uuid": "60be1fbc-4331-5b8b-be63-01826158b415",
    "entry": "特例",
    "reading": {
      "primary": "とくれい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
