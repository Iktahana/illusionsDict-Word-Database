[
  {
    "uuid": "e6e41a11-7018-5dfb-8d99-9368c2a67854",
    "entry": "得点",
    "reading": {
      "primary": "とくてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
