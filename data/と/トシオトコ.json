[
  {
    "uuid": "47f33518-1d54-50c5-aa1b-8ecfe14cc5d6",
    "entry": "年男",
    "reading": {
      "primary": "としおとこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
