        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "肴屋には秋刀魚重なり合ひ、八百屋には、唐菜、三河島、大根、葱などの山積する時節也。",
              "citation": {
                "source": "近藤重藏の富士山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代に、まだ今のように白菜にならん前のものが長崎に来て、それが日本に拡まったのですが、それをその当時の日本人は、支那から来た菜というので唐菜といって居る。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔来た唐菜は今ではどうなったか。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大根や唐菜が、耕された畑に青々と伸びてゐた。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に白状すると、これはポオの翻案であつて、鶏の朝鳴を、とをてくうる、もうるとうなどの音韻で表象させ、全体にポオの「大鴉」と似たやうな詩想を、似たやうな表現技巧で出さうとした。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源は「ウーム」とうなつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長はちょっとうなづいてだまって室の隅に書記が出して立てて置いた校旗を指した。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊「知ってるよ」とうなずく。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「さもあらん　さもあらん」　とうなずく。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中隊長は、皆んなを危険なところへは曝しとうない。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面に陳列された商品がさき盛った野の花のように見え、天井に回るファンの羽ばたきとうなりが蜜蜂を思わせ、行交う人々が鹿のように鳥のようにまたニンフのように思われてくるのである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七老人はご尤もとうなずいて、又しずかに語り出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は、罪人のように、悄々とうなだれて立上った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とうなってゐます。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）とうなっていました。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠍は頭に深い傷を受け、大烏は胸を毒の鉤でさされて、両方ともウンとうなったまま重なり合って気絶してしまいました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、佳境には入って来たというのはほんとうなんですよ。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん雌は「ゲ・ゲ」とうなずいている。",
              "citation": {
                "source": "交尾",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしほんとうな意味での新しい独創的の研究をするのに市場に売り古されて保証の付いているほど陳腐な器械ばかり寄せ集めてできたためしはおそらくないであろう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそのこと、全部間違いばかりと事がらがきまればかえって楽であるが、困ったことには時にほんとうなことが交じるので全部捨てるわけにゆかないから始末が悪いのである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は恩を売る気はもうとうないけれども、少しは私たちにも何か楽しみを与えてくれてもよさそうに思われるのであるが、やはり捨犬はだめなものである。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵穴の眼玉はたちまちなくなり、犬どもはううとうなってしばらく室の中をくるくる廻っていましたが、また一声「わん。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬がふうとうなって戻ってきました。",
              "citation": {
                "source": "注文の多い料理店",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから線路の左がわで、ぐゎあん、ぐゎあんとうなっていたでんしんばしらの列が大威張りで一ぺんに北のほうへ歩きだしました。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜あけごろ、遠くから小さなこどものあぶがくうんとうなってやって来て網につきあたった。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あぁかいてながのくぅも、　てながの赤いくも　あんまり網がまづいので、　八千二百里旅の蚊も、　くうんとうなってまはれ右。",
              "citation": {
                "source": "洞熊学校を卒業した三人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊が一｜疋くうんくうんとうなってやって来ました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜あけごろ、遠くから蚊がくうんとうなってやって来て網につきあたりました。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あぁかいてながのくぅも、　あんまり網がまずいので、　八千二百里旅の蚊も、　くうんとうなってまわれ右。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　童子の脳は急にすっかり静まって、そして今度は早く母さまの処にお帰りなりとうなりまする。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
