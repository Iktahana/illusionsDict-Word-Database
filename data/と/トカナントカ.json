  {
    "uuid": "0ec08164-9e62-5e03-ba69-56cdfc66fc9b",
    "entry": "とか何とか",
    "reading": {
      "primary": "とかなんとか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
