        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "駅と吉林城の東壁と十二町の間が商埠地になつてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "小壁のうちで特に美しいのは、入り口から左へ突き当たった隅の、東壁及び南壁である。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
