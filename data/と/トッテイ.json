        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第二突堤より運送船××丸にて出帆す。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の麓の灯が次第に迫って来て、突堤でモリナガキャラメルのネオンサインが点滅した。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つ、向日葵か、いな、突堤の、線の灯あしだ。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "西日して潮満つるまの夕干潟営み長く蟹ぞつぶやく夕凪の干潟まぶしみ生貝や弥勒むく子の額髪にして西日には蟶むきて居るならし後姿気ぶかき四五の女童女童や我は思へば額髪のかぐろき瞳｜此方見あげつ潮くさき突堤に沁むる夏西日音あわて落つるむつごろ影あり註、沖端にては突堤をうろこと云ふ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚「むつごろ」は小さき山椒魚に似たる魚にて、よく潟を走り、突堤の石垣にも登る、前世紀の遺物の由。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレヤ、霞の雲仙、島原は追風の一と潮、風さきの向う突堤は三潴ばの、のうもし。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮の關係で、突堤には着けられなかつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮の関係で、突堤には着けられなかった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は六歳になった筆者を背中に乗せて水泳を試み、那珂川の洲口を泳ぎ渡って向うの石の突堤に取着き、直ぐに引返して又モトの砂浜に上った。",
              "citation": {
                "source": "父杉山茂丸を語る",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の麓の灯が次第に迫って来て、突堤でモリナガキャラメルのネオンサイン塔が点滅した　船が横づけになり、桟橋にぱっと灯がつくと、あっ！",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それから数分の後――　荒れ果てた廃港の、線路のある突堤埠頭の先端に、朝の微光を背に受けて、凝然と立｜竦んでいた私達の眼の前には、片腕の駅長の復讐を受けた73号を深々と呑み込んだドス黒い海が、機関車の断末魔の吐息に泡立ちながら、七色に輝く機械油を、当もなく広々と漂わしていた。",
              "citation": {
                "source": "気狂い機関車",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "突堤に積み上げられた樽の上で、苦力たちが湿って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "突堤の先端に立っている警羅の塔の入口から、長靴を履いた二本の足が突き出ていた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「参木が突堤で待ってるのだが、もう幾時です。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そのときはもう甲谷は参木に逢いに突堤へ行った後だった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　甲谷は突堤へ行ったが参木の姿は見えなかった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は戦闘心を養うために、河を登るフィリッピン材の勢力を眺めに突堤に添って歩いて見た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品の年代でいうと、次にかかれたのは「小祝の一家」「鏡餅」「乳房」「突堤」である。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第四巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じこの理由から、前巻に収められている「突堤」のはじまりの文章も分りにくい。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第五巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「飲みたくなったからさ」　海にも灯が入った――帆船の黄色い灯や、突堤の端に碇泊している監視船の青と赤の灯が、ちろちろ瞬きはじめた。",
              "citation": {
                "source": "ラ・ベル・フィユ号の奇妙な航海",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "吠え狂ふ怒濤の間に間に、突堤の上に焼け残つた木株や石が異様に黒ずんで見えてゐる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍵形に曲った突堤と埠頭の両側から、吊り橋のように起重機が連り下っている。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身が船を突堤にすてている旅行者の心となる処に、甚だ軽快な味を感じる。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「随分小さいのもいるね」　私と上の弟とは並んで腰かけ、砂へ左右の手をついて上体を折りまげ水をのぞきこんで眺め興じたが、気がついて見ると次の弟だけ一人離れて、その突堤のずっと手前のところに立ってこっちを見ている。",
              "citation": {
                "source": "突堤",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この高雄の港口の突堤の上で、私は変なことを考えた。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出る船と入る船とどちらが多いかと、私は突堤の上で自分に尋ねてみた。",
              "citation": {
                "source": "台湾の姿態",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説「突堤」（これは淀橋署に拘留中に書いた。",
              "citation": {
                "source": "年譜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "友情と金銭とのあいだには、このうえなく微妙な相互作用がたえずはたらいているものらしく、彼の豊潤の状態が私にとっていくぶん魅力になっていたことも争われない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹はすぐに察知したらしく、「ペリカンをかいているのです」とひくく私に言って聞かせながら、ペリカンの様様の姿態をおそろしく乱暴な線でさっさと写しとっていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私は久しぶりで先生のお宅へお伺いして、大隅君の縁談を報告し、ついては一つ先生に媒妁の労をとっていただきたいという事を頗る無遠慮な口調でお願いした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
