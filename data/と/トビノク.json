    "definitions": [
      {
        "index": 1,
        "gloss": "to jump back",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……そのトタン……飛び上るようなサイレンの音に、ハッと驚いて飛び退く間もなく、一台の自動車が疾風のように私を追い抜いた。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物すごき形相に、お妙はぎょっとして飛び退く。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "走り込んで行った炭車を飛び退くようにして、立ちはだかった男の腕の中へ、お品は炭車の尻を蹴るようにして水々しいからだを投げかけて行った。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて飛び退くと、そのあとから何千何万とも知れぬ熊蜂が一度に鬨と飛び出して、三人の悪者に飛びかかって、滅茶滅茶に刺して刺して刺し殺してしまった。",
              "citation": {
                "source": "猿小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝兵衛と弥助はあわてて飛び退く。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "出逢ひがしらに正親はあつとおどろいて飛び退く。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ふたりはびつくりして飛び退く。",
              "citation": {
                "source": "正雪の二代目",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は飛び退くとお柳を蹴った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "安重根　（ぎょっとして飛び退く）金？",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "刹那、内儀さんは齒を喰ひ縛り恐ろしい形相をして、魂消て呆氣にとられてゐる彼女にものも言はず飛び退くやうに石鹸の泡も碌々拭かないで上つてしまつた。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者は飛び退くと、杉戸を背にして突き立った。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　それは、慄っとするのと飛び退くのと、同時だった。",
              "citation": {
                "source": "一週一夜物語",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やられた」と思った彼は、一散に横へ飛び退くと、人形師の家の雨戸を蹴って庭の中へ馳け込んだ。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一二「ホ、ホ、大方、こんなこともと思っていたんだ」　お初は、雪之丞から、パッと飛び退くと、右手を帯の間に突ッ込んでいた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、娘は狼狽しながらも、ピョンと背後へ飛び退くと、袖を手に巻きキリキリと頭上高く差し上げたが、それをグルグルグルグルと、渦巻きのように廻したものである。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東軍流ではかなりの手利き、同じく飛び退くとヌッと延し、抜き持った太刀｜柄気海へ引き付け、両肘を縮めて構え込んだが、すなわち尋常の中段である。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平造は慌てゝ飛び退く。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "政一は、無意識に飛び退く。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして一様に飛び退くと、ひとつのかたまりとなつて逃げだした。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、叫んだものの、飛びかかって行こうとはせず、反対に、飛び退くと、部屋の背後の壁へ背をもたせ、刀を、例の中段に構え、眼前を睨んだ。",
              "citation": {
                "source": "血曼陀羅紙帳武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ワッ」と陣十郎が途端に叫び、飛び退くと刀を肩に担ぎ、不覚にも一方へよろめいた。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてもう一尺前へ出れば、いざと云う時、土の上へ飛び退く手間が一尺だけ遅くなる。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "――トツサに飛び退く工夫。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩を押してゐた人々が飛び退く。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と兄は飛び退くようにして部屋を出て行ったが、間もなく嫂と二人で大急ぎではいって来ると、女中に手伝わせて二人で押入れから床を引摺り出すやら、女中の持って来た飛び上るように冷たい濡れ手拭を私の額に載せるやら！",
              "citation": {
                "source": "逗子物語",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　顔色変えて二、三人、函の廻りから飛び退く者がある。",
              "citation": {
                "source": "ウニデス潮流の彼方",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑から首を擡げた権六の如きは、泥になったその顔と両手を持ったまま、悪い事でもしていたように、びっくりした様子で後へ飛び退くなり平伏してしまう。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」と、雲霧は黒塀の横へ飛び退く。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それらが両側にとびのくといっしょに、大きなそりがとまりました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっと思う瞬間だったが、水兵はおどろいてとびのくなり、挙手の敬礼をして走りさった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
