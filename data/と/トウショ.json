[
  {
    "uuid": "b21bba13-70b7-5077-ad42-0596f5dc4569",
    "entry": "島嶼",
    "reading": {
      "primary": "とうしょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
