        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それを左へ曲るとウンテルデンリンデンですぐ右側の角がツォイクハウス、次が番兵屯所、その次が大学である。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "救護隊の屯所なども出来て白衣の天使や警官が往来し何となく物々しい気分が漂っていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戦中ターリングは軍隊の駐屯所となった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、葬列が村の屯所の前にさしかゝった時、状態が急に変化した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市場の辻の消防｜屯所夜でも昼でも火の見で見張りぐるぐる見回る　　北は………　　南は………　　西は………　　東は………どっかに煙はさて見えないか。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる後家さんの屯所であろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に彰義隊の屯所の上野界隈は、昼でも悠々と飯を食っている客は少かった。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、京都に止ること二十日ばかりで分裂し、芹沢、近藤等十三人が清河に反き、宿舎八木源之丞の邸前へ「壬生村浪士屯所」の看板を出したのが、所謂新撰組の濫觴である。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り敢へず、武具類を土蔵に収めて封印して主人喜右衛門を壬生の屯所に引致して、拷問したところ、驚く可き陰謀が発見されたのである。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "○壬生屯所を囲み、焼討して新撰組を鏖殺し、京都擾乱に乗じて、長州の兵を京都に入れる。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "漸く事済み候跡へ、御守護職、御所司代の人数三千余人出張に相成り、夫より屯所へ｜被打入候処、会侯の手に四人召捕、一人打取る。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だれか一騎、すぐに屯所へ飛べッ」「心得た。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぶきみな思いをしながら待ちあぐんでいたところへ、前後して三騎がはせ帰ってくると、城内屯所へいったのが馬上から呼び呼び伝えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、権藤四郎五郎左衛門なる長い名のその生駒家新浪人が、いちはやくご府外へ逐電したならば、五街道口のいずれかの隠し屯所へ、まだ市中に潜伏しているならば一町目付けのどこかの隠し場所へ、必ずなんらかの足跡動静を残しておいたであろうと知ったからです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいか、四人は街道口隠し屯所へ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "念までもあるまいが、隠し屯所へ出入りいたすときは、人に見とがめられぬよう、じゅうぶんに注意いたすがよいぞ」「はっ」　とばかりに八美少年は、馬上ゆたかに雪の道を、八方に散っていきました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩兵｜屯所の一件なぞがそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "これじゃあ市中の評判もよくない筈ですよ」「その一万人はどこに屯していたんです」「四組に分かれて屯していたのですが、髪切りの一件がおこったのは神田｜小川町の屯所で、第三番隊というのでした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "屯所の方でも、こんな事はなるべく秘密にして置きたかったのでしょうが、人の口に戸は立てられません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一件は慶応元年の二月から三月にかけての出来事で、半七が小川町の歩兵屯所へ呼び出されたのは三月二十五日の朝であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "小川町の歩兵屯所も土屋｜采女正と稲葉｜長門守の屋敷の建物はみな取り払われて、ここに新らしい長屋と練兵の広場を作ったのであるが、ある一部には昔の庭の形が幾分か残されている所もあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで何かの打ち合わせをして、半七は屯所の門を出ると、ひとりの若い女の姿が眼の前に見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「屯所へ呼ばれたそうですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い大名屋敷には往々そんな怪談が付きまとうので、屋敷跡の屯所の築山にも古狐か古猫のたぐいが棲んでいないとは限らない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「屯所の一件が評判になっているので、何が無しに髪切りの真似をしてみたのか、それとも何か仔細があるのか、どっちでしょうね」と、幸次郎も判断に迷っているらしかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩兵屯所の八重桜も定めてさんざんに吹き散らされるであろうと、半七は想像した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房はやっぱり鮎川という歩兵と訳があって、なんとか彼とか名をつけて、屯所へ呼び出しに行くらしい。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　その翌日、半七は歩兵屯所へ出頭して、小隊長の根井善七郎に面会を求めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断をしていると、この屯所の中でもまだまだ切られる者があるかも知れません」　根井もおおかた覚ったらしく、これも声を忍ばせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "屯所内の者の仕業だな」「鮎川丈次郎、増田太平の二人だろうと思います」「鮎川と増田……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
