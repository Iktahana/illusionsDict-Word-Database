[
  {
    "uuid": "b15c320a-7551-59fc-9d7d-77f3c03ccaef",
    "entry": "問い切り",
    "reading": {
      "primary": "といきり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
