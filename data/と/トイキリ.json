      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "last death anniversary for which there is a memorial service held (usu. the 32nd or 49th)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何とか返辞をしろ、といきり立ち腕力に訴えようとしても、相手は、双葉山である。",
              "citation": {
                "source": "横綱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とか返辭をしろ、といきり立ち腕力に訴へようとしても、相手は、双葉山である。",
              "citation": {
                "source": "横綱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一思にこんなやくざ女を蹴とばしてしまはうといきりたつこともあつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂々、袴をはいて出席し、大演説、などといきり立ってみるのだが、私は、駄目だ。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでは如何に幕府打倒といきり立つてゐる薩長と雖も文句がつけられないのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "想へ、京都は今や薩長の精兵によつて充満し、幕兵一掃といきり立つてゐる時である。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不用意な仕草がコワリョーフをかっといきり立たせてしまった。",
              "citation": {
                "source": "鼻",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥つちよのめかしやは赫つといきりたつたが、しかし荷馬車はその時もうよほど遠く距たつてゐたので、女房はその腹癒に罪もない継娘や、のそのそ歩いてゐる亭主に当り散らした。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、死後でもなく、また、服毒以前でもないのだがね」「冗談じゃないぜ」と熊城は思わず呆れ顔になって、「これが即死でないのなら、一つ君の説明を承ろうじゃないか」といきり立つのを、法水は駄々児を諭すような調子で、「ウン、この事件の犯人たるや、いかにも神速陰険で、兇悪きわまりない。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し又、一方「死馬の骨を買ひし者あるを聞かずや」といきり立つた清少納言と同様「我も昔は」とも言ふべき形を、含んでゐるとも見える。",
              "citation": {
                "source": "鸚鵡小町",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある屋根裏に棲んでゐたといふのであるが、東京には欧羅巴の安宿なみの屋根裏なんぞ見当らないといきりたつ性質のよろしくない読者のためには、ＢＯＮ！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗北するや口惜しがること夥しく、今のは怪我敗けだ、ほんとは俺の方が強いのだといきりたつし、勝てば忽ち気を良くして、あんたは下手だと大威張りである。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵である以上当然やるであらうやうなことを怪しからんなどといきり立つ必要は毛頭ない。",
              "citation": {
                "source": "心理の洞察",
                "author": "――政治に求めるもの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればといって、卑怯者といきりたち、今度は要心専一に立向ってみても、尚さら手もなく倒されるばかりで、どうにもならない。",
              "citation": {
                "source": "花咲ける石",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると紅蓮の焔はまるで生物のように八十助の存在を認めて、そのメラメラといきり立つ火頭を彼の方に向け直すと、猛然と激しい熱風を正面から吹きつけた。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはるがいうには、自分が勝手で洗濯していたところへ作衛がやって来て、どうしても俺のところへ帰って来いといきりたつ。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして文子の素朴な心に比べたなら、老獪な狐の心にすぎないところの醜怪さを完膚なく発いてやらうといきりたち意気込まずにはゐられなかつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供のように軽くあしらわれて、この野郎め、ふざけやがるな、黒石を皆殺しにしてやるぞ、といきり立ってしまった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その七　石の下",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次がお臺所町の富崎佐太郎浪宅を訪ね、――親の敵――といきり立つ佐太郎を撫めて訊くと、金森家へ三千兩の小判を返し、佐太郎の父親の罪を贖つたのは、全く佐太郎の知らぬことと判りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "八千兩異変",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ笹野の旦那をおつれして、見事俺に恥を掻かせるつもりだろうが、そんなわけにゆくものか」　万七はしきりといきり立っております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もその事を佐々が言い立てて、イライラといきり立つて詰め寄つて行くのだつた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとただちに憤然といきりたって、家庭の務めと中庸の財産とをもって人は幸福であり得る――幸福であり得なければならない――という思想を、「市井的な卑しいもの」だと見なした。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "主よ、汝が創ったものをこわさんといきり立つのは、それは汝である、汝自身である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざ／＼笹野の旦那をおつれして、見事俺に恥を掻かせる積りだらうが、そんなわけにゆくものか」　萬七はしきりといきり立つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "キリシタンの武士たちは宣教師の京都追放を憤り、おのれの所領や妻子を捨てて死の覚悟を以てそれに抗議しようといきり立っていたので、ビレラはそれを鎮めるのに苦心していた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "理由によってはそちらから離縁を望まぬでも、こちらから熨斗を付けて親許へ帰して上げるから、仲人を呼ぶまでのことはない、ここでハッキリした理由を言いなさいというようなわけで、彦吉がここにいるために言いにくいのなら彦吉にはしばらく店の方へ出てもらいましょう、といきり立つのでございます。",
              "citation": {
                "source": "蒲団",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも仙台はうるさい」と雅楽頭は云った、「仙台びとの我の強いのと倨傲にはうんざりする、平穏だという状態は半年とつづかず、いつもなにかしらごたごたを起こし、互いに相手を凌ごうといきりたつ」　雅楽頭は滝尾の胸のふくらみを撫でながらつづけた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう惨めったらしい奴を、無法だろうとなんだろうと、あくまでいじめさいなむ快感に酔い痴れながら、私はそやつをなおも踏んだり蹴ったりしてやろうといきり立っているのだった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "きかれるものは、ただ罰せられた子供たちの叫喚といきりたった先生の怒号ばかりでございましょう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "曹仁は、大いに怒って、小癪なる玄徳が輩、ただちに新野へ押し寄せて、部下の怨みをそそぎ、眼にもの見せてくれんといきり立ったが、その出兵に当って、李典にはかると、李典は断じて反対を称えた。",
              "citation": {
                "source": "三国志",
                "author": "孔明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
