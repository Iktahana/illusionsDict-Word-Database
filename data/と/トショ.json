[
  {
    "uuid": "4b4e7193-42c8-56cc-9cd9-831160142d8f",
    "entry": "図書",
    "reading": {
      "primary": "としょ",
      "alternatives": [
        "ずしょ"
      ],
      "is_heteronym": false
    },
    "grammar": {
