    "definitions": [
      {
        "index": 1,
        "gloss": "breaking through",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と得意滿面、このたびの大厄難突破の次第を、唾を飛ばし散らしながら物語る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "突破しろ……」　少年が鋭く叫んだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だって突破しろなんて云うんだ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互に心持は奥底まで解っているのだから、吉野紙を突破るほどにも力がありさえすれば、話の一歩を進めてお互に明放してしまうことが出来るのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ私等は流行の裏を突破した。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校四年生の時、野沢温泉から木島まで吹雪の中をスキイで突破した時のおそろしさを、ふいと思い出した。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "締切を突破した予告原稿だから……。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その個所を突破しさえすれば問題の解決は著しくはかどるのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前樣は婦に逢ひに行く、」「…………」「な、然も、先方は、義理、首尾で、差當つては間の惡い處を、お前樣が突詰めて、斷つて、垣も塀も、押倒し突破る、……其の力で、胸を掻※るやうにあせるから、婦も切つて、身にも生命にも代へて逢はうと云ふ。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平坦な道を一気に突破して午後の三時半というに沼田町へ着いた。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎天、烈風、猛雨、この間を突破し来りたる我々には、この広大無辺なる海洋の夕暮れに、闇らき波の白く砕けて岸に咆ゆる有様がいい知れぬ快感を惹き起して、我れ知らず躍り上るを禁じ得なかった。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "塲内の光景は實に慘憺たるもので、濁浪怒濤は一方の岩壁を突破つて、奔流の如く其處から浸入したものと見へ、其直ぐ側の、兼て發動藥液の貯藏せられて居つた小倉庫の鐵の扉は微塵に碎かれて、十二の樽は何處へ押流されたものか、影も形も無かつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "三羽四羽憤怒の皷翼と共に矢の如く氣球に飛掛かる、あつといふ間に、氣球は忽ち其鋭き嘴に突破られた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ガンブロー鳥」に突破られたる輕氣球は、水素瓦斯の洩るゝ音と共に、キリヽ／＼と天空を舞ひ降つて、『あはや』といふ間に、大洋の眞唯中へ落込んだのである。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日迄幸に防禦線は突破されずに戦つては来たものの、俺は疲れる。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "トテモ際どい芸当をやったもんでさあ……」「ナアルホドネエ……張り込んでいる刑事がこの男を調べている隙を見て非常線を突破したわけですな」「どうもそうらしいんです。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い電燈の下で、汽鑵の圧力計指針が、二百｜封度を突破すべく、無言の戦慄を続けている数分間である。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "機体の全部に関する精確な検査能力と、天候に対する鋭敏な観察力と、あらゆる危険を突破した経験以外には、何者をも信用しない事にきめている私は、そうした司令官や同僚たちの、迷信じみた心配に対する単純な反感から、思い切ってこうした急角度の上げ舵を取ったのであった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが……ソンナような反感も、ヒイヤリと流れかかる層雲の一角を突破して行くうちに、あとかたもなく消え失せて行った。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もう三百キロを突破しているのにこの静かさはドウダ……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と得意満面、このたびの大厄難突破の次第を、唾を飛ばし散らしながら物語る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "運命への忍辱　とはいへ環境の闇を突破すべき、どんな力がそこにあるか。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロマンチシズムに拠って、夢の力に拠って、難関を突破しようと気構えている時、よせ、よせ、帯がほどけているじゃないか等と人の悪い忠告は、言うもので無い。",
              "citation": {
                "source": "かすかな声",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵を伏せて敵を誘ひ、奇を以て勝を制し、重囲を突破して、千里に横行する、痛快無比の状を叙せり。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陣営は厳密、まさに周亜父細柳の如くなるべし、然らずんば敵の猛將の奇襲突破するところとならん。",
              "citation": {
                "source": "囲碁雑考",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "近來人皆勝つことを好むの心｜亢り、好んで詭※の説を聽き、古往今來、萬人の行きて過たず、萬々人の行きて過たざるの大道路を迂なりとし、奮力向前して、荊棘滿眼、磊石填路の小徑を突破せんとするが如き傾がある。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それより船生、玉生、田所の地を矢板へ走らせて、それから那須野が原の一部分を突破し、關谷から山へ入つて鹽原へ行かうといふのである。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "推せども突けども金鐃は破れず、身を大きく変化させて突破ろうとしても、悟空の身が大きくなれば金鐃も伸びて大きくなり、身を縮めれば金鐃もまた縮まる始末で、どうにもしようがない。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等のいる中へ、いま、すっかり憔悴して而かも身なりも崩れている葛岡を連れ込むのは可なり恥かしい想いであったが、葛岡に対する心配で手もなく突破して、わたくしたちは食堂の河岸側のテーブルに落付きました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "敷居を跨ぐ時、一つ躓いて、とっぱぐったじき傍に、婦人が立ってたので、土間は広くっても袖が擦れて、（これは。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
