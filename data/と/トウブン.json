[
  {
    "uuid": "99dfd891-0b5b-5bfe-b29f-a22cba3355b9",
    "entry": "当分",
    "reading": {
      "primary": "とうぶん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "for the present",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで、私としては、良心を澄ませる、即ち謙虚な気持を修熟させることが第一だと思ひ、従つて、当分発表するものは、旧作であるから、それがつまらないからといつて、如上の考へをも愚であるとされたくない。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "弱者への慰めのテエマが、まだ当分は、映画の底に、くすぶるのではあるまいか。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、当分、自信の無さから、のがれる事は出来ません。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして私の推察するに、私の所から逃げた当分は、新しき男とその友人の家などに行つた場合、男を変へたことを少々誇りげにし、その理由として男が自分に教へた理智的な目的を語つたり、もつと気紛れな場合には、私について人に分り易い欠点――そのために彼の女が私を嫌つたのではない欠点を語つたらしいのである。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後当分、耕二は何時も裏庭でコソコソ一人遊んだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんなら傭入の方は当分止めるだらうに、――いゝえその方は相変ず従前通といふ仕末であつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕を出して午睡しようと思つてる時、「俺には女は当分当抵得られないものだ……」つて言葉の一字一字が、所々ハゲた壁の上にピヨコピヨコみえるやうな気がした。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで、当分は枕を高くして寝られる」と地主たちが安心しかけた処であった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "禿頭は父親から男の子に遺伝する性質だという説があるが、それがもし本当だとすると、私の父は七十七歳まで完全に蔽われた顱頂を有っていたから、私も当分は禿げる見込が少ないかもしれない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学がキャピタリズムやミリタリズムやないしボルシェヴィズムの居候になっているうちは、まあ当分見込がなさそうに思われる。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやのことが薄々二人に知れたので、僕から言いだして当分二人は遠ざかる相談をした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は当分毎日お墓へ参ります……」　話しては泣き泣いては話し、甲一語乙一語いくら泣いても果てしがない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし教授の職に附帯したうるさい仕事のために研究が出来なくなるという心配があれば、また適当な後任者の出来るまで当分の間だけ引受けるというのだったら、むしろ御断りになる方がいいと思う」という意味のことを忠告した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "栽培法や製法の改良を加えて行けば、天然藍も当分市場に立ちゆかれる見込みだという。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "処がよもぎは一度喫うと当分は喫う気がしません。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「当分喜ばして　置くサ」　半次「当分喜ばして置いて」　大吉、Ｔ「気が向いた時　出掛けて行って　冥途へ送ってやる」　「なーる程」と半次。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）もう当分伺いませんわ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも当分御一しょの。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロオズ夫人にお別れした妾は、当分モスコーで暮すために旅装を整えて二つの彫像を二個のトランクに入れて、巴里停車場に車を走らせました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日になって再びチタ子は私のアパートを訪れてきて、当分、私から離れたくないと言ったのです。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きょうのことは、誰にも当分沙汰なしにして置いてくんねえよ」四　寺の門を出ると、半七は松吉に逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "母に対しても、お登久に対しても、かれは正直に打ちあける勇気がないので、ここでもまた好い加減の嘘を作って、筋の悪い品物を買った為にその引き合いを受けるのが迷惑だから、当分は世間に顔を出したくないと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう当分は打ちくつろいでいてもよかろう」　今まで薄暗かった行燈の灯はかき立てられて、座敷は俄かに明るくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえはまあ当分は家に隠れていて、店へ顔を出さない方がよかろうよ」　いつまた連れに来るかも知れないという懸念があったので、お亀は娘を店へ出さないことにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "仔細あって娘を当分は音信不通の約束でこちらへ貰いたいと、こう云うんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等はまあ当分は生簀にして置いて、ほかから来る奴らに気をつけろ」　多吉は承知して帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「当分、月給を渡さないということになってるんだがなあ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お類がＴ「兄さんから金が来る迄当分此処で逗留ね」　浪之助風呂へ行くべく立ち上って、Ｔ「その間に伊吉の奴を片付け無くちゃ」　と言い乍ら廊下へ出る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、とうぶんそのまま宮中へおとどめになって、おてあつくおもてなしになった後、改めてお宮の近くの村へお住ませになり、毎日一度はかならずおそばへめして、やさしくお言葉をかけておやりになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、高志は超然としているので、とうぶん心配はないだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
