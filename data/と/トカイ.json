[
  {
    "uuid": "fb29efea-d73b-5424-9a17-903a7856f46e",
    "entry": "都会",
    "reading": {
      "primary": "とかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
