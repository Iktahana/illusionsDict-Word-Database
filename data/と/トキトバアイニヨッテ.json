    "definitions": [
      {
        "index": 1,
        "gloss": "should time and circumstances permit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
