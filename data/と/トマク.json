[
  {
    "uuid": "9329b3af-52c0-5535-8381-a69af33e8a9b",
    "entry": "塗膜",
    "reading": {
      "primary": "とまく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(dried) paint coating",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこで武も隠居仕事の五円十円説では到底夫婦さし向かいの碁打ちを説き落とすことはできないと考え、今度は遊食罪悪説を持ち出して滔々とまくし立ててみた。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻は尋常で、唇は少し厚く、笑うと上唇がきゅっとまくれあがる。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とまくし立てて、怯むところへ単刀直入、「しばらく足を洗ったために、乞食｜夥間を省かれた。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "高座へ出ると、行きなりお尻をくるっとまくって据わるのですもの。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はパーソナルコンピューターがいかに面白いかを、私には理解できない言葉でとうとうとまくしたてたあと、「パーソナルコンピューターによって、情報処理の強力な武器を国家や大資本が独占している状態がくずせるのだ」と、しばらくはお目にかかれなかった生き生きとした表情で付け加えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物の裳をぐいとまくって、威勢よく歩けと、うしろから声をかけましたが、小僧には聞えなかったのか、やはり黙ってびちょびちょ歩いているので、お武家はちっと焦れったくなったと見えまして、三足ばかりつかつかと寄って、おい小僧、こうして歩くんだと云いながら、着物の裳をまくってやりますと……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "その内に「上る箱根の御関所でちょいとまくり、若衆の物では受け取れぬ、こちゃあ新造でないかとちょと三島」てふ名句があった。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを通り抜けて自分の部屋に来て見ると、胸毛をあらわに襟をひろげて、セルの両｜袖を高々とまくり上げた倉地が、あぐらをかいたまま、電灯の灯の下に熟柿のように赤くなってこっちを向いて威丈高になっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾のあたりは旗のやうにパツ／＼とまくれ上つた。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃の照りつづきで乾ききつた路の砂埃が、ぱつとまくし起つて、一煽り煽り立つたと思ふと、先細にすぢりもぢつてころころと轉がつて來る。",
              "citation": {
                "source": "旋風",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜着とまくらなのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏道仏心｜弥陀の極意はこのひとまくらのうちにありといわぬばかりで名人は、求道弘法の経巻を頭の下にしながら、おりから聞こゆるお山の鐘を夢の国への道案内に、すやすやと心よいいびきをたてはじめました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "やにわとまくらもとのわきざしを、がらにもなく取りよせましたものでしたから、当然のごとく名人の口にカラカラという大笑がわき上がると、いとも胸のすく小気味のいい啖呵が、ずばりときられました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぺらぺらとまくった拍子に、そのいんちきばくち必勝秘伝書の中から、ひらひらと下に舞い落ちただれかの書面らしい紙片がありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮長はよく、かわるがわるテューターを呼んでは、酒をふるまって、学校の未来について、滔々とまくしたてるという話だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、まことに（立板に水を流すやうに）ぺらぺらとまくし立てるのであつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めはしずかに調べていて、さあという急所になって来たら、一気にべらべらとまくし掛けて、相手にちっとも息をつかせないようにしなければいけません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "三つの声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハヽヽ、どうです、偉いでせう、僕は――」などと、彼は、何の辻棲も合はぬ、夢にもないことをペラペラとまくしたてた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　ここで、くだんの若い英吉利紳士の頭に、ちょいとまくった女袴の下からちらと覗いてる巴里の大腿が映画のように flash したに相違ない。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "何をするのかネ」「この動坂氏を裸にしてみるのだ」「ナニ、この人を裸に……」　呆れている速水を促して、僕は端の方から蒲団をソッとまくった。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな話をすると人は何と思われるかしれませんが、母は戴きものをすると、水引きは丁寧にほどき、長い棒にあてて、紙でくるくるとまく。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "上着と下着との裾をぐっとまくって、帯の上に持て来て挟む。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長はシャツの袖を高々とまくりあげ、にゅっと伸ばした腕に波をうたせながらやって来て、『麻酔はいいかね？",
              "citation": {
                "source": "麻酔剤",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんはその夕方、姫さんをそっとまくら元に呼び寄せて、やせ衰えた手で、姫さんのふさふさした髪の毛をさすりながら、「ほんとうに髪の毛が長くおなりだこと。",
              "citation": {
                "source": "鉢かつぎ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこでチチコフは口を開いて、だがそのミヘーエフだってもう疾うの昔にこの世を去っているのだと注意しようと思ったが、ソバケーヴィッチは、いわゆる自分の弁舌につりこまれて、滔々とまくし立てたものだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点では父祖の習慣に忠実であったしだいであるが、女房と口論をする段になると、やれ俗物だの、ドイツ女だのとまくしたてたものである。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ上流の紳士という奴は、何でもかんでも喋りちらすのだ、どんなことにでもちょっぴり言及して、本の中から曳っぱりだしたことを、滅多矢鱈に滔々とまくし立てるが、それが頭へは一向はいってこないのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんは裾をくるりとまくって、草の中へしゃがんだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝もやっぱりいつもの通り憂鬱なまじめな顔をしながら、黒い逞ましい両腕を悠々とまくり上げて、妾をヤンワリと抱き上げてくれた。",
              "citation": {
                "source": "ココナットの実",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
