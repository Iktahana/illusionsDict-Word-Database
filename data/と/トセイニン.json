        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渡世人らしい旅人が一人休んで居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「姐さん草鞋があるかい」　「え、御座います」　「そうかい、じゃ一つくんな」　「はい」　その時、通りかかった……これも渡世人の旅人が三人。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お侍の果し合か」　「ううん」　「じゃ渡世人か、其奴ァ面白え」　石松、起き上って表へ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと名のある渡世人に違えねえと俺ァ思うんだ」　「誰だろう？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでも森の源兵衛と云やァ渡世人仲間じゃ少しは人に知られた男だった」　「矢張りそうだったのか。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲か、役者か、渡世人か、いきな処で、こはだの鮨は、もう居ない。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここいらの宿屋の亭主には渡世人上りが多いという話を……。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "月代の伸びた荒くれ男どもは本職の渡世人らしく、頬冠りや向う鉢巻で群がっている穢苦しい老若は、近郷近在の百姓や地主らしい。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モトモト久蔵親分は、好きで渡世人になった訳じゃないし、法律の一つも心得ているだけに、東京へ出て一旗上げたい上げたいと思いながら、因縁に引かれ引かれて足を洗いかねているところへ、最愛の女房から踏み付けにされちゃったのですからスッカリ気を腐らしたのでしょう。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう言へば、長谷川伸さんの侘しい股旅渡世人の幾種かを演じた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小男のくせに妙に身体のガッチリした、苦味走つた中々の美男子であるが、商人――といふと其れとも違ふ、出来損ひの渡世人といつた風な感じである。",
              "citation": {
                "source": "竹藪の家",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる二足の草鞋であって、渡世人からは卑怯であるとして、とかく悪口を云われるものであるが磯五郎ばかりは評判がよかった。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「アッハハ大変ですねえ、お侍さんだけに渡世人と異って、物の見方が面白いや。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとご挨拶せずばなるまい）　渡世人の仁義である。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう他人の苦難の際に、男を売物の渡世人が、私怨の私闘は謹むべきだ」「そうですねえ、そう云われて見れば、こいつ一言もありませんや。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、こうと思いこむと執念深くて、必ずやりとげるような根強い実行力があり、人々に、否、ガマ六のような腕ッ節の強い、世渡りに自信のある老獪な渡世人にまで、怖れられていたという。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめて聴いたくだりであるが、何か天竜川の近くで、昨日渡世人の足を洗ったばかりという老侠へ止むないことから喧嘩を挑みかかる日本左衛門の意気地を叙した一席だった。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "園絵をこっそり帯屋小路の家へつれて来て、久しぶりに喬之助に会わせてやろうと、思い立つと、何でも即座に実行しないと気の済まない喧嘩渡世人だ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、元番士神尾喬之助……ではない、紛らわしいが、これは、喬之助に化け澄まして――ナニ、化けなくても、生地のまんまで喬之助ソックリなんだが、その上、斬込みの時の着付けまで寸分同じな、神田は帯屋小路、今評判の喧嘩渡世人、茨右近先生だ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡世人と岡っ引は人柄を読むことと場の臭いを嗅ぐことが大切である。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "長五　しかし女は買わず酒は飲まずの渡世人というのも珍しかろうぜ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の抜道を斜に歩く俺のような渡世人にゃ、この世の中がどうなろうと知ったことかい。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "知れたことよ、俺あ渡世人だ、邪魔あして貰いたくねえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御存じありますめえが、盆ゴザに坐りゃ渡世人は、自刃の上に坐った覚悟で、へい、昨日今日ポッと出のバクチ打ちなんぞ途中から割り込んで来ることさえもようできることじゃねえ、それぐらいに凄い意気合いの物でがんす。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし筑波を荒したのが三ン下にしろ渡世人のはしくれだったと、後で世間に聞こえて皆さんのお顔にかかる心配が有りゃ、ぬすっとにして下すっても結構でがんす。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "西部から中西部を経て東部に流れこんだ、博奕打ち、喧嘩師などの渡世人、脱走船員、密入国者、密買行商人といった、日本の夢も見ない連中だけがつくっている大きなサークルで、ほとんどみな第三街に住み、邦人のクラブなどには絶対に顔をださない。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生再出発は元金十銭『ちょいとごめんなすって……』　私はふすまをあけて両手両ひざをつき、見よう見まねの渡世人の仁義をよそおい上目づかいにいざり寄った。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "おむら　それでは自棄も手伝って、荒っぽい渡世人にも成る筈だねえ。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
