        "examples": {
          "standard": [
            {
              "text": "どんなボトムスにも合わせやすい、シンプルなデザインのトップスを選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "流行のオーバーサイズのトップスを着て、今っぽいコーディネートを楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今日の外出には、お気に入りの刺繍が入ったトップスを着ていこう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
