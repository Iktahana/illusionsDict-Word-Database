        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こう諾かなかったらすて姫のこぼれるわかさを、溶きほぐすすべも、なかったからだ。",
              "citation": {
                "source": "舌を噛み切った女",
                "author": "またはすて姫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、朝倉先生が、沈黙をときほぐすように、たずねた。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "年をとった今は、むしろ我儘＊をしてわたしの沈みがちな心持をときほぐすのだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
