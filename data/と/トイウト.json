    "definitions": [
      {
        "index": 1,
        "gloss": "when it comes to ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "月の十何日、風のない暖かい日、医者の許可を得たから植物園へ連れて行ってやると言うとたいへんに喜んだ。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分はすっかりよくなったと言うから、もうそろそろ帰ろうかと言うと、少し驚いたように余の顔を見つめていたが、せっかく来たから、もう少し、池のほうへでも行ってみましょうと言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言うと、靴屋の主人気むずかしい顔で愛嬌よく笑って、　――ほんとうですとも、いくらだってクリスマス前に売っちまわなけりゃあ、これが今の独逸の「クリスマス値段」ですから。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処がよいかと言うとよもぎは道端と云わず山と云わず野と云わず南支至る処にあります。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "「帰れよ、なッ」　と言うと、今度は勝坊メソメソ泣き出した。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこでやっているのかと言うと、それが君の家の庭なんだ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも」と言うと、義兄は笑いながら「はっきり言うとかんのがいかんのやさ」と姉に背負わせた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気候は、と言うと、ほかほかが通り越した、これで赫と日が当ると、日中は早じりじりと来そうな頃が、近山曇りに薄りと雲が懸って、真綿を日光に干すような、ふっくりと軽い暖かさ。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の晩酌の時と言うとはじまって、貴下が殊の外弱らせられたね。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の小都会の小さな書店には気のきいた洋書などはもとよりなかった、何か少し特別な書物でもほしいと言うと番頭はさっそく丸善へ注文してやりますと言った。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし目が二つあれば目で見えるはずのものがなんでも見えるかと言うと、そうは行かない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それじゃけにお目付の松倉さんはどっちかと言うと襟半をタタキ上げて事を片付けたい口ぶりらしいが、しかし襟半から手を廻わいて蔵元屋の娘を毒殺するというような筋合いは、どう考えてもないと言うて、私が一人で突張っとるがなあ」「それは当り前の話じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも何かと言うと私の知恵袋にしておったアンタを、直接に松倉｜様に引合わせて、私とも膝をば突合わせたなら、三人寄れば何とやら、よい知恵が出まいとも限らぬ……と言う私の一生涯の知恵を絞ったドンドコドンのドン詰めの思い付きじゃが、ドウかいな。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ちお婆さんの手から飛び出して、「フーッ」　と言うとそのまま一目散に山の方へ逃げ出しました。",
              "citation": {
                "source": "犬の王様",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの××麦酒に一つ庭球試合を申込んで遣ろうじゃないか」　と言うと、皆総立ちになって賛成した。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "フン何ぞと言うと直ぐ泣くのだ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "老爺大変よろこんですぐ持って帰るというから、それは困る明日まで待ってくれろ今日は自宅へ持って帰って少しは手を入れたいからと言うと、そんならちょっとわしが宅へ寄ってくれろじきそこだからッて、僕が行くとも言わないに先に立ってずんずんゆくから、僕もおもしろ半分についていったサ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその一二を受けながら、シナの水兵は今時分定めて旅順や威海衛で大へこみにへこんでいるだろう、一つ彼奴らの万歳を祝してやろうではないかと言うとそれはおもしろいと、チャン万歳チャンチャン万歳など思い思いに叫ぶ、その意気は彼らの眼中すでに旅順口威海衛なしである。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなこんなで前借のこと親方に言い出すのは全く厭だったけど、言わないじゃおられんから帰りがけに五円貸してくれろと言うと、へん仕事は怠けて前借か、俺も手前の図々しいのには敵わんよ、そらこれで可かろうって二円出して与こしたのだ。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし全く別々で縁がないかと言うとそう簡単でもない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無代ででも貰って行くような調子で、若旦那済まねえがこれを少し分けておくんなさいと言うと、やるから持ってけ――だが負からねえぞ。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老婆はどんなメンタルテストをしたかと言うと、自分の腰元の中でも、年頃で一番美人の女を選びまして何やらそっと命令け、かの禅僧の修業している庵室へ行かせました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは、金はいくらでもあってよいかと言うと、余り沢山持ち込むと、また、不幸になります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく考えますと、時間的に縦に組立てられた因縁の結果であるいろいろの運命への便宜は、どちらかと言うと消極的、惰性的のものであって、ともすれば安易に付き、運命を腐らす危険があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今度は逆に考えて、その理を知った以上、誰でも米を作れるかと言うと、そうはゆきません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、これで知識経験は充分かと言うと、なかなかそうは言い切れません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代人の実感上、地獄感が多いか極楽感が多いかと言うと、勿論地獄感の方が多いと言う人が多いでありましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう大きなものばかりかと言うと、蟋蟀の髭の尖に生命用心の機能を揮わしめ、苔の花一つに種の繁殖の仕組みを籠めさしてあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者太宰治　私は、青森県北津軽郡というところで、生れました。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは対戦中の右翼小説ほどひどくは無いが、しかし小うるさい点に於いては、どっちもどっちというところです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
