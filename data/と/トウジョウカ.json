    "definitions": [
      {
        "index": 1,
        "gloss": "flower head",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "春から夏の初めへかけて数寸ないし一尺｜許りの茎が立って、梢に黄色の小さい頭状花がビッシリ固まって着く。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この今名タビラコ古名ホトケノザは、我邦諸州の田面に普通で秋に種子から生じ早春に漸く繁茂し、春｜闌わにして日光を受け競うて小なる黄色の頭状花（舌状花より成る）を開きすこぶる美観を呈する。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茎頂に沢山な白色頭状花が聚り着き、その各頭状花は多数の小花より成っている。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその頭状花の周縁に射出する多数の舌状弁花をその光線に見立ったものだ。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつにキク科の中でこんな大きな頭状花を咲かせるものはほかにはない。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "園芸的に改良せられた種類にはその頭状花が大きくかつ八重咲で、多くは黄色あるいは柑色を呈し見事である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな集合花を、植物学上で頭状花と称する。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "キク科の花はいずれもみな頭状花である。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
