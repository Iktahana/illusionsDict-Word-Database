    "definitions": [
      {
        "index": 1,
        "gloss": "loading (on a ship)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある軍人の話によると、重爆撃機には一キロのテルミットを千箇搭載し得るそうである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二｜本の煙筒に四｜本檣の頗る巨大な船である、此度支那及び日本の各港へ向つての航海には、夥しき鐵材と、黄金眞珠等少なからざる貴重品を搭載して居る相で、其船脚も餘程深く沈んで見えた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、外形に現れても何も審しい點はないが、少しく私の眼に異樣に覺えたのは、總噸數一千｜噸位にしては其構造の餘りに堅固らしいのと、また其甲板の下部には數門の大砲等の搭載て居るのではあるまいか、其船脚は尋常ならず深く沈んで見える。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、魔の日魔の刻の因縁などは信ぜられぬが、老女が最後の一言、『弦月丸には、珍らしく澤山の黄金と眞珠とが搭載されて居ます、眞珠と黄金とが夥しく海上で集合と屹度恐る可き祟があります。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある軍人の話によると、重爆撃機には一キロのテルミットを千個｜搭載しうるそうである。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "８０８６、８０２８６を搭載した低価格のノートブック・マシンは、ワークスに類似した低価格統合ソフトとの組み合わせで専用ワープロを越えた情報家電の本命をパーソナルコンピューターの裾野に形成することになる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "京セラ自身百も承知だろうが、現在搭載されている二四〇×三二〇ドットの液晶は遅すぎるし解像度が低すぎる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハードウエアは、８０２８６搭載の松下電器のＰａｎａｃｏｍ　Ｍ５３０である。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "６８０３０搭載マシン購入のための貯金を崩し、Ｔ田はサードパーティのアクセラレーターと大型モニターを買った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＯＳ開発にあたっていた松下は系列の松下通信工業から、教育市場向けとして８０２８６搭載のＰａｎａｃｏｍ　Ｍ５３０にＢＴＲＯＮ１を乗せてＰａｎａＣＡＬ　ＥＴとして発売し、かろうじて意地を見せるにとどまった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＲＯＮチップのＧ　ＭＩＣＲＯ１００、２００、３００をそれぞれ搭載した複数の製品ラインが用意されるとのことで、低価格攻勢をかけるサンのマシン並のお値段となるだろうと、オレの責任において勝手に予測しておく。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今盛んに燃焼している部分を完全に消し留めることによって、これから先燃焼するであろう物件を助け出し、それによってゼムリヤ号の搭載荷物とか遺留物品を点検して何かの新しい手懸りを得ようとするのであった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "搭載爆弾は――』のところで本文が切れている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "成層圏を自由自在に駆ける驚異的航空機、それに搭載して敵国の中枢部を破壊する革命的兵器は、あらゆる防禦手段を無効にして、決戦戦争の徹底を来たし、最終戦争を可能ならしめる。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに搭載される火砲や発射管から撃ち出される弾丸や魚雷によって敵艦を打ち沈める。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初ＴＲＳ―80とアップル※は自社のベーシックを使っていたが、その後マイクロソフト製も搭載することになり、アメリカではこれが本命になることは間違いないらしい。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベーシックで使うことが常識となった初期のパーソナルコンピュータでは、モニターやベーシックの翻訳ソフトがＲＯＭに焼き込んだ形で搭載されるようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして続く十月には、これまたＩＴＯＳを搭載したシステム１００の三つのモデルが発表された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにこの年の三月から、ＮＥＣＩＳはＩＴＯＳを搭載した新機種をアストラと名付け、アメリカ市場での販売を開始した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに同じマイクロソフトのベーシックでも、異なったマシンに搭載される場合にはメーカーの注文に応じて機能が拡張されている場合がある。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レベルアップしたハードウエアの性能を生かすべく、ＰＣ―８８０１には大幅に機能拡張されたマイクロソフト製のＮ88―ＢＡＳＩＣが搭載された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがアルテアへの搭載で一歩先駆けたマイクロソフトのベーシックは、ビル・ゲイツが怒り心頭に発したホビイストたちのコピーもあずかって、広く普及していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このマシンには、従来どおり日本電気製のベーシックが搭載されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "このＰＣ―８００１への搭載を突破口として、西と古川は日本のパーソナルコンピューターに続々とマイクロソフトのベーシックを採用させていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "次世代の主流となる８０８６を採用したマシンに搭載されるべき決定版は、「こいつは凄い！",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面に表示した機能メニューをキーボードから選ぶ、マルチプランに採用された形式のインターフェイスを用い、ベーシックの搭載も予定されていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八ビットのマシンながらＣＰ／Ｍを搭載し、フロッピーディスクドライブとドットプリンターを従え、表計算やワードプロセッサーのアプリケーションを載せたＴＲＳ―80は、立派なターンキーのシステムを構成しているように見えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゲイツはマイクロソフトの表計算ソフトを、あらゆるＯＳを搭載したあらゆる機種に移植しやすいように、パスカルで書こうと考えた★。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七八（昭和五十三）年の九月から十月にかけて、情報処理小型システム事業部はユーザーと対話しながら使い方を指導する機能を盛り込んだ基本システム、ＩＴＯＳを搭載したオフィスコンピューターの新機種を発表していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうさいごの一節になりました。",
              "citation": {
                "source": "銀の笛と金の毛皮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
