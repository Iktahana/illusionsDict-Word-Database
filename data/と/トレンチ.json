        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "晴れても降っても、白茶けたトレンチコートの学生群が、舗道の上を右往左往するだけの街になった。",
              "citation": {
                "source": "神田界隈",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、陸上トレンチノ線の、快勝が原因だったのである。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二日払暁、ロヴェレット南方より、スガナ渓谷にいたる、トレンチノ全線の砲兵が、約二千門といわれる砲列の火蓋を切った……。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝巻の上へ大きなトレンチコートを着て煙草を喫いながらゆっくりとこっちへやってくる。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くトレンチ生活だったわ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいにたたんだトレンチ・コートが、かたわらに置いてあった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
