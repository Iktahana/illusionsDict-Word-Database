        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鳴ききたる鵝島のうからしらしらと水に飛び入る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "気早なのは海中に飛び入り飛び入る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎゃお、わお、がお、うわあああ、わお、おお、　飛び入る、飛び入る、飛び入る。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "熟と観察するに、壺中の石の配置や光線が網眼に映る工合、蠅を飛び下す小孔の位地から蠅を持ち行きやる人の手の左右など、雑多の事情に応じて、蠅が孔より飛び入る方角｜趨勢がほぼ定まりある。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "――痛手にこらえかねて、身をよろめかしたとき、ひらひらと京弥の小姓袴が、艶に美しく翻えったと見えましたが、ばっと対手のふところに飛び入ると、刹那に施されたものは遠気当て身の秘術でした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一匹の枕もとに飛び入る小虫さえも珍らしく眺める病床の無聊は、却って私に身近の切実な物思いをも一時救ってくれた。",
              "citation": {
                "source": "窓",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて死に飛び入る為のスプリング・ボオドを必要とした。",
              "citation": {
                "source": "或旧友へ送る手記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを元に戻すべく反逆そのものの眞中に飛び入る惠みが即ち赦しである。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "決死隊が、敵に飛び入ると、敵はそれを目がけて、弾丸を集中しました。",
              "citation": {
                "source": "とびよ鳴け",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しそれ、風絶えて空曇りたる寒き日の暮れ近く、鶫の餌をあさりながら空庭に散り積った落葉をがさりがさりと踏み歩む音の寂しさに至っては、恐らくは古池の水に蛙の飛び入る響にも劣るまい。",
              "citation": {
                "source": "写況雑記",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うわうっ」　と、ひとり誰かが、怒濤の中へ飛び入るように吠えて、だっと出る――。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
