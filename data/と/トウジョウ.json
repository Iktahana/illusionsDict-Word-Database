[
  {
    "uuid": "0b7da56b-eab1-5531-be71-58d74eff803d",
    "entry": "登場",
    "reading": {
      "primary": "とうじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
