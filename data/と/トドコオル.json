[
  {
    "uuid": "6af86388-e691-5775-8eaf-fe494d8e47ed",
    "entry": "滞る",
    "reading": {
      "primary": "とどこおる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
