    "definitions": [
      {
        "index": 1,
        "gloss": "to go away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頻繁なる対人圏にあつて、各人が各人で朗らかであり得ぬ程度に比例して人々は互の「顔色を覗ふ」こと盛となる、即ち相対的となる、即ち創作的気心より遠ざかるわけである。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし後に小説家となり、その方の創作に専念するやうになつてからは、彼のポエヂイの主生命が、悉く皆散文の形式の中に盛り込まれて、次第に詩文学から遠ざかるやうになつてしまつた。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "模様が平行線としての縞から遠ざかるに従って、次第に「いき」からも遠ざかる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやのことが薄々二人に知れたので、僕から言いだして当分二人は遠ざかる相談をした。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "親仁は差心得たものと見える、この機かけに手綱を引いたから、馬はすたすたと健脚を山路に上げた、しゃん、しゃん、しゃん、しゃんしゃん、しゃんしゃん、――見る間に眼界を遠ざかる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女気に遠ざかる事、鞄を除いて十｜里に余つた。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此花咲けば此頃よりやがて酒の味うまからずなりて、菊の花咲くまでは自ら酒盃に遠ざかること我が習ひなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天狗」や「河童」の類となると物理学や気象学の範囲からはだいぶ遠ざかるようである。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけはわからないが本能的に敵から遠ざかるような方向に駆け出すのである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸から遠ざかるに連れて、やっと人間らしい気持になって来たのであろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬいさんの家から遠ざかるにしたがって、小刻みに震う前髪がだんだんはっきりと眼につきだして、とうとうそのまま歩きつづけてはいられなくなったからだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間から身体の構造が遠ざかるに従ってだんだん意識が薄くなるかどうかそれは少しもわかりませんがとにかくわれわれは植物を食べるときそんなにひどく煩悶しません。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼はそれらを得意としているのであるから、自然に大歌舞伎から遠ざかるのも無理はなかった。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから栄蔵も他の子供達から、だんだん遠ざかるやうになつてしまつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その外、当時の同級生には今の美術学校長正木直彦、専門学務局長の福原鐐二郎、外国語学校の水野繁太郎氏などがあって、それ等の人はなかなか出来る方であったが、私達遊び仲間の連中は総て不成績で、漸次、是等の諸氏と席の方が遠ざかるばかりであった。",
              "citation": {
                "source": "私の経過した学生時代",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その負担をのがれる為めと、やゝもすれば身辺に近づいて来る画像の誘惑から遠ざかる為めと、もひとつ彼の思ひつきの為めに彼は翌年の春の初、寺のうしろの畑地の隅に居を移した。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、火の傍へ寄れば少くとも髭は焼かれるから、誰しも御免｜蒙って疎み遠ざかる。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう温泉場からその釣橋へ行く道の半ばからは、一方が小山の裙、左が小流を間にして、田畑に成る、橋向ふへ※ると、山の裙は山の裙、田畑は田畑それなりの道續きが、大畝りして向ふに小さな土橋の見えるあたりから、自から靜かな寂しい參拜道となつて、次第に俗地を遠ざかる思ひが起るのである。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とか云って、貸本の素見までが遠ざかる。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "親仁は差心得たものと見える、此の機かけに手綱を引いたから、馬はすた／＼と健脚を山路に上げた、しやん、しやんしやん、しやんしやん、しやんしやん、――見る間に眼界を遠ざかる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "町家や工場の眺めに遠ざかるほど沼は広くなって来ます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛も亦た斯くの如く造化の妙契と威厳に遠ざかるところには、如何に豪逸奢美を粧ふとも、其美、其妙は枯痩して、浜の砂地に生えたる小草に、あはれ気に咲く花の如けんかし。",
              "citation": {
                "source": "「伽羅枕」及び「新葉末集」",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "海中の顏は瞬一瞬に後に遠ざかる。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "かう思つて、「何物でも、この自分を遠ざかるものは、もう、無關係だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に色眼鏡をかけて済まし返っているスゴイような丸髷美人の横顔が、ハッキリと網膜に焼付いたまま遠ざかる。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーッと、むこうの空へ、とおざかるかとおもうと、またこちらにもどってきます。",
              "citation": {
                "source": "妖星人Ｒ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足音が地の下へとおざかるのを聞きながら、蚕婆はすぐもとのとおり床板や蓆を敷きつめ、壁にかかっている獣捕りの投げ縄をつかむが早いか、いきなりおもてへ飛びだした。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
