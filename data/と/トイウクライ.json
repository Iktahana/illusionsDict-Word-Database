    "definitions": [
      {
        "index": 1,
        "gloss": "to the extent that (you could say that)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
