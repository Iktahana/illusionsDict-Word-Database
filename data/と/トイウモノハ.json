[
  {
    "uuid": "2852f64a-51b3-5a85-9424-20aae0b973d3",
    "entry": "と言うものは",
    "reading": {
      "primary": "というものは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "副詞"
      ],
      "ctype": null,
