    "definitions": [
      {
        "index": 1,
        "gloss": "ladies and gentlemen!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
