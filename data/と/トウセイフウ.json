    "definitions": [
      {
        "index": 1,
        "gloss": "latest style (fashion, hairstyle, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これに反して新道沿いに新しく出来た当世風の二階家などで大損害を受けているらしいのがいくつも見られた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "可笑しいことには、古来の屋根の一型式に従ってこけら葺の上に石ころを並べたのは案外平気でいるそのすぐ隣に、当世風のトタン葺や、油布張の屋根がべろべろに剥がれて醜骸を曝しているのであった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に真鶴の山中は、当世風の扮装した一のこの旅客を得て、はじめて湯治場へ行く道の、熱海街道となったのである。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ロマンティストは、何時もすべっこく髭を剃り立ての頤を光らせていたり、伊達色の当世風に身についた新調の衣服を着たり、香水の匂いをさせたりしないことや、また道を歩きながら余り明けっぴろげに娘たちばかりを眺めたりしてはならないことを教えてくれた。",
              "citation": {
                "source": "浪漫趣味者として",
                "author": "―― Ibi omnis effusus labor ! ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふところに収めたる当世風の花簪、一世一代の見立にて、安物ながらも江戸の土産と、汗を拭きふき銀座の店にて購ひたるものを取出して、昔日の少娘のその時五六歳なりしものゝ名を呼べば、早や寝床に入れりと言ふ、枉げてその顔見せてよと乞へば、やがて出で来りて一礼す。",
              "citation": {
                "source": "三日幻境",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "どちらかといえば大柄の、色の白い、眉の形のいい、別に取立てていうほどの容貌ではないが、こちらでは十人並として立派に通用する女で、名はお辰、当世風にいえば辰子で、本来ならばお互いにもう見忘れている時分だが、彼女にはきのうの朝も会っているので、双方同時に挨拶したわけだ。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから読み取れることは、夜間の訪問客の数は二、ひとりは目立つ背丈（これは歩幅から見積もった）、もうひとりはブーツの残した小さく上品な形から判断するに当世風の装い。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……自動車はつい別になりましたんですが、……おなじ時に、――画家　私は乗合でしたがな――さよう……お一方、仕立てた方があったように思いますが、それは、至極当世風の髪も七三で……（と半ば言う。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "応対の雍にして人馴れたる、服装などの当世風に貴族的なる、或は欧羅巴的女子職業に自営せる人などならずや。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから表立つて親御へ申込まれる華族、豪商、権門の方を始め、何かに托つけて邸へ出入りする当世風の若紳士、隙があれば喰はふといふ君達狼連まで、有るは／＼、自称候補者の面々が無慮一万人ばかりだね。",
              "citation": {
                "source": "犬物語",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりにはすべて当世風の新しい住宅や商店ばかりが建ちつゞいている。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "上のは細い金の枠に比較的大きな真珠を盛つた当世風のもので、三年前結婚の御祝として代助から贈られたものである。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを両親が当世風の生活に慣れさせるためにヱネチアに来させたのだと、レオネルロが自ら語つた。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "当世風の娘ならば丈の高い、少しふとり肉の手のふっくりとして小さい、眼のまつ毛が長くて丸く大きく、唇もあんまり厚くなく、あごのくくれたような輪かくのはっきりしたかおがすき。",
              "citation": {
                "source": "妙な子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落語が現代的に変改が加へられて来たら、歌舞伎の当世風演出と同じくナンセンスなのだ。",
              "citation": {
                "source": "落語家たち",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「義を、道を学ぶ者として、俗吏の咎め位を恐れて、何と致しましょう」　若者は、その当世風の着物に似ず、しっかりした口調でいった。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "横浜の貿易商の子で、当世風の派手好の兄妹を、養子は平生好きでなかった。",
              "citation": {
                "source": "九月一日",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は年の頃二十四、五、都風に髪を結い当世風の扮装をし色白面長の顔をした女好きのする男であったが、眼に何んとなく剣があり、唇が余りに紅いのは油断の出来ない淫蕩者らしい。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、当世風の人たちがこの並木通りを散歩する時刻に、私は例によってこの廃宅の前に立って、じっと考え込んでいると、私のそばへ来て私を見つめている人のあることを突然に感じた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "廃宅",
                "note": "青空文庫"
              }
            },
            {
              "text": "上のは細い金の枠に比較的大きな真珠を盛った当世風のもので、三年｜前結婚の御祝として代助から贈られたものである。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "又狂言には、当世風流の寛濶ぶりをうつして、歌舞妓芸を創作する様になつた。",
              "citation": {
                "source": "古代研究　追ひ書き",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてそれがいはゆる「当世風」であることも必要ではないと思ふ。",
              "citation": {
                "source": "『ハイカラ』といふこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は、「当世風」といふ言葉の代りに「新時代」、「現代式」の代りに「近代的」とか「モダアン」とかいふ言葉が使はれてゐるが、これも「ハイカラ」といふ言葉を定義するには役立たないと思ふ。",
              "citation": {
                "source": "『ハイカラ』といふこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが生意気な当世風の娘だとこういう場合に直ぐ我儘を言出して、ヤレあの人と婚礼が出来なければ死んでしまうの、一生お嫁に行かないのととんでもない事を言う。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、それは源氏の五十余帖を当世風に描いたもので、絵は二代豊国あたりの筆。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、年頃だから、こんな美しい当世風の浮世絵を見ていれば、悪い気持もしないのでしょう、にくらしい」　浅吉はこの時、お雪を憎らしい子だと思いはじめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通、陶器をやる人は瀬戸物家に生まれた人であるとか、工芸学校出身者などが主でありまして、色々と当世風なものを表現されておりますが、私は自分の食道楽が因をなし、止むに止まれず、作陶に手を出したという始末で、そのためか、今以て食器以外のものは殆ど作る気になりません。",
              "citation": {
                "source": "陶器鑑賞について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "当世風の厚化粧｜入毛沢山の庇髪にダイヤモンドちりばめ女優好みの頬紅さしたるよりも洗髪に湯上りの薄化粧うれしく思ふ輩にはダリヤ、ベコニヤなんぞ呼ぶものよりも雪の下蛍草なぞのささやかなる花こそ夏には殊更好ましけれ。",
              "citation": {
                "source": "一夕",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅井忠の板下を描いた当世風俗五十番歌合というものに、「風ひきめまいの大奇薬、オッチニイ」とその売声が註にしてある。",
              "citation": {
                "source": "巷の声",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹沢の出はづれで、当世風の紳士を乗せた一台の人力車が丑松に追付いた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
