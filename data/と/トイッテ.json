        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はその時のことを追想して、草双紙で読んだ昔物語を、そっくり現実に経験した様だったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の手の某所に住んでるある華族の老婦人が、非常に極端な西洋嫌いで、何でも舶来のものやハイカラなものは、一切『西洋｜臭い』と言って使用しない。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、少しも西洋臭くない』と言って大満足なので、『あなた西洋臭くないでしょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その度ごとに、ヘルンはまた『ごめん、ごめん』などと言って笑いふざけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は自らそれを告白して、良人の気性をすっかり呑み込むようになるまでは、一通りでない努力をしたと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしよく解った後では、全く子供のように正直一途で、子供のように純情無比の人であったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの趣味はすべてにおいて庶民的で、儀式ばったことが嫌いなので、フロックコートなどの礼服を非常に嫌い、常に野蛮人の服と称し『なんぼ野蛮の物』と言っていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "八雲は縁側に立ってそれに聞き惚れ、『いかに面白いと楽しいですね』と言って喜んだが、また『私、心痛いです』と言った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし……』と言って悲しげに『かわいそうです。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、なんと言っていいか。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとがひとの能力を試みるなんてことは、君、容易ならぬ無礼だからね」「そうです」「と言ってみただけのことさ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれを酒ぶとりであると言って、こうからだが太って来ると、いよいよ危いのだ、と小声で附け加えた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学のほうではアンドレ・ジッドとトオマス・マンが好きです、と言ってから淋しそうに右手の親指の爪を噛んだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬場はかるく狼狽の様子で、「くらべたりするもんじゃないよ」と言って笑ったが、すぐにけわしく眉をひそめ、「いや、ものごとはなんでも比較してはいけないんだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って、また蒲団を頭からかぶった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、君を信じる、と言っていた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、かれは豪放磊落を装い、かまわんかまわんと言って背広服で料理屋に乗込んだものの、玄関でも、また廊下でも、逢うひと逢うひと、ことごとく礼服である。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、男ッぷりが悪いので、何かと人にからかわれて、ひとりでひがんでいましたが、叔母だけは、私を、いい男だと言ってくれました。",
              "citation": {
                "source": "五所川原",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢想家が、この世で成功したというためしは、古今東西にわたって、未だ一つも無かったと言ってよい。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とても書けない」と言って、お断りしたら、「それは困る。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちの面目丸つぶしです」と言って来た。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丸つぶれ」でなく、「丸つぶし」と言っているのも妙である。",
              "citation": {
                "source": "無題",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この詩の作者の名をかくして、明治年代の若い新体詩人の作だと言っても、人は決して怪しまないだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に芭蕉も弟子に教えて、常に「俳句は調べを旨とすべし」と言っていたという。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王が代わりに自分の弓を与えたのを引き絞ってみて「弱い弱い、大王の弓にはあまり弱い」と言って弓を投げ捨て、剣と盾とを取って勇ましく戦った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戦を歌った当時の詩人の歌の最後の句にも「人はその願う事をやがて信ずる」と言っている。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵軍が近寄るのでフィンが呼びさますと、「もう少し夢のつづきを見せてくれればよかったのに」と言ってその夢の話をして聞かせる。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は「南門殿還幸」を意味すると言っていたがそれはあまり当てにはならない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
