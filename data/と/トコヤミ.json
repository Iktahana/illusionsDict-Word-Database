    "definitions": [
      {
        "index": 1,
        "gloss": "everlasting darkness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "浮世の花の香もせぬ常闇の国に永劫生きて、ただ名ばかりに生きていなければならぬかと思うと、何とも知れぬ恐ろしさにからだがすくむ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は「桐一葉」「ヴェニスの商人」「常闇」。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "物の表は永劫の真昼に白み亘り、物陰は常闇世界の烏羽玉いろを鏤めている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは毛髮｜倒に竪ちて、卓と柩との皆｜獨樂の如く旋轉するを覺え、身邊忽ち常闇となりて、頭の内には只だ奇しく妙なる音樂の響きを聞きつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　四人の死骸と二人の腰拔けとが、各々家族と友達との手に渡つた時、彼等が悲憤の泣聲は、世を常闇の底に引入るゝ叫びに等しかつた。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "このトレミイ・Ｈの言としてポウがある作品で引用してゐるのに「未聞の事柄を探求するために、冒険者達は常闇の海に乗り出す。",
              "citation": {
                "source": "『ユリイカ』挿話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "△尾竹国観――『常闇』火の消えるのを防ぐ神々は出てゐたが、火の消えるのを恐怖する表情は出てゐなかつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜すがら両個の運星｜蔽ひし常闇の雲も晴れんとすらん、隠約と隙洩る曙の影は、玉の緒長く座に入りて、光薄るる燈火の下に並べるままの茶碗の一箇に、小き蛾有りて、落ちて浮べり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、ふたたび日本の世をかき乱して、邪魔になる忠臣の正成をほろぼし、義貞を殺し、悪魔はいよいよ威勢を振うて、津々浦々に兵乱やむ時なく、家は焼かれ、人は疲れ、天も晦く、地も冥く、世は常闇となることを祈っている。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前どもが永い間閉じ籠められた常闇の国から抜け出して来て、久しぶりに見たのが今夜の満月でございましょう。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、疑惑と不幸と絶望との常闇の迷路をつまずき歩いている自分のすがたを、私は見守っていた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "世はむかしの常闇にかえったかと思われるばかりに真っ暗になって、大地は霹靂に撃たれたようにめりめりと震動した。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見懸けた夢をそのままに、文三が振返ッて視遣る向うは隣家の二階、戸を繰り忘れたものか、まだ障子のままで人影が射している……スルトその人影が見る間にムクムクと膨れ出して、好加減の怪物となる……パッと消失せてしまッた跡はまた常闇。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ラザルスに言葉をかけた人たちの心では、あの三日間の死の常闇が余りにも深刻であったので、この地上の熱や光りではとても温めることも出来ず、また彼の眼に沁み込んだ、その常闇を払い退けることが出来ないのだと思って、やれやれと溜め息をつきながら行ってしまうのであった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラザルス",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に和合するかと思えば、また夫婦喧嘩をして、かれらは火花の如くに輝き、火花のごとくに常闇の世界へと消えて行った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "ラザルス",
                "note": "青空文庫"
              }
            },
            {
              "text": "失明の川を溯りて永遠の獄より脱れし汝等は誰ぞや　四〇―四二誰か汝等を導ける、地獄の溪を常闇となす闌けし夜よりいづるにあたりて誰か汝等の燈火となれる　四三―四五汝等斯くして淵の律法を破れるか、將天上の定新たに變りて汝等罰をうくといへどもなほわが岩に來るをうるか。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮は寂しく沈み、濤は暮れて、櫓の音今こそ朽ちめ、嗚呼わが日の生命の榮よなやみよ逝き果つるや、つひにはこの身の罪の淨めがたく回憶しげき荊棘の途に下り、常闇つきぬ苛責にやさまよふべき。",
              "citation": {
                "source": "獨絃哀歌",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も其子孫に言ひ及して居ない処から見れば、一般の万葉人の為には、やはり常闇の「妣の国」が、横たはつて居るばかりだつたものであらう。",
              "citation": {
                "source": "万葉びとの生活",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其常闇の国が、段々光明化して行つた。",
              "citation": {
                "source": "国文学の発生（第四稿）",
                "author": "唱導的方面を中心として",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣長は三つの解釈の中、冥土・黄泉など言ふ意に見て、常闇の国と言ふ意味に入れて説いてゐる。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、「常世行く」と言ふ――恐らく意義は無反省に、語部の口にくり返されて居たと思はれる――成語は、確かに常闇の夜の状態が続くと言ふ事に疑ひがない。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "常世の国は、我が記録の上の普通の用法では、常闇の国ではない。",
              "citation": {
                "source": "「とこよ」と「まれびと」と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天地の神なきものにあらばこそ吾が思ふ妹に逢はず死せめ」（巻十五・三七四〇）、「逢はむ日をその日と知らず常闇にいづれの日まで吾恋ひ居らむ」（同・三七四二）などにあるように、「天地の神」とか、「常闇」とか詠込んでいるが、それほど響かないのは、おとなしい人であったのかも知れない。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣長も、冥土・黄泉などの意にとつて、常闇の国の義としてゐる。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "常闇は時間について言ふ絶対観でなく、物処について言ふもので、絶対の暗黒と言ふ事である。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一義としての常闇の国土なる「とこよ」が、祖先の考へにあつた事は想像してよい。",
              "citation": {
                "source": "古代生活の研究",
                "author": "常世の国",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
