    "definitions": [
      {
        "index": 1,
        "gloss": "transparency",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜九時、大風｜室を四匝せる石壁を透徹して雷吼す、駭魄して耳目きはめて鋭敏となり、昨夜御殿場旅館階上の月を憶ひ起し、一人｜窃に戸を排して出で、火孔に吹き飛ばされぬ用心して、這ふが如く剣ヶ峰に到り、その一角にしがみ附きて観る。",
              "citation": {
                "source": "霧の不二、月の不二",
                "author": "――明治三十六年八月七日御殿場口にて観察――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただちがふところは、ラムボオが透徹した知性人であつたに反し、中原君がむしろ殉情的な情緒人であつたといふ一事である。",
              "citation": {
                "source": "中原中也君の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの奇怪な『猫』の表現の透徹した心持は、幾度となく私の模倣したものであつたが物にならなかつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀で染めた髪と、眉の間に鼻眼鏡をかけたアウギュスト・ロダン氏は、妾の小さい手を芸術家らしい熱情をもってとると、不思議に透徹した眼光が妾を凝視しているのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は尻のところに縫模様のある緑色の部屋で踊子のベッドに寝ころんで天井に口汚く附着したシャンパンの斑点をみつめながら、病み果てた病人のように透徹した頭脳であわただしく過ぎて行った赤い歴史をめくるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "數多くのその短篇は美しく簡潔で、例の「涙を含んだ微笑」と言はれる一種の物懷しい情緒をたたへながらも、その人生に人間性に放つ眼は鋭く透徹してゐる。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、若しこれが成功したならば、畸形ながらにも、原作に對するある解釋と、私自身の創作が、同時に讀者に示せると思つてゐたのだつたが、それに必要な頭の透徹と時間の贅澤が與へられなかつたため、どうも強引でものにしたやうな傾きがある。",
              "citation": {
                "source": "川端康成第四短篇集「心中」を主題とせるヴァリエイシヨン",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また一方下級の技術官たちの間では実に明白に有効重要と思われる積極的あるいは消極的方策があっても、その見やすい事が、取捨の全権を握っている上長官に透徹するまでにはしばしば容易ならぬ抵抗に打ち勝つことが必要である。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもダーウィンの進化論や、アインスタインの相対性云々よりも、もっと深刻透徹した名原則をあらわす公式なのだからね。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私の見るところでは、むしろ珍しいくらいいい透徹した頭脳をもっていたように思われる。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "信念は心を平静にし、透徹させます。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ参考としては、当時の国民実情に対する透徹した洞察あるのみであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "燭が映って、透徹って、いつかの、あの時、夕日の色に輝いて、ちょうど東の空に立った虹の、その虹の目のようだと云って、薄雲に翳して御覧なすった、奥様の白い手の細い指には重そうな、指環の球に似てること。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然の無関心な心、秋の透徹した気、午後三時頃の温かい光線が衰弱した神経の端々まで沁みわたって、最う社会もない、家庭もない――自分自身さえもなくなろうとする。",
              "citation": {
                "source": "夜長ノート",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "恰で空明透徹な大氣の中へ淡い水蒸氣が流れ出したやうな有様であツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人は氏の自殺に対して、病苦、家庭苦、芸術苦、恋愛苦或いはもっと漠然とした透徹した氏の人生観、一つ一つ別の理由をあて嵌めた。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会児の洗練透徹した機智は生れ付きのものだった。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は愛があるうちは愛の完全透徹した力を信じてゐた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時はやや病が衰えて元気が回復したかのように、透徹るような瘻れた顔に薄紅の色がさして、それは実に驚くほどの美しさが現われることも有ったが、それは却って病気の進むのであった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはもつと深い透徹を要する。",
              "citation": {
                "source": "京阪聞見録",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "童が髪に燃えつきて仏の如く透徹らしめ、またしばし、輝かす、ふくらかに臀部の円みの滑りよく、白く、冷たき肉づきを、銀のうぶ毛を。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "石よりも堅くて青くて透徹るよ。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それら無言の石どもの間に坐って、その美しい結晶や正しい劈開のあとを見ていると、何か冷たい・透徹した・声のない・自然の意志、自然の智慧に触れる思いがするのである。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "へ……俗受けを棄てて純真へ……華麗から率直へ……客観から主観へ……最高の芸術的良心の表現へ……透徹した生命の躍動へと進化して行く。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "内面的に云えば在来の能の表現を一層求心的にしたもので、喜多流の能が完成すれば最も単純な、最も透徹した仮面舞台表現が出現する訳である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷に倚りて水を望めば、一塊の石、一叢の藻、歴々として數ふべく、晴れたる日の空氣といへども、恐らくはこの玲瓏透徹なからんとぞおもはるゝ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "燭が映つて、透徹つて、いつかの、あの時、夕日の色に輝いて、丁ど東の空に立つた虹の、其の虹の目のやうだと云つて、薄雲に翳して御覧なすつた、奥様の白い手の細い指には重さうな、指環の球に似てること。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日透徹した空をぢり／＼と軋りながら高熱を放射しつゝあつた日も餘りに長い晝の時間に倦まうとして、空からさうして地上の凡てが漸く變調を呈した。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
