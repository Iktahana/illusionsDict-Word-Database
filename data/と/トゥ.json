        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "所でラヴェルなんてバッハが見たら苦労性なデコラトゥールだ。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男といふのは文士のアンリ・ド・ラトゥシュ。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "笞を忘るるな｛１１｝」とは老婆がツァラトゥストラに与えた勧告であった。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮名ではトゥ）であったと考えられる。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドーヴァへ渡ったときは「エネシング、トゥ、デクレアー」と聞かれ「ノー」と答えた、ただそれだけであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスムッセンの「第五回トゥーレ号探検記」にもこれに似た唄合戦の記事があるところを見ると、これに類似の風俗はエスキモー種族の間にかなり広く行われているのではないかと思う。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐水病の予防　昨年中パリのパストゥール免疫所で狂犬に噛まれた人のために恐水病予防の注射を行うた件数が七百七十三、その中で不幸にして該病のために死んだのはわずかに二人しかない。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　リルケが晩年、ラアガツのホテルで、この小時の作品の思ひ出をトゥルン・ウント・タクジス公爵夫人に語つた一夜のことが、夫人の囘想記には興深く敍せられてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "リルケは先づ、ソルボンヌ區トゥリエ街十一番地に寓した。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "後出の妻クララ及びロダンに宛てられた二つの手紙は、前述のトゥリエ街の寓居で書かれたものだが、最初のルウ・アンドレアス・サロメに宛てて書かれた手紙は、その翌年羅馬から獨逸のヴォルプスヴェデに歸つてから當時を追想して書かれたものである。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "……二　妻クララに一九〇二年九月十一日、巴里トゥリエ街十一番地　……私は一日中、ムウドンの庭の中の、靜かな場所に坐つてゐました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺は真先に神田の三崎町にあるトゥヰンビー館に行って円山さんに会った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥヰンビー館といえば、札幌の演武場くらいを俺は想像していたんだが、行ってみたら、白官舎を半分にして黴を生やしたような建物だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいをいうと、トゥロンという町にはかたわ者といっては一人もいないはずなのです。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからというもの、このトゥロンの町もかたわ者ができるようになったのです。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トゥロンにはたくさんのかたわ者ができた中にも、二人のえらいかたわ者がいる。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人は神様の心を知る予言者、一人は神様の忠義なしもべ、さすがにトゥロンは聖マルティンを守り本尊とあおぐ町だけあると、他の町々までうわさされるようになりました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでトゥロンでも年寄った人々がよりより相談して、長い間山の中にかくまっておいた尊像を町におむかえしようという事に決まりました。",
              "citation": {
                "source": "かたわ者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またそのなかでいっしょになったたくさんのひとたち、ファゼーロとロザーロ、羊飼のミーロや、顔の赤いこどもたち、地主のテーモ、山猫博士のボーガント・デストゥパーゴなど、いまこの暗い巨きな石の建物のなかで考えていると、みんなむかし風のなつかしい青い幻燈のように思われます。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんたうはデストゥパーゴって云うんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「デストゥパーゴ？",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボーガント・デストゥパーゴかい。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この前きみは姉さんがデストゥパーゴのとこへ行くかもしれないって云ったねえ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その叫びは気のせいか、デストゥパーゴ万歳というようにもきこえました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのときデストゥパーゴがコップをもって立ちあがりました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからデストゥパーゴの方を見ました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとデストゥパーゴはちょっと首をまげて考えました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "デストゥパーゴは不機嫌そうな一べつをわたくしに与えてから仕方なさそうにうなずきました。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
