    "definitions": [
      {
        "index": 1,
        "gloss": "chicken skin (esp. in cooking)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
