    "definitions": [
      {
        "index": 1,
        "gloss": "surrounding at a distance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "青年団や、消防組が、山を遠巻きにして、犯人を狩り出していた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに引きかえて、自分への興味のために、父の旧式水泳場をこの材木堀に無償で置いてくれ、生徒を世話してくれたり、見張りの船を漕いでくれたりして遠巻きに自分に絡まっている材木屋の五十男貝原を見直して来た。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを遠巻きに見物している人達をかきわけて、半七と庄太は前へ出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛々しい犬は、小屋をも遠巻きに取巻いて、波のように、うごめき呻っていた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者の鼈四郎は、こういう景致や物音に遠巻きされながら、それに煩わされず、逃れて一人うとうとする束の間を楽しいものに思い做した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太鼓に、鉦に、ひしひしと、打寄する跫音の、遠巻きめいて、遥に淀川にも響くと聞きしは、誓文払いに出盛る人数。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南へ行進して行く漢軍を遠巻きにしながら、馬上から遠矢を射かけるのである。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "匈奴はまたしても、元の遠巻き戦術に還った。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝成大声に、「既に今日まで百日余の遠巻きをした。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを四方から遠巻きに取り囲んで口々に何か言っているのである。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小左衛門の露路の近所を遠巻きにして、そこらをうろ付いている筈であるが、半七は念のために露路の奥へ覗きにゆくと、井戸を前にした小左衛門の家の奥から女の泣き声が洩れてきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらには雪どけの泥水と、さんざんに踏みあらした下駄の痕とが残っているばかりで、近所の子供や往来の人達がそれを遠巻きにして何かひそひそとささやき合っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを取逃がしてはならないというので、侍は岸を遠巻きにした。",
              "citation": {
                "source": "馬妖記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "大菱屋ではいかに未来の危険を恐れていても、差し当っては外記をことわる口実を見いだすのに苦しんで、単に注意人物として遠巻きに警戒しているに過ぎなかった。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "片盤の坑夫や坑女たちは、網をかぶった薄暗い電気の光に照らされながら、閉された採炭場の防火扉の前に、意味ありげに二つも並んだ屍体を遠巻きにして、前とは違って妙にシーンとしていた。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞記者などがどこをどうして探り出したか、始めのうちは押し強く葉子に面会を求めて来たのを、女将が手ぎわよく追い払ったので、近づきこそはしなかったが遠巻きにして葉子の挙動に注意している事などを、女将は眉をひそめながら話して聞かせたりした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "群がり集まって来た子供たちは遠巻きにその一人の子供を取り巻いた。",
              "citation": {
                "source": "卑怯者",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "脅迫状に指定された翌晩が来ると、警察署長以下、警部一名、刑事巡査六名がことごとく変装して、鎮守の森を遠巻きにしたそうです。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも水引奉書に飾り立てた品々が、ずらずらとそこに並べられたのを見眺めると、胡散げに退屈男を遠巻きにしながら監視していた若侍の面々が、期せずしてざわざわとざわめき立ちました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "かせぎを終えて帰った二十六人が親方たちに守られながら、ぶらりとさがっている二枚の着物を遠巻きにして、こわいものをでも見るようにながめているのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、点と見えた敵の影は忽ち翼を伸ばして、あはや池の真上にさしかゝらうと遠巻きの大輪を描いてゐた。",
              "citation": {
                "source": "鵞鳥の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "中間どもが追い払っても、やはり遠巻きにして眺めている。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ他の諸生らも集まって来て、これはおそらく本当の人間ではあるまい、鬼がこんな姿に変じて我々をあざむくのであろうなどと言いながら、しばらく遠巻きにして窺っていると、女はやがて眼をあいて、あたりを見まわして驚き怖れるような様子であった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "続夷堅志・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火の下の死骸を遠巻きにしている人達は思い思いの推量をくだして、がやがやと立ち騒いでいた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼、ひょっとこ、狐、天狗、将軍たちが、面をかむっていなくても鬼の面と化した大鬼を、遠巻きにして、一方を追えば一方から石を投げして、やがて芋畑は世にも奇妙な戦場と化した。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はまだここらをさまよっていたらしく、あまたの犬は牙をむき出して彼女を遠巻きにしているのであった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官隊や消防隊は、はるかに離れて、これを遠巻きにしていた。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "重量をつけて海の底へ沈められては、さすがの猫ももう再び浮かび上がれないものとおまきも覚悟したらしく、人々にむかって嘆願した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "母とおまきさんとはだれでもがするようにこめつきばったをやって居る。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の火星人は、先生と丸木とをとおまきにして、つっ立っている奴もあれば、無作法にもごろんと地面に寝そべっている者もあった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
