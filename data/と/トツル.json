        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "向ふとこっちの岸に星のかたちとつるはしを書いた旄がたってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向ふとこっちの岸に星のかたちとつるはしを書いた〔旗〕がたってゐました。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うとこっちの岸に星のかたちとつるはしを書いた旗がたっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうとこっちの岸に星のかたちとつるはしを書いた旗がたっていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うとこつちの岸に、星のかたちとつるはしを書いた旗がたつてゐました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔うと柳吉は「おい、こら、らっきょ」などと記者の渾名を呼んだりし、そのあげく、二次会だと連中とつるんで今里新地へ車を飛ばした。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、高志とつるんで遊ぶようになってからは、それが暗黙のルールみたいになったんだ」「ああ、わかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "武器と武器との触れ合う音、ビーンビーンとつる鳴りの音。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは祖父の弟で、子供たちが下島のおじさんというものを知るようになってから、いつも長い八の字髭をはやし、色のさめた黒木綿の羽織を着て頬っぺたがときどきピクピクとつる人だった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかあさんはもっとつるつるして柔らかな手をしている。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "門の左右を埋める藪のところどころから、簇々とつるをのばしたその花が、今では古びた門の柱にまといついて、ずり落ちそうになった瓦の上や、蜘蛛の巣をかけた楹の間へ、はい上がったのがあるからであろう。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵は、カーキー色の服を着、シャベルとつるはしとをかついで、針目博士邸へ行った。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、シャベルとつるはしとを力にして、ずるずるする斜面を、天窓の方へのぼっていった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにごとが起ったかと、泉水の方をこわごわみていたお邸の連中は、泉水の中から、いきなり、泥まみれの小僧が、シャベルとつるはしとをもってとびだしたものだから、きもをつぶしてしまった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを捕えた当番の知らせで深夜というのに被害者が参集、隠匿財産を白状しろとつるし上げがはじまったのだ。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと抱えもあるような太い梁がわたった煤けた天井に、行灯やら乾菜やら古｜洋灯やら、さまざまなものをごたくさとつるし、薄暗い土間の竈の前で狢が化けたようなちんまりした小娘が背中を丸くして割木を吹いている。",
              "citation": {
                "source": "生霊",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその日本太郎が松葉とかいう色の黒い馬面の女とつるみ高座でそののち睦の寄席へ現れ出したと思ったら間もなく消えて、震災の翌年の九月には、牛込肴町の柳水亭という端席へ、独演会の看板を上げた。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはっははは」　とつるりと顔をなでて、もう何をいったか忘れたようにすまし返ったのだが、そのようすをぼんやり網膜へうつして、若松屋惣七は、相変わらずの龍造寺主計であるとにっこりした。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お前知とつるかい、あの人は幽霊を見た人やぞえ……』とおしんさんは竈の下の火をつくろひながら、お政さんを見て云うた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生ならいいかも知れません」とつるつると口を滑らして、はっと言い過ぎたと下を向いた。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "外套掛けには、袖口のすりきれた薄地のコートが、仕留められたケモノの皮のように、あわれなようすでグッタリとつるさがっている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから一旦警視庁にとって返すと、例の四銃士を呼び寄せて、今暁有明荘の六人が「カーマス・ショオ」の六人とつるんで泊り込んだ築地の待合「すず本」の検証、現警視総監すなわち前京都府警察部長と松谷鶴子の身元調査、並びに元日の午前三時五十分から四時五十分までの総監の行動調査を命じた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……三時になってから、もうそろそろ王様に逢いに行こうとそのつもりをしていると「カアマス・ショオ」の連中とこれから「すず本」へ繰り込むのだという、はなはだ迷惑だが、行きがかり上俺だけ外すという訳にもゆかない、皆とつるんで「すず本」へ押し上ったが、相方のジャネットが邪魔で仕様がない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜王様とつるんで「巴里」を立ち出た以来のことを思い起すと、事件は波瀾に波瀾を重ね、さながら一篇の伝奇小説の如くでもある。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍とつるぎと巨大なる石塊とりて敵陣の　540中を貫きヘクトール、かく勇猛にあらべども、テラモニデース・アイアスと戰ふことを敢てせず、（＊優れるものに手向ふをヂュウスは彼に喜ばず）543　此一行いづれの寫本にも無し。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "雛の顔鼻無きがごとつる／＼と三月五日　家庭俳句会。",
              "citation": {
                "source": "五百五十句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだらう君、そこで藤吉郎が、テレ隱しに、一さし舞つて、舞ひながら惡友共とつるんで外へ出るとしたら‥‥。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ驚いたのは目くされの坊主で、大将もろとも討死の覚悟か目をつぶつて死に身にぐたりとつるさがつたなりどうしてもはなれない。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "かたちとつるつるの手ざわりのせいだろう、僕がこの電話の受話器を持つと、三度に一度は滑らせて落としてしまう。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い仲間とつるんでいる。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
