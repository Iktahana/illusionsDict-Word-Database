[
  {
    "uuid": "9cc3d03f-ef0c-55ef-82d3-89e9fee23eef",
    "entry": "通り物",
    "reading": {
      "primary": "とおりもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
