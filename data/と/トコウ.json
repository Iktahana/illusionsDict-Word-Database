[
  {
    "uuid": "b52b7952-e1a5-513f-94b4-01dee3c8ff97",
    "entry": "渡航",
    "reading": {
      "primary": "とこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
