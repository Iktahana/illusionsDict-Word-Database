[
  {
    "uuid": "ef3fd83a-81cb-5799-9c8d-0e72a19f8759",
    "entry": "十日夜",
    "reading": {
      "primary": "とおかんや",
      "alternatives": [
        "とおかや"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Harvest festival held on the night of the tenth day of the tenth month (to send the rice paddy gods back to the mountains after harvest)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "妹でございます、姉伊都子ことは昨年の暮ふとした病気にかゝり、十二月二十日夜永遠にかえらぬ旅に立ってしまいました。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこの一週間ばかり旅行して昨十日夜に帰って来ますと、私の机の上に森下氏のお手紙と新青年の六月増大号と、「アヤカシノゴセイコウヲシュクス○トシ○タミ○フミ○チヨ」という岡山発の電報がほかの手紙とゴッチャになって乗っています。",
              "citation": {
                "source": "所感",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "をとこがをなごが水がせゝらぐ灯かげ（雑）　三月二十日夜の明けきらないうちに起きて散歩、佐波川はおもひでのしづけさをたたへて鶯も啼いてゐる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十日夜来の雨は霽れて、空の色が身にしみる、雪の浅間の噴烟ものどかだ。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "文淵堂所蔵の一｜戸隆次郎著「榎本武揚子」に拠れば、武揚等の諸艦は「十一月二十日夜に乗じて函館を距る十里なる鷲木港に入る」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尊大君事十一月十日夜半より御発病（中略）、同月十七日遂に御遠行之趣（中略）、御愁傷之程奉恐察候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日夜兵火｜息む。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月三十日夜栄太郎　　平野様　　　　　侍史",
              "citation": {
                "source": "平野義太郎宛書簡",
                "author": "一九三二年四月三十日",
                "note": "青空文庫"
              }
            },
            {
              "text": "――昭和十四年九月十日夜――",
              "citation": {
                "source": "きもの",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "気温はこの山行で十一月三十日夜常念の小屋で零度（降雪中）翌十二月一日大天井岳頂上で零下五度（晴、強風）であった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十一日（金曜）　二十日夜、まつの留守。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十月十日夜）　いよいよ報告をつゞらねばならぬ。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十日夜　きょうははじめて生駒山を越えて、河内の国｜高安の里のあたりを歩いてみた。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に二十日夜が最もよく一舟五十余尾を上げたのさえあった。",
              "citation": {
                "source": "夜の黒鯛",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十日夜戌の刻堂内の明を消して、生贄にする僧（貞云、名所図絵に俗とあるは古い式で、後には僧を以て之に代へたものか）を座せしめ、衆僧も暗中に居て、代る／＼陀羅尼や神呪を大声に唱へて、彼の僧を一時祈り殺す。",
              "citation": {
                "source": "憑き物系統に関する民族的研究",
                "author": "その一例として飛騨の牛蒡種",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時余輩は現存の法隆寺金堂・塔婆・中門等の古建築物に関して、該寺が天智天皇九年庚午四月三十日夜半の大火に一旦焼失し、その後いつの頃からか再建築に着手して、奈良朝の初め頃までにはほぼ完成を見るに至ったものであることの前提の下に、所謂非再建論に対して素人の無鉄砲なる駁論を発表したのであった。",
              "citation": {
                "source": "法隆寺再建非再建論の回顧",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "吟草の巻首に録せられた絶句に「十二月二十日夜霊岸港ニ泊ス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十日夜より二十八日までニューヨーク滞在。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日夜十時、日本郵船会社汽船安芸丸に乗り込み、翌朝四時出港す。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "その首藤が捨てた新聞には、「別府市××町では、三十日夜、町内への永年の功労者に賞状が贈られ、その一人、太田泰造さん（六九歳・大阪府出身）は、……」と書かれていた。",
              "citation": {
                "source": "湯けむり",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月二十日　〔市ヶ谷刑務所の顕治宛　豊島区目白三ノ三五七〇より（はがき）〕　四月二十日夜。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはね、島田から送って下すった炭が十俵無事三十日夜到着。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月十日夜　〔巣鴨拘置所の顕治宛　駒込林町より（封書）〕　九月十日　いまは、夜の九時。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十日夜　〔巣鴨拘置所の顕治宛　駒込林町より（鶴ヶ岡八幡宮の写真絵はがき）〕　さきほどすぐ事務所に電話して切符のことをたのみ、どうにかして寝台も買えたら買うようたのみました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "水野主馬はもと結城藩老、天狗の携ふる所となれる者、土浦より結城を志し、行々土兵に苦しめられつゝ、十日夜九つ時、猿島郡新和田にて捕へらる。",
              "citation": {
                "source": "天狗塚",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十九日朝、芥川夫人午後芥川方ニヨバレテユク――二十日夜、青池ト大塚　青池ニノマス　青池は芥川の親戚、をぢと姪との間に生れて、生母を姉さんと言つてゐた男、畫かき志望であつたが若くて死ぬ。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座裏、東宝を出て国民の方へ行く角に、すき焼のネオンが二階に出てる、感じのよさゝうなうちが出来たのを前から狙ってたが、二十日夜行ってみる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の初めの案では、二十九日の興行を一日延して三十日夜の総上りを献金したいつもりで、その間づっと宣伝するからウンと来ると思ってゐたのだが、都合で今日にされ、座へ行ってみると大満員とまで行かない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその代りに十月の十日夜と名づけ、ちょうど中国地方のイノコヅキと同じに、藁の束をもって地面を叩きまわる子供遊びがあったのである。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌の文句は、とおかんや、いいもんだ、朝そばきりに昼だんご、夕飯食ってひっぱたけまた、とおかんやの藁鉄砲、餅を食ってひっぱたけ　武州｜大里吉見辺にも同じことをするという。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
