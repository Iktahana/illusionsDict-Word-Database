[
  {
    "uuid": "ce1aaaca-c090-596b-a6fb-cc84785742bd",
    "entry": "と言わず",
    "reading": {
      "primary": "といわず",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
