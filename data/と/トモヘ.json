        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "見苦しき者どもをば皆海へ入れて、船の掃除召され候へ』とて、掃いたり、拭うたり、塵拾ひ、艫舳に走り廻つて手づから掃除し給ひけり。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海凪ぎぬ、朝ぼらけ潮もかなひぬ、艫舳接ぎ、大御船、御船出今ぞ。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "齊明天皇の御世に、百濟援助の目的で戰艦を造つたが、折角出來上ると間もなく「艫舳相｜反」といふ有樣で、實用に適せなかつたといふ（『日本書紀』卷廿六）。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "艫舳、廻旋することを得ず。",
              "citation": {
                "source": "金将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "山賀兵藤次秀遠は、九州一の強弓といわれる勇士だったが、先陣を承まわると、五百余人の精鋭をつのり、舟の艫舳に立たせて、五百の矢を一度に源氏に向って射かけさせた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第十一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の士官が、ともへ帰ると、ボースンとナンバンとが呼ばれた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくして私達は再び私の腰かけていた漁船のともへ返りました。",
              "citation": {
                "source": "Ｋの昇天",
                "author": "――或はＫの溺死",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ちっともへんじゃない。",
              "citation": {
                "source": "雌に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その谷がやがて、ともへ行くと推進器は空中でから回りをする。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ともへと出かけた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆にそういってくれよ、いいかい」彼は、ともへと帰って行った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の知人に夜釣りに行つたら、吾妻橋より少し川上で、大きなすつぽんが船のともへ、乗りかかるのを見たと云ふ人あり。",
              "citation": {
                "source": "雑筆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「区々の微功も相立てて少しくその罪もあひ償ひたく日夜焦慮苦心まかりあり候へども庸劣にして」ともへりくだった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はなんだかあの池のことが気になり、奇怪な太湖石のこともへんに眼について、あの時、窓からのび上がって、庭の方を覗いていた。",
              "citation": {
                "source": "碑文",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「病気らしい……そんなのは、ちっともへんじゃない。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「出ではしり去ななともへど」というあたりの、朴実とでも謂うような調べは、憶良の身に即き纏ったものとして尊重していいであろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前のようにちゃんとおとなしくなり、いうこともへんではなくなりました。",
              "citation": {
                "source": "霊魂第十号の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "お姫さまはなんともへんじをしませんでしたが、ほんのちょっとうなずいてみせました。",
              "citation": {
                "source": "十二人兄弟",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さま　あなたはなにしていらっしゃるおやすみですか　おめざめですか　わかいものがなんともへんじをしませんので、カモがまたいいました。",
              "citation": {
                "source": "森のなかの三人の小人",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前がぜひともへえつくばらなけりゃならねえんなら、手前の亭主や子供のためになるようにへえつくばれ。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれはちっともへんなことではない。",
              "citation": {
                "source": "自然の恵み",
                "author": "――少国民のための新しい雪の話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたつめ　なんともへんてこな絵づらのご一行がほとりにお集まり――羽を引きずった鳥さんたちに、毛がぴたーとなったむくじゃらたち――みんなずぶぬれで気持ち悪くていやな気分。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "稽古やめの合図があった時には、さすがに二人ともへとへとにつかれていた。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ずっとかいている歴史的なものを一貫してゆくことが、チビチビ月評より遙にまさる自他ともへの勉強ですから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともへびは、とかげのようにちょいちょい出っくわしはしませんでした。",
              "citation": {
                "source": "百姓マレイ",
                "author": "フョードル・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年「運、鈍、根」などといって、いかにも商人出身の実業家らしい体得を自他ともへの箴言としていたが、彼にもそうした信念を確めるだけの修業時代があったのである。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランシスが一声号令をかけると、二人の看守はいっそうきつく囚人を掴み、半ば導くように、半ば追いやるようにして、なんともへたくそに階段を上がらせた。",
              "citation": {
                "source": "絞首刑",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中はまんご末代みろくの船がつゞいたァともへには伊勢と春日中は鹿島のおやしろありがたや息栖おもりはこがね社壇うてかゞやくうしろにはひよき（清き？",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちはやふる神々をいさめなればみろく踊のめでたしまことやら熱海の浦にみろく御舟が着いたとよともへには伊勢と春日の中は鹿島のおん社　云々　他にもまだ色々の歌はあるが、鹿島踊というからには是が元歌であったろう。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
