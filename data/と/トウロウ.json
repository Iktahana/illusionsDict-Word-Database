[
  {
    "uuid": "64483ab1-8a9d-5501-93e3-b4dac2a16206",
    "entry": "登楼",
    "reading": {
      "primary": "とうろう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
