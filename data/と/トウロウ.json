      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "climbing a tower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "図に乗ってまくし立てるようだが、登楼して、おいらんと二人でぐっすり眠って、そうして朝まで、「ひょんな事」も「妙な縁」も何も無く、もちろんそれゆえ「恋愛」も何も起らず、「おや、お帰り？",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯八の諜報に依ると、雲水僧は登楼して以来、普通の遊客と少しも違わぬコースを取った。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鑑定は適中して新宿の伊賀屋といふ店へ登楼した一人の客が右の小指に火傷をしたと云つて、相方のおせんと云ふ女郎から山崎の守符を借りたことが判つた。",
              "citation": {
                "source": "赤膏薬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ朝まで客は拾えないし、それにその日雨天のため花火は揚らなかったが、飛田遊廓創立二十周年記念日のことであるし、何んぞえゝことあるやろと登楼をすゝめた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論断ったが、十八にも成ってと嘲けられたのがぐっと胸に来て登楼った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で聞きゃ、ある時も、結婚したての細君を連れて、芳原を冷かして、格子で馴染の女に逢って、（一所に登楼るぜ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは飛田一の家やぜ」　どうせ朝まで客は拾えないし、それにその日雨天のため花火は揚らなかったが廓の創立記念日のことであるし、なんぞええことやるやろと登楼を薦めた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん断ったが、十八にもなってと嘲られたのがぐっと胸に来て登楼った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、わざと汚ない楼をえらんで、登楼した。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "登楼の念切なるを感じてゐたが、馬に乗り、枯草色のシヤツを着け、風を引きかけてゐる身の大事をとつて小屋の引籠からつかみだした虫臭いほんとうの赤毛布をマントにしてゐる姿を思ふと、いつになつたらあの門を潜れるかと歎ぜられた。",
              "citation": {
                "source": "水車小屋の日誌",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二去国三巴遠登楼万里春傷心江上客不是故郷人　あゝ、もういよいよ春だ。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、こつそりと村境ひのターバンなどへ登楼して、左り団扇をつかひながら、わたしはメートルをあげた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてどこというあてもなく、ぶらりぶらりと二廻りしてしまったのが丁度四ツ半下り、――流連客以外にはもう登楼もままならぬ深夜に近い時刻です。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小格子女郎のところへなぞはどう間違ったにしても、舞い降りて下さる筈もないお直参の旗本が、それを向うから登楼したので、悉く思い上がりながら仇めかしく両頬を紅にぽっと染めて、ふるいつくように言いました。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、彼の目の先にちらついたのは、何と彼は、吾ながらあきれたことには、仕事や生活に対する奮発心などといふものではなくつて、帰郷してゐるうちに旧い友達に伴れられて遊里へ登楼した折に幾度か見たところのひとりの若い芸妓の姿であつた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その頃清と一処に初めて町の料理屋へ登楼して、終ひには一家に悶着を起させるに至つた程の或る失敗をしたことがあつた。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早春登楼」の詩に「蘇暄身漸健、楼上試攀躋」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう半年も前のことやよつて、今でもそこに居やはるかどうか知れへんけれど、家へ来る牛乳屋はんが遊びに登楼らはつたら、そしたらその敵娼はんが、どうどツしやらう、お信さんどしたいふやおまへんか。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――浮舟楼でも、妓達の肉親から、出征者を出すものがあると、得意になつて、妓達は、登楼の客にふいちやうした。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿の浮舟楼にも、冨勇の思ひ出をしのんでは時々登楼した。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月の十日ごろまでは来たが、その後は登楼ことがなくなり、時々｜耄碌頭巾を冠ッて忍んで店まで逢いに来るようになッた。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウセ登楼などの出来そうな柄でない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "また吉原や深川や品川へ登楼もする。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、私は他の人の如く多くの酒も飲まぬから、料理屋へ行くとか登楼するとかいうことは、附合いなら別段、自動的には余りせなかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田へ着いた日直に外宮内宮を参拝して、妙見町に止宿したが、その晩奮発して、古市へ登楼した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ好いたらしい若い衆だと思うと見ぬ振をしてじろり／＼顔を見るもので、男の方では元より名指して登楼るくらいでげすもの、疾くに首ッたけとなって居るんでございます。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら日本軍がやって来たって、今度の北伐軍の前には、牛車に向かうとうろうだよ、と笑った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅馴れぬ旅行者のように、早く駅前へ出ようとうろうろする許りである。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私という若い渡り鳥が、ただ東から西、西から東とうろうろしているうちに老いてしまうという主題なのです。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "房州石の安物のとうろうではあるが、一対こわれもせずにあった。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
