    "definitions": [
      {
        "index": 1,
        "gloss": "stoppage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "石楠花の群落が一時途絶えて、私の歩みは御庭へと移された。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルが段々調子を上げ、全で余韻がなくなるほど絶頂に達すると、一時途絶えた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云つても、収入が途絶してしまつてゐるのだから、その範囲は極めて狭く局限されるのだつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして話の途絶えた間、北海の浪の音を聞いていると、私はこの老婦人と一緒に永遠に四郎を待つ気持になれた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉時雨は、一しきり盛りになって山の翠も揺るるかと思われる喧ましさ、その上、あいにくと風がはたと途絶えてしまったので周囲を密閉した苫船の暑さは蒸されるようです。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "興味が弾まないままみち子は来るのが途絶えて、久しくしてからまたのっそりと来る。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またひとしきりどかどかと続いて来るかと思うとまたぱったり途絶えるのである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく人の途絶えたときに、仏になった老人の未亡人が椅子に腰かけて看護に疲れたからだを休めていた。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一瞬間、それらの物音が途絶えてひつそりとすると、私の頭上の何處かで、窓を開けるらしい音がするのでした。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の眞晝近く、地上のすべての事物は、人も、樹木も、家屋も、電柱も、また砂にまぎれる小蟻さへも、息を途絶えさすやうな劇しい暑さに疲れ果てて、ぢつと聲をひそめて立つてゐるやうに思はれるその眞晝近く、私は理科大學研究室の窓際の机に向つて、一所懸命に蘭科植物の葉色素研究の爲めに顯微鏡を覗き込んでゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遼陽城頭夜は更けて‥‥」と、さつきまで先登の一｜大隊の方で聞えてゐた軍歌の聲ももう途絶えてしまつた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だら／＼流れ出た血が所々途絶え、また、所々、点々や、太い線をなして、靴あとに添うて走っていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足あとは血を引いて、一町ばかり行って、そこで樹々の間を右に折れ、左に曲り、うねりうねってある白樺の下で全く途絶えていた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、一時途絶えたかと思うと、また、警戒兵が気を許している時をねらって、闇に乗じてしのびよってきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼の自由になる金が途絶えた生活は續けられて行つた。",
              "citation": {
                "source": "奎吉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "座が白けて、しばらく言葉が途絶えたうちに所在がないので、唄うたいの太夫、退屈をしたとみえて、顔の前の行燈を吸い込むような大欠伸をしたから。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りも殆ど途絶えた。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく途絶えていた鳥の声がまた聞こえる。",
              "citation": {
                "source": "病院の夜明けの物音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗組員は全部墜死してしまい、しかも事故の起こったよりずっと前から機上よりの無線電信も途絶えていたから、墜落前の状況については全くだれ一人知った人はない。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りはまったく途絶えていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「哲は」「哲はな」　兄の声はそこで途絶えてしまつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して人通りが途絶えてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれが今のように、全く途絶してしまうと、こどものうちから見慣れている眼にはまるで窒息しつつある怪物のように思えて、慧鶴には、惨たらしく感じられた。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時は、時々ばったりと往来が途絶えて、その時々、対合った居附の店の電燈｜瓦斯の晃々とした中に、小僧の形や、帳場の主人、火鉢の前の女房などが、絵草子の裏、硝子の中、中でも鮮麗なのは、軒に飾った紅入友染の影に、くっきりと顕れる。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこ、何、お茶、お茶、どこへお茶を買って来、」　とちょっと途絶える。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と俯向いて一寸言が途絶え……「やがて、其の後から、私は身體を載せられて、釣臺で門を出ました。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りものでもするらしい、人足が麻布の空まで途絶えて居る……　所へ、貴女がおいでなすつたのに、恁うしてお出合ひ申したんです。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お約束でもあつたんだと――何うにか出來さうなものですがね、――又不思議に人足が途絶えましたな。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、聲が途絶えて、チリ／＼と鐸が鳴つた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
