    "definitions": [
      {
        "index": 1,
        "gloss": "attaining salvation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "阿那律、先に容貌｜好きも、既に得道の後は顔色常に倍せり。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の穢濁を断じて聖浄の楽土に住む得道出家の身にてありながら、徒にただ肉を追う餓鬼畜生の類なのだ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や、民のほねをくだける白米、人の血をしぼれる如くなるふるさけを、佛法華經にまいらせ給へる女人の、成佛得道疑べしや。",
              "citation": {
                "source": "尼たちへの消息",
                "author": "――よく生きよとの――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄土其他の念仏に伴ふ、成仏得道の過去生譚をも語つた。",
              "citation": {
                "source": "組踊り以前",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の既成の諸宗は不了義の権経にもとづく故に、ことごとく無得道である。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの一遍上人は二人の妾の嫉妬を夢に見て道心を起し、出家得道したところが、二人の妾も同じく出家して上人に従った。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを厳格に申しますならば、ひとり課役忌避の非人法師ばかりでなく、いやしくも公民権を失ったものはすなわち非人で、出家得道して僧侶となったものの如きも、家を出たものすなわち国家の公民でないという理由から、やはり非人と言ってよいのかもしれませぬ。",
              "citation": {
                "source": "融和問題に関する歴史的考察",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終このようであれば、出離得道するだろうと思う。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは出離得道のためには一切無用だと思う。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし自分が入宋求法の志を遂げて、一分の悟りでも開いたならば、たとい一人の人の迷情に背いても、多くの人の得道の因縁となるであろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して「もし今｜生を捨てて仏道に入りたらば、老母はたとひ餓死すとも、一子をゆるして道に入らしめたる功徳、豈得道の良縁にあらざらんや」（同上第三）。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとひ高堂大観玉をみがき金をのべたりとも、これによつて得道のものあるべからず。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして女流もまた男子と同じく得道することを説いた後に、淫欲の誘惑として女を斥けるものを痛罵している。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また曰く、「六道に輪廻して苦楽の二報を受けて、生死窮まりなし」と）牟子理惑論云、魂神固不滅矣、但身自朽爛耳、身譬如五穀之根葉、魂神如五穀之種実、根葉生必当死、種実豈有終亡、得道身滅耳。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの死後の極楽地獄、成仏得道を説くがごときも、またただ方便に過ぎざるか。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、仏教はかえってこの積極的道理によりて、成仏得道を説くものなり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教のいわゆる自力、他力の二宗も、ひとたび妖怪学によりて仮怪の迷雲をはらい去りてのち信念得道すべく、教育のいわゆる知育、徳育も、ひとたび妖怪学によりて真怪の明月を開ききたりてのち開発養成すべし。",
              "citation": {
                "source": "妖怪学講義",
                "author": "緒言",
                "note": "青空文庫"
              }
            },
            {
              "text": "上總屋は小さい孫二人をその日｜新發意（自己｜催眠になる一種の得道）にするつもりで、晴着を着せて土藏の中へ呼んだのだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "隱し念佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は七人であるとはいえ、くっきょうのおとなどもで、食人鬼のごとくどうもうなる暴漢である、味方は数こそ多いが、筋骨いまだ固まらざる十六歳に満つや満たずの少年たちである、これを思うと、だれもみな一まつの不安を感ぜずにはおられなかった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の言のごとくどうでもよい、放任せよというは怪しからぬ」　という人もある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
