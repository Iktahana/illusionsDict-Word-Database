[
  {
    "uuid": "623c1145-a0e5-54fa-96b8-d3c8797cd933",
    "entry": "俗称",
    "reading": {
      "primary": "ぞくしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "common name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○さんざいとは綾瀬川の隅田川に合するところの南の岸を呼ぶ俗称なり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の陸軍では非職のことを「げじげじ」という俗称が行なわれていた。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "是仏の俗称は斎藤権右衛門であった」と云うのである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸書にこの人の俗称を源之助と書してあるが、あるいは後に改めたものか。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "『国史補』には四指のを天虎五指のを人虎と俗称すと出づ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリ版という俗称は、この音から生まれたのでしょう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のゐる寄生木も隣りの怒山も、その他五つの字名の小区域と共に竜巻村といふものゝ中の小字であり、俗称であつて、登録された名称ではないのです。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが邦も竹林などに蛇夥しく聚まる事あり、蛇の長競べと俗称す。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "因って右の二城とも白米城と俗称す（『斐太後風土記』十一、『三国地誌』三九）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本で馬糞石など俗称し、稀に馬糞中に見出す物で予も数個持ち居る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖縄首里の人末吉安恭君二月号に載せた予の不毛婦女に関する説を読んで来示に、かの辺りで不毛をナンドルー（滑らか）と俗称し、少し洒落ては那覇墓と唱う、琉球の墓は女根に象る、普通その上と周縁に松やうず樹｜芒等を栽え茂らす、しかるに那覇近所の墓に限り多くは樹芒少なく不毛故の名らしい。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは支那で羔子と俗称し、韃靼の植物羔とて昔欧州で珍重された奇薬で、地中に羊児自然と生じおり、狼好んでこれを食うに傷つけば血を出すなど言った。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに和漢とも後には老いたる豕も本は子であったから猪、イノコと唱えたので、家に畜う家猪に対して、野生の猪を野猪また山猪、和名クサイイキ、俗称イノシシという。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダーリヤ　白井博士教示に天保十三年初めて輸入され、初めは蘭名ラノンケルで通用したが、葉花共にやや牡丹に近いゆゑ天竺牡丹と俗称したと、舶上花譜に出づと。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗称｜白縫のお芳、窃盗きんちゃっ切りの罪重なるをもって四月三日死罪に処せられしうえ梟首獄門。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十軒店を左に折れて俗称願人坊主の小路といわれた伝右衛門横町、その横町の狭い路地をどんどん奥へはいっていくと、奇怪です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "目の下二尺の鯛が釣れようと、三年の鱸が食いつこうと、あるいはまた間違って糸｜蚯蚓ほどの鮠（註に曰く、ハエをハヤというは俗称なり。",
              "citation": {
                "source": "軍用鮫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ俗称の蛙がゐると見える、いつたい何んな蛙の謂なのか――と私は、読みかけてゐた本を顔の上に伏せて、蚊帳のなかで耳をそばだてた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィクトリヤは俗称トリアと云い、代々日本人の一番世話になるところだとの事だ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この船は、「｜大西洋の真珠」と俗称されるアゾウレスとマデイラの南島から、材木やバナナを積んでくる。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "子賛名｜襄、俗称｜久太郎なり。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「男子賛亦助談、子賛名襄、俗称久太郎なり」の数句が、故人を叙する語に似ぬやうに覚えたからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "福田氏所蔵の「福山風雅集稿本」の詩人姓名の部に、「三箇知雄、字子光、号箕洲、俗称角兵衛」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞白は本姓磯野、名は元亮、俗称勝五郎である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に上顎門上歯が幾分前に出て居りしや否や、下顎犬歯は普通人に比して長きや否や、犬歯の俗称鬼歯と称するものなりや否や。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "両国でも本家の四ツ目屋のあった加賀屋横町や虎横町――薬種屋の虎屋の横町の俗称――今の有名な泥鰌屋の横町辺が中心です。",
              "citation": {
                "source": "江戸か東京か",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨屋町とは、南北に通っている町で、俗称であるが、それは、和泉町から本町へかけて、丁度、今の公設市場のように、一切の食料品店が、その辺に集っていた。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等のグループは、私らの家のあった所の崖下、俗称野麦と称した所にいたらしいが、機があったら、私は彼と一緒の高座へ上って「荒木又右衛門」でも弁じてみようと思っている。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戎橋は、戎橋や」　と、云っても、大抵の人には、いいであろうが、この名は、俗称で、本当の名は、別にあるのである。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
