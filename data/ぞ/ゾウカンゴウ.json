          "literary": [
            {
              "text": "（「探検世界」明治四〇年一〇月増刊号）",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十五年新春増刊号）",
              "citation": {
                "source": "ヂュパンとカリング",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十四年夏季増刊号）",
              "citation": {
                "source": "ポオとルヴェル",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十四年新春増刊号）",
              "citation": {
                "source": "歴史的探偵小説の興味",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十五年夏季増刊号）",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当世書生気質」を収録した『太陽』増刊号の赤いクロースの厚い菊判も、綴目がきれて混っている。",
              "citation": {
                "source": "本棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（日本に於ける叙景詩の発生は、雑誌「太陽」七月臨時増刊号に書いたから、ここには輪郭だけに止める――全集第一巻――。",
              "citation": {
                "source": "歌の円寂する時",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "『週刊朝日』春季増刊号　昭27・３・24",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『戦旗』一九三〇年三月臨時増刊号に発表）",
              "citation": {
                "source": "さらわれた兄よ",
                "author": "――残された妹の歌――",
                "note": "青空文庫"
              }
            },
            {
              "text": "立止ると……兵卒達の眼は一斉に週番司令を睨んだ（『プロレタリア文学』一九三二年四月作品増刊号に発表）",
              "citation": {
                "source": "動員令",
                "author": "波立一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（『文芸戦線』一九二九年十一月臨時増刊号に今村桓夫名で発表）",
              "citation": {
                "source": "プチロフ工場",
                "author": "今村恒夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十一年七月中旬に水彩風景画家の大下藤次郎君は、日光から尾瀬沼に大規模の写生旅行を試み、多数の収穫を齎し帰りて、其中の幾点かは文部省の展覧会に出品され、其主宰する雑誌『みづゑ』は、臨時増刊号「尾瀬沼」を発行した。",
              "citation": {
                "source": "尾瀬の昔と今",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画雑誌の秋の特別増刊号として、その物語だけで一冊を作ることを、その担当者は映画雑誌を発行している出版社に提案した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような内容で、秋の特別増刊号を作ることが、六月のうちに正式に決定した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "増刊号はそれに合わせた企画として成立した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "宣伝部の優子の担当者は島村冬彦に連絡をつけ、増刊号への写真の提供を依頼した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集部の担当者に紹介された島村は、自分とヨシオが中心になって増刊号を作ることを提案した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "増刊号のページ数に合わせて、使用する写真とその数がほぼ決定した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月の第四週に、その増刊号は出来あがった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシオの部屋で、ふたりはそれぞれに、増刊号の出来ばえを検討した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "増刊号を一冊、ヨシオはホノルルの節子に送った。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "店頭にならんだその特別増刊号は、売れ行きが良かった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "発行もとの出版社は、増刊号の延長として日比谷優子の写真集を発想した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "増刊号を担当した編集者が、上司である男性の社員とともに、冬彦に優子の写真集の計画を伝えた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間だってもっとあるし」　増刊号をヨシオは直子にも進呈した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨシオと冬彦が増刊号を作っているあいだ、優子は撮影に時間を取られたままだった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその五拾銭で、ある週刊雑誌の増刊号と※パンを買った。",
              "citation": {
                "source": "遁走",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
