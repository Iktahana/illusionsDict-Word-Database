    "definitions": [
      {
        "index": 1,
        "gloss": "stolen goods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "アリストテレースなどは贓品の蔵を建てた男である。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄谷の響、神通の流の音は、ひとしきりひとしきり脈を打って鳴り轟いて、堆いばかりの贓品は一個々々心あって物を語らんとするがごとく、響に触れ、燈に映って不残動くように見えて、一種言うべからざる陰惨の趣がある。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにぶんにも証拠とすべき贓品がないので、容易に判決をくだすことが出来なかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼の贓品　陝西のある村に老女が住んでいた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれらのたずさえて来た諸道具はみなほんとうの金銀宝玉を用いたものであるので、老女はそれを官に訴え出ると、それらは一種の贓品と見なして官庫に没収された。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼の贓品という意である。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "スパイダーはサディのアパートの裏手にある自動車庫の道具箱に贓品を仕舞い込んだ。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此のシンプソン君のお蔭で、自動車庫から贓品と棍棒を発見したよ。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体手といふものは、よく汚れるもので、マコウレエの談話によると、英吉利のある鍛冶屋は、泥棒に頼まれて金物の贓品を火に溶かす折には、手で触つては汚れるからといつて、態と長火箸を使つたといふ事だ。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、やつと、私と同じ候補生の牧田と云ふ男が、贓品を見つけました。",
              "citation": {
                "source": "猿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、まだ無経験だつたので、さう云ふ事は、まるで知りませんでしたが、軍艦では贓品が出ても、犯人の出ないと云ふ事が、時々あるのださうです。",
              "citation": {
                "source": "猿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝石や貴金属の鑑定には、名人だという噂があり、贓品などをも秘密に買って、秘密に売るという噂もあった。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木屋は恐ろしさに顛倒してしまつて、忽ちその贓品を吐き出してしまつた。",
              "citation": {
                "source": "若い僧侶の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し自ら「通がり」となる事の嫌ひな僕は眞に鼠賊が贓品を使用する時のやうな忸怩の情を以つて、事情の許す限り控へ目に之を使用するのみである。",
              "citation": {
                "source": "三太郎の日記　第二",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速、腹心のひょろ松をひそかに呼びよせ、手下の下ッ引を動員して、市中の質屋、古物｜贓品買を虱つぶしにあたらせているが、今朝になっても一向に音沙汰がない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "稲荷の使",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、人通りが少し疎らになると、女はバタバタと店を仕舞って、件の贓品やらガラクタやらを竹籠の中に投り込み、大風呂敷に包んで背負った上、茣蓙を丸めて小脇に、馴れた様子でスタスタと柳原の方へ引揚げて行きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "呪いの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "存分に縛り上げろ、そいつは贓品買ひだ」「野郎ツ」　八五郎が飛び付き樣、滅茶々々に縛り上げたことは言ふまでもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "家搜しをして見ると、藏の中はお觸書にある贓品だらけ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちでも忘れ難いのは、まず第一番に、この四郎の隠れ家を訴人して縛らせた上、女房のお冬を役人の手に渡し、自分は贓品買いの大罪を許して貰って、ぬくぬくと栄耀をつづけている、麹町六丁目の桜屋六兵衛一家。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "存分に縛り上げろ、そいつは贓品買いだ」「野郎ッ」　八五郎が飛び付きざま、滅茶滅茶に縛り上げたことは言うまでもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "家捜しをしてみると、蔵の中はお触書にある贓品だらけ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、人通りが少し疎になると、女はバタバタと店を仕舞つて、件の贓品やらガラクタやらを竹籠の中に投り込み、大風呂敷に包んで背負つた上、茣蓙を丸めて小脇に、馴れた樣子でスタスタと柳原の方へ引揚げて行きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "呪ひの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちでも忘れ難いのは、先づ第一番に、この四郎の隱れ家を訴人して縛らせた上、女房のお冬を役人の手に渡し、自分は贓品買ひの大罪を許して貰つて、ぬく／＼と榮耀を續けてゐる、麹町六丁目の櫻屋六兵衞一家。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巨盜還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "音次郎は相変らず、贓品や抜荷を扱って、大坂から長崎へ、江戸へと移った後を尋ねて、骨にも沁むような艱難が、去年の暮、江戸へ入る一足手前の、神奈川の安宿で、お楽の命を奪ってしまったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お染の歎き",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラッ八の面白そうに動く手に従って引っ張り出されたのは、悉くお奉行所のお触れ書に載った贓品ばかり。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お染の歎き",
                "note": "青空文庫"
              }
            },
            {
              "text": "贓品が五つでも六つでも出て来たら、この私は処刑、家は欠所に決っている。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お染の歎き",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリの御用ずみの贓品をひそかに所持していることに、ぼくは共犯者のそれのような、あの疚しげなスリルと、秘密の悪事に荷担する奇怪な歓びをおぼえたのだ。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "開いてみると、今回の窃盗事件はアルセーヌ・ルパンの指揮の下に行われ、贓品は翌日北アメリカへ向けて送られた。",
              "citation": {
                "source": "探偵小説アルセーヌ・ルパン",
                "author": "EDITH AU COU DE CYGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "挙人老爺は贓品の追徴が何よりも肝腎だと言った、少尉殿はまず第一に見せしめをすべしと言った。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが旨く行かんと乃公の責任になるんだよ」　挙人老爺は大に窮したが、なお頑固に前説を固持して贓品の追徴をしなければ、彼は即刻民政の職務を辞任すると言った。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
