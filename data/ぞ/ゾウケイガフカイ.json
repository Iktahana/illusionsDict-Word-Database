    "definitions": [
      {
        "index": 1,
        "gloss": "well-versed (in)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
