        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――君、佐竹の自尊心の高さを考えると、僕はいつでもぞっとするよ」ビイルのコップを握ったまま、深い溜息をもらした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はぞっとしました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸の外を、桜｜樹立がぐるりと囲む……桜が……しんしんと咲き静まった桜樹立が真夜中に……棟を圧して桜樹立が……桜樹立がしんしんと……私は、ぞっとして夜具をかぶった。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかはすぐそれを呑みこみましたが、その時何だかせなかがぞっとしたように思いました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "えいぞっとする　気味の悪いやつだ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞっと身振いをするほど、著しき徴候を現したのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵卒は、老人の唸きが聞えるとぞっとした。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お心あたりがございますならば、どうぞ教えていただきたいのでございますが……」　その訴えるような声音が一種の恨みを含んでいるらしくも聞えたので、お徳はまた俄かにぞっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この女は水から出て来たのではあるまいかと思うと、気の強い女房も俄かにぞっとしたのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の起ったあとを見ると、そこの畳の上は陰ったように湿れているので、かれは又ぞっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房はぞっとして鶏肌になった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時にはわたくしもぞっとしました」　恐怖におののいている其の声にも顔色にも、詐りを包んでいるらしくないのは、多年の経験で半七にもよく判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲惨な死を遂げた歌女代の魂が黒い蛇に乗り憑って邪慳な養母を絞め殺したのかと思われて、半七もぞっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "大師匠が蛇に殺されたと訊いた時には、わたくしは思わずぞっとしました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古池の底には大きい鯰の主が住んでいると、一人の女が教えてくれたのでお蝶はぞっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "一郎もなぜかぞっとしました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああさっきのお百姓がものの間違でも故道には蛇がこうといってくれたら、地獄へ落ちても来なかったにと照りつけられて、涙が流れた、南無阿弥陀仏、今でもぞっとする。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はぞっとして面を背けたが、婦人は何気ない体であった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は、その下蔭は矢張こんなに暗かったか、蒼空に日の照る時も、と然う思って、根際に居た黒い半被を被た、可愛い顔の、小さな蟻のようなものが、偉大なる材木を仰いだ時は、手足を縮めてぞっとしたが、（父親は何うしてるだろう、）と考えついた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてもぞっとする話である。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やけどと思って見るとぞっとするくらいであるがレッキスとして見れば実に美しい。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたものが自分の皮膚にとりついていると想像すればぞっとするのは当然かもしれない。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えただけでも、背中に冷水をかけられたように、ぞっとして、息がつまる。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とやはり大声で答えて、それから、またじゃぶじゃぶ洗濯をつづけ、「酒好きの人は、酒屋の前を通ると、ぞっとするほど、いやな気がするもんでしょう？",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、戸外でポチが、ばたばたばた痒さに身悶えしている物音に、幾度ぞっとさせられたかわからない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、ほんものがこの百花楼へひょっくりやって来たら、と思うと、流石にぞっとするのであった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い出すさえ、ぞっとする。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一句として見ても、また前句との付きぐあいから見ても、どうにもあまりぞっとしないと思われる句が七部集の中でもたくさんにある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
