[
  {
    "uuid": "11012891-8204-5601-af37-cee67a9aa588",
    "entry": "俗人",
    "reading": {
      "primary": "ぞくじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "person with low tastes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "友人の目にも、俗人の目にも、ともに大人しい人といふ印象を与へて、富永は逝つた。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弟もやつぱり小心な、そして俗人式でセンチメンタルな奴なんだな。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父も母も自身が関東人式な好いでも悪いでもないといつた素気なさの全然ない俗人であつたために、自分の中にないものは想像出来ないらしかつたのだ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗人とは、物象の有機的要素のみを見るものと。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに俗人と雖も無機的要求をも真に僅を見るなり。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然り俗人もまた欲望あり、希望あり。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣の毒だ、馬鹿だ、などといふのは、私たち俗人の勝手な盲斷に過ぎない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗人の眼より見ればこの予言は外れたりと云う外なかるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質の観念が未開人にもあるのにエネルギーの考えが俗人に通ぜぬのはそのためではあるまいか。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世俗人情に関した理論などはいざ知らず、物理学上の方則は事実を煎じつめて得たもので嘘のあるはずはない。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように、一方では遁世を勧めると同時に、また一方では俗人の処世の道を講釈しているのが面白い。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ほんものの俗人ですね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、きっと俗人なのでございましょう。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その通信欄で言葉を交し、謂わば、まあ共鳴し合ったというのでしょうか、俗人の私にはわかりませんけれど、そんなことから、次第に直接に文通するようになり、女学校を卒業してからは、急速に芹川さんの気持もすすんで、何だか、ふたりで、きめてしまったのだそうです。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この環境の変化に応ずる風俗人情の差異の多様性もまたおそらく世界に類を見ないであろう。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ宗教で、人間超越の見込みがつかず、享楽本位に気持を入れ換えたのなら、いっそ俗人に立ち還って、心置きなくその目的に身を入れたらよさそうなものだと思うのに、慧鶴はそれもしなかったらしい。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "慧鶴は折角、寝ても覚めても思索一途に嵌り込めるようになった心境の鍛錬を俗人との世間咄しに乱されてしまうのは惜しくて堪らなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが本当の仏教が勇ましく私たちに教え勧める処世法であり、先刻の禅僧といえども、この事を体得しなければ俗人に劣ると言わねばなりません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに都会の持つ俗人への魅力もあるわけです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し我々俗人は之をも不思議の一つに数へるのが慣例だ。",
              "citation": {
                "source": "雨夜の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒だ、馬鹿だ、などといふのは、私たち俗人の勝手な盲断に過ぎない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど、いい家庭のお嬢さんよりも、その、鮎の娘さんのほうが、はるかにいいのだ、本当の令嬢だ、とも思うのだけれども、嗚呼、やはり私は俗人なのかも知れぬ、そのような境遇の娘さんと、私の友人が結婚するというならば、私は、頑固に反対するのである。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かういふ坊さんに限つて、中味が浅く薄くて、俗人とちつとも変らぬ根性を持つてゐることを、良寛さんはよく知つてゐた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに天才の煩悶と、深い祈りがあるのであろうが、僕は俗人の凡才だから、その辺のことは正確に説明できない。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何せもう、四十年も昔の事で、決して、そんな、ごまかす積りはないのですけれども、私のような俗人のたわいない記憶など果してお役に立つものかどうか。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は俗人のせいか、あまり高尚な風景や詩よりも、民衆的な平易な物語のほうが好きです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のような俗人でも、月光を浴びると、少しは sentimental になるようです。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは俗人の極めて凡庸な判断で、私自身さえ興覚めるくらいのものだが、しかし、私などには、どうも、そうとしか思われない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉翁の行脚は、私たち俗人から見れば、ほとんど蕉風宣伝のための地方御出張ではあるまいかと疑ひたくなるほど、旅の行く先々に於いて句会をひらき蕉風地方支部をこしらへて歩いてゐる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、野暮な俗人というしっぽが、いつまでもくっついていて、「作家」という一天使に浄化する事がどうしても出来ません。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
