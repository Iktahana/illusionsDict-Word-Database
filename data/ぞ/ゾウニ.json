[
  {
    "uuid": "0514d719-a9dd-5b6d-9064-fc7b23b01b0c",
    "entry": "雑煮",
    "reading": {
      "primary": "ぞうに",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
