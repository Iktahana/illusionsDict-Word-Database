        "examples": {
          "standard": [
            {
              "text": "医師は造影剤を使い、患者の脳血管の状態を詳しく検査した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "MRI検査では、特定の造影剤を注射することで病変部が識別しやすくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "造影剤アレルギーの有無を確認するため、事前に問診が行われる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "最初は骨の傷害や病気の診断に使われたが造影剤の応用によって透視法がますます広がり胃腸管その他の臓器を見ることができるようになった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
