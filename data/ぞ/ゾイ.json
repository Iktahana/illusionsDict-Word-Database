[
  {
    "uuid": "715ede90-9e33-5b8d-b8c9-4381dd877bd6",
    "entry": "沿い",
    "reading": {
      "primary": "ぞい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞"
      ],
