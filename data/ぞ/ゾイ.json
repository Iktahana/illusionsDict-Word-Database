      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "along (a river, coast, railway, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "水鳥や朝飯早き小家がち　川沿いの町によく見る景趣である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頃、寒月の冴えた夜などに友達の家から帰って来る途中で川沿いの道の真中をすかして見ると土の表面にちょうど飛石を並べたようにかすかに白っぽい色をした斑点が規則正しく一列に並んでいる。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表の河沿いの道路に面した格子窓には風鈴が吊されて夜風に涼しい音を立てていたように思う。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川に沿いて、両側に森がある。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十四日　蒲田より白水谷を渉り、中尾を経て、割谷に沿い、焼岳（硫黄山）の新旧噴火口を探りて、再び上高地温泉に一泊。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十五日　宮川の池に沿いて、宮川の窪を登り、岩壁を直進して、御幣岳の最南峰に登り、各峰を縦走して、二十一日の来路と合し、降路は下宮川谷に入りて、梓川に下り、上高地温泉に帰宿。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　温泉宿から梓川に沿いて、河童橋を渡り、徳本の小舎まで来た、飛騨から牛を牽いて、信州へ山越しにゆく牧場稼ぎの人たちが、行き暮れて泊まるところだ。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の汽車は、箱根｜火山彙を仰ぎ見て、酒匂川の上流に沿い、火山灰や、砂礫の堆積する駿河｜小山から、御殿場を通り越したとき、富士は、どんより曇った、重苦しい水蒸気に呑まれて、物ありげな空虚を天の一方に残しているばかり。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して新道沿いに新しく出来た当世風の二階家などで大損害を受けているらしいのがいくつも見られた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は軌道に沿いながら、林の中の不規則な小径を通った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵は靉河右岸に沿い九連城以北に工事を継続しつつあり、二十八日も時々砲撃しつつあり、二十六日｜九里島対岸においてたおれたる敵の馬匹九十五頭、ほかに生馬六頭を得たり――「どうです、鴨緑江大捷の前触れだ、うれしかったねえ、あの時分は。",
              "citation": {
                "source": "号外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺の昔のままの荒川沿いの景色がこうしたモダーンな道路をドライヴしながら見ると、昔とはまた全く別な景色に見えるから妙である。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "溪沿いに大きな椎の木がある。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は川沿いのある芝地を空風の吹く夜中に通っていると、何者かが来て不意にべろりと足をなめる、すると急に発熱して三日のうちに死ぬかもしれないという。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "礫多き路に沿いたる井戸の傍らに少女あり。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "先月からの雨に荒川があふれたと見えて、川沿いの草木はみんな泥水をかむったままに干上がって一様に情けない灰色をしていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登りつめるときれいな芝を植えた斜面から玉川沿いの平野一面を見晴らす事ができた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は首をすくめ、懐ろ手をしながら、落葉や朽葉とともにぬかるみになった粘土質の県道を、難渋し抜いて孵化場の方へと川沿いを溯っていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どことも覚えない大溝が通っていて小橋がまばらに架り、火事の焼跡に休業の小さい劇場の建物が一つ黝み、河沿いの青白い道には燐光を放つ虫のようにひしゃげた小家が並んでいる。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手より曹長先頭にて兵士一、二、三、四、五、登場、一列｜四壁に沿いて行進。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」正面壁に沿い左向き足踏み。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "（銅鑼の音）左手より、特務曹長｜並に兵士六、七、八、九、十　五人登場、一列、壁に沿いて行進、右隊足踏みつつ挙手の礼　左隊答礼。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」左隊右壁に沿い足踏み（銅鑼）曹長特務曹長（互に進み寄り足踏みつつ唱う）「糧食はなし　四月の寒さストマクウオッチももうめちゃめちゃだ。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺絞りの首抜きの浴衣を着て、赤｜毛布を引き絡い、身を持て余したるがごとくに歩みを運び、下駄の爪頭に戞々と礫を蹴遣りつつ、流れに沿いて逍遥いたりしが、瑠璃色に澄み渡れる空を打ち仰ぎて、「ああ、いいお月夜だ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "海沿いの道を馬車は走った。",
              "citation": {
                "source": "電報",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者は大抵東京の海沿いから渡ったもので、下町らしい気分があり、波の音かと思われる鼓や太鼓が浜風に伝わった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　倉持はそう言って出て行ったが、銀子はちょっと顔を直し、子供に留守を頼んで家を出たが、そこは河に近い日和山の裾にある料亭で、四五町もある海沿いの道を車で通うのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い松原　海岸沿いの国有防風林の松原の中に、托鉢坊主とチョンガレ夫婦とが、向い合わせの蒲鉾小舎を作って住んでいた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨はまだ降るだらうかインキ壺をのぞいてニブリ加減をみよう",
              "citation": {
                "source": "（ツツケンドンに）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その沖の可なり此方と思はれるあたりに、海の中からマストがのぞいてゐる。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
