    "definitions": [
      {
        "index": 1,
        "gloss": "commonly (called, said, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
