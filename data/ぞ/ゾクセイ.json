[
  {
    "uuid": "2bfa86b1-6c4a-5aff-bcae-47bca4b1d18e",
    "entry": "属性",
    "reading": {
      "primary": "ぞくせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
