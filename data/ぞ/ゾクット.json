        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "外へ出ると、生寝の身体にゾクッと寒さが来た。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、ゾクゾクッと寒気がして、オレがたった一人ぼっちで青天井の野ッ原のマンマンナカへ放りだされたような気がして、たよりなくて仕様がねえや。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ウームこのダラシない男を一番怖れてマンジリともしなかったのか」　と考えると、はりつめた気がゆるんだか、バカバカしいと思う代りに、なんとなくゾクゾクッと寒気を感じたのである。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋敷中に、パッと明るく灯が輝いて、婢たちの駈けまわるあわただしい音、よびあう声々――遠く裏庭のほうにあたっては、多人数のあし音、掛け声が乱れ飛んで、たいがいの者なら、ゾクッと頸すじの寒くなる生血の気はいが、感じられる。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩乃様を一眼見て、背骨がゾクッと総毛走った拍子に、スーッと恋風をひきこんじまった。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙な晩だの」「あまり乗せたい乗せたいと思ってるもンだから、気のせいでそんなふうに聞えたのでしょう」「大きに、そんなところだろう」　行きかかると、また、呟くような声で、「もし、駕籠屋さん……駕籠屋さん……」　アコ長は、ゾクッとしたようすで、「こいつアいけねえ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "初春狸合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と言っておいて、ゾクッと慄えあがりました。",
              "citation": {
                "source": "犂氏の友情",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「嫌だねえ」　ゾクッとして、まとまりのつかない顔で立ち竦んでいると、「おい、伝兵衛、ここだ、ここだ」　その声は、どうやら、はるか虚空の方から響いて来るようである。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "源内先生も、すこしゾクッとした顔で、恐るおそる喰い合せの悪い門扉の隙間から、内部を覗いていたが、とつぜん、「おッ！",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピロちゃんも、鮎子さんも、トクべえさんもゾクッとしたような顔で互いに眼を見合わせた。",
              "citation": {
                "source": "キャラコさん",
                "author": "海の刷画",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋はこれから話してあげます」　一座はゾクッとしたような顔で眼を見合せ、さすがに声を発するものもない。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「親分さん、どうぞ」　品をつくって七三に平次とガラッ八を眺めると、背筋をゾクッと不気味なものが走ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はゾクッとしたよ。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
