[
  {
    "uuid": "5ead3fa8-0369-5210-8178-15c1a324a184",
    "entry": "曹司",
    "reading": {
      "primary": "ぞうし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
