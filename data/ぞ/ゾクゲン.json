[
  {
    "uuid": "462faa2b-80a3-5b64-8078-200cca43ad88",
    "entry": "俗言",
    "reading": {
      "primary": "ぞくげん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
