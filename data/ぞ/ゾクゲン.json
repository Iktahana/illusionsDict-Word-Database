    },
    "definitions": [
      {
        "index": 1,
        "gloss": "colloquial language",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "窮すれば通ず、という俗言をさえ、私は苦笑しながら呟いたものであった。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨の国人は驚異の眼を以て、風俗言語の全く異れる蒙古の兵者を迎えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "只早く皇化に浴して風俗言語も改りたる所は、先祖より日本人のごとくいひなし居る事とぞ思はる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "凶くまじなふを俗言にまじくると云も是也。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "シテ見るとこの「ケイヅ」といふ言葉は誇るべき由緒といふやうな事を意味する当時の俗言であつたと見える。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、風俗言語の上に、なほいろいろと変つた事があるやうであるが、よくよく研究せねばわれわれには分らぬ事が多い。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし俗言は耳に入りやすく高談は世に容れられがたし、利害を棄て毀誉を排しもって真理を明らかにせんと欲するものは豈に尋常の熱心ならんや、吾輩は当時の自由論派の世に待遇せられたるを回想して深く感ずるところあり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者の俗言を冷笑するも亦悪辣を極めたりと云ふべし。",
              "citation": {
                "source": "案頭の書",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを要するに、今の紳士も学者も不学者も、全体の言行の高尚なるにかかわらず、品行の一点においては、不釣合に下等なる者多くして、俗言これを評すれば、御座に出されぬ下郎と称して可なるが如し。",
              "citation": {
                "source": "日本男子論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "擬古文を書く初歩の人が使う字引きとして、「雅言俗解」「俗言雅訳」といった種類のものがある。",
              "citation": {
                "source": "辞書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物を読む場合には「雅言俗解」を使い、擬古文を作るときには、いまの語から古い語を引いてくる必要があったので「俗言雅訳」を引く。",
              "citation": {
                "source": "辞書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俗言雅訳」と似ているが、この語に当る字は何かと探すのだから、違う。",
              "citation": {
                "source": "辞書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴屋答問録に、「ほと」は俗言の「あわ（は）てふためく」の「ふた」に同じいとあるのも参考となるだろう。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれなどもその時代の教養人が、遠国にいて、その地方の俗言を取り入れたものだ。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち地中の球根（球根は俗言で正しくいえば襲重鱗茎）から、葉と共に花茎（植物学上の語でいえば※）を抽いて直立し、茎頂に数花を着けて横に向かっている。",
              "citation": {
                "source": "植物知識",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、さような俗言を藉らずとも、先は殿だ。",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "男寝て待つ果報者――それは武士達のあいだには通用しない俗言とみえて、こんなに朝早くから陸続と道場の門をくぐっているのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "カルウは普通の辞典には見えぬが背負うという意味の中古の俗言である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを俗言に喩えていうと、我らが話しをする時に、きっと「何々です」とか「何々だ」とか「何々した」とかいう、この「です」「だ」「した」などいう文字がないと、話につづまりがつかぬ。",
              "citation": {
                "source": "俳句はかく解しかく味う",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「可愛さ余って憎さが百倍」という俗言がある。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　てこでも動かないという俗言がある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　凡下の俗言だが、これは個人の通念的正しさをいっているものだ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もそういう人々の俳諧の定義は勝手放題に弘いもので、心の俳諧以外に形の俳諧だの言葉の俳諧だのを認め、単に用語が今風の俗言でありさえすればもうそれで宜しいようにしていたが、そうして見たところがやはり窮屈な話で、それだけで普く人生の森羅万象、あらゆる境涯・感情を表現するに足らぬのは当り前の話である。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生の言を聞いておると、他人の立場はどうにでもいえる――という俗言が思い出される。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
