        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（明治二十八年十二月「文藝倶樂部」臨時増刊　閨秀小説）",
              "citation": {
                "source": "十三夜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――十三年五月――底本・初出：「新青年　第五巻第十號　夏季増刊『探偵小説傑作集』」博文館　　　1924（大正13）年※底本のコピーは、推理小説研究家の山前譲氏にご提供頂きました。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「探検世界」明治四〇年一〇月増刊号）",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十五年一月十五日發行、女學世界定期増刊　第拾貮卷第貮號所載）",
              "citation": {
                "source": "白瓜と青瓜",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "スチュヂオやアート・ヂャーナルの増刊やマイステル・デア・ファーベや其他各種の美術書は凡そ一千部以上も焼燼した。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「太陽」増刊　明治四十五年六月十三日号）",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も増刊〔『新青年』〕の分を読んで、九月号は雑誌が着くとすぐに旅に出たので、旅先で買って読み、十月号の分も雑誌が着くと真っ先に読んだ。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻頭の『十八時の音楽浴』は「モダン日本」の増刊に発表したものである。",
              "citation": {
                "source": "『十八時の音楽浴』の作者の言葉",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十五年新春増刊号）",
              "citation": {
                "source": "ヂュパンとカリング",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十四年夏季増刊号）",
              "citation": {
                "source": "ポオとルヴェル",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十四年新春増刊号）",
              "citation": {
                "source": "歴史的探偵小説の興味",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「新青年」大正十五年夏季増刊号）",
              "citation": {
                "source": "「マリー・ロオジェ事件」の研究",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十月十八日）（『シナリオ』昭和十三年十一月臨時増刊・山中貞雄追悼号。",
              "citation": {
                "source": "人間山中貞雄",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当世書生気質」を収録した『太陽』増刊号の赤いクロースの厚い菊判も、綴目がきれて混っている。",
              "citation": {
                "source": "本棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の燒打を初として、翌年正月の鳥羽、伏見の戰ひ、其他すべては「文藝倶樂部」の臨時増刊、第九年第二號「諸國年中行事」といふ中に、「三十五｜年前」と題して私は委しく話した事がある。",
              "citation": {
                "source": "兵馬倥偬の人",
                "author": "塚原蓼洲",
                "note": "青空文庫"
              }
            },
            {
              "text": "プロジェクトの成果に励まされたアルブレヒトは、タイニーベーシックにテーマを絞ったニューズレターを、『ＰＣＣ』の臨時増刊として出そうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして臨時増刊は、『ドクター・ドブのコンピューター美容体操と歯列矯正ジャーナル』と名付けられることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "増刊には加えて、「オーバーバイトなしで軽やかに走らせよう（Running Light Without Overbite）」という副題が付けられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初タイニーベーシックにテーマを絞った三冊の臨時増刊として企画された『ＤＤＪ』だったが、ウォーレンは取り扱うテーマをソフトウエアの幅広い分野に拡張して、この雑誌をソフトウエアの空白を埋める共棲の拠点として守り続けたいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「女子文壇」増刊附録）",
              "citation": {
                "source": "佃のわたし",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うづみ火」のこと　陸中國釜石鑛山内水橋康子として懸賞に應募し、明治四十三年十一月號の『女學世界第一卷第十五號定期増刊「磯ちどり」才媛詞藻冬の卷・小説』の初頭に掲載され特賞（賞金十圓）を得、又主幹松原二十三階堂（岩五郎）氏に激勵鞭撻の書簡を送らる。",
              "citation": {
                "source": "うづみ火",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十二年、〈新青年〉特別増刊探偵小説傑作集に発表）",
              "citation": {
                "source": "ドイルを宗とす",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『中央公論』の秋季増刊に出させる様に口をきくと云って下さった。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『文章世界』の増刊をよんで見ると、種々な感に打たれる。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十年の『太陽』の増刊、紅葉の「二人女房」、「当世書生気質」、「浮雲」等をよみ、驚く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、『日本及日本人』の秋期増刊から科学者の事業年表と云うようなものを写しつつ、我々の持つ知識の未だ新らしいものなのに驚く。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
