        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのころ習い始めたメンデルスゾーンの「春の歌」の、左手でひく低音のほうを繰り返し繰り返しさらっていた。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後で考えてみたらそれは人間のスペルマトゾーンの一集団であったのである。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある一つのスペルマトゾーンの運動径路がきわめてわずか右するか左するかでナポレオンが生まれるか生まれぬかが決定し、従って欧州の歴史が決定したと言った人があるが、ある人間のある瞬間に宇宙線が脳のどの部分をどう通過するかによって、その人の一生の運命が決定することもありはしないか。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海濤衝激するところにオゾーンの自らにして發し、又松林密なるところに雷大に下る時オゾーンの發生するが如きは、單に地の氣とは云ひ難いが、此等の如きは最も著しく人の心身に影響するもので、地の理の招き致すところであるから、地の氣といふ中に含まれよう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小品ばかりか難しい曲も弾けることは、要望に応えて、メンデルスゾーンのリートや私のお気に入りを何曲か演奏してくれたことからもよくわかる。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンデルスゾーンにここの風物を――その寂寥、海の動揺、波のざわめき、海鳥の鳴声、風の号泣、大洋の怒涛などを、描いたきわめて美しい音楽、序曲「ヘブリディーズ」（一八三〇）がある。",
              "citation": {
                "source": "沈黙",
                "author": "――神話",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれはしけの場合は、ことにオゾーンが多いにもかかわらず、ほとんど窒息死の瀬戸ぎわまで眠る。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と自問した中に、ベートーベンの楽譜をあげてゐるのに興趣を覚えた故為か、わたしはメンデルスゾーンやモツアルトのレコードを四五枚画板の中へ入れて肩にかけた。",
              "citation": {
                "source": "幽霊の出る宮殿",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ガキのころ、『ミステリー・ゾーン』で、そういうのを見たな。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから堀田は、シヨパンが何うの、メンデルスゾーンの憂鬱な旋律が何うのとかと酒から音楽へ移つて他人も無げな通を振りまきながら次第に濃厚に女に戯れはじめるのであつたが、何うしたわけかやゝともすれば手洗場へ立つて行くのであつた。",
              "citation": {
                "source": "街角",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホモ・ファーベルはゾーン・ポリティコンであり、その故にまたロゴン・エコーンである。",
              "citation": {
                "source": "絶対矛盾的自己同一",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスチャン・ヴォルフやメンデルスゾーンやカントがその尤なるものだ。",
              "citation": {
                "source": "啓蒙の現代的意味と役割とについて",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "オゾーンに充ちた、松｜樹脂の匂う冬の日向は、東京での生活を暗く思い浮ばせた。",
              "citation": {
                "source": "明るい海浜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどその代り、涯しもない大洋と、限りない蒼空と、それから、波も、風も、オゾーンも、元気な水夫達の放埒な生活も、すべてはみな、叔父の若さを養うのには充分であった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず私は、胸をはって、大きな口をあけて、オゾーンを多量に含有している大気を思う存分吸っては吐いて、大地と一つに融け合ったような気持ちになるのであった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "北緯四十二度、時節は一月初め、歐羅巴や北米ゾーンと違つて亞細亞はこの緯度で十分寒く、首都の東京を離れる二百里で、「白色恐怖」は思ひの儘に威力を振ふ。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はユンケル先生の指揮するオーケストラで、メンゼルスゾーン作曲の「ジエルサレム」を独唱いたしましたが、私の歌が御意に召したか、うたいおわりましたら御拍手を賜り、御退場の折、私どもが並んでお見送り申上げましたら、特に私に対して、神々しい、すずやかなお美しいお目で、じいっと私に御会釈を賜わりました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンデルスゾーン（Mendelssohn）の同名の著書は、名聲の高かつたにも似ず、又外形上は輪郭や登場人物をプラトンより借り來つたに拘らず、啓蒙時代の流行思想を内容とする飜案的乃至模倣的作品に過ぎず、それの存在の意義は哲學的よりはむしろ文學的のものであつた。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンデルスゾーンによつて「一切の粉碎者」と命名され、又かれによつて代表された當時流行の靈魂不死説を事實粉碎した、カントがそれに代へて「實踐理性の要請」の名のもとに提案した新しき靈魂の不死性の證明について見るも、強き深き信念や世界觀を背景として持つてゐるにも拘らず、證明そのものは甚しく粗笨である。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代はプラトン及びプロティノスより、中世はトマス・アクィナス、近世はライプニッツやメンデルスゾーンに及んで、最も廣く行はれた姿においては、存在論的論證は主體の單純性を論據とする。",
              "citation": {
                "source": "時と永遠",
                "author": "波多野精一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――○――　интересно　страдать〔苦しむことはおもしろい〕　интересно　прожить〔生きることはおもしろい〕四月五日　モスク※の建築セゾーン〔シーズン〕に入って来た。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーテンスが精神能力として「感情」、「悟性」、「活動力（意志）」と名づけたのが最初で、メンデルスゾーンは、これを「認識能力」、「感覚」あるいは「同意能力（快不快の感情）」「意欲能力」として分けている。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この「知情意」の三つに分けるヒントを、カントが、メンデルスゾーンからうけついだにもせよ、この役割りは大きかったのである。",
              "citation": {
                "source": "美学入門",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は真面目にヤーダスゾーンの教科書を貸した。",
              "citation": {
                "source": "久野女史をいたむ",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来は、オゾーンが重視されていたが、そのほかにこの過酸化窒素も、有力な犯人のようである。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、だいこんの生活史上におけるロマンチック事件の代表的な一つになるのかもしれない、なんて思うと、急に浮き浮きしてきてメンデルスゾーンの〈｜春の歌〉みたいな気持になった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな汽船の一等客になつて、フワ／＼した柔かいベツトに寢て、オゾーンを含んだ大海の空氣を吸つて。",
              "citation": {
                "source": "新婚旅行",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓蒙主義の通俗哲学者メンデルスゾーンの手にかかればソクラテスもまた啓蒙主義的通俗哲学者になる。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
