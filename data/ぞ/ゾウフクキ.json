        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして電蓄の増幅器のつまみをひねって、音を一段と大きくした。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしたんだい」深山学士は増幅器の向うから顔を出した。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "増幅器もまだうまいところへ調整がいっていません。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんで、たしかにきこえたはずだが、今日は、ぴいっという、うなりの音も出ない」　新田先生は、さらに、増幅器を加えたりしたが、空間は、寝しずまったようにしずかであった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――こっちが増幅器で、こっちが継電器ですよ」と馬詰はドライバーの先で機械を指した。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
