  {
    "uuid": "70e454d6-8d6c-576a-b29a-705449f5bee6",
    "entry": "賊心",
    "reading": {
      "primary": "ぞくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "malicious intent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人は知らず、この温泉の口の奥は驚くべき秘密を有して、滝太郎が富山において、随処その病的の賊心を恣にした盗品を順序よく並べてある。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は今日にても、狂愚者にして其言、往々乘輿に觸るゝ者ある由、傳聞したれども、是れとても眞に賊心あるものとは思はれず。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それが、目の前に、投弓の家にころがっていたものですから、若干の草鞋銭なんぞは辞退しても、これをかっさらって行こうという賊心に駆られたのも、また無理のないところがありましょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ彼らは賊心を抑える自制に弱く、反骨の方はやたらにありすぎる。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "目的の娘が、切支丹屋敷へかくれたまで見届けたなら、何も、危険を冒して、こんな尾州家の奥深い殿中まで、忍んで来る必要がないように考えられるのは、善良人の思いそうなところで、盗賊心理はまた別であります。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
