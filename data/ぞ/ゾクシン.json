[
  {
    "uuid": "c534f35c-3852-5c00-a070-a3be4473347e",
    "entry": "俗信",
    "reading": {
      "primary": "ぞくしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
