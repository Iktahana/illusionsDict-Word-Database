[
  {
    "uuid": "936615ee-ae14-5449-81e3-4cc365e3c831",
    "entry": "蔵本",
    "reading": {
      "primary": "ぞうほん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's library",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち池田亀鑑氏の調査によれば、ここの本文が「ひゝ」とあるのは上田秋成の校本だけであって、中村秋香の『落窪物語大成』には「ひう」とあり、伝｜真淵自筆本には「ひと」とあり、更に九条家旧蔵本、真淵校本、千蔭校本その他の諸本には皆「いう」となっている。",
              "citation": {
                "source": "駒のいななき",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "『食鑑』は予蔵本あれど、田辺にないから『要覧稿』に引いたまま写そう。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『韓詩外伝』には魯哀公井を穿たしむるに一生羊を得、公祝をしてこれを鼓舞して上天せしめんとしたが羊上天し能わず、孔子見て曰く水の精は玉、土の精は羊となる、この羊の肝は土だと、公それを殺して肝を視れば土であったと出づというが、予の蔵本には見えぬ。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この一冊と早大図書館所蔵本とが今残ってる馬琴日記の全部である。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは毎巻｜金沢文庫の印があって、北条顕時の旧蔵本である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四十五　半井本の『医心方』を校刻するに当って、仁和寺本を写した躋寿館の旧蔵本が参考せられたことは、問うことを須たぬであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳富蘇峰さんの蔵本になっているのを、わたくしは借覧した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "万延元年の「武鑑」は、わたくしの蔵本に正月、三月、七月の三種がある。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊沢の蔵本即酌源堂本は、此南宋版であつて、全部五十巻目録一巻の中、目録、一、二、十四、十五、十六、十七、十八、十九、計九巻が闕けてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊沢氏で寛政九年に病源候論を写したとすると、それは自蔵本の副本を作つたのか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同じ銭屋の蔵本の中に又画一元亀の零本があつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶藤井氏の蔵本が先づ至つたので、わたくしは此に由つて驥※日記のいかなる書なるかを知つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「応是契丹蔵本」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは所謂道蔵本と道蔵本に変改を加へたものとである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　千金方の道蔵本は即ち九十三巻の嘉靖本で、四庫全書の収むる所である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その枠の下の本棚は私の御秘蔵本棚とも云うべきもので、いろいろ愛する本を並べて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三四年（昭和九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "破提宇子の流布本は、華頂山文庫の蔵本を、明治｜戊辰の頃、杞憂道人鵜飼徹定の序文と共に、出版したものである。",
              "citation": {
                "source": "るしへる",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも同書の第三段は、悪魔の起源を論じた一章であるが、流布本のそれに比して、予の蔵本では内容が遥に多い。",
              "citation": {
                "source": "るしへる",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦死した旧友の蔵本に相違ない。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この図書館の自慢の蔵本に「金花傾嵐抄」といふものがある。",
              "citation": {
                "source": "島原一揆異聞",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "燦爛たる光耀を伴うような、神への尊崇と神への敬順を具象化したような宝玉や金属で飾られた寺院本、紋章や唐草や絡み模様などでけんらんと装われた貴族蔵本などは自ら過剰な、華飾的な此等の生活と風俗を具えている。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に所蔵本の丁寧なものに用いるもので古くは此の法によったもので堅固の点では遥に後者を凌ぐものである。",
              "citation": {
                "source": "書籍の風俗",
                "author": "恩地孝四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも前者の我蔵本に交りて倶に焼けしは、我最も憾とする所なり。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "本書に掲載した当時の『新小説』「すみだ川」の口絵は斎藤昌三氏の所蔵本を借りて写真版となしたものである。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十三年六月相馬愛蔵本郷における創業時代郷里信州を出づ　孔子は「三十にして立つ」と言われたが、私は三十二歳で初めて商売の道に入った。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "林道春の旧蔵本などには「渭雲遠樹書屋」の捺印や、本人の書入れなどのある貴重なものが少なくない。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）斯書の再版本（栃内氏旧蔵本）を海軍省の一室で読んだのは、今年三月の末であったか、その一三四―一三五頁に於て前記和訳文の原文は見られる。",
              "citation": {
                "source": "南嶋を思いて",
                "author": "――伊波文学士の『古琉球』に及ぶ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとしたことでも、物は調べてみなければならない、学問上のことについては、独断であってはならないという自覚を、お銀様がその時に呼び起されてみると、同時に、ただあの詩の中の右の一句だけでなく、あの長詩全体に亘っての意味を味わわなければならないと、自家蔵本の渉猟にとりかかりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "新月の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも私が興味ふかく思ったのは、往年、天理教の中山正善氏からわざわざ「武蔵の俳句がある」といって貸してくだすった天理図書館蔵本の「鉋屑集巻第二」という江戸初期頃の句集に、无何というその俳号と共に、彼の句が載せられていることだった。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
