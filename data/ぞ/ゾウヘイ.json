[
  {
    "uuid": "0cfbc645-9c6a-564f-951d-511dec915951",
    "entry": "造兵",
    "reading": {
      "primary": "ぞうへい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
