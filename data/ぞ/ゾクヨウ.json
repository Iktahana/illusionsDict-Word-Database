    "definitions": [
      {
        "index": 1,
        "gloss": "everyday affairs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伏木の妹夫婦へ姪の縁談に就き、ニユウ・ヨオクの妹夫婦へ雜信、仙臺の小池堅治氏へ同氏の著書出版の交渉經過に就き、本郷の北岡壽逸君より亡妻追悼録を贈られた謝禮、その他俗用の葉書三つ。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗用で外出を已むなくされる事も、偶には無いではない。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗用の書状だけでも私の代筆が出來るならばまだしものことであります。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "処へその姉と称える二十四、五の女が来て、俗用の仏語で若い女を叱るを聴くと、その男はかつて女に会った事のない奴だ、かれこれと言うだけ無駄と知らぬか、商売柄目が利かないにもほどがあるといった。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問をする人がうるさい俗用を避けて、なるべく単純な生活にがまんするのは、みんな研究のためやむをえないんだからしかたがない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にこの頃のように俗用多端じゃ――」　こう云いかけた野村の眼には、また冷評されはしないかと云う懸念があった。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は俗用の生じたのを喜こぶ如くに、すぐ鞄の中から卷紙と封じ袋を取り出して、御米に遣る手紙を書き始めた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問をする人が煩瑣い俗用を避けて、成るべく単純な生活に我慢するのは、みんな研究の為め已を得ないんだから仕方がない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は俗用のためしばしば出入りするこの隣人の家の、小金の有り所をいつの間にか知っていたのである。",
              "citation": {
                "source": "沼畔小話集",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は俗用の生じたのを喜こぶごとくに、すぐ鞄の中から巻紙と封じ袋を取り出して、御米にやる手紙を書き始めた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳が遠いから、俗用は召使の者に――と言ふのを、神田の錢形平次と名乘つて、押して逢つて貰ひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "米が文化の問題から離れた時代に、兵糧米などをヨネといわず、片端からコメといい、米何十石という風に、神聖な言葉を俗用してから、ごっちゃになってしまった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月六日の昼少し前、永代橋の上はひっきりなしに、遅れた礼者と、お詣りと、俗用の人が通ります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "刑場の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳が遠いから、俗用は召使の者に――と言うのを、神田の銭形平次と名乗って、押して逢って貰いました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "庚申横町",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月六日の晝少し前、永代橋の上はひつきりなしに、遲れた禮者と、お詣りと、俗用の人が通ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "刑場の花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　越後｜縮ちゞみの文字｜普通の俗用にしたがふ又しゞみと訓べきをもちゞみと俗にならふ　縮は越後の名産にして普く世の知る処なれど、他国の人は越後一国の産物とおもふめれど、さにあらず、我住魚沼郡一｜郡にかぎれる産物也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば今｜俗用する節用集は新撰字鏡和名抄を先祖の父母として、后のは皆其子孫也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は○雪車○雪舟の字を用ふるは俗用なり。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　原文の「其愚不可及也」（その愚は及ぶべからず）は、日本ではしばしば、「非常な馬鹿者」という意味に俗用されている。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗用には、裏紋を使用しておる。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本には僧侶の総称をホウシという俗用の他に、どこか形のこれと似て一かさ小さい者を、転用によってホウシといった時代があった。",
              "citation": {
                "source": "野草雑記・野鳥雑記",
                "author": "野草雑記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、なにを云い出すかと、お徳は相手の俯向き勝ちの顔をのぞくように見ていると、女はやがて低い声で云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に吉さん女房を持つ気はないかね』と、突然におかしな事を言い出されて吉次はあきれ、茶店の主人幸衛門の顔をのぞくようにして見るに戯談とも思われぬところあり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』お梅は時田のそばに寄って顔をのぞくようにして見た。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の岸にははんの木や柳が、水の中をのぞくようなかっこうで立っていた。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓から見おろすとそこは中庭で、井戸をのぞくような気がする。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは、芙蓉城の七郎さまの奥様が、お里がえりをなさるところでございますよ、田舎｜女を若い衆がのぞくようなことをせられては困ります」　侍女はそう言うかと思うと轍の土を掬うてふりかけた。",
              "citation": {
                "source": "瞳人語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近眼の、すこぶる度の強そうな眼鏡で格子の外をのぞくように、君、はいらんかという。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑暇なものですから、南のほうの高い窓のある建物のほうへ行って、車の音がすると若い女房などは外をのぞくようですが、その主人らしい人も時にはそちらへ行っていることがございます。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなでもなかなか心は働いていらっしゃるんですからねえ」　と婆やは、葉子の膝の上に巣食うように抱かれて、黙ったまま、澄んだひとみで母の顔を下からのぞくようにしている定子と葉子とを見くらべながら、述懐めいた事をいった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
