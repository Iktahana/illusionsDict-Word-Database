[
  {
    "uuid": "e9674e33-ab05-543d-a783-8ddde7df662c",
    "entry": "雑木",
    "reading": {
      "primary": "ぞうき",
      "alternatives": [
        "ざつぼく",
        "ぞうぼく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "various kinds of small trees",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一群の人たちは、遅塚麗水、大町桂月、江見水蔭、田山花袋、久保天随、坪谷水哉などであるが、花袋が紀行文家と言われた時分は、自然派文学勃興以前のことで、文章に感傷癖はあったが、淡泊清新、ことに武蔵野あたりの原野や雑木林の寂しさを、淡彩的に点描するのに巧みであった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "刈り残された雑木林の下路が、むら消えの雪のように、灰をなすりつけている。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にも山頂に落ちた白雪は、私の神経を刺戟することにおいて、幾百反歩の雑木林の動揺と、叫喚とにも、勝っている。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "茅草・尾花の布き靡く草の海の上に、櫟・榛の雑木林が長濤のようにうち冠さっていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "栗や雑木が一杯にしげってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらにひろがる高い雑木の梢を見た、あすこまで昇ればまづ大低の洪水なら大丈夫だ、そのうちにきっと弟が助けに来る、けれどもどうして助けるのかなとおれは考へた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして雑木の幹に白いきのこを見た。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松とちいさな雑木しか生えていないでしょう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ北側なため雑木が少しはよく育ってます。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑木は二本雑木が光る。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その先の松林の片隅に雑木の森があって数多の墓が見える。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲田桑畑芋畑の連なる景色を見て日本国じゅう鋤鍬の入らない所はないかと思っていると、そこからいくらも離れない所には下草の茂る雑木林があり河畔の荒蕪地がある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄道線路脇のちょっとした雑木林の陰に草を折り敷いて、向うの丘陵に二軒つづいた赤瓦屋根を入れたスケッチを始めた。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰路は夕日を背負って走るので武蔵野特有の雑木林の聚落がその可能な最も美しい色彩で描き出されていた。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国土青き草山雑木山、　　　　　　はた松森と岩の鐘、ありともわかぬ襞ごとに、　　白雲よどみかゞやきぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日表にことさら明るんで見えるのは季節を染め出した雑木山枯茅山であった。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑木と枯茅でおおわれた大きな山腹がその桑畑へ傾斜して来ていた。",
              "citation": {
                "source": "闇の書",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は中学の時使った粗末な検索表と首っ引で、その時分家の近くの原っぱや雑木林へ卯の花を捜しに行っていた。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂を下りるにつれて星が雑木林の蔭へ隠れてゆく。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲はその平地の向うの果である雑木山の上に横たわっていた。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑木山では絶えず杜鵑が鳴いていた。",
              "citation": {
                "source": "蒼穹",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤松とちひさな雑木しか生えてゐないでせう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ北側なため雑木が少しはよく育ってます。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水車へ水を取るので橋から少し下流に井堰がある、そのため水がよどんで細長い池のようになっている、その岸は雑木が茂って水の上に差し出ているのが暗い影を映しまた月の光が落ちているところは鏡のよう。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見上げると両側の山は切り削いだように突っ立って、それに雑木や赭松が暗く茂っていますから、下から瞻ると空は帯のようなのです。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある雑木林の出っ鼻の落ち葉の上に風呂敷をしいてすわり込んで向かいの丘を写し始めた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう谷の所にはきまって松や雑木の林がある。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風がまた吹いて来て窓ガラスはまたがたがた鳴り、ぞうきんを入れたバケツにも小さな黒い波をたてました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またきのうのように教室の中にいるのかと思って中をのぞいて見ましたが、教室の中はしいんとしてだれもいず、黒板の上にはきのう掃除のときぞうきんでふいた跡がかわいてぼんやり白い縞になっていました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベースには蓆の切れ端やぞうきんで用が足りた。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
