    "definitions": [
      {
        "index": 1,
        "gloss": "in a crowd",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すると家中の者がぞろぞろ出て来る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はよくここにこうして坐りこみながら眼のまえをぞろぞろと歩いて通る人の流れを眺めているのだが、はじめのうちは堪忍できなかった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝の八時すこしまへで、學校に急ぐ中學生の列が、黒くぞろぞろ、つづいてゐた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをまた組立てて綱渡りをさせるのが自分の責任だがどうしたらよいかと思い惑っていると、周囲のラウベンコロニーの青い小屋からドイツ人の男女がぞろぞろ出て来た。",
              "citation": {
                "source": "御返事（石原純君へ）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "造林のときは苗や何かを一杯つけた馬がぞろぞろここを行くんだぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなぞろぞろ従いてくる。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "市野川やみんながぞろぞろ崖をみちの方へ上って行くらしい。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十国峠の無線塔へぞろぞろと階段を上って行く人の群は何となく長閑に見えた。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この裸體の人魚たちが、幕間にぞろぞろと廊下を歩いた。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　車室の向うから大勢ぞろぞろとやつてきた。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "群集も、ぞろぞろ後から従う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その出品は重に習字、図画、女子は仕立物等で、生徒の父兄姉妹は朝からぞろぞろと押かける。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねくたれた寝衣を着流したような人の行列がぞろぞろあの狭い入口を流れ込んでいた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もよく知らないが、なんでもゆうべの夜中にどこからか帰って来て、縁の下や台所の櫺子窓からぞろぞろと入り込んだものらしいと云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一と群れがこっちの岸へ着いて、ぞろぞろ上がってゆくのを待ち兼ねたように、御符売りは入れ替って乗った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "副官は、剣吊りボタンをはずして、ぞろぞろ押しよせた十四人を、いぶかし気に睨みまわした――何ごとだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ眼の前は谷のやうになった窪地でしたがその中を左から右の方へ何ともいへずいたましいなりをした子供らがぞろぞろ追はれて行くのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘠せて青ざめて眼ばかり大きな子、髪の赭い小さな子、骨の立った小さな膝を曲げるやうにして走って行く子、みんなからだを前にまげておどおど何かを恐れ横を見るひまもなくたゞふかくふかくため息をついたり声を立てないで泣いたり、ぞろぞろ追はれるやうに走って行くのでした。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーンで夜おそく町をうろついて、タンネンバウムを売っているのを見た時にちょうど門松と同じだと思ったのと、ヴェネディヒで二十五日の晩おびただしい人が狭い暗い町をただぞろぞろ歩くのを見てさびしい思いをしたきりでしたが、ことしはここの田舎で田舎らしい純粋の降誕祭を経験しました。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ダンテ・アリギエリ　晩秋の夜、音楽会もすみ、日比谷公会堂から、おびただしい数の烏が、さまざまの形をして、押し合い、もみ合いしながらぞろぞろ出て来て、やがておのおのの家路に向って、むらむらぱっと飛び立つ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前を、ぞろぞろ人が通って行く。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに、みんな捜し出されて、ぞろぞろ西洋間へひきあげて、「おさむさんは、まだだよ。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "健全の思念は、そのあとから、ぞろぞろついて来て呉れる。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてバスは駅前の広場に止り、ぞろぞろ人が降りて、と見ると佐吉さんが白｜浴衣着てすまして降りました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私も加わり、暫く、黙って酒を飲んで居ると、表はぞろぞろ人の行列の足音、花火が上り、物売りの声、たまりかねたか江島さんは立ち上り、行こう、狩野川へ行こうよ、と言い出し、私達の返事も待たずに店から出てしまいました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "往来に、あるいは佇み、あるいはながながと寝そべり、あるいは疾駆し、あるいは牙を光らせて吠えたて、ちょっとした空地でもあるとかならずそこは野犬の巣のごとく、組んずほぐれつ格闘の稽古にふけり、夜など無人の街路を風のごとく、野盗のごとくぞろぞろ大群をなして縦横に駈け廻っている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾を振って、ぞろぞろ後についてくる。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきもきらず、ぞろぞろと流れるやうに通るのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきもきらず、ぞろぞろと流れるように通るのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなは、こんどはなんにももたないで、ぞろぞろ森の方へ行きました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
