        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし邸を見上げると反対に洋館を増築したり、庭を造り直したりした。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月××日　増築完成。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "払えると思っていた増築費、半分しか払えない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学校が増築される時には、だから人々は珍らしそうに毎日普請場へ顔を見せた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "年を経るにつれ、これは増築されていき、大きな屋敷にまでなった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "増築した廊なども趣があって園内に引いた水の流れも美しかった。",
              "citation": {
                "source": "源氏物語",
                "author": "松風",
                "note": "青空文庫"
              }
            },
            {
              "text": "長く染みこんで来た都会趣味や町住ひらしい家庭気分が彼には煩はしくなつてゐたが、その癖彼はまた二十年住みなれた家を離れかねて、家を造築して見たり、最近は又増築工事の時破壊された庭を造り直したりして、兎角居住に迷ひがちな自身の気持を強ひても落着けようとしてゐた。",
              "citation": {
                "source": "芭蕉と歯朶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつかの家族風呂が増築されたばかりで、部屋も新築されたらしく、新らしい廊下を伝つて行くと、まだ壁の塗られない箇所があつたりした。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにある広場には欅や桜の木がまばらに立っていて、大規模な増築のための材料が、煉瓦や石や、ところどころに積み上げてあった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "増築が出来かゝつた儘で四五年来も投げ放しになつてゐたのだが、察するところ其処は仏間にでもする思案があつたらしかつた。",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう冬も少し深くなって、増築の部分の棟あげもすんでいた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには永年の懸案であった家の増築ということも彼の気分転換に相当役立った。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "増築の出来｜栄えが庸三の期待を裏切ったことはもちろんであったが、一旦請負師の要求に応じて少なからぬ金を渡し、貨車で運ばれた建築用材を庭の真中へ積みこまれてしまうと、その用材からしてすでに約束を無視したものだということに気がついていても、今更どうすることもできないのであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹村は近ごろの増築らしいその部屋の壁にかかった、正宗やサイダの広告、床の間の掛け物や、瓶に※した彼岸桜などを眺めていたが、するうちにいいつけたものが、女中の手で運ばれた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家を増築するか、別に一軒家を借りるか、するより外なかつた。",
              "citation": {
                "source": "風呂桶",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヵ年計画は、勤労階級の文化向上のため、文盲撲滅費、住居増築費、学校・病院・托児所増設、食堂の増設、ラジオ・キネマ配布網の拡大費等に莫大な基金を予定している。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五ヵ年計画は、勤労者の住居増築のために七十四億九百万ルーブリという金を支出している。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "校舎不足のために地方では苦しまぎれに町村民に校舎増築費の寄附をさせているところが多い。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "始め二室から出来た洋館だつたが昨年十畳一室を増築した。",
              "citation": {
                "source": "私の書斎",
                "author": "土田杏村",
                "note": "青空文庫"
              }
            },
            {
              "text": "金もなかつたが、仕事も段々激しくなり、工場は建物を増築して、学徒の勤労奉仕も大勢来るやうになつた。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近に増築した保命館は此辺切っての旅館であった。",
              "citation": {
                "source": "真珠塔の秘密",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の長城は、秦以後西漢・後魏・北齊・北周・隋・明時代に渉つて、幾度となく増築又は改築されたものである。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "校舎増築について前からＨを知っていただけに、猶更、憎悪の念が深まりました。",
              "citation": {
                "source": "化生のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "校舎増築のことでです。",
              "citation": {
                "source": "化生のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "地所はまだ広く残っていますが、そこは将来の増築の場所ですし、庭の方にも思うような場所はなく、最後に、女将さんの居間の横手に連れてゆかれました。",
              "citation": {
                "source": "霊感",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして次々に、小さな屋翼が増築され、周囲の土塀も広げられて、今では多人数の一家となっていました。",
              "citation": {
                "source": "碑文",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして旅館に帰ってから、増築中の仕事場からであろうか、木目の美しい木片を一つ拾ってきて、ナイフで熊を彫りはじめたのである。",
              "citation": {
                "source": "山上湖",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四の原因は、云ふまでもなく、かゝる政治に本質的メスを加へようとせず、教育の振興は学校増築にありといふやうな幼稚な観念に支配されてゐた国民有識階級の「政治意識」にある。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "増築案は前村長時代から持ち越されていたものだが、それさえ行き悩みつつあったのに、今度はさらに何万かを加算しての新築案。",
              "citation": {
                "source": "瘤",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "一〇七八年に建築され始め、後次第に増築されたのである。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
