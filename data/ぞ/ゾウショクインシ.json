        "examples": {
          "standard": [
            {
              "text": "創傷治癒には、様々な増殖因子が関与している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "がん細胞は、自己の増殖因子を過剰に分泌することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "再生医療の分野では、増殖因子の活用が期待されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ニコチン酸が細菌増殖因子であることが見つかった後で、ついに1937年ウィスコンシンでニコチン酸とニコチン酸アミドが黒舌病に対し、そしてアラバマ州では、ペラグラ患者に対しても、高い治療効果を持つことが見出された（58,59）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビタミン葉酸　【その３】に記載したように“葉酸”と呼ばれた物質はサルとトリが大赤血球性貧血になるのを防ぐビタミンであり、ある種の細菌の増殖因子であった。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある細菌増殖因子の測定方法に助けられた。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
