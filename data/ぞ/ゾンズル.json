    "definitions": [
      {
        "index": 1,
        "gloss": "to know",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "曰く、不束なる女ども、猥に卿等の栄顧を被る、真に不思議なる御縁の段、祝着に存ずるもの也。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お見受け申す処、しかるべき大将と存ずる。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼君、「否、予は汝が氣に入りたれば、餘人にては氣に入らず、獻立は如何樣にても可し、凡そ汝が心にて此ならば可しと思はば其にて可きなり、自ら旨しと存ずるものを予に構はず仕れ」とまた他事も無くおほすれば、不得止「畏まり候」と御請申して退出ける。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "因りて倩々案ずるに、國許に候恩田杢と申者、老職末席にて年少なれど、きつと器量ある者につき、國家の政道を擧げて任せ申さむと存ずるが、某も渠も若年なれば譜代の重役をはじめ家中の者ども、決して心服仕らじ、しかする時は杢が命令行はれで、背く者の出で來らむには、却て國家の亂とならむこと、憂慮しく候。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時、就中御歳寄の君つと褥を進め給ひ、「御用の趣餘の儀にあらず、其方達も豫て存ずる如く豆州御勝手許不如意につき、此度御改革相成る奉行の儀、我等相談の上にて、杢汝に申付くるぞ、辭退はかまへて無用なり」と嚴に申渡さるれば、並居る老職、諸役人、耳を欹て眼を※れり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るにこの典型的論理に私が多少疑問あることは最遺憾に存ずる次第であります。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りがかりには挨拶をしましたが、仔細あって、しばらく、ここへ参るまいと存ずるので、会釈に一献進ぜました。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「就いては長年お世話になったお礼も申し上げたく、心ばかりの祝宴も開きたいと存ずるから、御迷惑でもお越しを願いたい。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて遠き古の事、考え知らんにも今如何ともし難けれど、我等凡愚にはただ因縁不可思議とのみ存ずる、何様いうものでござろうか、と意外な逆手に出られた。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といろいろの世界を股にかける広い広い大きな渡海商いの世界から見ましょうなら、何人が斬れるでも無い一本の刀で癇癪の腹を癒そうとし、時節到来の暁は未練なく死のうまでよと、身を諦めて居らるる仁有らば、いさぎよくはござれど狭い、小さい、見て居らるる世界が小さく限られて、自然と好みも小さいかと存ずる。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "図書　（疑の目を凝しつつあり）まさかとは存ずるなり、私とても年に一度、虫干の外には拝しませぬが、ようも似ました、お家の重宝、青竜の御兜。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西も弁えぬこの荒野とも存ずる空に、また、あの怪鳥の鳶の無気味さ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に道を教えて下された、ああ、尊さ、嬉さ、おん可懐さを存ずるにつけて……夜汽車の和尚の、室をぐるりと廻った姿も、同じ日の事なれば、令嬢の、袖口から、いや、その……あの、絵図面の中から、抜出しましたもののように思われてなりませぬ。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫、神とも存ずる、令嬢。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "北八が此作の如きは、園内に散ばつたる石碑短册の句と一般、難澁千萬に存ずるなり。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これはお心づけ忝のう存ずる、それでは早速」と云って伴助を見て、「これ、てめえ、白湯をしかけろ」　其の時屏風の中で嬰児の泣く声がした。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この娘を予が手許に召仕ひたう存ずるが、奉公さする心はないか。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長公の嫡孫三法師殿の在すからには、この君を立て参らせるのが、最も正当であると存ずるが、如何であろう」と。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼士存ずる旨あれば名は名乗らじ、我は秀頼の為に命を進ずる間、首取って高名にせよと、首を延べて相待ける。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ねてかかる使をせられなば存ずる旨あり」と、断平として言って、追返した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その政治上の主義としては、彼の上書に、「全体我共は尽忠報国の志士、依而今般御召相応じ去二月中遥々上京｜仕り、皇命尊戴、夷狄攘斥之御英断承知仕り度存ずる志にて、滞京｜罷存候云々」（文久三年十月十五日上書）　とある。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "縱令忘られざらんも、その偶※存ずるは汝が囹圄の桎梏として存じ、汝が性命の杯中に落ちたる毒藥として存ずるならんといふ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その名は今タツソオによりて僅に存ずるにあらずや。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の朝には、胸中僅かに今一たび相見んの願を存ずるのみなりき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「いやいや、仰せではありますが、早い話が、これが手前なら、やっぱり貴辺をそう存ずる、……道でござる、理でございます。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、不束なる女ども、猥に卿等の栄顧を被る、真に不思議なる御縁の段、祝着に存ずるものなり。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "申さずとも、御坊は承知と存ずるが。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、かた／″＼の御心もじ、御如才はないかに存ずる。",
              "citation": {
                "source": "妖魔の辻占",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｆ君と私との距離を縮めた、主な原因は私が君の「童貞」を発見した処に存ずる。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そ、そんなことをしたら……」　藤波は、手酌でぐっとひっかけておいて、驕慢に空嘯くと、「ふッふッふ……ところで、甚だ遺憾にぞんずるが、杉の市は直接たっての下手人じゃねえ。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "三人目",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
