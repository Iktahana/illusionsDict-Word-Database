        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "フラウ・ゾルゲとハイマートとサンクト・ヨハニス・フォイエルとインガソールの文集とであつた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井田は其の中からフラウ・ゾルゲを取上げて、「貴方も是れをお持ちですね、僕は此間丸善に註文して置いたが」と云つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相島は井田がフラウ・ゾルゲの飜譯に着手しようとして居るのを知つて居る、而して「あれが井田の弱點だ。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二人の間にフラウ・ゾルゲの内容に就て話が進んだが、どうした調子か話頭が戀愛の事になると、相島は突然彼れの周圍に起つた種々の事件を語り出した。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気の時には、一切のゾルレンが消えてしまふ。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バットやチェリーやエアシップは月並みだと思ったが、しかし、ゲルベゾルテやキャメルやコスモスは高すぎた。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆっくりとしたディゾルヴで、“The Kids Were Alright” に文字が変わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面がハレイションを起こし、そのまま洗面所の光景にディゾルヴする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に思うと、前者はエインス・ウォルスの小説「ウィンゾル・キャストル」で、後者は例の「ハムレット」であったらしい。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼はルツセンゾルテを吸ひながら、すぐその手紙に返事を書いた。",
              "citation": {
                "source": "火の点いた煙草",
                "author": "一名――煙草蒐集家の奇禍",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戯２・３（夕）　英国のウインゾル王宮の皇室図書館に、毎月の雑誌が取揃へてある雑誌棚がある。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家アンデルス・ゾルンが買い取ってアカデミイへ寄附したもので、場処それ自身も芸術的に面白く、おまけに料理がいい。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私などはいつもゾルレン癖から、かつては他人を責め裁く心の烈しかったものです。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "祝さねばならぬというゾルレンがあればこそ心の常識を保ってはおれ、私は苦しくてたまりません。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　Marx-Engels Archiv, ※, 241.　マルクス主義は理論と実践との弁証法的統一を知るが故に、それはいかなる当為をも、いかなるゾルレンをも知り得ない。",
              "citation": {
                "source": "マルクス主義と唯物論",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　Marx-Engels Archiv, ※, 241.　マルクス主義は理論と實踐との辯證法的統一を知るが故に、それは如何なる當爲をも、如何なるゾルレンをも知り得ない。",
              "citation": {
                "source": "唯物史観と現代の意識",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "弁証法的にはっきり見る時には、あらゆる「ゾルレン」は当然否定される。",
              "citation": {
                "source": "傍人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゾルレン」を否定すれば、イデオロギーは、創作上、一つのポーズではないか。",
              "citation": {
                "source": "傍人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "道徳的真理は起るものであり、従って起らないこともあり得る故に、それは命令或いは当為（ゾルレン）の形をとるのである。",
              "citation": {
                "source": "哲学入門",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊８　なべての、愛と苦悩とを背負う孤独者たちが、また、トリスタンとイゾルテの幾群れかが、死に近づく時のあの足取り。",
              "citation": {
                "source": "二十歳のエチュード",
                "author": "原口統三",
                "note": "青空文庫"
              }
            },
            {
              "text": "またドイツのカール・アントン・フォン・フォーフェンゾルレン殿下の御前演奏をした経歴をもつ日本の声楽家でございますが、はるばる日本から参りましたから、どうぞ歌を教えて下さいまし、と詳しい履歴を書いた手紙を出しました。",
              "citation": {
                "source": "お蝶夫人",
                "author": "三浦環",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、この前「金オルノゾル」が発表された時も、患者は丸で相手にもしなかつた。",
              "citation": {
                "source": "癩院記録",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらに本然に備われる要求は動かすべからざるザインであって同時にゾルレンの根源をなすものである。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし、私たちはゾルレンを掴むことにおいて自信のない愚人である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはゾルレン臭。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゾルレンの臭気、仏と自分との間の水くさいかすが残っている。",
              "citation": {
                "source": "生活と一枚の宗教",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の作品は、まだほかに、「ある女の一生」「トリスタンとイゾルドの悲劇」「テエブ王ウディイプ」「勝祝ひ」「王者の悲劇」「奴隷」などがある。",
              "citation": {
                "source": "サン・ジョルジュ・ド・ブウエリエについて",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、スキイ・ジャンピングの競技場などでも、他のレゾルトでは、スキイ穿きで見物に来た人が、ずらりと雪の上に立って取り巻いているくらいのものだが、サン・モリッツとなると、瑞西の国旗を立て並べてお祭りさわぎの装飾をする。",
              "citation": {
                "source": "踊る地平線",
                "author": "白い謝肉祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "〜〜〜〜〜〜〜〜〜〜　（前文略）去る五月は浪さんと伊香保にあり、蕨採りて慰みしに今は南半球なる豪州シドニーにあり、サウゾルンクロッスの星を仰いでその時を想う。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "〜〜〜〜〜〜〜〜〜〜（前文略）去る五月は浪さんと伊香保にあり、蕨採りて慰みしに今は南半球なる豪州シドニーにあり、サウゾルンクロッスの星を仰いでその時を想う。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
