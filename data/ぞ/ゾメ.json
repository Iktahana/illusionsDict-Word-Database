    "definitions": [
      {
        "index": 1,
        "gloss": "first doing of ... (ever, in one's life, in the new year, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私がこの本を初めて知つたのは大正十四年の暮であつたかその翌年の初めであつたか、とまれ寒い頃であつた。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことが果される時に詩は初めて「作品」として通用するのだと思ふ。",
              "citation": {
                "source": "感想",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕としてそんな用命にあづかつたことは生れて初めてでもあつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "エレベーターに初めて乗つたのも、その夏である。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には、晴れた空の一部分に黒い濃い雲形定規のやうな雲があつて、一寸欠け初めたばかりの月が、みえたり隠くれたり、可なり威勢よく渡れ亙つてゆくのが見られた。",
              "citation": {
                "source": "古本屋",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくヘルンはその時初めて心の隅に、幸福という物の侘しい実体を見たのであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めからボヘミアンであったヘルンは、晩年においてもなおボヘミアンであり、永遠に故郷を持たない浦島だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人の告白によれば、自分の良人に対する真の愛は、その時初めて起ったという。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると『それ貝が鳴った』とばかり、夫人を初め女中や書生たちが大騒ぎをし、先を争って離れの書斎に駈けつけた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて大久保の新居に移った時は、春の麗らかな日であって、裏の竹藪で鶯がしきりに鳴いてた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて病気の発作が起った時、ヘルンは自己の運命をすっかり自覚し、死後における妻子の保護と財産の管理とを、親友の法学士に一任して、後に心がかりのないようにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿を初めて見た時、田圃の中に建設された、一夜作りの大都會を見るやうな氣がした。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長の去つた後で、途中から来た者と初めからゐた者とは話合つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長は初め、笑顔の好い教師程気になつた頃、達沢といふ上席教師が中でも一番気になつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長はそれを聞くと初め一寸は危惧の念に駆られたが、「なあに課業の妨げにはなりませんよなあに」と大きい声で云はれてる中遂に承諾せざるを得なくなつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大正四年の初め頃だつたか終頃であつたか兎も角寒い朝、その年の正月に亡くなつた弟を歌つたのが抑々の最初である。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私が今初めに此の男を意識的だといつたのをなんとか改訂しなければなりません。",
              "citation": {
                "source": "小林秀雄小論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて自分の物を好いと思つた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当の、本当の悲劇は物質を基調として初めて存在する。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前初めて辻氏を訪ねたら貴兄に手紙を出してみるがいゝといはれたので、手紙を書かうとしたのですが、手紙つて奴が僕には六ヶ敷いから、過日書いた貴兄についての論文（？",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それを聞いた妻君は初めて笑顔を作つても好い機会を持つたわけであつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論彼の家に来るのも初めてだつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "好きな仕事が一つあり、たえずそれに心が集中される時に初めて、人生変化も感じられるといふものである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "耳で聽いて意味がわからず、文字に書いて見せた上で、初めて視覺から語意が通ずるといふやうな言葉を、日常語の會話に使用するやうな國民があるとしたら、世界で最も不便で最惡の國語を所有する民族と言はねばならぬ。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの時、初めて日本語に眞の「韻」といふものが出來、支那西洋の國語と同じく、我々の言葉にもまた眞の「韻律」が發生する。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕪村の価値が、初めて正しく評価され、その俳句が再批判されたのは、彼の死後百数十年を経た後世、最近明治になってからのことであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その崇拝する芭蕉の庵を、初めて親しく訪ねた日は、おそらく感激無量であったろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり言えば、その心に「詩」を所有している真の詩人が、対象を客観的に叙景する時にのみ、初めて俳句や歌が出来るのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば詩の翻訳者は、原作を自分の中に融化し、自分の芸術的肉体として、細胞化した場合にのみ、初めて訳者としての著作権を有するのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
