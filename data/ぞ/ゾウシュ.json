    "definitions": [
      {
        "index": 1,
        "gloss": "sake brewing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "佐吉さんの兄さんは沼津で大きい造酒屋を営み、佐吉さんは其の家の末っ子で、私とふとした事から知合いになり、私も同様に末弟であるし、また同様に早くから父に死なれている身の上なので、佐吉さんとは、何かと話が合うのでした。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イーハトヴの友も及ばないとしますととても密造酒ではないと存じました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それからあとは毎日林の中や谷をあるいて山地密造酒を探して居りました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯は、さしみと豆腐汁と煮豆と茄子漬、なかなかの御馳走だつた、ことに前は造酒屋だから、飲みすごしたのも無理はなからう！",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の衣はもう十年ばかりも着て、ぼろぼろになつてしまつたので、良寛さんと懇意な阿部造酒右衛門といふ人が、今度新しくお衣を、つくつてくれたのであつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙は阿部造酒右衛門さんの宅に届いた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "造酒右衛門さんが開いて見ると、「昨日は新しいお衣を忝く頂戴しました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣のすそを何かにひつかけて、破つたのかも知れない、と思つた造酒右衛門さんは、注文のものを下男に持たせてやりながら、「禅師はお年寄りで、そんな細かい仕事は難儀だらうから、お前がしてあげなさい。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そいつは何だ、講釈師がよく饒舌る、天保水滸伝中、笹川方の鬼剣士、平手造酒猛虎が、小塚原で切取って、袖口に隠して、千住の小格子を素見した、内から握って引張ると、すぽんと抜ける、女郎を気絶さした腕に見える。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……こいつには、笹川の剣士、平手造酒の片腕より女郎が反るぜ、痛快！",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "※の濃染手拭、酒の名の「潮」の盃、引出よと祝ふとわけて、我が老舗酒はよろしと、新の桝酒に磨くと、春や春、造酒よ造酒よと、酒はかり、朱塗の樽の栓ぬき、神もきかせと箍たたき、たたきめぐれば、ほのぼの明けぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "反歌春の夜と滴りあまる豊造酒は朱塗の樽に添ひて流れつ習字太竹の青き筒、つやつやし筒に、たぷたぷと素水入れ、硯の水｜清けし、墨磨れと、傍注ぎ、注ぎてまはりぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "西多摩や造酒屋は門櫓いかしく高く、棟さはに倉建て竝め、殿づくり、朝日夕日の押し照るや、八隅かがやく。",
              "citation": {
                "source": "海阪",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "西多摩や造酒屋は門櫓いかしく高く、棟さはに倉建て並め、殿づくり、朝日夕日の押し照るや、八隅かがやく。",
              "citation": {
                "source": "篁",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は福岡県朝倉郡の造酒屋、畑中正作の三男で、昌夫と呼ばれていた者です。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "變な望みだが一向此方に損の行かぬ事と其二子を殺すと老父「阿房共め、吾二子年若くて汝等に説かれて心動き、どうやら秘訣を授けさうだから殺させた、もはや秘訣は大丈夫洩るゝ氣遣ひがないわい」と大見得を切つたのでアイリツシユ人大に怒り、其老人を寸斷したが造酒の秘法は今に傳はらぬさうだ。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｈ市の旧家でございます」「御両親の御職業は……」「造酒屋を致しております」「ほお。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "造酒家ばかりが知つてゐるひねり餠といふのと同じものだ。",
              "citation": {
                "source": "日光",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "小畑は郡役所に勤めている官吏の子息、小島は町で有名な大きな呉服屋の子息、桜井は行田の藩士で明治の初年にこの地に地所を買って移って来た金持ちの子息、そのほか造酒屋、米屋、紙屋、裁判所の判事などの子息たちに同窓の友がいくらもあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人造人間は、まず措くとするも、人造｜絹糸、人造酒、人造染料、人造肥料、人造光線、人造真珠、人造宝石、などと、数えてゆけば、きりがない。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の恰度｜中央の大きい造酒家の前には、往来に盛んに篝火を焚いて、其｜周囲、街道なりに楕円形な輪を作つて、踊が初まつてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の丁度中程の大きい造酒家の前には、往來に盛んに篝火を焚いて、其周圍、街道なりに楕圓形な輪を作つて、踊が始まつてゐる。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」……「あの綺麗な噴水の傍らで、リラやカーネイシヨンの花籠を抱へたピピヤスが、ホーレイスの歌か何かを歌ひながら道往く人々に花を売つてゐる有様を、シツダルの肩にでも凭りかゝつて眺めながら、この辺で一杯飲んでゐれば、屋台店の密造酒だつてレイマンの氷で冷した灌奠酒よりも旨く飲めるといふものさ。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に於ても既に素盞嗚尊の時に酒があり、少彦名神は造酒の神なりと言はれ、支那に於ても酒を以て薬物の始とした。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "相接した裏木戸傳ひに、隣の裏庭へ出ると、そこは暗い酒藏の前で、大きな造酒の樽の陰には男達が出入して働いて居たものです。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "農民の間の反動的分子は密造酒を飲みながらゴネだした。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "密造酒をつくることも、仲介人が結納品のかけ合をやる婚礼もすぐには絶えなかった。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飲んだ、たらふく飲んだ、造酒屋が二軒ある、どちらの酒もよろしい、酒銘「一人娘」「虎の児」。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "場内騒然）〈司会〉会場が大へんそうぞうしゅうございまして、お話がききたい方の耳に届かないと思います。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいこの会場の最前列には、新聞社の関係の方が取材においでになっているわけですけれども、これは取材の余地がないほどそうぞうしゅうございますので、このさい静粛にお話をうかがいまして、このあと進めたいと思います。",
              "citation": {
                "source": "浅沼稲次郎の三つの代表的演説",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
