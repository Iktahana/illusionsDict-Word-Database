[
  {
    "uuid": "c90ebcfb-b3a0-50e0-84e3-a315c03d225a",
    "entry": "造酒",
    "reading": {
      "primary": "ぞうしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
