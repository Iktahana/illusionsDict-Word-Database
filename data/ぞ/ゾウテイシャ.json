          "standard": [
            {
              "text": "病院のロビーには、多額の寄付をしてくれた贈呈者の名前が刻まれたプレートがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼は、大学に研究資金を寄贈した匿名の贈呈者として知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "博物館では、貴重な美術品を寄贈してくれた贈呈者への感謝状を授与するセレモニーが開催された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "其等は一々高く振上げて衆に示され、接収役が鄭重な儀礼的誇張を以て、品名と贈呈者とを呼び上げる。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            }
          ]
        }
