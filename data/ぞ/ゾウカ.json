[
  {
    "uuid": "edc6f6c8-c563-5876-bbca-42a36fbb61c6",
    "entry": "増加",
    "reading": {
      "primary": "ぞうか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
