    "definitions": [
      {
        "index": 1,
        "gloss": "madly in love",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "団九郎、おしまに、Ｔ「拙者の顔は　女にもてんと　申しおった」　まァとおしまが、Ｔ「だって先生　此処に一人　そのお顔に」　と団九郎に寄り添って、Ｔ「ぞっこん　惚れた女が　あるじゃ　御座いませんか？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、ぞっこんとなって、お稲ちゃんをたってと云うの、これには嫂が一はながけに乗ったでしょう。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてみると、せんせいたちもこの断ち切れないお互いのものには、ぞっこん苦労した連中かな。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唐突に嫁入らせると、そのぞっこんであった男が、いや、失望だわ、懊悩だわ、煩悶だわ、辷った、転んだ、ととかく世の中が面倒臭くって不可んのです。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今思うと、――ぞっこん、これが、目にしみついていますから、私が背負っている……雪おんな……」（や、浜町の夜更の雨に――　……雪おんな……　唄いさして、ふと消えた。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷く澄んでお上品な処に、ぞっこんというんだから、切った、切ったが気になるんだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）そしてやっぱり一人息子にぞっこんな主人逸作への良き見舞品となる息子の手紙は、いつも彼女は自分が先きに破るのだった。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ああ、お説の通り、わいはぞっこん参ってまんねん。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸七は小児のうちから、妙に、見ることも、聞くことも、ぞっこん蛙といえば好きなのである。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の六兵衛どんを前にして言いにくいことでござりまするが、両方共にぞっこんという仲でござりましてな、あれこそ本当の真夫――曲輪雀共もこのように申していた位でござります。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちのだんなは、江戸の娘がぞっこんの――」「こらッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが二人の相識る機会となり、グレージーは女と宝石とにぞっこん惚れこんで、彼女の宝石をどしどし買い込んだのである。",
              "citation": {
                "source": "変な恋",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただの水、なまぬるい水、ぞっこん心がしびれてくる水、人の情のようになぐさめてくれる水、誇張の水、歩きながら泣くのはまことに工合がいい。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その上、大の色男で、お歌がぞっこん惚れている」　女狩は人々の間に挟まれて、赤くなっていた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "南玉は、小藤次も、深雪も、気にかけずに「この岡田様が、この姪の、お綺麗なところに、ぞっこん惚れ奉って、えへへ――まずこういう工合でござります、下世話に申します、首ったけ」　扇を、顎の下へ当てて、頸を延した。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方役者にぞっこんまいッてしまったらしいぞ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりぞっこん惚れ込んだのであった。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうこれだけいっただけで説明にも及ぶまいとおもうが念のために蛇足を添えるならつまりぞっこんと惚れ込んでいるこの自分の心をうっかり話の途切れに相手に悟られてしまってはならない、そうしたその思惑がつい何べんも何べんも「お久さん何処へ」と下らなく同じことばかり訊ねてしまってはいるのである。",
              "citation": {
                "source": "我が圓朝研究",
                "author": "「怪談牡丹燈籠」「江島屋騒動」「怪談乳房榎」「文七元結」「真景累ヶ淵」について",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢みが悪いとは異なことをいうけれど、相手はぞっこんわが輩を慕っているのだ。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……お前にぞっこん参っているらしい。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぞっこん恋風とやらを引き申候。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとからお艶にぞっこんまいって機会あらばと待ち構えていた彼、羽織衆夢八となってひとしお嬌美を増したお艶の前に、富五郎はもう有頂天になっているのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄人女の中には、ようすのいいのにぞっこん惚れこんで血道をあげるのもすくなくないが、こちらは荒い風にもあたらぬ大家のお嬢さん、いくら声がよくとも小粋でも、道楽者くずれの小鰭の鮨売などに迷って駈けだそうなどとは考えられない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "小鰭の鮨",
                "note": "青空文庫"
              }
            },
            {
              "text": "かねてお源にはぞっこんまいっていて附け文の二、三度もしたことがあるンだから、てっきり文の返事を手っとり早いところでやってくれたンだと早合点して、自分じゃもうお源の婿になったつもりでおさまり返っていた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はこう見えても、ぞっこんお静に惚れているんだよ、ハッハッハッハッ」　モジモジする徳三郎を顧みて、平次はそのまま長火鉢の前に引くり返ってしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "永楽銭の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「小用に下へ降りた帰りの悪戯だ、――殺すほどの気は無かったかも知れないが、日頃から主人に取入って居る奇月の幇間振りが癪にさわって居た上に、近頃才六もぞっこん惚れて居るお滝を取持って、主人に人身御供に上げようとして居る奇月が憎かったのさ」「すると、石灯籠を転がして、奇月に留めを刺したのも才六で？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "若くて良い男で、十七のお嬢さんにぞっこん参っている、――お嬢さんのお琴さんが、首尾よく日本橋の欄干を渡ったら、それから何うなると思います」「――――」「沢屋の借金は延びて、一日伸ばしに身上は立ち直り、お嬢さんはどこかへ嫁に行くかも知れない」「？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "橋の上の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうえ、十八になったばかりの娘のお絹にぞっこんで、まるで夢中で見ちゃいられないとお六が言いますよ」「そのお六というのは」「高輪の旅籠屋の女中だから、宿場の飯盛じゃありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "当然ながら妹のソフィアはもう一目でぞっこんで、背の高さと美男ぶりと『陽気な振る舞い』を克明に書いていますよ。",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
