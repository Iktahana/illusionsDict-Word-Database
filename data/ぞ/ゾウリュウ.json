    "definitions": [
      {
        "index": 1,
        "gloss": "erecting (a temple, Buddhist statue, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
