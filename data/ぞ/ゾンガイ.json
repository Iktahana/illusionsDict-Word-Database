    "definitions": [
      {
        "index": 1,
        "gloss": "beyond expectation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうせ目下が精神の貧寒時代であることは分つてゐますし、詩人が存外の苦吟をするのであることも分つてゐるのですから、もつとあけすけにして、もつと具体的なことを論ずることが、詩壇の急務ではありますまいか。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ是等三様式は極めて短い詩形であるから、語自体の力が、語を駆使する作者の力よりも存外に大きいものであることは明瞭であらう。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "この豚存外に心利きたる奴にて甲斐々々しく何かと世話しくれたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、また志士や学者が言っているような「民衆」というような人間は捜してみると存外容易に見つからない。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白剥山の入口などは、解らなくて、森の中を一行が、離れ離れに迷うばかり、滝上りまでもやった、一時は絶望に近かった、しかし山腹に辿りついてからは、去年の路が、微かに見分けが出来た、頂は存外変りがなかった。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "高峰の雪というと、誰でもその高潔を予想するが、新雪はともかく、いわゆる万年雪の状態にあるものは、表面は雨水が流れたり、崖の砂が塗られたり、偃松の枯枝が散ったりして、存外に汚ないものが多い。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "読者のうちにはそういうことに気がついている人は多いであろうが、わざわざ著者に手紙をよこしたりあるいは人伝てに注意をしてくれる人は存外きわめて稀である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺屋の白袴、医者の不養生ということもあるが、物理の学徒等が日常お互いに自由に話し合う場合の用語には存外合理的でないものが多数にあって、問題の「速度のはやい」などもその一例である。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこういう研究が仮に出来上がったとしたところで多くの歌人には何の興味もない事ではあるかも知れないが、しかし歌人にして同時に科学者であるような人にとっては少なくも消閑の仕事としてこんな事をつついてみるのも存外面白いかも知れない。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそういうものがどんなに変っても、同じ作者の「顔」は存外変らぬもののように思われる。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも事実上はこの規準的関係の実現は存外困難であった。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらでも代はりのありさうなものが實は此の世の中には存外ないのである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "存外すいて居る車に乘込んだが、すぐあとから小團體がやつて來て完全に車内の空間を充填してしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうだとすると、矢張り土曜日に出かけて人に揉まれに行く方が存外いゝ事になるかも知れない。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどうも此の東京の街頭に畫架を据ゑて、往來の人を無視してゆつくり落着いて、目を細くしたり首をひねつたりする勇氣は――やつて見たら存外あるかも知れないが、考へて見ただけではどうもなささうに思はれる。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことによると日本の歴史以前の諸先住民族の中にはそうした漂流者の群が存外多かったかもしれないのである。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑中にある民家でぼろぼろに腐朽しているらしく見えていながら存外無事なのがある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば低気圧という言葉の意味すらよく呑込めていない人が立派な教養を受けたはずのいわゆる知識階級にも存外に多いのに驚かされることがある。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事な日の続いているうちに突然に起った著しい変化を充分にリアライズするには存外手数が掛かる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷鳴の時に蚊帳を釣ってもぐり込むのは誰が考えた事か知らぬが、ただの迷信とちがって存外理窟に合っている。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "関八州が急に狭くなったような気がして帰って来たが、東京駅から駒込までの馴れた道筋はその割に存外遠いような気もした。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし東京市民が申し合せをして私宅の風呂をことごとく撤廃し、大臣でも職工でも皆同じ大浴場の湯気にうだるようにしたら、存外｜六ヶしい世の中の色々の大問題がヤスヤス解決される端緒にもなりはしまいか。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはつまらぬ事件のようであるが、実際自分の経験では存外生徒の実験的趣味を喚起する効果があるようである。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手に仕事を途中で中止してのんきに安眠するという事は存外六ケしい事であるに相違ない。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」こう云った時にアインシュタインの顔が稲妻のようにちょっとひきつったので、何か皮肉が出るなと思っていると、果して「自然が脳味噌のない『性』を創造したという事も存外無いとは限らない」と云った。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、それでもそう沢山の音がある訳ではなく、一定数しかないのであって、それも存外多くないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしもそうであったとしたら、この『徒然草』が中学校の教科書として広く行われていたという事が、一時代の国民思想といったようなものに存外かなりの影響を及ぼしたのかもしれないと思われる。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも平凡と云えば平凡のことであるが、この平凡事を忘れているために大きな損をしている人は現在の世間にでも存外多いらしい。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは存外見上げたものだと思われる。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しい目で自然を見るという事は存外六かしい事である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
