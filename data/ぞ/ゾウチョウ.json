[
  {
    "uuid": "10410da0-e3af-5962-bd8e-5e903b931eb1",
    "entry": "増長",
    "reading": {
      "primary": "ぞうちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
