    },
    "definitions": [
      {
        "index": 1,
        "gloss": "shivering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "といふ叫びも、狸の不意の訪問に驚き、かつは喜悦して、おのづから發せられた處女の無邪氣な聲の如くに思はれ、ぞくぞく嬉しく、また兎の眉をひそめた表情をも、これは自分の先日のボウボウ山の災難に、心を痛めてゐるのに違ひ無いと解し、「や、ありがたう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月だといふのにいろいろなものの芽立ちが南に向いた畦だの崖だのにぞくぞく生えてゐた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞いてゐると、たまらなくぞくぞくしてくる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひんやりした夜氣が急に體にぞくぞく感じられて來た。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを思うとぞくぞくした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さがぞくぞくからだに浸みる。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さがすと証拠もぞくぞく出ている。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さがすと證據もぞくぞくと出てゐる。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまるでぞくぞくしました。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはお目に掛けたいほど熱心なる馬鈴薯党でしたがね、学校に居る時分から僕は北海道と聞くと、ぞくぞくするほど惚れていたもんで、清教徒を以て任じていたのだから堪らない！",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは門前の川が汎濫して道路を浸している時に、ひざまでも没する水の中をわたり歩いていると、水の冷たさが腿から腹にしみ渡って来る、そうしてからだじゅうがぞくぞくして来ると同時にまた例の笑いが突発する。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から、ぞくぞくして、ちりけ元は水のような老番頭、思いの外、女客の恐れぬを見て、この分なら、お次へ四天王にも及ぶまいと、「ええ、さようならばお静に。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あや子は身うちがぞくぞくして来たので、火鉢を抱へるやうにして顔を火の上にかざした。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と突入れつつも肩が聳え、「まったく、ぞくぞくもしよう、寒気もしよう、胸も悪かろう、唇も汚らしかろう。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも宿を出る時、外套はと気がさしたが、借りて着込んだ浴衣の糊が硬々と突張って、広袖の膚につかないのが、悪く風を通して、ぞくぞくするために、すっぽりと着込んでいるのである。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこいら一帯に、袖のない夜具だから、四布の綿の厚いのがごつごつ重くって、肩がぞくぞくする。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何だかぞくぞくするようね、悪い陽気だ。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「有名な俳優と口を利けるということが、それ程ぞくぞくと嬉しいのか」　そう自嘲しながら、信吉が第四五三号室で眼を覚ましたのは、もう正午過ぎであった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒さ凌ぎに昨夜出先で風呂を貰い、お神がもう冷めているかも知れないから、瓦斯をつけようというのを、酔っていた彼女はちょっと手を入れてみて、まだ熱そうだったので、そのまま飛びこみ、すっかり生温になっていることが解ったが、温まろうと思い、しばらくじっとしているうちに、身内がぞくぞくして来た。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服の着流しでコンクリートのたたきに蹲っていると、裾のほうから冷気が這いあがって来て、ぞくぞく寒く、やりきれなかった。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "といふ叫びも、狸の不意の訪問に驚き、かつは喜悦して、おのづから発せられた処女の無邪気な声の如くに思はれ、ぞくぞく嬉しく、また兎の眉をひそめた表情をも、これは自分の先日のボウボウ山の災難に、心を痛めてゐるのに違ひ無いと解し、「や、ありがたう。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春としなれば山奧のふかい森の中でもくされた木株の中でもうごめくみみずのやうに私のたましひはぞくぞくとして菌を吹き出すたとへば毒だけ　へびだけ　べにひめぢのやうなものかかる菌の類はあやしげなる色香をはなちてひねもすさびしげに匂つてゐる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春がくる　春がくる春がくるときのよろこびは　あらゆるひとのいのちを吹きならす笛のひびきのやうだそこにもここにもぞくぞくとしてふきだす菌　毒だけまた藪かげに生えてほのかに光るべにひめぢの類。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄闇の濕地にかげをひいてぞくぞくと這へる羊齒植物　爬蟲類蛇　とかげ　ゐもり　蛙　さんしようをの類。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがそうした気分の底に、どこか或る一つの点で、いつもとちがった不思議の予感が、悪寒のようにぞくぞくと感じられた。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
