[
  {
    "uuid": "b46e676d-7264-541c-9933-442c0fb755e9",
    "entry": "ぞくぞく",
    "reading": {
      "primary": "ぞくぞく",
      "alternatives": [
        "ゾクゾク"
      ],
      "is_heteronym": false
    },
    "grammar": {
