    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Minister of Finance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名もない一遊子ではあるけれど、私も幼い時から、富士の影を浴びて、武蔵相模で育った一児童として、永い間の外国生活から、故国へ放還された一旅人として、親友と、子供と、忠実なる案内者とに囲まれて、今富士の膝下へ来て亡き母の顔に見えまつるが如く、しみじみと見ているのだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何百年の間、武蔵相模の土に亙って逞しい埋蔵力を持ちながら、葡い松のように横に延びただけの旧家の一族に付いている家霊が、何一つ世間へ表現されないのをおやじは心魂に徹して歎いていたのだ。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵相模は新皇親征とあつて、馬蹄｜戞※大軍南に向つて発した。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで上野下野武蔵相模たちまちにして旧官は逐落され、新軍は勢を得たのかと想像される。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "秩父の山中から流れ出て、東京湾に流れ入る多那川は上流で早くから山岳地帯から離れ、武蔵相模平野の中を蜒々として東南に向うので鷺町辺では地勢も地質もいろ／＼な変化を見せています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妓楼は主に品川の島崎｜湊屋、土蔵相摸で、引手茶屋は大野屋万治方であった。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜口蔵相の節約主義がこれをどの辺で喰い止めるか。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "浜口蔵相は大整理を断行するという。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "選挙をまえにして民自党はどんなにいい評判をとりたいでしょう、ところがおきの毒さまにも十三日の新聞にあらわれた泉山蔵相の事件のようなことがあらわれて最後の幕切れとなった。",
              "citation": {
                "source": "泉山問題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉山蔵相のくだのなかで「新給与問題よりも山下春江（民主）女史の方がすきだということの方が問題だ」といったということが新聞にでていますが、これはなまよい本性にたがわず、本音でしょう。",
              "citation": {
                "source": "泉山問題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泉山蔵相がよって、醜態を演じて、さめたときはおぼえがないという、それでとおってきたこれまでの天皇制的特権者たちの共通なみにくさとはらだたしさです。",
              "citation": {
                "source": "泉山問題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方で高倉テル氏をつかまえ自由を剥奪し、ハンストを行わせるまでにしながらかくすよりあらわるるはなしで、こんなくだらないことでこれほど民自党を周章狼狽させた泉山蔵相は現代のカリカチュアです。",
              "citation": {
                "source": "泉山問題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕刊が配達されると、木挽町の蔵相官邸の門衛は、恰どそこへ来合はせてゐた自分の話し相手に頓着なくいきなり夕刊を開けて、蔵相親任の条を読下した。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "実業家の漢語５・11（夕）　勝田蔵相が最近大阪に乗込んで来た時、その旅館は御機嫌伺ひに頭を下げに往つた実業家で一杯になつたが、なかに大阪の某銀行の頭取だといふ爺さんが交つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　頭取はかう言つて、それが蔵相のお蔭ででもあるやうに鄭寧に頭を下げたが、その一刹那、何か難かしい漢語でも使つて、自分が一ぱし物識だといふ事を、居合はす皆の前で吹聴したかつた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "たつた一人勝田蔵相ばかりは流石に一寸吹き出さうとしたが、その瞬間大臣といふものは、滅多に笑つてはならない事を思ひ出して、強ひて顔を捩ぢ曲げるやうにして笑ひを噛み殺した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時利得税をうんと背負はなければならない筈の山下氏は、それだけ他人より大きな声を張り上げる資格がある者のやうに、図技けた牛のやうな調子で蔵相に挨拶した。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝田蔵相は苦し紛れに「犬馬」のやうにあんぐり口を開けて笑つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――暫くして客がどやどや帰つて往くと、蔵相は両手をさしあげて、大きな欠伸をした。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日の茶話で神戸の山下亀三郎氏が勝田蔵相にうつかり「犬馬の労を取つて欲しい」と言つたといふ事を書いた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シルエツト６・４東京日日（夕）　水野越前の天保の大改革は、思ふほどの効果があげられなかつたが、フランスにも一七五九年ごろ水野にもおとらないほどのやかましい倹約家が、時の政府の蔵相の椅子にすわつてゐて、一切の贅沢を御法度にしたことがあつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮肉なパリつ児はそれを苦に病みながらも、いろんな安物にこの蔵相の名前をつけてよろこんだものだつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "やかましやの蔵相閣下のお名前でもつけておくんだね。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔵相の名前は、Etienne de Silhouetteといつた。",
              "citation": {
                "source": "茶話",
                "author": "大正十四（一九二五）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の日本の財政のまかない手である蔵相はラジオで放送して、銃後の民の心がけというものをとかれた。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "インフレーションの悪化は防ぎようもなくて、先日のラジオで石橋蔵相が何といったでしょう。",
              "citation": {
                "source": "今度の選挙と婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "特権階級の政治的無能と没落のしるしを聖書のことばで瞞着するということは世界のどの歴史の蔵相もあえてしなかったことです。",
              "citation": {
                "source": "今度の選挙と婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の蔵相は人民を愚弄しています。",
              "citation": {
                "source": "今度の選挙と婦人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
