[
  {
    "uuid": "0b750a70-0200-59ce-b7ae-2295ab04ecbe",
    "entry": "蔵相",
    "reading": {
      "primary": "ぞうしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
