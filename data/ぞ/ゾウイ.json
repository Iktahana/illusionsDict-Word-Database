    "definitions": [
      {
        "index": 1,
        "gloss": "conferral of a posthumous rank",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
