    },
    "definitions": [
      {
        "index": 1,
        "gloss": "pathetic",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の最期の言葉は、聴く者の心に哀切な響きを残した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "戦地の兵士が故郷を思う手紙には、哀切な心情が綴られていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "そのバイオリンの音色は、聴く者の涙を誘う哀切な調べだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "別れ際に交わされた二人の会話は、哀切極まるものがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "老いた母が幼い子の遺品を抱きしめる姿は、見る者に哀切の念を抱かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の詩には、失われた青春への哀切な思いが込められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一言にして言えば、それは時間の遠い彼岸に実在している、彼の魂の故郷に対する「郷愁」であり、昔々しきりに思う、子守唄の哀切な思慕であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち蕪村は、その藪入りの娘に代って、彼の魂の哀切なノスタルジア、亡き母の懐袍に夢を結んだ、子守歌の古く悲しい、遠い追懐のオルゴールを聴いているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の亡き母に対する愛は、加賀千代女の如き人情的、常識道徳的の愛ではなくって、メタフィジックの象徴界に縹渺している、魂の哀切な追懐であり、プラトンのいわゆる「霊魂の思慕」とも言うべきものであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは柚の花の侘しく咲いている、昔々の家に鳴るオルゴールの音色のように、人生の孤独に凍え寂しむ詩人の心が、哀切深く求め訪ねた家郷であり、そしてしかも、侘しいオルゴールの音色にのみ、転寝の夢に見る家郷であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇の調子が高まって妾の情人の哀切な心を表した舞姿に異国人が海の彼方の歌劇的な情味を感じた時、若い武士になった佐野が舞台に現れました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢で慈母を喪つた悲しみは、むしろ現實のそれに數倍して哀切である。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢に魘えて夜泣きをする幼兒の聲ほど、生命の或る神祕的な恐怖と戰慄とを、哀切に氣味わるく感じさせるものはない。",
              "citation": {
                "source": "夢",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば私の詩を讀む人は、ひとへに私の言葉のかげに、この哀切かぎりなきえれぢいを聽くであらう。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく彼等は、その恋が到底及ばぬものであり、身分ちがひの果敢ないものであるといふことを、自ら卑下して意識することで、一層哀切にやるせないリリシズムを痛感し、物のあはれの行きつめた悲哀の中に、自らその詩操を培養して居たであらう。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特にさうした失恋の動機によつて、山野に漂泊したと言はれる西行には、就中月の歌が極めて多く、且つそれが皆哀切でやるせないフエミニストの思慕を訴へてゐる。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は涙もろくなり、情緒に溺れ、哀切耐えがたくなって、嗚咽する。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには常に、何かの訴えているものがあり、哀切しているものがあり、欲情しているものがいる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんの繁劇な都会の濠川の人為的生活が、雪という天然の威力に押えつけられ、逼塞した隙間から、ふだんは聞取れない人間の哀切な囁きがかすかに漏れるのを感ずるからであった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときには、男を揶揄するほどぴんとして気嵩なところがあり、ときには哀切胸も張り裂ける想ひが溢れ、それでゐて派手で濃密である。",
              "citation": {
                "source": "小町の芍薬",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けども、あんな立派な体格をして、あたし、絶対そんなこと信じられないわ」　必ず自分の熱誠で男を助けて見せるといふ哀切な息使ひが、せん子の言葉以上に桂子を刺戟した。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀切極まる名残の尾を私たちのこころの上に覆い冠せてなお幾日か山の記憶は、先生の記憶は、私たちを奇妙な憂愁へとたぶらかし続けることでありましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今はただ天道様の無情を怨むばかり……といったような、それはそれは哀切を極めたものでしたが、その文句には全く泣かされましたよ。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "友には理不尽なる嘲笑を浴びせられてその誤解を解くの道なし、ここにおいて神に向いてただ涙の目を注ぐのみと、哀切の極である。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの哀切なる悲声が彼の魂の咽喉を絞りて出でたるがために、多くの患難悲痛にある人々が彼によって救わるるのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その愚劣の中に、魂の哀切なる呻きが聞こえる。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に三友はヨブの哀切なる懇求に接しても、依然としてヨブを圧する態度を取りて、庇護同情を少しも現わそうとはしなかった。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寂寞を僅かに破るものは、牧童の吹き鳴らす哀切なる牧笛の音であるのだろう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その哀切な虫の調べがなんだか全身に沁み入るように覚えた。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寂寞を僅かに破るものは、牧童の吹き鳴らす哀切なる牧笛の音であるのだらう。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の方で鳶がしきりに鳴く、哀切な声だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三はもちろん他の男にも同じ表情をしあるいはもっと哀切｜凄婉な眉目を見せるであろう瞬間を、しばしば想像したものだったが、昨夜のように気分の険しさの魅惑にも引かれた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　葉子は哀切な言葉でしきりに訴えた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い肉体に重すぎる生活の荷にひしがれて病気を発することも、その病気のために働きを休めば一家は饑餓にさらされることから遂に倒れてのち已む決心で働きとおす哀切な強い精神を持つ少年青年たちも、今日ただいま決して一人二人ではないであろう。",
              "citation": {
                "source": "『静かなる愛』と『諸国の天女』",
                "author": "――竹内てるよ氏と永瀬清子氏の詩集――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんたるあいせつの笛の音だらう鬼のやうなものがゐて木の間で吹いてる。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
