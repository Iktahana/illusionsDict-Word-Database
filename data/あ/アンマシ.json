  {
    "uuid": "52329413-cc7d-5575-a169-dd42e0b81ba8",
    "entry": "あんま師",
    "reading": {
      "primary": "あんまし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "masseuse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんま師は盲目の人が多かった職業だ。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の技術は師弟関係で伝承されている。",
              "source": "幻辞"
            },
            {
              "text": "医学的にあんま師の施術は効果がある。",
              "source": "幻辞"
            },
            {
              "text": "あんま師になるには国家試験に合格する必要がある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツチームであんま師が疲労回復を担当している。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の人手不足は社会問題だ。",
              "source": "幻辞"
            },
            {
              "text": "地域によってあんま師の質に差がある。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の技術の習得には長年の修行が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の賃金は地域によって異なる。",
              "source": "幻辞"
            },
            {
              "text": "高齢者はあんま師の施術を望む人が多い。",
              "source": "幻辞"
            },
            {
              "text": "あんま師が医療の現場で活躍している。",
              "source": "幻辞"
            },
            {
              "text": "法律的にあんま師の活動は厳格に規定されている。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の学校は全国に数十校ある。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の倫理綱領は厳しく守られている。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の仕事は肉体的に負担が大きい。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の歴史は日本の医療史でも重要である。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の技術の中には秘伝があるとも言われている。",
              "source": "幻辞"
            },
            {
              "text": "あんま師が統合医療の一部として注目されている。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の組織は全国規模で団結している。",
              "source": "幻辞"
            },
            {
              "text": "あんま師の社会的地位の向上が求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その他、しじみ屋、下駄の歯入れ、灰買い、あんま師、衣紋竹売り、説経祭文、物真似、たどん作り……そういった人たちが、この竜泉寺名物、とんがり長屋の住人なので。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
