    "definitions": [
      {
        "index": 1,
        "gloss": "remainder",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あんましについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんましという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんましの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんましが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんましを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんましについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんましの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんましの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんましが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんましという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんましという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんましについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんましを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんましは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんましについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんましが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんましは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんましの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんましは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんましは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
