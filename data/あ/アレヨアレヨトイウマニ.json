            {
              "text": "あれよあれよという内に子どもが大きくなった。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよという間に一年が過ぎた。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよという内にキャリアが変わった。",
              "source": "幻辞"
