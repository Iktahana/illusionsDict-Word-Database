        "examples": {
          "standard": [
            {
              "text": "あああ、目覚まし時計の音がうるさい。",
              "source": "幻辞"
            },
            {
              "text": "あああ、仕事の期限が今日だった。",
              "source": "幻辞"
            },
            {
              "text": "実験が失敗した時、研究者は思わずあああと声を出した。",
              "source": "幻辞"
            },
            {
              "text": "物語の主人公はあああと叫んで、絶望から立ち直った。",
              "source": "幻辞"
            },
            {
              "text": "子どもがテストで100点を取ってあああと喜んだ。",
              "source": "幻辞"
            },
            {
              "text": "医者はあああと患者の病状を聞いて、心配そうな表情をした。",
              "source": "幻辞"
            },
            {
              "text": "裁判長はあああと判決文を読み上げた。",
              "source": "幻辞"
            },
            {
              "text": "選手は優勝した時にあああと歓声を上げた。",
              "source": "幻辞"
            },
            {
              "text": "木の上の野鳥があああと鳴いて、飛び立った。",
              "source": "幻辞"
            },
            {
              "text": "歴史家はあああと古い文書を見つけて、興奮した。",
              "source": "幻辞"
            },
            {
              "text": "シェフはあああとソースの味を確認してから出した。",
              "source": "幻辞"
            },
            {
              "text": "観光客はあああと壮大な景色を目の前にして立ち止まった。",
              "source": "幻辞"
            },
            {
              "text": "友人の訃報を聞いてあああと泣いた。",
              "source": "幻辞"
            },
            {
              "text": "音楽を聴いてあああと心が落ち着いた。",
              "source": "幻辞"
            },
            {
              "text": "経営会議であああという唸り声が聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "学生は難しい問題を見てあああと困った顔になった。",
              "source": "幻辞"
            },
            {
              "text": "患者はあああと痛みに耐えながら治療を受けた。",
              "source": "幻辞"
            },
            {
              "text": "法廷であああという驚きの声が上がった。",
              "source": "幻辞"
            },
            {
              "text": "運動選手はあああと疲労で倒れ込んだ。",
              "source": "幻辞"
            },
            {
              "text": "自然愛好家はあああと美しい夕焼けを眺めた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あああ」と私は、椅子から起つて、欠伸をした。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ」馬場は溜息ついて縁台にごろんと寝ころがった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああ、舌打ちの音まで馬場に似て来たようだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はむしろに座って、「わあああああああああ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが不思議なことは、「わああああんああああ。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしはゆっくりでいいんだからお前さきにおあがり、姉さんがね、トマトで何かこしらえてそこへ置いて行ったよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしもそう思う。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あああの白いそらの帯がみんな星だというぞ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああれ工兵の旗だねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ大きな落日が見たい」　彼は家を出て遠い展望のきく場所を捜した。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああああ本道じゃ、何ね、この間の梅雨に水が出て、とてつもない川さ出来たでがすよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああありがとうございます。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああありがとうございます。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああありがたい、山猫さま。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああありがたい山猫さま。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はますますよろこんで、「ああありがたや、山猫さま。",
              "citation": {
                "source": "蜘蛛となめくじと狸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしはゆつくりでいいんだからお前さきにおあがり。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あああたしもさう思ふ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
