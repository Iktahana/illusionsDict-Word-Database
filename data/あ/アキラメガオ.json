        "examples": {
          "standard": [
            {
              "text": "試験の結果を見てあきらめ顔になった。",
              "source": "幻辞"
            },
            {
              "text": "彼はあきらめ顔で荷物をまとめた。",
              "source": "幻辞"
            },
            {
              "text": "母親はあきらめ顔で話を聞いていた。",
              "source": "幻辞"
            },
            {
              "text": "あきらめ顔で敗北を認める選手もいる。",
              "source": "幻辞"
            },
            {
              "text": "医者の話を聞いてあきらめ顔になった患者。",
              "source": "幻辞"
            },
            {
              "text": "面接官はあきらめ顔で応募者を見つめた。",
              "source": "幻辞"
            },
            {
              "text": "あきらめ顔で終業のベルを待っている。",
              "source": "幻辞"
            },
            {
              "text": "長年の努力が実らずあきらめ顔になった。",
              "source": "幻辞"
            },
            {
              "text": "人生相談であきらめ顔をしている人がいた。",
              "source": "幻辞"
            },
            {
              "text": "あきらめ顔をしながら現実と向き合っている。",
              "source": "幻辞"
            },
            {
              "text": "写真ではあきらめ顔の表情が捉えられている。",
              "source": "幻辞"
            },
            {
              "text": "演劇であきらめ顔の演技が求められた。",
              "source": "幻辞"
            },
            {
              "text": "キャスターはあきらめ顔でニュースを読んだ。",
              "source": "幻辞"
            },
            {
              "text": "子どもがあきらめ顔で宿題をしている。",
              "source": "幻辞"
            },
            {
              "text": "あきらめ顔の表情は誰の心にも響く。",
              "source": "幻辞"
            },
            {
              "text": "パフォーマンス評価ではあきらめ顔は減点対象だ。",
              "source": "幻辞"
            },
            {
              "text": "心理学の教科書ではあきらめ顔の研究結果が掲載されている。",
              "source": "幻辞"
            },
            {
              "text": "年配の人がよくあきらめ顔をしていると思う。",
              "source": "幻辞"
            },
            {
              "text": "友人があきらめ顔で相談を打ち切った。",
              "source": "幻辞"
            },
            {
              "text": "人相学ではあきらめ顔は性格を表すと考えられている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「持ちたいですがねえ……」持ちたいですが、現在の身の上では、火星探険と同じように、自分の力では出来ない相談だと源一はあきらめ顔になる。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞いても、やっぱり信じられまいと思うが――」　と博士はあきらめ顔で、「こういう謎がおわかりかな。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人はさもあきらめ顔に大佐の傍に従っていた。",
              "citation": {
                "source": "探偵小説アルセーヌ・ルパン",
                "author": "EDITH AU COU DE CYGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……可惜、あなたほどな人物を、七年もこの地の牢城長官の小使みたいに朽ちさせておくのは勿体ないし、また将来とても、とうてい、官界の堕落腐敗のなかに長く晏如としていられるあなたでもないことは知れきっていると思ったからだが……」　と、さすが才略の弁に富む呉用もいまはあきらめ顔して。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ひとえに、首を刎ねられ候えとのみ、どう諭しても、玄蕃の心はかたく、一切、余事を申しませぬ」「そちがいうてみても、それのみとあれば、なお強いるは、情けであるまい」　秀吉は、ふっと、あきらめ顔に、顔の筋を解いた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうから、帝はご不予（病気）を口実に、一日でも長くここの逗留を延ばそうとしておられたらしいが、「いまは、ならぬか」　と、おあきらめ顔と共、廉子だけを室へ召して、こうささやかれた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ではやはり……」と、尊氏も今は半ばあきらめ顔に。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに、あきらめ顔の尊氏は、こう彼をねぎらった。",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            }
          ]
        }
