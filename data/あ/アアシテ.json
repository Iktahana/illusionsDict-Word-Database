        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ああして毎日の仕事をこなしている。",
              "source": "幻辞"
            },
            {
              "text": "営業はああして顧客を説得する。",
              "source": "幻辞"
            },
            {
              "text": "実験はああして進めるのが標準だ。",
              "source": "幻辞"
            },
            {
              "text": "作家はああして物語を構成する。",
              "source": "幻辞"
            },
            {
              "text": "教育者はああして学習環境を整える。",
              "source": "幻辞"
            },
            {
              "text": "医者はああして診断を下す。",
              "source": "幻辞"
            },
            {
              "text": "法律家はああして法律を適用する。",
              "source": "幻辞"
            },
            {
              "text": "選手はああして試合に臨む。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではああして営まれている。",
              "source": "幻辞"
            },
            {
              "text": "歴史家はああして過去を研究する。",
              "source": "幻辞"
            },
            {
              "text": "シェフはああして完璧な料理を作る。",
              "source": "幻辞"
            },
            {
              "text": "旅人はああして目的地に到着する。",
              "source": "幻辞"
            },
            {
              "text": "セラピストはああしてクライアントを支援する。",
              "source": "幻辞"
            },
            {
              "text": "アーティストはああして作品を完成させる。",
              "source": "幻辞"
            },
            {
              "text": "マネージャーはああしてプロジェクトを進める。",
              "source": "幻辞"
            },
            {
              "text": "保護者はああして子どもを導く。",
              "source": "幻辞"
            },
            {
              "text": "看護師はああして患者の世話をする。",
              "source": "幻辞"
            },
            {
              "text": "検察はああして起訴を進める。",
              "source": "幻辞"
            },
            {
              "text": "コーチはああしてチームを指導する。",
              "source": "幻辞"
            },
            {
              "text": "保全活動家はああして自然を守る。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ごらん下さい、私はいまこうしています、ああしていますと、いちいち説明をつけなければ指一本うごかせず咳ばらい一つできない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、乙姫はご自分の家へやつて來た珍客を階段まで出迎へて、さうして安心して、あとはあなたのお氣の向くままに勝手に幾日でもここで遊んでいらつしやるやうにと、素知らぬ振りしてああしてご自分のお部屋に引上げて行くといふわけのものぢやないんですかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただああして幽かに笑つて琴をかき鳴らしたり、またこの廣間をふらふら歩きまはつて、櫻桃の花びらを口に含んだりして遊んでゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして月給取も店員も運転手も職工も小僧も女事務員も町娘も女給も仲居もガソリンガールも一緒になって踊っているのは何と美しく善いことだろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして一銭も要らずに誰れでもが飛び入りで踊って遊べるというのは何といいことであろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして踊っている間はどんな苦労も忘れているだろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "池につないでおくと、たぶん職人か土方だろうが、よくいたずらをして困るので、ああして引き上げておくのである。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その物慣れた仕草から、星野からの手紙が何通もああして開かれたのだと園に思わせた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆や婆やたらいって、大事にしておくれなさったが……ま、行く行くは皆ああして羽根が生えて飛んでいかれるは定なれど、何んとやら悲しゅうてなもし。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて王子のからだは一か月ほど地の上に横になってありましたが、町の人々は相談してああして置いてもなんの役にもたたないからというのでそれをとかして一つの鐘を造ってお寺の二階に収める事にしました。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして僕をすてて行つても女の身で差当り困るだらうと思つて、どうにか出来るまで辛抱して居てくれといつでも頼むんだ。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああしてしまえば東京に用事は無いのだ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "御当家へ迷惑は懸ないから、帰るまでああして蔵匿て置いて下さらないか、衣服に血が附てたり、おどおどしている処を見ると、邪慳な姑にいびられる嫁か。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもひいひい泣きまして耳の遠い私でも寝られませんし、それに主公、二日もああして梁に釣上げて置いちゃあ死んでしまうじゃございませんか。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてああしてこうして、と独りほくほく頷きて、帳場に坐りて脂下り、婦人を窺う曲者などの、万一入り来ることもやあらむと、内外に心を配りいる。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいえ、ああして置くときっと庄屋様からお前を呼びに来て、手詰の応対、寅刻を合図に首討って渡せとなります。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああしておいて様子を見ましょう。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それもそうだな、じゃ、一ぺんやってみようかな、っていう訳で、この店のボーイになったというんだが、やり出してみると案外働くことが面白いので、ああして一生懸命一日も休まず働いてるんだよ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、ああして、お城に住んでいるっていうのに、ぼくときたら、こんな箱しかないんだからなあ。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなは、ああして、ご主人の考えを狩りに連れていこうと、むかえにきたんですよ。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ、ああして、はだしのまま、こんな世界の遠くまでも、こられたんじゃないか。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとうさんが、ああして、おかあさんを呼んでるじゃないの」　それから、すこしすると、今度は、深いため息が聞えてきました。",
              "citation": {
                "source": "お墓の中の坊や",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして、あんな高いとこにぶらさがって、光ってるんなら光っているがいい。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああして、舌を出すようすは、ほんとうによく似合っている！",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、乙姫はご自分の家へやつて来た珍客を階段まで出迎へて、さうして安心して、あとはあなたのお気の向くままに勝手に幾日でもここで遊んでいらつしやるやうにと、素知らぬ振りしてああしてご自分のお部屋に引上げて行くといふわけのものぢやないんですかね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただああして幽かに笑つて琴をかき鳴らしたり、またこの広間をふらふら歩きまはつて、桜桃の花びらを口に含んだりして遊んでゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで一瞬の生も無駄にせず、貴重な時間を浪費すまいと考へ、ああして毎日、時計をみつめて居るのです。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが坊さん、ああして難儀させにや、子供は一人前になれませんだ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごらん下さい、私はいまかうしてゐます、ああしてゐますと、いちいち説明をつけなければ指一本うごかせず咳ばらひ一つできない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
