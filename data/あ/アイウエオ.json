    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese syllabary",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子どもはあいうえおから日本語を学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおは日本の基本的な文字体系だ。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室にあいうえおのポスターが貼ってある。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおの発音は日本語学習の第一歩だ。",
              "source": "幻辞"
            },
            {
              "text": "古い教科書ではあいうえおが重要視されていた。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおを覚えるのに時間がかかった。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおは音韻体系を表現している。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおの順序は伝統的に決まっている。",
              "source": "幻辞"
            },
            {
              "text": "外国人学習者はあいうえおから始める。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおなしでは日本語を読めない。",
              "source": "幻辞"
            },
            {
              "text": "タイピング練習であいうえおを何度も打つ。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおは五十音図の一部だ。",
              "source": "幻辞"
            },
            {
              "text": "子どもの頃あいうえおを歌で覚えた。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおの字形は芸術的である。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおを正しく発音することは重要だ。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおは平仮名の基礎を構成する。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおをマスターすることが日本語学習の第一歩だ。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおは日本文化の重要な要素だ。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおの研究は言語学の対象だ。",
              "source": "幻辞"
            },
            {
              "text": "あいうえおから始まる言葉は多い。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "本体はマイクロコンピューターを使ったシステムで組み、テレビとのインターフェイスを付けて「あいうえお」の文字を順に画面上に表示していく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面上に「あいうえお」を順に出していき、確定された文字を引き取って文章を続けていくプログラムは、玉城重信が中心になってすぐに書き上げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なので、このお遊び訳でも、あいうえお作文のうち「ぬ」と「ね」は似てるだろうってことで、「ね」を飛ばしたりしております。",
              "citation": {
                "source": "あップルパイを",
                "author": "ケイト・グリーナウェイ　え",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
