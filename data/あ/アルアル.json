[
  {
    "uuid": "37fa0522-c661-5d50-83eb-db9c4851bdbd",
    "entry": "あるある",
    "reading": {
      "primary": "あるある",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "I can relate (to that)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝寝坊して遅刻するあるある。",
              "source": "幻辞"
            },
            {
              "text": "スマートフォンを忘れて焦るあるある。",
              "source": "幻辞"
            },
            {
              "text": "職場の人間関係のあるある。",
              "source": "幻辞"
            },
            {
              "text": "医者の診察室での待ち時間が長いあるある。",
              "source": "幻辞"
            },
            {
              "text": "学生時代の試験前夜の勉強あるある。",
              "source": "幻辞"
            },
            {
              "text": "社会人になってからの疲労感あるある。",
              "source": "幻辞"
            },
            {
              "text": "ダイエット中の誘惑に負けるあるある。",
              "source": "幻辞"
            },
            {
              "text": "旅行で荷物が多くなるあるある。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ選手がやる縁担ぎあるある。",
              "source": "幻辞"
            },
            {
              "text": "料理を作るときレシピを見ないあるある。",
              "source": "幻辞"
            },
            {
              "text": "買い物に来たのに別のものを買ってしまうあるある。",
              "source": "幻辞"
            },
            {
              "text": "映画館で予告編の方が面白いあるある。",
              "source": "幻辞"
            },
            {
              "text": "家計簿が続かないあるある。",
              "source": "幻辞"
            },
            {
              "text": "年末大掃除で思い出の品が出てくるあるある。",
              "source": "幻辞"
            },
            {
              "text": "引っ越しで行方不明になるものあるある。",
              "source": "幻辞"
            },
            {
              "text": "コーヒーを作り忘れるあるある。",
              "source": "幻辞"
            },
            {
              "text": "SNSで見かける自撮り技あるある。",
              "source": "幻辞"
            },
            {
              "text": "懐かしい曲が流れると歌ってしまうあるある。",
              "source": "幻辞"
            },
            {
              "text": "駅で反対方向に進んでしまうあるある。",
              "source": "幻辞"
            },
            {
              "text": "本を買っても積読になるあるある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "全く別の世界だぞ、　気を落ちつけて（黄のひかり）あるある、あるには有るがあの泥炭をつくったやつの甥か孫だぞ、黄のひかりうすあかり鳴れ鳴れかしは。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅に近い盛り場にあるある店の看板は、人がよく「ボンラクサ」と読んでなんのことだろうと思うそうである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は斯く云いつつ、瓶を差し上げて太陽の光線に透かしてみたが、「オオ、あるある果してみょうな物があるある」と叫んで、好奇心は満面にあふれ、口栓を抜くのももどかしと、かたわらの巖石をめがけて投げつけると、瓶は微塵に砕け、なかから黄色い紙に何か細々と記した物が出て来た。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あるある、一人ある。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん、あるある。",
              "citation": {
                "source": "少年探偵　呉田博士と与一",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくびょう者でひときわ口やかましい者、お心当たりござりませぬか」「あるある！",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなもの目にかからば、おきてお定め書きにもあるとおり、証文の吟味もうけるべきはず、いっこう見かけなんだわい」「それはちと奇態、なんぞ変わったところ、目にとまった覚えござらぬか」「さようのう……いや、あるある、一つ覚えがござるわい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの道の先の、ほら左側に赤松があるでしょう」猟人「あるある」少女は猟人の方を見て笑っている。",
              "citation": {
                "source": "春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に何か木の葉でも冠せてあると見えて、籠の中に手を突つ込みながら、「ほう、あるある。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむあるある寺参りだ。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志藤森が、論文中にあるある種の文句を、不適当のものとして指摘したことは正しい。",
              "citation": {
                "source": "前進のために",
                "author": "――決議によせて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あした出る筈で、その切符を買って来てあるある船は、あさっての出帆に延びていた。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おおあるある一つある。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すればするほど、彼のうちにあるある大きな力が感じられた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あるある………。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやむしろ彼の中にあるある物は、その事実である事を、祈りさえした。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると直傍に、青に白の線のある腕章をつけた交通巡査がいて、「あるある、出雲町の交番の裏だ」と深切におしえてくれた。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "篤介は広子にも顔馴染みのあるある洋画研究所の生徒だった。",
              "citation": {
                "source": "春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊ベルリンのベテカをよんで、フレデリック博物館の art gallery のところを見ると、あるあるレムブラント、ルーベンス、自分まだ一つも本ものは見たことなきデューラーその他。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがややあって、斜酣があるあると言って膝を打つのだ。",
              "citation": {
                "source": "採峰徘菌愚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさか、奥州仙台陸奥守のことでござるから、嘘にしても何かよるところがあるでござろうがな」「あるある、大いにある、そのよるところを話してお聞かせ申そう」　ここまで主客の間に話が進んだ時、来客で話の腰を折られて、それぎりになりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思って、夜中に、またまた醍醐まで、びっこ足を引きずり引きずり立戻って、藪の中をさがしてみると、まだあるある、いい気持ですやすや眠っているような形で、袋が藪の中に横たわっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……伊集院さんの方にはないかしら、そういう理想的の別嬪が」　すると伊集院考えたが、「うん、あるある、一人ある！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小圓太にとってそれは、あとからあとからまだあるあると口の中へ放り込まれる美味しいお菓子にもさも似ていた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってもし残りの八万二千ホグスヘッドが、海外に送り出されて国内においてより需要のあるある物と交換され得ないならば、その輸入は直ちに止み、そしてそれと共に、この八万二千ホグスヘッドの煙草を年々購買すべき財貨の製造に現在用いられている大英国のすべての住民の生産的労働は止むであろう。",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "』しかし大英国の生産的労働のこの部分は、国内においてより需要のあるある物を購買すべき何らかの他の種類の財貨の生産に用いられ得ないであろうか？",
              "citation": {
                "source": "経済学及び課税の諸原理",
                "author": "PRINCIPLES OF POLITICAL ECONOMY AND TAXATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "情あるあるじの子の、情深き賜物を辞むは礼なけれど……」「礼ともいえ、礼なしともいいてやみね。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからと、――まだあるある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとなし手もちぶさたな時がすぎて、やがて日本側の主賓であるある評論家が入って来た。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
