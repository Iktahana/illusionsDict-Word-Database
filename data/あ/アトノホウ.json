        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議の議題は、後の方で詳細を詰めることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この小説は、後の方になってから物語が急展開する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山のルートは、後の方ほど勾配がきつくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一年を通して見ると、作物の収穫は後の方に集中している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "列の後の方に並んでいたので、窓口まで時間がかかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "テストの難易度は、後の方の問題ほど高かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「すみません、後の方に回してもらえませんか？」と、彼女は恐る恐る尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、スピーチの後の方で最も重要なメッセージを強調した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "切符売場前の長い列の、私は最後の方だつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の背後の方の戸が開く音を聞くと直ぐ彼は振り返つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の方でダーダーと云う者があるからふりかえると、五、六｜間後の畔道の分れた処の石橋の上に馬が立っている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不思議な事には巻物の初めの方に朽ち残った絵の色彩は眼のさめるほど美しく保存されているのに、後の方になるほど絵の具の色は溷濁して、次第に鈍い灰色を帯びている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今唇の前後の方向の位置をＸで表わし、唇の開きをＹで表わすとるると、イエアオウと順に発音する場合にＸＹで表わされる直角坐標図の上の曲線はざっと半円形のようなものになる。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "十歳位の男の子が二人來て後の方で見て居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内に土方のやうなものが二三人すぐ背後の方へ來て材木の上に腰かけて何かしきりに話し合つて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし後の方の理由からとしたならこれは卒爾には済まされんことだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の方で半次見て居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀野、今後の方針に就て。",
              "citation": {
                "source": "講演會　其他（大正十五年二月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、暫くすると、私は不意に背後の方に低い靴音を耳にした。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしたぶんそれは後の方であったらしい。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻煙草を吸い出したのもやはり中学時代のずっと後の方であったらしい。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、後の方の説が勢力を占めて、その役目を云いつけられた武士どもは、身分柄にもあるまじき拐引同様の所行をくり返すことになったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "真蔵はなるべく後の方に判断したいので、遂にそう心で決定てともかく何人にもこの事は言わんことにした。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ほんとかって、あなたがそれを知らんということはない、だけれども知らなかったらそれまでの話です、もうあなたも知ってみればこの後の方法をつけんじゃア』『どうすればええだろう？",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の顔が見えると妹は後の方からあらん限りの声をしぼって「兄さん来てよ……もう沈む……苦しい」　と呼びかけるのです。",
              "citation": {
                "source": "溺れかけた兄妹",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かやはたちまちその殻に抑え切れ無い程な好奇心と愛着を生じてしまって、まだほかに幾つも幾つも欲しかった、それを見付けるために、雑朶の間をあちらこちら歩いて居ると、後の方の婆やと吉蔵との間に、いがみ合う様な笑い声が突然起った。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようよう、」とまた後の方で、雀海中に入った時のごとき、奇なる音声を発する者あり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどその時、四五十歩を隔てた、夜店の賑かな中を、背後の方で、一声高く、馬の嘶くのが、往来の跫音を圧して近々と響いた。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当に執拗い空瓶だこと」と、今度は妹娘が拾って投げようとすると、その時｜背後の方より、「二人とも何をしている、拾ったのは何んだ」と呼んだ者がある、振り向いて見ると父のモンテス博士で、ニコニコしながら進みよる。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の方を振り返へると、看守長の宮部と云ふ人が、被告席の一番後の片隅に椅子に凭つてゐるのを見付けた。",
              "citation": {
                "source": "逆徒",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は一倍群ったが、向側が崖沿の石垣で、用水の流が急激に走るから、推されて蹈はずす憂があるので、群集は残らず井菊屋の片側に人垣を築いたため、背後の方の片袖の姿斜めな夫人の目には、山から星まじりに、祭屋台が、人の波に乗って、赤く、光って流れた。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の方にてまた別人の声、「赤城様、得三様。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　卒然従者を顧みて立住まれる少年は、へいげん等を去ること数十歩ばかり後の方にありて、浪打際を散歩せるなり。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後の方も見えるから、振返つて背後を見ると、娘は何故か、途中へ踞んでて動かない。",
              "citation": {
                "source": "廓そだち",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――処をすかさず受取るんだ、よう、と云って後の方で。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十一）　この時、背後の方から不意に物の気息が聞えて、何者か忍び寄るようにも思われたので、市郎は手早く蝋燭を把って起上ると、余りに慌てたので、彼は父の死骸に蹉いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之も風の吹き廻しで、声は却って後の方へ響くので、巡査は彼女が重太郎を呼ぶ声を聞いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ最初に死骸を見付けた本人ですから、名主さん達からいろいろのことを訊かれていましたが、わたしは何だか気が咎めるので、なるたけ後の方へ引きさがって、遠くから覗いていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
