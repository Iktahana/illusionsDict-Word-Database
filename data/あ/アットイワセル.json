    "definitions": [
      {
        "index": 1,
        "gloss": "to startle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あっと言わせるについて考えてみました。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるの意味を理解しました。",
              "source": "幻辞"
            },
            {
              "text": "日常生活であっと言わせるが使われています。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるに関する知識を深めました。",
              "source": "幻辞"
            },
            {
              "text": "辞書であっと言わせるを調べました。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるの用法について学びました。",
              "source": "幻辞"
            },
            {
              "text": "様々な分野であっと言わせるが活用されている。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるの応用例を見つけました。",
              "source": "幻辞"
            },
            {
              "text": "専門家があっと言わせるについて論じている。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるについての研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "教育の場であっと言わせるが教えられている。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるの歴史を追うことは興味深い。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からあっと言わせるを理解する。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるの変化に気づきました。",
              "source": "幻辞"
            },
            {
              "text": "言語や文化におけるあっと言わせるの重要性。",
              "source": "幻辞"
            },
            {
              "text": "分析結果からあっと言わせるの特性がわかった。",
              "source": "幻辞"
            },
            {
              "text": "一般的なあっと言わせるの使い方を習得しました。",
              "source": "幻辞"
            },
            {
              "text": "複雑なあっと言わせるの概念を説明する。",
              "source": "幻辞"
            },
            {
              "text": "あっと言わせるに関連する他の用語がある。",
              "source": "幻辞"
            },
            {
              "text": "最新のあっと言わせるに関する情報を入手した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのかわりおまえは、おれの死んだ息子の読んだ本をこれから一生けん命勉強して、いままでおれを山師だといってわらったやつらを、あっと言わせるような立派なオリザを作るくふうをしてくれ。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつは人をあっと言わせることにしか、生甲斐を感じていないんです。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、そのような推理をしておいて、その筋の真ん中を少し向こうへやって、聞き手にその始まりと結論だけを見せようものなら、人をあっと言わせることができるわけだが、まあ、ほんのこけおどしだ。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "乱歩氏ほどの作者に、あれだけの自信があるのだから、結末は定めし、読者をあっと言わせるに相違ないと誰しも期待したに相違ない。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "久子――いまあちらの余興がすんだあとで、妾たち四人で何か奇抜な、みんなをあっと言わせるようなことをしてみたいと思ったんですの。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぞというトリックなしに最後まで読者にサスペンスをもたせることができれば、それに越したことはないが、現実の事件にはそうした場合はほとんどないから、まず多少の伏線を示しておいて、最後にトリックであっと言わせるということが多くの場合必要になってくる。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に人をあっと言わせる安さんだと思ったから、あたし、こんなことになったんだわ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ヤンの姿が消えたと思ったとき、またも座間をあっと言わせるようなことが起った。",
              "citation": {
                "source": "人外魔境",
                "author": "有尾人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら今度は勝太郎が『菩提樹』でも唄って、あっと言わせる番である。",
              "citation": {
                "source": "勝太郎",
                "author": "兼常清佐",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰もがあっと言わせるようなことを言わないのは、誰もあっと言わせるような話の種を持っていないということになる。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "上床",
                "note": "青空文庫"
              }
            },
            {
              "text": "三輪の万七親分にあっと言わせるつもりで、熊吉を挙げてみるがいい」「ヘエ――」　平次は精いっぱいの激励をするのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "唖娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体その幽霊は誰だったんだ」「番頭の左太松という二十七の若い男、――そいつが百物語が済んで、灯がみんな消えるのを合図に、芝居の幽霊の装束で出て来て、あっと言わせる趣向だったんで――」「フーム」「出て来てあっと言わせたまでは筋書通りだった。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百物語",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も世間をあっと言わせるような、珍しい生活形式を強いて作りだそうというのではない。",
              "citation": {
                "source": "次郎物語",
                "author": "第五部",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、一たび、「何か人をあっといわせるようなことをしてみたい」　と、思うと、もう腹の虫がむずむずして来て、いても立ってもおられなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて言えば、雪子を警官の手から奪うという、大それた暴挙が「何か人をあっといわせるような破天荒なことを今直ぐしてみなくっちゃ、おれの気が済まない……」　という、たった今さき腹の虫を動かせて来た不意の思いつきに、ピッタリ合っているではないかと咄嗟に自分に云いきかせる余裕だけは、さすがに残っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、自首したということは、「何か人をあっといわせるような、意表外のことを……」　と、つねに考えている豹吉の心にかなったわけだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから小さい時から飛行家が曲乗りを研究するように、他人をあっといわせる曲死の方法を研究していた。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾城買の四十八手は、何一つ心得ぬことのない藤十郎様が、密夫の所作を、どなに仕活すか、さぞ見物衆をあっといわせることだろうと、夢中になっての高話じゃ。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあいつの目的はその大胆な行為を、なるべく多勢の人に見せてあっといわせることにあるんですからね。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は実は今日の園遊会に、何か変わった趣向をして皆様をあっといわせるつもりで、家内と相談して、近頃東京じゅうの金持ちが名前をきくだけでも慄えあがっている仮面強盗に変装してご婦人のかたを吃驚させようと目論んでいたのです。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ二十二才のわかい科学者だったぼくには、これに一｜生をささげて、いつかは世間のやつどもを、あっといわせるような研究をやりとげようと決心したんだ」　透明人間は、いつもの、いんきくさい世をのろったような声とはまるでちがう、わかい張りのある声で話しつづけた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "慄えながらも、その手はしかし、帽子のなかからウサギを取り出して、人をあっといわせる技術をけっして忘れてはいなかった。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "ド・エスコバアルは大急ぎで、あっといわせるような速さではじめた。",
              "citation": {
                "source": "なぐり合い",
                "author": "WIE JAPPE UND DO ESCOBAR SICH PRUGELTEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじいさん、ハイカラぶって洋服着ていても、もう腰が曲りかけとるのに、そんな破けた洋服きて、あっといわせるもないわ。",
              "citation": {
                "source": "おるすばん",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おじいさんがミカン畑を作って、あっといわせるなら、和子もモモを植えて、お父さんをあっといわせたいと考えました。",
              "citation": {
                "source": "おるすばん",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い千枝が日々のたつきの苦しさに腹を立てて、着物をぬいでは目の覚めるようなぜいたくをして夫や子供を時々あっといわせるあの冒険は、同じ姉妹でも閑子にはないとミネは思っている。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく「彼」は旧式な登山家で、「曲芸」にせよ「勲業」にせよ、目覚ましいようなこと、人をあっといわせるようなこと、新聞や雑誌に出るようなことはしなかったのである。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたし、また舞台へ出るわ」若尾は元気に云った、「薙刀の腕が違ったから、新しい水車の手を編みだすの、あしかけ五年修業して来たんですもの、あっといわせるような手を考えてみせるわ」　だが五日めに和次郎が迎えに来た。",
              "citation": {
                "source": "みずぐるま",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまから一か月のあいだに、きみたちを、あっといわせるようなことが、おこるだろう。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪人二十面相の世間をあっといわせるたくらみだ。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
