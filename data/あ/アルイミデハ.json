[
  {
    "uuid": "a5b62a3c-5a48-5ac8-ace3-9ab0bf6ec1ad",
    "entry": "ある意味では",
    "reading": {
      "primary": "あるいみでは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in a sense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その判断はある意味では正当性がある。",
              "source": "幻辞"
            },
            {
              "text": "このやり方はある意味では効果的だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの視点ではある意味では必要な損失だ。",
              "source": "幻辞"
            },
            {
              "text": "医学的にはある意味では症状抑制が優先される。",
              "source": "幻辞"
            },
            {
              "text": "学習の面ではある意味では失敗も貴重だ。",
              "source": "幻辞"
            },
            {
              "text": "社会的にはある意味では規範の維持が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "競技ではある意味では心理戦が勝敗を決める。",
              "source": "幻辞"
            },
            {
              "text": "人生経験ではある意味では苦労が財産だ。",
              "source": "幻辞"
            },
            {
              "text": "開発段階ではある意味では試行錯誤が必須だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的観点ではある意味では過去の繰り返しがある。",
              "source": "幻辞"
            },
            {
              "text": "法律上ではある意味では例外条項が存在する。",
              "source": "幻辞"
            },
            {
              "text": "市場経済ではある意味では自由競争が理想だ。",
              "source": "幻辞"
            },
            {
              "text": "創作活動ではある意味では制限が創造性を高める。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではある意味では食物連鎖が秩序を保つ。",
              "source": "幻辞"
            },
            {
              "text": "組織運営ではある意味では権力分散が安定を招く。",
              "source": "幻辞"
            },
            {
              "text": "個人成長ではある意味では困難が機会となる。",
              "source": "幻辞"
            },
            {
              "text": "言語学ではある意味では方言が言語進化を示す。",
              "source": "幻辞"
            },
            {
              "text": "建築設計ではある意味では制約が美しさを生む。",
              "source": "幻辞"
            },
            {
              "text": "投資判断ではある意味ではリスク分散が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "国際関係ではある意味では相互理解が平和を招く。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二　暦の上の春と、気候の春とはある意味では没交渉である。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "颱風に関する気象学者の研究はある意味では今日でもかなり進歩している。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学上の言葉は概念的抽象的であるからある意味ではかえって翻訳とその通用とが容易であるとも考えられる。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には、『桜陰比事』に最も明白に現われている西鶴の「探偵趣味」とも称すべきものが、これもまたある意味では西鶴の中の科学者の面貌を露出したものと云われるであろう。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では野蛮でブルータルであると同時に一方ではまた新鮮で明朗で逞しい美しさがないとは云われない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもある意味では世界中の文明人が今現にやっている習俗と同じ事である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では変化し過ぎて困るかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では広いと見えます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の遊楽の中でもいわゆる花見遊山はある意味では庭園の拡張である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらはある意味ではたしかにききめはあった。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「中等教科書に現われた物理ほど非物理的な物理はない」こんなパラドクシカルな事もある意味では言えない事はない。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この文辞の間にはラスキンの癇癪から出た皮肉も交じってはいるが、ともかくもある意味ではやはり思想上の浅草紙の弁護のようにも思われる。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事はある意味では器械的であるが一つ一つの記録を読んで行くうちに昔の江戸の生活が、小説や歴史の書物で見るよりも遥かに如実に窺われて実に面白かった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍国の兵力の強さもある意味ではどれだけ多くの火薬やガソリンや石炭や重油の煙を作り得るかという点に関係するように思われる。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいことには、また一方で、自然界に存する実際のすべての波動はやはり「虚成分」をもっていて、これが減衰を支配し、ある意味ではまた拡散をも意味する。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある意味ではほんとうだと思われる。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一方でまた「科学者はあたまが悪くなくてはいけない」という命題も、ある意味ではやはりほんとうである。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の歴史はある意味では錯覚と失策の歴史である。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このジャーナリズムの一相と見らるる「事実の類型化」はある意味では確かにうそをつくことであるが、しかしまたよく考えてみると、これは具体的個別から抽象され一般化された規準的事実の記述だと解釈されないこともない。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の筋も場面も実に尋常普通の市井の出来事で、もっとも瘋癲病院の中で酒精中毒の患者の狂乱する陰惨なはずの場面もありはするがいったいに目先の変わりの少ないある意味では退屈な映画である。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うば鮫を捕獲する一巻でも同じような場面がずいぶん繰り返し長く映写されるので、ある意味では少し退屈である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服というものはある意味では人間の個性を掩蔽するものである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ英文活字に若干遺憾の点があるが、これもある意味ではこうした限定版の歴史的な目印になってかえっておもしろいかもしれないのである。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では確かにそうかもしれない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはある意味では実際そうであるが、しかし必ずしもそうばかりではない。",
              "citation": {
                "source": "ラジオ・モンタージュ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし映画の時間は確かにある意味では立派に逆転し、従って歴史はほんとうに掛け値なしに逆さまに流れる。",
              "citation": {
                "source": "映画の世界像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが工場へ入って労働運動というような仕事に身を投げ出したのも、ある意味ではその積極的な一つの表れということができた。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では必要であるとさえも考えられる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえやおれが殺したんだ」「そうかな……ウーン、まあ、ある意味ではそうかもしれない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会のまん中で、動物と植物とが人間の破壊の手から保護されている動物園は、ある意味では処女林と同じだ。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
