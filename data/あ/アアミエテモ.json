        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あの人はああ見えても相当な努力家だ。",
              "source": "幻辞"
            },
            {
              "text": "その企業はああ見えても経営難だ。",
              "source": "幻辞"
            },
            {
              "text": "単純に見える化学反応もああ見えても複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "その物語の登場人物はああ見えても深い背景がある。",
              "source": "幻辞"
            },
            {
              "text": "この教科書はああ見えても高度な内容だ。",
              "source": "幻辞"
            },
            {
              "text": "その症状はああ見えても危険かもしれない。",
              "source": "幻辞"
            },
            {
              "text": "その法律はああ見えても厳しい罰則がある。",
              "source": "幻辞"
            },
            {
              "text": "アマチュアの選手はああ見えてもプロ級の実力がある。",
              "source": "幻辞"
            },
            {
              "text": "その自然現象はああ見えても重要な意味がある。",
              "source": "幻辞"
            },
            {
              "text": "その歴史的事件はああ見えても複雑な背景がある。",
              "source": "幻辞"
            },
            {
              "text": "そのシンプルな料理もああ見えても工夫が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "その観光地はああ見えても隠れた魅力がある。",
              "source": "幻辞"
            },
            {
              "text": "その人物はああ見えても感受性が強い。",
              "source": "幻辞"
            },
            {
              "text": "そのシンプルなアート作品もああ見えても奥深い。",
              "source": "幻辞"
            },
            {
              "text": "その若い起業家はああ見えても豊富な経験がある。",
              "source": "幻辞"
            },
            {
              "text": "その学生はああ見えても天才的な才能がある。",
              "source": "幻辞"
            },
            {
              "text": "その患者はああ見えても深刻な状態だ。",
              "source": "幻辞"
            },
            {
              "text": "その被告はああ見えても有罪の証拠がある。",
              "source": "幻辞"
            },
            {
              "text": "その素人のスポーツマンはああ見えても才能がある。",
              "source": "幻辞"
            },
            {
              "text": "その自然保護区はああ見えても生物多様性に富んでいる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それじゃから云うて聞かすが、お前の母親というのは、ああ見えても若いうちはナカナカ男好きじゃったのでナ。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「でもなかにゃああ見えても、なかなか学問が出来るんだって、そういってる者もあるんだ。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の親父はああ見えても産れが好いんです。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "浄瑠璃の芸題も姉たちは殆んど皆覚え、あの段ものの、切れ切れな場面を語るのに、あれはどうした筋で、ああ見えても似せ首なのだとか、本当は腹を切って来ているのだとか、あのお姫さまは捨て児だったのだとか、何でも知っていて私に話してくれるのだった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "叔父はああ見えても往生していたのだ。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ少佐はもちろん、その通訳も、多分、ああ見えてもやることはやるんだらう――これは、そのロシヤ婦人の傍を片時も離れない禿頭のルウマニヤ人である。",
              "citation": {
                "source": "世界覗眼鏡",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……温順しい、それは深切な人なんですけれど、男というものは、ああ見えても皆な道楽をするものですかねえ。",
              "citation": {
                "source": "別れたる妻に送る手紙",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ見えても、皆悪いのよ。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ見えてもこのつづみにかかっちゃア甘えもんだと、与吉はいっそう足を早めて、見えぬ泰軒に追われるように絶えず小走りをつづけて来たのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ見えても、たいへんな寂しがり屋ですから、再婚したい気はあったのでしょうが、きょうまで、ぼくが、極力、邪魔をしていたんです」「それは、なぜ？",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "川田はサンフランシスコやロサンジェルスを地盤にして西部の小原に張合っていたむかしのいきさつがあるので、ああ見えても内実はたいしたものではないなどと軽くいっているけれども、評判どおり生仲な日本人などは寄りつきもできないような存在になっているのは事実らしかった。",
              "citation": {
                "source": "復活祭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "横町の瞽女はああ見えても金持だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "彦徳の面",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると老師は、「いや、ああ見えても、中々秩序の立ったよい頭を持って居る」とて、深く推奨せられたことを覚えて居る。",
              "citation": {
                "source": "釈宗演師を語る",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美樹ちゃんは、ああ見えても、気の強いこなのよ。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、今度は蕎麦屋の主人ですが、彼は、ああ見えても却々しっかりした男ですから、探り出すのに可成骨が折れましたよ。",
              "citation": {
                "source": "Ｄ坂の殺人事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああみえても神さまみてえにど偉え剣術の先生だでよ、失礼のねえようによく気をつけてくろよ」　杢助はそっちを見ようともしなかった。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
