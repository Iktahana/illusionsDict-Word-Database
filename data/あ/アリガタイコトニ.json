        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ありがたい事に無事に着いた。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に皆は元気だ。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に天気がよくなった。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に支援してくれる人がいた。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に仕事が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に間に合った。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に誰も怪我をしなかった。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に予定通りに進んだ。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に助けてくれる人がいる。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に理解してもらえた。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に病気から回復した。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に皆が同意してくれた。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に家族は全員揃った。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に追加費用は不要だった。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に意見が一致した。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に解決策が見つかった。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に良い結果が出た。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に誤解が解けた。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に信頼を得られた。",
              "source": "幻辞"
            },
            {
              "text": "ありがたい事に幸せな結末となった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "と、ありがたい事には力三は平気な顔で兄と居相撲か何か取つて、大きな声で笑つて居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十二月二十五日）　　　　　　　十三の三　ありがたい事には、この物語も今日で無事に終わりを告げうることとなった。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一ありがたい事には何も思つてみた事がねえンだからね。",
              "citation": {
                "source": "なぐさめ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたい事に私の神経は静まっていた。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたい事に味噌汁がついていたんで、こいつを南京米の上から、ざっと掛けて、ざくざくと掻き込んだんで、今度は壁土の味を噛み分ないで済んだ。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたい事に達者で――針も持ちます、苧もうみます、御団子の粉も磨きます」　この御婆さんに石臼を挽かして見たくなった。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、御叔母さん」「ありがたい事に今日には困りません。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただありがたい事に人を羨む気も起らんから、それだけいいね」「会計は近頃豊かかね」「なに同じ事さ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがたい事に弓は無難です。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたい事になりましたね」「まず古来の賢哲が女性観を紹介すべしと書いてある。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたい事に室の廂と、向うの三階の屋根の間に、青い空が見えた。",
              "citation": {
                "source": "思い出す事など",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、ありがたい事に、私の分裂症状はなおった。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたい事に、間も無く電車はＳ驛に停つた。",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかとゴーシュはどきっとしましたがありがたいことにはこんどは別の人でした。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ところが、ありがたいことに、戸があけはなしになっていました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいことに、とびらが、すこしあいていました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし徳一君や、加市君や、兵太郎君など、日ごろのなかまがいまのことばを聞いていたなら、あとで久助君は、背中をたたかれたりしながら、どんなにひやかされるかしれないのだが、ありがたいことに、それを聞いたのは、太郎左衛門だけである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ありがたいことには、神様、今いちどだけ、私をおゆるし下さいました。",
              "citation": {
                "source": "喝采",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ありがたいことには、海べに立って、沖の方をながめていますと、一そうの白帆の、こちらへ近づいて来るのが見えました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "四、船乗シンドバッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいことに、わたしは至極大胆である。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここだけの話、スカンディナヴィア王室やフランス共和国のために尽くした先日の事件のおかげで、個人的にもありがたいことに、しばらく静かに暮らしながら化学実験に専念できるご身分にはなっていてね。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいことには、蓋を留めてあるのは二本の抜き差しのできる閂だけだった。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "六三郎もありがたいことに思って親方大事に奉公していた。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブレッシングトンの坂下ですが……」　非常にありがたいことには、例の人力車が私たちを待ち構えてはいたけれども、二十ヤードほどもさきにいてくれた。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ、ありがたいことにね！",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「もちろん、ありがたいことには違いないが……だが、それでどうしてあれらのことを、とやかく言えるのかね？",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でもね、そんな人にぶつかりっこはないわ、ありがたいことにね！",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だってまだまだ、君の心にあることは、ちゃんと顔に出ているもの、ありがたいことにね。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "※ありがたいことには、私は此頃また以前のやうに御飯をおいしく食べるやうになつた、逃げた幸福がかへつてきたのである、生きることは味ふことであるが、食べることは味ふことの切実なるものである（殊に老境に於ては、食べることが生きることである）。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――炭の粉もなくなつてしまつた（ありがたいことには米はまだ／＼ある）、――貧乏には慣れてゐるけれど、貧乏はやつぱりつらい！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
