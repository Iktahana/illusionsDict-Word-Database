        "examples": {
          "standard": [
            {
              "text": "私は毎日あーんについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あーんという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあーんの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあーんが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あーんを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあーんについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あーんの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあーんの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあーんが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あーんという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあーんという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあーんについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あーんを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあーんは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あーんについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあーんが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあーんは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあーんの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あーんは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあーんは興味深い例である。",
              "source": "幻辞"
            }
          ],
