    "definitions": [
      {
        "index": 1,
        "gloss": "opening (one's mouth) wide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あーん、と口を開けて医者に診察を受ける。",
              "source": "幻辞"
            },
            {
              "text": "スプーンで口に入れる時に「あーん」と言う。",
              "source": "幻辞"
            },
            {
              "text": "歯医者に「あーん、と開けてください」と指示される。",
              "source": "幻辞"
            },
            {
              "text": "赤ちゃんに食べ物を与える時「あーん」と言う。",
              "source": "幻辞"
            },
            {
              "text": "医学検査で「あーん」と言って喉を見せる。",
              "source": "幻辞"
            },
            {
              "text": "看護師が患者に「あーん」と言わせて診察する。",
              "source": "幻辞"
            },
            {
              "text": "あーん、と大きく口を開ける必要がある。",
              "source": "幻辞"
            },
            {
              "text": "幼児に「あーん、と開けてください」と言う。",
              "source": "幻辞"
            },
            {
              "text": "耳鼻咽喉科であーん、と言って診察を受ける。",
              "source": "幻辞"
            },
            {
              "text": "親が子供に「あーん」と言いながら食べさせる。",
              "source": "幻辞"
            },
            {
              "text": "あーん、と言いながら運動を始める人もいる。",
              "source": "幻辞"
            },
            {
              "text": "口腔衛生の検査であーん、と言わされる。",
              "source": "幻辞"
            },
            {
              "text": "あーん、という音で口の動きを習う。",
              "source": "幻辞"
            },
            {
              "text": "発声練習で「あーん」と言う基本がある。",
              "source": "幻辞"
            },
            {
              "text": "あーん、という掛け声で気合を入れる。",
              "source": "幻辞"
            },
            {
              "text": "医療現場で「あーん、と開けてください」はよく聞く。",
              "source": "幻辞"
            },
            {
              "text": "映像作品では患者が「あーん」と言うシーンがある。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に「あーん」は健全な発音だ。",
              "source": "幻辞"
            },
            {
              "text": "あーん、と言う際に舌の位置が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションで「あーん」と発声する訓練がある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "心の中ががあーんとしてしまつて、前後のことがめちやくちやになり連絡がつかなくなつてしまつた。",
              "citation": {
                "source": "耳",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "テン太郎さあーんどうしませう○どうしませう　テン太郎さん何んとか考へなければ…あッ　向ふから親切な看護婦さんが走つてきた○やあ　看護婦さん！",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　って訊くと、まるでちゃあーんと仕込まれた九官鳥みたいな調子で、「そりゃア旦那様が、競馬で儲けて下さるんでしょう？",
              "citation": {
                "source": "あやつり裁判",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の番の音をきくと、「お稲荷さあーんと長く声を引いてあるく「稲荷ずし売」の事を思う。",
              "citation": {
                "source": "夜寒",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかはりあの谷川のところへ着いたら、空二さんにお魚を釣つてあげますよ」　空二はあーんと泣き出した。",
              "citation": {
                "source": "雲雀病院",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あーん、あーんと、泣声の絶え間には、ふと、彼は自分の泣声を吟味するやうに聞いてゐた。",
              "citation": {
                "source": "雲雀病院",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々が不便に思って女を抱き起そうとすると、女はさも苦しそうに、「あーん、あーん」と唸りながら地面に指で何やら書いたが、やがて、「うーん」と一声口走ったかと思うと、そのまま絶命してしまった。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なあーんだ……と口走りながら苦笑した。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お客さまなんですよ」　藍子は、何事かと思った顔をゆるめ、駄々っ子らしく、「なあーんだ」と云い、本包みとショールをそこへ置いた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、女湯で、子供が泣き出したわな」「ばばばあーん、これぞ、真田の張抜筒」　右源太は、光の届かぬ、湯の中の隅へ入って（南部だけでなく、江戸にも、人気があるらしいが――もし、江戸へでも、現れたなら）　と、心臓を固くして、額の汗を拭いていた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一　だあーん――それは、その近くに住む人が、生れて以来、聞いたことの無い音であった。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、人々と一緒に門内へ入ると――たあーんと、長屋の戸へ、矢を射立てて、そこにいる人々を、威嚇するのが合図であった。",
              "citation": {
                "source": "寺坂吉右衛門の逃亡",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "近藤は、飛出す弾丸を見ようとしていたが、ばあーんと、音が、木魂しただけで弾丸の飛ぶ筋が見えなかった。",
              "citation": {
                "source": "近藤勇と科学",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭の中で、があーんと、頭いっぱいに鳴り響くものと、全身にこたえた痛みとがあった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、庄公、あーんと、口を開きな。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、ほんの一刹那――だ、だあーん――湖水いっぱいに、山々に、橋に、響き渡った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もう一度「お嬢さあーん」　と、呼ばれた時（ああ、誰か、遠くで、自分の名を呼んでいる）　と、感じた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして思わず川島が、両手を口に当ててメガホンのようにし「洋子さあーん」　と呼んで手を振ったのに、いや、却ってその声が、あたりの森の中にわーんと泌込んで行ったせいか、彼女は、その美しい顔を泣き笑いのように歪めると、ぱっと身を飜えして木々の間に消え失せてしまったのだ。",
              "citation": {
                "source": "植物人間",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあーんだ」「あゝ、蝙蝠か」　二人は顔を見合せました。",
              "citation": {
                "source": "エミリアンの旅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "清少年は、両手でメガホンを作って、「※代さあーん。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千世子さあーん」　Ｈはパッと開いた花の色の様な声でよんだ。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番おしまいの紙くずをなげ込んだ時、「千世子さあーん」　Ｈが呼んだ。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きさは一センチ位かな」「なあーんだ。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、なあーんだ」　彼は、毛布の中で、くっくっと、いつまでも笑いがとまらなかった。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あーん……」と、自分は打ちのめされた氣持で、彼女の兩手を取つた。",
              "citation": {
                "source": "蠢く者",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なあーんだ……これは……。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあーんだ、と思っても、やはり気にかかった。",
              "citation": {
                "source": "溺るるもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
