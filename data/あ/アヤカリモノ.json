        "examples": {
          "standard": [
            {
              "text": "その彼女はあやかり者であることに気づかなかった。",
              "source": "幻辞"
            },
            {
              "text": "社会的地位を求めるあやかり者は多い。",
              "source": "幻辞"
            },
            {
              "text": "文学ではあやかり者が主人公として描かれることがある。",
              "source": "幻辞"
            },
            {
              "text": "心理学はあやかり者の心理メカニズムを研究している。",
              "source": "幻辞"
            },
            {
              "text": "社会学ではあやかり者の行動パターンが分析される。",
              "source": "幻辞"
            },
            {
              "text": "教育的には、あやかり者への対応が課題である。",
              "source": "幻辞"
            },
            {
              "text": "法律的には、あやかり者の詐欺行為が問われる。",
              "source": "幻辞"
            },
            {
              "text": "倫理学ではあやかり者の行為が道徳的に考察される。",
              "source": "幻辞"
            },
            {
              "text": "人間関係の研究ではあやかり者の影響が分析される。",
              "source": "幻辞"
            },
            {
              "text": "歴史的には、権力層に近づくあやかり者が存在した。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではあやかり者が出世を求める。",
              "source": "幻辞"
            },
            {
              "text": "映画ではあやかり者が重要な役割を果たすことがある。",
              "source": "幻辞"
            },
            {
              "text": "自伝文学ではあやかり者から抜け出した経験が語られる。",
              "source": "幻辞"
            },
            {
              "text": "小説ではあやかり者の虚栄心が批判的に描かれる。",
              "source": "幻辞"
            },
            {
              "text": "社交の場ではあやかり者を見分けることが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "心理療法ではあやかり者の傾向に対処する。",
              "source": "幻辞"
            },
            {
              "text": "自己啓発の書ではあやかり者の心理が分析される。",
              "source": "幻辞"
            },
            {
              "text": "人脈形成ではあやかり者に頼らない本物の関係が大事だ。",
              "source": "幻辞"
            },
            {
              "text": "仕事の相談ではあやかり者への警戒が必要である。",
              "source": "幻辞"
            },
            {
              "text": "人生経験の中であやかり者との出会いは避けられないものだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そのお友達こそ、ずいぶんのあやかり者だと思います。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "身がかたまって、生命がけの願が叶って、容子の可い男を持った、お蔦はあやかりものだって、そう云ってね、お母さんがお墓の中から、貴方によろしく申しましたよ。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、これも、あやかりもの。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤「実に君はあやかりものだ。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸市中の女子どもから嫉まれる、そのあやかりものは何処の誰れじゃ」　と片里が言うのに呉羽之介は答えて、「何処の姫でも廓の大夫でもございませぬ。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すで人からのあやかりものである。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば、潦水に影やどす、お月様踏んだればとて、こんな心地はせまいものと、歎く我が身の不運さは、これに限りて、あやかりものとも思はれる、妙な心地もそれは昨日までの事。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あそこはあやかりもの、御来会も、遅なはる筈の事。",
              "citation": {
                "source": "したゆく水",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやかりものですね」　無駄を言ひ乍らも立ち上つた喜八は、煙草をポンと叩くと、煙草盆を押やつて、手馴れた剃刀を取上げました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "頬の疵",
                "note": "青空文庫"
              }
            },
            {
              "text": "親と娘を隔てる、町の女房、娘達、美しく華やかな夕陽の中に、あやかりものの駕籠を、何處までも追ひます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巾着切の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「變な心持ですよ、親分」「あやかりものだよ、――化け序にもう少しその儘にしてゐてくれ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "「変な心持ですよ、親分」「あやかりものだよ、――化けついでにもう少しそのままにしていてくれ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "ガラッ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "親と娘を隔てる、町の女房、娘達、美しく華やかな夕陽の中に、あやかりものの駕籠を、どこまでも追います。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巾着切りの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿だなア、お前もそんな事をして、絞め殺されてえのか」「殺されるのは御免だが、ちよいとあやかりものぢやありませんか――おや、三輪の親分は見えないやうですが」「櫛を持つて飛んで行つたよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "青葉の寮",
                "note": "青空文庫"
              }
            }
          ]
        }
