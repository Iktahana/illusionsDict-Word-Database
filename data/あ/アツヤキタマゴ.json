        "examples": {
          "standard": [
            {
              "text": "お弁当の定番おかずである厚焼き玉子は、その鮮やかな黄色で彩りを添えてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "弱火で何度も丁寧に巻き上げることで、焦げ目のないふっくらとした厚焼き玉子が完成する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やっぱり、お寿司屋さんの厚焼き玉子は出汁がしっかり効いていて格別だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家庭によって、砂糖を多めに入れた甘い厚焼き玉子か、塩味の効いたものかで好みが分かれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "居酒屋で注文した厚焼き玉子に、添えられた大根おろしをたっぷりのせて醤油を垂らす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、この厚焼き玉子、断面が綺麗な層になっていて職人技を感じるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
