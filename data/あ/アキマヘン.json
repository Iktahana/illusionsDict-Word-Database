        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あきまへんと関西人は言う。",
              "source": "幻辞"
            },
            {
              "text": "そんなことあきまへんで。",
              "source": "幻辞"
            },
            {
              "text": "もうあきまへん、疲れました。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんよ、そんなつまらないこと。",
              "source": "幻辞"
            },
            {
              "text": "あきまへん方言は大阪出身者が使う。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんという言葉は標準語では「あきません」という。",
              "source": "幻辞"
            },
            {
              "text": "彼はあきまへんと首を横に振った。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんてことですな。",
              "source": "幻辞"
            },
            {
              "text": "関西方言を学ぶためにあきまへんについて調べた。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんは否定や拒否の意思を表現する。",
              "source": "幻辞"
            },
            {
              "text": "映画で登場人物があきまへんと言っていた。",
              "source": "幻辞"
            },
            {
              "text": "方言辞典ではあきまへんの用法が詳しく説明されている。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんという言葉は古い時代から使われている。",
              "source": "幻辞"
            },
            {
              "text": "方言学の研究ではあきまへんが重要な例として取り上げられる。",
              "source": "幻辞"
            },
            {
              "text": "子どもの頃あきまへんという言葉をよく聞いた。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんと言う仕草には特有の表現力がある。",
              "source": "幻辞"
            },
            {
              "text": "関西弁の特徴を学ぶ上であきまへんは欠かせない。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんという言葉の音韻的特徴は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "あきまへん以外の関西方言の否定形も一緒に学んだ。",
              "source": "幻辞"
            },
            {
              "text": "あきまへんという言葉は地域のアイデンティティの一部だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "徳兵衛が刀を収めて、Ｔ「先ず二両」　山左が驚いて、Ｔ「捨て売りにしても五十両は」　徳兵衛、Ｔ「この不景気に御冗談を」　と言われて山左が、Ｔ「では三十両」　徳兵衛、あきまへん。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ぢやてて、貴方はん、梯子がおへんよつて、どないにもあきまへん。",
              "citation": {
                "source": "人參",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あて、あきまへんのどっせ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠したかてあきまへんぜ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の言うことを信用したらあきまへんぜ。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんまにあんた、警戒せなあきまへんぜ」　警戒とは大袈裟な言い方だと、私はいささかあきれた。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう心掛けやさかい、あんたはいつまでたっても前座してんならんネやぜ、それに、なんだっせ、いつまでも『無筆の片棒』一点張りではあきまへんぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどめから会うたらあきまへんぜ」　蚊帳の中へはいってからも、他吉の小言は続いた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――もうこれから、どんなことあっても、次郎ぼんと会うたら、あきまへんぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここを、君ちゃん、よう噛み分けて考えなああきまへんぜ」「そんなら、潜る気はちょっともおまへんねんな」　君枝はすっかり当てが外れた想いで、蒼い溜息をついた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "気を落したらあきまへん」　と慰め、女の生理の脆さが苦しいまでに同情された。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うちの人の様にくよくよしとると、ほんまにあきまへん。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどめから会うたらあきまへんぜ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきまへん、降りとくなはれ」結局、豹一は降りざるを得なかった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その細い糸の上に人間が立つてるちふやうな将棋にならんとあきまへん。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お蔭で飯もよう喰わんと走り出して来居って……、ひもじゅうて叶わんがな」「どだい此処等の宿屋の女中があきまへんわ」　船頭の代りに屋根の下から答うる者がいた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう迚もあきまへんよつて、お先きへ遣つて貰ひまつさ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あきまへん、迚もあきまへんよつて、お先きへ往かしとくなはれや、そしてお爺さんは後から緩くりおいなはれ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大阪に深い馴染のある方やないとあきまへんな。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうだすとも、大阪に深い馴染のある方やないとあきまへん。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そやけど、そない芝居をするとなると、仕打の白井さんは当にならんし、劇場から借りん事にはあきまへんぜ……」「劇場なら乃公が心配しよう。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃龍も居合わせ、「きっとどっせ、好う好う左の花道見といやっしゃ」と云ったが、自分一人になった時、「ほんまに間違えてお座りやしたらあきまへんえ、左の花道のねきいお座りやっしゃ」と念を押した。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶商売では、茶を飲み分けることができないとあきまへん。",
              "citation": {
                "source": "わが母を語る",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何んぼ隱れなはつても、あきまへんで。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そらあきまへんとも、私なぞ。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "『良いやうでも百姓はあきまへん。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の身體には矢ツ張り漢法醫がよいので、西洋醫者はあきまへんわい。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
