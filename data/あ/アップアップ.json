    "definitions": [
      {
        "index": 1,
        "gloss": "floundering while nearly drowning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あっぷあっぷについて考えてみました。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷの意味を理解しました。",
              "source": "幻辞"
            },
            {
              "text": "日常生活であっぷあっぷが使われています。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷに関する知識を深めました。",
              "source": "幻辞"
            },
            {
              "text": "辞書であっぷあっぷを調べました。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷの用法について学びました。",
              "source": "幻辞"
            },
            {
              "text": "様々な分野であっぷあっぷが活用されている。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷの応用例を見つけました。",
              "source": "幻辞"
            },
            {
              "text": "専門家があっぷあっぷについて論じている。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷについての研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "教育の場であっぷあっぷが教えられている。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷの歴史を追うことは興味深い。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からあっぷあっぷを理解する。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷの変化に気づきました。",
              "source": "幻辞"
            },
            {
              "text": "言語や文化におけるあっぷあっぷの重要性。",
              "source": "幻辞"
            },
            {
              "text": "分析結果からあっぷあっぷの特性がわかった。",
              "source": "幻辞"
            },
            {
              "text": "一般的なあっぷあっぷの使い方を習得しました。",
              "source": "幻辞"
            },
            {
              "text": "複雑なあっぷあっぷの概念を説明する。",
              "source": "幻辞"
            },
            {
              "text": "あっぷあっぷに関連する他の用語がある。",
              "source": "幻辞"
            },
            {
              "text": "最新のあっぷあっぷに関する情報を入手した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あっぷあっぷ溺れるまねをしたりなんかもするねえ、そんなことをしてふざけながらちゃんと魚をつかまえるんだからえらいや、魚をつかまえてこんどは大威張りで又氷にあがるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、よほど頭がわるく、それにまた身のほど知らぬ自惚れもあり、人の制止も聞かばこそ、なに大丈夫、大丈夫だと匹夫の勇、泳げもせぬのに深潭に飛び込み、たちまち、あっぷあっぷ、眼もあてられぬ有様であった。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちどんどん舟は崩れて、あっぷあっぷいうまもなく、たぬきはとうとう沈んでしまいました。",
              "citation": {
                "source": "かちかち山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "メキシコのどぶ川の中で、あっぷあっぷしていた奴を、おせっかいの団長が、えりくびとって引上げてやったのさ。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体に訣別して、そしてなにかしら精神的な愛情を求めて、あっぷあっぷしてるんじゃないか。",
              "citation": {
                "source": "怒りの虫",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の中へはまって、あっぷあっぷするのは、いい形じゃないよ」　僕は忠告してやった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをとって素顔を見せたりすると、たちまちあっぷあっぷで土左衛門と変名しなくてはならない。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日向水の鮒ああっぷあっぷのちょろちょろだい！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉の勢以子は外御門へ命婦に行き、七十くらいになっていた母堂が鼻緒の壺縫いをするというあっぷあっぷで、安部は学習院の月謝をいくつもためこみ、どうしようもなくなって麻布中学へ退転したが、そこでもすぐ追いだされ、結局、いいことにして絵ばかり描いていた。",
              "citation": {
                "source": "予言",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊豆は手足をじたばたさせて口中から白い泡を吹いていたが、麻油が手を離してから暫くあっぷあっぷしていて、おもむろに四這いになると、部屋の中央へ白い嘔吐を吐き下した。",
              "citation": {
                "source": "小さな部屋",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "空気を吸いこみたいのだが、水のなかへでも落ちたみたいに、あっぷあっぷしている。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
