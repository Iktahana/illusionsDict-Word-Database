    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tidying up",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祭りの興奮も冷めやらぬまま、町内会の人々は翌朝早くから会場の後片付けに追われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "料理を作るのは好きだが、油で汚れた鍋や食器の後片付けがどうしても億劫になってしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "前任者が残したトラブルの後片付けに奔走させられ、自分の本来の業務に手が回らない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "子供たちには、遊んだ後はおもちゃを元の場所に戻すという、後片付けの習慣を身につけさせたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "宴会が終了した後は、各自が責任を持って自分の身の回りを後片付けしてから退室してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "引っ越しの荷造りは終わったが、旧居の掃除や不用品の処分など、細かい後片付けがまだ山のように残っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "一ばん口数を利く妹娘のお絹がこんな考えに耽ってしまっていると、もはや三人の間には形の上の繋りがなく、鼈四郎はしきりに煙草の煙を吹き上げては椅子に踏み反って行くだけ、姉娘のお千代は、居竦まされる辛さに堪えないというふうにこそこそ料理道具の後片付けをしている。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「よく後片付けをして行かないんだね。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房がいう通り、市商人は碌々に後片付けをして行かないとみえて、そこらにはしおれた鼠尾草や、破れた蓮の葉などが穢ならしく散っていた。",
              "citation": {
                "source": "異妖編",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "表はもう閉まっているので、裏木戸の方へ廻ってゆくと、楽屋の者もみんな帰ってしまって、楽屋番の爺さんが一人で後片付けをしているところであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お照の父",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勘蔵の白状によると、前の年の暮に備前屋の娘の綺麗な肌をみたときには、まだどうしようというほどの煩悩も起らなかったのですが、火事の後片付けの済むまで娘は橋場の親類へ立ち退いているうちに、そこの店の若い者と出来合ってしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "熊の死骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、他のパーティの邪魔になったり、小屋の後片付けについて非難を受けたりするようでは、山に登る資格はない。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隱居の後片付けをした時、あの清少納言の大幅だけは、何う探しても見えなかつたさうである。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝手元の方の手伝いなども後片付けを済ませて皆引き上げて行くと、家の中は初めてがらんとして、灯明の光りの似合う静な夜になった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "下級員が仕事している間に、船尾の食堂へ彼等の食事を運んで遣るだけで、後片付けは見習がすることになっていたので、為吉が彼等と顔を合わすのは昼間甲板で作業する時だけだった。",
              "citation": {
                "source": "上海された男",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後片付けをしたそうな。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "井上さんが大勢のお客さんを連れて来て、二階は散らかりぱなし、お島さんは帰ってしまい、後片付けは明日にしようということになったのです。",
              "citation": {
                "source": "男ぎらい",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は後片付けをして、炬燵でしばらく考えこんだ。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "傷の手当や後片付けがすむと、私と照代は、炬燵に火をいれてあたり、あらためて酒をくみ交した。",
              "citation": {
                "source": "復讐",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜久子はちょっと後片付けをしたらしい。",
              "citation": {
                "source": "朝やけ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "用がないと、居眠りをしていて、最後の後片付けに呼び起される。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれ一人が店の後片付けか、と思っていると、赤木が呼んでくれた。",
              "citation": {
                "source": "花ふぶき",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業したばかりの若い医学士で、二階の八畳を借りてる中村が、病院から帰って来て、和服にくつろいで、玄関の茶の間で煙草を吹かしてる時、そして、辰代が澄子に手伝わして、台所の後片付けをやってる時、大学生は引越して来た。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして食事の後片付けをする。",
              "citation": {
                "source": "ゼンマイの戯れ（映画脚本）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、女中が食事を済し後片付けをした頃、彼女は立っていった。",
              "citation": {
                "source": "反抗",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう調子だから、食後の後片付けという、主婦にとって一番いやな仕事も、十五分くらいですんでしまう。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から晩おそくまで、食事の用意、後片付け、家の掃除などという、眼に見える仕事の他に、つくろいや洗濯や、いろいろなやりくりなど、ありとあらゆる雑用に追い廻されて、一日を無我夢中で過ごしているのが、今日の日本の主婦の実状である。",
              "citation": {
                "source": "捨てる文化",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の後片付けが済んだ時行って、ツイ先刻｜亥刻（十時）の鐘が鳴ると、――おやもうそんな時刻か知ら、伯父さんに叱られるといけないから――と大急ぎで帰ったそうです」「あの娘の近所の評判はどうだ」「悪くありませんよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "安子夫人は、「あなたは不断お行儀が悪いからですわ」　と窘めて、後片付けに客間へ戻った。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "懐紙に包んで、小判で五両、――ところが、窓から金を投り込まれたのは、お徳の殺された晩で、しかも叔母がたった一人で晩飯の後片付けをしている時だというから、戌刻（八時）より遅くはありません」「何だと？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "身投げする女",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く食事の後片付けを終わろうと急いでいた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "後片付けを終わると、やって来て低い椅子にすわった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女中はなお居残って、後片付けにぐずついていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "平素彼女は早めに仕事を終えるのだったが、その晩はいつまでも台所の後片付けを終えなかった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい」　と、答え、もの静かに後片付けをして、布団をのべ、わしが枕についてから、二十分ほどは姿を消すが、細帯の寝巻姿で、小ざるに載せた蒸しタオルを捧げる様にして入って来る。",
              "citation": {
                "source": "面",
                "author": "富田常雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……それよりもうすぐ終るだろうから後片付けの手配でもするとしよう」「けれどもお小頭」　と、若い足軽のひとりが立って来て云った。",
              "citation": {
                "source": "足軽奉公",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
