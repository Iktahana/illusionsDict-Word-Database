[
  {
    "uuid": "cd48606d-95b8-581c-a8c0-ab4b74288ae1",
    "entry": "後片付け",
    "reading": {
      "primary": "あとかたづけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
