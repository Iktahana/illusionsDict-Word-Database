        "examples": {
          "standard": [
            {
              "text": "この計画は、一度着手したからにはもう後に引けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度「やります」と皆の前で宣言してしまったので、今さら後に引けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多額の資金を投じたプロジェクトだから、失敗しても後に引けない状況だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ここまで来たら、もう後に引けない。最後までやり遂げよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「いや、もう後に引けないよ。ここまで準備したんだから！」と彼は力強く言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "一度引き受けた役目だから、どんな困難があろうと後に引けない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "相手の条件を飲んでしまった以上、交渉は後に引けない局面を迎えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
