        "examples": {
          "standard": [
            {
              "text": "その学者はあふるる恩寵にあずかり学問を究めた。",
              "source": "幻辞"
            },
            {
              "text": "宗教の教えではあふるる恩寵が人生を導くと説かれる。",
              "source": "幻辞"
            },
            {
              "text": "神学的には、あふるる恩寵は神の無条件の愛を示す。",
              "source": "幻辞"
            },
            {
              "text": "その芸術家はあふるる恩寵に支えられて傑作を生み出した。",
              "source": "幻辞"
            },
            {
              "text": "歴史家はあふるる恩寵が文明の発展を支えたと論じる。",
              "source": "幻辞"
            },
            {
              "text": "文学作品では、登場人物がしばしばあふるる恩寵を受ける。",
              "source": "幻辞"
            },
            {
              "text": "教育学では、教師のあふるる恩寵が学生の成長を促す。",
              "source": "幻辞"
            },
            {
              "text": "医学的には、患者があふるる恩寵を感じることで治癒が早まる。",
              "source": "幻辞"
            },
            {
              "text": "心理学はあふるる恩寵の感覚が精神的な安定をもたらすことを研究している。",
              "source": "幻辞"
            },
            {
              "text": "法学ではあふるる恩寵に基づいた刑の減免が議論される。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの選手は、コーチのあふるる恩寵により成長する。",
              "source": "幻辞"
            },
            {
              "text": "音楽史では、多くの作曲家がパトロンのあふるる恩寵を受けた。",
              "source": "幻辞"
            },
            {
              "text": "芸術パトロンのあふるる恩寵により多くの傑作が生まれた。",
              "source": "幻辞"
            },
            {
              "text": "企業の後援者のあふるる恩寵により若い才能が育つ。",
              "source": "幻辞"
            },
            {
              "text": "親のあふるる恩寵は子どもの人格形成に大きな影響を持つ。",
              "source": "幻辞"
            },
            {
              "text": "旅人はその町の人々のあふるる恩寵により救われた。",
              "source": "幻辞"
            },
            {
              "text": "古い物語では、主人公は一神のあふるる恩寵により運命が変わる。",
              "source": "幻辞"
            },
            {
              "text": "社会福祉の理念はあふるる恩寵の相互的実践に基づいている。",
              "source": "幻辞"
            },
            {
              "text": "自伝では、著者がいかにあふるる恩寵を受けたかが述べられている。",
              "source": "幻辞"
            },
            {
              "text": "哲学者はあふるる恩寵と自由意志の関係について考察している。",
              "source": "幻辞"
            }
