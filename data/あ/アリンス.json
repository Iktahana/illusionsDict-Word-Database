        "examples": {
          "standard": [
            {
              "text": "これはいい品物ありんす。",
              "source": "幻辞"
            },
            {
              "text": "あの方は有名な先生でありんす。",
              "source": "幻辞"
            },
            {
              "text": "このプロジェクトは重要でありんす。",
              "source": "幻辞"
            },
            {
              "text": "彼女は医者でありんす。",
              "source": "幻辞"
            },
            {
              "text": "江戸時代の文献ではこのような表現がありんす。",
              "source": "幻辞"
            },
            {
              "text": "法律上の問題でありんす。",
              "source": "幻辞"
            },
            {
              "text": "学術的にはそれが正しいでありんす。",
              "source": "幻辞"
            },
            {
              "text": "この商品は最高級でありんす。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ選手としても優秀でありんす。",
              "source": "幻辞"
            },
            {
              "text": "社会的地位の高い人でありんす。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な重要性を持つものでありんす。",
              "source": "幻辞"
            },
            {
              "text": "科学的根拠のあるものでありんす。",
              "source": "幻辞"
            },
            {
              "text": "料理のプロフェッショナルでありんす。",
              "source": "幻辞"
            },
            {
              "text": "文化的遺産でありんす。",
              "source": "幻辞"
            },
            {
              "text": "技術革新の成果でありんす。",
              "source": "幻辞"
            },
            {
              "text": "美術的価値のあるものでありんす。",
              "source": "幻辞"
            },
            {
              "text": "音楽的才能に恵まれた方でありんす。",
              "source": "幻辞"
            },
            {
              "text": "経済的に成功されたお方でありんす。",
              "source": "幻辞"
            },
            {
              "text": "政治的に影響力のあるものでありんす。",
              "source": "幻辞"
            },
            {
              "text": "自然の奇跡でありんす。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "冬の日鳥居清忠ゑがく枠は皆朱の立屏風、さて立膝の、細筆に春の柳をかく女、それを寝て観る男髷、男磨る女童、日向縁、手水がめにはおかめ笹、冬の日和はもつやうで、まだ薄墨の時雨ぐせ、しよざいなささの、しんじつの、ええ、つれづれの小半日でありんす。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうした義理じゃあござんすまいに、栄之丞さんも随分不実な人でありんすね」などと、新造の掛橋や浮橋もそばから煽った。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんなあとで判ることでありんす」　彼女は紙につんだ十両を男の手に掴ませた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佐野の大尽はどうして来ない」「来られた義理でもありんすまい。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お宿の首尾はどうでありんすえ」　綾衣に訊かれても男はただ笑っていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「甲府勝手とは何でありんすえ」「遠い甲州へ追いやられるのだ。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうに、どうなるやら知れない先きのことを、前から苦労するのは馬鹿らしゅうありんすね」　運命の力が強く圧しつけて来るのを十分に意識していながら、男も女も堪えられるだけは堪えて見ようと、冷やかに白い歯を見せていた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "早乙女の御前様が御帰りでありんすよ！",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「早乙女の御前様でありんすか！",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いぎりすもふらんすも皆里言葉たびたび来るは厭でありんす　和泉守の狂歌であるがこんな洒落気もあった人物で、そうかと思うと何かの都合で林大学頭が休講した際には代わって経書を講じたというから学問の深さも推察される。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきんす・しんす（又、……iisu）の類は、吉原の一部や、岡場所語としては、「いきいす」又は「いきんす」「おつせいす」（仰）を普通としてゐ、特に insu（「いきんす」「ありんす」）の場合、遊里情趣が表現せられるものと考へたらしい。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、東京の色町なんかで言ふやうに、ありんすとか行きいすとか言ふ、さう言ふ風なのです。",
              "citation": {
                "source": "国語と民俗学",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざます・ありんすは、即、其形見と考へられるのである。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか一日も早く堅気になりたいものと一生懸命に気をつけているのでありますが、どうかいたすとつい口の先へそうざますのありんすのと、思わず里の訛が出そうになりまして、御新造様とお話をしていましてもそれはそれはもう心配でなりません。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "――」「伺うのは初めてだといいしたが、二十四五の、みすぼらしいお人でありんす」「どッから来たといった」「深川とかいいなんした」「なに、深川。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一合お願い申しやす」「おほゝ、御酒でありんすか」「左様」「御酒なら、わたしがお酌しいす。",
              "citation": {
                "source": "曲亭馬琴",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺生なひとでありんすねえ。",
              "citation": {
                "source": "村井長庵記名の傘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "バラ　木がありんす、そのほかに何の役に立つんかえ？",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三という良い年増で、曾ては「ありんす国」の水も呑んだ強か者。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "暴君の死",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
