[
  {
    "uuid": "531a0fe1-15c1-5ad7-84f0-1046a4e6ef7d",
    "entry": "艶姿",
    "reading": {
      "primary": "あですがた",
      "alternatives": [
        "えんし"
      ],
      "is_heteronym": true
    },
    "grammar": {
