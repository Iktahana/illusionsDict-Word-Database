    "definitions": [
      {
        "index": 1,
        "gloss": "charming figure",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "花街の練り歩きで、芸妓たちの艶姿が沿道の観客を惜しみなく魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "舞台に現れた主役の艶姿に、客席からは感嘆のため息が漏れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "晴れ着に身を包んだ新成人たちの艶姿は、冬の寒さを忘れさせるほどに街を華やがせている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、なんと見事な艶姿だこと」と、叔母は振り袖姿の姪を眩しそうに眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社交界の華として、彼女の艶姿は常に夜会の注目の的であった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "雨の京都で、蛇の目傘を差して歩く女性の艶姿には、言葉に尽くせぬ情緒がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "鏡の間の壁に嵌めた無数の鏡は、女の艶姿嬌態を千万倍にして映じ出だした。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの階上の裏側の窓から新橋の美妓諸姉の夕化粧の艶姿がみえるとて、若いものたちが事に託してかいまみたものだとて今日の古老のうちあけ話である。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　その頃、雪之丞が、松枝町屋敷玄関先まで艶姿をあらわしたとき、「いえいえ、夜分と申し、お敷居外にて、どうぞおいとまを――御前のお目通りなぞ、あまりに恐れ多うござります」　と、平に辞退したに拘らず、切なるすすめで、三斎の居間に招じ上げられてしまったのだった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔容は夜目、ことには、頭巾眼深――ちょいとハッキリしないのだが、この艶姿から割り出すと、さもあでやかだろうとしか考えられない。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　口々に、提灯で、雪之丞の艶姿を振り照らしながら呼びかけた。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、おきたが茶汲み女として、美貌と艶姿とで鳴らしているのを見た。",
              "citation": {
                "source": "一枚絵の女",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人眼が怖いか裏口から、横町へ抜ける細道伝いに娘お糸が今しも自家を出るところ、町家にしては伊達者めいた艶姿、さすが小町の名を取っただけ、容色着付の好み、遠眼ながら水際立って見えた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "松五郎の娘お駒、山の手一番と言はれた十九の艶姿が、無慙大地の上に仰向に倒れて、玉を延べたやうに美しい咽喉、少し左寄りの方へ、矢文を結んだまゝの矢が、箆深く突つ立つて居たのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "松五郎の娘お駒、山の手一番と言われた十九の艶姿が、無慙大地の上に仰向けに倒れて、玉を延べたように美しい喉笛、少し左寄りの方へ、矢文を結んだままの矢が、箆深く突っ立っていたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死の矢文",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中や湯島、芳町あたりの蔭間茶屋にも、こんな艶姿の少年が養われて居たことは言うまでもありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷中や湯島、芳町あたりの蔭間茶屋にも、こんな艶姿の少年が養はれてゐたことは言ふ迄もありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "我里の羽子｜擢は辺鄙とはいひながら、かゝる艶姿にあらず。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東西、東西、このところお聞きに達しまする浄瑠璃｜芸題、「艶姿女舞衣」、語りまする太夫、玉井｜春昇、三味線お京、いよいよ、三勝半七酒屋の段、そのため口上、東西東西」　拍手。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東西東西、このところお聞きに達しまする浄瑠璃｜芸題『艶姿女舞衣』、語りまする太夫、玉井春昇、三味線徳弥、いよいよ、三勝半七酒屋の段、そのため口上、東西東西」　この芸題が馬鹿の一つ憶えのようになってしまった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸題は、一つおぼえの「艶姿女舞衣、三勝半七酒屋の段」。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「晩にね」　と、媚びた眼をのこして、緋と白との、鮮らかな艶姿を、拝殿の蔭へ、消してしまった。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ、その艶姿は、海棠が持ち前の色を燃やし、芙蓉が葉陰に棘を持ったようでなお悩ましい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そしてちらと、武松の姿へ流し眼をむけた金蓮の明眸といいその艶姿といい、はっと、男を蠱惑するかのような何かがある。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法事姿なので、強い色彩や濃粧は嫌っているが、一点の臙脂は唇に濃く、ほんのりと薄化粧を刷いた白珠のおもむきが、むしろ日頃の艶姿よりはなまめかしい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今を時めく寵妃とたれ知らぬはない阿野｜廉子などの艶姿であった。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしては、どこやら垢ぬけし過ぎた艶姿だ。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて時来たれば迎えてとらせる」「……はい」　艶姿にはなお、瑞々と垂れるようなものがあったが、廉子ももう聞きわけのない妙齢ではない。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの艶姿と賢さと、わけてその情熱とは、獄裡の夢にも夜々恋々と消し難いものがおありなのにちがいない……と、道誉にはよくわかる。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "伍一が不快そうに顔をしかめたとき、女中がやっと起きたらしく格子戸をガタガタとゆすぶりながら錠をはずしているらしい気配がしたが、外にいる多吉はそんなことには無頓着で、「可愛いお前のあですがた」と、同じ文句を何べんとなくくりかえしながら門の潜り戸のあくのを待っていた。",
              "citation": {
                "source": "菎蒻",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
