    },
    "definitions": [
      {
        "index": 1,
        "gloss": "since then",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あれ以来、毎日ジョギングを続けている。",
              "source": "幻辞"
            },
            {
              "text": "あの事件あれ以来、警備が厳しくなった。",
              "source": "幻辞"
            },
            {
              "text": "卒業式あれ以来、クラスメートとは会っていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、彼との関係は気まずくなった。",
              "source": "幻辞"
            },
            {
              "text": "病気から回復したあれ以来、健康的な生活を心がけている。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、私の人生が変わった。",
              "source": "幻辞"
            },
            {
              "text": "引っ越したあれ以来、新しい友人ができた。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その地域は大きく発展した。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、この技術は急速に普及した。",
              "source": "幻辞"
            },
            {
              "text": "破産したあれ以来、再出発に必死だ。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、政策が大きく転換した。",
              "source": "幻辞"
            },
            {
              "text": "結婚式あれ以来、毎年会っている。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その工場は操業を停止している。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、気象パターンが変わった。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、この習慣は続いていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、不信感を払拭できていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、年1回の定期会議が始まった。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、技術革新が加速している。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、彼女とは連絡が途絶えた。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その価値観に疑問を持ち始めた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "私と津田氏とは、不和というわけではないけれども、どうも、あれ以来しっくり行かなくて、教室で顔を合せても、お互い軽く会釈するくらいで、打解けた話をした事はいちども無かった。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年ほど前、東京の郊外の或る野道を、兄はやはりこのやうに背中を丸くして黙つて歩いて、それから数歩はなれて私は兄のそのうしろ姿を眺めては、ひとりでめそめそ泣きながら歩いた事があつたけれど、あれ以来はじめての事かも知れない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木之助はあれ以来女房や娘に苦労をかけているのを心の中では済まなく思って、それでも負け惜しみをいった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "張りつめていた復讐心が既に融け始めて、あれ以来の自分の惨めな毎日が涙の中に浮び上った。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来予は既に三個所も居を移してゐる、いつも田舎の母家を予の宛名にはしてゐるが。",
              "citation": {
                "source": "消息抄（近頃書いた或る私の手紙から。）",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれ以来暫く読まないが――」新星「あれ以来といふのは、あの井伏鱒二以来といふことか？",
              "citation": {
                "source": "エハガキの激賞文",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「井伏鱒二といへば大変な騒ぎさ、あれ以来！",
              "citation": {
                "source": "エハガキの激賞文",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来と云うもの、僕たちはただの一日だって、平和だったことはありアしないんだ。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来、心休まる日はなかった――ただの一日も。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来、こちとらは胸の前に掲げて拍手した手のやり場に困って実に肩身が狭い。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕の田舎の友達で、あれ以来夜中に突然飛び起きるといふ新しい習慣が出来て、それが為に始終睡眠不足で、到々店を失敗してしまつたＢといふ男があるよ。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田　あれ以来、僕も何だか大連にいるのが忌になったので、いっそ内地へ帰って仕舞おうかとも思ったんですが、帰ったところで仕様もないので、まあ当分はやっぱりここで働くことにしたんです。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれ以来絵筆を忘れてゐたが、久し振りでまた自画像をかいて見ようかな。",
              "citation": {
                "source": "悪筆",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二階にお通ししてお茶でも上げてお置き、なんだって今ごろ……御飯｜時も構わないで……」　とめんどうくさそうにいったが、あれ以来来た事のない古藤にあうのは、今のこの苦しい圧迫からのがれるだけでも都合がよかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来ゲッソリ痩せてしまった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来加藤は村瀬に出遇ふと、「早く結婚のことを考へなさいよ。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来彼とＡ子とは親しく往来する仲になつてゐたが、何故か彼の眼鏡は方向を転じて、町端づれの裏道にある薄暗い長屋に向けられてゐた。",
              "citation": {
                "source": "風媒結婚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来の、ひとりの自分の眼に映ずる様々な風景が、夢ともなく、現実ともなく、一つ一つの額枠に収つて、新奇に私の胸に影響してゐるのを知つた。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "名前を聞かなかつたし、あれ以来一度も見かけないので水夫はその老人が何処の人かは知らなかつたが、あの老人の声の麗はしさが忘れられなかつた。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあれ以来妻はそんな顔をするのをやめた。",
              "citation": {
                "source": "嫉妬する夫の手記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "上海へ逃げて行った松川からは、あれ以来何の音沙汰もなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "小林の談によって想像されるあれ以来のお柳は、持病のヒステレーが一層｜嵩じているらしかった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあれ以来軽率に感情を告げたりすることもなく慎んでいるのである。",
              "citation": {
                "source": "源氏物語",
                "author": "藤袴",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知の通り二十四年と申しますと、あの濃尾の大地震がございました年で、あれ以来この大垣もがらりと容子が違ってしまいましたが、その頃町には小学校がちょうど二つございまして、一つは藩侯の御建てになったもの、一つは町方の建てたものと、こう分れて居ったものでございます。",
              "citation": {
                "source": "疑惑",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来、パリには罷業が頻発して来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来、ますます人相にも奸黠の度を加えてきた、セルカークを憫むようにながめている。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあれ以来一度も死なんぞと云う事を考えた事はないぜ。",
              "citation": {
                "source": "青年と死",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ以来、どうも調子がよくないんだよ」「困ったわねえ。",
              "citation": {
                "source": "ふしぎ国探検",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、知らせるといっても、博士はあれ以来、ずっと面会謝絶で、意識がはっきりしないということだから、知らせようがないわけだね」「だれが経営しているんだろうか。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇一君は、あれいらい、毎日のように、そうして洋館の前を通ってみるのですが、いつも、鉄の門がしめきってあって、赤レンガの建物の中にも、人がいるのか、いないのかわからないほど、しずかなので、ものたりなく思いながら、通りすぎてしまいました。",
              "citation": {
                "source": "虎の牙",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
