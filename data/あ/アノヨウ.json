    "definitions": [
      {
        "index": 1,
        "gloss": "such",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "まさか、たった数ヶ月であの様に事態が急変するとは思いもしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの様に一方的な意見ばかりでは、議論は深まらないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の夢があの様な形で実現するとは、人生は何が起こるか分からない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のあの様に人を惹きつける魅力は、生まれ持ったものだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "過去の失敗から学び、二度とあの様な過ちを繰り返さないと誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "説明書を読まずに、感覚であの様に組み立ててしまうのは彼ならではだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトの初期段階であの様な根本的な問題が見つかるとは、幸いだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "王、あれア石垣の、やつらがくやしがつてあの様ににらめて居るので御座らう」ヒヨウキン者の郭光は妙な口調でこういつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "抓っても確に活返ったのじゃが、それにしても富山の薬売はどうしたろう、あの様子ではとうに血になって泥沼に。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの様な贋物があるものではございますまい。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんは、やさしい人なつこいあのやうなおつかさまでも、いざ自分のものとなると、あの様な劇しい詞が口から出る。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの様子では一足だつて歩けたものぢやない。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの様子では同じく翼が生えて飛出したかも知れぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それにしてもあの様な最初から最後まで奇妙だった出会いの後ではあるし、又眩しいほどの彼女の美しさであるから、一応は逃げたくもなるだろうけれど。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十余年前自分が身を浄めて土台を据ゑたこの屋敷内へ、どうしてあの様な浅ましい妄鬼――否々、何の業因が不憫な娘達の異形となつて現はれたのか。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの様子では、もうあの老人は、あと二、三｜日で死ぬに違いない。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの様な見崩れ人種が大将では、義朝や悪源太が何程働いたとて勝味は無い。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、あの様子では、須々木乙彦のことなんか、ちっとも、なんとも、思っていない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう、あの様子では、須々木乙彦のことなんか、ちつとも、なんとも、思つてゐない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの様子では確に呑んだよ、どうも殺られたろうと思うがね。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生理的の欠陥者が、その不自然な動作ゆえに却って名優が大まかに工んだ芸をしてるようにも受取れるあの様子を、男女、二人、しかも手つなぎで揃って行くものですから、もちまえ芝居がゝつて見える遊郭風景に加えて、大歌舞伎の道行姿を切抜いて貼付けたような、際立たしさで浮きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もあの様にして這いさがろ思てよく見ると、うわさに聴いた支那犬やないか？",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ロス大佐のあの様子ではどうあってもお目こぼしもありそうにないが。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「悪党と云いますと、殿様でございますか」「そうさ、伯爵さ、貴族院議員なんて澄まし込んでやがるが、悪党だよ」と云った書生は、急に主翁の肩を突いて、「見ろ、あの様を、もう、すぐ演戯が始まるぞ」　主翁は榻の方を見た。",
              "citation": {
                "source": "黄燈",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに省作との関係もです、嫁にやるやらぬは別としても糺さずにおかれません」「なあにだめだだめだ、あの様子では……人間もばかになればなるものだ、つくづく呆れっちまった。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの酔漢を眼にして何時か遊女に対しても端然たる態度を保つやうになつてゐた僕であるが、都のあの様な配光の和やかな室に於てゞあるならば、自分もあの様に美しい酌女の肩や手に大らかに触れても見たい――などゝ思つたりした。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しい写絵を持つてゐない連中があの様に浜田を騒ぎ立てるのは当然のことだと思つた。",
              "citation": {
                "source": "蘭丸の絵",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの様子ぢや名なんかも解りは為ますまい」「さうして今晩来るのか」「来られては困りますけれど、きつと来ますよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ貴方が話したい事が有ると言るる、善し、あの様に間を詐つた貴方じや、又僕を幾何ほど詐ることぢやらう、それを聞いた上で、今日こそは打※してくれやうと待つてをつた。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際では、まつたくだらしのない飲酒家になり、あの様に見苦しい醜態を日々演じてゐるのだ、たゞ何れの点から見ても所謂酒客の性がないばかりであつた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、その秘密の長い尾につながっていた三之助も、あの目、あのいろ、あの様子では、どこに一つ疑わしいところはないのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は今や青雲街道を踏み出していると見るべきだ」記者パイク「でも、あの様子じゃ、大統領は“影”の委員会からボイコットされますぜ。",
              "citation": {
                "source": "諜報中継局",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この章の冒頭に設計書の写しだけをその儘書き誌すつもりだつたが、今もつて如何程思案しても頭部の構造と眼口の配置が出来ない、代りに思ひ出の凧に就いてのみあの様に散漫に書き誌すより他はなくなつてゐるのだ。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全くたわいないものさ」と彼は出し抜けに云った「僕等は先ず第一にあの様な彫像に眼をつける奴を考えて見た。",
              "citation": {
                "source": "赤い手",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "留はあの様子じゃあ、まだ当分は思うように働かれめえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山を石膏細工の人形とすれば、雲は衣裳で、あのようにまで、モデルの肢節にぴったり合って、屈伸するものとは思っていなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
