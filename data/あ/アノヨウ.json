[
  {
    "uuid": "9d68bb31-a9ee-5954-9b83-3ac3e2395f5d",
    "entry": "あの様",
    "reading": {
      "primary": "あのよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
      ],
      "ctype": null,
      "inflections": null
