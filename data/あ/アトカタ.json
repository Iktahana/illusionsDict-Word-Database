        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "激しい爆発により、かつてそこにあったはずの工場は跡形もなく吹き飛んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "長年親しまれてきた古い駅舎が取り壊され、今ではもう元の跡形もない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "周到に証拠隠滅が図られたのか、現場には犯人が侵入した跡形すら残っていなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "春の陽気で雪がすっかり溶け、子供たちが昨日作った雪だるまは跡形もなく消え去った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "大規模な土砂崩れに巻き込まれ、山あいの集落はかつての跡形を留めない無残な姿へと変わり果てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "直線から成る割菱模様が曲線化して花菱模様に変ずるとき、模様は「派手」にはなるが「いき」は跡形もなくなる。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれの教えられている孝という思想は跡形もなく破壊せられてしまっています。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも多くの場合に原形の跡形だけは止めている。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした詩が数千年そのままに伝わって来ていたのがわずかにこの数十年の間に跡形もなく消えてしまうのではないかと疑われる。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸の心にある未練を残しつつその万花鏡のような花は跡形もなく消え失せた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時には寒色の雲が跡形もなく隱れてしまつて、太陽がきら／＼と半日を照り續ける事がある。",
              "citation": {
                "source": "春",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が万物の霊長だなんて威張っていても、たかだか七、八十年経てば、すっかり跡形もなくなってしまうのでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親兄弟もある人物、出来る限り、手を尽くして捜したが、皆目｜跡形が分らんから、われわれ友だちの間にも、最早や世にない、死んだものと断念めて、都を出た日を命日にする始末。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は恥かしくて、顔の上に火が走り、それがちらちら心を焼いて、己惚れも自信もすっかり跡形もなくなってしまった。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、跡形もなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日のことさえ跡形もなかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　雁次郎横丁――今はもう跡形もなく焼けてしまっているが、そしてそれだけに一層愛惜を感じ詳しく書きたい気もするのだが、雁次郎横丁は千日前の歌舞伎座の南横を西へはいった五六軒目の南側にある玉突屋の横をはいった細長い路地である。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガス灯に照らされた男の顔から、すべての色が跡形もなく消えていくのが見えた。",
              "citation": {
                "source": "蒼炎石",
                "author": "THE ADVENTURE OF THE BLUE CARBUNCLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったん書いたものを、跡形もなくきれいに消すこともできる。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日来の苦悩は跡形も無く消え去った。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "數日來の苦惱は跡形も無く消え去つた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一成、十太夫は主人右衞門佐に逆意があるなどゝは跡形もない事で、なぜ利章がそんな訴をしたか分からぬと云つた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶の精神か神経かの情態に、何か変ったことがあったかどうだか、恋愛が芽ざしていたか、性欲が動いていたか、それとも僕の想像が跡形もない事を描き出したのであったか、僕はとうとう知らずにしまった。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて何の跡形もなくお前も私も散つてしまふであらうあゝ、窓の外には暗い冷たい幔幕が垂れ下り花の上にも夕暮れがせまつてきた艶々しい潮の上のただ一瞬の光りもの葡萄の房のやうな帆をあげてゐる。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして瞬く中に跡形もなく永劫の中に溶け込んでしまって、私はいなくなるのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球の内部が残っていさえすれば、縦令地殻が跡形なく壊れてしまっても、一つの遊星としての存在を続ける事が出来るのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "折り重なった鈍色の雲のかなたに夕日の影は跡形もなく消えうせて、闇は重い不思議な瓦斯のように力強くすべての物を押しひしゃげていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の中に、ひそかに懐いていた子供らしい想像は、跡形もなく踏み躙られていた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔あとかたもなく消えてしまった〕　実に意外の感があった」などといっている。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、あの一個中隊が、どこでどうして消えてしまったのか、今だにあとかたも分らなかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい今しがたまで示していた昂然たる意気組もプライドもあとかたもない。",
              "citation": {
                "source": "線路",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の思い出とか、未来の夢とかいうものはあとかたもなく消えつくして、ただ、現在の感じを、そのままに受け入れる力しか残っていなかった。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが……ソンナような反感も、ヒイヤリと流れかかる層雲の一角を突破して行くうちに、あとかたもなく消え失せて行った。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとかたもなく消えゆけり。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人のひとりひとりにもつ憂ひと悲しみと、みなそこの日影に消えてあとかたもない。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
