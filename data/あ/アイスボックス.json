        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "キャンプに持っていくアイスボックスには、飲み物と食材がぎっしり詰まっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暑い日のピクニックには、冷たいお茶を入れたアイスボックスが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「釣った魚は、このアイスボックスに入れておいてください」と船長が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "停電に備え、アイスボックスに保冷剤と食料を入れて準備した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バーベキューパーティーでは、ビールやジュースがアイスボックスいっぱいに冷やされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の家庭には、電気冷蔵庫の代わりに大きなアイスボックスがあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "運動会の休憩時間には、冷えたスポーツドリンクがアイスボックスから配られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "テラスに入って来た僕を見て、マティルダは足もとのアイスボックスを示した。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やしたビールが、大きなアイスボックスのなかにつまっていた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
