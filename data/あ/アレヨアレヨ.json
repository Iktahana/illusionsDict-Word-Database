              "source": "幻辞"
            },
            {
              "text": "あれよあれよと問題が発生した。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよと時間が経った。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよと昇進が決まった。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよと成功を手にした。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよと人生が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよと権力が移った。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよと危機が訪れた。",
              "source": "幻辞"
            },
            {
              "text": "あれよあれよと機会が来た。",
              "source": "幻辞"
            },
            {
