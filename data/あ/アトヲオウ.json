      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to follow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子供は母親の「後を追って」、公園の奥へと駆けていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "登山隊は、経験豊富なガイドの「後を追う」ようにして険しい山道を登った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「待ってくれ！」彼は、走り去る彼女の「後を追った」。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "若手研究者は、恩師の「後を追って」、同じ分野で研究を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの新興企業が、成功した先輩企業の「後を追う」ようにして市場に参入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年連れ添った夫の「後を追う」ように、妻も静かに息を引き取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "マニュアルの「後を追う」ように作業を進めれば、間違いは起こらないだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "『ほれ喧嘩だ』と、云ふとドツと一時に動搖めいて一崩れ、ばたばたと男の後を追うて、津浪が押し寄せた樣、逸早く合點した連中は、聲を擧げて突貫した。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "変な顔して三次と紙入れを見比べて居たが、紙入れを拾って三次の後を追う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なりひら小僧単身そッとその後を追う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて山左と左膳が後を追う。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎大声に、Ｔ「泥棒ッ」　と叫んで文六の後を追う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑怯者ッ、とばかり、文六と若侍達後を追う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎が心配して、　「コレコレ怒るな」　で後を追う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊吉は逃げて行く浪之助とお類の姿を見て後を追う。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "群を離れた犬が一疋汀へ飛んで来て草の間を嗅いでいたが、笛の音が響くと弾かれたように駆け出して群の後を追う。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "広袖を着たまま亡くなると、看病やつれの結び髪を解きほぐす間も無しに、母親も後を追う。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お雪は黒百合の花を捧げて、身に影も添わず、淋しく心細げに彳んでいたが、およそ十歩を隔てて少年が一度振返って見た時、糸をもて操らるるかと二足三足後を追うたが、そのまま素気なく向うを向いてしまったので、力無げに歩を停めた、目には暗涙を湛えたり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と間に割込むは、夫人の後を追うて、勝手口より出たる矢島、「今聞いた、何か、活す法もあると謂ったな、なろう事なら活して戻せ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "後を追うて大阪に来た、探すのに苦労した、今はこの辺りの料亭にいる。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "八代の共同作業所へ着いたのは五時過ぎだつた、そして意外にも樹明君が後を追うて来た、小郡から自転車で二時間半で飛んだのである。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後を追うようにして、先日の女のひとが鞄とステッキを持って玄関からあわてて出て来て、「あら！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「頭、大変だ、お店の軒下に縊死人があるのだ、すぐ来ておくんなさい」「そうか、すぐ往く」　米は羽織を引っかけながら小僧の後を追うた。",
              "citation": {
                "source": "寄席の没落",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "假に分ち名づけたる心が身に先だてば、身は心に隨つて後を追うて漸く一となり、身が左の方へ進めば、心も左の方へ伴なつて行き、心身一即二、二即一、の妙趣を不斷に繰返すのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴染みの女給がちかごろ東京へ行った由きいたので後を追うて行きたいと思っていた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本だけと酒をとり、果物もおごってやって、オイチョカブの北田のことを訊くと、こともあろうに北田は小鈴の後を追うて別府へ行ったらしい。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お岩は物乞に往っている父親の左門を、お袖は途中で別れた与茂七の後を追うて来たところであった。",
              "citation": {
                "source": "南北の東海道四谷怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三年の後、スティヴンスンは、其の時カリフォルニアに帰っていたファニイの後を追うて、大西洋を渡った。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニイの後を追うてカリフォルニア迄渡って来、極度の貧困と極度の衰弱との中に、友人や肉親との交通も一切断たれたまま・桑港の貧民窟の下宿に呻吟していた時のことだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にゐた二人の島民水夫が其の場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "船尾にいた二人の島民水夫がその場から海に跳び込んで脱走者の後を追うた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとかれはこのとき、海水にぬれた壁のあとをおうて眼をだんだんに上へうつしたとき、水は階段の上の口、すなわち甲板への出入り口から下へ落ちてきたのだとわかった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもなら、とびだしてきてあとをおうのですが、どうしたのか、音もたてなければ、姿も見せませんでした。",
              "citation": {
                "source": "ペスときょうだい",
                "author": "小川未明",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to die right after a loved one",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "愛する夫の死を聞き、妻は悲しみに暮れ、自らその後を追った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "唯一の肉親を失った彼は、数日後、その後を追うようにこの世を去ったという報道があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "残された家族は、深い悲しみのあまり、母親の後を追おうとしたが、周囲の懸命な説得で思いとどまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼にとって、最愛の妻を失うことは、生きる意味の喪失であり、自らその後を追うことと等しかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔の物語では、主君が亡くなると家臣が後を追うことが美談として語られることもあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年連れ添った伴侶が亡くなり、「もう私もその後を追うだけだ」と老人は寂しげに呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもが先立つ親の悲しみは深く、稀に自らその後を追う者もいると聞く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to follow an example set by earlier generations (or one's master, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "家業を継ぎ、父の偉大な功績の「後を追う」決意をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は幼い頃から尊敬する画家の「後を追う」ように、ひたすら絵の技術を磨いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "伝統芸能の世界では、師匠の教えを守り、その「後を追う」ことが弟子にとって最も重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの若者が、彼の起業家としての成功の「後を追う」べく、新たなビジネスに挑戦している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先駆者たちの研究の「後を追う」ことで、新たな発見が生まれることもある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は、偉大な祖父が築き上げた地域貢献の精神を「後を追う」と誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域のワイナリーは、隣の有名なワイナリーの品質を「後を追う」ことに尽力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
