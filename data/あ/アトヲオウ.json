[
  {
    "uuid": "7f1c9e0d-469c-5b22-b47f-28b6ce74035b",
    "entry": "後を追う",
    "reading": {
      "primary": "あとをおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ウ行"
      ],
