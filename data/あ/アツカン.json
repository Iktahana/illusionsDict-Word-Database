    "definitions": [
      {
        "index": 1,
        "gloss": "hot sake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒い夜には熱燗が体に染み渡る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人と語り合いながら熱燗を酌み交わした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鍋料理にはやっぱり熱燗がよく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「すみません、熱燗を二本お願いします。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "疲れた一日の終わりに、ゆっくりと熱燗を傾けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "父親は晩酌にいつも熱燗を好んで飲んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの酒場で、肴をつまみに熱燗を楽しむのが至福の時だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "何と……」「これは私の心意気じゃ……この首を熱燗十本で売りませう　　　　　　　　　　　損得無しの一升一生……」「アハハ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして煮肴一皿だけを取りよせて、熱燗を何本となく続けのみにした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮煮の鯛の目、鮑の蒸したのが涼しそうで、熱燗の酒がヒヤリと舌に冷いくらい――貴女が云った自棄ですか――　夕方、今しがた一時は、凪の絶頂で口も利けない。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒は熱燗のぐい呷り、雲助の風に似て、茶は番茶のがぶ飮み。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と熱燗を手酌で傾けて、「親類うちで一軒でも燒けなかつたのがお手柄だ。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……壜ごと熱燗で引掛けて、時間が來たから、のこり約一合半を外套の衣兜に忍ばせた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」懇に註文した、熱燗を鷲掴みにしながら、框へ胸を斜つかけ、腰を落して、下睨みに、刺青の腕で、ぐいと突き出す――といつた調子だから、古疊の片隅へ、裾のよぢれたので畏まつた客の、幅の利かないこと一通りでない。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鶯懷爐で春めいた處へ、膝栗毛で少し氣勢つて、熱燗で蟲を壓へた。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕許へ熱燗を貰って、硝子盃酒の勢で、それでもぐっすり疲れて寝た。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房さん、銚子をどうかね、ヤケという熱燗にしておくんなさい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　炉辺に大あぐらをかき熱燗のお酒を、といふ私のけしからぬ俗な念願は、奇蹟的に実現せられた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お天気はいいし、それに、熱燗のお酒も飲んだし、寒いどころか、額に汗がにじみ出て来た。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまっさえ熱燗で、熊の皮に胡坐で居た。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と熱燗三杯、手酌でたてつけた顔を撫でて、「おかみさん。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お世辞のいいこと、熱燗も存じております。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「熱燗附の出前ですね、こいつは好い、家にゐて持つて来て貰ふ方が好いな、もつとも駄賃が高くなりますからね、」　先生は妹の方を見て笑つた。",
              "citation": {
                "source": "黒い蝶",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱燗をぐっと引っかけて、その勢いで寝るんですな。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢや半分づつ」　熱燗の酒は烈々と薫じて、お静が顫ふ手元より狭山が顫ふ湯呑に注がれぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "了見の狭いところが少し気に入らぬが、力を貸してつかわすゆえに、家へ帰ったならば家内共に熱燗でもつけさせて、首長う待っていろよ」　退屈男らしく皮肉を残しておくと、京弥を随えながら、なにはともかくと、中間馬丁達の詰め所にやって行きました。",
              "citation": {
                "source": "旗本退屈男　第三話",
                "author": "後の旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "澄夫は恭しく大盃を押戴いたが、伝六郎が在合う熱燗を丸三本分｜逆様にしたので、飲み悩んだらしく下に置いて口を拭いた。",
              "citation": {
                "source": "笑う唖女",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　胃の腑の中に、熱燗の酒がジリジリとしみこんで行くことを考えると、日焼けした百姓ののどがガツガツした。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」安物の武士道の鼓吹者は血を啜るやうな気持で、ぐつと熱燗の酒を呷飲つた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぷんと香気のして来るような熱燗を注いで勧めた。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後山口へ、まず湯田で一浴、それから市中を歩きまはつて、労れた胃の腑へ熱燗でおでんを入れる。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "源は熱燗の極というところを猪口にうけて、「お前の御酌だと、同じ酒が余計に甘く飲めるというもんだ」「まあ、源さの巧く言うこと」「どうだい、私の女房になる気はねえかよ」「戯語ばかりお言いでない」　客も黙ってはいられません。",
              "citation": {
                "source": "藁草履",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、重吉は滑稽な状で平身低頭する眞似をして、自分にもグツと一杯熱燗を呷つた。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから早速｜草鞋を脱ぎの、行燈を下げた婢と一しよに、二階座敷へせり上つたが、まづ一風呂暖まつて、何はともあれ寒さ凌ぎと、熱燗で二三杯きめ出すと、その越後屋重吉と云ふ野郎が、始末に了へ無え機嫌上戸での、唯でせえ口のまめなやつが、大方｜饒舌る事ぢや無え。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
