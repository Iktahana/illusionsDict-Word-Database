        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "直接不満をぶつければいいものを、彼はいつも遠回しに当てこすってくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、お若い方は体力があって羨ましいですこと」と、暗に私の経験不足を当てこすられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女はわざと周囲に聞こえるような大声で、ライバルの不手際を当てこすった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "課長はミスをした部下を叱る代わりに、過去の成功例を引き合いに出して執拗に当てこすった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ふん、どうせ私なんか」と自虐を装いながら、相手の恵まれた環境を当てこする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "隣家の主人は、庭の手入れが行き届かないわが家を「自然がいっぱいでいいですね」と当てこすってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「やっぱり、才能のある方は努力の仕方も違いますね」と、皮肉を込めてライバルを当てこすった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "」　三宅は、最後の言葉を、信一郎に当てこするように云った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　三宅は、最後の言葉を、信一郎に当てこするやうに云つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」お銀は笹村に当てこするような調子で言った。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "お角の腕を認めるのは、つまりこの女の働きのないことを当てこする意味になるのを、誰も御当人ほどに受取らない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一度も平手打ちを喰ったことのない連中も、やっぱりよく飲みこめないでしょう』こういったわけで、わたしが今までの生涯で、おそらく平手打ちの一つくらい喰ったものだから、そこでこの問題の通人らしい口をきくのだろうという意味を、婉曲に当てこするに相違ないのだ。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子が何か当てこするかどうか、はっきり知りたかった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あてこするない。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャクが自分にあてこするような話をしたと信じたからである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャクが自分にあてこする樣な話をしたと信じたからである。",
              "citation": {
                "source": "狐憑",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十にもなって、碌に人に挨拶もできない奴ばかりじゃないか」と弟達にあてこすることもあった。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十にもなつて、碌に人に挨拶もできない奴ばかりぢやないか」と弟達にあてこすることもあつた。",
              "citation": {
                "source": "壊滅の序曲",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ｃ．彼は私の年をあてこする。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "演説があれば演説であてこする。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あてこする必要はない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
