        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そんなことはあり得ない。",
              "source": "幻辞"
            },
            {
              "text": "科学的にあり得ないことは起きない。",
              "source": "幻辞"
            },
            {
              "text": "常識からするとあり得ない展開だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得ない奇跡が起こった。",
              "source": "幻辞"
            },
            {
              "text": "物理的にはあり得ないことだ。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないほど幸運な人だ。",
              "source": "幻辞"
            },
            {
              "text": "法律的にあり得ない判決である。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないミスをしてしまった。",
              "source": "幻辞"
            },
            {
              "text": "医学的にあり得ない回復を遂げた。",
              "source": "幻辞"
            },
            {
              "text": "あり得ない状況に陥っている。",
              "source": "幻辞"
            },
            {
              "text": "通常はあり得ない事態が発生した。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあり得ないことが起きた。",
              "source": "幻辞"
            },
            {
              "text": "人間がそこまで変わるのはあり得ない。",
              "source": "幻辞"
            },
            {
              "text": "技術的にはあり得ないとは言えない。",
              "source": "幻辞"
            },
            {
              "text": "あり得ない偶然の連鎖だった。",
              "source": "幻辞"
            },
            {
              "text": "倫理的にあり得ない提案だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないことですが起きました。",
              "source": "幻辞"
            },
            {
              "text": "常識的にあり得ない行為である。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないほどの幸運に恵まれた。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないと思っていたことが現実になった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "すべてかういふことは、判然と示証することは出来ないけれども、短歌を作りたいといふことが、今後とも人々に全的な希望、全的な仕事として考へられることはあり得ないやうに思はれる。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、あいつに無精なんてあり得ない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな場合でもあり得ない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、歴史は面白いが個人は面白くないなぞといふことはあり得ない。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれくらいの事が自慢になるようであったら世の中に易者や探偵という商売は存在しない訳であり、奥歯一本の化石から前世界の人間や動物の全身も描きだすような学者はあり得ない訳である。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常な暴風のために空気中に物理的な発光現象が起るということは全然あり得ないと断定することも今のところ困難である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵画的模様が模様として「いき」であり得ない理由はその点に存している。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからばその際用いられる色はいかなる色であるかというに、「いき」を表わすのは決して派手な色ではあり得ない｛３｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」の存在会得に対して概念的分析は、この意味においては、単に「機会原因」よりほかのものではあり得ない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "チューインガムの流行常用によってその歯噛みの動作の反応作用から日本人が生理的並びに心理的にだんだんアメリカ人のようなものに接近して行くというようなことはあり得ないものか。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の都でなければあり得ない現象である。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "南京方面の商人が前後不覚でマルセーユからベニスあたりまで寝ているなんてことはあり得ないことですからね。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、探偵小説の面白さは實際にあり得ない事があり得るらしさに近づいてゐればゐる程強められ深くなる。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々は、ブルジョア的平和主義者や、日和見主義者に変ることなく、吾々が階級社会に住んでいること、階級闘争と支配階級の権力の打倒との外には、それからの如何なる遁れ路もないし、またあり得ないことを忘れてはならぬ。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も有利な見方をしても結局一枚の水彩画の内容の最も簡単なる説明書き以外の何物でもあり得ないであろう。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またもしそれが夢幻的空想的であるとしても、日本人のそれのように濃厚に圧縮されたそうして全国民に共通で固有な民族的記憶でいろどられたものではおそらくあり得ないであろうと思われる。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に述べたように俳句というものの成立の基礎条件になるものが日本人固有の自然観の特異性であるとすると、俳句の精神というのも畢竟はこの特異な自然観の詩的表現以外の何物でもあり得ないかと思われて来る。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちにしたって、俺等だけが部分的によくなるちゅうことはあり得ないんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　漠然とした新人なるものはあり得ない。",
              "citation": {
                "source": "「青空語」に寄せて（昭和二年一月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かぐ」ことなしにはいかなる実験も一歩も進捗することはあり得ない。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、無から有ができるとすれば、ある母体からちがった子が生まれるはずだといったような議論はしているが、これらは決して証明ではあり得ない事は明らかである。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクスウェルのデモンはあるいはまさにその一つの魔物ではあり得ないか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この難儀の問題の黒幕の背後に控えているものは、われわれのこの自然に起こる自然現象を支配する未知の統計的自然方則であって、それは――もしはなはだしい空想を許さるるならば――熱力学第二方則の統計的解釈に比較さるべき種類のものではあり得ないか。",
              "citation": {
                "source": "量的と質的と統計的と",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくらい新井田の夫人は渡瀬に対して開けっ放しに振舞ったし、渡瀬は心の中で、ありえない誘惑に誘惑されていたのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "各自が自己をこの上なく愛し、それを真の自由と尊貴とに導き行くべき道によって、突き進んで行くほかに、人間の正しい生活というものはありえないと私自身を発表してきた。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自己の階級に対してみずから挽歌を歌うものでしかありえない。",
              "citation": {
                "source": "想片",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生に清算はありえない、清算がありえないほど、かぎりなく伸びてゆくのが生である。",
              "citation": {
                "source": "行乞記",
                "author": "大田から下関",
                "note": "青空文庫"
              }
            },
            {
              "text": "・Ｍ　・ＥＲＥ　・・Ｅ　ＳＬ・ＮＥ・　すると、最初の文字はＡしかありえない。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬鹿馬鹿しくてありえないことは間違いないが、想像の余地はあるだろう？",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "足跡の重なり具合については疑いなどありえない。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            }
          ]
        }
