        "examples": {
          "standard": [
            {
              "text": "私は毎日あり得ないについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあり得ないの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあり得ないが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあり得ないについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあり得ないの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあり得ないが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあり得ないという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあり得ないについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあり得ないは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあり得ないが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあり得ないは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあり得ないの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あり得ないは様々な場面で使われる。",
