[
  {
    "uuid": "de908ca8-fa5f-51e8-8b9c-872ae8785806",
    "entry": "後棒",
    "reading": {
      "primary": "あとぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
