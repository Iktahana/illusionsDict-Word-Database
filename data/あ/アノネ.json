        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あのね、今日あったこと、まだ誰にも言ってないんだけど…」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのね、ちょっと相談したいことがあるんだけど、今いいかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのね、悪いんだけど、これ手伝ってくれない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのね、実はね、来月結婚することになったんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのね、さっきの言い方、ちょっときつくなかった？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのね、ママ、今日ね、公園でね、可愛い子犬を見たんだよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのね、みんなに大事なお知らせがあるんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ポオの無韻詩「大鴉」の表現効果は、あのねえばあ・もうあとか、れのああとかいふ言葉の、寂しく遠い、墓場の中から吹いて来る風のやうな、うら悲しくも気味の悪い音韻の繰返す反響にある。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてあのねち／＼した豆の香を嗅ぐやうな思ひがする。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、天の川の岸にね、おっかさんお話なすったわ、………〔」〕「それから彗星がギーギーフーギーギーフーて云っ〔て〕来たねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、あのねむの木の方かどこか、烈しい雨のなかから、「雨はざあざあ、ざっこざっこ、　風はしゅうしゅう、しゅっこしゅっこ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのね、この先の結核の患者の方ね。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、署長さんがね、僕のうちから、灰を二俵買ったよ。",
              "citation": {
                "source": "毒もみのすきな署長さん",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、天の川の岸にね、おっかさんお話なすったわ、……」「それから彗星がギーギーフーギーギーフーて云って来たねえ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おふみが「あのね」Ｔ「どうぞ私の願いが叶いますようにッて」　アレッレッ、　と伝六驚いて、　さてはおふみちゃん、Ｔ「誰かに惚れたね」　「知らないわ」　伝六が、　「ハテ誰かな」Ｔ「誰に惚れたんだい」　「知らないッ」　おふみちゃん、ちょいと赧い顔して立ち上る。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのね、下駄の鼻緒を切らしちゃったの。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、百花楼ではね、ときどきお客が女のひとを連れこむのに、いやよ、笑っちゃ。",
              "citation": {
                "source": "断崖の錯覚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、天の川の岸にね、おっかさんお話しなすったわ、……」「それから彗星がギーギーフーギーギーフーて言って来たねえ」「いやだわ、たあちゃん、そうじゃないわよ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、天の川の岸にね、おつかさんお話なすつたわ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、あのねむの木の方かどこか、烈しい雨のなかから、「雨はざあざあ　ざっこざっこ、　風はしゅうしゅう　しゅっこしゅっこ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてあのねちねちした豆の香をかぐような思いがする。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね……あなたまた画かきになるんでしょう……とも子近づこうとする。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのね、見舞ひに行きますのは、私の主人……まあ、旦那なんですよ。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「へーいツ」「あのね、母樣。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、ぶん撲るとね、飛着くよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからぼくをほめたよ」「あのね、すぐなくなるって。",
              "citation": {
                "source": "ありときのこ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、お金は月末まで待って呉れ給え。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからぼくをほめたよ」「あのね、すぐなくなるつて。",
              "citation": {
                "source": "朝に就ての童話的構図",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と急はしく呼鈴を鳴らして、入來つた小間使に『あのね、奧さんに珍らしいお客樣が……。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのね、お前にね。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、これが小さな、紫色の苗になりましてから、白髪のおとっさんが、あのね。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あのね、実はね、今夜あたり紀州のあの坊さんに、私が抱かれて、そこへ、熊沢だの甘谷だのが踏込んで、不義いたずらの罪に落そうという相談に……どうでも、と言って乗せられたんです。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
