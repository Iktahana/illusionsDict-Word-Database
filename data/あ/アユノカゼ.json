        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そよ風はあゆの風と呼ばれることがある。",
              "source": "幻辞"
            },
            {
              "text": "詩ではあゆの風という表現が使われる。",
              "source": "幻辞"
            },
            {
              "text": "夏の季語としてあゆの風が古典文学に登場する。",
              "source": "幻辞"
            },
            {
              "text": "俳句ではあゆの風が自然の情景を表現する。",
              "source": "幻辞"
            },
            {
              "text": "文学的には、あゆの風は涼しさを象徴する。",
              "source": "幻辞"
            },
            {
              "text": "川釣りの人々はあゆの風の季節を愛している。",
              "source": "幻辞"
            },
            {
              "text": "日本の自然季節ではあゆの風が特別な意味を持つ。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景ではあゆの風は江戸情緒を表す。",
              "source": "幻辞"
            },
            {
              "text": "美術ではあゆの風を主題にした作品がある。",
              "source": "幻辞"
            },
            {
              "text": "音楽ではあゆの風をテーマにした楽曲が作られている。",
              "source": "幻辞"
            },
            {
              "text": "民俗学ではあゆの風に関する季節風習が研究される。",
              "source": "幻辞"
            },
            {
              "text": "観光業ではあゆの風を宣伝材料にすることもある。",
              "source": "幻辞"
            },
            {
              "text": "川の生態系ではあゆが現れる季節とあゆの風は一致する。",
              "source": "幻辞"
            },
            {
              "text": "水温があゆの風が吹く季節に上昇する。",
              "source": "幻辞"
            },
            {
              "text": "漁業ではあゆの風の時期が重要な指標だ。",
              "source": "幻辞"
            },
            {
              "text": "文学批評ではあゆの風という表現の詩的意義が分析される。",
              "source": "幻辞"
            },
            {
              "text": "教育では日本文化の一部としてあゆの風が学ばれる。",
              "source": "幻辞"
            },
            {
              "text": "京都などの伝統地ではあゆの風が情緒を呼び起こす。",
              "source": "幻辞"
            },
            {
              "text": "詩歌の創作ではあゆの風が創意のヒントになる。",
              "source": "幻辞"
            },
            {
              "text": "現代詩人の中にもあゆの風という古典的表現を新しく解釈する者がいる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "汐騒のとゞろく波は　白く光れり故園一夏ひるの暑さ　やゝなごみ来る夜にいりて、家しづまりて　あゆの風いづつぎ／＼に　もらひ湯に来る隣人　ものいひなれて、礼深からず夜に入りて　やゝ風いでぬ。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "途方もなく古い話だが、私は明治三十年の夏、まだ大学の二年生の休みに、三河の伊良湖崎の突端に一月余り遊んでいて、このいわゆるあゆの風の経験をしたことがある。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
