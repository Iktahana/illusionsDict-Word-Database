[
  {
    "uuid": "58b19772-7a3f-5b3c-a5d3-093622810ba9",
    "entry": "後から",
    "reading": {
      "primary": "あとから",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
