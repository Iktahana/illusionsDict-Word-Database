      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "after",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「先にお店に入ってて。私は仕事が終わったら後から合流するから」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「その場では適当に返事をしてしまったが、後から考えると取り返しのつかない約束だった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「味が薄いようでしたら、後からお好みで塩を足して召し上がってください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「事故の時はパニックで何も感じなかったが、数日経って後から首の痛みがひどくなった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「後から後から人が押し寄せてきて、会場はあっという間に身動きが取れなくなった」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「今更そんなことを後から言われても、もう予算は決定済みで変更は効かないよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "格別、先生の口唇が、鼻腔が可笑しいといふのぢやない、起立して、先生の後から歌ふ生徒等が可笑しいといふのでもない、それどころか、俺は大体、此の世に笑ふべきものがあらうとは思つちやゐなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、さうした事態を脱がれようとするものの如く、後から後から新しい主義主張が簇出しつつあることも事実である。",
              "citation": {
                "source": "近頃芸術の不振を論ず",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本飲み終つた頃、また後から一人来た、今度は先のよりは少し綺麗、デツプリ太つて自信がおありだ。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "」下の姉さんが、上の姉さんの背後から美しい笑顔をのぞかせて言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、それら後から後から案出される※きの種々は、結局失敗に終るだらう。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から彼が悠然と歩んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが面白かつたので、すぐ次の外題が掛かると祖母にせがんで連れてつて貰つたが、その時は本願寺の高僧の葬儀の実写か何かで、後から後からゾロゾロゾロゾロ坊主ばかりの行列であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度目はまだ好い所へゆくつて気もあつたから元気だつたが、今度はもう目的地が一通りや二通り分つてゐるためでもあつて、やたらに家のことが後から後から頭に出て来た。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はＳ子の後から昇降口の方へ歩み寄つた、――ピヨツとＳ子は運転台の方へ走つて行つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして畔道には、麦を積んだ車が通り、後から後からと、列を作って行くのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あれ、芳ちやん』此の時女は耐り兼ねて、紳士の背後から躍り出た。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から靠掛る樣に抱きついて密接顏を押し附けると、切なげに身を悶えて『堪忍してよ、芳ちやん………』『………』男は何か言はうとして、僅に手先を動かしたが『阿※』と一｜唸呻、言下に反繰返つて仰樣に僵れた。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い沫が、その上を回転して、両崖の森林を振りかえりながら、何か、禍の身に迫るのを、一刻も早く遁げたいというように、後から後から、押し合って、飛んで行く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "川の水が子守歌のように、高くなり、低くなって、私たちの足音を消して、後から追い冠せて来るときには、一行はまた、森の中の人となっていた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　富士浅間神社　浅間神社の後からならでは、出すまじき馬を、番頭が気を利かして、宿まで馬士にひかせて来てくれたが、私はやはり、参詣を済ませてから乗りたいため、馬を社後まで戻させ、手軽なリュックサックを提げて町を歩きだした。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには毎日午後から雷雨と聞いているから、晴れた朝によく見て置きたいと思ったからだ。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャスタへの登路は、氷河踏査を主とするならば、私たちの路を取らずに、南のマック・クラウド村から登るか、またはやや北行して、シャスタとシャスチナ間の、窪地を目指して登る方が、よかったということを、後から聞かされた。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その背後から陶器の盃でも伏せたように、透き徹っているのは、言うまでもなく富士の山だ。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の後から跟いて入って来た者もなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服、私服の警官隊が四人、前後からドカドカッと入って来た。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、駈けていた積りであったのに、後から登って行く小林に追いつかれた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から考えるとこんなことを聞くのが如何な非常識であったかがよく分るのであるが、その当時自分と同様の質問を車掌に持出した市民の数は万をもって数えられるであろう。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後からは、男女まぜこぜのベルリン大学のお友達が沢山来た。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "というよりも芥を永く溜めてはおけない流水のように、新鮮で晴やかな顔がすぐ後から生れ出て晴やかな顔つきになる。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君ちやん（僕の名、実は君介、どうもブラ公みたいな名ですよ）どうも遅くなつて御免よ、富田の奥さんがいろんな話をしなさるから、あとからあとから話しなさるから。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとからボーイにカバンを持たせて、彼のゐる所を探すやうにやつて来る。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「四時頃」の三字はあとから行の右側へ書き入れになっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで茶をのんで餅をつまんでゐたら、同宿の若い夫婦連れがあとからはいつて来た。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の先生らしい一行があとから自分等を追越して行つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "存外すいて居る車に乘込んだが、すぐあとから小團體がやつて來て完全に車内の空間を充填してしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
