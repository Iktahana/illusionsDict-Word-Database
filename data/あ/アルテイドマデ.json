[
  {
    "uuid": "07774861-81b3-5b6b-958e-61b3fd7d7d7a",
    "entry": "ある程度まで",
    "reading": {
      "primary": "あるていどまで",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to some degree",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ここまでのプロセスはある程度までは予想できた。",
              "source": "幻辞"
            },
            {
              "text": "医学的な説明はある程度までは可能だ。",
              "source": "幻辞"
            },
            {
              "text": "学習内容はある程度までは習得できた。",
              "source": "幻辞"
            },
            {
              "text": "社会的な説明はある程度までは成り立つ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの技術習得はある程度までは教えられる。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス戦略はある程度までは計画できる。",
              "source": "幻辞"
            },
            {
              "text": "技術的な予測はある程度までは可能だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な推測はある程度まではできる。",
              "source": "幻辞"
            },
            {
              "text": "法的な相談はある程度までは弁護士が対応できる。",
              "source": "幻辞"
            },
            {
              "text": "人間関係の改善はある程度まではできる。",
              "source": "幻辞"
            },
            {
              "text": "経済予測はある程度までは可能だ。",
              "source": "幻辞"
            },
            {
              "text": "環境改善はある程度までは個人で実行できる。",
              "source": "幻辞"
            },
            {
              "text": "科学的な説明はある程度までは可能である。",
              "source": "幻辞"
            },
            {
              "text": "言語学習はある程度までは独学でできる。",
              "source": "幻辞"
            },
            {
              "text": "料理技術はある程度までは教科書で学べる。",
              "source": "幻辞"
            },
            {
              "text": "運動技術はある程度まではコーチに学べる。",
              "source": "幻辞"
            },
            {
              "text": "財政計画はある程度までは個人で立てられる。",
              "source": "幻辞"
            },
            {
              "text": "時間管理はある程度まではシステム化できる。",
              "source": "幻辞"
            },
            {
              "text": "ストレス軽減はある程度までは自分でできる。",
              "source": "幻辞"
            },
            {
              "text": "情報収集はある程度まではインターネットで可能だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それが肉体の変化の直接の影響であるか、あるいは精神的変化が外界の刺戟に誘発されてそれがある程度まで肉体に反応しているのだか分らない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは要するに適当に選ばれたる有限の独立変数にてある程度までいわゆる原因を代表し、いわゆる方則によりて結果の一部を予報し得るに依る。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず現に天気予報がその科学的価値を認められ、実際上ある程度まで成効しおるは如何なる理由によるべきか。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下の歪みの程度を測知する事はある程度までは可能なるべく、また主なる第二次原因を知る事も可能なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に上の仮想的の場合において現象の発生する時期がある程度まで知られたりと仮定せよ。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう試みがある程度まで成効した結果が今日の科学である。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは自然界の現象が有限な項から成る方程式である程度まで代表され得るというのである。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一定の位置並びに寒暖計の示す温度において測った金属棒の長さは、不可測的の雑多な微細な原因のために、種々異なる価を与えても多数の測定の平均はある程度まで一致すると考えられるのはやはりこの偶然の御蔭である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "目はまぶたによって任意に開閉され、また頭を動かすことなしにある程度までは自由に左右上下に動かされる。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある程度までは生理的効果でだれにでも共通なものである。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが云わば敵国の英国の学者の日蝕観測の結果からある程度まで確かめられたので、事柄は世人の眼に一種のロマンチックな色彩を帯びるようになって来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身も後者の類例をある程度まで承認している。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字の方はその意味を覚えるまでの練習を要する代りに、一度覚え込んでしまえばその意味の内容はある程度までははっきり規定されてしまう。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もどの画家でも相当な人ならばある程度まではそういう事を考えぬ人は無いかもしれないが、しかしそう考えるばかりで何時までも同じ谷間の径路を往復しながら対岸の自然を眺めているのでは到底駄目であろう。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女学校時代に、鮨屋の娘ということが、いくらか恥じられて、家の出入の際には、できるだけ友達を近づけないことにしていた苦労のようなものがあって、孤独な感じはあったが、ある程度までの孤独感は、家の中の父母の間柄からも染みつけられていた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句を研究してある程度まで理解しているあるフランス人に言わせると日本人は一人残らずみんな詩人であるという。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう方法によれば少なくも一時的の効果はある程度まで得られるに相違ない。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも寒暑の往来によって昼夜季節の変化を知る事はある程度までできる。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不可能でないのみならずある程度までのある意味での理解はかえってきわめて容易な事かもしれない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある程度まで近代的に翻訳する余地があるかと思われる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは少なくもある程度までは偶然的人間的な事情に支配されることは疑いないように思われる。",
              "citation": {
                "source": "物理学圏外の物理的現象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理論的に言えば、破壊の起こる直前までの過程についてはプラスティックな物体の力学からある程度まではこぎつけられるが、ほんとうに破壊が起こり始めたが最後、もう始めの微分方程式も境界条件も全部無効になるから、これらの理論はその後の事がらについては全く一言の権利もなくなってしまう。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその意図はある程度までは遂げられたように見える。",
              "citation": {
                "source": "感覚と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろんその省略が妥当であったかどうかを、最後にもう一度吟味しある程度まで実証的に判定し得られる場合もあるが、必ずしもそうでない場合がはなはだ多いのである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた一方でこの過失は、適当なる統制方法によってある程度まで軽減し得られるというのもまた疑いのない事実である。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのために特別な科学的研究機関もあり、あまり理想的ではないまでもともかくも各種の研究が行なわれ、その結果はある程度まで有効に予防と消火の実際に応用されている。",
              "citation": {
                "source": "函館の大火について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評はやはりある程度までは客観的分析的であってほしい。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音の境内や第六区の路地や松屋の屋上や隅田河畔のプロムナードや一銭蒸汽の甲板やそうした背景の前に数人の浅草娘を点出して淡くはかない夢のような情調をただよわせようという企図だとすれば、ある程度までは成効しているようである。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿や鳥などが、その食料とするいろいろの昆虫の種類によって著しい好ききらいがあって、その見分けをある程度までは視覚によってつけるらしいということが知られている。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思って自分の場合に当たってみるとある程度まではそれでうまく説明ができるように思われる。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
