        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その説明はあやふやで信用できない。",
              "source": "幻辞"
            },
            {
              "text": "あやふやな証拠では裁判に勝てない。",
              "source": "幻辞"
            },
            {
              "text": "あやふやな返事をする人は信頼されない。",
              "source": "幻辞"
            },
            {
              "text": "法学ではあやふやな法律条項の解釈が論じられる。",
              "source": "幻辞"
            },
            {
              "text": "論理学ではあやふやな命題が批判の対象になる。",
              "source": "幻辞"
            },
            {
              "text": "言語学はあやふやな表現が言語使用に与える影響を研究している。",
              "source": "幻辞"
            },
            {
              "text": "科学的方法論では、あやふやなデータは用いられない。",
              "source": "幻辞"
            },
            {
              "text": "医学ではあやふやな診断は避けるべきだ。",
              "source": "幻辞"
            },
            {
              "text": "心理学はあやふやな記憶の信頼性について研究している。",
              "source": "幻辞"
            },
            {
              "text": "教育学ではあやふやな理解を正確に修正することが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "弁護士はあやふやな証拠について異議を唱える。",
              "source": "幻辞"
            },
            {
              "text": "会計では、あやふやな計算は許されない。",
              "source": "幻辞"
            },
            {
              "text": "品質管理ではあやふやな基準は改定される。",
              "source": "幻辞"
            },
            {
              "text": "契約書ではあやふやな条項は紛争の原因になる。",
              "source": "幻辞"
            },
            {
              "text": "報告書ではあやふやな表現は削除される。",
              "source": "幻辞"
            },
            {
              "text": "プレゼンテーションではあやふやな説明は避ける。",
              "source": "幻辞"
            },
            {
              "text": "翻訳ではあやふやな用語は検討される。",
              "source": "幻辞"
            },
            {
              "text": "研究論文ではあやふやな結論は認められない。",
              "source": "幻辞"
            },
            {
              "text": "コミュニケーション研究ではあやふやな伝わり方が分析される。",
              "source": "幻辞"
            },
            {
              "text": "現代では、情報の正確性が重要なためあやふやは許されない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "もし、この順序をあやふやにして、全部人任せだったり、又は、ろくろく調べもせず、ただ覚悟ばかりで婚約し、間もなく結婚に飛び込んだとします。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何處を何う行くのだつけ、あやふやなものだけれど、日和は可し、風も凪ぎ、小川の水ものんどりとして、小橋際に散ばつた大根の葉にも、ほか／＼と日が當る。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、」とばかりで、これも一向に取合わないので、小間使は誠に張合がなく、「それでは、」といって我ながら訳も解らず、あやふやに立とうとする。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸はあやふやに、モウと唸って、膝にのせた、腹鼓。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ羽を伸して、此のあやふやな境遇を脱けて見やうじやないか。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おふくろは、何の事だか頓と解らないといふ風で、「え、そりや………」とあやふやなことを謂ツて、お房の顏を見る。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに現詩壇の常識は、極めてこの点があやふやであり、朦朧漠然とした雲の中で、認識が全く失踪している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで自由詩に関する一切の誤謬と偏見とは、実にこの二義の言語の、同一概念に於けるあやふやな混乱的錯覚に起因している。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "発表されると予期しているような、また予期していないような、あやふやな書簡、及び日記。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈芸術的〉という、あやふやな装飾の観念を捨てたらよい。",
              "citation": {
                "source": "芸術ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "村でいちばん、ものしりの牧師さんでさえ、それには、あやふやでした。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうも旦那、お出になるかならないかあやふやだったけれども、あっしゃあ舟を持って来ておりました。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、真砂町の酒井氏の、」　と首を伸ばして、分ったような、分らぬような、見知越のような、で、ないような、その辺あやふやなお妙の顔の見方をしたが、「君、紹介してくれたまえ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもあやふやだと安心がならぬ、人を恃むより神佛を信ずるより、自分を信仰なさるが一番ぢや。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「芸術的」という、あやふやな装飾の観念を捨てたらよい。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文体もあやふやで申しわけありません。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「松村です、松村は確かだけれど、あやふやな男ですがね、弱りました、弱ったとも弱りましたよ。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある種の歌が怪しく空虚に見えたり虚飾に見えたりするのは、主として観照の態度、物に対つての精神の据ゑ方、感じ方が先づあやふやな上に、不純な小主観を交へ過ぎたり、不謙譲だつたり、身構へしたり、才情の放恣、無節度と云ふ点から来る。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、渠が吉彌に女優になつて呉れろと頼んだり、吉彌の母を東京から呼び寄せて、私かにあと始末の相談をしたり、あやふやな女よりも矢張り女房の方がいいと思ひ出したりするところを、かの女は現在の自分に利害關係があるかのやうに考へた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "いッそ、かの女の思うままになっているくらいなら、むずかしいしかもあやふやな問題を提出して、吉弥に敬して遠ざけられたり、その親どもにかげで嫌われたりするよりか、全く一心をあげて、かの女の真情を動かした方がよかろうとも思った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくのあやふやな思想が、態度が、きみを病気にしたのだから」　永峯は吉本の顔を見ないようにして、一塊の鉄のように頑丈な磁鉄製の灰皿へ煙草の灰を落としながら言った。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやふやといえばぼくだってあやふやなんだ。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まずの、」とあやふや。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はそうとも思わず、ははあ、こりゃやはり自分たちと同様｜風説ばかりで、一体、実際縦覧をさせるか、させぬか、そこどころちとあやふやな華族の庭。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日にも館よりの内使が見えるかも知れないに手古奈の心があやふやでは困る。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人はこんな結論をこしらえてみたけれど、すぐあとからあやふやになってしまった。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「作家志望だと称する泥酔の佐田某なる老村吏が現れて、最もあやふやな自然主義の主張を喚きたてた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
