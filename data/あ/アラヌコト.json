    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the unthinkable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はあらぬ事をして会社を首になった。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事をされないよう警備は厳しくしている。",
              "source": "幻辞"
            },
            {
              "text": "古文ではあらぬ事が物語の転機になる。",
              "source": "幻辞"
            },
            {
              "text": "法律家はあらぬ事の責任について論じた。",
              "source": "幻辞"
            },
            {
              "text": "道徳教育ではあらぬ事をしないことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事が起こらないよう予防措置を取っている。",
              "source": "幻辞"
            },
            {
              "text": "歴史の教科書ではあらぬ事が国家に与えた影響が描かれる。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事の結果は取り返しがつかない。",
              "source": "幻辞"
            },
            {
              "text": "倫理的にあらぬ事は許されない。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事を企む者は必ず露見する。",
              "source": "幻辞"
            },
            {
              "text": "警察はあらぬ事が起こる前に対策を立てる。",
              "source": "幻辞"
            },
            {
              "text": "組織文化ではあらぬ事の風土を作らないことが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事の報告は管理職に上げられる。",
              "source": "幻辞"
            },
            {
              "text": "家庭教育ではあらぬ事をしない子どもを育てる。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事に巻き込まれないよう気をつけるべき。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではあらぬ事が物語を複雑にしている。",
              "source": "幻辞"
            },
            {
              "text": "社会的にあらぬ事は厳しく非難される。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事を防止するために規則があるのだ。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事が明かされると信頼が失われる。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ事をしないという約束が大事である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おまへの抱かれて居るは誰何、知れるかえと母親の問へば、言下に兄樣で御座りましやうと言ふ、左樣わかればもう仔細は無し、今話して下された事覺えてかと言へば、知つて居まする、花は盛りにと又あらぬ事を言ひ出せば、一同顏を見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の抱かれてゐるは誰君、知れるかへと母親の問へば、言下に兄様で御座りませうと言ふ、さうわかればもう子細はなし、今話して下された事覚えてかと言へば、知つてゐまする、花は盛りにと又あらぬ事を言ひ出せば、一同かほを見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の抱かれて居るは誰君、知れるかへと母親の問へば、言下に兄樣で御座りませうと言ふ、左樣わかれば最う子細はなし、今話して下された事覺えてかと言へば、知つて居まする、花は盛りにと又あらぬ事を言ひ出せば、一同かほを見合せて情なき思ひなり。",
              "citation": {
                "source": "うつせみ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと嬉しうて、今やこの事かたり出ん、しばししてや驚かすべき、さこそは人の羨やましがるべきをと、嬉しきにも猶はゞかられつゝ、あらぬ事ども言ひかはすほどに、折しもかの子規軒端に近う鳴く声のする。",
              "citation": {
                "source": "すゞろごと",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は多く北風吹き、火のあやまちは冬多きものなれば、怪むべくもあらぬ事ながら、東京の大火を叙せんとて、心も無く、北へ行く雲に火の色うつりて天は紅霞のわたれるが如し、など別の故も無きに筆を舞はして記さば、如何に見苦しきものに老いたる人などの見なさん。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は興奮し、あらぬ事を口走った。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言う事は、少しも取りとめがなく、すぐ、ぷんと怒るかと思えば、矢鱈に笑ったり、そうかと思えば大勢の臣下のいる前で、しくしく泣いて見せたり、また、あらぬ事を口走って王に、あなた、食ってかかったりするのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "王妃さまから、子の母として御真情を承り、つい胸が一ぱいになって、あらぬ事まで口走りました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君たちは、僕の仕事をさつぱりみとめてくれないから、僕だつて、あらぬ事を口走りたくなつて来るんだ。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少年から、嘘つき、と言われ、奇妙に痛くて逆上し、あらぬ事まで口走り、のっぴきならなくなったのである。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらぬ事を口走るものではない」　言葉尻をつかまえて、からかおうとした故、では、それがしの申すことを出鱈目、嘘いつわりと申さるるかと血相変えて詰め寄ると、その殺気におそれを成したのか、奉行はにわかに狼狽していった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、そんな話」　自分でも、あらぬ事を口走った、と思った。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛情を、お母さまの愛情を、それだけを私は信じて生きて来たのです」　とまた、ばかな、あらぬ事を口走った。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども僕がその手紙をひどく馬鹿にしているのを、マア坊は敏感に察して、たちまち態度をかえ、泣くやら、押すやら、あらぬ事を口走る結果になったのに違いない。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」あらぬ事で激昂して、ベッドから降りて帯をしめ直し、「おれは、この回覧板をたたきかえして来る。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなどは更にわけの若衆の思い入れにはあらず、情を懸けし甲斐こそあれ」とは、西洋で石田を耕すに比べられ、『四季物語』に「妹脊の道は云々、この一つのほかの色はただ盛りも久しからず、契りの深かるべくもあらぬ事なるを、いい知らずもすける愛なき云々、幼き心つからは何かは思わん。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しき憂世にたつき求むとて、心にもあらぬ事を忍びたるも幾度ぞや。",
              "citation": {
                "source": "杉田の一夜",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "館へ戻って、何かあらぬ事どもを言い触らそうも知れませぬ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのようなことが世間に洩れきこえると、口さがない京わらんべは、やれ楠の祟りじゃの、新田の怨霊じゃのと、あらぬ事どもを言い触らして、父上の武名を傷つきょうも知れぬ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしてもなか／＼いゝ女だ、久しぶりにあゝした女を見た、などとまたあらぬ事を考へ始める。",
              "citation": {
                "source": "岬の端",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "話の余勢に、思わずあらぬ事を口滑らした息子は、家に帰ってからは、これはどうしたらよかろうと思いあまって、悔い嘆いたがいまはもう取返しがつきません。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえにさかんに繁昌するとき、万一の場合を慮りてあるいは貯蓄するなり、あるいは新事業に手を出すことを慎むなり、あるいは繁昌に乗じて驕奢を極むることを矯めたりすれば、不幸にして利あらぬ事ありとするも、右のごとき謹慎を加えなかった者に比すれば失態を演ずることが少ない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとを続けようとして机に向っても心はいつもあらぬ事にのみそれて行った。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まのあたり見しにもあらぬ事どもは」しるさず、又信じないのが白石の生涯を一貫した学的精神で、シローテ審問の要領も亦もとよりこの軌道の上にあり、科学的訓練のない当時にあつて真に異例の精神であつたが、之に応じたシローテが又その知識に於てその誠実真摯な信仰に於て遜る所のない人物であつた。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ちむっと臭くなる汗の匂い、髪の匂い、げにかれらまことに雄々しく生くるために働きてあれど、なんぞその顔の日にやけ、頬はやせ、髪はあかくつやなく、かくのごとくみすぼらしくあることぞ、かくのごとく身も心も餓えてあることぞ、考えれば、かくてあらば、げに、生くるとはあまり美しくもあらぬ事かな。",
              "citation": {
                "source": "夕がたの人々",
                "author": "西村陽吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔に襲われて夢に物いう人の如く、あらぬ事のみ口走る。",
              "citation": {
                "source": "薤露行",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "君子はとやかく思ひ悩めど、さて花子の方の案に違ひたるを、包み得べくもあらぬ事なれば、拠なく有りのままを告げたるに、母はさもこそとしばしばうなづきて、さうだらうともさうだらうとも私もまさかとは思つたのだけれど、あまりお前が気にするもんだから、とうとう釣込まれてしまつたのだよ。",
              "citation": {
                "source": "当世二人娘",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "君子はとかく心進まねど、さて花子に注意を加へたる筋の事などは、父母の前にいひ得べくもあらぬ事なれば、ただ今しばらく独身にて在りたい由乞ひけるに、父はこれを我儘気随意とのみとりて、それ程の事は親の力にて抑へ得べき事と思へるにや、形ばかりの聞合せも済みて、先方へは承諾の旨告げ遣りぬ。",
              "citation": {
                "source": "当世二人娘",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　メフィストは遂に逆上し、あらぬ事さえ口走った。",
              "citation": {
                "source": "メフィスト",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ一人でも穂吉のことから、まことに菩提の心を発すなれば、穂吉の功徳又この座のみなの衆の功徳、かぎりもあらぬことなれば、必らずとくと聴聞なされや。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
