[
  {
    "uuid": "1d2367e0-df80-5e9f-8016-57357ddff42f",
    "entry": "あらぬ事",
    "reading": {
      "primary": "あらぬこと",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
