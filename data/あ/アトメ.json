[
  {
    "uuid": "72b1c0d3-4b4e-5490-9c21-741b8cfd94aa",
    "entry": "跡目",
    "reading": {
      "primary": "あとめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
