    "definitions": [
      {
        "index": 1,
        "gloss": "tsk tsk",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あらら、何かこぼれてしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらら、思った以上に大変だ。",
              "source": "幻辞"
            },
            {
              "text": "あらら、そんなことになってたんですか。",
              "source": "幻辞"
            },
            {
              "text": "子どもは何か悪いことをするとあらら、と言う。",
              "source": "幻辞"
            },
            {
              "text": "あらら、予定より遅くなってしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらら、チャンスを逃してしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらら、人間関係が複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あらら、天気が変わってしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらら、忘れ物をしてしまいました。",
              "source": "幻辞"
            },
            {
              "text": "あらら、この話は長くなりそうだ。",
              "source": "幻辞"
            },
            {
              "text": "母親はあらら、と小さく溜め息をついた。",
              "source": "幻辞"
            },
            {
              "text": "あらら、もう終わりの時間ですか。",
              "source": "幻辞"
            },
            {
              "text": "あらら、その方法は失敗したね。",
              "source": "幻辞"
            },
            {
              "text": "あらら、足りないものがあります。",
              "source": "幻辞"
            },
            {
              "text": "あらら、誰かが待ってるんですか。",
              "source": "幻辞"
            },
            {
              "text": "あらら、手に怪我をしてしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらら、運が悪かった。",
              "source": "幻辞"
            },
            {
              "text": "あらら、気づかなかった。",
              "source": "幻辞"
            },
            {
              "text": "あらら、その計画は立てられませんね。",
              "source": "幻辞"
            },
            {
              "text": "あらら、どうなることやら。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ふぶき萩原朔太郎くち惜しきふるまひをしたる朝あららんらんと降りしきる雪を冒して一目散にひたばしるこのとき雨もそひきたりすべてはくやしきそら涙あの顏にちらりと落ちたそら涙けんめいになりて走れよひたばしるきちがひの涙にぬれてあららんらんと吹きつけるなんのふぶきぞ青き雨ぞや",
              "citation": {
                "source": "ふぶき",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたき西の風きたり、　　　　あららにひとの秘呪とりて、粟の垂穂をうちみだし、　　　　すすきを紅く燿やかす。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらら木のたらたら坂に樹の蔭もなし。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　栄蔵は声をあららげていつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽ち屏風をあららかに引き退けて飛び込んだものがある。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "エリス帰りぬと答うる間もなく、戸をあららかに引き開けしは、半ば白みたる髪、悪しき相にはあらねど、貧苦の痕を額にしるせし面の老媼にて、古き獣綿の衣を着、汚れたる上靴を穿きたり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人の声はあららかにそつけなく聞えたり。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この時、二点三点、粒太き雨は車上の二人が衣を打ちしが、瞬くひまに繁くなりて、湖上よりの横しぶき、あららかにおとづれ来て、紅を潮したる少女が片頬に打ちつくるを、さし覗く巨勢が心は、唯そらにのみやなりゆくらむ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが屋根に俄かに降れる夜の雨の音のたぬしも寢ざめて聽けばあららかにわがたましひを打つごときこの夜の雨を聽けばなほ降る　雨はよく疲れた者を慰むる。",
              "citation": {
                "source": "樹木とその葉",
                "author": "なまけ者と雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが屋根に俄かに降れる夜の雨の音のたぬしも寝ざめて聴けばあららかにわがたましひを打つごときこの夜の雨を聴けばなほ降る　雨はよく疲れた者を慰むる。",
              "citation": {
                "source": "なまけ者と雨",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの飛行家が他の飛行を試みるものに殘したといふ言葉は、おそらくあらゆる技藝の祕訣もそこにあららうと思はれるもので、わたしは新聞紙上にその消息の傳へてあつたのを讀み、今だに忘れがたく思つてゐる。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらら木細工、花漬などを売る家が軒を並べている。",
              "citation": {
                "source": "木曾御嶽の両面",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "抒情詩においては、和歌の形式がいまの思想を容るるに足らざるをおもい、また詩が到底アルシャイスムを脱しがたく、国民文学として立つゆえんにあらざるをいったので、款を新詩社とあららぎ派とに通じて国風新興を夢みた。",
              "citation": {
                "source": "なかじきり",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妹とわれといるさの山の山あららぎ」（手をとりふれぞや、かほまさるかにや）と美しい声で歌いながらはいって来た大将は、「どうしてこんなに早く戸を皆しめてしまったのだろう。",
              "citation": {
                "source": "源氏物語",
                "author": "横笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "無いって、あらら、マよ、マヨネズよ、位で、一度、赤面すると、覚えてしまう心がけがある。",
              "citation": {
                "source": "大阪を歩く",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "南玉は、張扇で読み台を一つ叩くと、肩を聳かして「もやもやもやと、もやつき渡る、朝霧の中へ、俄然――忽然として現れ出でたる旗印、地から降ったか、天から湧いたか、とんと判らん、摩訶不思議、あらら不思議に、妙不思議、奇怪奇手烈、テンツクテン――」　南玉は、力任せに、ぱちんと台を、叩いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "Yew（ユー）【名】（or -tree）［植物］水松（いちい）、あららぎ。",
              "citation": {
                "source": "熟語本位英和中辞典",
                "author": "Y",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、父ちゃんが死んじゃったら、おっ母ちゃんは、肺病やみじゃないまた別の父ちゃんを捜すんだってさ、そいからまたお店を出して……お店をね、ああらら……」富次はきゅうに声を低め杉本の耳に口を寄せた。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「校長先生がはいってきたよ、あらら……やんなっちまうあ」",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長、声をあららげ、『答えぬとは、無礼者。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙念は不安に刻まるるがごとく、ともに周辺を眺めたりしが、僧徒らの姿を見るやまたあららかに、妙念　お前たちは本門の傍で見張りをしているのだ、また眠りこけてなんぞいると、総身の膚膩が焼き剥がれて生きながら骸骨ばかりになってしまうのだぞ。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（僧徒らを顧みあららかに）だがみんなどうしようというのだ。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、こっちへ来い」　隊長らしい艇員の一人が、声をあららげて、誰かを叱りとばした。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、わしも、べつだん、事をあららげたくはないのだ。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬からおろされた姫は向うに見える城あとの樹立をじっとながめていたが、遽に気をあららげて、腰に手をやって、「こんなものが今更何になる。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉野雀右衛門は、一切の経過を聞いてから、下僚と共に白州の正面へ着座して、声をあららかに訊問をはじめたが、なんと責めても怪漢は、一言も口を開かない。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "古来帝都に奉り、御笏の料とした一位の木（あららぎ）を産するのでも名高い。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、思わず声をあららげて、ジノーヴィー・ボリースィチが叫んだ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
