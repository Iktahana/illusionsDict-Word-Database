        "examples": {
          "standard": [
            {
              "text": "その好意はありがた迷惑だった。",
              "source": "幻辞"
            },
            {
              "text": "親切にされたがありがた迷惑な場合がある。",
              "source": "幻辞"
            },
            {
              "text": "ありがた迷惑な提案に困った。",
              "source": "幻辞"
            },
            {
              "text": "その支援はありがた迷惑だったらしい。",
              "source": "幻辞"
            },
            {
              "text": "良かれと思ってのことがありがた迷惑になる。",
              "source": "幻辞"
            },
            {
              "text": "ありがた迷惑という言葉は日本語らしい。",
              "source": "幻辞"
            },
            {
              "text": "指摘されたことはありがた迷惑だった。",
              "source": "幻辞"
            },
            {
              "text": "人生相談もありがた迷惑なことがある。",
              "source": "幻辞"
            },
            {
              "text": "心配してくれるのはありがた迷惑な場合もある。",
              "source": "幻辞"
            },
            {
              "text": "親心がありがた迷惑になることもあります。",
              "source": "幻辞"
            },
            {
              "text": "親切な助言がありがた迷惑に感じられた。",
              "source": "幻辞"
            },
            {
              "text": "気遣いがありがた迷惑な結果になった。",
              "source": "幻辞"
            },
            {
              "text": "善意の押しつけはありがた迷惑だ。",
              "source": "幻辞"
            },
            {
              "text": "上司の厚意もありがた迷惑な時がある。",
              "source": "幻辞"
            },
            {
              "text": "サプライズはありがた迷惑になる可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "こういった状況がありがた迷惑である。",
              "source": "幻辞"
            },
            {
              "text": "感謝しながらもありがた迷惑と感じた。",
              "source": "幻辞"
            },
            {
              "text": "社会的圧力がありがた迷惑の原因だ。",
              "source": "幻辞"
            },
            {
              "text": "ありがた迷惑を上手く断るのは難しい。",
              "source": "幻辞"
            },
            {
              "text": "人間関係ではありがた迷惑はよくあることだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中に立ってる者はありがた迷惑だ。",
              "citation": {
                "source": "疲労",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "気まぐれの御親切は、ありがた迷惑だ。",
              "citation": {
                "source": "令嬢アユ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてもやめなければならないなら、それまでは楽しくやろうっていってましたから」「令子ちゃんにとっては、かえって、ありがた迷惑だったね」　自嘲などみっともないのはわかっていたが、どうしても抑えられなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は寧ろそれをありがた迷惑だと思い、大きな御世話だと思ったところで、別段、なんの差支えもなさそうである。",
              "citation": {
                "source": "浮浪漫語",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の同志や私などが、あまりひどい御馳走を施してその上ありがた迷惑なお説教を聞かしたりすることを批難しましても、彼は決してへこみはしませんでした。",
              "citation": {
                "source": "ある男の堕落",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃありがた迷惑だね、と笑っている。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦しむほうの腕白小僧にしてみればまったくありがた迷惑なことだが、彼は折檻をしたあとでは、かならず「おまえは生きているかぎりはこのことを思い出して、ありがたく思うだろう」と言ったものだ。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時も和助は父のそばにいて、ただただありがた迷惑なような顔ばかり。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがたいけど少しありがた迷惑だ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる方言｜矯正の事業はいかにも有害な殺伐なるありがた迷惑極まる事である。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、系図書や古文書類を、家におくより役立ててほしいと、送ってくださる方もあるが、これは正直にいってありがた迷惑である。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "原因はニイチェが馬鹿正直で、ワグナアに忠実で、心から賞め、心から批評するのが、策略にとんだワグナアにはありがためいわくになったからだそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありがためいわくでね、どうも。",
              "citation": {
                "source": "演技の果て",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これじゃあんまり繁昌しすぎて、ちとありがためいわくのようだね」　と、夫人をかえりみて、悲鳴をあげられたくらいでした。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
