    },
    "definitions": [
      {
        "index": 1,
        "gloss": "riddle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "近所の駄菓子屋にあった当て物で、一番いい景品を引き当てた時の高揚感は今でも忘れられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "目隠しをして手の感触だけで中身を言い当てるという、古典的な当て物に子供たちは大はしゃぎしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "客観的なデータに基づかない市場予測など、ただの当て物に等しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "宴会の余興として用意された数々の当て物は、参加者の予想を裏切る難解なものばかりだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "適当にマークシートを塗りつぶすような当て物感覚では、この難関資格を突破することは到底不可能である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "嫌よあたし、そんな当て物みたいなこと」　ロスリッジが黙って俯向いて、焼麺麭の片を弄んでいるので、細君は半ば冗談に、だが、何となくきっとした声で、「誰なの？",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ツに一ツだから率のよい当て物だ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "『この当て物はなかなか骨だわい』と彼は、空想を逞しゅうしながら考えるのだった。",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでこいつは当て物だわえ」　才蔵はすっかり悦に入った。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "メンコ、根ッ木、ブランコ、縄飛び、ラムネの玉遊び、コマ、凧、石蹴り、石鉄砲、竹馬、金輪廻し、吹矢、当て物、隠れンぼ、かるた、十六ムサシ、といったような類である。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘイ……つめたいお茶を一ツ……おあてものも御座いませんで……アナタ……」「……ヤッ……どうもありがとう……どうぞお構いなく……」　と大きな声で云いながら、私は余儀なく板張りに坐り込んだ。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが或る日柄にない力にまかいてこれぞと云う目あてものうて朝早くから飛び出いた。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその次には、玉転がし、文廻し、鉄砲、くじ引き、瓶釣り、その他あらゆるあてものの店がならんでいる。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もっと深いところでこんにち認められる危険は、資本主義社会のいわゆる文化、娯楽が、きわめて知覚的な刺戟の連続として歌謡・バレー、あてものなどで組立てられ、プログラムづけられているということである。",
              "citation": {
                "source": "文学と生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その時分のモダンは、四布風呂敷ほどの大きさの肩掛けをかけたり、十八世紀風のボンネットや肩に当ものをしたり、お乳にもあてものをして、胸のところで紐を編上げたりするシミズを着て、腰にはユラユラブカブカする、今なら襁褓干しにつかうような格好のものを入れて洋服を着ていた時代である。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "何じゃろ、今日のよな日のあてものにはもってこいと云うものじゃ……第一の精霊　嬉しがりもせず笑いもせなんだ？",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "口あくと歯にしみる風は願うても吹いては居ぬ、サ、今のあてものでも云って見なされ下らない様でも面白いものじゃ。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の精霊　とは御相拶な、考える事のなさそうなお身が考えて居るとは、――今のあてものかそれともほかの事かな。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてものよりもむずかしいものと見えて、すけをたのみたいほど迷って居るワ。",
              "citation": {
                "source": "葦笛（一幕）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水飴のほかにあてものや駄菓子などももつてるのでみんなは我がちに赤や青の紙をめくつてあてものをする。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は配達の帰りなどにこの駄菓子屋に寄って、近所の子供たちとあてものの籤を引いたりした。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてもの遊び　鹿の角なら二本にきまっているようなものだが、これは角の叉がいくつに岐れているかということらしい。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行といってしまえばそれでも説明はつくが、あまりにも無意味だから何か別の形があり、それが鹿・鹿・角・何本でないまでも、少しはこれに近いような「あてもの遊び」が、行なわれていた名残りではないかと考えている。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうと一しょに全員が土の上にしゃがんでしまい、そのあとで、うしろの正面だァれというのもあり、また全くそれをいわないのもあるが、動いている人の輪がはたと静止したときに、真後にいるものを誰かときくのだから、これは明らかに「あてもの遊び」の一つであった。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなの遊戯などということは考えにくいようだが、今でも元気な人たちは退屈すると、おりおり思いついて子どもみたようなあてものなどをする。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが今はただ児童のあてもの遊戯の中に、幽かな残形を留めているのである。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初これがあてもの遊びの一つであることを知っていた間は、女の児の中でも行なわれていたものと思われる。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "prize",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "縁日の屋台で、一等賞の豪華な景品を狙って当て物に挑戦する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「さあ、何が出るかは引いてのお楽しみ、当て物だよ」と威勢のいい声が飛ぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔懐かしい駄菓子屋の店先で、子供たちが小銭を握りしめて当て物のくじを引いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "十分なデータに基づかない市場予測などは、結局のところ当て物に過ぎない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんなの当て物じゃないか」と、根拠のない無責任な推測を一笑に付した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "箱の中身が何であるかを当てる当て物遊びをして、放課後の教室で盛り上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "covering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ズボンの膝が擦り切れてしまったので、裏から丈夫な布の当て物を縫い付けて補強した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "精密機器を梱包する際、外部の衝撃から守るために発泡スチロールの当て物を隙間に詰めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「金槌で直接叩くと材が凹んでしまうから、適当な木片を当て物にしてから打ってね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "傷口を保護するために、清潔なガーゼを当て物として使い、その上から包帯を巻いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長時間のバイオリン演奏で首が擦れないよう、あご当ての部分に柔らかな布の当て物を装着した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家具を搬入する際、柱の角を傷つけないよう厚手の段ボールを当て物にして養生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
