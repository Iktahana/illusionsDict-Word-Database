        "examples": {
          "standard": [
            {
              "text": "年末年始は、久しぶりに親戚の集まりが予定されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕事帰りに、大学時代の旧友たちと小さな集まりを持った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この公園は、週末になると近所の愛犬家たちの集まりの場として賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "明日の夜、マンションの理事会の集まりがあるため、早めに帰宅しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今夜はちょっとした集まりがあるから、夕飯は外で済ませてくるよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学会の閉会後、専門分野を同じくする若手研究者らによる非公式な集まりが開かれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は華やかなパーティーよりも、気心の知れた友人同士の静かな集まりを好む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "間もなく水はサラサラ鳴り、天井の波はいよいよ青い焔をあげ、やまなしは横になつて木の枝にひつかかつてとまり、その上には月光の虹がもかもか集まりました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処は多分は、野馬の集まり場所であったでしょう、霧の中に円い広場のように見えたのです。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところどころに、五六人の女が集まり、小さな群團をつくつてゐた。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝まだき、東の空ようやく白みしころ、人々皆起きいでて合羽を着、灯燈つけ舷燈｜携えなどして波止場に集まりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの経験的事実の集まり方はそれまでの歴史に無関係ではない。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと考えると数学は純粋な論理の系統であり、語学は偶然なものの偶然な寄り集まりのように見える。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またすぐ眼の下のまちまでが、やっぱりぼんやりしたたくさんの星の集まりか一つの大きなけむりかのように見えるように思いました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河原のいちばん下流の方へ洲のようになって出たところに人の集まりがくっきりまっ黒に立っていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廻りの五疋も一ぺんにぱっと四方へちらけようとしましたが、はじめの鹿が、ぴたりととまりましたのでやっと安心して、のそのそ戻ってその鹿の前に集まりました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鹿はそれからみんなばらばらになって、四方から栃のだんごを囲んで集まりました。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからはもう毎日毎日子供らが集まりました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそんなことには一向構はず林にはやはり毎日毎日子供らが集まりました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その杉もやっと一丈ぐらゐ、子供らは毎日毎日集まりました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処は多分は、野馬の集まり場所であったでせう、霧の中に円い広場のやうに見えたのです。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーティストたちは、あるいは戸口に立ち、あるいはたき火のそばまで行って、外の景色をながめてゐましたが、この時大急ぎでみんな私のうしろに集まりました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子鼻の上の松林には今夜も梟の群が集まりました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」小さな子どもらはみんな集まりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはたぶんは、野馬の集まり場所であったでしょう。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそんなことには一向構わず林にはやはり毎日毎日子供らが集まりました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その杉もやっと一丈ぐらい、子供らは毎日毎日集まりました。",
              "citation": {
                "source": "虔十公園林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく水はサラサラ鳴り、天井の波はいよいよ青い焔をあげ、やまなしは横になって木の枝にひっかかってとまり、その上には月光の虹がもかもか集まりました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その自殺致しました△△には妻と男の子が三人ありまして、今申上げましたような事情で路頭に迷うておりますのを、微力ながら吾々友人が寄り集まりまして、どうにかこうにか喰えるように処置いたしましたが、ここに困りますのはその三人の子供に父の死因が知らせられない事で御座います。",
              "citation": {
                "source": "恐ろしい東京",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある年の十二月末つ方、年は迫れども童はいつも気楽なる風の子、十三歳を頭に、九ツまでくらいが七八人、砂山の麓に集まりて何事をか評議まちまち、立てるもあり、砂に肱を埋めて頬杖つけるもあり。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはいかに、われらの火燃えつきぬと叫べば、童ら驚ろき怪しみ、たち返えりて砂山の頂に集まり、一列に並びてこなたを見下ろしぬ。",
              "citation": {
                "source": "たき火",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "よそから毎晩のようにこの置座に集まり来る者二、三人はあり、その一人は八幡宮神主の忰一人は吉次とて油の小売り小まめにかせぎ親もなく女房もない気楽者その他にもちょいちょい顔を出す者あれどまずこの二人を常連と見て可なるべし。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二郎述べおわりて座につくや拍手勇ましく起こり、かれが周囲には早くも十余人のもの集まりたり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年の目と少女の目と空に合いし時、少女はさとその面を赤らめ、しばしはためらいしが急に立ちあがりかの大皿のみを左手に持ちて道にのぼり、小走りに駆け入りしは騎馬隊の兵士が常に集まりて酒飲むこの街唯一の旗亭なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」弧光燈にめくるめき、　　　　　　　羽虫の群のあつまりつ、川と銀行木のみどり、　　　　　　　まちはしづかにたそがるゝ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "火雲あつまり去れば、　　麦の束遠く散り映う。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなはだれもパッと顔をほてらせてあつまり手を斜に東の空へのばして「ホッホッホッホッ。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
