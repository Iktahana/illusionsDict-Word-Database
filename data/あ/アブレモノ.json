        "examples": {
          "standard": [
            {
              "text": "私は毎日あぶれ者について考えている。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあぶれ者の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあぶれ者が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあぶれ者について学習した。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあぶれ者の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあぶれ者が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあぶれ者という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあぶれ者についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあぶれ者は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあぶれ者が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあぶれ者は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあぶれ者の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあぶれ者は興味深い例である。",
              "source": "幻辞"
            }
          ],
