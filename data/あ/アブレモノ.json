        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "社会的にあぶれ者となった彼は居場所を求めていた。",
              "source": "幻辞"
            },
            {
              "text": "昭和の文学ではあぶれ者が主人公として描かれることが多い。",
              "source": "幻辞"
            },
            {
              "text": "社会学はあぶれ者の生活実態を研究対象とする。",
              "source": "幻辞"
            },
            {
              "text": "あぶれ者と呼ばれた人々には深刻な差別があった。",
              "source": "幻辞"
            },
            {
              "text": "経済的な理由であぶれ者になる人も多い。",
              "source": "幻辞"
            },
            {
              "text": "教育現場では、あぶれ者への差別をなくすことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "法律ではあぶれ者への基本的人権を保護している。",
              "source": "幻辞"
            },
            {
              "text": "心理学はあぶれ者の孤立感と抑うつについて研究している。",
              "source": "幻辞"
            },
            {
              "text": "映画ではあぶれ者の人生が感動的に描かれることもある。",
              "source": "幻辞"
            },
            {
              "text": "文学賞を受賞した小説ではあぶれ者が深刻に描写される。",
              "source": "幻辞"
            },
            {
              "text": "医療現場ではあぶれ者への対応が課題である。",
              "source": "幻辞"
            },
            {
              "text": "福祉制度はあぶれ者への支援をめざしている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的には、社会的弱者はしばしばあぶれ者と見なされた。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの世界でもあぶれ者は存在する。",
              "source": "幻辞"
            },
            {
              "text": "労働組合はあぶれ者の労働権を守るために活動している。",
              "source": "幻辞"
            },
            {
              "text": "人権活動家はあぶれ者への差別撤廃を求めている。",
              "source": "幻辞"
            },
            {
              "text": "自伝文学ではあぶれ者から人生を変えた経験が語られる。",
              "source": "幻辞"
            },
            {
              "text": "旅人の中にはあぶれ者と呼ばれる人もいる。",
              "source": "幻辞"
            },
            {
              "text": "音楽の歌詞にはあぶれ者の悲哀が歌われることがある。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではあぶれ者という概念を超えた包括的な社会づくりが求められている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "未来都市計画は、お人好しの立案者が予想しなかったあぶれ者の流入によって、足元をすくわれると相場は決まっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会のまともな枠組みからはみ出したあぶれ者のかなりが、この新しい種に飛び付いた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶれ者共のするような喧嘩商売は、今日かぎり思い切らねばなりませぬぞ。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "役人さえ、あぶれ者の味方なのだ――見ろ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう狂っては、却ってお身の不為――あぶれ者の目にも触れなば、いのちがござらぬぞ」五　哮り狂う長崎屋の形相は、いよいよ物すごく歪むばかりだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとまた同時に、どこかその近邊をうろついてゐた一人の汚ないあぶれ者が別の方面から彼に近づいて來た。",
              "citation": {
                "source": "帽子箱の話",
                "author": "スティーヴンスン",
                "note": "青空文庫"
              }
            },
            {
              "text": "小男で、貧相で、見るからに風采の上らぬのんだくれの、人生のあぶれ者の感じであつたが、よく見ると、美しいのだ。",
              "citation": {
                "source": "花火",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には、あぶれ者など言ふ語をさへ生む様になつた程で、もと／＼彼等はごろつきだつたのである。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八　美的な乱暴以上述べて来た様に、歌舞妓芝居の起るまでには、従来考へられてゐたものゝ外に、かうしたあぶれ者・乱暴者の生活から発生してゐると言ふ事実があり、尚、直接の原因としては、幸若の舞太夫の扶持を離れたものが、民間に下つたと言ふことがある。",
              "citation": {
                "source": "ごろつきの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その民衆も生え抜きの民衆ではなく、民衆の中の泡です、民衆を代表すると名乗って、実は民衆のカス、民衆の屑、民衆のあぶれ者の、浅薄なる寄集りを民衆と称して、それに近寄って御機嫌を取ったために、最も浅薄な、そのくせイヤに性質の悪い勢力を作ってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "Ocean の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰文はかねて手なずけていたあぶれ者に天羽の寝所を襲わせて車部屋へひきこむと、いつそんなものを作ったのか、柱に十文字にぶっちがえた磔木に縛りつけてまず鞭で精一杯に撲りつけた。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二十日ばかり、保平殿は私を疎外し、打明けたことはなにもいってくれない」　泰文はあぶれ者を呼びこみ、天羽の手首を括り、縄の端を梁の環に通して網を引かせた。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っているだけのことを言います」　天羽をおろすと、あぶれ者どもを車部屋から追いだし、天羽と二人だけ残った。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申すのは、明け方まで中庭で待っているのが例だったからです」　あぶれ者が呼びこまれ、天羽はまた梁に吊りあげられた。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホ、ホ、ホ、その澄江様、どうで担いだ人間が、馬方博徒のあぶれ者なら？",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これほどの大家の総領でいながら、あぶれ者などを集めまして、そのお頭などになりまして、近郷近在まで出かけて行き、面白ずくの殺傷沙汰。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　許せ――と、聞こえて、その、あぶれ者の浪人は、もう、佐原屋の土間口へ踏みこんだ様子だ。",
              "citation": {
                "source": "口笛を吹く武士",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "小声にいましめあって離室に迫った泰軒と栄三郎は、戸をあけたひとりは栄三郎が、抜き討ちに斬って捨てたもののそれは名もない小｜博奕うちの御家悪ででもあるらしく、なかには、当の左膳をはじめ何人あぶれ者が雑魚寝をしているかわからないから、両人といえどもうかつには踏みこめない。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者とは言え、あぶれ者の長庵のことだから、九寸五分ぐらいは何時だって呑んでいる。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、この二つ以外何ものもない、大悟徹底したあぶれ者が揃っていたものだ。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "その敵方の鷹匠町に、ひとりとほうもなく勇敢なのがいて、これにだけは、門前町のあぶれ者も手を焼いていた。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら気丈夫でも、女一人に相手はあぶれ者が五、六人、どうしてかなう道理はない。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "二間きりらしい荒れ果てた家、すぐに御家人くずれの博奕こき、あぶれ者の御家新が起きて来た。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "無明の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を殺すのに名乗りをかけてからやるやつもないもんだが、しかし、そんな気狂いじみたあぶれ者ということなら、やけっ腹になってどんなことをしでかさないともかぎらない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手の逆徒、天狗もさるもの、敵の陣立て見てあれば、総大将は水戸町奉行田丸稲之右門直諒をはじめとして文武諸館、神勢館の水戸藩土、浪人、あぶれ者、野士、百姓、町人、ならず者、都合その勢四千人、……オッと喋っちまっちゃ商売にゃならねえ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村のあぶれ者で、小博奕と強請を渡世のやうにしてゐる照吉と伊太郎といふのが、尾久の土手で斬られて、ひどい死樣で――」「フーム」「その晩、地主の清水和助の一人息子、清次郎といふ※粉で拵へたやうな息子が行方不知になつたんで」「昨夜は狐の嫁入はなかつたのか」「生憎雨が降らなかつたせゐか何んにもありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地者には、この二人のあぶれ者を一緒に相手にして、見事に斬り伏せるやうな、そんな腕の立つ人間はありません」　喜八の説明は如何にもよく行屆きます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "狐の嫁入",
                "note": "青空文庫"
              }
            },
            {
              "text": "泰文は手なづけていたあぶれ者をやって、天羽を車舎にひきこむと、いつの間にそんなものを作ったのか、十字にぶっちがえた磔木に縛りつけ、まず鞭で精一杯に撲りつけた。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "保平が朝霞のところでなにをしていたか、あなたは知っているはずだ」「この二十日ばかり、保平殿は私を疎外し、打明けたことをいってくれないからなにも知らない」　泰文は天羽の手首を括って繩の端を梁の環に通し、あぶれ者にその綱を引かせた。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おろしてください、知っているだけのことを言います」　天羽をおろすと、あぶれ者どもを車舎から追いだし、二人だけになったところで、いかめしく促した。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
