        "examples": {
          "standard": [
            {
              "text": "機内アナウンスで、担当アテンダントへの連絡方法が案内された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "講演会では、参加者の誘導や質問対応のため、数名のアテンダントが配置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "特別な観光ツアーでは、各グループに一名ずつ専任のアテンダントが付き、詳細な説明を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "駅構内で迷っている乗客に、ボランティアのアテンダントが親切に声をかけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お手荷物のお預かりは、あちらのカウンターのアテンダントまでどうぞ」と、係員が案内していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "入院患者を病室まで案内する際、医療アテンダントが付き添った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "イベント会場での円滑な進行のため、多数のアテンダントが会場内を巡回した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "ジャンクションを曲がるとき、向こうのガス・ステーションの給油ポンプのわきで、アテンダントのジョーが手を振った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
