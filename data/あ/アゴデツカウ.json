[
  {
    "uuid": "4f50cf2f-d50c-5454-aa9e-1e27f795fef6",
    "entry": "あごで使う",
    "reading": {
      "primary": "あごでつかう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-ウ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to set someone to work in an arrogant fashion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "上司があごで僕を使って報告書を作らせた。",
              "source": "幻辞"
            },
            {
              "text": "母親が子どもたちをあごで使って家事をさせている。",
              "source": "幻辞"
            },
            {
              "text": "監督が選手たちをあごで使って練習させた。",
              "source": "幻辞"
            },
            {
              "text": "あいつはいつもみんなをあごで使うばかりだ。",
              "source": "幻辞"
            },
            {
              "text": "部長は新人たちをあごで使うのが癖になっている。",
              "source": "幻辞"
            },
            {
              "text": "親が子どもをあごで使うのは教育的ではない。",
              "source": "幻辞"
            },
            {
              "text": "昔の貴族は召し使いをあごで使うのが当たり前だった。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトマネージャーはチームメンバーをあごで使う傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "彼女はボーイフレンドをあごで使う癖がある。",
              "source": "幻辞"
            },
            {
              "text": "会社の偉い人たちはしばしば部下をあごで使う。",
              "source": "幻辞"
            },
            {
              "text": "姉は弟をあごで使って荷物を運ばせた。",
              "source": "幻辞"
            },
            {
              "text": "社長がスタッフをあごで使って全部やらせた。",
              "source": "幻辞"
            },
            {
              "text": "先輩後輩の関係であごで使われることもある。",
              "source": "幻辞"
            },
            {
              "text": "あごで使わずに丁寧にお願いするべきだ。",
              "source": "幻辞"
            },
            {
              "text": "映画では貴族があごで使う場面がよく出てくる。",
              "source": "幻辞"
            },
            {
              "text": "従業員をあごで使うような経営者は信用されない。",
              "source": "幻辞"
            },
            {
              "text": "親があごで使うと子どもが反発する。",
              "source": "幻辞"
            },
            {
              "text": "あごで使う人間関係は長続きしない。",
              "source": "幻辞"
            },
            {
              "text": "部屋の掃除をあごで使ってやらせてしまった。",
              "source": "幻辞"
            },
            {
              "text": "研究チームではリーダーがあごで使うような環境は避けるべき。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "どなる悠吉、妻や娘をあごで使うことに不自然を感じない悠吉の中に、妻を引っぱって肩を並べてゆこうとするものも隣りあっているのだ。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
