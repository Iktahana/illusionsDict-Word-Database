        "examples": {
          "standard": [
            {
              "text": "あってはならないについて考えてみました。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないの意味を理解しました。",
              "source": "幻辞"
            },
            {
              "text": "日常生活であってはならないが使われています。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないに関する知識を深めました。",
              "source": "幻辞"
            },
            {
              "text": "辞書であってはならないを調べました。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないの用法について学びました。",
              "source": "幻辞"
            },
            {
              "text": "様々な分野であってはならないが活用されている。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないの応用例を見つけました。",
              "source": "幻辞"
            },
            {
              "text": "専門家があってはならないについて論じている。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないについての研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "教育の場であってはならないが教えられている。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないの歴史を追うことは興味深い。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からあってはならないを理解する。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないの変化に気づきました。",
              "source": "幻辞"
            },
            {
              "text": "言語や文化におけるあってはならないの重要性。",
              "source": "幻辞"
            },
            {
              "text": "分析結果からあってはならないの特性がわかった。",
              "source": "幻辞"
            },
            {
              "text": "一般的なあってはならないの使い方を習得しました。",
              "source": "幻辞"
            },
            {
              "text": "複雑なあってはならないの概念を説明する。",
              "source": "幻辞"
            },
            {
              "text": "あってはならないに関連する他の用語がある。",
              "source": "幻辞"
            },
            {
              "text": "最新のあってはならないに関する情報を入手した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "一言にしていえば「いき」の研究は「形相的」であってはならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間は床板を張って室内の他部と判明に対立することを要する、すなわち床の間が「いき」の条件を充すためには本床であってはならない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "お取り込みのところをそれには及ばないと、おせきは一応辞退したのであるが、それでも間違いがあってはならないと言って、伯母は無理に要次郎を付けて出した。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に有るべきところの人生は、決してこんな態であってはならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家であっても、またもちろん詩人であっても、芸術家は本質上に於て俗物であってはならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから探偵小説は芸術であってはならない。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その遺書には、　心を正しくしなければ諸人誠をもって仕えない、ただ才智｜許りでなく度量を広く持たれます様に、　無慾にして依古贔屓があってはならない、能才を見出さなければならない、　武のみでは立ちがたいものである、文を修められますように、　礼節を軽んぜられませぬように、　等々の箇条があった。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつ如何なる場合にも声が顫えるようなことは金輪際あってはならないのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷章は自分のしうちがあまり残酷であったと思って後悔すると共に、女に万一のことがあってはならないと思って、はらはらしながら家を出て探しに往った。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南は万一のことがあってはならないと思ってまた賄賂を用いたので、その事件もそのままになってしまった。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただ、彼女の健康がすぐれなくて、彼女に万一のことがあってはならないと思ったからだけですもの。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じように分配して、誰も余計にとるようなことがあってはならない。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし迂闊な者を酒宴の席に侍らせて、酒の上から彼の感情を害すような事があってはならないという遠慮から、すべての者を遠ざけて、酒席の取持ちは太守一人が受持つことにした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "宣室志（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、それはこんな場合であってはならない。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一巻の虫食い本に眼を眩まされて、死ぬまで尚机を離れないようであってはならない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから私は彼がその点で逆に誤解を受けることがあってはならないとも思って、親王にしないで人臣の列に入れておいた。",
              "citation": {
                "source": "源氏物語",
                "author": "榊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来源氏はいろいろと昔以上の好意を表しているのであるが、なお若かった日すらも恨めしい所のあった源氏の心のいわば余炎ほどの愛を受けようとは思わない、もう二人に友人以上の交渉があってはならないと御息所は決めていたから、源氏も自身で訪ねて行くようなことはしないのである。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで自分がもろい涙を見せて、男の覚悟をにぶらせるような事があってはならない。",
              "citation": {
                "source": "心中浪華の春雨",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し人間の生活の中に在る一人の人間はかくあってはならない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の恋には絶頂があってはならない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな写真がいったいこの部屋なんぞにあってはならないのだが。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "探偵小説にももちろん、神秘的要素は必要だが、探偵小説の神秘は、科学前期の神秘であってはならない。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれはどうでもいいが、お前が困るようなことがあってはならない。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に申上げた祖母のお初はまだ十八の娘で、今夜のお給仕役を勤めるはずになっているので、なにかの手落ちがあってはならないと台所の方へ見まわりに行きますと、お料理はお杉という老婢が受持ちで、ほかの男や女中たちを指図して忙しそうに働いていましたが、祖母の顔をみると小声で言いました。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらのことで、夜もだんだんに更けてくるので、わずか二分の金を惜しんで万一の間違いがあってはならないと、誰の考えもおなじことで、若狭屋でも相手の注文通りに金の袋を出しておいたが、それは夜のあけるまでそのままになっていた。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
