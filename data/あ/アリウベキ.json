        "examples": {
          "standard": [
            {
              "text": "私は毎日あり得べきについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あり得べきという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあり得べきの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあり得べきが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あり得べきを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあり得べきについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あり得べきの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあり得べきの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあり得べきが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得べきという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあり得べきという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあり得べきについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あり得べきを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあり得べきは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得べきについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあり得べきが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあり得べきは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあり得べきの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あり得べきは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあり得べきは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
