        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これはあり得べき結果だと思う。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき状況を想定して対策を立てた。",
              "source": "幻辞"
            },
            {
              "text": "最もあり得べき展開はこのようなものだ。",
              "source": "幻辞"
            },
            {
              "text": "科学的にあり得べき仮説を立てた。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき複数のシナリオを検討した。",
              "source": "幻辞"
            },
            {
              "text": "予測不可能だが数あり得べき可能性がある。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき失敗パターンを洗い出した。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき困難に備える必要がある。",
              "source": "幻辞"
            },
            {
              "text": "リスク管理ではあり得べき悪場面を想定する。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき確率が高い。",
              "source": "幻辞"
            },
            {
              "text": "歴史的背景からあり得べき結論だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき論理的帰結である。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき理由が複数ある。",
              "source": "幻辞"
            },
            {
              "text": "統計的にはあり得べき傾向だ。",
              "source": "幻辞"
            },
            {
              "text": "心理学的にはあり得べき反応だ。",
              "source": "幻辞"
            },
            {
              "text": "経済学的にあり得べき動きをしている。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき懸念は払拭できていない。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき選択肢の中から最適を選んだ。",
              "source": "幻辞"
            },
            {
              "text": "今後あり得べき事態に対応する。",
              "source": "幻辞"
            },
            {
              "text": "あり得べき最悪のシナリオも考慮した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ところが五十音図によると、五十だけの違った音があり得べきはずであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　永久の夜と云う事がこの地球上にあり得べきや、しかりあり、いまだ見し人はなしと云えど、この地球上―人間の行くあたわざる果に到れば、そこには昼なく常に夜のみと云う事をかつて聞けり。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてのあり得べき奇異の事情と、その臆測される推理の後で、夫人はすっかり混惑してしまった。",
              "citation": {
                "source": "ウォーソン夫人の黒猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを是正されるという事は如何に芸術の力とはいえ医学上あり得べき事でない。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御覧な、あの数々のものの、剛健な、あり得べき夢とあり得べからざる夢の間に、忽然と展いた通りを。",
              "citation": {
                "source": "花束一つ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる詐欺が行わるべしとは今の人に受け取れぬが、『義残後覚』七、太郎次てふ大力の男が鬼面を冒り、鳥羽の作り道で行客を脅かし追剥するを、松重岩之丞が斫り露わす条、『石田軍記』三、加賀野江弥八が平らげた伊吹の山賊鬼装して近郷を却かした話などを参ずるに、迷信強い世にはあり得べき事だ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔話ならば格別、実際に於いてそんな事実が決してあり得べき筈がないと彼は思った。",
              "citation": {
                "source": "火薬庫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事があり得べきではない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は單にかういふ事をあり得べき事として想像するのみでない。",
              "citation": {
                "source": "維新史の資料に就て",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "作のくだらなさを演技指導ないし演出で補うなどということはあり得べきこととは思えない。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくに蕪村が幾分か太祇に導かれし部分もあり得べきを信ずるなり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し、右のような態度が、人類のあり得べき発達の少くとも或る程度迄到達した状態であるとしたら、今日、我々の周囲を取繞く、日本の社会はどうであろう。",
              "citation": {
                "source": "深く静に各自の路を見出せ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくあり得べき一つの重大な誤解を警戒しておく必要があると思う。",
              "citation": {
                "source": "空間概念の分析",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "この根本的な立場に立つ一つのあり得べき意見として遠隔作用の説は待遇されねばならぬ。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりこの場合は、所謂印象批評の上乗のものであるわけだが、勿論こういう印象批評であっても、批評のあり得べき一つの親しい様式として、大いに意味のあることは否定出来ない。",
              "citation": {
                "source": "所謂批評の「科学性」についての考察",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の老齢の諸先生方がこの恩典に預かったことはあり得べきことと思われるが、われわれはまだ老人というわけでもなく、また、今日まで多少美術のことに力を尽くして来たとはいうものの、まだ歳月も浅し、経験も浅く、功績というほどのことを残したと思うほどのこともない。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "帝室技芸員の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父なる神」や救世主や天主の守護神なども存在しないし、さらに、私たちにはあり得べき隠れ家も、自分たち自身の他にはあり得ないことを教えてくれるだろう。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこんな事のあり得べきかどうかについて疑い出した。",
              "citation": {
                "source": "常識",
                "author": "COMMON SENSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあり得べき事か、またはＹ――の錯覚であるか、それはこの物語がすんだあとで貴方は当然私に答えて下さらなければならないのです。",
              "citation": {
                "source": "壊れたバリコン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "久木氏のことで死を導いた父のこの骨箱だとしても、それが誰があり得べきことだと思うだろうか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "従ってその液体の何たるかを問わず、単に水に似たるもの、もしくは、それが何等かの液体なる事を認めたるのみにて直ちにこれを嚥み下すことは、あり得べき道理なり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこれを問題にするのはあとで読者をあっと云わせる探偵小説か何かの話で、実際にはあり得べき事でない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、また、冷静に考えて、「虫」であるというには、尺八が主になることもあり得べきことだが、尺八ばかりではまとめてゆけないから、ある部分は尺八に譲っても、結局箏を主にすることになると考えた。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、「颶風時代」の第三幕に於ては、文久二年十二月十三日の品川宿遊女屋土蔵相模に於ける、伊藤俊輔と志道聞多との会話、焼弾陰謀の相談等、実際にあり得べきことである。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "一般に哲学へのあり得べき正しき道として三つのものが指摘し得られる。",
              "citation": {
                "source": "語られざる哲学",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "所信の貫徹に潜める大苦心　元来、義務と義務との衝突は根底においてあり得べきものでない。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは溪の上にだるま茶屋があって、そこの女が客と夜更けて湯へやって来ることがありうべきことだったのである。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにも係わらずその善良な心からどこまでも葉子の言葉に信用を置いて、いつかは自分の誠意が葉子の心に徹するのを、ありうべき事のように思って、苦しい一日一日を暮らしているに違いない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ありうべき光景の最も素晴らしいものは、世界のごくありふれた緑の中に――つまり、生命の終わりなき出現の中に存在するのではなかろうか、と。",
              "citation": {
                "source": "博多にて",
                "author": "AT HAKATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の天国の救いや天上の愛に関する、かくも長き清らかな夢から虚しく目覚めることになるという見込みは、人間にとってありうべき最も暗い予想とはならないだろう。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
