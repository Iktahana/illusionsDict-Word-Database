          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "翌年の計画について話し合った。",
              "source": "幻辞"
            },
            {
              "text": "あくる年、彼は新しい職場で働き始めた。",
              "source": "幻辞"
            },
            {
              "text": "あくる年になって初めて結果が分かった。",
              "source": "幻辞"
            },
            {
              "text": "その年の災害のあくる年、復興が進んだ。",
              "source": "幻辞"
            },
            {
              "text": "あくる年の春、新しい学年が始まった。",
              "source": "幻辞"
            },
            {
              "text": "契約のあくる年、更新するか決めなければならない。",
              "source": "幻辞"
            },
            {
              "text": "あくる年、子どもが大学に入学した。",
              "source": "幻辞"
            },
            {
              "text": "オリンピックのあくる年、次の大会の準備が始まる。",
              "source": "幻辞"
            },
            {
              "text": "あくる年の予算について検討する。",
              "source": "幻辞"
            },
            {
              "text": "戦争終了のあくる年、占領期間が始まった。",
              "source": "幻辞"
            },
            {
              "text": "あくる年の初めに経営方針が変わった。",
              "source": "幻辞"
            },
            {
              "text": "病気から回復したあくる年、再発の不安があった。",
              "source": "幻辞"
            },
            {
              "text": "あくる年、業績が大幅に改善した。",
              "source": "幻辞"
            },
            {
              "text": "その論文発表のあくる年、追加研究が行われた。",
              "source": "幻辞"
            },
            {
              "text": "あくる年、彼は法律事務所を開設した。",
              "source": "幻辞"
            },
            {
              "text": "収穫のあくる年、作物の選択を変えた。",
              "source": "幻辞"
            },
            {
              "text": "あくる年の中頃、彼は海外へ移住した。",
              "source": "幻辞"
            },
            {
              "text": "その映画の公開のあくる年、続編が制作された。",
              "source": "幻辞"
            },
            {
              "text": "あくる年の秋に同窓会が開かれた。",
              "source": "幻辞"
            },
            {
              "text": "その事件のあくる年、犯人が逮捕された。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ことしの春に中学を卒えたれば、あくる年の春には美術学校の入学試験をうけんといい、その準備のために川端画学校に通いいたるに、かりそめの感冒が大いなる禍の根を作りて、夏の盛りを三月あまりも病み臥して、秋｜闌ならんとする頃に遂に空しくなりぬ。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが嵩じて、あくる年の三月頃になると、かれは燈火をも嫌うようになった。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　そのうちに、あくる年の二月の末になって、チエ子の父親が、長い航海から帰って来たが、玄関に駈け出して来たチエ子を見ると、ビックリして眼を瞭った。",
              "citation": {
                "source": "人の顔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "村はおかげで全滅をのがれ、あくる年からまたうるおいはじめたのである。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで聞くと、あくる年の四月になって、刑の執行猶予を申渡されて、無事に出獄したそうだ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる年、二ばんめのおねえさまが、海の上へあがって行って、好きな所へおよいでいっていい、おゆるしがでました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "作右衛門の兄弟は親代々の猟師で、甲州の丹波山とかいう所からもっと奥の方に住んでいて、甲府の町すらも見たことのない人間だったそうですが、なにか商売の獣物を売ることに就いて、兄貴の作右衛門がはじめて江戸へ出て来たのは文化二年の暮で、あくる年の春まで逗留しているうちに、ふと妙な気になったのだと云います。",
              "citation": {
                "source": "半七捕物帳",
                "author": "槍突き",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬じゅうに少しも雪を見ないというのは、殆ど前代未聞の奇蹟であるかのように、江戸の人々が不思議がって云いはやしていると、その埋め合わせというのか、あくる年の文久二年の春には、正月の元旦から大雪がふり出して、三ガ日の間ふり通した結果は、八百八町を真っ白に埋めてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎欠脣の定吉という奴も、そのあくる年の正月にやっぱり酒の上で喧嘩をして、相手に傷を付けたので、吟味中に牢死しました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "お葉はそこに小一年ほど奉公していたが、その年の暮に暇を取って、あくる年の三月からお玉ヶ池の其月の家へ二度目の奉公をすることになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる年、三月、そろそろまた卒業の季節である。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「助蔵は生れ付きの百姓で、薄ぼんやりしたような奴ですが、女房のおきよというのはなかなかのしっかり者で、十八の年に助蔵のところへ嫁に来て、そのあくる年に伊兵衛を生んで、今年ちょうど四十になるそうです。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "士族の商法はたいてい失敗するに決まっていたが、ここは余ほど運のいい方で、あくる年の五、六月ごろには親子二人の質素な生活にまず差し支えはないという見込みが付くようになった。",
              "citation": {
                "source": "平造とお鶴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる年わたしは再びシムラで逢った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、これはお母様の事ですが、お母様が御婚礼をなすったあくる年の十六のお正月に、お仕事のお師匠様の処へ御年始にお出でになりました節、御親戚の事とてお師匠様はお雑煮を出すからと用意をされました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために小僧もひとり残されることになったので、久松がその役にあたって、あくる年の正月を小梅で迎えました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その紙鳶はよくよく私に縁が無かったとみえて、あくる年の正月二日に初めてそれを揚げに出ると、たちまちに糸が切れて飛んでしまった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ大家で金銭に不自由はないのと、由井の家の名は遠方までもきこえているのとで、こういう場合には何かの都合もよかったのであるが、それでもこの詮索ばかりは思うようにいかないで、あくる年の四、五月ごろまでむなしく月日を過してしまった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる年の春、喜兵衛は妻を迎えて、夫婦の仲もむつまじく、男の子ふたりを儲けた。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが嵩じて、あくる年の三月頃になると、かれは燈火をも嫌ふやうになつた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年が暮れて、あくる年のお正月のことでした。",
              "citation": {
                "source": "誰が・何時・何処で・何をした",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる年の春が来て、殺生石は雪の底から再びその奇怪な形をだんだんに現わしたが、旅びとの姿はもう見えなかった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはそのあくる年の正月、市村座の中幕「阿古屋の琴責」で彼の岩永左衛門をみて、いよいよ彼が歌舞伎俳優として他に比類なき舞台顔の持主であることを知った。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘も案外素直に承知して、とどこおりなく祝言の式もすませ、夫婦仲も至極むつまじいので、まあよかったと主人も安心し、わたくしも蔭ながら喜んでいましたが、そのあくる年に娘は死にました」「病死ですか」と、私はすぐに訊き返した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "弁天娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる年の正月五日の午後、赤坂へ年始まわりに行くと、老いてますます健かな老人は、元気よく新年の挨拶を述べた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる年早々、Ｉ総監が半身不随に罹った旨が報ぜられた。",
              "citation": {
                "source": "外務大臣の死",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいつ頃でございましたか、又｜如何いう事からと申す事ははっきりおぼえませぬが、あくる年の春、或るお親しいお方とお話をなさッた後の事と存じて居ります。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　あくる年の正月、主人夫妻は彼女の友達の一人なる甲州の某氏から彼女に関する消息の一端を知ることを得た。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくるとしの元旦には、もっとめでたいことが起った。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくるとしに父の黄村が死んだ。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
