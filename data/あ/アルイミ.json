    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in a sense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これはある意味正しい判断です。",
              "source": "幻辞"
            },
            {
              "text": "その方針はある意味賢い決断だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスではある意味リスクが必要だ。",
              "source": "幻辞"
            },
            {
              "text": "医学的にはある意味対症療法が有効だ。",
              "source": "幻辞"
            },
            {
              "text": "学問的にはある意味妥協も大事だ。",
              "source": "幻辞"
            },
            {
              "text": "社会生活ではある意味建前が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツではある意味相手を理解することが勝利につながる。",
              "source": "幻辞"
            },
            {
              "text": "人間関係ではある意味多様性が力だ。",
              "source": "幻辞"
            },
            {
              "text": "技術開発ではある意味失敗が成功の母だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にはある意味周期的なパターンがある。",
              "source": "幻辞"
            },
            {
              "text": "法律的にはある意味グレーゾーンが存在する。",
              "source": "幻辞"
            },
            {
              "text": "経済学ではある意味需給の法則が支配している。",
              "source": "幻辞"
            },
            {
              "text": "文化的にはある意味共通点を探すことが理解につながる。",
              "source": "幻辞"
            },
            {
              "text": "自然界ではある意味競争と協力が共存している。",
              "source": "幻辞"
            },
            {
              "text": "教育ではある意味個性尊重が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "音楽ではある意味規則を破ることが創造になる。",
              "source": "幻辞"
            },
            {
              "text": "美術的にはある意味完璧さより個性が評価される。",
              "source": "幻辞"
            },
            {
              "text": "人生ではある意味苦難が人間を成長させる。",
              "source": "幻辞"
            },
            {
              "text": "科学ではある意味未知の領域の探求が進化を促す。",
              "source": "幻辞"
            },
            {
              "text": "政治ではある意味妥協が民主主義を支える。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "かうした彼の哲学（人格の語る哲学であつて思想の語る哲学ではない）は、ある意味に於て、あの偉大なる古代ギリシヤ人のそれと全く共通する。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "因に、この句の「捨てる」は、文法上からは現在の動作を示す言葉であるが、ここでは過去完了として、既に前から捨ててある意味として解すべきでしょう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　暦の上の春と、気候の春とはある意味では没交渉である。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "颱風に関する気象学者の研究はある意味では今日でもかなり進歩している。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学上の言葉は概念的抽象的であるからある意味ではかえって翻訳とその通用とが容易であるとも考えられる。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして科学の発達の歴史はある意味においてこの道具の発達の歴史である。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点もまたある意味において科学的であると云われなくはない。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には、『桜陰比事』に最も明白に現われている西鶴の「探偵趣味」とも称すべきものが、これもまたある意味では西鶴の中の科学者の面貌を露出したものと云われるであろう。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの武士道観、恋愛観は、ある意味からともかくも唯物論的な西鶴の立場を窺わせる窓口となるものでないかと思われる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに西鶴が冷静｜不羈な自分自身の眼で事物の真相を洞察し、実証のない存在を蹴飛ばして眼前現存の事実の上に立って世界の縮図を書き上げようとしている点が、ある意味で科学的と云っても大した不都合はないと思われる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく、物理学で出逢う種々の方則等はある意味で非常に抽象的なものであって、吾人の眼前にある具体的な、ありのままの自然そのものに直接そっくり当て嵌められるようなものはほとんどないとも云われる。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば天気予報などもある意味においてそうである。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前にも云った通り、作物の舞台面に出ているものは所知者ばかりであり、所知者ばかりの世界はある意味で科学の世界であるからである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際こういうような考えはある意味において甚だ危険である。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際波はある意味で生きている。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観者に関するあらゆる絶対性を打破する事によって現出された客観的実在は、ある意味で却って絶対なものになったと云ってもよい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局味いという詞の解釈上に起れる仮定の差別に過ぎないので、味いは無くても面白い歌という事は、味いということを、ある意味に極限した上から出た批評に過ぎないのであろう。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味に於て、予の最も強く主張する叫びの意味の多い歌であるが、予の好みはその叫びの声が今少し潤いを帯びてありたいのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では野蛮でブルータルであると同時に一方ではまた新鮮で明朗で逞しい美しさがないとは云われない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもある意味では世界中の文明人が今現にやっている習俗と同じ事である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では変化し過ぎて困るかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もほんとうに絵を味わい楽しむためには、ある意味での批評をしなければならない事は勿論であるが、しかし、意識的に批評のための批評をしようという心持があっては、芸術品を楽しみ味わう邪魔になるばかりでなく、却って本当の正しい批評をすることの障碍になりはしまいか。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある意味においては人を死なすかも知れません。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では広いと見えます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆栽生け花のごときも、また日本人にとっては庭園の延長でありまたある意味で圧縮でもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の遊楽の中でもいわゆる花見遊山はある意味では庭園の拡張である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはだ無意味でつまらないようである意味で非常に進歩しているのはアメリカのナンセンス映画やミュージカル・コメディの類である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてある意味で活動映画の先駆者と見なしてもよいものである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらはある意味ではたしかにききめはあった。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯浅氏の回顧陳列もある意味で日本洋画界の歴史の側面を示すものである。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
