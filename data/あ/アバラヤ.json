        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あばら屋について考える必要があります。",
              "source": "幻辞"
            },
            {
              "text": "このあばら屋は非常に重要です。",
              "source": "幻辞"
            },
            {
              "text": "あばら屋の意味を理解することが大切です。",
              "source": "幻辞"
            },
            {
              "text": "多くの人があばら屋について知っています。",
              "source": "幻辞"
            },
            {
              "text": "あばら屋は日常生活で使われます。",
              "source": "幻辞"
            },
            {
              "text": "専門家はあばら屋の価値を認めています。",
              "source": "幻辞"
            },
            {
              "text": "あばら屋に関する研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの世界ではあばら屋が重要です。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からあばら屋を見ると面白いです。",
              "source": "幻辞"
            },
            {
              "text": "あばら屋の歴史は深いものです。",
              "source": "幻辞"
            },
            {
              "text": "教育現場でもあばら屋が取り上げられます。",
              "source": "幻辞"
            },
            {
              "text": "医学の分野ではあばら屋が注目されています。",
              "source": "幻辞"
            },
            {
              "text": "あばら屋について新しい発見がありました。",
              "source": "幻辞"
            },
            {
              "text": "法律でもあばら屋は言及されています。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの領域でもあばら屋は使われます。",
              "source": "幻辞"
            },
            {
              "text": "食文化の中であばら屋は重要な役割を果たします。",
              "source": "幻辞"
            },
            {
              "text": "旅行に行った時にあばら屋について学びました。",
              "source": "幻辞"
            },
            {
              "text": "あばら屋の特性を生かした利用法があります。",
              "source": "幻辞"
            },
            {
              "text": "環境問題とも関連するあばら屋の側面があります。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではあばら屋の理解が必須です。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
