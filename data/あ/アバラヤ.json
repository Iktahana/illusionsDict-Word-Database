    "definitions": [
      {
        "index": 1,
        "gloss": "dilapidated house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その貧しい村にはあばら屋がいくつもあった。",
              "source": "幻辞"
            },
            {
              "text": "あばら屋の軒先で雨が降り込む。",
              "source": "幻辞"
            },
            {
              "text": "昭和初期の映画ではあばら屋の中での生活が描かれる。",
              "source": "幻辞"
            },
            {
              "text": "社会学はあばら屋で暮らす人々の生活実態を研究している。",
              "source": "幻辞"
            },
            {
              "text": "歴史的な貧困地域にはあばら屋が立ち並んでいた。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではあばら屋で生まれ育つ登場人物がいる。",
              "source": "幻辞"
            },
            {
              "text": "建築学の観点からは、あばら屋は不安定な構造が特徴だ。",
              "source": "幻辞"
            },
            {
              "text": "経済学者はあばら屋の出現が社会的不公正を示すと指摘する。",
              "source": "幻辞"
            },
            {
              "text": "教育現場では、あばら屋での貧困について学習する。",
              "source": "幻辞"
            },
            {
              "text": "医学的には、あばら屋での衛生環境の問題が研究されている。",
              "source": "幻辞"
            },
            {
              "text": "法律では、あばら屋での労働者の権利が保護されている。",
              "source": "幻辞"
            },
            {
              "text": "その老人の思い出の家はあばら屋だった。",
              "source": "幻辞"
            },
            {
              "text": "旅行記にはあばら屋での奇妙な体験が書かれている。",
              "source": "幻辞"
            },
            {
              "text": "自伝文学ではあばら屋で育つ苦労が描写されている。",
              "source": "幻辞"
            },
            {
              "text": "映画史では、戦前の日本映画がこぞってあばら屋を舞台にした。",
              "source": "幻辞"
            },
            {
              "text": "美術館の展示にはあばら屋を描いた絵画がある。",
              "source": "幻辞"
            },
            {
              "text": "音楽の歌詞にはあばら屋での貧しい生活が歌われている。",
              "source": "幻辞"
            },
            {
              "text": "人類学の現地調査ではあばら屋での生活実態が記録された。",
              "source": "幻辞"
            },
            {
              "text": "ニュース報道ではあばら屋の火事が大きく報じられた。",
              "source": "幻辞"
            },
            {
              "text": "現代社会ではあばら屋という概念は希薄になったが、貧困は存在する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "文壇の知識に飢え渇いていた私は、あばら屋の中で黴臭い紅茶をすすめながら、次から次へと愚問を連発した。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "）蓮月　――このあばら屋に何か欲しいものがおありなのですか。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この風説は或る夕カムパニアなるドメニカがあばら屋にさへ洩れ聞えぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを得避くる事もできないで、巣を破られた蜂が、その巣跡にむなしくたむろしているごとくに、このあばら屋に水籠りしている予を他目に見たらば、どんなに寂しく見えるだろう。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "とぼとぼと、また故郷のあばら屋に帰る途中の、悲しさは比類が無い。",
              "citation": {
                "source": "竹青",
                "author": "――新曲聊斎志異――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら貧乏しても、こんなあばら屋ってえものはねえですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もののたとえにも、日本橋といや土一升金一升というくれえのもんだが、目と鼻のその日本橋近くにこのあばら屋は、なんですかよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いづれも破れ障子のあばら屋にて、權三の家の臺所は奧にあり。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりはどんなにあばら屋でも、自分の家で足を長くして寝て居る方が好い。",
              "citation": {
                "source": "朝",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "型どほりの藁ぶきのあばら屋で柱も垂木も腐れかゝつて片方に傾いてゐるやうな家だつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としては素直ななつかしさで訪ねたのだが、向こうでは家があばら屋なのと、進学していないのに気がさして、初めの間は不安そうであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は罹災後、あの寒村のあばら屋の二階で石油箱を机にして、一度そのノートに書きかけたことがある。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばら屋の二階には、たまたま兄が疎開させていた百科辞典があった。",
              "citation": {
                "source": "夢と人生",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その神社のそばのあばら屋に、おじいさんとおばあさんとが住んでいました。",
              "citation": {
                "source": "金の目銀の目",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（二）　村の南北に通じた里道に沿うて、子供沢山で居て貧しい小作男の夫婦が居るあばら屋がある。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子がずっと今まで養父母のもとにいたわけで、葉の黒ずんだ茨のあいだにある花園の薔薇よりも美しく、このあばら屋のなかに花咲いているのだった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "良吉の住んでいる家はあばら屋でありました。",
              "citation": {
                "source": "星の世界から",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家は全くのあばら屋で、戸障子の開けしめも自由でない。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに若いお前は、田舎のあばら屋でも我慢もできるだろうが、私はどうしても都を離れたくないのだよ」　涙ながらにかきくどく母の言葉には、抗うすべもなく、妓王はいやいや、妹と他の二人の白拍子と連れ立って西八条に出かけていった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々が、あばら屋であったところに、あの揺れ方で、僅かに残っていた築地も崩れ、屋根は全く傾いてしまった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "灌頂の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "年月熟柿の香に染みて、夜眼には鳶とも見紛ふべきが、片肌はぬげかかりて、今にも落ちさうなるには心付かねど、さすが生酔の本性は違はでや、これも人の住家にやと、怪しまるるあばら屋の門辺にて立止まり、　ここだここだ違げへねえ違げへねえ、いくら酔つても、この家を、覚えてるところがえれえぢやねえか。",
              "citation": {
                "source": "磯馴松",
                "author": "清水紫琴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が昇ると、農夫の亭主は、畑に行く代わりに、あばら屋の中のレンガが敷かれていないところを、くわで掘り始めました。",
              "citation": {
                "source": "コロロッチョ",
                "author": "GRILLINO",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠く離れたセーレムにあってかくも思いがけず、見慣れたあばら屋が自分自身の家の歴史にとって重要な意味を持つと証明されたことは、ウォードにとっていたく印象的だった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてトリガーセンはポートグィン村を成す一群のあばら屋に着いた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の下の、竹藪や雑木林に囲まれた、じめじめした陰気な一画で、三軒ともすっかり住み古し、殆んど朽ちかかったあばら屋であるが、……そのいちばん道に近い家のものらしい、物置小屋のようなものの前に、屋形の侍と下僕とが四、五人いて、声高になにか云っているのが見えた。",
              "citation": {
                "source": "菊千代抄",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の響や、自転車の姿に気がつくと、白い胸をはだけたお浜は、あばら屋のなかからしどけない姿でとびだしてくる。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "お浜の住み家であるトタンぶきのあばら屋から、辺りをうかがうようにして、一人の男が戸外の薄す闇のなかに出てきたのである。",
              "citation": {
                "source": "南方郵信",
                "author": "中村地平",
                "note": "青空文庫"
              }
            },
            {
              "text": "（b）――でもそんなに遠い旅に出たら、いつかあばら屋の一間に哀れなその身をよこたえ、あらゆる不自由をなめられることであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここか」範宴は、立ちどまって、薄暗い一軒のあばら屋をのぞきこんだ。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見れば、寺とは名のみの、ひどい茅葺堂が一宇と、僧の住むあばら屋が、堂の裏にあるだけに過ぎない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "my house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
