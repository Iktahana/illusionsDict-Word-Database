    "definitions": [
      {
        "index": 1,
        "gloss": "glamorous",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "伝統的な友禅染の振袖に身を包んだ彼女の姿は、成人式の会場で一際艶やかに輝いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まあ、今日の装いは一段と艶やかでいらっしゃいますね」と、女将が茶室の入り口で客人をにこやかに出迎えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "スポットライトを浴びて舞台中央で艶やかに舞う踊り子の姿に、客席からは惜しみない拍手が送られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その女優は、年を重ねるごとに洗練された艶やかな色香を漂わせ、多くの人々を魅了し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "秋の夜長、ライトアップされた庭園の紅葉が、闇の中に艶やかな色彩を浮かび上がらせていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女の奏でるチェロからは、深みのある艶やかな音色が溢れ出し、聴衆の心を静かに揺さぶった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新作のコレクションでは、シルクの光沢を最大限に活かした艶やかなドレスが次々と披露され、ランウェイを華やかに彩った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "前髪に蝶結びのリボンを巻いた踊子の意気姿、かの女はもとよりショウト・スカウト、ハイヒール、流行色の粧いが艶やかだ。",
              "citation": {
                "source": "東京ロマンティック恋愛記",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "女たちがまた手伝って、衣桁にかけてある艶やかなお振袖を取って、お蝶のすくんでいる肩に着せかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "片頬に触れた柳の葉先を、お品はその艶やかに黒い前歯で銜えて、扱くようにして引断った。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば人間達が、折かく元気よく暮らして居るこの世の中に、いつの間にか流行病のバチルスが、そっと片隅から湧き出したり、でこぼこな黒い土のなかから美しい赤い花が、艶やかに咲き出たり、正しい善良な人が貧しい暮らしをして居るかと思えば、富んで遊んで暮らす人の居る世の中でもある。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小走りに急いで来る、青葉の中に寄る浪のはらはらと爪尖白く、濃い黒髪の房やかな双の鬢、浅葱の紐に結び果てず、海水帽を絞って被った、豊な頬に艶やかに靡いて、色の白いが薄化粧。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　というと、艶やかな歯でニヤリと笑む。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪艶やかに中腰になった処を、発奮で一打、ト颯と烏の翼の影、笹を挙げて引被る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君は、しかけた用の忙しい折から、冬の日は早や暮れかゝる、ついありあはせた躾の紅筆で懷紙へ、と丸髷の鬢艶やかに、もみぢを流すうるはしかりし水莖のあと。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "笛は谺す、一鳥聲あり、汽車はする／＼と艶やかに動き出す。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札口を冷く出ると、四邊は山の陰に、澄渡つた湖を包んで、月に照返さるゝ爲か、漆の如く艶やかに、黒く、且つ玲瓏として透通る。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片頬に觸れた柳の葉先を、お品は其艶やかに黒い前齒で銜へて、扱くやうにして引斷つた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのずから得ならぬ薫、襟脚の玉暖かく、衝と血の湧いた二の腕に、はらはらと冷くかかった、黒髪の末｜艶やかに飜り、遮るものはなくなった。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、黒繻子の帯の色艶やかに、夜を招いて伸上る。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "舷へ、かたかたと何やら嵌込む……　その嵌めるものは、漆塗の艶やかな欄干のようである、……はてな、ひそめく声は女である。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな鶏卵の、軽く角を取って扁めて、薄漆を掛けたような、艶やかな堅い実である。",
              "citation": {
                "source": "栃の実",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "間を隔てた座敷に、艶やかな影が気勢に映って、香水の薫は、つとはしり下にも薫った。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "円髷艶やかに二三段、片頬を見せて、差覗いて、「ここは閉めないで行きますよ。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、幻ならず、最も目に刻んで忘れないのは、あの、夕暮を、門に立って、恍惚空を視めた、およそ宇宙の極まる所は、艶やかに且つ黒きその一点の秘密であろうと思う、お稲の双の瞳であった。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "緋芍藥花ちる庭の艶やかさ、戀は濃雲と凝りにけらしな。",
              "citation": {
                "source": "短歌",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹に満ちた咀嚼物は陽のあたためを受けて滋味は油のように溶け骨、肉を潤し剰り今や身体の全面にまでにじみ出して来るのを艶やかに感ずる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ、眄視、流目の間に艶やかな煙霞の気が長い睫毛を連ねて人に匂いかかることを。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの皿と入れ違ひに、附近の山でとれたといふ採りたての無花果の実が、はじけ相な熟した果肉を漸く圧へた皮のいろも艶やかに、大きな鉢に入れられて濃いこうばしいお茶と一緒に運ばれました。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとうさんは顎鬚のそりあとを艶やかに灯かげに照らして煙草のけむりを静に吐いてゐました。",
              "citation": {
                "source": "秋の夜がたり",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば敵の毛羽艶やかに峨冠紅に聳えたる鶏の如く、此方は見苦しき羽抜鳥の肩そぼろに胸｜露はに貧しげなるが如くであつたが、戦つて見ると羽ふくよかなる地鶏は生命知らずの軍鶏の敵では無かつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "艶やかに兀げた前頭からは光りが走った。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "艶やかな濡髪に、梅花の匂｜馥郁として、繻子の襟の烏羽玉にも、香やは隠るる路地の宵。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……湯上りの上、昼間｜歩行き廻った疲れが出た菅子は、髪も衣紋も、帯も姿も萎えたようで、顔だけは、ほんのりした――麦酒は苦くて嫌い、と葡萄酒を硝子杯に二ツばかりの――酔さえ醒めず、黒目は大きく睫毛が開いて、艶やかに湿って、唇の紅が濡れ輝く。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "車を彩る青葉の緑、鼈甲の中指に影が透く艶やかな円髷で、誰にも似ない瓜核顔、気高く颯と乗出した処は、きりりとして、しかも優しく、媚かず温柔して、河野一族第一の品。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女は、丈長掛けて、銀の平打の後ざし、それ者も生粋と見える服装には似ない、お邸好みの、鬢水もたらたらと漆のように艶やかな高島田で、強くそれが目に着いたので、くすんだお召縮緬も、なぜか紫の俤立つ。",
              "citation": {
                "source": "妖術",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い丸髷の下町式マダムが弁慶縞の上っぱりで、和装令嬢式近代娘を相手に、あでやかにつややかに活躍している。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
