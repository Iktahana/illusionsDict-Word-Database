[
  {
    "uuid": "1040275d-27b9-5aac-a7dd-a89f19341691",
    "entry": "艶やか",
    "reading": {
      "primary": "あでやか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
