    "definitions": [
      {
        "index": 1,
        "gloss": "to let things end up as they will",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "計画あるに従って事業を進める。",
              "source": "幻辞"
            },
            {
              "text": "法律あるに従って行動する。",
              "source": "幻辞"
            },
            {
              "text": "医学的根拠あるに従って治療を決定する。",
              "source": "幻辞"
            },
            {
              "text": "教科書あるに従って授業を進める。",
              "source": "幻辞"
            },
            {
              "text": "社会規範あるに従って生活する。",
              "source": "幻辞"
            },
            {
              "text": "スポーツルールあるに従ってゲームをする。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス契約あるに従って取引をする。",
              "source": "幻辞"
            },
            {
              "text": "技術仕様あるに従ってシステムを構築する。",
              "source": "幻辞"
            },
            {
              "text": "歴史記録あるに従って事実を述べる。",
              "source": "幻辞"
            },
            {
              "text": "法制度あるに従って権利を行使する。",
              "source": "幻辞"
            },
            {
              "text": "言語文法あるに従って文章を書く。",
              "source": "幻辞"
            },
            {
              "text": "芸術的規則あるに従って作品を制作する。",
              "source": "幻辞"
            },
            {
              "text": "科学的原則あるに従って実験を行う。",
              "source": "幻辞"
            },
            {
              "text": "経営計画あるに従って事業運営する。",
              "source": "幻辞"
            },
            {
              "text": "財政予算あるに従って支出を決める。",
              "source": "幻辞"
            },
            {
              "text": "組織規則あるに従って職務を遂行する。",
              "source": "幻辞"
            },
            {
              "text": "倫理規範あるに従って判断する。",
              "source": "幻辞"
            },
            {
              "text": "親の指示あるに従って行動する。",
              "source": "幻辞"
            },
            {
              "text": "医者の指示あるに従って薬を飲む。",
              "source": "幻辞"
            },
            {
              "text": "コーチの指導あるに従って練習する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "高山寺本に箸人とあるに従うべきものであろう。",
              "citation": {
                "source": "間人考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
