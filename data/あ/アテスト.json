    "definitions": [
      {
        "index": 1,
        "gloss": "to attest (a scorecard)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
