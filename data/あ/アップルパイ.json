        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "焼きたてのアップルパイの香りが、店中に広がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の作るアップルパイは、毎年クリスマスの定番になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「わあ、このアップルパイ、リンゴがゴロゴロ入っていて贅沢！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "温かいアップルパイにバニラアイスを添えると、最高のデザートになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母が送ってくれた地元のアップルパイを、皆で美味しくいただいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カフェのメニューには、定番のアップルパイ以外に季節限定のタルトも並んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この店のアップルパイは、甘さ控えめでコーヒーとの相性が抜群だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし出てくる名探偵の片言隻語のうちには、なかなか味わうべきありがたい言葉があるよ」　彼はこういいながら、アップルパイをフォークでしきりとほおばりはじめた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、オーブンをなおして、アップルパイをやいてあげた。",
              "citation": {
                "source": "日記",
                "author": "一九二〇年（大正九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "チーズに牛肉にコーヒーにチョコレートにアップルパイにウィスキーかなんかがないと戦争ができないてんだから大したものじゃないか。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "リュックの中からアップルパイと桃のカンヅメをとりだして、少年を部屋へよびこんで、御馳走した。",
              "citation": {
                "source": "発掘した美女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラック珈琲の美味さなど私たちが知りそめたのは、中戸川吉二氏の「アップルパイワン」に登場するかのカフエパゥリスタのブラジル珈琲時代が一とわたりすんだ此も震災前年ころであらうとおもふ。",
              "citation": {
                "source": "大正東京錦絵",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
