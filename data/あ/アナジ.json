        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "強いあなじが吹き荒れ、漁に出るのを断念した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "窓の外ではあなじが唸り、冬の到来を告げていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あなじに晒された肌は、すぐに赤く凍えてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山の稜線を越えてきたあなじは、里にも雪を運んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あなじが吹きつける中、震えながらバスを待った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方の冬は、毎年あなじが厳しく、農作物への影響も大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「まったく、きついあなじだなあ」と、旅人は襟を立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "」「匂あなじょだ、匂あ。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お奉行さまからのお呼び出しというと、尋常一様のあなじゃなさそうだが、おれでなくちゃとでもおっしゃっていられるのかい」「そうなんですよ、そうなんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎が手がけたあなじゃ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかしてくれたら、はあなじょうに小気味がよかっぺえ！",
              "citation": {
                "source": "禰宜様宮田",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
