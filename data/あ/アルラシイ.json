    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seems to be",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "春が来たようで、桜が咲き始めた。",
              "source": "幻辞"
            },
            {
              "text": "田中さんは仕事を辞めたようだ。",
              "source": "幻辞"
            },
            {
              "text": "昨日の会議は中止されたようだ。",
              "source": "幻辞"
            },
            {
              "text": "新製品は好評のようで販売が好調だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はその話題を知らないようだ。",
              "source": "幻辞"
            },
            {
              "text": "天気予報は明日雨が降るようだ。",
              "source": "幻辞"
            },
            {
              "text": "その店の評判は良いようだ。",
              "source": "幻辞"
            },
            {
              "text": "実験結果は期待を下回ったようだ。",
              "source": "幻辞"
            },
            {
              "text": "医者の診察は問題ないようだ。",
              "source": "幻辞"
            },
            {
              "text": "書類の提出期限は明日のようだ。",
              "source": "幻辞"
            },
            {
              "text": "新聞の報道によると事故があったようだ。",
              "source": "幻辞"
            },
            {
              "text": "その候補者は経験が豊富なようだ。",
              "source": "幻辞"
            },
            {
              "text": "品切れは人気の証のようだ。",
              "source": "幻辞"
            },
            {
              "text": "計画は予定通り進んでいるようだ。",
              "source": "幻辞"
            },
            {
              "text": "その地域は治安が良くないようだ。",
              "source": "幻辞"
            },
            {
              "text": "会社の経営状況は改善されたようだ。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトは延期されるようだ。",
              "source": "幻辞"
            },
            {
              "text": "その事件は解決したようだ。",
              "source": "幻辞"
            },
            {
              "text": "新しい規則は来月から実施されるようだ。",
              "source": "幻辞"
            },
            {
              "text": "その技術は革新的なようだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それあまあ、昔だつて一般世人は美術家より装飾美術家の方をリアリスティクだと思つてゐたものではあるらしい。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "流しの鉛管をつまらせる事は日本人の特長であるらしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の理論の上に輝く何かしら神秘的の光環のようなものを想像している人もあるらしい。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、夏目先生が英国へ留学を命ぜられたために熊本を引上げて上京し、奥さんのおさとの中根氏の寓居にひと先ず落着かれたときのことであるらしい。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼にも、いろいろの種類があるらしい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあれで、何か色氣があるらしいんだね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外にも壊れかかった石祠がある、中には神体代りの小鉄板が、※びて腐蝕しながらも、奉納白根大日如来寛政七年乙卯六月と読まれた、白峰赤石両山脈の頂で、山の荒神たちと離れられない関係があるらしい、鉄の槍身が、赤｜錆びになって仆れていた。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりではない、足利時代の『鷹筑波集』からも、猿楽狂言からも、また貞徳の「独吟百韻」からも、富士｜詣の群衆のざわめきは、手に取るように聞えるが、それらの参詣者は、皆この村山口を取ったものであるらしい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "新年になると着なれぬ硬直な羽織はかまを着せられて親類縁者を歴訪させられ、そして彼には全く意味の分らない祝詞の文句をくり返し暗誦させられた事も一つの原因であるらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして飲みたくない酒を嘗めさせられ、食いたくない雑煮や数の子を無理強いに食わせられる事に対する恐怖の念をだんだんに蓄積して来たものであるらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々と六かしい、しかもたいていはエゴイスティックな理窟を並べてはいるようであるが、結局は、当り前分り切った年賀状の効能を五十の坂を越えてから始めてやっと気のつくようになったのであるらしい。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両岸の崩壊箇所が向かい合っているのもやはり意味があるらしい。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラビアの詩にも十五種ほどもミーターの種類があるらしいが、その中でも十五、十五の連続あるいは八、八、八、八の連続などは乱暴に読めば短歌風に読まれなくはない。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "有る處にはあり餘つて無い處にはないといふのは、智慧や黄金に限らず、勝景や温泉に限らぬ自然の大法則であるらしい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人を見てもやつぱりさうであるらしい。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "凶作の原因となる気温異常には他にも色々な原因はあるとしても一つの因子としてこれと東北沿海の海水の温度異常との間に若干の相関があるらしいということは、我邦の学者の間ではもう少なくも二十年も前から問題となっていたことである。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本武尊東征の途中の遭難とか、義経の大物浦の物語とかは果して颱風であったかどうか分らないから別として、日本書紀時代における遣唐使がしばしば颱風のために苦しめられたのは事実であるらしい。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "色々聞合わせてみてもその現象の記載がどうも要領を得ないのであるが、ともかくも電光などのような瞬間的の光ではなくてかなり長く持続する光が空中の広い区域に現われたことだけは事実であるらしい。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母さんにはまた伯母さんとしてのたくさんな担いものがあるらしいから」　胸にこう自問自答して、女は洞の中の男の傍に介抱すべくとどまった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車にも乗せた人があるらしい。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うにも一つ滝があるらしい。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」と「粋」との相違は、同一内容に対する江戸語と上方語との相違であるらしい。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番大事なものはやはり心の自由風流であるらしい。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が球を飛ばせたり転がしたりする遊戯の種類が一体どのくらいあるか数え切れないほどあるらしい。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に朱赤色や濃黄色といったような熱色の花には単調な色彩が多くて紫青色がかったものや紅でも紫がかったものにはこうした色のかがよいとでもいったものがあるらしい。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二人と自分とだいぶ似たところがあるらしい。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "釘に引っかける札の穴の周囲を疵だらけにしている人と、そうでない人との区別もあるらしい。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと汚れ方との相関もあるらしいがまだよく調べてみない。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
