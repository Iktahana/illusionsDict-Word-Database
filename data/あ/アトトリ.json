[
  {
    "uuid": "60fb19f2-3961-5655-9d0e-6c27f3902890",
    "entry": "跡取り",
    "reading": {
      "primary": "あととり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
