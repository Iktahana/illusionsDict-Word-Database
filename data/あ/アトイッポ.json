      {
        "index": 1,
        "gloss": "one more",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "優勝まで「あと一歩」というところで敗北した。",
              "source": "幻辞"
            },
            {
              "text": "合格点まで「あと一歩」という成績だった。",
              "source": "幻辞"
            },
            {
              "text": "成功は「あと一歩」のところで掴めるかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "目標達成まで「あと一歩」となった。",
              "source": "幻辞"
            },
            {
              "text": "愛する人との和解は「あと一歩」のところだ。",
              "source": "幻辞"
            },
            {
              "text": "契約締結まで「あと一歩」である。",
              "source": "幻辞"
            },
            {
              "text": "完成まで「あと一歩」の段階に入った。",
              "source": "幻辞"
            },
            {
              "text": "真実解明は「あと一歩」のところに隠れている。",
              "source": "幻辞"
            },
            {
              "text": "決断の時が「あと一歩」先にある。",
              "source": "幻辞"
            },
            {
              "text": "恋愛成就は「あと一歩」かもしれない。",
              "source": "幻辞"
            },
            {
              "text": "経営再建まで「あと一歩」の企業だ。",
              "source": "幻辞"
            },
            {
              "text": "世界記録は「あと一歩」のところで逃した。",
              "source": "幻辞"
            },
            {
              "text": "平和実現は「あと一歩」ではなく長い道のり。",
              "source": "幻辞"
            },
            {
              "text": "復職は「あと一歩」の患者である。",
              "source": "幻辞"
            },
            {
              "text": "合併交渉は「あと一歩」で破談した。",
              "source": "幻辞"
            },
            {
              "text": "教育水準向上には「あと一歩」が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "環境問題解決は「あと一歩」では済まない。",
              "source": "幻辞"
            },
            {
              "text": "国際関係改善は「あと一歩」で停滞している。",
              "source": "幻辞"
            },
            {
              "text": "科学的証明は「あと一歩」のところまで来ている。",
              "source": "幻辞"
            },
            {
              "text": "社会改革には「あと一歩」の勇気が必要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あと一歩です」　放二は、こまりきって、「このさきが雲をつかむようなんです」「いゝえ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あと一歩というところで、ベルは止まった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そこで師直もついにあぐねてしまい、あと一歩の肉薄をのこして、急に、京都へひきあげた。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            }
          ]
        }
