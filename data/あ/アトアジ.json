        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "コーヒーの深いコクと、すっきりとした後味が楽しめる一杯だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "誤審騒動の末の勝利という、何とも後味の悪い結果に終わってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "最後に明かされる真実はあまりにも残酷で、観る者に強烈な後味を残す映画である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "スパイスの効いたカレーを食べた後は、ミントティーで口の中の後味を爽やかにするのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "取引先との交渉は平行線のまま打ち切りとなり、双方にしこりを残す後味の悪い面談となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "この白ワインはフルーティーな香りが特徴で、キレのある後味が魚料理によく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――「ああ、そうですな」少し間誤つきながらそう答えた時の自分の声の後味がまだ喉や耳のあたりに残っているような気がされて、その時の自分と今の自分とが変にそぐわなかった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしきょうこのごろ日本でいわゆるジャーナリズムという言葉には、これ以外にいろいろ複雑な意味や、余味や、後味や、またニュアンスやがあってなかなか簡単に定義しひと口に説明することはできないようである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "憤怒の苦い後味が頭の奥でいつまでも／＼彼を虐げようとした。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、そりゃ困る」「困るのはあたしの方だわ、だいいち、後味が悪いし、それに、それじゃ何だかあたしがみじめだわ」「しかし、この金あんたはいるんだろう？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その軽い疲労が、しかし二十七歳の彼女の体の中に、何か満たされぬ後味となってやるせなく残っていた。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か後味が悪かった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちぶれたもとの旦那の三好に再会した後味の悪さを、酒で消そうとしたのと、一つには階下の鶴雄に言いたいことがあった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "横紙破りの、ちょっと他人には真似ることの出来ないいたずらだったから、やってみると、快感はあったが、しかし、そのいたずらが結局殺人行為となってみると、いかな豹吉でも、さすがに薄気味悪い後味は心の底に残っていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ、抒情的な音楽を聴いたあとのような甘い後味が残り、唇の間からちょっと舌を覗かせて、照れ症らしく天井や壁をにやにや見ながら話をする冴子の癖がもはや何ものにもかえがたいもののように思われるのだった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その時分は銀子もまだ苦い汁の後味が舌に残りながら、四年間｜同棲した、一つ年上の男のことが、綺麗さっぱりとは清算しきれずにいた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ陽子がそんな薄汚い草履をはいて来たのか、木崎には判らなかったが、しかし、草履をはいた陽子の後姿は、いつまでも瞼にこびりつき、淡い失恋の甘さにも似た後味があった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽子を誘惑し損ったまま東京へ帰るのは、何としても後味が悪い。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "半年近いホール生活で、すっかり体をこわしたのだろうか、こんなに盗汗をかいてるわ――と思う前に、なぜ京ちゃんと踊っている夢を見たのだろうと、何か自分でも思いがけぬ触感のリズムが伴う胸苦しい甘さの後味に驚いていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺田は何か後味が悪く、やがて競馬が小倉に移ると、１の番号をもう一度追いたい気持にかられて九州へ発った。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　姉と争った後味の悪い気持で、お店へ来ると、女給の一人の妙子という、チンマリと可愛い顔の少女が、豊かな黒髪を、プツリと切って、すっかり見違えるような後姿で、水盤の水を入れかえているので、新子は驚いて、「まあ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはだ後味のわるいものだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の努力から受ける感じというのは、柄にもない飛び上りな行いをした後に毎時でも残される苦しい後味なのだ。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時彼にとっては行為の結果に対する苦い後味が残る。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後味をごまかすために、彼は人の為めに社会の為めに義務を果し、献身の行いをしたという諦めの心になる。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪費の後の苦々しい後味を、強いて笑いにまぎらすその歪んだ顔付を見るがいい。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく、果物を食って珈琲をのんでしまった読者の舌の上へ、しつこい豚料理か何かを出して、後味をのこさせるようなものである。",
              "citation": {
                "source": "「陰獣」その他",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、この作品の後味としてひとくちに云えない感じをのこす所以であろうと思う。",
              "citation": {
                "source": "観念性と抒情性",
                "author": "――伊藤整氏『街と村』について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って、部分部分の雰囲気は画面に濃く、且つ豊富なのであるが、この作の総体を一貫して迫って来る或る後味とでも云うべきものが、案外弱いのは何故だろう。",
              "citation": {
                "source": "「愛怨峡」における映画的表現の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉親であれば無視出来ず、それ故却って、あとあじの悪い反感が高くなっていた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　あとあじの悪いものであった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「うん」「ねえ、いらっしゃいよう」「ちょっと待って」　片づけられた食堂のテーブルのところから伸子を気軽に立ち上らせないのは、やっぱり、けさのごたごたの、いやなあとあじだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
