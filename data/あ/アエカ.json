    "definitions": [
      {
        "index": 1,
        "gloss": "delicate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はあえか笑いを浮かべた。",
              "source": "幻辞"
            },
            {
              "text": "あえかな表情で彼女は頷いた。",
              "source": "幻辞"
            },
            {
              "text": "あえか色の着物が展示されている。",
              "source": "幻辞"
            },
            {
              "text": "あえかな雰囲気の日本庭園だ。",
              "source": "幻辞"
            },
            {
              "text": "あえかな光が窓から差し込む。",
              "source": "幻辞"
            },
            {
              "text": "彼女のあえかな笑みに皆が惹かれた。",
              "source": "幻辞"
            },
            {
              "text": "あえか線画で描かれた美しい挿絵。",
              "source": "幻辞"
            },
            {
              "text": "あえかな味わいのお茶を出された。",
              "source": "幻辞"
            },
            {
              "text": "美術館ではあえかな作品が多く展示されている。",
              "source": "幻辞"
            },
            {
              "text": "あえか優雅さを感じさせる日本画だ。",
              "source": "幻辞"
            },
            {
              "text": "詩人はあえかな言葉を選んで表現した。",
              "source": "幻辞"
            },
            {
              "text": "あえかな香りが部屋に漂っている。",
              "source": "幻辞"
            },
            {
              "text": "彼のあえかな声が心に響いた。",
              "source": "幻辞"
            },
            {
              "text": "古典文学に登場する女性はあえかな美しさで描かれる。",
              "source": "幻辞"
            },
            {
              "text": "あえかな季節の風情を感じさせる写真だ。",
              "source": "幻辞"
            },
            {
              "text": "あえかな動きで舞い手は演じた。",
              "source": "幻辞"
            },
            {
              "text": "伝統工芸のあえかな繊細さに驚いた。",
              "source": "幻辞"
            },
            {
              "text": "あえかな家族の情景が物語の中心だ。",
              "source": "幻辞"
            },
            {
              "text": "あえか儚さを感じさせる作品である。",
              "source": "幻辞"
            },
            {
              "text": "あえかな音色のピアノ音が響く。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その頃です、僕が囲炉裏の前で、　　あえかな夢をみますのは。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬はかくて痩せ細り夏に雨を得て肉附くことを繰返しながら、瞳は一途にあえかなるものに向って求めているのだと土民はいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水うら濁る島の苔、　　　　　萱屋に玻璃のあえかなる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まがつびここに塚ありと、　　おどろき離るゝこの森や、風はみそらに遠くして、　　　山なみ雪にたゞあえかなる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩頸列西は箱ヶと毒ヶ森、　　　　　　　椀コ、南昌、東根の、古き岩頸の一列に、　　　　　　　氷霧あえかのまひるかな。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありていにいえば、この「起ち上ろうとする」もしくは「起ち上りつつある」――更に「起ち上った」大阪の表情のあえかな明るさに、よしんばそれがそこはかとなき表情であるにせよ私は私なりに興奮したのである。",
              "citation": {
                "source": "起ち上る大阪",
                "author": "――戦災余話",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ蛍を飛ばすなら、祇園、先斗町の帰り、木屋町を流れる高瀬川の上を飛ぶ蛍火や、高台寺の樹の間を縫うて、流れ星のように、いや人魂のようにふっと光って、ふっと消え、スイスイと飛んで行く蛍火のあえかな青さを書いた方が、一匹五円の闇蛍より気が利いていよう。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "先斗町の雰囲気は鶴雄にとっては堪え切れぬものだったが、しかしわずかに鈴子がいることで、鶴雄のあえかな郷愁をそそった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今こそ鶴雄は、あえかに抱いていた鈴子への恋情が――いや、その恋情だけが、自分の青春のすべてであるように、思われるのだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、この驚きには甘い喜びが、あえかにあった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいなお星様」　呟いた時、ふと星が流れて、青い光がすっと斜に、あえかな尾を引いて、消えた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に通ふ靜かな物音を聞いてゐると、かの少年時の薄玻璃の如くあえかなる情操の再び歸り來るのではないかと疑ふ。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長順　幼き時ゆこがれたる、ほの珍らかにいと甘き、いとあえかにもなつかしき『不可思議』の目見は我胸より全く消えうせ、遺れるは氷の如き空の影。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえかな美しさにうっとりしていると、解説者は南十字星へ矢印の青い光を向けて、「――さて、皆さん、ここに南十字星が現われて、わたし達はいよいよ南方の空までやって来ました。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "螢のあえかな青い火は、汗かきの八重子のあらわな白い胸のふくらみの上に、すっと停って瞬いた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "降るような星空に、星が流れ、あえかな尾を引いてすっと消えた拍子に、カラ子は京吉を想い出した。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえかな微笑だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな人間でも持っているあえかなノスタルジアのようなものであった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを頭痛だとはなにごとかと、当然花嫁の側からきびしい、けれども存外ひそびそした苦情が持ちだされたのを、仲人が寺田屋の親戚のうちからにわかに親代りを仕立ててなだめる……そんな空気をひとごとのように眺めていると、ふとあえかな螢火が部屋をよぎった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁丹を買うためにパトロンを作った彼女は、煙草も酒も飲まず、酒場のボックスでは果物一つ口にしない行儀のよさが、吉田の学生街のへんに気取ったけちくさいアカデミックな雰囲気に似合っており、容姿にも何かあえかなノスタルジアがあった。",
              "citation": {
                "source": "中毒",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "青き花南紀旅行の紀念として且はわが羅曼底時代のあえかなる思出のために、この幼き一章を過ぎし日の友にささぐ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そののちも人とうまれて、微妙くも奇しき幻ゆめ、うつつ、香こそ忘れね、かの青き花をたづねて、ああ、またもわれはあえかに人の世の旅路に迷ふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "順礼はつとにめざめてあえかなる友をかおもふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そことなくおほくのひとのあえかなるかたらひおぼえ、われはただひしと凝視めぬ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あえかなる罪のまぼろし、――濃き華の褐に沁みゆく愛欲の千々のうれひを。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "春なれば街の少女が華やぎに、君も交りて美しう、恋の祈誓の初旅や笈摺すがた鈴ふりて、大野のみなみ、菜の花の黄金海透く筑紫みち列もあえかのいろどりに御詠歌流し麗うらと練りも続く日、軟かぜに絵日傘あぐる若菜摘、法師、馬上の騎士たちも照りつ乱れつ菅笠に蝶も縺るる暖かさ。",
              "citation": {
                "source": "第二邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻の白い体の上を、スイスイと青い灯があえかに飛んだ。",
              "citation": {
                "source": "蚊帳",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄昨日姫桃ちりこぼれ、風｜香ぐはしき春の日を、丸髷姿あえかにて、君窓による夢をみぬ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "透影しろき鱗を柳のかげにのぞき見て、毒ある海にあえかなる身の薄命をおもふかな。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなた天路のはづれに、白衣の靡きゆららに、今宵し六日のかたわれ月、（さはあえかなる病女の夕眺めするなよびや、）さ青のまなじり伏目がちに。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
