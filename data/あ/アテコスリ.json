[
  {
    "uuid": "51b39b66-4ccc-5c5a-8f9a-14139d5d948a",
    "entry": "当てこすり",
    "reading": {
      "primary": "あてこすり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
