      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "snide remark",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昇進が決まった私に対して、彼は「運がいい人は羨ましいものだ」と嫌味な当てこすりを言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そんな遠回しな当てこすりはやめて、文句があるならはっきり言ってください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼女のスピーチには、暗に現政権の失策を批判するような当てこすりが随所に散りばめられていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "何気ない世間話のつもりだったが、被害妄想の強い彼には自分への当てこすりに聞こえたようだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "私の家事のやり方に対する義母の執拗な当てこすりには、もうこれ以上耐えられそうにない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人前で部下に当てこすりを言うような真似は、上司としての器の小ささを露呈するだけだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライバル会社の不祥事を引き合いに出して、自社の潔白を主張するのは卑怯な当てこすりと言わざるを得ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "愚弄に報ゆるに愚弄をもってし、当てこすりに答えるに当てこすりをもってする事のできる場合には用はないが、無言な正義が饒舌な機知に富んだ不正に愚弄される場合の審判者としてこの二つの品が必要である。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしたちの、つらい立場を知りもせぬ癖に、わかい者たちは何かと軽薄な当てこすりやら、厭味やらを言って、ひとの懸命の生きかたを遊戯の道具に使っています。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、「損得の判らない人間くらい、世の中に恐ろしいものはないね」　と、わたくしを睨んでまだ当てこすりを言っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉やお若もわきを向いていてほとんど挨拶もしないばかりか、豊吉は時どき当てこすりらしい毒口さえ放った。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とか、地まわり連のうちには随分憤慨しているのもありましたが、なにしろ相手は侍ですから無暗に喧嘩を吹っかけるわけにも行かないので、横眼で睨んで店さきを通りながら何か当てこすりの鼻唄でも歌って行くぐらいのことでした。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「岸本の叔母さん」　当てこすりで無くてこれが何であろう、と岸本はその言葉を繰返して見た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "自炊を嫌ふ階下の亭主の当てこすりの毒舌を耳に留めてからは、私はたいがい乾餅ばかり焼いて食べてゐた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホビイストへの公開状」を書いて開発者の権利保護を訴えたビル・ゲイツを当てこすり、二人組は「どこかのソフト屋さんとは違って、我々は皆さんがタイニーベーシック拡張版をいじくり回してもっと小さくしてくれることを大いに歓迎いたします」と書き添えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は風呂を焚かなかつた為に、或時は籾を干し忘れた為に、或時は牛の放れた為に、お住はいつも気の強いお民に当てこすりや小言を云はれ勝ちだつた。",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｙ、母が来て居られた時、不愉快な、当てこすりのようなことを云われて気にして居たのに、キタに用を命じるとき、ふと理由ない遠慮を感じた、「何故そんな卑屈な心持にならなければならないか、ああ自分の家が欲しい、二人のでない、自分きりの」と思ったのであった。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それとも、当てこすりですの？",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいや、当てこすりもしやせんよ。",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあきらかに家族のなかの頓智家で、婦人たちを相手に茶目な冗談や当てこすりをさかんに飛ばしたり、昔の話題をくりかえしたりして、この上なく賑かにしていた。",
              "citation": {
                "source": "クリスマス・イーヴ",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたくしがあなたを、お気を悪くなさらないでね、淑女扱いに致すと言って、みなさん呆れておしまいになって、当てこすりをおっしゃるのですのよ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そんな当てこすりをされるおぼえは多計代にない、というのだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」当てこすりなのだろうか？",
              "citation": {
                "source": "千里眼の村",
                "author": "クリスマス・ストーリー",
                "note": "青空文庫"
              }
            },
            {
              "text": "この薄倖な女に対する彼の同情は、一種神聖なもののようになって、二十年も後の今でも、誰の口から出たにせよ、ちょっとでも彼女のことを悪く言うような当てこすりは我慢がならず、すぐさまその無礼者をとっちめるのであった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワでも面と向かって、そんな風に当てこすりを言われたことがありました。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな当てこすりをするといふことがあるものか。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州の支配者達は同じような政略結婚をします」　ルースの口調には若干の当てこすりがあった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしちかごろになって、ようやく、それが自分に対する当てこすりだ、ということがわかってきた。",
              "citation": {
                "source": "雪の上の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これまでの、当てこすりやこけ威しとは調子が違っていた。",
              "citation": {
                "source": "雪の上の霜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、そんな、こじつけみたいな、あてこすりみたいな、芝居のせりふのやうなものは、一向あなたに似合ひませんよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか、そんな、こじつけみたいな、あてこすりみたいな、芝居のせりふのようなものは、一向あなたに似合いませんよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それは矢島の陋劣なあてこすりだったのだ。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻が、決して、りんきやあてこすりで麗姫に逢えと云うので無いことは判り過ぎるほど判って居た。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "退社時刻に眼覚し時計を鳴らすのは、何かのあてこすりだろうということになったのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（原注一五）　ボーヴェエにあてこすりを言っていることなんぞは、君はひと言で受けながしてしまうだろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんだっていやにあてこすりばかり言って、つまらん事にも目口を立てて小言を言うんです。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は晴れているためかめっきり冷えますから」　と早田が口添えするにもかかわらず、彼らはあてこすりのように暗い隅っこを離れなかった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
