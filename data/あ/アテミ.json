    "definitions": [
      {
        "index": 1,
        "gloss": "blow to a vital point of a person's body",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "合気道においては、投げ技を掛ける前の導入として、相手の体勢を崩し隙を作るための当て身が多用される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "暴漢に襲われた被害者は、咄嗟に喉元への当て身を食らわせ、相手が怯んだ隙にその場から逃走した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古流柔術の奥義には、人体の急所を的確に突き、最小限の力で相手を制圧する高度な当て身の技法が含まれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「くっ、あの体勢から正確に当て身を打ち込んでくるとは……。かなりの手練れだな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "格闘ゲームにおいて、相手の打撃を受け流すと同時に強烈な反撃を見舞う「当て身技」は、読み合いの醍醐味の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "空手の組手で、みぞおちへの鋭い当て身が決まり、対戦相手は悶絶してその場に膝をついた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "刃物でなく、拳固で突いただけであるから、いわば当て身を食わされたようなわけで、一旦は気が遠くなったが他に別条もなかったのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "――痛手にこらえかねて、身をよろめかしたとき、ひらひらと京弥の小姓袴が、艶に美しく翻えったと見えましたが、ばっと対手のふところに飛び入ると、刹那に施されたものは遠気当て身の秘術でした。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "六日前から、そうあるべき事を待ちあぐんでいた矢先でしたから、ひらひらと緋色の裾端を空に散らすと、ぱたり、ぱたりと得意の揚心流当て身で、先ずその両三名をのけぞらしました。",
              "citation": {
                "source": "旗本退屈男　第二話",
                "author": "続旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "用のすむまで、ゆっくり涼んでいろい」　ダッと、あっさり草香の当て身をかまして寝かしておくと、声をたよりに奥座敷を目ざしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぽかりとひと突き、草香の当て身がその脾腹へはいりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　声といっしょにぎゅっとドスもろともそのきき腕をねじあげたかとみるまに、ぐっとひと突き、こぶしの当て身がわき腹を襲いました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに、おれがもう一本十手の当て身をくらわしてやらあ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　声もろともに、ダッとひと突き、みごとな草香の当て身でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "張った捕り網にもこぼれはねえが、草香の当て身にもはずれがねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "二天流黒岩清九郎が赤岩清九郎になろうとも、右門秘蔵草香の当て身の前には歯も立たないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "並んでいっぷくせい」　右へ二人、左へ三人、行く手を塞いだ四五人に、あっさり揚心流当て身の拳あてて片づけながら道を開いておくと、「女つづけッ」　にったり打ち笑みながら、さッと駈け出しました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その折の骨を用いて他流試合に参ったごとく持ちかけ、そちの手にあまる者が飛び出て参るまで、当て身、遠当て、程よく腕馴らしやってみい」「心得ました。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お次はどなたじゃ」　爽やかな京弥の声が飛んだとき、すでに対手はタンポ槍をにぎりしめたまま、急所の脾腹に当て身の一撃を見舞われて、ドタリ地ひびき立てながらそこに悶絶したあとでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラリ、兵助は手にせる真槍を叩きおとされて、片手突きの当て身に脾腹を襲われながら、すでにそこへのけぞっていたところでした。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "京弥の当て身に倒れた二人も交えて、ひと束にしながら長持の中へ投げ込むと、事もなげに言ったことです。",
              "citation": {
                "source": "旗本退屈男　第十話",
                "author": "幽霊を買った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに脾腹へ当て身を食わされて、気が遠くなってしまったのだそうです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですから僕は直ぐにあの男の背後から近付いて不意打ちの当て身を一つ喰わして電気｜炬燵のコードでしっかりと縛って、あの寝室の隣りの標本室の大机の足にしっかりと縛りつけて、外から鍵を掛けておいたのです。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤一刀斎景久が、晩年に工夫した一手であって、場合によっては刀を返し、柄頭で敵の鼻梁を突き、空いている方の左手で、敵の人中を拳当て身！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に大刀の柄頭で兵藤のひばらの辺に当て身を入れたらしい。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「二階へ庇を渡って入った上、よく眠ってる金之助を当て身で目を廻らせ、鎌で切り刻んだのは猾いやり方だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭の銀貨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿波屋さんの皆さんが着くほんの四半刻ほど前でしたよ、深い饅頭笠で顔を隠した、腰法衣の修行者が訪ねて来て冠物のまま阿波屋の使いの者だがと私を呼出し、いきなり一と当て当て身を喰わせて眼を廻させてしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――鶴雄さんが好きにならはるのン、無理はない」　そう思うと、嫉ける前にまず、「――あてみたいなもンあかん」　と、いう諦めが先に立って、がっかりした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と主税は刹那に感じ、真先に切り込んで来た武士を反し、横から切り込んで来た武士の鳩尾へ、拳で一つあてみをくれ、この勢いに驚いて、三人の武士が後へ退いた隙に、はじめて刀を引っこ抜き、正眼に構えて身を固めた。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた大学では秀才やったそうやさかい、あてみたいなもん定めし幼稚に見えるやろけど、あてから見たら化石みたいな人やわ、というてやった事もあります。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
