[
  {
    "uuid": "49e224a3-c4bd-5019-ab0a-9b0201ece412",
    "entry": "当て所",
    "reading": {
      "primary": "あてど",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aim",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「もう人生も先が見えないし、当て所もなく、ただぼんやりと一日を過ごしているよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "会議は終始、当て所ない議論の応酬で、具体的な成果は何もなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "親の元を離れ、彼はただ当て所もなく、地図にもない町へと向かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "災害で家を失い、身寄りもなく、避難所から避難所へと当て所なく移り住む日々が続いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学卒業後、彼女は明確な当て所もなく、とりあえず有名企業に就職することにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "研究は長年続けられてきたが、その当て所が曖昧で、進展が見られなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう頑張る気力もない。この先、どこへ向かえばいいのか、全く当て所がないんだ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "そういう時、二人は帰りがけに、山の上へ引っかえして、ヤケクソに持っているだけの弾丸をあてどもなく空に向けて発射してしまったりした。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してあてどもなく壁を見詰めてゐた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな風にして眠ってしまったあの人の寝顔を見ていると、私は急にあてどもない嫉妬を感じた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、君勇はいきなり、「小郷はんを殺したのは、あてどす」　と、自白した。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで空を流れる雲のやうに、あてどもなく旅をしていつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――Ｋと私とは暗い路上に視線を落したまま、詞もなく、あてどもなく歩き續けて行くのだつた。",
              "citation": {
                "source": "霧の夜に",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに何時の間にやら重いたどたどしい足どりが泥酔漢めいて来て、時とするとその痛い乳の上から真白な畜生の手でもふいと飛び出しさうなそんな気がしてただもう恐ろしく、抑えては引つ込ませ、抑えては引つ込ませ、益々深い濃霧の中をあてどもなくまぎれ込んで了ふのであつたが……。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧を湛へし海水に、快げに、遊泳せる鱗は、鰭の運動も忙しく、あてどもなく彷徨ひぬ。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、どこをあてどもなしに走って、やっと気が注いたところで、そこに板屋根の小窓から威勢のいい燈の見えている家があった。",
              "citation": {
                "source": "馬の顔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は、しばらくあてどもなく立つてゐた。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "かなしい希望は、はるかな道々につながつて、彼等二人は、あてどもなく歩いて行つた。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "矢野はあまり中島を好かぬのだけれど、あてどもなく下宿をさがすもいやだから、ともかくもと思ってたずねたのだ。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方とごいっしょに、あてども無しにそこらを探してあるいているんです」「それは御苦労さまですね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅な村落の内で毎日凡ての目に熟して居る女の所在を覘ふことは、蛸壺を沈めるやうな其※寧ろあてどもないものではない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "雜木林の間に馬を繋いだ儘で彼は衣物を改めてあてどもなくぶらつくのが好きであつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し篝は其光の及ぶ範囲内に動いて居る人々を明かに見せる丈で一向にあてどもない。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "円タクにでも乗つて、あてどもなく海岸通りなどをまはり、春霞みを衝いて出てゆく船を眺め、ゆつくりと支那料理屋にでも休んでから、夜はまたひとりでオデオン座の特等席になりとをさまつて、居眠りでもして来ようといふやうな、何とわたしには全く珍しい「好日」には違ひなかつたのである。",
              "citation": {
                "source": "好日の記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは嘉村君と、天気の好い日などに、しばしばあてどもなく町中を歩いて、やがて野原に出て日暮時になり、更にまた電車のなくなるまでも街々を歩き、さういふ時には哀しさも忘れて、却つて得難いのびやかさを味はつたことが屡々だつた。",
              "citation": {
                "source": "痩身記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は雪の中に道を失ふた旅人のやうに、あてどもなくふら／＼と歩いて、眠気の襲来を待つのであつたが、不図、辛うじて一台の車を拾ふと、品川まで――とつたへた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬰児は何処をあてどもなく匍匐する。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして小屋の中が真暗になった日のくれぐれに、何物にか助けを求める成人のような表情を眼に現わして、あてどもなくそこらを見廻していたが、次第次第に息が絶えてしまった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉の眼で恐ろしい夢でも見るように、産婦はかっと瞼を開いて、あてどもなく一所を睨みながら、苦しげというより、恐ろしげに顔をゆがめた。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこをあてどともなく歩いていると、小さな草の丘に出て来た。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "菱１　どこをあてどともなく歩いていると、そそけた灌木にとり囲まれた池のほとりに出て来た。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の世に希望を失った人生の落伍者が、あてどのない八つあたりの不平と自己嫌悪とに気を腐らして、人生の行路さながらの吹雪道を無目的に歩いているように見える。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてどもなく前の方ばかりを見つめて歩いてゐるうちに、はつきりしてゐた燈がいつか瞼にうるんでゐた。",
              "citation": {
                "source": "神樂阪の半襟",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々思い出したように上野の図書館に参りましては、医学に関係しました不思議な出来事や、珍らしい事実を書いた書物を、あてどもなく読み散らしておりますうちに又も、思いもかけませぬ書物から大変なお話を見つけ出しまして、ビックリ致したので御座います。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞に書いたら一部送って下さい」　その言葉の中には、何のあてどもない、行き当りバッタリ式の仕事をしている人々の心の痛みがこもっていた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙二はフットあたりを見廻してから口笛を吹き出して何のあてどもなく足元の花をむしった。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
