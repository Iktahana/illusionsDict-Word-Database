        "examples": {
          "standard": [
            {
              "text": "侍は主君からの「あてがい扶持」で生活していた。",
              "source": "幻辞"
            },
            {
              "text": "江戸時代の藩士は「あてがい扶持」で生計を立てた。",
              "source": "幻辞"
            },
            {
              "text": "家臣は領主から「あてがい扶持」を月々受け取る。",
              "source": "幻辞"
            },
            {
              "text": "禄高は「あてがい扶持」として家に配分された。",
              "source": "幻辞"
            },
            {
              "text": "若年寄が「あてがい扶持」で優遇されている。",
              "source": "幻辞"
            },
            {
              "text": "侍女は大名家から「あてがい扶持」で養われた。",
              "source": "幻辞"
            },
            {
              "text": "給与は毎月「あてがい扶持」として通帳に振り込まれた。",
              "source": "幻辞"
            },
            {
              "text": "官吏は「あてがい扶持」で官職を維持していた。",
              "source": "幻辞"
            },
            {
              "text": "平時の家計は「あてがい扶持」のみで成り立った。",
              "source": "幻辞"
            },
            {
              "text": "楽士は宮廷から「あてがい扶持」を受けていた。",
              "source": "幻辞"
            },
            {
              "text": "扶持米が「あてがい扶持」の主要な部分を占めた。",
              "source": "幻辞"
            },
            {
              "text": "番士は主家から「あてがい扶持」で養われていた。",
              "source": "幻辞"
            },
            {
              "text": "別邸の維持費には「あてがい扶持」が充当された。",
              "source": "幻辞"
            },
            {
              "text": "隠居後も「あてがい扶持」が月々支給された。",
              "source": "幻辞"
            },
            {
              "text": "階級によって「あてがい扶持」の額が厳密に定められた。",
              "source": "幻辞"
            },
            {
              "text": "武装購入は「あてがい扶持」の範囲内で行われた。",
              "source": "幻辞"
            },
            {
              "text": "倉庫の管理費は「あてがい扶持」で賄われた。",
              "source": "幻辞"
            },
            {
              "text": "公務員は「あてがい扶持」で生活水準が保証された。",
              "source": "幻辞"
            },
            {
              "text": "親族は親からの「あてがい扶持」で家計を支えた。",
              "source": "幻辞"
            },
            {
              "text": "家族経営では「あてがい扶持」で従業員を雇用していた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "けれども、配給とりも直さず万事あてがい扶持で、唯々諾々と生きる無気力の習性となるなら、それは堕落と云われなければならない。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてがい扶持の低い家禄のものとして、余裕のないその日その日は、気の持ちようまでもぎすぎすさせ一図にさせたのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな所へ寮を建てて、そこへ奥様を住まわせて、あてがい扶持をくれて飼って置かれる。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "収入もまたかりにお客が二千円くれたのに千円ですと言って、その中から千円分の税金と部屋代、（折半に近い金額）を支払われても、パレス側は一切、女からのあてがい扶持で、唯々諾々としていなければならない。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、今まで、さしたるライバルもなく、呑気にあてがい扶持に満足していた公卿たちである。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もあてがい扶持のニュースを与えられるだけだ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子は、やがて子爵家の跡目相続をした近親のものが邸へ乗り込んで来ること、そうなれば親族会議の結果定められたあてがい扶持で別邸に住まねばならぬこと、それにつけても、あなたは子爵家の遠い縁者に当るのだから、何分のお力添えが願い度いなどと、しんみりした打開話さえしたものだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はその頃はもう、あてがい扶持の別邸住いになっていたが、そこから川村の目を忍んで、独でわしのホテルへ遊びに来ることもあった。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑠璃子は今ではあてがい扶持の別邸住いなので、ついそのことを知らずにいたのだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は大牟田家のあてがい扶持なんかつき返して、僕の女房になって、どこへでも好き勝手な所へ行けるのだ。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間らしい生活に対する翹望というものは職場、職分の相違、したがって細かい気持の部分部分では全く同一でないにしろ、働いて、税を出して、あてがいぶちの賃銀を払われて暮している者すべての人々を貫いて流れる一線である。",
              "citation": {
                "source": "今日の文学に求められているヒューマニズム",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてがいぶちの食事をぼそぼそ食べ、そこにごろりと寝ころんで、暮れかかった空を眺めていると、へんに佗びしい気持ちになった。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分長い間、今小学校の校長の居る処に住んで居て、畑や米の世話をして居たが、気の勝った年寄の召使と主人とは、しばしば衝突が起って、しばらく東京の家の方へ来て居た事もあったけれ共、今は、隣村とこの村の境のどっちともつかない様な処へ息子からの「あてがいぶち」で暮して居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
