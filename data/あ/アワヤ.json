        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あわやという時に助け船が来た。",
              "source": "幻辞"
            },
            {
              "text": "あわや事故になるところだった。",
              "source": "幻辞"
            },
            {
              "text": "あわや倒産という危機を脱した。",
              "source": "幻辞"
            },
            {
              "text": "あわや死亡という重傷を負った。",
              "source": "幻辞"
            },
            {
              "text": "あわや失敗という結果を回避した。",
              "source": "幻辞"
            },
            {
              "text": "あわや火事になるところだった。",
              "source": "幻辞"
            },
            {
              "text": "あわや沈没という状況だった。",
              "source": "幻辞"
            },
            {
              "text": "あわや感染という恐怖を経験した。",
              "source": "幻辞"
            },
            {
              "text": "あわや無一文という状態だった。",
              "source": "幻辞"
            },
            {
              "text": "あわや解雇されるところだった。",
              "source": "幻辞"
            },
            {
              "text": "あわや破産という危機を免れた。",
              "source": "幻辞"
            },
            {
              "text": "あわや生死の境をさまよった。",
              "source": "幻辞"
            },
            {
              "text": "あわや絶望という状況だった。",
              "source": "幻辞"
            },
            {
              "text": "あわや全滅という戦況だった。",
              "source": "幻辞"
            },
            {
              "text": "あわや取り返しがつかないところだった。",
              "source": "幻辞"
            },
            {
              "text": "あわや致命的な誤りを犯すところだった。",
              "source": "幻辞"
            },
            {
              "text": "あわや地獄を見るところだった。",
              "source": "幻辞"
            },
            {
              "text": "あわや夢が破れるところだった。",
              "source": "幻辞"
            },
            {
              "text": "あわや野たれ死にという人生だった。",
              "source": "幻辞"
            },
            {
              "text": "あわや悪夢が現実になるところだった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」　とあとよりいいたるはわが家につかいたる下男の声に似たるに、あわや出でむとせしが、恐しきもののさはたばかりて、おびき出すにやあらむと恐しさは一しお増しぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "国賊逆徒、売国奴、殺せ、撲れと、衆口一斉｜熱罵恫喝を極めたる、思い思いの叫声は、雑音意味も無き響となりて、騒然としてかまびすしく、あわや身の上ぞと見る眼｜危き、ただ単身なる看護員は、冷々然として椅子に恁りつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋭い怯えがたびたび来て、あわや叫び声を出しそうだった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわや台座に留まろうとして、術の施す隙なき状に、そのまま仰向けに黄昏の地に吸われたが、白脛を空に土を蹴て、褄をかくして俯向けになって倒れた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は我が背後で微に物の動く気息を聞いたので、何心なく顧ると、驚くべし彼のお杉｜婆は手に磨ぎ澄したる小刀を振翳して、あわや彼を突かんとしているのであった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとまた或日来た青年の手紙は強請的な哀願にしおれて、むしろかの女の未練やら逡巡やらのむしゃむしゃした感情を一まとめにかき集めて、あわや根こそぎ持ち去って行きそうな切迫をかの女に感じさせた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙子が御持参の花だから、」「…………」「君がどうと云う事も無いのなら、一本二本惜むにゃ当るまい、こんなに沢山あるものを、」「…………」「失敬、」　あわや抜き出そうとする。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "理順は既に室に迫って、あわや開けようとすると、どこに居たか、忽然として、母夫人が立露れて、扉に手を掛けた医学士の二の腕を、横ざまにグッと圧えて……曰く、「院長。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "万有あわや死せんとす、と忌わしき使者の早打、しっきりなく走るは鴉で。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわやと抱き留めた惣助は刎倒されて転んだけれども、渠危し、と一目見て、道子と菅子が、身を蔽いに、背より、胸より、ひしと主税を庇ったので、英臣は、面を背けて嘆息し、たちまち狙を外らすや否や、大夫人を射て、倒して、硝薬の煙とともに、蝕する日の面を仰ぎつつ、この傲岸なる統領は、自からその脳を貫いた。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエホフの芝居にも、ひとりの気のきかない好人物が、「あわや、というまに熊は女を組み伏せたりき。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわや、というまに熊は女を組み伏せたりき。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわや、というまに熊は女を組み伏せたりき、か。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎は、あわや袁は聞き憶えがあった。",
              "citation": {
                "source": "山月記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、また、颯と駈け出して、あわやという中に影も形も見失ったのでありまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たん釣り上げかけて、ちらりと銀光の閃きを見た魚を、あわや水際で取逃がしたような妙に気が脱けた形で、而かもいよ／＼未練は募るばかりといった気持も籠らせながら、池上はわたくしが母の家へ具体的な結婚談を待受けるために帰るまでの一週間を寮の中で、わたくしのまわりをおかしいくらいまご／＼と過しています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわや持って行きかけた千代重の左の手首を、突然かの女の両手が飛び出して握り締た。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二条で追いつき、あわや襟首をつかもうとした時、盗賊はぶらついていた首をいきなり千切ってふところへ入れたので、すかされて前のめりになった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すれ違いさま、あわやと見たので、思わず急角度で避けようとしたのである。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に此の演習の二三日前などは学校裏の崇政殿という、昔の李王朝の宮殿址の前に引張られて、あわや殴られようとしたのを、折よく其処を生徒監が通りかかったために危く免れたのだという。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、あわや打据えんとしつつ前後を見た無法ものは、フトその母衣の中に目を注いだ。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろみんな酔っているので、ふた言三言の云い争いからあわや腕ずくになろうとする一刹那に、どうしたのか甚右衛門はうんと唸ったままで倒れてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度は誰も止める者がないので、喧嘩はいよいよ大きくなって、あわや腕ずくになろうとするところへ、提灯をさげた一人の侍が通った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "人形使い",
                "note": "青空文庫"
              }
            },
            {
              "text": "よんどころなく江を突っ切って進んでゆくと、やがて岸に着いた時に、船の勢いを止めるにも止められず、あわやという間に突き当って、洲はくだけ、岸はくずれた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "録異記",
                "note": "青空文庫"
              }
            },
            {
              "text": "「雲のあわやから鬼が穴う突ん出して縄で縛るよな屁をたれた」　甚句を歌うものがある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゆく先はこの西湖で、彼女は月を仰いで暫く泣いた後に、あわや身を投げ込もうとするところへ、不意にあらわれて来たのが、かの蘇小小の霊といわれる美人だ。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札の顔はだんだん険しくなって、あわや通路をしめてしまおうとした時、葉子はするするとそのほうに近よって、「どうもすみませんでした事」　といって切符をさし出しながら、改札の目の先で花が咲いたようにほほえんで見せた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労と不意の襲撃に立ち直るひまもなく、あわやプツリと太股へ不覚の穂先を見舞われたかと見えた刹那！",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "声に応じて四十人の武者は、一度に馬から飛び降りて、二十人は弓を満月のように引き絞り、あとの二十人は剣を構えて眼の前に近付いて来た光る者にあわや打ちかかろうとした。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
