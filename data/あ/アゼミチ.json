        "examples": {
          "standard": [
            {
              "text": "農村風景のあぜ道を歩いた。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道は農業地帯の典型的な景観である。",
              "source": "幻辞"
            },
            {
              "text": "子ども時代あぜ道を走り回っていた。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道はホタルが多く見られる場所だ。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道の両側に花が咲いている。",
              "source": "幻辞"
            },
            {
              "text": "その絵画ではあぜ道が描かれている。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道をジョギングコースにしている。",
              "source": "幻辞"
            },
            {
              "text": "農家はあぜ道を通って田んぼに向かう。",
              "source": "幻辞"
            },
            {
              "text": "写真家があぜ道の美しさを撮影している。",
              "source": "幻辞"
            },
            {
              "text": "その映画ではあぜ道でのシーンが印象的だ。",
              "source": "幻辞"
            },
            {
              "text": "古い日本の風景としてあぜ道は重要である。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道は生物多様性が豊かな環境である。",
              "source": "幻辞"
            },
            {
              "text": "田舎でのあぜ道の風景は心を落ち着かせる。",
              "source": "幻辞"
            },
            {
              "text": "その詩ではあぜ道が主題になっている。",
              "source": "幻辞"
            },
            {
              "text": "観光地としてあぜ道を売り出している地域がある。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道のメンテナンスは農家の重要な作業だ。",
              "source": "幻辞"
            },
            {
              "text": "都会人にとってあぜ道は異なる世界に見える。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道の歴史は日本の農業の発展と共にある。",
              "source": "幻辞"
            },
            {
              "text": "子どもたちはあぜ道でカエルやトンボを探している。",
              "source": "幻辞"
            },
            {
              "text": "あぜ道は季節の変化を感じやすい場所である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "大きな太鼓や鐘があぜ道にすえられて赤裸の人形が力に任せてそれをたたく。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は徳二郎のあとについて田んぼにいで、稲の香高きあぜ道を走って川の堤に出た。",
              "citation": {
                "source": "少年の悲哀",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "本あぜ道は榕樹の林へ向っていた。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かの女と手を引き合ひながら、また稻の間のあぜ道を縫つて歩いたり、筆の軸の長さほどもない小幅の流れの小さい田螺を――お鳥の毎年起きる脚氣の藥りだと云ふので――拾つて見たりして、宿へ歸つて來た。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鳥は、或日暮れに、あぜ道を歩いてゐて通りすがつた一人の田舍者を闇に挑發して見せるかのやうに、義雄の横顏へ熱心な接吻を與へたことがある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごんぺいじいの家から祖母の家まではあぜ道を五十歩ぐらい走れば行かれる所である。",
              "citation": {
                "source": "三年前",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれがこのあぜ道に立っているとき、おりおりいうにいわれぬ侮辱を受けることがある。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鼠は畑のあぜ道の土中に穴を掘って巣となし、麦をかみ切っては巣に運んで、だんだん多く貯蓄しておき、必要に応じてこれを食料にあてる。",
              "citation": {
                "source": "動物の私有財産",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は石を拾って、わざわざ線路の方まで、田のあぜ道を伝わってゆきました。",
              "citation": {
                "source": "長ぐつの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "林太郎は、おきぬねえちゃんの手につかまって、たんぼのあぜ道を湖の方へ歩いていきました。",
              "citation": {
                "source": "あたまでっかち",
                "author": "下村千秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は一間ぐらいの畑、左はたんぼ、三尺くらいのあぜ道でヘビに出会ったが、たいがいのヘビは竿尻で打つと逃げ出すものだが、一尺も鎌首を持ちあげて向かってきたので、竿をその場へ放り出して、後ろも見ずに逃げたことがある。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪くすると押されてあぜ道を踏みはずし、泥田に足を突っ込むなど全く災難。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩公園を出れば蛙鳴くたんぼ道で、酉の市には大鳥神社まで群衆のつづくのが見渡され、あぜ道伝いに吉原の非常口、いわゆる吉原田圃、入谷田圃、浅草田圃と皆親類、所々に案山子が立って風流千万。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぜ道に沿った、まばらな生垣をもぐり越すと、そこがもう問題の墓場でした。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これなら大丈夫と見定めた上、彼は元のあぜ道にとって返し、附近の百姓家をあさり廻って、難なく一本の鍬を手に入れ、源三郎の墓地に戻って来た時分には、それが皆猫の様に跫音を盗み、闇の中で身を隠しての仕事だったものですから、非常に手間を取り、もう十一時近くになっていました。",
              "citation": {
                "source": "パノラマ島綺譚",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のあぜみちに坐つてゐると、おほなみのやうな土壌の重みが、わたしの心をくらくする、土壌のくさつたにほひが私の皮膚をくろずませる、冬枯れのさびしい自然が私の生活をくるしくする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぜみちを馳けまわる小さな闘士は、大空にむかってオレタチの歌を唄う！",
              "citation": {
                "source": "白い魔の手",
                "author": "長沢佑",
                "note": "青空文庫"
              }
            },
            {
              "text": "田も畑もあぜみちも、すっかり雪にうずもれてしまい、川という川はみんな、かたく凍りついてしまいました。",
              "citation": {
                "source": "フランダースの犬",
                "author": "A DOG OF FLANDERS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
