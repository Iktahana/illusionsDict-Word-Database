        "examples": {
          "standard": [
            {
              "text": "その映画の悪役はあばずれ女として描かれている。",
              "source": "幻辞"
            },
            {
              "text": "戦前の文学作品ではあばずれ女が社会的偏見の対象だった。",
              "source": "幻辞"
            },
            {
              "text": "昔の町では、あばずれ女という烙印を押された女性がいた。",
              "source": "幻辞"
            },
            {
              "text": "その女優はあばずれ女の役を演じて大きな反響を呼んだ。",
              "source": "幻辞"
            },
            {
              "text": "歴史小説ではあばずれ女がしばしば登場人物となる。",
              "source": "幻辞"
            },
            {
              "text": "教育の観点からは、あばずれ女というレッテルは有害だ。",
              "source": "幻辞"
            },
            {
              "text": "法律家はあばずれ女への社会的差別について論じる。",
              "source": "幻辞"
            },
            {
              "text": "医学的には、あばずれ女というカテゴリー分けは根拠がない。",
              "source": "幻辞"
            },
            {
              "text": "心理学者はあばずれ女への世間の偏見を研究している。",
              "source": "幻辞"
            },
            {
              "text": "古い言葉では、あばずれ女とは品行方正でない女性を指した。",
              "source": "幻辞"
            },
            {
              "text": "時代劇ではあばずれ女がしばしば悪役として描かれる。",
              "source": "幻辞"
            },
            {
              "text": "現代では、あばずれ女という表現は使われなくなった。",
              "source": "幻辞"
            },
            {
              "text": "文化人類学者はあばずれ女という概念の変遷を研究している。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ界ではあばずれ女というレッテルは女性選手に不当な負担をかけた。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスの歴史では、女性実業家がときどきあばずれ女と中傷された。",
              "source": "幻辞"
            },
            {
              "text": "旅行記でも、異国の女性を指してあばずれ女と述べることがあった。",
              "source": "幻辞"
            },
            {
              "text": "料理番組の歴史では、女性シェフがあばずれ女と呼ばれることもあった。",
              "source": "幻辞"
            },
            {
              "text": "音楽業界の昔の記録では、女性歌手がときどきあばずれ女と批評された。",
              "source": "幻辞"
            },
            {
              "text": "自伝文学では、あばずれ女という社会的偏見に苦しむ描写がある。",
              "source": "幻辞"
            },
            {
              "text": "現代の性差別研究では、あばずれ女という概念自体が問題視されている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あばずれ女の亭主が歌つたおまへはおれを愛してる、一度とておれを憎んだためしはない。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより仁侠の、親分にしても姐御にしても、白刄の中をもおそれぬ氣魄と正義觀のあつた者を、當初は立ててきたのであらうが、總稱して、姐御とは親分のおかみさんをさすことになり、それに似たつくりのあばずれ女などを多くさしていつたものとなつたのだ。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがおきたと夫婦になっていたら、おきたはこんなあばずれ女に、決してなってはいなかっただろう！",
              "citation": {
                "source": "一枚絵の女",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、だれの目にも、あばずれ女としか見えなかった青服の若い女房は、ふだん唇を紅くぬって断髪をちぢらしていたが、雲がくれする前のこと、「わたしたちみたいな、ばかはないよ。",
              "citation": {
                "source": "春はよみがえる",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "と恋愛論を長々と述べ、なお金を請求したことについて検事は疑義を有せらるる如きも、前記の如きあばずれ女は勿論金の問題に来るはずである。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハイ、私でござんすか」　一方の引き合わせも待たず、お米はむしゃくしゃまぎれに突っかけて、「川長のお米というあばずれ女、エエ、法月さんとは、ずっと前からのお知り合いでネ」「あら、お米さんといえば？",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
