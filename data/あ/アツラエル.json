[
  {
    "uuid": "0354922b-8a6c-5974-be7c-b32b610e096a",
    "entry": "誂える",
    "reading": {
      "primary": "あつらえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to give an order",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "娘の結婚式に合わせ、馴染みのテーラーで一生ものの背広を誂えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "部屋の入り組んだ間取りに合わせて、壁一面を覆う書棚を家具職人に誂えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "亡くなった母が若い頃に誂えたという訪問着を、娘の卒業式に合わせて仕立て直した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "外反母趾で既製品の靴が合わないため、浅草の専門店で足を計測して革靴を誂えることにした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "創立記念式典の記念品として、社名入りの万年筆をメーカーに特別に誂えてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「まるでお誂え向きの快晴ですね」と、庭師は空を仰ぎながら微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "隠居後の楽しみとして、自宅の庭に数寄屋造りの茶室を誂える計画を立てている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その祈請の筋を聞いてみると物を誂えるような塩梅で、時間なども気短かに区切って注文してあります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで嵌るで染物屋へ物を誂えると同じ調子で、人間の思慮や力量以上の大きな了見の仏菩薩に向って頼む様子ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」身ぶるいをした彼女はそういって、そこでいこじになってヴァニラとチョコレートと盛り分けのアイスクリームを誂える。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、当日、小作の挿画のために、場所の実写を誂えるのに同行して、麻布我善坊から、狸穴辺――化けるのかと、すぐまたおなかまから苦情が出そうである。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞く方では、祝儀のかわりに、なくても我慢の出来る、片手とれた鍋の鋳掛も誂えるといった寸法。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "埴生は料理を誂える。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は酒が飲めるかというと、飲まなくても誂えるものだという。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "古賀がいくらだけ焼けと金で誂えるのに先ず驚いたのであったが、その食いようを見て更に驚いた。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして銀座で水菓子の籠を誂えると、上野駅まで自動車を飛ばした。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は新規に誂えるまでもなく、松坂屋あたりの店で見つけた出来で間に合わせて、唯寸法だけを少し詰めて貰ったとも言った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば夜なべの気も惓んじた頃、戸外に一度この声を聞く時は、狐窓から呼び止めて熱いのをと幾つか誂える。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが食事を誂える。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭陵の酒を買わせるやら、桂州の竜眼肉をとりよせるやら、日に四度色の変る牡丹を庭に植えさせるやら、白孔雀を何羽も放し飼いにするやら、玉を集めるやら、錦を縫わせるやら、香木の車を造らせるやら、象牙の椅子を誂えるやら、その贅沢を一々書いていては、いつになってもこの話がおしまいにならない位です。",
              "citation": {
                "source": "杜子春",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "隠者はあまりに歳を取り弱っていて、自分では食べ物を誂えることができなかったのです。",
              "citation": {
                "source": "羊飼いハイタ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから赤茄子を五つ誂える時に、五つが五つ同し大きさのを持って来るように言いつける。",
              "citation": {
                "source": "独居雑感",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど夜会服を誂える段になっても彼女は誰とも相談しないで、ただ父親だけに話して自分の母親だったらどんな衣裳で舞踏会に出たろうかとあれやこれやと想像してみた。",
              "citation": {
                "source": "頸の上のアンナ",
                "author": "АННА　НА　ШЕЕ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へん年に一遍牛肉を誂えると思って、いやに大きな声を出しゃあがらあ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さざなみの番頭で」「馬鹿野郎、『さざなみ』のお年玉を、『さざなみ』の番頭が誂えるに、何の不思議があるんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつは酒ではなく焼酎なので、一合のそれを天鉄で二合に割ったうえ燗をしてもらうのだが、誂えるてんぷらも変っていた。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあゝ云う贅沢な真似は出来ないまでも、せめて自分の好みに叶った器を造り、それへ水洗式を応用するようにしてみたいと思ったのだが、そう云うものを特別に誂えると、よほどの手間と費用が懸るのであきらめるより外はなかった。",
              "citation": {
                "source": "陰翳礼讃",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし名刺を誂える時にもう後悔しました。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸ッ子で、足袋屋の小僧だったが、その頃は足袋を足に合わせて誂えるものが多く、小僧の蓮城は顧客の足を計るのを憤慨して十三歳の時出奔、狩野菫川の門人になったという、子供の頃からの変り物。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "職人はいても誂える人がなくなってしまいました。",
              "citation": {
                "source": "手仕事の日本",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、客がその奥座敷へ通って、うなぎの蒲焼や泥鱒鍋をあつらえた時には、かのすっぽん共は平気で遊んでいるが、もし泥鼈をあつらえると、かれらは忽ちに水のなかへ飛び込んでしまう。",
              "citation": {
                "source": "魚妖",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは依頼者の方であらかじめ糯米を買い込んでおくので、米屋や菓子屋にあつらえるよりも経済であると云うのと、また一面には世間に対する一種の見栄もあったらしい。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなかには烏帽子をあつらえる者もあった。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し歩いて、千疋屋の二階に落付いて、不純なものよりもと彼女が笑って、メロンと紅茶とをあつらえるまで、私はただ彼女のお伴みたいに振舞ってしまった。",
              "citation": {
                "source": "道化役",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一昨日のお詫びやら、珈琲をあつらえるやら、どこに行きましょうかと尋ねるかと思えば、海の見える室をとっておいて貰ってるとか、へんにそわそわして、小料理屋の主婦らしい態度に生娘らしい調子を交えていた。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理店で食事をするのに、自分で好みの料理をあつらえることが出来ないと、君はいうのかね」　そんなばかなことがあってたまるものか。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　昌作がいつもあつらえる珈琲とコニャックとを取りに、沢子が立って行った時、俊彦は落着いた調子で云った。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
