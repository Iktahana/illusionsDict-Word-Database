            }
          ],
          "literary": [
            {
              "text": "あまりと言えば、あまりの歯の浮くような見え透いたお世辞ゆえ、客はたすからぬ気持で、「わかった、わかった。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春彦　その気質を知ればこそ、日ごろ堪忍していれど、あまりと言えば詞が過ぐる。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（親鸞を押す）慈円　あまりと言えば失礼な――良寛　お師匠様に手を掛けたな。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それではさっきから闇の中で黙って頭の君は私の影を御覧になっていたのかと驚いて、私はあまりと言えばあまりな頭の君を「まあ、お人の悪い。",
              "citation": {
                "source": "ほととぎす",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　お銀様がこの夜中に家を脱け出したのは、あまりと言えば無謀です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜、酔っぱらって、とりみだして、あまりと言えば、あまりの醜体です。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "落第だよ、こりゃみんな」　自分で自分をあやすことのできない、あまりと言えばこのだらしのなさ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのことで部落民が助かるなら、おれは、武士の誇りも捨てて、開城しようかとも思ったが、あまりと言えばあまりの条件だ。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "郁之進　（おろおろして）あまりと言えば、あまりな！",
              "citation": {
                "source": "稲生播磨守",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和からの戻るさ、立場立場の茶屋で拵えさせた握飯を兵糧に、四日というもの物置に忍んで、昨夜、翫之丞を手に懸けおおせたものの、あまりと言えば細工が過ぎた。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怨霊首人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、まア美しいな」「痩せ我慢を言ってはいけない、そう言っては失礼だが、お雪殿より外に女が無いように思って居る貴公は、あまりと言えば世間を知らない――」「黙れ、無礼だろう」　声は低いが、左馬之助の口調には、押え難い憤怒が漲ります。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第八夜　蛇使いの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んな事をしても女を奪い還せ「これ南条ッ、何をするッ」「あまりと言えば無法ッ」「馬鹿ッ、血迷ったか、人に見られたら、貴公の破滅だぞ」　半狂乱となった南条左馬之助が、危うく小袖幕の中へ飛び込もうとするところを、日頃仲の好い朋輩が二、三人駆け付けて、危ういところで擁き止めました。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第八夜　蛇使いの娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「平次、御奉行｜朝倉石見守様から厳い御達しだ、――近頃府内を騒がす盗賊、盗んだ品を返せば罪はないようなものではあるが、あまりと言えばお上の御威光を蔑ろにする仕打だ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大盗懺悔",
                "note": "青空文庫"
              }
            },
            {
              "text": "向柳原の名物娘が一人、絞め殺されて死んだのを、うやむやに葬るというのは、あまりと言えばわけが解らなさすぎます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰でも宜い、その女を手に掛けるとは、あまりと言えば不仁」「何を、其方の知ったことか、――それより、今頃此の山にうろうろするのは怪しい奴ッ、それッ」　奥村主殿が手を挙げると、六人の若党、三方からパッと飛び付きます。",
              "citation": {
                "source": "天保の飛行術",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを今更貴公の口から、さかしら立てて聞かしてもらうのは、あまりと言えば白々し過ぎると言うのだ！",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二つの椀を左右の手に持って立ち上り、「如意でお悪ければ、この品でお相手を致すでござろう」　あまりと言えば人をばかにした仕業である。",
              "citation": {
                "source": "大菩薩峠",
                "author": "慢心和尚の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことはもうあまりと言えばあまりに説明のできないことなので、ひどくドゥーニャを不安にした。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりと言えば人を嘗めた値段で、実際の取引きはなかったことと思うが、とにもかくにも、パッティとタマニヨは高いレコードの両大関であった。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせいはあまりといえば父もあまりだと思った。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこれらのあまりといえば変化のなさすぎるような心の印象の後には、何か忌々しい動揺が起ろうとしているように思えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて平右衛門もあまりといえばありありとしたその白狐の姿を見ては怖さが咽喉までこみあげましたが、みんなの手前もありますので、やっと一声切り込んで行きました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あまりといえば、おんぼろで、伺いたくても伺えなし、伺いたくて堪らないし、損料を借りて来ましたから、肌のものまで。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おのれ、それ程までにして我が心を試そうとは、あまりといえば憎い奴」　男の魂は憤怒に焼け爛れたらしく、彼は声も身も顫わせて罵った。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもあまりといえばあんまりだった。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりといえば人を踏みつけにしたしわざだとは思ったけれども、葉子としては結句それがめんどうがなくっていいとも思った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それにしてもあまりといえばあまりな仕打ちだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そう推察すると葉子は自分のあまりといえばあまりに残虐な心に胸の中がちくちくと刺されるようになった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはしかし岡が葉子のあまりといえば露骨な言葉を恥じたのか、自分の心持ちをあばかれたのを恥じたのか葉子の迷いやすくなった心にはしっかりと見窮められなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あまりといえば乱暴ななされ方だ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
