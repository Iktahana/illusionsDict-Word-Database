        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はあおばという苗字を持っている。",
              "source": "幻辞"
            },
            {
              "text": "あおばさんは我が社の営業部長だ。",
              "source": "幻辞"
            },
            {
              "text": "隣人の名前があおばさんという。",
              "source": "幻辞"
            },
            {
              "text": "小説の主人公の名前があおばだった。",
              "source": "幻辞"
            },
            {
              "text": "あおばという姓は日本に何人かいるだろう。",
              "source": "幻辞"
            },
            {
              "text": "あおば氏の意見に皆が同意した。",
              "source": "幻辞"
            },
            {
              "text": "学校であおば先生の授業を受けている。",
              "source": "幻辞"
            },
            {
              "text": "町内会の長があおばさんに変わった。",
              "source": "幻辞"
            },
            {
              "text": "あおばという名前は青葉という字でも書かれる。",
              "source": "幻辞"
            },
            {
              "text": "古い資料にあおばという人物が登場する。",
              "source": "幻辞"
            },
            {
              "text": "地域の有名人にあおばという人がいた。",
              "source": "幻辞"
            },
            {
              "text": "小説『あおば』は昭和初期の作品である。",
              "source": "幻辞"
            },
            {
              "text": "あおばという名前の企業も存在する。",
              "source": "幻辞"
            },
            {
              "text": "あおばさんのご子息も有名人だと聞いた。",
              "source": "幻辞"
            },
            {
              "text": "幕末の記録にあおばという武士の名前が見える。",
              "source": "幻辞"
            },
            {
              "text": "あおばという駅名があると思う。",
              "source": "幻辞"
            },
            {
              "text": "美術品に署名されたあおばという作家の作品がある。",
              "source": "幻辞"
            },
            {
              "text": "あおばという店名のレストランが街にある。",
              "source": "幻辞"
            },
            {
              "text": "歴史的文献ではあおばという人物が活躍していた。",
              "source": "幻辞"
            },
            {
              "text": "あおばという地名も日本に存在する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「だって、ありゃあおばさんだよ。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おほりの　へりのあたりで　あおばえが　ぶんぶん　いったり、　１ぴきの　ちいさな　おばさんねずみが　ジャムのびん　ふきんの　ごみを　あさったり　していました。",
              "citation": {
                "source": "ばにばにきょうだいのはなし",
                "author": "THE TALE OF THE FLOPSY BUNNIES",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしの弓で、わたしの矢羽で、わたしがころした、こまどりのおすを」「だァれがみつけた、しんだのをみつけた」「そォれはわたしよ」あおばえがそういった。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、あおばえに苦めらる。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　すると仁太は、得意になって、あおばなをすすりもせずに、「氏神さまからなら、すぐじゃった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おせんちゃん、このひとは下総の古河からみえた方でね、お常さんの実の兄さんに当るんですってよ」「まあおばさんの、――それはまあ……」　おせんは寒いような気持におそわれた。",
              "citation": {
                "source": "柳橋物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで女が、彼の安心がゆくように説明してやると、城太郎は、「じゃあおばさんは、吉野太夫っていう人の召使なの」　地獄で仏に会ったような顔を見せ、初めて心をゆるしたように従いて行った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
