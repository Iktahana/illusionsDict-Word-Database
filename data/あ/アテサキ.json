        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "送信ボタンを押す直前に、宛先のメールアドレスに間違いがないか念入りに確認した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宛先不明で戻ってきたハガキを整理しながら、疎遠になった旧友に思いを馳せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "宅配便の伝票には、アパート名や部屋番号まで正確な宛先を記入してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「宛先はどちらにいたしましょうか」「こちらの支店宛にお願いします」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年賀状を出すため、パソコンの住所録から最新の宛先データを抽出して印刷する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "社外秘のファイルを、不注意から全く別の宛先へ誤送信してしまい、大きな問題となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "封筒の表書きに、万年筆を使って美しい文字で丁寧に宛先を記す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "何しろ、その時は、沢山の手紙が間違いなく宛先へつくのが奇跡のように思われたものだ。",
              "citation": {
                "source": "雑文一束",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "中積船が来たら托送しようと、同じ苗字の女名前がその宛先きになっている小包や手紙が、彼等の荷物の中から出てきた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　宛先不明・明治四十一年一月二十八日　またやられたよ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "インターネットに接続してあるという条件は付くが、注釈のダブルクリックでブラウザーが立ち上がり、世界への扉が開いて、宛先のページが画面上に呼び出される。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "履歴書や身分証明書のような色々の物を取り揃えてやって来て就職を頼み、紹介状を書いてやり、宛先の雑誌社に電話をかけておいてやるのに、姿を見せず、一ヶ月ほどすぎて、又、悄然と現れて、どうしても行けなかった心境をのべて、重ねて同じ紹介を依頼し、そういうことが綿々と重複する青年。",
              "citation": {
                "source": "精神病覚え書",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに伊東の宛先の新番地が大マチガイときているから、あっちこッちで一服してくるらしく、到着順の前後混乱甚しく、連載小説を読むには全く不適当である。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミリアムが見れば、大部分の宛先は衣服やファッションを愛好するくだらないお店だった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "答案の宛先は、日本小説社、です。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戻ってくると彼はレストー伯爵夫人のところへクリストフのボケを使いにやったんだが、やつは我々に手紙の宛先を見せてしまった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お金を包んで、宛先を書いて、そして小間使いに言って持ってゆかせればいいじゃないですか」「本当に貴方って素敵な方だわ」と彼女が言った。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱の宛先住所と名前を教える。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "宛先や署名が無いから、一般書類かもしれません」　とベリントン大佐。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の部屋でこの電報を落とす可能性のあるひとは、宛先の人物にほかなりません。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "宛先がオードリ地区百番地と書いてあるのを見ても驚かなかった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "客間へ戻って、もう一通の封筒にパラダイス通りの宛先を書いて、白紙を入れた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "署名がないのは変ですが」「それに宛先も書いてない。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
