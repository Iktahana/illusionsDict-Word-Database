        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ドアに指を挟んであ痛と声を上げた。",
              "source": "幻辞"
            },
            {
              "text": "転んでこすった膝がかゆくてあ痛と声を出した。",
              "source": "幻辞"
            },
            {
              "text": "注射針の痛みにあ痛と反応した。",
              "source": "幻辞"
            },
            {
              "text": "歯が痛くてあ痛と唸った。",
              "source": "幻辞"
            },
            {
              "text": "熱いやかんに触ってあ痛と手を引っ込めた。",
              "source": "幻辞"
            },
            {
              "text": "運動中に筋肉痛であ痛と呟いた。",
              "source": "幻辞"
            },
            {
              "text": "医者の処置の際にあ痛と痛みが走った。",
              "source": "幻辞"
            },
            {
              "text": "階段から足を踏み外してあ痛と叫んだ。",
              "source": "幻辞"
            },
            {
              "text": "虫に刺された時にあ痛と反射的に反応した。",
              "source": "幻辞"
            },
            {
              "text": "冬の朝の冷たい水にあ痛と息を飲んだ。",
              "source": "幻辞"
            },
            {
              "text": "運動で肉離れを起こしてあ痛と悲鳴を上げた。",
              "source": "幻辞"
            },
            {
              "text": "針で指を刺してあ痛と痛みが走った。",
              "source": "幻辞"
            },
            {
              "text": "医学部の実習であ痛の種類を学んだ。",
              "source": "幻辞"
            },
            {
              "text": "子どもは転んでもあ痛と言わずに泣いていた。",
              "source": "幻辞"
            },
            {
              "text": "兄は妹のあ痛という声に駆けつけた。",
              "source": "幻辞"
            },
            {
              "text": "演技の練習で痛みの表現にあ痛と声を出す。",
              "source": "幻辞"
            },
            {
              "text": "捻挫の痛みであ痛と歩行が困難になった。",
              "source": "幻辞"
            },
            {
              "text": "外科手術の痛みで患者はあ痛と呻いた。",
              "source": "幻辞"
            },
            {
              "text": "激しいスポーツで怪我をしてあ痛と声が出た。",
              "source": "幻辞"
            },
            {
              "text": "家庭内で転倒して子どもがあ痛と泣いた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "泣くたって一体お父さんたちは、まだ僕の近くに居るだろうか、ああ痛い痛い。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ痛いまあ」といって片手で痛みを押えながらも、延び上って西山さんを見ようとした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と轟大尉は顏を顰めたが、負けぬ氣の大尉、何程の事やあらんと同じく毛脛を現はして、一押押したが、『あ痛た、たゝゝゝ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、大へん、みんな、「あ痛っ、あ痛っ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と励ませば、八蔵はようように、脾腹を抱えて起上り、「あ痛、あ痛。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに気を得て勇をなし、二人の書生は腕を叩き拳を揮うて躍懸れば、撲たれぬ前に、「あ痛、」「お痛。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　悩める婦人は顔も得上げず、病苦に声も切れ切れにて、「あ痛、あ痛々々、冷えましたせいか差込みまして……」「ふむ、持病の癪か。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と車夫の吉造、不意に飛込んで、婦人の髻鷲掴みにしてぐいと引けば、顔をしかめて、「あ痛、つつつつつ」と拳に手を懸け、「無体な、何をするんだねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方を見せて見物を泣かせる目算のあてはずれ、発奮で活歴を遣って退け、手痍少々負うたれば、破傷風にならぬようにと、太鼓大の膏薬を飯粒にて糊附けしが、歩行たびに腹筋よれて、跛曳き曳き、「あ痛、あ痛。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その髪の一条を、雪次郎が引いてとった時、「あ痛、」と声を上げたくらいであるから。",
              "citation": {
                "source": "鷭狩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そりゃあ痛いのなんのって。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "今じゃあ痛くもなんともないが、打たれた時にあ痛かったよ。",
              "citation": {
                "source": "雁坂越",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "古手拭で、我が鼻を、頸窪へ結えたが、美しい女の冷い鼻をつるりと撮み、じょきりと庖丁で刎ねると、ああ、あ痛、焼火箸で掌を貫かれたような、その疼痛に、くらんだ目が、はあ、でんぐり返って気がつけば、鼻のかわりに、細長い鳥の嘴を握っていて、俎の上には、ただ腹を解いた白鷺が一羽。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ痛、あ、あ、痛。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、白粉べたべたの洋装婦人の立膝がもろくもぶっつぶれて、「あ痛っ、こん畜生。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "下りの終汽車らしい、と思った時、（あ痛、痛。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴を反して、雪なす足を折曲げて、「あ痛々々々。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「虫殺しだ、ちったあ痛えや。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ痛え、畜生ッ、ほ、骨がめりこむようだ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうですな、ちょっと開けてみましょう……なかなか固くにぎりしめていますわい」　検事が、老人の人差指と中指とを、指先をつかんで無理にこじあけようとすると、今まで人事不省のままで眠っていた老人は、「あ痛っ！",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが両手はまだしばられたままなので、「あ痛いっ！",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ痛ッ」　ドレゴが叫んだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ううむ、ううむ、と大袈裟に唸りながら、めちや苦茶に鎌を振りまはして、時々、あいたたたた、などと聞えよがしの悲鳴を擧げ、ただもう自分がこのやうに苦心慘憺してゐるといふところを兎に見てもらひたげの樣子で、縱横無盡に荒れ狂ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいたたた、それにしても、おれが生れてから三十七年間、あの裏山で遊んで育つて來たのだが、つひぞいちども、あんなへんな目に遭つた事が無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、お前はいい子だ、な、いい子だから、そのお前の持つてゐる櫂をこつちへ差しのべておくれ、おれはそれにつかまつて、あいたたた、何をするんだ、痛いぢやないか、櫂でおれの頭を毆りやがつて、よし、さうか、わかつた！",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は夕陽にきらきら輝く湖面に浮きつ沈みつ、「あいたたた、あいたたた、ひどいぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈台看守はやっと両腕があいたのでこんどは自分で一つづつ睡ってゐる姉弟の膝にそっと置きました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二室三室と移って行くうちに、始めの緊張した心持は孔のあいた風船玉のようにしぼみ縮んで行く。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一度は大正七年に重い流感にかかつて危く死ぬ處だつた高熱往來の最中に、どう云ふ因縁だか、私の寢てゐた部屋の縁側の障子があいて（無論これは幻覺的にあいたので、實際にあいたのではない）島村抱月さんの姿が見えた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然障子があいたやうな氣がしたかと思ふと紋着羽織に袴をつけた抱月さんが、例の朝鮮髭をはやした頬のこけた、思索家的な奧深い光を持つ細い眼をした顏を靜かにその間から現して、どう云ふ譯だか何の詞もなく、蒲團の袖に鼾つくやうにして丁寧に頭をさげた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
