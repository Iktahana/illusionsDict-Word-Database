        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんさんのこと心配していたよ。",
              "source": "幻辞"
            },
            {
              "text": "あんさんもこの話に参加していたのか。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのような人は珍しい。",
              "source": "幻辞"
            },
            {
              "text": "あんさんの意見を聞かせてもらいたい。",
              "source": "幻辞"
            },
            {
              "text": "あんさんはどうお考えですか。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのお力添えがあれば幸いです。",
              "source": "幻辞"
            },
            {
              "text": "あんさんの経験は貴重だ。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのご指導をお願いします。",
              "source": "幻辞"
            },
            {
              "text": "あんさんの視点は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "あんさんであればできるはずだ。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのような方は滅多にいない。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのご協力に感謝申し上げます。",
              "source": "幻辞"
            },
            {
              "text": "あんさんの意思決定は尊重したい。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのお悩みは理解できます。",
              "source": "幻辞"
            },
            {
              "text": "あんさんであればきっと成功する。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのご提案は検討の価値がある。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのご経歴は素晴らしい。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのお力をお貸しいただきたい。",
              "source": "幻辞"
            },
            {
              "text": "あんさんのようなリーダーが必要だ。",
              "source": "幻辞"
            },
            {
              "text": "あんさんとのお話は勉強になりました。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "赤坂区青山町とあるのを見て、伝三郎は、「あんさん、えらい粋な所に住んだはりまんナ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、政江もかつて崎山に、「あんさんらは、何でんナ、青切符が無料でおますよって、旅する云うても結構でおますナ」と言ったことがある。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の中で芸者三人連れて大尽振っている中年の男を見つけ、失礼ですが、あんさんは何御商売したはりますのですか、ときくと、男は哄笑一番、やがて、連れの芸者にはゞかるのか低声で、もと紙屑屋しとったが、今はこないに出世しましてん。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんさんの時代も日本がポツダム宣言で手をあげたら、やって来ますな。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんさん、お下りさんやおへんか。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、翌る日には登勢ははや女中たちといっしょに、あんさんお下りさんやおへんか、寺田屋の三十石が出ますえと、キンキンした声で客を呼び、それはやがて淀川に巡航船が通うて三十石に代るまでのはかない呼び声であったが、登勢の声は命ある限りの螢火のように勢いっぱいの明るさにまるで燃えていた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんさんは第一番に来て貰わんことには……」　雑誌のことには触れなかったが、雑誌で激励された礼をしたいという意味らしかった。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんさんのお父つぁんに都合が悪うて、私は顔合わされしまへんがな」柳吉は別に異を樹てなかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんさんとは今日こんお初にござんす……」案の定、わざとらしいはったりの仁義を掛けて来た。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏間の敷居へ、もっそりと膝を支くと、「あんさん、」　と、べろりと赤爛れに充血した瞼で、凝と視上げた、その目がぽろりぽろりと、見る見る涙に塞がった。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久という人は、やっとその火鉢の縁へ、鬱金の袖口を引張って、「……思ったより、あんさんは若いこと。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんさん煙管を貸してたあせ……今朝から御飯も欲しゅうない、気がせいてね、忘れて来た。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ見習いで、十分にのうてねえ、くらしはお姑さんが、おもに取仕切ってやもんですから、あんさん、それは酷いぞね――半月おきには、下駄の歯入れや、使いまわしも激しいし……それさえ内へ強請りに来るがね。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人ともねえ、好きやぐらいか、あんさんのお弟子にもなりたいとねえ……血統は争われぬもんじゃぞね。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「婿も……やっぱり、自然と繋がる縁やよって、あんさんにお逢いして、謡やら、舞とかいうものやら。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんさんは酔ってですね。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんさんは、ようものを饒舌ってや。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――まだ世界に一人のあんさんだの、たった一人の妹を言っている！",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんさん、縁者の人――こちらは養家さきの兄の家内たちや――見物をさしてたあせ。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ほんに、あんさんのお庇で……今日という今日は、私は肩身が広いぞね。",
              "citation": {
                "source": "卵塔場の天女",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが頼みの電卓屋は「そりゃあんさん高いわ」と買ってくれず、キャッシュ・レジスタくらいにしか売り先がない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれ何時か云ってやろう、云ってやろうと思って待っていたんだが、お前さんとこの働き手や俺ンとこの一人息子をこったら事にしてしまったのは、この」と云って、お前の母を突き殺すでもするように指差しながら、「この伊藤のあんさんのお蔭なんだ。",
              "citation": {
                "source": "母たち",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんさんがこっちにいたとき、よく息子の進とこさ遊ぶに来る来ると思ってだら、碌でもないことば教えて、引張りこみやがっただ。",
              "citation": {
                "source": "母たち",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんさん、鰊場稼ぎなさるのかね？",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「これはなアあんさん、非常に大切なもんなんぢやよ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こりやあんさん、何も井戸側ばかしぢやない、たとへば石垣なんぞもおんなじ理窟さ。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、駿介が云ひ出す前に、急ににこにこして、「あ、杉野んとこのあんさん」と云つた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、田の水で苦勞した過ぐる日の話などが一句切りつくと、なかの一人が、「杉野のあんさん、東京は此頃どんなふうだかね？",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしはまたあんさんは大阪さ稼ぎに行つとつたんだとばかり思つとつたが。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
