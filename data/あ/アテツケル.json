      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to do (something) to spite (someone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は、私が掃除をしないのを当てつけるかのように、わざと大声で「部屋が汚いな」と言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいプロジェクトで彼が成功したのは、いつも私に仕事を押し付けていた上司への当てつけだったのかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、彼氏が他の女の子と話しているのを見て、わざと私にベタベタと甘えて当てつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "母親は、子供たちが食べ残した夕食を見ながら、「これだから料理のし甲斐がないのよね」と、私に当てつけるように言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議で彼が「もっと効率的なやり方があるはずだ」と発言したのは、前の担当者である私への当てつけだと感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "首相は、特定の政党を名指しせずとも、その政策の矛盾を当てつけるような発言を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "浮気された彼は、新しい彼女との幸せそうな写真をSNSに投稿し、元カノに当てつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さぞかし手きびしく当てつけることであろうからな。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に葉子に当てつけるわけでもなかったが、彼女の感情を庇護う余地はなくなっていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私厭だと言ったんだけれど、皆なしてやらすようにしたんです」おひろはお絹に当てつけるように言うのであった。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしげや、まあ、どこへ行つたんだろうね、のぼせ上つて……」　当てつけるようなお上さんの怒声が谷村さんの部屋まで聞えて来ます。",
              "citation": {
                "source": "清修館挿話",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初彼は相手が自分に当てつけるために、わざと庄左衛門の女の話を持ちだしたのだと思った。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「えッ……」　何だ、何だ、何だてえんだ、ありゃいってい、人間の片腕じゃあねえか、イヤに当てつけやあがるぜ、人間の生腕が一本、三宝の上に置いてあるんだぜ、いってえ、何のおまじねえだ、当てつけるなら少々お門違いのようなものだが、あいつらの言った今の口上は、「岩倉三位殿に献上！",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツカ／＼と追い越すのは当てつけるようで粋が利かない。",
              "citation": {
                "source": "冠婚葬祭博士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ふいにちょうどこの瞬間、まるでわざと当てつけるように、きのう自分が階段の上に立って、おかみがアヴドーチャのことで嫉妬を起こすだろうと、二人に話した時のことが、まざまざと思い出された……これはもう堪え得られぬことだった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　笑楽のおやじは半分登恵子にも当てつけるように言った。",
              "citation": {
                "source": "女給",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「妙なところで当てつけるね」　と三輪さんは聞き捨てにしなかった。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当てつけるなよ」　と密に黒チックというのを利用して黒がっている団さんが笑った。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はおれに、いくぶんあてつける気持で、そう言ったのだろうが、しかし、泣いているのはお前だけでない。",
              "citation": {
                "source": "桜桃",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イトコ同志の親に生れた馬鹿者やいと言うところを、優星学の談でうまくあてつけるのでしょうか。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここの小家から、あの婆さんが顔をだして、ろくでもない奴が来やがって、うるさくってしかたがないなんて、僕にあてつけるようなことを云ったのだよ」　益雄の記憶もたしかにその木の傍であった。",
              "citation": {
                "source": "草藪の中",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恨んで居る様なゾリゾリと云う不愉快な音はあてつける様にほそい毛の間から起った。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのことをあてつける者がいましたね。",
              "citation": {
                "source": "女と帽子",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おのれこの姉にあてつける気か！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長平さんにあてつけるわけではないが、いつのまにやら、長平さんと梶せつ子がよろしく両成敗の当事者となっている隅ッこで、いつのまにやら三人目の一方損をひきうけてブウブウ言っているのがワタクシさ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人にあてつけるに手数は掛らない、ちょっと八っちゃんに剣突を食わせれば何の苦もなく、主人の横っ面を張った訳になる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてを小枝にあてつける多計代の刺すような言葉が、和一郎にどんなに猛烈な母への憎悪をたきつけるか。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なんですか、もう、」とイングラム孃はあてつけるやうに唇をそらして云つた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "四尺以上の身長で、常に二本足で立って歩き、一夫一婦であり、子は一ぴきしか生まないという群棲動物を見ていると、非常に我々人間にあてつけるようであり、自分達の家庭生活をいやでも思い出さざるを得ない。",
              "citation": {
                "source": "親は眺めて考えている",
                "author": "金森徳次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to make a display of affection (for each other)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "公衆の面前で当てつけるように振る舞うカップルに、周囲は冷ややかな視線を送っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "彼女は元恋人に当てつけるかのように、新しい彼氏と腕を組んで通り過ぎていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "独り身の私の前で、わざと当てつけるように二人の仲の良さをアピールしてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "周囲に当てつけるような彼らの過剰なスキンシップには、誰もが苦笑いするしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "パーティーの最中、二人は他の客に当てつけるかのごとく、自分たちの世界に入り込んで見つめ合っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      }
