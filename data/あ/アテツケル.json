[
  {
    "uuid": "2f619546-1e60-596b-a41c-11a31164de36",
    "entry": "当てつける",
    "reading": {
      "primary": "あてつける",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
        "動詞-他動詞"
      ],
