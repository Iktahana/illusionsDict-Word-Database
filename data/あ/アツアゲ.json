        "examples": {
          "standard": [
            {
              "text": "厚揚げを一口大に切って、大根と一緒に煮物にしました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今夜はおでんに厚揚げを入れようか」と妻に尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スーパーで新鮮な厚揚げを見つけたので、今晩のおかずにしよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "厚揚げの表面は香ばしく、中はふっくらとしていて美味しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "居酒屋で出された厚揚げの生姜醤油がけが、熱燗によく合う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子どもが厚揚げの煮物を気に入って、「もっと食べたい」とおかわりをしてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冷蔵庫に厚揚げが残っていたので、急遽野菜炒めに追加した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "葛岡は晩、下谷の腰掛け店で厚揚げのカツレツを御馳走して呉れました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
