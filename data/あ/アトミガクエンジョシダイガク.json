        "examples": {
          "standard": [
            {
              "text": "跡見学園女子大学のオープンキャンパスに参加し、キャンパスの雰囲気や学生の活気ある様子を肌で感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "娘は跡見学園女子大学の文学部を志望しており、来年春の入学を目指して受験勉強に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "跡見学園女子大学で培われた教養と専門知識は、卒業後、多様な分野で活かされている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "最新の大学進学情報誌では、跡見学園女子大学が「キャリアサポートが充実した女子大学」として紹介された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "母校である跡見学園女子大学の同窓会が近々開催されるので、久しぶりに友人たちと再会するのが楽しみだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「跡見学園女子大学って、もしかして英語の授業がすごく充実してる？」と、留学経験のある友人に尋ねてみた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
