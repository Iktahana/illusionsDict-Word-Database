    "definitions": [
      {
        "index": 1,
        "gloss": "calculating",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女の笑顔はあざとくてついつい騙されてしまう。",
              "source": "幻辞"
            },
            {
              "text": "その営業担当者のやり方があざとい。",
              "source": "幻辞"
            },
            {
              "text": "あざとい手法で顧客を獲得している。",
              "source": "幻辞"
            },
            {
              "text": "彼のあざとい態度に皆が気づいている。",
              "source": "幻辞"
            },
            {
              "text": "社会心理学ではあざとい行動パターンを研究している。",
              "source": "幻辞"
            },
            {
              "text": "あざとく演じるのが得意な俳優がいる。",
              "source": "幻辞"
            },
            {
              "text": "その広告はあざといと指摘されている。",
              "source": "幻辞"
            },
            {
              "text": "恋愛テクニックはときにあざとく見える。",
              "source": "幻辞"
            },
            {
              "text": "相手をあざとく操作しようとしている。",
              "source": "幻辞"
            },
            {
              "text": "政治家のあざとい発言が批判を浴びている。",
              "source": "幻辞"
            },
            {
              "text": "あざとく取り入ろうとする姿勢は好かれない。",
              "source": "幻辞"
            },
            {
              "text": "その映画のシーンはあざとく作られている。",
              "source": "幻辞"
            },
            {
              "text": "マーケティング戦略があざとすぎる。",
              "source": "幻辞"
            },
            {
              "text": "子どもながらあざとい表現をしている。",
              "source": "幻辞"
            },
            {
              "text": "あざとい仕草が演技に見えた。",
              "source": "幻辞"
            },
            {
              "text": "販売戦略の中にあざとい工夫がある。",
              "source": "幻辞"
            },
            {
              "text": "友人の手助けの申し出があざとく感じた。",
              "source": "幻辞"
            },
            {
              "text": "あざとさが売りのタレントがいる。",
              "source": "幻辞"
            },
            {
              "text": "商品のパッケージングがあざとい。",
              "source": "幻辞"
            },
            {
              "text": "あざとい計算が見え隠れしている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "――　万世橋向うの――町の裏店に、もと洋服のさい取を萎して、あざとい碁会所をやっていた――金六、ちゃら金という、野幇間のような兀のちょいちょい顔を出すのが、ご新姐、ご新姐という、それがつい、口癖になったんですが。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実の人間同士の間には国境などというあざといものはありゃしない。",
              "citation": {
                "source": "烈婦",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、徒らに言葉尻を捉へて、あざとい批評を加ふべきではなく、論者の真に言はんとするところを、虚心坦懐に聴くべきでありますが、また同時に、その人の使ふ言葉は、どういふ意味に使はれてゐるにせよ、そのことが即ち、その人の思想を端的に示してゐることも亦、争はれないところであります。",
              "citation": {
                "source": "戦争と文化",
                "author": "――力としての文化　第三話",
                "note": "青空文庫"
              }
            },
            {
              "text": "葵を見ると、乾は、ついと立ち上って、あざとい愛想笑いをしながら、「お、葵嬢。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ねえ、葵嬢、すこしあざといようだが、それを教えてくれたら、お金を渡すということにしようじゃないか。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "……四の日と七の日が〈那覇〉のボーイの昼番だから、いよいよ六月の四日にやろうということになり、〈遺産相続の通知〉なんていうあざとい手紙をほうぼうへ送りつける。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはすぐにその黒く染められた部分を越え、風雨にさらされてヒビのきれたあざとい素肌をむきだしにした白い上半部へとかかった。",
              "citation": {
                "source": "煙突",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぎらぎらした、なまなましい原色のあざとい他の女たちの印象とかけはなれて、黒いスーツの女には、ある稀薄な、退屈をわがものとした人のひそやかな落着きも感じられた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "手前から奥では遠近法を強調するようでややあざとい。",
              "citation": {
                "source": "鉄道模型の夜",
                "author": "円城塔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
