    "definitions": [
      {
        "index": 1,
        "gloss": "oh",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あれ、それはありゃあ問題だね。",
              "source": "幻辞"
            },
            {
              "text": "あの新製品ですか？ありゃあ高い。",
              "source": "幻辞"
            },
            {
              "text": "昨日の会議でしょ？ありゃあ長かった。",
              "source": "幻辞"
            },
            {
              "text": "そのプロジェクト？ありゃあ失敗するよ。",
              "source": "幻辞"
            },
            {
              "text": "あの医者？ありゃあ優秀だ。",
              "source": "幻辞"
            },
            {
              "text": "あの料理？ありゃあ美味しい。",
              "source": "幻辞"
            },
            {
              "text": "あの法律？ありゃあ難しい。",
              "source": "幻辞"
            },
            {
              "text": "あの小説？ありゃあ傑作だ。",
              "source": "幻辞"
            },
            {
              "text": "あの運動選手？ありゃあ天才だ。",
              "source": "幻辞"
            },
            {
              "text": "あの会社？ありゃあ将来性がある。",
              "source": "幻辞"
            },
            {
              "text": "あの歴史上の人物？ありゃあ偉大だ。",
              "source": "幻辞"
            },
            {
              "text": "あの技術？ありゃあ革新的だ。",
              "source": "幻辞"
            },
            {
              "text": "あの旅先？ありゃあ素晴らしい。",
              "source": "幻辞"
            },
            {
              "text": "あのテレビ番組？ありゃあ面白い。",
              "source": "幻辞"
            },
            {
              "text": "あの家？ありゃあ豪邸だ。",
              "source": "幻辞"
            },
            {
              "text": "あの交渉？ありゃあ成功した。",
              "source": "幻辞"
            },
            {
              "text": "あの研究？ありゃあ重要だ。",
              "source": "幻辞"
            },
            {
              "text": "あの伝統？ありゃあ大事にすべき。",
              "source": "幻辞"
            },
            {
              "text": "あのスポーツ大会？ありゃあ盛り上がった。",
              "source": "幻辞"
            },
            {
              "text": "あの科学者？ありゃあノーベル賞レベルだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "囲炉裏に榾をさしくべ、岩魚の串刺にしたやつを炙りながら、山林吏が、さっき捨てた土饅頭は何だね、と案内の猟師に訊ねる、旦那、ありゃ飛騨の御大名の墳で、と右の一伍一什をうろ覚えのままに話す、役人は、そんな由緒のあるものと知ったら、何とか方法もあったものをと口惜しそうな顔をした。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ腐った臓腑だけっか入ってねえんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ここらでは汽車の中ぐらゐ立派な家はまあありゃせんよ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）「おい親友、鉄カブトかぶれよ、危ねえぞ」「何言ってやんでえ　可笑しくッて鉄カブトが冠れますかッてンだ」「鉄砲の弾丸は頭ばかり当たるッて訳のもんでもあるめえ、手に当る事もありゃ足にも当らア鉄のテッ甲脚絆でもはめてきアがれ」○帽子の中へ写真を入れて置く兵隊。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎が、Ｔ「その印籠を所持致す奴こそ敵棚倉伝八郎」　聞いた三次が「よう御座います」と引受けて、Ｔ「三日もありゃきっと探し出してお見せします」　何分よろしくと三四郎が頼む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、面白くも何んともありゃしない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな顔になっちゃあ為方はありゃしない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにゆうべ夢に見たから、何事かありゃしないかというのですよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "己の処には何んにもありゃしない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「許すも許さないもありゃあしない」「薫さん、ついてお出でよ。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も関係ありゃしないんです。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしから猫が化けるということをよく云いますが、ありゃあほんとうでしょうか」「さあ、化け猫の話は昔からたくさんありますが、嘘かほんとうか、よく判りませんね」と、わたしはあいまいな返事をして置いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにね、長屋の奴らは猫婆が斃死って好い気味だぐらいに思っているんですから、誰も詮議をする者なんぞはありゃしません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「会計にだって、支配人にだって、俺の云うことなんか、ちっとも効果がありゃせんのだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々が、こうしてこの土地に工場をこしらえなかったら、奴等は、ゼニを儲ける口もありゃせんのだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僅かしかありゃしねえでがすよ、顔を知っとる奴なら、三百人もありますべえか。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「おい、おい、ここのマッチは、軸木さえありゃ、板をこすっても、石をこすっても火が出るんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "利益は何にもありゃしない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これゃ、支柱をあてがわにゃ、落盤がありゃしねえかな。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなに五体がちぎれちまって見るかげもありゃせん。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱だ何でもありゃしない！",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞くことがありゃどこでも聞かれるが、わざとここん処へ引張って来たのには、何か吾々に思う処がなければならない。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのまた白と紅との三枚｜襲で、と羞ずかしそうに坐った恰好というものは、ありゃ婦人が二度とないお晴れだな。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルクスの口髭は、ありゃ何だ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳にとっては、いなかで十日ばかりいっしょに遊んだ松吉や杉作は、なんでもありゃしないんだと。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ありゃありゃ、又三郎おれの机の上さ石かけ乗せでったぞ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ありゃ、あいづ川だぞ。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃ、又三郎の置いた葉、あすごにあるぢゃい。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともちゃん、おまえのその帯の間に、マドンナの胸の肉を少しばかり買う金がありゃしないか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
