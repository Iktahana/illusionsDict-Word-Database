    "definitions": [
      {
        "index": 1,
        "gloss": "brambling (bird) (Fringilla montifringilla)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
