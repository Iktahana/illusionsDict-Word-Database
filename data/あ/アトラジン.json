        "examples": {
          "standard": [
            {
              "text": "トウモロコシ畑の除草剤として、アトラジンは効果が高いことで知られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "河川水からアトラジンの残留物が検出されたため、水質監視が強化された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "欧州連合（EU）では、アトラジンの環境への潜在的リスクを理由に、その使用が厳しく制限されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この研究論文は、アトラジンが非標的生物、特に水生昆虫に与える長期的な影響を調査している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この畑はアトラジンでしっかり除草しておけば、後が楽だよ。」とベテラン農家は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "飲料水へのアトラジン混入を防ぐため、農地からの流出抑制策が全国的に検討されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
