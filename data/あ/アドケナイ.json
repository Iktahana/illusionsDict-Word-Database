[
  {
    "uuid": "c9ed1fbc-014b-55e3-b6a0-45e0acde8309",
    "entry": "あどけない",
    "reading": {
      "primary": "あどけない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
