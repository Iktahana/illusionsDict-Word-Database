        "examples": {
          "standard": [
            {
              "text": "あぐら鼻の特徴について医学的に調べた。",
              "source": "幻辞"
            },
            {
              "text": "彼はあぐら鼻で悩んでいた。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻を矯正する手術がある。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻は鼻翼が広がった状態だ。",
              "source": "幻辞"
            },
            {
              "text": "人類学ではあぐら鼻が遺伝的形質として研究されている。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻は特定の民族に多いと言われている。",
              "source": "幻辞"
            },
            {
              "text": "形成外科医はあぐら鼻の患者を多く見ている。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻を気にして医者に相談する人が多い。",
              "source": "幻辞"
            },
            {
              "text": "美学的にあぐら鼻をどう評価するかは議論がある。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻の子どもは大人になると受け入れるようになる。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻は呼吸機能に影響することもある。",
              "source": "幻辞"
            },
            {
              "text": "イラストであぐら鼻の人物が描かれることは少ない。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻についての偏見を減らす必要がある。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻の形成は遺伝と環境の両方に関わる。",
              "source": "幻辞"
            },
            {
              "text": "美容整形外科ではあぐら鼻の相談が増えているという。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻という言い方が適切かどうか議論されている。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻を持つ有名人も多くいる。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻についての学術的研究は限定的だ。",
              "source": "幻辞"
            },
            {
              "text": "文化によってあぐら鼻の見方が異なる。",
              "source": "幻辞"
            },
            {
              "text": "あぐら鼻を否定的に見る文化的背景がある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やがて、そのあぐら鼻の先から、一生｜摺り切れない尻尾の先に至るまで、牛どもは勝ち誇った水の虻の軍勢の下で、全身滝となって、心地よげにからだをくねらせ始めるのである。",
