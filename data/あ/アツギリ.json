        "examples": {
          "standard": [
            {
              "text": "スーパーで特売の厚切り豚肉を買ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カフェで頼んだ厚切りトーストは、外はカリカリ、中はふわふわだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このポテトチップスは厚切りなので、食べ応えがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ステーキは厚切りで、焼き加減はレアでお願いします。」と店員に伝えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "贅沢な朝食には、厚切りハムと目玉焼きが欠かせない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "職人が丁寧に手で切った厚切り刺身は、口の中でとろける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回の新商品は、素材の味を最大限に引き出すため、厚切りにこだわりました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "夜の食卓に、あの鰹が皮つきのまま厚切りの刺身となって現れた。",
              "citation": {
                "source": "鯨を釣る",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まぐろというものはむやみに厚切りするものではないという彼の信念が表われていておもしろい。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "こいつはどうかな」と中野君は洋刀を揮って厚切りの一片を中央から切断した。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "肴には厚切りのビフテキが出たことは言ふまでもない。",
              "citation": {
                "source": "山形屋の青春",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間にお辰は茶を入れて、厚切りの羊羹とこぼれるばかりの愛嬌とを一緒に持って来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二枚の小判",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
