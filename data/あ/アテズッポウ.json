    "definitions": [
      {
        "index": 1,
        "gloss": "(random) guess",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "試験で全く分からなかったので、当てずっぽうで答えを書いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の予想はいつも当てずっぽうだが、なぜか当たることも多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今の発言は当てずっぽうに過ぎない。根拠を示してほしい」と厳しく指摘された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "宝くじの数字を当てずっぽうで選んでみたが、やはりかすりもしなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初対面の人に対して、当てずっぽうで年齢を尋ねるのは失礼にあたる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "正確なデータがないため、この予測は当てずっぽうな要素が大きい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「どこに隠したの？」「当てずっぽうで探してみて」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "早すぎて当てずっぽうにも思えるが、その実いつも論拠があり、結果、持ち込まれた問題を解き明かしてしまう。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる闇夜の礫で、もちろん確かな的は見えないのであるが、当てずっぽうに投げ付ける小石がぱらぱらと飛んで、怪しい声の主をおびやかしたらしく、屋根の上を逃げて行くらしい足音がきこえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そうこうしている間に、原書の辞書の方もいい加減分るようになり、子供雑誌も当てずっぽうに判読するようになった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は何を考えるということもなく、何の希望もなく、只もう当てずっぽうに歩いているのであった。",
              "citation": {
                "source": "小さきもの",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動写真たあまるっきり違うんだからな」　窓側の一番前にいるさい槌頭の阿部が、その時がたがた立ちあがり、当てずっぽうに杉本を呼ぶのであった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "生き死にがどうやら分るだけであとは石を当てずっぽうにベタベタ並べていて、それでどこが面白いのかヨソ目には見当もつかないが、当人は面白くてたまらぬという。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジノーヴィー・ボリースィチの姿を、どこそこで見かけた、いやどこそこで見かけたなどと、当てずっぽうを言いだす者も出てきたが、それでもやっぱり戻ってはこず、第一どうしたって戻ってこられるはずのないことを、誰よりもよく知りぬいているのは、当のカテリーナ・リヴォーヴナに違いなかった。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てずっぽうに行って見よう。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てずっぽうにいって、十年程度の年月はかかるであろう。",
              "citation": {
                "source": "動力革命と日本の科学者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "半当てずっぽうにしょっぴいて来て「さあ、申し上げろ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、この犯人は、十中八九まで、新聞記者だろうと思う、――君は変な顔をするが――決して私は当てずっぽうを言ってるのでは無い――」　花房一郎の顔には、何んとなく自信が充ち満ちて、一句、一句、千種十次郎を説き伏せるように迫って来ます。",
              "citation": {
                "source": "女記者の役割",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この専門化はその昔の無教育で単に当てずっぽう経験主義の「肺医者」や「熱医者」と混同すべきではない。",
              "citation": {
                "source": "簡約医学史",
                "author": "A Concise History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は彼の細君のことも知っています」と、Ｋは少し当てずっぽうにいってみた。",
              "citation": {
                "source": "城",
                "author": "DAS SCHLOSS",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに寸法を取らずに、当てずっぽうで買って来たんだから、ぼく今夜一晩じゅう寝られないじゃないか。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てずっぽうではなかった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「当てずっぽうに言って、たとえば十年」「あり得なくはない」「いなくなったとき二十五歳だから、十五歳くらいの頃から始めたとか」　日比谷はフロアから立ち上がった。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのときでございます」「実際イズミは死んでいないな」　多少当てずっぽうだった。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            },
            {
              "text": "」あてずっぽうでも無かった。",
              "citation": {
                "source": "佐渡",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お使いにいって、買うものを忘れてしまい、あてずっぽうに買って帰って、まるでラジオで聞く落語みたいだとわらわれたこともあった。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の経験もせぬ生活感情を、あてずっぽうで、まことしやかに書くほど、それほど私は不遜な人間ではない。",
              "citation": {
                "source": "鴎",
                "author": "――ひそひそ聞える。なんだか聞える。",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてずっぽうにめいめい勝手なことは言ったが、真相を明らかにすることは誰にも出来ない。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "占のようなもんだと謂いたいが、占だって占者に謂わせればドウして仲々大そうな根拠があるのだから、此の答案は先ず、占よりも以上に、あてずっぽうの方である。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸通りの方の骨董店とちがいますか」牛丸は春木から聞いたチャンフー号の店の話を思い出して、あてずっぽうながら、いってみた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼が聞けば笑いそうな想像、あてずっぽうを云って居るかもしれない。",
              "citation": {
                "source": "追憶",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減な感じや、あてずっぽうでは却て構成上の自由が得られないのである。",
              "citation": {
                "source": "蝉の美と造型",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるっきり知らない大阪へやって来て、最初あてずっぽうにはいった店が此処であり、珈琲は大して美味しいとは思わなかったが、店の人が商売人くさくないことと、川を眺めるたのしみとで、彼女は度々やって来ていた。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "同業者や批評家はいまだに孤高の文学、異色の文学、きまり文句でお座なりの五、六行文芸時評の片すみへこれも稼ぎのためだからと筆まめにいい加減あてずっぽうに書いてくれるのが時々いたりするけれども、もう女房だけは騙すことができない。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四には、また同じことを繰り返すようなれど、教養なき自己流の出鱈目、あてずっぽうの作陶は所詮ものにならぬことを力説したい。",
              "citation": {
                "source": "窯を築いて知り得たこと",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず、それについても、料理というものの概念がないと、とにかくあてずっぽうで、でたらめの仕事に陥りますし、しかも、楽しんで食べるということにもなりませんから、根本的概念を作りましょう。",
              "citation": {
                "source": "衰えてきた日本料理は救わねばならぬ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、十郎兵衛の半あてずっぽうが的中したのである。",
              "citation": {
                "source": "寛永相合傘",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
