    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the way (something) ought to be",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "組織のあり方を見直す必要がある。",
              "source": "幻辞"
            },
            {
              "text": "人生のあり方について考えた。",
              "source": "幻辞"
            },
            {
              "text": "仕事のあり方は時代で変わる。",
              "source": "幻辞"
            },
            {
              "text": "社会のあり方を問い直すべき時だ。",
              "source": "幻辞"
            },
            {
              "text": "あり方によって人生が変わる。",
              "source": "幻辞"
            },
            {
              "text": "教育のあり方について議論がある。",
              "source": "幻辞"
            },
            {
              "text": "経営のあり方が問われている。",
              "source": "幻辞"
            },
            {
              "text": "家族のあり方は多様化している。",
              "source": "幻辞"
            },
            {
              "text": "技術のあり方は社会に影響を与える。",
              "source": "幻辞"
            },
            {
              "text": "政治のあり方を改善すべき。",
              "source": "幻辞"
            },
            {
              "text": "人間関係のあり方が課題だ。",
              "source": "幻辞"
            },
            {
              "text": "文化のあり方を継承する責任がある。",
              "source": "幻辞"
            },
            {
              "text": "司法のあり方について論争がある。",
              "source": "幻辞"
            },
            {
              "text": "医療のあり方が問題になっている。",
              "source": "幻辞"
            },
            {
              "text": "報道のあり方に批判の声がある。",
              "source": "幻辞"
            },
            {
              "text": "労働のあり方を変えるべき時代だ。",
              "source": "幻辞"
            },
            {
              "text": "環境問題のあり方は急務である。",
              "source": "幻辞"
            },
            {
              "text": "福祉のあり方を充実させたい。",
              "source": "幻辞"
            },
            {
              "text": "あり方の多様性を認める必要がある。",
              "source": "幻辞"
            },
            {
              "text": "これからのあり方を一緒に考えよう。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "同じ理由から俳句を研究することは日本人を研究することであり、俳句を修業することは日本人らしい日本人になるために、必要でないまでも最も有効な教程であり方法である。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一切の文芸は、他の一切のものと同じく、我等にとつては或意味に於て自己及び自己の生活の手段であり方法である。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっさいの文芸は、他のいっさいのものと同じく、我らにとってはある意味において自己および自己の生活の手段であり方法である。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、不圖頁をくつた或る本の中に、自分の精神のあり方を此の上なく適切に説明してくれる表現を見つけた。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で自分のあり方を客觀的に見ようなどといふ・自然に悖つた不遜な眞似は止めろ。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "パワーブックで読むという想定で、電子本の基本的なあり方を決めて行くにあたって、彼らは先ず、これまでの紙の本の体裁を徹底的に真似ることを目標に置きました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "心のあり方に影響を与えるような薬を飲むことに、以前勧められたときは抵抗を感じました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日までのスタイルにしがみついていないで、新しいあり方を探せよと。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知的財産戦略の推進」を国策としている我が国は、著作権保護のあり方について国際間の調和を図るべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「知的財産戦略の推進」を国策とし、コンテンツビジネスの積極的な海外展開を進めようとしている我が国は、保護期間をはじめとする著作権保護のあり方について、国際間の調和を図るよう努力すべきである。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "部屋のあり方はいろいろあるものだと、慶一は呆れている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうじゃなく、社会制度が本当に変ったときには、生活のやり方が変って、私ども人間も心の組み立て、その表現、あり方が変って来るからこそ、よい社会の制度の上では私どもの幸福がまして来るのです。",
              "citation": {
                "source": "社会と人間の成長",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日私たちはこういう文化のあり方と、文化というものについての理解に対して大きい疑問をいだきはじめた。",
              "citation": {
                "source": "明瞭で誠実な情熱",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日本人は世界における日本のあり方について現実的な認識をもたなければならない。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会主義的民主主義の社会では、文化の仕事に従う者が、知能的労働者として非常に多くの社会的保証を受けていることは、やはり今私たちのまわりにある文化よりは、文化の正しいあり方だと思います。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "インターネットの上で生きて、インターネットの上で読まれる、新しい〈本〉のあり方を突き詰めれば、ブックはネットワークに接続したサーバーに置くのが本当だろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした働き方、労働のあり方が、タケシには不思議だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの本質をあらためて〈万能の物まね機械〉と定義しなおせば、電子計算機というこれまでのあり方は、単に計算機をなぞってみせた物まねの一つのパターンだったとも考えられる。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの誕生はこうした同社のあり方を流動化させる可能性を持っていたが、ＩＢＭは市場の独占を通じて培ってきた体力に物を言わせて、作表機をコンピューターに置き換える作業を見事に成し遂げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人ひとりが自立し、自我を核として振る舞う家族のあり方も、西にとっては教育的だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくの増設スロットをこのために一つつぶしてしまう点でも、そもそも新一六ビットのあり方を決める基本ソフトを増設ボードに置くという不自然さにおいても、こうした選択は望ましくなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本自身は政治集会やデモに直接参加することはなかったが、友人たちとの話題にはベトナムや成田や、何よりだめな日本のあり方が紛れ込んできた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした試みによって、極端なハードとソフトの分業化を超えて、より健全なコンピューターとユーザーとのあり方が実現できるのではないか」　そう考えた安田は、一年の予定でモトローラの６８００を使ったシステムの自作にいたるスケジュールを組んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "当面はこのままエレクトロニクス分野の仕事を中心とし、いずれは科学と社会のあり方にテーマを広げていく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タクシーの中でもバーのカウンターについてからも、「パーソナルコンピューターは対話性のあるメディアとして育ち、社会のあり方を決定的に変化させてしまうだろう」と、西は語り続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが中には高額の入会費をぶんどったうえに、会員がただで提供したプログラムに値段をつけようとするようなメーカー主導のグループも存在し、こうしたあり方をＣＣＣはよしとしなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アップル※でもＣＰ／Ｍが利用できるようマイクロソフトが開発したソフトカードのあり方は、この時点でのＯＳの可能性と限界を雄弁に物語っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけはなたれた窓から、死んだ女が、人間のありかたをといていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、現代のような時代を生きる人々の心には、自分たちの生きて来た日々、生きている刻々、生きるであろう明日について、ひっくるめてこの人生のあるありかたについて、生き、そして死ぬということについて、つくづくと眺め、わかり直し、再び感じ、自分自身に納得してみたい心持があるのだと思う。",
              "citation": {
                "source": "人生の共感",
                "author": "――求められる文学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "利害相剋の緩和者として出現している梶井のありかたも、いいが、気になる何かが在るところも面白いと思う。",
              "citation": {
                "source": "徳永直の「はたらく人々」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
