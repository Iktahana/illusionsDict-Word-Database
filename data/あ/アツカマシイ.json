[
  {
    "uuid": "5664a387-53da-58ac-ae0d-1b02a4bccb91",
    "entry": "厚かましい",
    "reading": {
      "primary": "あつかましい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
