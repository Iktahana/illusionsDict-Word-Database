    "definitions": [
      {
        "index": 1,
        "gloss": "pushing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "坂道で重い荷車を後ろから後押しする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "政府の新たな補助金制度が、中小企業のデジタル化を強く後押ししている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "圧倒的な世論の後押しを受けて、関連法案は全会一致で可決された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "恩師の温かい言葉が後押しとなり、起業という大きな一歩を踏み出すことができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "記録的な円安傾向が、輸出関連企業の業績回復を後押しする最大の要因となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "この混合した粉を硝子板の表面に一様に篩いかけて後押し付けると三色の粉を不同なく板の上に密布し、顕微鏡で見れば全体がモザイックのようになっている。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ったら頭の閊える箱の中に数人の客をのせたのを二、三人の人間が後押しして曲折の多い山坂を登る。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが今度は悪の力でそれが後押しされるのだ。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ人間が悪の力で後押しされる恋の情熱の嚮う途は大概極まって居る。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初は吾々も我慢して乗っていたが、いよいよ歩みの遅々たるに業を煮やし、ソレッとばかり飛び下りて、四人がワッショイワッショイ馬車の後押し、前後左右へガッタンガッタンするのを、一向お構いなく一生懸命になって馬車の後押しをした。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "お客が馬車の後押しをするなんてことは恐らくどこにもあるまい。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "後れたる人力車は次の建場にてまた一人を増して、後押しを加えたれども、なおいまだ逮ばざるより、車夫らはますます発憤して、悶ゆる折から松並み木の中ほどにて、前面より空車を挽き来たる二人の車夫に出会いぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、下町から重い荷車を挽いて来た者は、ここから後押しを頼むことになる。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ちン坊はその後押しを目あてに稼ぎに出ているのであるが、距離の遠近によって二銭三銭、あるいは四銭五銭、それを一日に数回も往復するので、その当時の彼らとしては優に生活が出来たらしい。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新助は仲仕を働き、丹造もまた物心つくといきなり父の挽く荷車の後押しをさせられたが、新助はある時何思ったか、丹造に、祖先の満右衛門のことを語ってきかせた。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "芹沢亡き後の新撰組は、当然近藤、土方の天下で、幕府の後押しもあり、京都守護職、松平｜容保の信頼もあり、隊の勢は日ならずして隆々として揚り、京洛に劃策する勤皇の志士にとつて、陰然たる一大敵国を成すに到つた。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "後押ししてくれたのは、旺文社の椛田敏彦さんだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂の上で振り返つて見たら芋俵を馬に積んで來た兼次の親爺が持つて居た手綱を放して後押してくれたのである。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともそのような種々の念が、張る気の随伴者となり後押しや前引きをしている光景がある。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "後押しの奴も御目鑑通り早乙女主水之介でござりまするぞ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドン底に近付いてはトロの後押し、土方の手伝い、ヨイトマケ、紙屑｜撰り、工女、掃除女に到るまで、数えて来ると随分ある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、若し、街頭で子を背負い乍ら車の後押しをしている人間の女を見るならば、彼は眉をひそめて、態と眼を閉じて了う。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二十一回　時計の音盆　お浦は全く秀子に対し戦争の仕直しに遣って来たのに違い無い、前の戦争は秀子を虎の顋に推し附け充分の勝利と云う間際で失敗した、今度は高輪田長三と云う恐る可き後押しを連れて居る、万に一つも失敗せぬ積りで有ろう。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は一昨日も荷車の後押しをして坂を上る時息が苦しくて後で嘔吐を催しました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "巨大化した組織が往々にして官僚的な手続きを煩雑化させ、迅速な処理の足を引っ張ることを自覚していたＩＢＭは、社員の自発的な試みを後押しする受け皿となることを目指して、独立事業単位という制度を用意していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加えて浜田は、三つの柱からなる特別チームを別個に組織し、開発計画を後押しするとともに、可能な限りの準備を進めておこうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして第六に、増設ボードを簡単に組み込めるように拡張スロットを用意し、仕様を公開してサードパーティーによる開発を後押しすること。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サードパーティーの開発を積極的に後押しし、個人ユーザーを狙ったＰＣ―９８０１に対し、オフィスコンピューターを引きずったマルチ16は、従来型の文化の枠組みの中で望みうる成長しか達成できなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その弱い力のありったけをふり搾って後押しをやった。",
              "citation": {
                "source": "乞食",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おれが後押しをやるから、お前は馬の頸を左の方へ向けて、鞭で脚をうんと引ぱたいてくれ。",
              "citation": {
                "source": "乞食",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、村人どもが高を括つて竊に舌を吐いてゐる最中に、僅か昨日立つて京都へ行つたばかりの太政官は、もう今日の夕方、紫縮緬の大きな袱紗に包んだ貴い揮毫を捧げつゝ、大きな赭顏に、はち切れさうな微笑を湛へて、網曳後押し付きの人車で歸つて來た。",
              "citation": {
                "source": "太政官",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕もあとおしを手伝はう――」「さうさう、昆虫の本だけはとつておきたいんだが。",
              "citation": {
                "source": "裸虫抄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この牧師はきわめて学識があり、礼儀正しい人物で、ほんとうに上品なキリスト教徒で、つねに老紳士の意見をあとおしし、彼のかるい罪はわざと見のがしてやり、子供たちが言うことをきかないときには叱りつける。",
              "citation": {
                "source": "ジョン・ブル",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わたしがあとおしをしますよ」　顎十郎は、腕を組んでなにか考えこんだまま返事もしない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "都鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "イスラエル・ヤングやロバート・シェルトンのあとおしで、ディランは、ゲルデス・フォーク・シティで、オーディション的にうたった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "pushing from behind (a cart, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "政府の新たな経済政策が、スタートアップ企業の成長を強力に後押しするだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長年の研究が実を結び、画期的な発見がプロジェクト成功の大きな後押しとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もう少しだ、頑張れ！」と、仲間からの温かい声が登山者の後押しとなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ベテランの職人が、若手の技術習得を実践的に後押ししている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "重い機材を搬入する際、数人がかりでトラックの荷台から後押しして降ろした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "消費者の環境意識の高まりが、エコ製品市場の拡大を後押ししている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の実績が周囲からの信頼を勝ち取り、最終的に市長選挙への立候補を後押しした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
