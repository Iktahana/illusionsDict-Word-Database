[
  {
    "uuid": "3c43a256-aeff-5f9c-a074-a1bd8b11f68b",
    "entry": "後を慕って",
    "reading": {
      "primary": "あとをしたって",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
