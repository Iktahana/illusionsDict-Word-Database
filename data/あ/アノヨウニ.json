        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あの様に」流暢に外国語を話せるようになるには、相当な努力が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は弟子に、「あの様に」筆を運びなさいと細かく指導した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏の夜空に「あの様に」無数の星が瞬くのを見ると、宇宙の広大さを感じる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は「あの様に」細部までこだわった料理を、いつも手際よく作り上げる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な状況でも、「あの様に」冷静に対処できるのが彼の強みだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府が「あの様に」唐突な政策変更を行うのは、国民の信頼を失う原因となる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "幼い子供が「あの様に」大人たちの言葉遣いを真似て覚えるのは微笑ましい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "王、あれア石垣の、やつらがくやしがつてあの様ににらめて居るので御座らう」ヒヨウキン者の郭光は妙な口調でこういつた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分もあの様にして這いさがろ思てよく見ると、うわさに聴いた支那犬やないか？",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの酔漢を眼にして何時か遊女に対しても端然たる態度を保つやうになつてゐた僕であるが、都のあの様な配光の和やかな室に於てゞあるならば、自分もあの様に美しい酌女の肩や手に大らかに触れても見たい――などゝ思つたりした。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "珍しい写絵を持つてゐない連中があの様に浜田を騒ぎ立てるのは当然のことだと思つた。",
              "citation": {
                "source": "蘭丸の絵",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸ひ貴方が話したい事が有ると言るる、善し、あの様に間を詐つた貴方じや、又僕を幾何ほど詐ることぢやらう、それを聞いた上で、今日こそは打※してくれやうと待つてをつた。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際では、まつたくだらしのない飲酒家になり、あの様に見苦しい醜態を日々演じてゐるのだ、たゞ何れの点から見ても所謂酒客の性がないばかりであつた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この章の冒頭に設計書の写しだけをその儘書き誌すつもりだつたが、今もつて如何程思案しても頭部の構造と眼口の配置が出来ない、代りに思ひ出の凧に就いてのみあの様に散漫に書き誌すより他はなくなつてゐるのだ。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはしかし、千石船か何かで、野郎の船頭を詠んだので御座いましょうが、川船の女船頭が、梶座に腰を掛けているのに、後から風が吹いて、アレあの様に乱れ毛が頬に掛るところは、なんとも云えませんな。",
              "citation": {
                "source": "悪因縁の怨",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あの様に重い沈んだ音を出す時計と云うのが、寺には一つもないのだからね」　然し、法水のどんより充血した眼を見ると、夜を徹した思索が如何に凄烈を極めていたか――想像されるのだが、そうして熊城の話を聴き終ると、その眼が俄かに爛々たる光を帯びて来た。",
              "citation": {
                "source": "後光殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、ガラス窓越しに中庭の向うから放たれたのだとすると、見た通りガラス盤の後方は、二人の死蝋が着ている、朱丹と緑青色の布とで塞がっているのですから、あの様に真白に見える、気遣いはないのです。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "前には三人の女、僕の隣にはドリルが「今にムネ・シユリイの此食卓もあの様に飾られるのだ」と云ふ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "…………晃兄さんも習字があの様に善く出来て、漠文の御本も善く読める癖に、何故真面目に成つて夷人さんの語が習へないのかなあ。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌舞妓が最初から、あの様に我々の鑑賞に堪へる内容を持つてゐたり、又本芸となるだけの目的あるちやんとした狂言を持つて居たものと言ふことになるのである。",
              "citation": {
                "source": "芸能民習",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "話では太公望の妻が貧しきを厭うて夫を棄てた後、もとの夫があの様に斉の君となつたので、再び妻たらん事を請うた。",
              "citation": {
                "source": "石を積む",
                "author": "別所梅之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お節は、疑がとけないであの様にするのだろうと思っていろいろ達のために云い解きをしたけれ共、「そな事、よう分っとる、　云わんとええ。",
              "citation": {
                "source": "栄蔵の死",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は――何時もあのやうに静な、あのやうに清浄な、あの様に温和しい――お前が野獣のやうに部屋の中で怒り狂つてゐるではないか。",
              "citation": {
                "source": "クラリモンド",
                "author": "LA MORTE AMOUREUSE",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何故あの子があの様に突き飛ばしたの？",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し父が僕をあの様に打つとは？",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは当局の措致に不満足なところがあるに由って、あの様に数次の革命を重ねねばならなかったが、革命思想――革命思想の起る源は何としても日本の勃興に在る。",
              "citation": {
                "source": "日支親善策如何",
                "author": "――我輩の日支親善論",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜドーブレクがあの様に厳重に監視されておるか、一ツ大いに取調べる必要があるぞ』　ルパンが、早速秘密探偵局について取調べさせた処によると、「アレキシス・ドーブレク。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の今まであの様に泣入っていた給仕女が、いきなり快活に立上ったかと思うと、もうもう耐らないという様に、身体をくの字にして、これも亦笑いこけるのだった。",
              "citation": {
                "source": "赤い部屋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "見す見す追いつかれると分っているものを、何ぜあの様に逃出したのであろう。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ぜといって、瑠璃子が若し、元の様に子爵家の実権を握っていたなら、仮令わしがどれ程の資産を以て誘惑したところで、あの様にたやすくなびかなんだであろうから。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故貴方が来られなかったのかを、貴方が父にあの様にお話された後で。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなくて、若し春泥が犯人であったとすれば、あの様にも綿密に、執拗に、長年月を費して企らまれた復讐計画が、彼にしては道草の様なものであった六郎氏殺害のみを以て、肝腎の目的を忘れた様に、パッタリと中絶されたことを、何と説明したらいいのでしょう。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、たよりと思う私から、あの様に疑い責められ、全く云い解くすべがないと知ると、心の狭い女の身では、一時の激動から、つい世を果敢なむ気になったのではあるまいか。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "数時間｜前、不義の外出から帰って、玄関にさしかかった時、あの様に胸騒がせた彼女とは（その時も已に十分悪女であったに相違ないのだが）我ながら別人の観があった。",
              "citation": {
                "source": "お勢登場",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "山を石膏細工の人形とすれば、雲は衣裳で、あのようにまで、モデルの肢節にぴったり合って、屈伸するものとは思っていなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてあのように角ができるか、どうして角の数が統計的に一定になるか、この疑問を年来いだいて今日に至る間に、おりにふれてはこれによく似たいろいろの問題が次第に蓄積して来た。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コーヒーに限らず、デパートの商品でも、あのようにたくさんにあるものの中で自分の趣好に適合するものの少ないのに困ることがしばしばある。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
