        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会社からの宛い扶持だけに甘んじることなく、自ら新しい販路を模索すべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日からここが君の宛いだ」と、上司に窓際の手狭なデスクを指し示された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今年度の予算の宛いが想定を下回り、研究計画の大幅な見直しを余儀なくされた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "単に上から降ってくる宛い仕事をこなすだけでは、プロとしての成長は望めない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今回の宛いは随分と気前が良いな」と、男は分配された報酬の多さに目を丸くした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "現場への資材の宛いに滞りが生じたことで、工事の工程に大きな遅延が発生した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その時先生はガラス窓に近づいて襖の方を枕にして寢て居られたが、上體を少し擡げて左の肘で支へ宛いま自分が出した名刺を蒲團の上へ置いて下を向いた儘じつと見詰めて居らるゝ所であつた。",
              "citation": {
                "source": "竹の里人〔二〕",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "めじが十尾ばかりと、あとは鯛やひらめなどが二、三尾宛いて、外に雑魚が一籠ばかり雑っていた。",
              "citation": {
                "source": "大謀網",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "表へ行き、五月下旬には、ヴァラエティー寄席ごっことして、五分宛いろ／＼な芸をやることを提議したら大賛成。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうする詮も知らずに着物をあたためてはあてがい、あたためてはあてがってるのみ、家じゅう皆立って手にすることがなくうろうろしてる。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "京一は、桃桶を袋の口にあてがいはずして、諸味を土の上にこぼしたのである。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝っぱらから呑み続けている赤い顔で、でっぷり肥り、坐蒲団を折って尻の下にあてがい、胡坐をかいていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "陸は急いで、朱の持っている美人の頭を取って切口にきちんと合わせ、そして後ろにしっかりと押しつけたが、これがすむと枕を肩にあてがい、朱に言いつけて細君の頭を静かな所に埋めさせて帰って往った。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "梓は丸腰の着流し、あたかもお館の法度を犯して裏庭から御台のお情で落ちて行くように、腕車で歌枕に送られたが、後を知らず、顔色も悪く未明に起きると、帯を取って、小取廻に尖を渡して、本式に畳んで置いた袴の腰板を取ってあてがい、着たまま枕頭に坐って介抱していた蝶吉が件の羽織を惜そうに脱いで被せた。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "正井に秘密な金を融通するためには倉地からのあてがいだけではとても足りなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はぜいたくな寝台の上に横になって、羽根｜枕に深々と頭を沈めて、氷嚢を額にあてがいながら、かんかんと赤土にさしている真夏の日の光を、広々と取った窓を通してながめやった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから瓦斯のホースをあてがい、水素｜瓦斯の補充を始めます。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "――銃口を左の肩にあてがい、狙いを定めて、静かに肩を左に廻してゆく。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間らしい生活に対する翹望というものは職場、職分の相違、したがって細かい気持の部分部分では全く同一でないにしろ、働いて、税を出して、あてがいぶちの賃銀を払われて暮している者すべての人々を貫いて流れる一線である。",
              "citation": {
                "source": "今日の文学に求められているヒューマニズム",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村先生はベッドの裾の方から廻って窮屈な形に肱をつき、自分で物尺を持ってあてがいながら、ずーっとこの辺入るかね？",
              "citation": {
                "source": "寒の梅",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、配給とりも直さず万事あてがい扶持で、唯々諾々と生きる無気力の習性となるなら、それは堕落と云われなければならない。",
              "citation": {
                "source": "今日の生活と文化の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年一日のような、見とおしのない、あてがい仕事を苦しく思っている。",
              "citation": {
                "source": "いのちの使われかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　千鶴子は足袋の筋目にパラソルの先をあてがい、前に蹲み込む姿勢で横の矢代の表情を窺うように云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　千鶴子はパラソルの柄を頬にあてがい、愁い気に矢代を盗み見て云った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時頃かえり、とりにぬいものをあてがい、その他種々のことをきめて床につく。",
              "citation": {
                "source": "日記",
                "author": "一九二一年（大正十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、研ぎ上った剃刀を頭へあてがい切れ味を試した。",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は赤子を受けとるとすぐ自分の懐ろに入れて、皺んだ袋のような乳房をあてがいながら、「何んと、手この冷えていること！",
              "citation": {
                "source": "凍雲",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてがいつぱい飮む、あんたがいつぱい飮む、あてが飮む、あんたが飮む。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてがい扶持の低い家禄のものとして、余裕のないその日その日は、気の持ちようまでもぎすぎすさせ一図にさせたのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな所へ寮を建てて、そこへ奥様を住まわせて、あてがい扶持をくれて飼って置かれる。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供等には寿司をあてがい、彼は酒を飲んだ。",
              "citation": {
                "source": "子をつれて",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あてがいました人形を相手に、ままごとをいたしておりまする。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてがいぶちの食事をぼそぼそ食べ、そこにごろりと寝ころんで、暮れかかった空を眺めていると、へんに佗びしい気持ちになった。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "座布団を二つに折って枕とし、仰向きに寝そべって、褞袍を胸元までかけ、左手の肱に書物をあてがい、手先が洗面器に浸るようにした。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛子は突然笑いだして、腕を引っこめ、両手を腰にあてがい、時彦と同じような姿勢を取る。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "随分長い間、今小学校の校長の居る処に住んで居て、畑や米の世話をして居たが、気の勝った年寄の召使と主人とは、しばしば衝突が起って、しばらく東京の家の方へ来て居た事もあったけれ共、今は、隣村とこの村の境のどっちともつかない様な処へ息子からの「あてがいぶち」で暮して居る。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
