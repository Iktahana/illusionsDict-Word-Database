        "examples": {
          "standard": [
            {
              "text": "私は毎日あんすについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんすという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんすの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんすが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんすを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんすについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんすの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんすの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんすが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんすという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんすという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんすについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんすを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんすは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんすについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんすが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんすは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんすの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんすは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんすは興味深い例である。",
              "source": "幻辞"
            }
