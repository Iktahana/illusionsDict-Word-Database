        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんすよ、そういったことは時々あるんです。",
              "source": "幻辞"
            },
            {
              "text": "あんす、明日も来てくださいね。",
              "source": "幻辞"
            },
            {
              "text": "あんすが、私は別の意見があります。",
              "source": "幻辞"
            },
            {
              "text": "あんす、お待たせしてすみません。",
              "source": "幻辞"
            },
            {
              "text": "あんすね、状況は複雑です。",
              "source": "幻辞"
            },
            {
              "text": "あんすか、ご不便をおかけします。",
              "source": "幻辞"
            },
            {
              "text": "あんすけど、予定は変わる可能性があります。",
              "source": "幻辞"
            },
            {
              "text": "あんす、今のところ分かりません。",
              "source": "幻辞"
            },
            {
              "text": "あんすな、事態は深刻です。",
              "source": "幻辞"
            },
            {
              "text": "あんす、多くの人がそう思っています。",
              "source": "幻辞"
            },
            {
              "text": "あんすから、注意が必要です。",
              "source": "幻辞"
            },
            {
              "text": "あんすや、理由は複数あります。",
              "source": "幻辞"
            },
            {
              "text": "あんすと、見方によっては異なります。",
              "source": "幻辞"
            },
            {
              "text": "あんすの、準備を整えましょう。",
              "source": "幻辞"
            },
            {
              "text": "あんすは、進め方を相談したいです。",
              "source": "幻辞"
            },
            {
              "text": "あんすで、協力をお願いします。",
              "source": "幻辞"
            },
            {
              "text": "あんすな、成功には時間がかかります。",
              "source": "幻辞"
            },
            {
              "text": "あんす、改善策を検討中です。",
              "source": "幻辞"
            },
            {
              "text": "あんすから、再度確認しましょう。",
              "source": "幻辞"
            },
            {
              "text": "あんす、今後の対応を考えています。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "お蔭でまめしくて居りあんす。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お内のお母さんだぢと始終ご一緒して居りあんす。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おりゃの米子どもいっつもお話し申してあんす。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖ぐなったらど思ってゐあんすたどもやっぱりその通りで善ぐもならなぃで。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「まぁんつたびだび米子どもお話してあんすすか。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "割合｜肥沃な：入力者注　主に外字の説明や、傍点の位置の指定（例）河童取りあんすた。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なじょして蔵して置ぐあんす。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「はあ、私もそうだと思ってあんすた。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民一「五畝歩でごあんす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "まんつお有難うごあんすな。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがらもどうがよろしぐお願いいだしあんす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民二「そうでごあんす、そうでごあんす、丁度それ位蒔ぎあんすた。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民二「はあ、そうでごあんす、そうでごあんす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民二「はあ、おりあんす、おりあんす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（金を出す）さあ、どうもおありがどごあんすた。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "おありがどごあんす。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」（金を出す）農民三「どうもおありがどごあんすた。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」農民四、五「どうもおありがどごあんすた。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもおありがどごあんすた。",
              "citation": {
                "source": "植物医師",
                "author": "郷土喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わし行つて來あんすから、此等こと見てゝおくんなせえ」おつぎと與吉とを南の女房へ頼んだ。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしも行つて見あんせう、自分の畑のがは一目見りや分りあんすから」恁ういつて被害者は蜀黍の穗を二三｜本持つて村落へ戻つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者は先刻から雨垂の水で土の窪んだあたりを見て居たが「はてな」と首を傾けて「蜀黍粒落つてあんすぞ、さうすつと此處へ引つ懸けたの又何處へか持つてつちやつたな」被害者はいつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう解つたから、それぢや自分の仕事をするがいい、後にわしが申報書を拵へて來て遣るから、それへ印形を捺せばそれで手續は濟むんだからな」巡査はさういつてさうして被害者が「そんぢや、わし蜀黍隱して置く處見出あんすから、屹度有んに極つてんだから」といふ聲を後にして畑の小徑をうねりつゝ行つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生さん、わしやまあだ來なくつちやなりあんすめえか」勘次は懸念らしい目を以て聞いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お内儀さん、こうちつとでもよくねえ錢へえつちや末始終はどうしてもえゝこたありあんすめえね」勘次は更にまた酷く懸念らしい容子をして突然に聞いた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんだがお内儀さんさうえ錢は自分のげ役に立てせえしなけりやどうしても違えあんすべえね」勘次は内儀さんに分つても分らなくても、そんなことを考へる餘裕がなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
