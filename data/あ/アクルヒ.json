    "definitions": [
      {
        "index": 1,
        "gloss": "next day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "翌日、結果が分かった。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、雨が降った。",
              "source": "幻辞"
            },
            {
              "text": "事故のあくる日、新聞が大きく報じた。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、仕事に戻った。",
              "source": "幻辞"
            },
            {
              "text": "その日のあくる日、彼から連絡があった。",
              "source": "幻辞"
            },
            {
              "text": "試験のあくる日、成績が発表された。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、天気が回復した。",
              "source": "幻辞"
            },
            {
              "text": "病院のあくる日、医師の診察を受けた。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、元気な姿で職場に戻った。",
              "source": "幻辞"
            },
            {
              "text": "約束のあくる日、二人は公園で会った。",
              "source": "幻辞"
            },
            {
              "text": "あくる日の朝、起きてすぐに出発した。",
              "source": "幻辞"
            },
            {
              "text": "結婚式のあくる日、新婚夫婦は旅立った。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、その話題は新聞の一面を飾った。",
              "source": "幻辞"
            },
            {
              "text": "誕生日のあくる日、彼女がケーキを焼いてくれた。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、友人たちが訪ねてきた。",
              "source": "幻辞"
            },
            {
              "text": "解散のあくる日、メンバーが再び集まった。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、警察の調査が始まった。",
              "source": "幻辞"
            },
            {
              "text": "発表のあくる日、反応は上々だった。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、誰もがその結果に驚いた。",
              "source": "幻辞"
            },
            {
              "text": "あくる日、新しい章が開かれた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あくる日｜銭を貰うて先ず学校へ行ったが、教場でも時々絵の事に心を奪われ、先生に何か聞かれても何を聞かれたか分らぬような事もあった。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日下女が薬取りから帰ると急に暇をくれと言い出した。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は翁は一日歩いて、また一二尺掠り除かれた雲の裾から山の麓を、より確かに覗き取ったが、歩めども歩めども山の麓の幅の尽きらしい目度を計ることができなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあくる日の朝日がたけて、その部屋のまわりの桜樹立が明るくあたりにかがやくころ目をさました。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あくる日行くと、また、兎は二人が雪を踏む靴音に驚いて、長い耳を垂れ、草叢からとび出て来た。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまきの死骸を収めた早桶は長屋の人達に送られて、あくる日の夕方に麻布の小さな寺に葬られた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたはおれが直接に出張って行くから案内してくれ」　あくる日も秋らしい陰気な雨がしょぼしょぼ降っていたが、熊蔵は約束通りに迎いに来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日の朝、七之助の死骸が芝浦に浮いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は大勢の人足をあつめて、その古池の掻掘をはじめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "用人の五左衞門も心配して、あくる日は市ヶ谷で有名な賣卜者をたづねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日小幡をたづねて、主人の伊織に逢つた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は十五夜で、晴れた空には秋風が高く吹いていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、あくる日も不機嫌なのだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日も、中山服は、やはり、その家の中にいた。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の友人と、佐吉さんと、私と五人、古奈でも一番いい方の宿屋に落ちつき、いろいろ飲んだり、食べたり、友人達も大いに満足の様子で、あくる日東京へ、有難う、有難うと朗らかに言って帰って行きました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日の夜、白石は通事たちを自分のうちに招いて、シロオテの言うたことに就き、みんなに復習させた。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、手紙が来たのである。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう致しますとそのあくる日の夕方に大工の女房が自分で洗濯物を持って参りまして、これだからお神さんを早くお持ちなさい、女房のありがた味はこれでもわかろうと私の膝の上に持って来たのを投げ出して帰えりました。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、西原氏は母親に連れて來られた少女に書齋で會つた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "西原氏はまた醉つたあくる日の朝の西原氏なので、昨夜のそわそわした氣持ちも拔けてぽかんとした中に嚴肅なものに對する一種の憧憬れを持つてゐるやうな氣分であつた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あとの大勢つたら、其のあくる日から、火の雨、火の風、火の浪に吹放されて、西へ――西へ――毎日々々、百日と六日の間、鳥の影一つ見えない大灘を漂うて、お米を二｜升に水一｜斗の薄粥で、二十｜人の一｜日の生命を繋いだのも、はじめの内。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを押し殺してすず子はあくる日の朝までに、すつかり仕度をしてしまつた。",
              "citation": {
                "source": "計画",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あくる日、晩飯の支度前に、臺所から女中部屋を掛けて、女たちが頻に立迷つて、ものを搜す。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで吉五郎も一旦は屈伏したが、あくる日になるとまたその申口をかえて、自分にはそんな覚えはない、同類の勝五郎というものの面体が自分によく似ているから、手代どもはおそらくそれを見あやまったのであろうと申立てた。",
              "citation": {
                "source": "拷問の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日の『タイムス』紙上を見ると、劇評家ウォーナック氏はこの一節を激賞して「この大悲劇中の見所は千代がわが子を残して去る一｜刹那にして、エデー嬢は悲劇俳優として大なる将来を有することを明かに示せり」といっていました。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は十三夜で、近江屋でも例年の通りにすすきや栗を買って月の前にそなえた。",
              "citation": {
                "source": "影を踏まれた女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども　あくるひの　あさ　ふくろうの　しまに　もういちど　みんなで　むかいました。",
              "citation": {
                "source": "きたりすナトキンのはなし",
                "author": "THE TALE OF SQUIRREL NUTKIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくるひ　おこしになるまで　しっかり　みはっておくと　やくそくしました。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて　ジェマイマは　ついに　あくるひから　あたためだす　こころづもりだと　つたえまして　――「で、　コムギを　ひとふくろ　もってくる　つもり。",
              "citation": {
                "source": "みずかきジェマイマのはなし",
                "author": "THE TALE OF JEMIMA PUDDLE-DUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "その　あくるひも　かわらず　おんなじでした。",
              "citation": {
                "source": "まちねずジョニーのはなし",
                "author": "THE TALE OF JOHNNY TOWN-MOUSE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
