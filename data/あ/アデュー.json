        "examples": {
          "standard": [
            {
              "text": "「それでは皆さん、アデュー！」と彼は言い残し、颯爽と舞台を去っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「また逢う日まで、アデュー」と彼女は微笑み、発車する列車の窓から手を振った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「さらばだ、我が友よ。アデュー！」と彼は芝居がかった手つきで別れを告げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「今日のところはこれで失礼するよ。アデュー」と、探偵は帽子を軽く持ち上げて見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "「アデュー」という短い手紙だけが机に残されており、彼の行方は誰にもわからなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
