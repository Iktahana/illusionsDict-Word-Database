[
  {
    "uuid": "cc3f7ebe-44b2-5b3f-9acf-b3da7749594d",
    "entry": "暑苦しい",
    "reading": {
      "primary": "あつくるしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sultry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "夏の蒸し暑い夜は、エアコンなしでは暑苦しくて眠れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "真夏日に厚手のセーターを着ていた彼は、見ているこっちまで暑苦しく感じた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の熱弁は暑苦しいほどだったが、その情熱は周囲を惹きつけた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "換気扇のない台所は、料理を始めるとすぐに暑苦しい空気に満たされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "梅雨が明けた途端、毎日暑苦しい日が続き、体力を消耗する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暑苦しいほど派手な柄のシャツは、今の季節には少し重いかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議室の暑苦しい沈黙を破るかのように、誰かが咳払いをした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "――　暑苦しいために明けっ放した表から、誰かが呼んだ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでおれは美しい正方形のつめくさの絨氈の上で夕方までいろいろ踊るといふのはどうだ　あんな単調で暑苦しい蔬菜畑の仕事にくらべていくら楽しいかしれないと考へた。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を考えて暑い日の暑苦しい心持をさらに増したのであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒸されるような暑苦しい谷間の坂道の空気の中へ、ちょうど味噌汁の中に入れた蓴菜のように、寒天の中に入れた小豆粒のように、冷たい空気の大小の粒が交じって、それが適当な速度でわれわれの皮膚を撫でて通るときにわれわれは正真正銘の涼しさを感じるらしい。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろなイズムも夏は暑苦しい。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばん深刻だと思われた場面は、最大速度で回る電扇と、摂氏四十度を示した寒暖計を映出したあとで、ブランシュの酒場の中の死んだような暑苦しい空気がかなりリアルに映写される。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泥濘を捏返したのが、其のまゝ乾び着いて、火の海の荒磯と云つた處に、硫黄に腰を掛けて、暑苦しい黒い形で踞んで居るんですが。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に土蔵の中から取出された見事な花｜茣蓙が敷詰められて、やはり土蔵の奥から持出された古い質草らしい、暑苦しい土佐絵の金屏風が建てまわされた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹽原にも瀧は多く、仁三郎の瀧、萬五郎の瀧、龍化の瀧等、觀るべきものであるが、わざと觀ないで濟ませたのは、いくら夏の日の瀧見でも、重複は暑苦しいからと、華嚴に敬意を表して、今度の秋の紅葉の頃の樂みに殘したのであつた。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売上のことはここで説明する必要もないが、私はその商売の都合で再び神戸へ行かなければならない事になったので、広島に暑苦しい一夜をすごして、その明くる日の午前には又もや神戸行きの列車に乗込んだ。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふところの素寒貧を覺えながらも、夏のほこり風にあふられて、蚊がすりの單衣の背とからだの脊中とがひツ付くほど汗のうるみを生じて、脇腹を垂れる汗のしづくが親ゆづりの博多帶――山の這入つた茶と紺との合せ帶だ――の下にとまるのが、如何にも暑苦しい。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前のことだが、日は既に南の方へまはつてゐて、餘り暑苦しいやうなことはない。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳へはひると有繋に暑苦しいので「うゝん」　と唸るやうな聲を出してごろ／＼して居ると娘は又臺所へ行つて何かこと／＼音を立てゝ居る。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏の暑苦しい砲台の空気のうちに、血腥い空気が澱んでいた。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈サマー・イン・ザ・シティ〉というだけあって、暑苦しい音だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――暑苦しい晩だった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　暑苦しいので寝られずにいた母親が、眼をさまして声をかけた。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然し随分暑苦しいことだらうな、この真夏の晩と来たら――」「婦人連が汗を流して、お行儀好く、あの姿で――俺達｜武士にお酌をする光景を想ふと、これ御同役、一興ぢやなからうかね。",
              "citation": {
                "source": "夜の奇蹟",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そんなことを考えて、努めて涼しそうな気分をよび出すようにして、わたくしはどうにかこうにかこの暑苦しい汽車旅行を終って、小さい田舎の停車場に降り立ったのは、午後一時に近い頃でした。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは何故か、朝から火葬場へ通う自動車の行列が頻繁で、絶えず禿山の裾が煙幕のような挨に包まれた、暑苦しい日の朝だった。",
              "citation": {
                "source": "三狂人",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう暑苦しいといってよい頃であったが、それでも開け放された窓のカーテンが風を孕んで、涼しげにも見えた。",
              "citation": {
                "source": "或教授の退職の辞",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「行田文学」にやる新体詩も、その狭い暑苦しい蚊帳の中で、外のランプの光が蒼い影をすかしてチラチラする机の上で書いた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄色い暑苦しい花、焔のような真赤な小さな花、黄や紫の白粉花など、毎歳その土地には絶えなかった。",
              "citation": {
                "source": "吾亦紅",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑苦しい夏の夜はその考へがきまらぬうちは床についてもなかなか眠れなかつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくあの上方邊の人達が「しんど、しんど」といひながら山また山を越したらう昔を思ふと、一息に暗い穴の中を通り過ぎてゆく今日の汽車旅は比較にもなるまいが、それでも私達はかなり暑苦しい思ひで幾つかのトンネルを迎へたり送つたりした。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸に多いトンネルのことを考へると二度と同じ道を通つて暑苦しい思ひをする氣にもなれない。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "……今日も午後は六丁釣場へ出かけた、先客一人、なか／＼上手に釣つてゐる、私もゆつくり構へこんだが、痔が痛むし、暑苦しいし、その上、近在の河童小僧連が押し寄せてうるさいので、早々切りあげて戻つた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずゐぶん暑苦しい日であつた、そして寝苦しい夜であつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、あんまり暑苦しいのでしばらく散歩、そして熟睡。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "何といふあつくるしい手であったらう。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
