        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あっちゃ、そういえば約束があった。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、靴を忘れた。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、もう遅刻だ。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、間違えた。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、素手で触っちゃった。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、焼き過ぎた。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、言ってしまった。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、割っちゃった。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、送信しちゃった。",
              "source": "幻辞"
            },
            {
              "text": "あっちゃ、こぼしちゃった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それでも衣裳の整はないのがあっちゃ、こっちの失態ですしね、えゝ、どうもこんなこっちゃ困りますぜ。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝらへ来て、こんな目にあっちゃ叶はねえ。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御幣まで立って警戒をした処があっちゃあ、遠くを離れて漕ぐにしても、船頭が船頭だから気味が悪いもの。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「交渉があっちゃあ大変だ。",
              "citation": {
                "source": "河鹿",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "気違いにあっちゃ、かなわない。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、ひどいめにあっちゃった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこの番頭にはじめて興味ある関心を持ち出しまして、試に、「いくら耳だけ、福耳にしたって、眼尻に泣｜黒子があっちゃあ駄目じゃないの」　と突き崩してみます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚市場の商売ナンテいうものは学問があっちゃ出来まっせん。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人めえもあっちゃ。",
              "citation": {
                "source": "駈落",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ならぐうの音も出させやしないと、まあ、そう思ったもんだから、ちっとも言分は立たないし、跋も悪しで、あっちゃアお仲さんにまかしておいて、お前さんを探して来たんだがね。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも定子さんがあっちゃ何だから、ちょいと一服モルヒネでも装りましょうか、手のもんでわけなしだって、洒落にもいっている人だから、すぐに味方して、血判をしてくれます。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "処へ夜が更けて、尋ねて行くものがあるから、おかしいぜ、此奴、贔屓の田之助に怪我でもあっちゃあならねえと、直ぐにあとをつけて行くつもりだっけ、例の臆病だから叶わねえ、不性をいうお前を、引張出して、夢にも二人づれよ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お力ちゃんが一緒に帰ってきて、途中でこんなことがあっちゃあ、甲州屋さんにも申し訳がないと云って……」「皆さんはもうお寝みになりましたか」と、お広は訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暇を貰おうという矢先きに、借りなんぞあっちゃ拙いから、よくお礼をいって、御用人に早く返しておしまいなさいよ」「だが、こっちも病気で物入りの多いところだろう」と、林之助は手を出しかねて、もじもじしていた。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもこんなに森があっちゃ夜になったらさびしいわねえ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「美智子さんにあっちゃ、敵いませんよ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前のようなおてんばにあっちゃ、誰だって驚くさ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっと高すぎてくやしいが、五両と聞いて逃げを張ったとあっちゃ、江戸っ子の名に申しわけがねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗相があっちゃいけないよ」　もぎとるようにしてお雪をつれて行くと、無理矢理有朋のそばへ坐らせて、お女将は、ここを先途と愛嬌をふりまいた。",
              "citation": {
                "source": "山県有朋の靴",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「胡散な捨て子が三人もあっちゃ、どうやらいわくがありそうだから、とち狂っていねえで、はええところしたくをしろといってるんだよ」「ちッ、ありがてえ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "追いかけた肝心のおくにが、死人に口なしにかたづけられておったとあっちゃ、敬だんな、さぞやしょげきっていたろうな」「ええ、もう、歯を食いしばっちゃ、ぽろり、ぽろりとね」「あの男が！",
              "citation": {
                "source": "右門捕物帖",
                "author": "闇男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもさ、冗談抜きで、いつのまに知りあっちゃったわけ」　逆転した攻守を、なんとか、もういちど逆転しようと、慶一が攻撃をはじめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは誘惑が多くていけないんですって、あのおやじより他の男にあっちゃいけないんですって？",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「子供はまだ三歳や四歳じゃあどうにもならねえが、そのおふくろというのはまだ十九だそうだから、間違いがあっちゃあ可哀そうだ」「若い女房だと思って贔屓をするな」と、半七は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなことがあっても、それより少いことが、あっちゃならない。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でもよろしゅう御座いますから明朝四谷へ行って御覧遊ばせ、きっと何か御座いますよ、婆やが受合いますから」「きっと何かあっちゃ厭だな。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしか間違いでもあって、後で親類に話の出来ないようなことでもあっちゃ済まないで。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供が二人もあっちゃ、なかなか出られませんね。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私みたいに、亭主運がわるくて、二度もあっちゃ大変でございますけれど。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにそのためにつむじを曲げて、芝居を蹴飛ばすようなことがあっちゃあ大痛手だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
