    "definitions": [
      {
        "index": 1,
        "gloss": "a day after the fair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "締切が過ぎてから重大な書き間違いに気づいたが、もう後の祭りだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今さら後悔しても後の祭りだよ。あの時あんな態度を取らなければよかったんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "契約書に判を押した後に条件の不利な点に気づいても、後の祭りである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "周囲の忠告を無視して大失敗をしてしまっては、後の祭りと言うほかない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "チケットが完売してから会場へ駆けつけても、後の祭りだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "病状が進行してから慌てて病院へ行っても、手遅れであれば後の祭りになりかねない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "株式市場が完全に暴落した後で売り抜ける方法を考えても、後の祭りである。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「今さら叱っても後の祭りだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の狐が天狗に化けて、おまえさん達を嚇かしたのだ」　こちらは大の男三人であるから、狐と知ったら叩きのめして、その正体をあらわしてやったものをと、今さら力んでも後の祭りで、又もや怪談の種を殖やすに過ぎなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "妖狐伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "後になって、ああもしておけばよかった、こうもしておけばよかったと後悔しても、すべては皆後の祭りです。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな意味で、僕などがもっと彼と往来して、彼の生活力を、刺激したならばと思うが、万事は後の祭りである。",
              "citation": {
                "source": "芥川の事ども",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はびっくりして、余の手を遮り「何をなさる、何を成さる」と叫んだけれど後の祭りだ、顔形は極｜脆い蝋の細工ゆえ、早や床の上で粉微塵に砕けて了った、余は猶も飽き足らず先生の手を振り払って顔形の屑を粉々に踏み砕いた、先生は呆気に取られ、呆然と見て居たが、又忽ち余を捕え「貴方は余りな事を為さる。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は後になってそれを悔んだけれど、もはや後の祭りであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "善からうが悪からうが構ふこつてねえだ――けふぢゆうに婚礼を挙げつちまやあ、なんてつたつて後の祭りだあな！",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "生前にこの事実を知ったら、何か旨い忠告が試みられたかも知れない――が、すべては後の祭りだった。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、悲しいことがつづいてから後になつて檢討され、それだからだつたと言ひあはされたが、あはれな娘にとつては、なんにもならない後の祭りでしかなかつた。",
              "citation": {
                "source": "「郭子儀」異變",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は、神が様々の芸能文化を分出し、又新しい芸能をとり容れて来られた迹を眺めて、今後の祭りの益賑々しく、栄えゆくことを思ひ、心自ら豊かなるを禁めえないのである。",
              "citation": {
                "source": "神賑ひ一般",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿に立派な路で、これを来ていたら、ガレであんな苦しみ方はしなかったろうと残念がったが後の祭り。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もはや後の祭りである。",
              "citation": {
                "source": "春の遠山入り",
                "author": "松濤明",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかし、とうとう饂飩を食わせられた今となって見ると、いくら饂飩屋の亭主を恨んでも後の祭りだから、まあ、我慢して、ここから曲がってやろう」「石段は見えるが、あれが寺かなあ、本堂も何もないぜ」「阿蘇の火で焼けちまったんだろう。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "正気に返って怒り怨み、泣き喚いた時は後の祭り。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「くわしきことを申し上げましても、詮ない次第後の祭り！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナーニお浦を連れ参らば、策を設けて奪い取り、犠牲にした織江をかえしたところで後の祭り、どうともなるまい）（見ぬ前はそうとも思わなかったが、眼に見た織江の美しさ！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは失敗したと氣がついた時は後の祭りでした、早く解散するに如かずと考へて、わたしが立つて閉會の辭と感謝の辭とを述べ始めると大杉と荒畑とは『無政府共産』『革命』等の白色文字を現した赤旗をふり、やがて私の言葉が終るや否や、高らかに革命歌を唄ひ始めました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正当な要求や主張が多くの場合相手の弱点をつくことになるために、常に「後の祭り」を警戒しなければならないといふやうな経験はだれにでもある。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はバタフライをつけてなかったか、気がついたが後の祭り、ワアーとはやされ逃げ込むおかしさ。",
              "citation": {
                "source": "ストリップ修学旅行",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺さずともよいに」　三好春房は声を掛けたが、それは後の祭りであった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アッと叫んだが、後の祭り。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "飄々としてわが行末を覚束ない風に任せて平気なのは、死んだ後の祭りに、から騒ぎにはしゃぐ了簡かも知れぬ。",
              "citation": {
                "source": "野分",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては、後の祭りだ、という気がした。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして鋸でゆっくりきゃつめの首を引き切ってやる」　とはいえ、これも後の祭りであった。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "騷ぎを聽いて土地の御用聞が驅け付けた時は、何も彼も後の祭り。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "毒酒",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は八百五十石取の旗本屋敷だ、誤摩化して死骸を取片付けられちや後の祭りだ」「で？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蹄の跡",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰だ、吹矢を捨てたのは」　と言つたところで、もう後の祭り、故意か過ちか、兎に角、又左衞門に大怪我をさした當人が、後の祟りを恐れて、隱して了つたことだけは確かです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "南蠻祕法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更氣がついても、後の祭りですが、せめては菊次郎さんを殺した下手人を擧げ、それから身を退き度いと存じ、明神下の親分さんのところへ參りました」「――」「ところが、徳三郎さんは」　平次にもその消息はよくわかるやうな氣がするのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "橋場の人魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰だ、吹矢を捨てたのは」　と言ったところで、もう後の祭り、故意か過ちか、とにかく、又左衛門に大怪我をさした当人が、後の祟りを恐れて隠してしまったことだけは確かです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "南蛮秘法箋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お新は此処へ来ませんか」「いや」「逃げたか、畜生」　八五郎は地団太踏みましたが、すべては後の祭りで、下女お新の影も形もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
