        "examples": {
          "standard": [
            {
              "text": "豚肉料理に添える定番として、このアップルソースは外せない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "焼きたてのパンケーキに、温かいアップルソースをたっぷりとかけて朝食にする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "砂糖不使用のアップルソースは、離乳食や介護食としても重宝されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ケーキの生地にアップルソースを加えると、しっとりとした食感に仕上がる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鶏むね肉のソテーに甘酸っぱいアップルソースをかけると、さっぱりといただける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このアップルソース、手作り？ りんごの自然な甘みがいいわね。」と母が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小腹が空いた時、ヨーグルトにアップルソースを混ぜて食べるのが日課だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
