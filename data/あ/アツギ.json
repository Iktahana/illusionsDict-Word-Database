[
  {
    "uuid": "34daeec3-7273-599c-abf7-53214c597b6a",
    "entry": "厚着",
    "reading": {
      "primary": "あつぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wearing thick clothes",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "寒い日に出かけるときは、子供に厚着をさせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の登山では、体温調節のため厚着は欠かせない装備の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "暖房の効いた室内で厚着をしていると、汗ばんで不快になることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天気予報では明日冷え込むとのことなので、厚着をして出かけよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「こんなに厚着しなくてもよかったのに、汗をかいちゃった。」と彼は言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "寒がりの彼女は、秋口でもすぐに厚着をし始める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "風邪予防のため、外出時には意識して厚着をするようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "彼はその当時の寄席芸人に似合わず、文学絵画の素養あり、風采もよろしく、人物も温厚着実であるので、同業者間にも大師匠として尊敬されていた。",
              "citation": {
                "source": "寄席と芝居と",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚着をさせてある頃で、この末の児はまだ匍いもしなかったが、チョチチョチ位は出来た。",
              "citation": {
                "source": "芽生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかと云って、厚着をして不形恰に着ぶくれた胴の上に青い小さな顔が乗って居る此の変な様子で人の集まる処へ出掛ける気もしない。",
              "citation": {
                "source": "秋風",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は日本服を着る以上は、正式にシャツ類を排斥したいと思う、ところでシャツなくては私の冬はあまりに残酷なのだからやむをえない、私は洋服を主として用いる、その洋服でもあまりの厚着はいけないそうだが、日本服の不体裁に比して遥かにましだと思う。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒い朝であったから、誰も厚着をしていた。",
              "citation": {
                "source": "寛永武道鑑",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分で、突いたが、厚着のため、一寸、肌へ傷ついただけの疵が、それでも、安心すると痛んでいるのが、感じられてきた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の前には厚着した上に水色の襟卷をした老婆が暖いので供も連れずに遠くへ出掛けると見える。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "見榮も恰好もなく着るによいだけ厚着をして、どれも皆元氣よく野獸のやうに強い響きをもつた、しかし其のなかに異樣なくらゐ可憐らしさの籠つた言葉でもつて、大聲に喚き合はしてゐる。",
              "citation": {
                "source": "地方主義篇",
                "author": "福士幸次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ｍ、又厚着、体がわるい。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚着をしているのと息ぐるしいのと、母上の話題とで、ハンカチーフを出して、汗をふいた。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、仮ににちがいないと思うが……病気で廃めたというだけのことに、せめて幾らか頼みの綱が繋がっているような気がして、それだけに心に少し勢いがついて、宿にとって返し、夜の寒さに風邪を恐れながら、思いきって厚着になり、また祇園町へと出かけていった。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "カゼをひかないように、せいぜい厚着して行こうと仰有ったのを覚えてます」　ということであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はお給仕しただけで、彼の出るのを見送ったわけでないから、どんな厚着して出かけたか分らないということだった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お宅の女中さんの話によりますと、兄さんは失踪直前の夕食中に今夜一晩は不寝番だからカゼをひいちゃいけないな、厚着しようと呟いておられたそうですね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人はつと立って、例の不恰好な厚着をした身体をぶるんとふるわせると、物もいわずに逃げだした。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒からうと豫想した輕井澤はスチイムで暑くて困る位でしたが、私のやうに厚着をしてゐる旅客が見えませんので温度を加減さすのも憚られて我慢して通しました。",
              "citation": {
                "source": "佐渡が島のこと",
                "author": "江南文三",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚着をさせてある頃で、お繁は未だ匍いもしなかったが、チョチチョチ位は出来た。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつもの名畫陳列のこの場所は、人込みと、暖房の熱氣と私が過度な厚着をしてゐるためとで、汗のしたゝるほどの暑くるしさを覺えてゐるので、高原の淨氣を鼻から感得するどころではなかつたのだが、それにかゝはらず私は、見てゐると畫面の天空に心を吸ひ込まれるやうに感じた。",
              "citation": {
                "source": "『アルプスの眞晝』（セガンチーニ作）",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる着用にて、炎熱の日に畑に出でたるには、炎熱と厚着の為めに全身は暑さを増すのみならず、汗出でて厚く着重ねたる木綿｜衣は汗にて流るるが如きに至るを以て、自ら臭気を発して、一種の不快を覚ゆると其｜苦さとにて、一日には僅に三四時間の労働に当るのみ。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に北海道の夏は、日中は最も炎熱甚しく、依て此厚着にて労働するが為めには実に労るる事多し。",
              "citation": {
                "source": "関牧塲創業記事",
                "author": "関寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の若い方は平均して昔の若い人より寒がりで厚着のようだ。",
              "citation": {
                "source": "噺家の着物",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るに忍びず、厚着をしている服のまま立たせて、まわりに枯枝やかわいたヤチなどを積みあげて二、三ヵ所に火をつけた。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく火を踏み越えて外にはい出たが、厚着の着物が熱をもって着ていられず、脱ごうにもずぶぬれの着物はなかなか脱げず、とうとう泣き声をあげてしまった。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういえば、お目にかかったとき、厚着していらっしゃるように見えたのですが、ちがうかしら。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "『とにかく一度、猿沢の背中を見ねばならぬ』　しだいに冬が近づくし、そうすればだんだん厚着になるし、裸の背中をのぞき見る機会は、ますますなくなってくるのです。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが大切にし過ぎて厚着をさせますから、皮膚が弱くなるんでございますわ」　とお母さんは日頃の干渉を問題にする。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父さんは自分が寒がりだから、子供に厚着を強いる。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚着をしていたのと、酔っていた所なので、彼は少からず面喰らった。",
              "citation": {
                "source": "※かみ浪人",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思い切りあつぎをし家にとじこもる。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
