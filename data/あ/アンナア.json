        "examples": {
          "standard": [
            {
              "text": "あんなあ、もう来たのか。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、ちょっと手を貸してくれよ。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、この話を聞いたことあるか。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、最近どう過ごしてるんだい。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、あの計画はどうなったんだ。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、時間がある？相談がある。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、その荷物重そうだね。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、あいつのことは忘れろよ。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、次の仕事の話を聞こうや。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、飯でも食わないか。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、元気そうだな。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、今夜の予定はどうだ。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、そこまで気落ちするなよ。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、一杯やろうぜ。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、その女の子は誰だい。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、試合はどうだった。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、鍵をなくしちゃった。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、この問題、解けたか。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、明日も仕事か。",
              "source": "幻辞"
            },
            {
              "text": "あんなあ、その話は別だろ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "おれはむしゃくしゃまぎれにあんなあはれな人間などをいぢめたのだ。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはむしゃくしゃまぎれにあんなあわれな人間などをいじめたのだ。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方は、あんなあわれなかたわを使って一銭のマッチを十円に売っているとは一体どう云うわけだ。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんなあばずれのいった言は、ナニ、蚊が鳴いたのだと思召しまし。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あれ、あんなあの、握飯を拵えるような手附をされる、とその手で揉まれるかと思ったばかりで、もう堪らなく擽ったい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人形たちが、大きなガラスの目で、どこともなく、じいっと見つめながら、あんなあわれなため息をついているのでした。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "してみると私たちのなかまのたれかが創案したのだが、いったいたれだろう、あんなあわれ深い遊戯をつくり出したのは。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのアメリカ人は傍のあの紳士を前｜葡萄牙マヌエル陛下と知らずに、あんなあけすけな態度で女の話をしかけて居る。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人に対する意地と反感と、準之助氏から受けた同情と好意と自然の脅威を前にして、人間同士がお互にすがりつこうとする本能から、ついあんなあやまちを犯してしまった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを伴れて使が小月氏国へ還ると、国の諸臣議すらく、仏鉢は直に貴く王これを崇むるはもっともだが、かの木菟入こそ怪しからぬ、あんなありふれた坊主を一億金代りに受け取ったは大勘違いでなかろうかと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び女の心のあんなあツたかみに接する時は金輪際なからう。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで冒頭に断っておくがこの第六感というものは、千里眼、又は催眠術なぞという迷信的なものとは全然別物なので、あんなあやふやな奇蹟的なものではない。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日もあすこに行つたことは家でも知つてゐますから、あんなあらしになつてとてもかへれなかつたと云ふことは家の人にもわかつてゐますし、Ｋ先生もおかへりになつてはゐませんから。",
              "citation": {
                "source": "嘘言と云ふことに就いての追想",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三田さん、おみつつあんなあ、あんたの事を男らしい人やいふてはりましたぜ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京都で育った娘なんて随分ぼんやりなもんだ事、けれども御化粧だけは随分気がつくもんだ事」「厚い御化粧で長い袂と着物であんなあたまで御かざりにはいいけれど」　母と二人でこんな事を云いあった。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはあんなあやしげな見世物を、一日も早くなくしてしまわないといけないと思って、思いきってそれをやったのだ」「あなたが、その場からお逃げになったのはどういうわけです。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの……何とか云う会社員……僕は片山さんから聞いたのだ……あんなあやふやなんじゃなかったんだ。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなあやふやな奴は駄目ですよ。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなあやふやな人物にしては面白味がない。",
              "citation": {
                "source": "春秋座の「父帰る」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　みんなは、そのときのいろんなできごとを思いだして話しましたが、エミイまでが、もうこんなに大きくなっては、あんなあそびできないというのをとがめて、おかあさんはいいました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "とみ　　あんなあ、おつ母さん、今なあ、またロオラが来たつばな。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして金座の烏凧だけがあんなあがり方をするのだとね。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしも、お祖父ちゃんとあんなあわただしい別れ方をして、気になってならないんだよ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうまもなく振袖も見っともなくなったのでわきをふさいでからも二三度縁組みして十四の時から嫁に行き初めて二十五まで十八所出て来たり出されたりしたんで段々人が「女にもあんなあばずれ者があるもんですかネー」と云いひろめられたので後では望み手もなくて年を経てしまった。",
              "citation": {
                "source": "元禄時代小説第一巻「本朝二十不孝」ぬきほ（言文一致訳）",
                "author": "井原西鶴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あんなあばずれは大嫌いで――」　丑松はムキになりました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮の浴槽",
                "note": "青空文庫"
              }
            },
            {
              "text": "けらお　（ひねくれて）なよたけのあんなあな！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（他の者を誘う）おい、みんなも云えよ、なよたけはあんなあなだい！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（大声で）なよたけのあんなあな！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なよたけのあんなあな！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
