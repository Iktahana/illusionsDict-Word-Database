    "definitions": [
      {
        "index": 1,
        "gloss": "in a hurry",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "朝寝坊してあたふたと準備をした。",
              "source": "幻辞"
            },
            {
              "text": "締め切りギリギリであたふたしている。",
              "source": "幻辞"
            },
            {
              "text": "駅で電車を見落としてあたふた走った。",
              "source": "幻辞"
            },
            {
              "text": "大事な書類を失くしてあたふたしている。",
              "source": "幻辞"
            },
            {
              "text": "急な訪問者にあたふたとした。",
              "source": "幻辞"
            },
            {
              "text": "試験前日にあたふたと勉強している。",
              "source": "幻辞"
            },
            {
              "text": "子どもが駅で迷子になってあたふたした。",
              "source": "幻辞"
            },
            {
              "text": "火事のときにあたふたと逃げ出した。",
              "source": "幻辞"
            },
            {
              "text": "プレゼン直前にあたふたとスライドを修正した。",
              "source": "幻辞"
            },
            {
              "text": "パーティーの直前にあたふたと準備している。",
              "source": "幻辞"
            },
            {
              "text": "その映画のシーンではキャラクターがあたふたしていた。",
              "source": "幻辞"
            },
            {
              "text": "医者はあたふたした患者を落ち着かせるのが仕事。",
              "source": "幻辞"
            },
            {
              "text": "その演技はあたふたした感じが上手い。",
              "source": "幻辞"
            },
            {
              "text": "緊急事態にあたふたするのは仕方がない。",
              "source": "幻辞"
            },
            {
              "text": "あたふたした態度は信頼性を損なう。",
              "source": "幻辞"
            },
            {
              "text": "忙しいときはあたふたしがちだ。",
              "source": "幻辞"
            },
            {
              "text": "冷静さを失ってあたふたしている。",
              "source": "幻辞"
            },
            {
              "text": "新しい仕事についてあたふたしている。",
              "source": "幻辞"
            },
            {
              "text": "あたふたした姿は情けなく見える。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではあたふたするキャラクターが登場する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "暑中休暇がすんであたふたと上京したら、馬場の海賊熱はいよいよあがっていて、やがて私にもそのまま感染し、ふたり寄ると触ると Le Pirate についての、はなやかな空想を、いやいや、具体的なプランについて語り合ったのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、おやじが、あたふたと、郭を探しにはいってきた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「三ツ、三ツ」房は、あたふたと答えた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "稍、うつむきこんで軸列器をがちゃがちゃ鳴らし、木枠に軸木を植えつけている于立嶺は、おどおどして、あたふたと頭をさげた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたふた黄ばみ雨を縫ふ、　　　もずのかしらのまどけきを。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或いは又、孫のハアモニカを、爺に借せと騙して取上げ、こっそり裏口から抜け出し、あたふた此所へやって来たというような感じでありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、あから顏の教授が、ふくらんだ鞄をぶらさげてあたふたと試驗場へ駈け込んで來た。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、あから顔の教授が、ふくらんだ鞄をぶらさげてあたふたと試験場へ駈け込んで来た。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくあっけにとられて居た婆やが、あたふた追い掛けて見ると、かやは、すこし色の褪せた緋縮緬の帯を小さく貝の口結びにした後姿を見せて、書院の縁へ顔を、うつぶせにして居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　島野は多磨太が先じたりと聞くより、胸の内安からず、あたふた床几を離れて立ったが、いざとなると、さて容易な処ではない。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あたふた飛んで来て柄杓を取れば、両手を出して濯ぎながら、跪坐る秀をじっと御覧じ、「秀。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お房は衝と立起ツて、あたふた　た　」はママ］格子の方へ行くかと思ふと、と、振返ツて、「お花ばかりで可いの。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と低く呟きながら、あたふたと部屋を出て行きました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の毒だねえ、せっかくのこんないいチャンス、……」　などと言っているうちに、顔は煤だらけ、おそろしく汚い服装の中年のひとが、あたふたと店にはいって来て、これがその岡島さん。",
              "citation": {
                "source": "酒の追憶",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいはいと寝惚け声で答えて、あたふた逸子が出て行く足音を聞きながら、鼈四郎は焜炉に炭を継ぎ足した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暑中休暇がすんであたふたと上京したら、馬場の海賊熱はいよいよあがつてゐて、やがて私にもそのまま感染し、ふたり寄ると觸ると Le Pirate についての、はなやかな空想を、いやいや、具體的なプランについて語り合つたのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理もねえ、なんて僕まで眼のいろを変えてあたふたと家出してみたところで、まるで、ナンセンスだものね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の中を、あたふたと床屋へ行く。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、あたふたと家へかへつて來たのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、あたふたと家へかえって来たのである。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といやに優しい言葉遣いをして腹に一物、あたふたと上方へのぼる。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　受話器を耳に當てたソオルの顏は忽ち眞青になり、あたふたと自席を飛び出して警視室の扉を荒々しく引きあけると、今耳にしたばかりの驚くべき報告を傳へた。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野の姿が、横ざまに飛んで、あたふた先へ立って扉を開いて控えたのと、擦違いに、お妙は衝と抜けて、顔に当てた袖を落した。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "め組が、中ほどから、急にあたふたと駈出して、二等室を一ツ覗き越しにも一つ出て、ひょいと、飛込むと、早や主税が近寄る時は、荷物を入れて外へ出た。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、あたふた上野駅にいそぐ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこでもいい、にぎやかなところへ下車させて下さい、と車掌さんにたのんで、ほどなく、それではここで御降りなさいと教えられ、あたふたと降りたところは長谷であった。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さん、あたふた、次の駅で下りましたがね。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい／＼の、犬の、婆の、金時計の、淺葱の褌の、其上に、子抱の亭主と來た日には、こりや何時までも見せられたら、目が眩まうも知れぬぞと、あたふた百花園を遁げて出る。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どう思召して下さいます、私は口が利けません、いいわけをするのさえ残念で堪りませんから碌に返事もしないでおりますと、灯をつけるとって、植吉の女房はあたふた帰ってしまいました。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
