      {
        "index": 1,
        "gloss": "pressure suppression (e.g. pool, container in a nuclear power plant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
