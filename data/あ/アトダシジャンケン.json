        "examples": {
          "standard": [
            {
              "text": "世論調査の結果を見てから政策を修正するのは、後だしジャンケンだと批判されても仕方ない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "競合の成功を確認してから類似商品を開発するなんて、まるで後だしジャンケンじゃないか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「そりゃ後だしジャンケンだよ。議論が終わってから新しい理屈を持ち出すなんて卑怯だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "問題がすべて解決した後に「もっと良い方法があった」と言われても、後だしジャンケンにしか聞こえない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "相手の出方を見てから自分の意見を変えるのは、後だしジャンケンと言われる典型的な行動だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "みんなが賛成した後に「私もそう思ってたんだ」と言うのは、後だしジャンケンみたいで気が引ける。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "交渉の最終局面で新たな条件を付け加えるのは、後だしジャンケンも甚だしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
