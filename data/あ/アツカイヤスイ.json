        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "この新しい電動ドライバーは軽量で、女性でも片手で扱いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "粘土は子供の創造力を育むのに扱いやすい素材だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "スマートフォンの操作画面が直感的で、初めて使う人にも扱いやすい設計になっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は協調性があり、どのようなチームでも扱いやすいメンバーだと言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このデータベースは、必要な情報を素早く検索でき、非常に扱いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "想定していたよりも規模が小さく、今回のトラブルは比較的扱いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初心者向けのバイクは、車体が軽く、カーブでも扱いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "時間をかけて練り上げた考えや物語をおさめる、読みやすくて扱いやすい最良の器は、紙を束ねて作った冊子であり続けた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語りの器となる〈本〉を、より作りやすく、より扱いやすいものにしていく。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の物語りを、読みやすく扱いやすい器におさめる術は、誰にとっても有用なものだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方で、これまでは算盤勘定の都合で書類にするしかなかったものを、読みやすく、扱いやすい本の器に収めることにも大きな意味がある。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハードウエアとソフトウエアの双方を改良して、より読みやすく、扱いやすい電子本を作ることが不可欠です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまだうまく想像できずにいるけれども、あと五十年もすれば、ベッドやトイレや風呂はもちろん、道を歩きながらでも読むことができる、もしかしたら、いまある本などよりもはるかに扱いやすい読書装置（ハードやソフト）がほぼ完全にできあがっているかもしれない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば人間も羊同然箇人としてよりは群集としての方が扱いやすいかも知れぬ。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと偽善になるようですが、悪徳の天真瀾漫よりは取り扱いやすいから結構です。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "勤労人民が生活安定を求めて団結する力を扱いやすい形に分裂させるため、組合民主化運動と称する分裂運動が盛に行われている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平罐のほうはまだしも扱いやすいが、高罐となるととても駈けだしの fresh eggs などの手に負えるものではないのである。",
              "citation": {
                "source": "南部の鼻曲り",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく簡単な――したがってみずから取り扱いやすい――概念的範疇を作っておいて万事をテキパキと処理しうる能力と度胸とができなければ決してよい役人にはなれない。",
              "citation": {
                "source": "役人学三則",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自伝的の部分は最初にあげた「左衛門の陣」の個所が直ちに結合し得られるのみならず、事件そのものに脈絡を見いだすことのできる最も取り扱いやすい部分である。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもこの製作上の発展は、漆喰や粘土のような扱いやすい材料を使ったことに帰せられているようである。",
              "citation": {
                "source": "麦積山塑像の示唆するもの",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小銃ほど扱いやすいものはないが、このドイツ人はそれ以上の恐ろしい武器を知ってるし、一流の化学者・兼・科学者だ。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "トリガーセンは扱いやすい段階に行きつつあった。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾分なりとも柔らかに取り扱いやすいようにしておく。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "人見知りをせぬ子供のようであつかいやすい気を院はお覚えになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いている女は、磯五にとって、いちばんあつかいやすいのである。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
