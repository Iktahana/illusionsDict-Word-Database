    "definitions": [
      {
        "index": 1,
        "gloss": "pockmarked face",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あばた面でも心優しい人は多い。",
              "source": "幻辞"
            },
            {
              "text": "その隣人はあばた面だが、とても親切だ。",
              "source": "幻辞"
            },
            {
              "text": "医学の教科書にはあばた面の原因が説明されている。",
              "source": "幻辞"
            },
            {
              "text": "皮膚科医はあばた面の治療法を患者に提供している。",
              "source": "幻辞"
            },
            {
              "text": "歴史的には、あばた面の人は社会で差別を受けることがあった。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではあばた面の人物が深い内面を持つ場合が多い。",
              "source": "幻辞"
            },
            {
              "text": "昔は「あばた面の上から粉」という言い回しが使われていた。",
              "source": "幻辞"
            },
            {
              "text": "教育現場では、あばた面への偏見をなくすことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "心理学ではあばた面への見方が自己イメージに与える影響を研究する。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス研修では、あばた面への外見的偏見について議論される。",
              "source": "幻辞"
            },
            {
              "text": "法律的には、あばた面を理由とした雇用差別は禁止されている。",
              "source": "幻辞"
            },
            {
              "text": "自然界では、あばた面はやけどやけが傷から生じる。",
              "source": "幻辞"
            },
            {
              "text": "古い慣用句として「あばた面も愛嬌」という言い方がある。",
              "source": "幻辞"
            },
            {
              "text": "旅行中に出会ったその老人はあばた面だが表情が温かかった。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ選手の中にもあばた面の人は多くいる。",
              "source": "幻辞"
            },
            {
              "text": "文化人類学では、あばた面への社会的反応は文化によって異なる。",
              "source": "幻辞"
            },
            {
              "text": "料理人の経験談では、火傷であばた面になった話がある。",
              "source": "幻辞"
            },
            {
              "text": "音楽の伝記では、演奏家があばた面であることが記述されている。",
              "source": "幻辞"
            },
            {
              "text": "社会学はあばた面に対する深い偏見の歴史を明らかにしている。",
              "source": "幻辞"
            },
            {
              "text": "現代の美的価値観ではあばた面も含めた多様性が尊重される。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "身体は大きくないが、骨組はがつちりしてゐて、顎や頬骨の張つてゐるあばた面の老人が、老いさらばひ、夕闇に一人で飯を喰べて居る姿はさびしかつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "次郎左衛門は芝居や講談で伝えられているような醜いあばた面の持ち主ではなかった。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうのあばた面さえ沢山にある時代ですから、薄いもぐらいはなんでもありません。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひきずりみっちゃは、痘痕の続いてゐる旁若無人なあばた面を言ふ。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、あばた面の乞食が銭を算えながらいっていました。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、あばた面の男は、仲へ入って、その場を円くおさめてくれました。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は、心の中で、顔つきにも似ず心のやさしい乞食だと思って、あばた面の男に感謝していました。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばた面が少年を揺すり起こしました。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といって、あばた面の乞食はうなずきました。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、いつのまにか自分より早く、あばた面がそこにきてすわっているのでした。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、あばた面は、目をぎょろりと光らしていいました。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばた面は、たいそう不機嫌な顔つきをして帰ってくると、少年に向かっていいました。",
              "citation": {
                "source": "石をのせた車",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに、あばた面で音曲の巧く人情噺の達人だった初代小さんは、これは春風亭小さんだったのでございます。",
              "citation": {
                "source": "初看板",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "……イリヤ・イリイーチ・テレーギン、一名、ワッフルと申しますのは、このとおりのあばた面だもので、口の悪い人がつけた仇名なのでございます。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃませずと部屋へ通せ」　源十郎、やぐら下まつ川の上がり口に立ちはだかって、うすあばた面の顔をまっかに、こうどなり立てている。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こわいあばた面も、このあたらしい着つけにそんなに似つかわしくないこともないのだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "年齢のころは四十あまり、剃刀のような長い蒼白いあばた面、薄い一文字の口、鴨居をくぐりでもしそうな珍しい背高、これぞ饗庭亮三郎その人である。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歴然が多少気にかかると見えて、主人は往来をあるく度毎にあばた面を勘定してあるくそうだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして先生のあばた面が出た。",
              "citation": {
                "source": "幼年時代",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、竈の前で、あばた面をほてらしながら、お糸婆さんが、能弁にあいづちをうつ。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは三十がらみのあばた面の女で、打ち身だらけになっており、上唇を少しはらしていた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "役所の同僚の一人は、見るも気持ちがわるいくらいな、ひどいあばた面で、おまけに強盗のような人相をしていた。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あばた面の料理番は柄にも無い親切らしい声でこう訊くのであった。",
              "citation": {
                "source": "女給",
                "author": "細井和喜蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビルという３人目の男は肩幅が広く、キツネのような赤毛、ひどいあばた面だ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばた面の男がつぶやいた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "天然痘にかからないためには種痘をしなければならない、あばた面になる代りとして、腕の一部分にメスを入れられるのだ。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また義貞としては、よしや尊氏が幾万の兵を持って来ようとも、本来の勇と智略と、そして、故郷｜世良田いらいの新田小太郎が面目にかけても、「なんであの、うすあばた面に！",
              "citation": {
                "source": "私本太平記",
                "author": "筑紫帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしてピンピンしていらっしゃる左膳さまのめえに、手前、よくイケしゃあしゃあとそのあばたづらをさらせるな。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
