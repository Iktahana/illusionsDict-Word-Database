[
  {
    "uuid": "1cede79c-8049-5fbb-8caf-6394b49c06b0",
    "entry": "あばた面",
    "reading": {
      "primary": "あばたづら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
