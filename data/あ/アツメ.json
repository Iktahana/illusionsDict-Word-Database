    },
    "definitions": [
      {
        "index": 1,
        "gloss": "collecting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "刑事たちは事件の真相を暴くべく、現場周辺での地道な証拠集めに奔走している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "幼少期から続けている珍しい切手集めが高じて、今ではその道の鑑定士として知られるようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「最近の趣味は何？」「昔懐かしいレトロゲームのソフト集めにハマってるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "環境団体は、プラスチックゴミ削減を訴えるキャンペーンのために駅前で大規模な署名集めを行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は新しい小説の舞台となる街へ赴き、数日間にわたって地元住民への入念なネタ集めを続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、また変なものを拾ってきて」「いいじゃない、私のコレクションの数集めなんだから」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週末の昼下がり、近所の河川敷で子供と一緒に珍しい形の石集めに熱中した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "大騒ぎをして買集めたであらうあれ等のお土産を棚の上に置いて、かうしていぎたなく眠つてゐる人間といふものは、思へば滑稽なものではないか。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その泣菫氏の自選詩集には、僕が昔愛讀した詩が殆んど皆オミツトされ、僕の嫌ひだつた詩ばかりがしかも多くの斧鉞を加へて集めてある。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんど河出書房から、近作だけを集めた「女の決闘」という創作集が出版せられた。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長は、全校の生徒を講堂に集めて、おわびをした。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大隅君が北京から、やって来るというので、家の者が、四、五日前から、野菜やさかなを少しずつ買い集め貯蔵して置いたのだ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私は三人の弟を集めた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "車窓偶感の掻き集めに過ぎざるものぞ！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼が石を集め、苔を植ゑて庭を造り楽しむ時、しばしばその自己流の道楽芸が専門の庭園師を嘆息させるほど、真にユニイクな芸術創作となるのである。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "無色の液体を二種混合するとたちまち赤や黄に変り、次に第三の液を加えるとまた無色になると云ったようなのを幾種類か用意してもらって、近所の友達を集めては得意になって化学的デモンストラチオンをやって見せたのであった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃を見計らって箒で掃き集めると米俵に一俵くらいは容易に捕れるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして田舎で不用になっている虫送りの鐘太鼓を借り集めて来てだれでもにそれをたたかせる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの樂しみは、お天氣のよい日、腰に一瓢をさげて、劍山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて立ち上り、大きいくしやみを一つして、それから拾ひ集めた柴を脊負ひ、こそこそと林の中に這入つて行く。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれだけの煙だと、さうさね、日本の國を二十ほど寄せ集めたくらゐの廣大な場所が燃えてゐる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ともつともらしい顏で言ひ、「どれ、それではおれも刈つた柴を大急ぎで集めて、下山としようか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　彼は、最後の精力を眼に集めた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはとにかくこの人の云う通り、自分なども五十年来書物から人間から自然からこそこそ盗み集めた種に少しばかり尾鰭をつけて全部自分で発明したか、母の胎内から持って生れて来たような顔をして書いているのは全くの事実なのである。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの線が一度はどこかの郵便局へ束になって集められ、そこで選り分けられて、幾筋かの鉄道線路に流れ込み、それが途中で次々に分派して国の隅々まで拡がってゆく。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには私の過去の道筋で拾い集めて来たあらゆる宝石や土塊や草花や昆虫や、たとえそれが蚯蚓や蛆虫であろうとも一切のものを「現在の鍋」に打ち込んで煮詰めてみようと思っている。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二千年の歴史によって代表された経験的基礎を無視して他所から借り集めた風土に合わぬ材料で建てた仮小屋のような新しい哲学などはよくよく吟味しないと甚だ危ないものである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ自分の描き集めた若干の油絵だけがちょっと惜しいような気がしたのと、人から預かっていたローマ字書きの書物の原稿に責任を感じたくらいである。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳を組立てている繊維の表面はよせ集めるとなかなか広い。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この結晶の形については昔からずいぶん多数の人が研究したものであるが、近頃アメリカの人で二十年の月日をこの研究に委ね数百種の結晶の写真を集めた者がある。",
              "citation": {
                "source": "雪の話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は帯の間からハンケチを取り出して膝の上へ広げ、熱心に拾い集める。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界中のを集めています」　と言うのでありました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近在で春蚕のあがったのを買集めているところです」　有志の一人は説明した。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の農夫は次から次とせわしく落ちて来る芯を集めて、小屋のうしろの汽缶室に運びました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代りしゅっこは、そこら中を、一｜軒ごとにさそって歩いて、いいことをして見せるからあつまれと云って、まるで小さなこどもらまで、たくさん集めた。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺もう少し草｜集めて仕舞がらな、此処らに居ろ。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の欲を金に集めて、十五｜年がほどの足掻きかたとては、人には赤鬼と仇名を負せられて、五十に足らぬ生涯のほどを死灰のやうに終りたる、それが餘波の幾万金、今の玉村恭助ぬしは、其與四｜郎が聟なりけり。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
