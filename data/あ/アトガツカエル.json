        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "駐車場が満車で、後がつかえて渋滞している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "レジの係が一人しかいないので、後がつかえてお客さんが並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "前の会議が長引いて、後の予定がつかえてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "廊下の真ん中で立ち話をしているせいで、後がつかえて通れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部品供給が滞り、組み立て工程で後がつかえている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「すみません、私が手間取って後がつかえましたね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の優柔不断な態度が、プロジェクト全体の進行を滞らせ、後がつかえる原因となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「湯か」「後がつかえるから、早う入ってもらいたいが」「俺は今日は、入らん、今井さんに入れと云え」「殿様が来ておるに、湯に入って垢を落とせばええに」　武次はまだ何か云いながら往ってしまった。",
              "citation": {
                "source": "海神に祈る",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
