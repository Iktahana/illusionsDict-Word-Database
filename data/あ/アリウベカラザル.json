        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その状況はあり得べからざるものだ。",
              "source": "幻辞"
            },
            {
              "text": "常識的にあり得べからざることが起きた。",
              "source": "幻辞"
            },
            {
              "text": "科学的にあり得べからざることは存在しない。",
              "source": "幻辞"
            },
            {
              "text": "人間がそこまで堕落するのはあり得べからざる。",
              "source": "幻辞"
            },
            {
              "text": "法的にあり得べからざる判決が下った。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざる奇跡が起こった。",
              "source": "幻辞"
            },
            {
              "text": "医学的にあり得べからざる回復を遂げた。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざる偶然が重なった。",
              "source": "幻辞"
            },
            {
              "text": "倫理的にあり得べからざる行為だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざる状況が続いている。",
              "source": "幻辞"
            },
            {
              "text": "歴史上あり得べからざる転機が訪れた。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざるミスが発生した。",
              "source": "幻辞"
            },
            {
              "text": "常識に反するあり得べからざることだ。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざる幸運に恵まれた。",
              "source": "幻辞"
            },
            {
              "text": "技術的にあり得べからざるとは言い切れない。",
              "source": "幻辞"
            },
            {
              "text": "人生経験の中でもあり得べからざる出来事だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざる合致が生まれた。",
              "source": "幻辞"
            },
            {
              "text": "物理的にあり得べからざるはずだ。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざる困難に直面した。",
              "source": "幻辞"
            },
            {
              "text": "あり得べからざるシナリオまで想定すべき。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あり得べからざることだ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、人間印象があつて観念がないといふことはあるけれど、実際云つて観念があつて印象がないといふことはあり得べからざることであるに鑑み、詩が小説よりも観念寄りといふよりは寧ろ印象寄りの仕事であることからして、詩がもつとよく開拓せられてから小説が関心されに到ることが物の順序でもあつたであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史上の遺蹟や古美術品の案内や紹介ならばともかく、科学上の権威においてはそのような ambiguity はあり得べからざる事ではないかという人があるだろうが、不幸にして科学上の事柄でも畢竟五十歩百歩である。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしどこまでも信用の出来る案内者はあり得べからざるものである。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「我れの欲する所は必ず他人の欲する所」といふのが彼の獨斷的の固い信念であるからして、他人が自分と同意しない意見や趣味をもつであらうといふことは、天地が逆さになるほどあり得べからざることなのだ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴夫人の己れと握手する事はあり得べからざるように思いおるゆえ驚きしなり。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば私の持つ普通の幸福を土灰にし去り、世にあり得べからざる幸福をちらと覗かせて、私の現実生活に対する情熱を中途半端なものにしてしまったからである。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あり得べからざる話を聴かされて、わたしも何だか夢のような心持になって来ました。",
              "citation": {
                "source": "白髪鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――御覧な、あの数々のものの、剛健な、あり得べき夢とあり得べからざる夢の間に、忽然と展いた通りを。",
              "citation": {
                "source": "花束一つ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは彼女の虚栄から言っても、あり得べからざることだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "現に私だって今ここに書こうとすることよりも百倍も不思議な、あり得べからざる「事」に数多く出会っている。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "南方先生裸で寝て居る所へ、禁酒家の娘が百万円持参で、押し付け娵入りに推し懸くるところを見た人はという事ほど、さようにあり得べからざる事である。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大和本草』に津軽に果然の自生ありと出づるがどうもあり得べからざる事で、『また仙猴、その鼻孔天に向う、雨ふる時は長い尾で鼻孔を塞ぐ、群行するに、老者は前に、少者は後にす。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって「あり得べからざる事」などという不思議な出来事ではないかも知れませんが、前にも申上げました通り、わたくし自身が現在立会ったのでございますから、嘘や作り話でないことだけは、確かにお受け合い申します。",
              "citation": {
                "source": "停車場の少女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "話はだんだん佳境に入って到底あり得べからざるような話に進んでいった。",
              "citation": {
                "source": "現下文壇と探偵小説",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがつて「あり得べからざる事」などといふ不思議な出来事ではないかも知れませんが、前にも申上げました通り、わたくし自身が現在｜立会つたのでございますから、嘘や作り話でないことだけは、確にお受合ひ申します。",
              "citation": {
                "source": "停車場の少女",
                "author": "――「近代異妖編」",
                "note": "青空文庫"
              }
            },
            {
              "text": "血色は優れず、両の眼玉は、あり得べからざるものの姿でも見た人のように、空ろに見開かれて、食器をとる手は、内心の亢奮を包み切れずか絶えず小刻に顫えていた。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "重力の方の変動も、あまりに数値が大きいので勿論あり得べからざることだ。",
              "citation": {
                "source": "科学者と夜店商人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……その途端に、わたしの見ている前で、あり得べからざることが起った。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この種の理想は人間の到底経験すべからざること、あるいは実際あり得べからざることを詠みたるものこれなり。",
              "citation": {
                "source": "俳人蕪村",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はただ事実のありのままを書くだけであって、決して少しの誇張も潤色もしないつもりであるが、読者は、こんな話はあり得べからざることだと思われるかもしれない。",
              "citation": {
                "source": "犬神",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "集団農場から、箇別農場への転落というのは、ブルジュア新聞にさえ書いてない、あり得べからざる事実の間違いだ。",
              "citation": {
                "source": "反動ジャーナリズムのチェーン・ストア",
                "author": "――森鶴子君に答える――",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇中劇などと逃げを打って、イヤに比喩めかして、あり得べからざる安易さで革命をこねあげて見せている。",
              "citation": {
                "source": "五ヵ年計画とソヴェトの芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに隠され、かくまわれていた秘密、或は神秘と呼ぶべきことが、これほど偶然の機会で明されるのかと思うと、スーラーブは、妙に、信じかね、あり得べからざることのように感じずにはいられない。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜のうちに富士のお山の五合目あたりまで行くということは、この時代としてはあり得べからざることで、驚く方が当然であった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――や、これはどないしたこつちやろ、大凶と出たわ、へえ、……」　と、呆れかへつて、私の顔を打守つてゐたが、「――あほらしい、こんなことあるはずない、をかしい、ほんまにをかしすぎる」　さもあり得べからざる変事が起つたのに、胆をつぶして了つた形であつた。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして最前のように「アッ……お兄様ッ……」と叫んで飛び付いて来はしまいか……というような、あり得べからざる予感に全神経を襲われつづけていたのであった。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて初めて馬に乗るものの為に乗馬の心得が浴場の壁に掛けてあつたとしても必ずしもあり得べからざる事でもない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでこの小説は、あり得べからざる殺害行為を説明せんがための、精緻な深刻な心理解剖である。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてここでも、一足とびに結論をいえば、この小説はあり得べからざる恋愛の精妙な心理解剖である。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
