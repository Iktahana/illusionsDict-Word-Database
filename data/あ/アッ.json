    "definitions": [
      {
        "index": 1,
        "gloss": "ah",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あっ、忘れた！",
              "source": "幻辞"
            },
            {
              "text": "あっ、もう時間だ。",
              "source": "幻辞"
            },
            {
              "text": "あっ、危ない！",
              "source": "幻辞"
            },
            {
              "text": "あっ、見つけた！",
              "source": "幻辞"
            },
            {
              "text": "あっ、そっか！",
              "source": "幻辞"
            },
            {
              "text": "あっ、そういえばそうだった。",
              "source": "幻辞"
            },
            {
              "text": "あっ、誰だ！",
              "source": "幻辞"
            },
            {
              "text": "あっ、盗まれた。",
              "source": "幻辞"
            },
            {
              "text": "あっ、そうなんですか。",
              "source": "幻辞"
            },
            {
              "text": "あっ、ありがとうございます。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "初めからボヘミアンであったヘルンは、晩年においてもなおボヘミアンであり、永遠に故郷を持たない浦島だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸当初の日に一瞥して嘔吐を催し、現代日本の醜悪面を代表する都会と罵り、世界のどんな汚い俗悪の都市より、もっと殺風景で非芸術的な都市と評した東京は、彼が死んでも住みたくない所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼の夫人にとって――世の多くの若い女性と同じく――東京はあこがれの都であり、そこでの生活は一生最高の理想であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻を愛称して『小サイ可愛イママサマ』と呼んでるヘルンは、同時にいかにまた子煩悩であったかが解る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "オババサマとは彼の妻の母であって、名義上、小泉家の養子たる彼にとっては、姑の義母に当る老婦人である。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姑の婦人もまた、旧武士の家庭に育った士族の娘で、純日本風の礼儀正しき教育を受け、かつ極めて善良に優しい心根の人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの生活様式は、全く純日本風であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の知人を訪問しても、洋風の応接間などに通されると、帰ってからも甚だ不機嫌であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の日本は、文明開化の欧米心酔時代であったので、至るところ、彼はそうした不機嫌の目に逢わされた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『野蛮人』という言葉は、彼の語藻において『西洋人』と同字義であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたヘルンの生活は、極めて質素のものであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは本土との交通がほとんどなく、少数の貧しい漁夫たちが、所々の寂しい山蔭に住んでるような、暗く荒寥とした島嶼であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり一口にいえば、今の日本の若い娘たちが、最も退屈を感じて『詰まンないの』というような場所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある時、ヘルンが案内して連れ出した所は、暗い闇夜の野道の中に、小高い丘があるばかりで、周囲は一面の稲田であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは昔の旗本が住んでた屋敷で、大きな武家風の門があり、庭には蓮池などがあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の仲の好い成人が、子供の片言のようなことをしゃべり合って、何時間もの長い間、笑ったり戯れたりしている風景こそ、おそらく真にフェアリイランド的であったろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ家の中に住んでる家族の者にさえも、ほとんど全く解らない不思議な言葉で、何時間も倦きずに睦じく語り合ってた二人の男女こそ、この世における最も理想的に幸福な夫婦であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてヘルン夫妻の生活が、正にそうした通りの理想であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の愛人同士は、周囲に多くの人々が住んでる環境に居て、しかも無人島に居る二人だけの会話を会話し、二人だけの生活を自由に享楽していたのであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私この小泉八雲、日本人よりも本当の日本を愛するのです』と言ったヘルンは、真に日本を熱愛した詩人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした八雲の心理は、我が子の魯鈍に幻滅を感じてる親が、他人から、その愛児の悪評を聞いて怒る心理と、よく似たものであったと思われる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本が西洋臭くなり日本の文化や風俗やが、日々にますます欧米化して来ることは、ヘルンにとって忍びがたい悲哀であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした彼は、事実上において熱心な仏教信者でもあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺は庭が広く、背後に老杉の茂った林があったので、彼の瞑想的な散歩に最も好ましい所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の文学は、本質的に我が『方丈記』や『徒然草』の類と同じく、仏教的無常観によった『遁世者の文学』であり、ヘルン自身がまた現実の『遁世者』であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の住持になって世を隠遁し、読経と墓掃除に余生を送りたいといった彼の言葉は、決して一時の戯れではなく、彼の心の無限の悲哀を告白した言葉であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならそれは、どんな貞淑に行き届いた妻の奉仕も、決して慰めることのできないものであったからだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
