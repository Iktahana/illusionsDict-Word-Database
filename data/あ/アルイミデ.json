    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in a sense",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これはある意味で革新的なアプローチです。",
              "source": "幻辞"
            },
            {
              "text": "その戦略はある意味で危険な賭けだ。",
              "source": "幻辞"
            },
            {
              "text": "このプロジェクトはある意味で社会的責任がある。",
              "source": "幻辞"
            },
            {
              "text": "医学的にはある意味で予防が最良の治療だ。",
              "source": "幻辞"
            },
            {
              "text": "学校教育はある意味で社会形成の基盤だ。",
              "source": "幻辞"
            },
            {
              "text": "会社組織はある意味で家族のような構造を持つ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツはある意味で人間の本質を表現する。",
              "source": "幻辞"
            },
            {
              "text": "技術革新はある意味で人類の進化だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的事件はある意味で時代の転換点となる。",
              "source": "幻辞"
            },
            {
              "text": "法制度はある意味で社会契約の具現化だ。",
              "source": "幻辞"
            },
            {
              "text": "経済活動はある意味で人間の欲望の表れだ。",
              "source": "幻辞"
            },
            {
              "text": "芸術作品はある意味で時代精神の鏡だ。",
              "source": "幻辞"
            },
            {
              "text": "文学的表現はある意味で真実の探求だ。",
              "source": "幻辞"
            },
            {
              "text": "自然現象はある意味で物理法則の実証だ。",
              "source": "幻辞"
            },
            {
              "text": "人間関係はある意味で複雑な化学反応だ。",
              "source": "幻辞"
            },
            {
              "text": "食文化はある意味で地域文明の歴史だ。",
              "source": "幻辞"
            },
            {
              "text": "ファッションはある意味で自己表現の手段だ。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ戦略はある意味で軍事戦術と似ている。",
              "source": "幻辞"
            },
            {
              "text": "消費行動はある意味で心理状態の表現だ。",
              "source": "幻辞"
            },
            {
              "text": "環境問題はある意味で人類共通の課題だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二　暦の上の春と、気候の春とはある意味では没交渉である。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "颱風に関する気象学者の研究はある意味では今日でもかなり進歩している。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "哲学上の言葉は概念的抽象的であるからある意味ではかえって翻訳とその通用とが容易であるとも考えられる。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "次には、『桜陰比事』に最も明白に現われている西鶴の「探偵趣味」とも称すべきものが、これもまたある意味では西鶴の中の科学者の面貌を露出したものと云われるであろう。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに西鶴が冷静｜不羈な自分自身の眼で事物の真相を洞察し、実証のない存在を蹴飛ばして眼前現存の事実の上に立って世界の縮図を書き上げようとしている点が、ある意味で科学的と云っても大した不都合はないと思われる。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく、物理学で出逢う種々の方則等はある意味で非常に抽象的なものであって、吾人の眼前にある具体的な、ありのままの自然そのものに直接そっくり当て嵌められるようなものはほとんどないとも云われる。",
              "citation": {
                "source": "物理学実験の教授について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前にも云った通り、作物の舞台面に出ているものは所知者ばかりであり、所知者ばかりの世界はある意味で科学の世界であるからである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際波はある意味で生きている。",
              "citation": {
                "source": "夏の小半日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "観者に関するあらゆる絶対性を打破する事によって現出された客観的実在は、ある意味で却って絶対なものになったと云ってもよい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では野蛮でブルータルであると同時に一方ではまた新鮮で明朗で逞しい美しさがないとは云われない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもある意味では世界中の文明人が今現にやっている習俗と同じ事である。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では変化し過ぎて困るかもしれない。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もほんとうに絵を味わい楽しむためには、ある意味での批評をしなければならない事は勿論であるが、しかし、意識的に批評のための批評をしようという心持があっては、芸術品を楽しみ味わう邪魔になるばかりでなく、却って本当の正しい批評をすることの障碍になりはしまいか。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある意味では広いと見えます。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "盆栽生け花のごときも、また日本人にとっては庭園の延長でありまたある意味で圧縮でもある。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人の遊楽の中でもいわゆる花見遊山はある意味では庭園の拡張である。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなはだ無意味でつまらないようである意味で非常に進歩しているのはアメリカのナンセンス映画やミュージカル・コメディの類である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてある意味で活動映画の先駆者と見なしてもよいものである。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらはある意味ではたしかにききめはあった。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯浅氏の回顧陳列もある意味で日本洋画界の歴史の側面を示すものである。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "川端竜子の絵もある意味であたまは働いているが、いつも少し見当のちがったほうへ働いていはしないか。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六「中等教科書に現われた物理ほど非物理的な物理はない」こんなパラドクシカルな事もある意味では言えない事はない。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この文辞の間にはラスキンの癇癪から出た皮肉も交じってはいるが、ともかくもある意味ではやはり思想上の浅草紙の弁護のようにも思われる。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事はある意味では器械的であるが一つ一つの記録を読んで行くうちに昔の江戸の生活が、小説や歴史の書物で見るよりも遥かに如実に窺われて実に面白かった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍国の兵力の強さもある意味ではどれだけ多くの火薬やガソリンや石炭や重油の煙を作り得るかという点に関係するように思われる。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "不可能でないのみならずある程度までのある意味での理解はかえってきわめて容易な事かもしれない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その波の量子エネルギーを定める振動数はある意味での量子の「形」とも見られるのではあるまいか。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際昔も今も、科学の前衛線に立って何か一つの新しき道を開いた第一流の学者たちは、ある意味でルクレチウスの後裔であった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろいことには、また一方で、自然界に存する実際のすべての波動はやはり「虚成分」をもっていて、これが減衰を支配し、ある意味ではまた拡散をも意味する。",
              "citation": {
                "source": "自然界の縞模様",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはある意味ではほんとうだと思われる。",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
