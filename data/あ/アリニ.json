        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "蟻がありの荷を背負って行列している。",
              "source": "幻辞"
            },
            {
              "text": "小さい蟻でもありの荷を運べる。",
              "source": "幻辞"
            },
            {
              "text": "夏の庭でありの荷を観察した。",
              "source": "幻辞"
            },
            {
              "text": "ありの荷の大きさは体の数倍だ。",
              "source": "幻辞"
            },
            {
              "text": "蟻の社会ではありの荷が命を支える。",
              "source": "幻辞"
            },
            {
              "text": "教科書にありの荷について説明がある。",
              "source": "幻辞"
            },
            {
              "text": "昆虫学者がありの荷の重さを測定した。",
              "source": "幻辞"
            },
            {
              "text": "子どもたちは蟻のありの荷に驚いた。",
              "source": "幻辞"
            },
            {
              "text": "自然ドキュメンタリーでありの荷が映された。",
              "source": "幻辞"
            },
            {
              "text": "蟻のありの荷から学べることが多い。",
              "source": "幻辞"
            },
            {
              "text": "庭で見つけた蟻の行列のありの荷がすごい。",
              "source": "幻辞"
            },
            {
              "text": "スポーツの練習でありの荷の話が比喩として使われた。",
              "source": "幻辞"
            },
            {
              "text": "蟻の巣の内部ではありの荷の運搬が絶えない。",
              "source": "幻辞"
            },
            {
              "text": "顕微鏡でありの荷の詳細が見える。",
              "source": "幻辞"
            },
            {
              "text": "蟻のありの荷の効率性は驚異的だ。",
              "source": "幻辞"
            },
            {
              "text": "生物の授業でありの荷を例に挙げた。",
              "source": "幻辞"
            },
            {
              "text": "アリの勤勉さはありの荷の運搬に表れている。",
              "source": "幻辞"
            },
            {
              "text": "研究室でありの荷の運搬メカニズムを研究した。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にありの荷は多くの文献に記述されている。",
              "source": "幻辞"
            },
            {
              "text": "食物連鎖におけるありの荷の役割は重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "機会宮沢賢治恋のはじめのおとなひはかの青春に来りけりおなじき第二神来は蒼き上着にありにけりその第三は諸人の栄誉のなかに来りけりいまおゝその四愛憐は何たるぼろの中に来しぞも",
              "citation": {
                "source": "機会",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのも大概は科学者自身に筆を執らせてそれを掲載するという賢明な方法をとっているので、そんな滑稽な記事はありにくいわけである。",
              "citation": {
                "source": "ジャーナリズム雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから、はがきの文句ですが、これからは、用事これありに付き、明日出頭すべしと書いてどうでしょう。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬の長門峡長門峡に、水は流れてありにけり。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は、恰も魂あるものの如く、流れ流れてありにけり。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――あなたは世を捨てた事はおありにならないし、またそうせよとお勧めするわけではありませんが、実際体験の上から申すと、世を捨てる程この世の中で働き宜くもなるし、また働きも出来るのです。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから、はがきの文句ですが、これからは、用事これありに付き、明日出頭すべしと書いてどうでせう。",
              "citation": {
                "source": "どんぐりと山猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あなたに、もしや、お兄さんが一人おありになりはしませんでしたろうか？",
              "citation": {
                "source": "恋",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "上諏訪へいらしたことがおありになって？",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「『あやかしの鼓』というのがこちらにおありになるそうですが……」　妻木君の笑顔がフッと消えた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に打つらしいのです」「ヘエ……途中で眼のさめるようなことはおありになりませんか」「ええ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御病身で、癇癖がお強く、御鞠の御名人で、しかも世に例のなかつたほどの美貌でいらつしやつたとか、そんな事くらゐを人から聞かされてゐる程度でございますが、いづれは非凡の御手腕もおありになつたお方に違ひございません。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にもちよつと申し上げましたが、この御台所さまは、かしこきあたりとも御姻戚関係がおありになる京の御名家、坊門信清さまの御女子にて、元久元年、御年十三にして当将軍家へ御輿入に相成りました由にございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの……此店に……」　若い女房が顔を見ると、いま小刻みに、長襦袢の色か、下着の褄か、はらはらと散りつつ急いで入った、息づかいが胸に動いて、頬の半※が少し揺れて、「辻町、糸七の――『たそがれ』――というのがおありになって。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何しろこの雪でしょう、それに私などと違って、あなたはお勤めがおありになりますから。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳河女学校にて額髪の笑ふ女童このごとくあどなきものを恋ふとありにし我老いぬただに愛しき額髪の面あげてあるその子ら見れば夏ごろも匂ふ少女は朝ひらくからたちの花と清しかるべし中学伝習館にて我、中学伝習館を学業卒へずして去りぬ。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "王さまは今ではよほど年を取ってお出でになるのですが、まだこれまで一度も王妃がおありになりませんでした。",
              "citation": {
                "source": "黄金鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかでの室、へびの室一　この大国主神には、八十神といって、何十人というほどの、おおぜいのごきょうだいがおありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かわけがおありになるのでございますか。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇にはお子さまが十二人おありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は、もはや三年もごちょう愛になっていた皇后でおありになるうえに、たまたまお身持ちでいらっしゃるものですから、いっそうおかわいそうにおぼしめして、どうか皇后のお身におけががないようにと、それからは、とりでもただ遠まきにして、むやみに攻め落とさないように、とくにご命令をおくだしになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い鳥一　第十二代｜景行天皇は、お身の丈が一｜丈二｜寸、おひざから下が四｜尺一寸もおありになるほどの、偉大なお体格でいらっしゃいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇には、すべてで、皇子が十一人、皇女が十五人おありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばお宮が破れこわれても、お手もとにはそれをおつくろいになるご費用もおありになりませんでした。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほかにはけっしてなんのわけもおありにはなりません。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鈴小鈴一　仁徳天皇には皇子が五人、皇女が一人おありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇はお身のたけが九｜尺二寸五｜分、お歯の長さが一｜寸、幅が二｜分おありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "天皇は、もとからある不治のご病気がおありになりましたので、このからだでは位にのぼることはできないとおっしゃって、はじめには固くご辞退になりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　軽皇子には、軽大郎女とおっしゃるたいそう仲のよいご同腹のお妹さまがおありになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
