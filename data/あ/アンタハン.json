        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんたはん、ちょっとお手伝いしていただけますか？",
              "source": "幻辞"
            },
            {
              "text": "大阪弁で「あんたはん」と呼びかけるのは親しみがある。",
              "source": "幻辞"
            },
            {
              "text": "あんたはんのご意見をお聞かせください。",
              "source": "幻辞"
            },
            {
              "text": "京都の茶屋でおかみさんが「あんたはん」と呼んでいた。",
              "source": "幻辞"
            },
            {
              "text": "関西地方ではあんたはんという表現がよく使われる。",
              "source": "幻辞"
            },
            {
              "text": "あんたはん、これは本当の話ですか？",
              "source": "幻辞"
            },
            {
              "text": "あんたはんにお願いがあるのですが。",
              "source": "幻辞"
            },
            {
              "text": "商家の店主は常連を「あんたはん」と呼んでいた。",
              "source": "幻辞"
            },
            {
              "text": "古い映画ではあんたはんという言葉が頻繁に出てくる。",
              "source": "幻辞"
            },
            {
              "text": "あんたはん、仕事のやり方を教えてもらえませんか？",
              "source": "幻辞"
            },
            {
              "text": "関西の方言「あんたはん」は敬意と親しみを表す。",
              "source": "幻辞"
            },
            {
              "text": "宿泊客に「あんたはん、お疲れさまでしたね」と言う。",
              "source": "幻辞"
            },
            {
              "text": "地域文化を学ぶためにあんたはんという言葉の歴史を調べた。",
              "source": "幻辞"
            },
            {
              "text": "あんたはん、どこまでその重い荷物を運ぶのですか？",
              "source": "幻辞"
            },
            {
              "text": "老舗のお店ではあんたはんという呼び方が今も生きている。",
              "source": "幻辞"
            },
            {
              "text": "文学研究であんたはんのような方言的敬語を分析する。",
              "source": "幻辞"
            },
            {
              "text": "旅行で関西を訪れて「あんたはん」を生で聞いた。",
              "source": "幻辞"
            },
            {
              "text": "NHKの朝ドラでもあんたはんのような方言が使われていた。",
              "source": "幻辞"
            },
            {
              "text": "店員が顧客に「あんたはんのお好みはどちらですか？」と聞く。",
              "source": "幻辞"
            },
            {
              "text": "あんたはん、この紋紗の名前を知っていますか？",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "彼は五円紙幣を無雑作に恵まれて驚き、「あんたはん。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "登勢はえくぼを見せて、それはそれは、わがまま者の伊助がいつもご厄介どした、よその人とちごて世話の掛る病いのある人どすさかいに、あんたはんかてたいてやおへんどしたやろ。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは火のついたようなあの赤児の泣声に似て、はっと固唾をのむばかりの真剣さだったから、登勢は一途にいじらしく、難を伏見の薩摩屋敷にのがれた坂本がやがてお良を娶って長崎へ下る時、あんたはんもしこの娘を不仕合せにおしやしたらあてが怖おっせと、ついぞない強い眼でじっと坂本を見つめた。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたはん、どないおしやすか」「お母ちゃん、あて、かなわんのどっせ。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "取次の女中へ何かいう、浅間な住居で、手に取るような、その「あんたはん、居やはりますか。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なぞといって、まじくないながら、とつおいつのうち、お絹が、四五人で客に連れられて来たのだけれど、いまは旅館に一人で残った……（早う、あんたはんの許へ来とうて、来とうてな。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたはんに恥を掻かせた、済まんなあ、……生命の親え。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何もな、何も知らんのえ、私路之助はんのは、あんたはん、ようお馴染の――源太はん、帯が弛む――いわはった妓どすの。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、斜にそむいて、「あんたはんまで、そない言わはる、口惜いえ。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんたはん、のましてくりゃはりますか。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「嬉しいな、段で、抱いてくれやはった時から、あんたはんは生命の親どす。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんたはんがな。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は重ねて、それを小供に与えよと言いけるに、始めて安堵したるらしく、幾度か押し戴くさまの見るに堪えず、障子をしめて中に入り、暫くして外出せんとしたるに、宿の主婦は訝りつつ、「あんたはんじゃおまへんか先刻女の乞食にお金をやりはったのは」という。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたはん、この次一人でおいでやすや。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、すっぽんどっせ、あんたはん。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ、あんたはんのお言いやす通り蟇蛙かもしれまへんけどな……」件の男はむくれ気味の博士の顔色を、半ば気味悪そうに、半ば冷かしに見返しながら言いました。",
              "citation": {
                "source": "初蛙",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それなら、あんたはん抛つといて私ら行つて来ますえ。",
              "citation": {
                "source": "悲しめる顔",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたはんのはいいが、これは少し青いぢやありませんか。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "えらい綺麗な子を、あんたはんお連れなさつたと思ひましたら。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうです女将さん、当りますか」　片手をひろ子に執られたまんま、息をのむようにし、「こわいもんどすなあ」　そして、本気に、「あんたはん、ほんまに手相お見やすのんどすか？",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、ヤリテ婆が出て来て、　――あんたはん、この妓に床をつけてやっておくんなはれ、でないと女郎屋の規則としてお金とる訳に行きませんよって――　と、泣かんばかりで妓を庇護したことがある。",
              "citation": {
                "source": "苦力頭の表情",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "京言葉「なあ、へ　×はん」「あんたはん、お見いしまへんのか」「あほくさ！",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それより、あんたはん奧さんおまツしやろ、お子さんも。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたはん、そや、キビスをこする石やつたのに、まア、どうしようかいの」　見るも無惨な凸凹の瘡蓋になつた私の顔に姉は膏薬を塗つてくれながらへんな苦が笑ひをした。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、あんたはん、あげますウ。",
              "citation": {
                "source": "明治座今昔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "粋なお方や、あんたはん一つおあがりなはツとくれやす。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あのわるさがお伊勢參りするんや言うてきゝまへんので若い衆も連れて下さりますさうで、いづれまア、あんたはんの御厄介や思うて、お頼みに參じました。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まア、ほんまや、あんたはん千里眼だツかいな。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "粹なお方や、あんたはん一つおあがりなはツとくれやす。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし、あんたはん！",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
