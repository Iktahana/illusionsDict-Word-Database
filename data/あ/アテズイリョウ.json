[
  {
    "uuid": "0949b146-6d8f-543c-8f97-cdcbc55d1894",
    "entry": "当て推量",
    "reading": {
      "primary": "あてずいりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
