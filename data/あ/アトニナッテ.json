[
  {
    "uuid": "aa9f2b75-1edc-5634-b42f-2e2a3712284a",
    "entry": "後になって",
    "reading": {
      "primary": "あとになって",
      "alternatives": [
        "のちになって"
      ],
      "is_heteronym": false
