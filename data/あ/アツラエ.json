[
  {
    "uuid": "7f5189d3-3504-56bc-b52e-7f72fdaf6491",
    "entry": "誂え",
    "reading": {
      "primary": "あつらえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
