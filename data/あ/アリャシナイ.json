        "examples": {
          "standard": [
            {
              "text": "そんな簡単なことありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "彼がそんなことするはずありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "このビジネスが成功するはずありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "医学的にそんな治療法ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "学校でそんなルールありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "社会常識でそんなことありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "スポーツのルールでそんなプレーありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "法律上そんな権利ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にそんな記録ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "科学的にそんな証拠ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "料理の基本でそんなテクニックありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "文学的にそんな表現ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "技術的にそんな機能ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "自然界にそんな生き物ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "経済学的にそんな理論ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "建築学的にそんな設計ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "音楽理論でそんなコードありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "美術的にそんな色合いありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "心理学的にそんな反応ありゃしない。",
              "source": "幻辞"
            },
            {
              "text": "地理的にそんな場所ありゃしない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "いや、面白くも何んともありゃしない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな顔になっちゃあ為方はありゃしない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにゆうべ夢に見たから、何事かありゃしないかというのですよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "己の処には何んにもありゃしない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も関係ありゃしないんです。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "利益は何にもありゃしない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱だ何でもありゃしない！",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳にとっては、いなかで十日ばかりいっしょに遊んだ松吉や杉作は、なんでもありゃしないんだと。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともちゃん、おまえのその帯の間に、マドンナの胸の肉を少しばかり買う金がありゃしないか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいら勝手に好な真似はしてるけれど、友達も何もありゃしないやな。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冗談じゃないや、アラスカなんか行くとこはありゃしない。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "余計な耳を押立てて、垂頬で、ぶよぶよッちゃアありゃしない。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙の名残は瞳の艶、莞爾と打微笑み、「二人とも強いんですもの、乱暴ッちゃありゃしない。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若ーさんはあんなお人よしで独りでよがっているんだし、たまに逢うくらい何でもありゃしない。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前はんに纏まった金を拵えろと言ってみたところで、出来る気遣いはありゃしない。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、そんな話はおもしろくなんかありゃしない、と、ドブネズミたちは言うのです。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「森の外には、なんにもありゃしない」と、カタツムリのおとうさんは言いました。",
              "citation": {
                "source": "幸福な一家",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのからだの中にはね、わるい血なんか、一てきも、ありゃしないんだよ。",
              "citation": {
                "source": "アヒルの庭で",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供と爺さんが夫から先どうなったにも、こうなったにも丸で頭も尻尾もありゃしない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけもなんにもありゃしない。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世の中に、理想なんて、ありゃしない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなへんてこな話は、ありゃしないよ。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも珍しい事なんかありゃしない。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "河野は急に景気づいて、「何、無いことはありゃしない。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、だって君、突込んであるんじゃないか、池の坊も遠州もありゃしない。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれッきり、座敷へなり、納戸へなりのたくり込めば、一も二もありゃしない。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だって、女学校を出たきりで、特別になんの学問もありゃしない。",
              "citation": {
                "source": "皮膚と心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャングだの、低脳記者だの、ろくなものありゃしない。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
