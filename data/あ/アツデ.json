    },
    "definitions": [
      {
        "index": 1,
        "gloss": "thick (paper, cloth, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今年の冬は特に寒いらしいから、厚手のコートを買わないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "名刺には、触った瞬間に質感の違いがわかるような厚手の用紙を選びたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "水彩画を描くのに適した、にじみにくい厚手の画用紙を探しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "農作業で使う作業着は、すぐに破れないように厚手の丈夫な生地で作られている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "輸送中に破損しないよう、壊れやすい品物は厚手の緩衝材で丁寧に包む必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "肌寒い朝は、肌触りの良い厚手のスウェットシャツを着てリラックスするのが好きだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "すでに想念に浮ぶ厚手の花の形と薄手の花の形と、輪違いに紙の中での狂い咲き。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラスでお茶が飲みたいわけではないが、プラスティックのコップはないだろう、と慶一は、その白地に銀の幾何学模様が入った、厚手で、口のひろいコップをながめた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論厚手の織物も其間に有つたにはちがひないけれども、一般には厚手は貴ばれない。",
              "citation": {
                "source": "染織に關する文獻の研究",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひいでた眉、高い鼻、思い切って切れ長の涼しい眼、私は冷酷じゃアありませんよ、こういいたげにやや厚手の、それでいて醜くない立派な口、金持ちの証拠に耳たぶが厚く、詩人的｜気禀があるからであろう、額が広く光がある。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "服装は薄茶の厚手な背広に、同色のゴルフパンツをはき、靴下も竪縞の同色で、ひどく瀟洒としたものだ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とホームズが投げてよこしたのは、開封して卓上に置かれていた薄紅色の厚手の便せんだった。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の小さい割には、躯の厳丈づくりで、厚手に出来た唇や鼻の大きい銅色の皮膚をした彼は、惘れたような顔をして、障子も襖もびしょびしょした茶の室の入口に突立っていた。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い額に髪がふさ／＼垂れさがつて、頬が脹らんでゐるので、ちよつと四角張つたやうな輪廓だが、鼻梁が削げて、唇が厚手に出来てゐる外は、別に大して手落ちはなかつたし、ぱつちりはしないが、目も切れ長で、感じは悪くなかつた。",
              "citation": {
                "source": "チビの魂",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀の箸ででもあったら、その箸のひとあては、茶碗のふちで涼しい音でも立てるのであったろうが、雑用の厚手な茶碗と木の箸で、その音はカチとカタの間にきこえた。",
              "citation": {
                "source": "菊人形",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "異様に白く、或は金焔色に鱗片が燦めき、厚手に装飾的な感じがひろ子に支那の瑪瑙や玉の造花を連想させた。",
              "citation": {
                "source": "高台寺",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉口には看視人が一人立っていて、額に赤十字の印のついた木綿編みの厚手の白い患者帽を、めいめいに手渡すのだった。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つはともに、いささか厚手ではあるものの、正方形の紙のケースに収められていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "青磁は鐵料の還元焔達成である、胎土に鐵分があり且つ厚手である、厚手の青磁にいゝものがあるのは當時の燒成の條件が厚手でないと失敗したからで、へたにまごつくと怪しげなものをつかませられる。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つはアフリカの器らしい厚手の水指と、支那の慶磁の白い湯呑、それに日本物では紫野の茶碗、その横に朝鮮の鶏龍の蓋物の鉢が一つ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は朝のうちから、女中達はそわそわしてゐたが、めいめい他所行に着換へ、厚手に白粉を塗つて、三田を促してうちを出た。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うように、少し厚手の唇を洩れ、時々見える歯並びのよさ、老人などとは思われない。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "向かい合っている醍醐弦四郎も、一種剛強の人物らしく、太い眉に釣り上った眼、むっと結んだ厚手の唇、鉄のように張った胸板など、堂々とした風采ではあったが、碩寿翁にかかっては及ぶべくもないのか、たじろいだような格好に、卓から一二歩後ろへ離れた。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤンニングスの厚手な、暖みのある、而して単純な心の老爺よくやって居た。",
              "citation": {
                "source": "日記",
                "author": "一九二六年（大正十五年・昭和元年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころきれいなのは水きわの崖などに、ショウジョウバカマという山の草が紫っぽいあかい花をつけ、又カタクリのかわいい紫の花が、厚手の葉にかこまれて一草一花、谷地にさき、時として足のふみ場もないほどの群落をなして、みごとなこともある。",
              "citation": {
                "source": "山の春",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの有名な僞石器製作家フリント・ヂヤックは一本の鐵の細い棒でかなりな所までやつてゐるが、未だ厚手のものしか出來なかつた。",
              "citation": {
                "source": "石鏃の思出話",
                "author": "濱田耕作",
                "note": "青空文庫"
              }
            },
            {
              "text": "単衣は、鶸茶にけまんを浮かせたあの厚手の吉野。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし三尺もの下壁と言わず、こまかく厚手なぶッつけ格子と言わず、がっしりとした構造は念の入ったものである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "柳やという小料理屋がありますからね、先生、このごろは柳やのおステさんと大あつあつで、いりびたりだ、かなわねえ」　駅へ行き、切符を買い、東京行きの省線に乗り、阿佐ヶ谷で降りて、北口、約一丁半、金物屋さんのところから右へ曲って半丁、柳やは、ひっそりしていた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして心理學は後の見方に沿ふて獨立の經驗科學に發達したのであつで、初期の經驗的心理學は意識内容を中心としたものである。",
              "citation": {
                "source": "知的作用と感情と",
                "author": "増田惟茂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
