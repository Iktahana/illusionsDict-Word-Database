      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "if there is a chance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あわよくば彼に会えるかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば昇進できたら嬉しい。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば優勝できたらいいな。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば賞金が獲得できたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば有名になれたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば良い結果が出たら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば再会できたら幸せだ。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば契約が成立したら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば告白が成功したら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば投資が成功したら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば誤りなく完了したら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば一発逆転できたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば新規顧客が獲得できたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば特別ボーナスが貰えたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば念願の転職ができたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば理想の人と結ばれたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば海外赴任できたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば自分の会社が持てたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば著作が出版できたら。",
              "source": "幻辞"
            },
            {
              "text": "あわよくば伝説の選手になれたら。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "清逸はそのことを責める気持はけっしてなかったけれども、父が軽薄な手段をめぐらしてその非を蔽い、あわよくば自分の要求すべき資格のないものを家族のものに要求しようとするのを見つけだすと快くなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、自分が、彼にまつわりついている間に、自分のお道化は、所謂「ワザ」では無くて、ほんものであったというよう思い込ませるようにあらゆる努力を払い、あわよくば、彼と無二の親友になってしまいたいものだ、もし、その事が皆、不可能なら、もはや、彼の死を祈るより他は無い、とさえ思いつめました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "イベットにあわよくば会えようと思って出て来たことも忘れ、彼は前後の考えもなくなり、何もかも面倒になって女をノルマンジーホテルの自分の部屋へ連れ込んで寝かして仕舞った。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄亮、あわよくば自分でも刈って見たい意気込みだったのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幕営の中に残った将士は、李陵の服装からして、彼が単身敵陣を窺ってあわよくば単于と刺違える所存に違いないことを察した。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれ共何とかして謡曲の御利益を納得させて、あわよくば一曲御所望を云わせてやろうと思う甲種熱心家が「でも高尚ではありませんか」と切り込むと、その返事は大抵「でもあの声が……」と来る。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、光秀が信長に反いたのは、平生の鬱憤を晴すと同時に、あわよくば天下を取ろうとする大志が、あったに違いない。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、大阪方としては、城濠を失っているのであるから、城を捨てて東軍を迎え撃ち、あわよくば西将軍の首級を狙う外、勝算はないわけである。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわよくば、と思っているに過ぎない。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわよくば自分も思いきりいいたい事をいってのけたかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわよくば助けてやりたかったのだ。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてあわよくば発毛剤の一罎を客に押しつけようとした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "實際、社會主義運動の中に、働くことのきらいなごろつきや食いたおしやがまじりこむと同じように、階級藝術運動の中にも、文藝のいろはもわきまえない連中が、糞眞面目な月給取商賣はいやだからというのであわよくば流行作家になりすまそうというどえらい野心を抱いて飛びこんだもののあつたことは事實である。",
              "citation": {
                "source": "文藝運動と勞働運動",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの印籠はもとよりわたしの細工もの、ちょうど手もとにあの品がござりましたゆえ、さも江戸錦様の持ち物らしく見せかけて、あのような金泥で名まえを書きこみ、あわよくば江戸錦様に罪をきせようためでござりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒色のくちびる",
                "note": "青空文庫"
              }
            },
            {
              "text": "では至急兵を募り、東ローマ皇帝と力を合わせ異教徒を征め、一には羅馬法王の勢力を強め、あわよくば東西二派に分れているキリスト教を合一させ、その元首となろう」といよいよ決心の臍を固めた。",
              "citation": {
                "source": "ローマ法王と外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「薩長土が、なんじゃ、皆幼帝をさしはさんで、己れ天下の権を取り、あわよくば徳川に代ろうという腹ではないか、虎の威を借りて、私欲を欲しいままにしようという狐どもじゃ。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしたら支那ソヴェト地方をぶっ潰すか、あわよくばソヴェト同盟もこの際ぶっ潰すかということを、熱心に研究している。",
              "citation": {
                "source": "「モダン猿蟹合戦」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "花から花へ花粉を運んで歩く蜜蜂であるが、花々の蜜の味を一つ一つ楽しむ点でこの蜜蜂は昆虫よりも多少道楽者であり、花粉を運んで歩いてあわよくば実を実らせようというたくらみのある点では、昆虫よりも知性に富んでいる。",
              "citation": {
                "source": "クリティシズムと認識論との関係",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "先方へつくと何分不案内な土地でしてな、と迎いの人に案内をさせ、あわよくばその案内人の家へ泊りこんだりして宿賃を浮かせる算段をする。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "賢を大学にやって法律家にし、あわよくば司法大臣か総理大臣にでもしようという考えから、父は、賢をまず中学に入れようとした。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわよくば仲間に引っぱり込んで仕事をさせる気でいたのでしょう。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊更に分り切った事を申立てゝ、あわよくば判官を瞞着し、拙く行っても審理を遅延させる事が出来ると考えたのか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわよくば、天空にまで昇りゆき、地の底にまで潜り込み、神の領域をも犯し、悪魔の領域をも犯さんとすること、それが彼の野心でありたい。",
              "citation": {
                "source": "ヒューメーンということに就て",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、Ramos Gimenez教授を主班とするその探検隊の目的は、以上三つの流系をしらべ、あわよくば、グラン・チャコの謎といわれる「蕨の切り株」を衝こうとするものであった。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、｜Ramos Gimenez 教授を主班とするその探検隊の目的は、以上三つの流系をしらべ、あわよくば、グラン・チャコの謎といわれる「｜蕨の切り株」を衝こうとするものであった。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だから乙骨君、僕が伸子の、開目の際を条件としたのも、つまるところは、マリア・ブルネル夫人と同じ朦朧状態を狙い、あわよくば、まさに飛び去ろうとする潜在意識を記録させようとしたからなんだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそれまで、あわよくば衝角を狙おうと、操舵していたのであったが、船長の決意は、全員の安危に白旗の信号を送ったのであった。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはその物々しい忠義｜呼わりの後に、あわよくば、家を横領しようとする野心でもあるのかも知れない。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが株屋の方はまたそれがつけ目なので、お敏を妾にする以上、必ずお島婆さんもついて来るに相違ありませんから、そこでこれには相場を占わせて、あわよくば天下を取ろうと云う、色と欲とにかけた腹らしいのです。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼はその声の方をじろりと見た、「お家を復興するという名にかくれて――あからさまに云うて進ぜよう――あわよくば家禄の恢復も、と、ゆめみておるのじゃ、万にひとつも、さよう、お慈悲によって――じゃ、秩禄を受けたとしてもそれが何程のことである？",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
