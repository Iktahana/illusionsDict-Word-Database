[
  {
    "uuid": "c09e93a0-0299-5a09-9a3b-302cc453928a",
    "entry": "あわよくば",
    "reading": {
      "primary": "あわよくば",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
