      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to be possible",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "そのようなことはあり得ることだ。",
              "source": "幻辞"
            },
            {
              "text": "多くの可能性がそこにはあり得る。",
              "source": "幻辞"
            },
            {
              "text": "人間はそう間違えることあり得る。",
              "source": "幻辞"
            },
            {
              "text": "季節的にはあり得る気象現象だ。",
              "source": "幻辞"
            },
            {
              "text": "あり得る限りの準備をしておこう。",
              "source": "幻辞"
            },
            {
              "text": "そういった可能性もあり得るかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "医学的にはあり得ることではない。",
              "source": "幻辞"
            },
            {
              "text": "あり得ることに備えるべき時だ。",
              "source": "幻辞"
            },
            {
              "text": "統計的にあり得ることは稀だ。",
              "source": "幻辞"
            },
            {
              "text": "こうした展開はあり得るシナリオだ。",
              "source": "幻辞"
            },
            {
              "text": "将来そのようなことあり得ると思う。",
              "source": "幻辞"
            },
            {
              "text": "十分あり得ることかもしれません。",
              "source": "幻辞"
            },
            {
              "text": "多くの理由がそれをあり得ることにしている。",
              "source": "幻辞"
            },
            {
              "text": "誰にでもあり得ることだと気づいた。",
              "source": "幻辞"
            },
            {
              "text": "物理法則ではあり得ないことが起きた。",
              "source": "幻辞"
            },
            {
              "text": "あり得ることばかりが起こるわけではない。",
              "source": "幻辞"
            },
            {
              "text": "少なくともあり得ることではあるだろう。",
              "source": "幻辞"
            },
            {
              "text": "あり得る可能性を見くびるなかれ。",
              "source": "幻辞"
            },
            {
              "text": "例外はあり得ることを忘れずに。",
              "source": "幻辞"
            },
            {
              "text": "ここではあり得ることだけを想定した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "勿論手記の形式を採つた作品といふものはあり得るがそれは別の話である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芥川君のあの論文、及び最近における彼の多くの感想をよんだ人は、いかに彼が純粹な詩の憧憬者であり、ただ詩的なものの中にのみ、眞の意味の文學があり得ることを、必死に力説してゐるかを知るだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで生活で敏活な人が芸術で敏活とはいかないし、芸術で敏活な人が生活では頓馬であることもあり得る。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来の如何なる「新しい詩」においても、和歌や俳句のレトリックする規範を離れて、日本語の詩があり得るとは考えられない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上品、下品とはまず物品に関する区別であり得る。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦横縞のうちでも縞の荒いいわゆる碁盤縞は「いき」の表現であり得ることがある。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてこの場合に、かような楽曲が「いき」の表現であり得る可能性は、一方に各節の起首の高音が先行の低音に対して顕著な色っぽい二元性を示していることと、他方に各節とも下向的進行によって漸消状態のさびしさをもっていることとに懸っている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ambulo が sum の認識根拠であり得るかをデカルトも論じた。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "客観的にはどんな間違ったことを書き連ねていても、その人がそういうことを信じているという事実が読者には面白い場合があり得るからである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまたこういうこともあり得る。",
              "citation": {
                "source": "観点と距離",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体どうしてそんなことがあり得るか。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、こういう代表的なアカデミックな仕事ですらも審査員の眼界があまりに狭くてその部門のその問題の他の方面にまで眼が行届かないような場合には、そこに提出された論文のせっかくの狙い所が正常の価値を認められずに軽視されることも実際にあり得るのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして科学者にとってはそれが同時に「美」であり得る。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "本質の上からはおそらく同じようなものであり得ると思われる。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ味いの無い佳作という事は容易に想定が出来ないに反し潤いの感じは無くても、佳作はあり得ると無雑作に考えられる。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケラーの主張が本当であり得るような気がすると同時に、そうであらせたいという気もした。",
              "citation": {
                "source": "鸚鵡のイズム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう特殊な条件の下に置かれた、特殊な人間の頭に映じた議会の第一印象が、かくのごとく特殊なものであり得るという事実だけは、ともかくも一つの記録としてここに誌しておくのも強ち無益の業ではあるまいと思う。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはむしろ自分のような純粋な素人の評の方が却って適切であり得るかもしれない。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに比べて芸術家が自然に対する見方は非常に多様であり得る事は勿論である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、ルブランの好い頭が如何にほんたうらしく、起り得るらしく、あり得るらしく作中の事件事實を作り出してゐようと、無論あんなものが私達の現實社會にあり得る筈はない。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、探偵小説の面白さは實際にあり得ない事があり得るらしさに近づいてゐればゐる程強められ深くなる。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこのＮＮは何がありえるか。",
              "citation": {
                "source": "三枚の学生",
                "author": "THE ADVENTURE OF THE THREE STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも私が明日死んでも、ありえることではありますが、この世での務めが、そう、きっちり果たされたと知った上で死ぬのです。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ありえる話ではある。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう、それは実際ありえると言える。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ならば、私たちが知らない力についてもまた、多くのものが真実でありえるだろう。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとすると、これは一人の人間の仕業かもしれないなどと思ったものはいなかったが、ランドリュの手帳に啓発されて、そういうこともありえると考えるようになった。",
              "citation": {
                "source": "青髯二百八十三人の妻",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かわけのわからない仕掛けでぼくがこの洞窟に入ってしまったのだとすれば、その逆の作用が働くこともありえるだろう。",
              "citation": {
                "source": "ＵＶ",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "異形のものが健常者と対等になることはありえず、ありえるのは軽蔑か畏怖のどちらかだけであり、そして実はそのふたつは同じ事柄の別な面にすぎぬのではあるが、しかしどちらの面が表に出るかということが、ことの本質以上に重大なことなのだ。",
              "citation": {
                "source": "桃太郎",
                "author": "石塚浩之",
                "note": "青空文庫"
              }
            },
            {
              "text": "［原注／付録：たとえ異なる単純観念の間でも、相互に相似や類似がありえることは明白である。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
