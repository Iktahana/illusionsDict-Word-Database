[
  {
    "uuid": "89606dd1-aa57-5929-82a4-35247500b4fd",
    "entry": "あり得る",
    "reading": {
      "primary": "ありえる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段",
