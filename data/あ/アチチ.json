    "definitions": [
      {
        "index": 1,
        "gloss": "ouch!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あちちについて考えてみました。",
              "source": "幻辞"
            },
            {
              "text": "あちちの意味を理解しました。",
              "source": "幻辞"
            },
            {
              "text": "日常生活であちちが使われています。",
              "source": "幻辞"
            },
            {
              "text": "あちちに関する知識を深めました。",
              "source": "幻辞"
            },
            {
              "text": "辞書であちちを調べました。",
              "source": "幻辞"
            },
            {
              "text": "あちちの用法について学びました。",
              "source": "幻辞"
            },
            {
              "text": "様々な分野であちちが活用されている。",
              "source": "幻辞"
            },
            {
              "text": "あちちの応用例を見つけました。",
              "source": "幻辞"
            },
            {
              "text": "専門家があちちについて論じている。",
              "source": "幻辞"
            },
            {
              "text": "あちちについての研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "教育の場であちちが教えられている。",
              "source": "幻辞"
            },
            {
              "text": "あちちの歴史を追うことは興味深い。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からあちちを理解する。",
              "source": "幻辞"
            },
            {
              "text": "あちちの変化に気づきました。",
              "source": "幻辞"
            },
            {
              "text": "言語や文化におけるあちちの重要性。",
              "source": "幻辞"
            },
            {
              "text": "分析結果からあちちの特性がわかった。",
              "source": "幻辞"
            },
            {
              "text": "一般的なあちちの使い方を習得しました。",
              "source": "幻辞"
            },
            {
              "text": "複雑なあちちの概念を説明する。",
              "source": "幻辞"
            },
            {
              "text": "あちちに関連する他の用語がある。",
              "source": "幻辞"
            },
            {
              "text": "最新のあちちに関する情報を入手した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あちちちち、ひでえ、あちちちち、助けてくれ、柴が燃えてる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、父のおっしゃる言葉をちっとも聞こうとなさらず、腕を伸ばして私の傍の七輪のお鍋を、どさんと下におろして、あちちと言って右手の親指と人さし指を唇に押し当て、「おう熱い、やけどしちゃった。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "薬鑵は顛倒して濛々たる湯気が部屋に立ちこもり、先生は、「あちちちちち。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あちちち」と顔を皺めて、「痛い事をなさるねえ！",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "白いお馬は、主かいな今宵帰して、いつの日か濡れにくるかや、しっぽりと抱いて、あかした移り香のさめて、果敢なや、肌寒の朝の廓の霜景色霜にまごうか白い馬「とくらあ――あちちちち」　一人の若い衆が、湯の中から、飛上った。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが“あちちち”さ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あちちちちッ」義眼はあつくなっていて、彼の手を焼いた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちち」　艇長は、コーヒー茶碗のふちで、口をやいたので、あわててそれをがちゃんと下においた。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
