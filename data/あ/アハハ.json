        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子どもたちの無邪気な「あはは」という笑い声が聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "彼女はジョークを聞いて「あはは」と大笑いした。",
              "source": "幻辞"
            },
            {
              "text": "テレビのコメディを見て家族全員が「あはは」と笑った。",
              "source": "幻辞"
            },
            {
              "text": "部長のしゃれに部下たちが「あはは」と応じた。",
              "source": "幻辞"
            },
            {
              "text": "友人の失敗談を聞いて、つい「あはは」と笑ってしまった。",
              "source": "幻辞"
            },
            {
              "text": "面白い映画を見ながら「あはは」と笑い続けた。",
              "source": "幻辞"
            },
            {
              "text": "赤ちゃんが「あはは」と声を出して笑う様子はかわいい。",
              "source": "幻辞"
            },
            {
              "text": "会議中、部長のユーモアに「あはは」と声をころしながら笑った。",
              "source": "幻辞"
            },
            {
              "text": "相棒のダジャレに「あはは、もう勘弁してください」と言った。",
              "source": "幻辞"
            },
            {
              "text": "昭和の映画では登場人物が「あはは」と大らかに笑う場面が多い。",
              "source": "幻辞"
            },
            {
              "text": "学校の教室で先生のギャグに全員が「あはは」と笑った。",
              "source": "幻辞"
            },
            {
              "text": "医学的には「あはは」という笑いはストレス軽減に効果的だ。",
              "source": "幻辞"
            },
            {
              "text": "心理学者は「あはは」という自然な笑いを研究している。",
              "source": "幻辞"
            },
            {
              "text": "法廷でも「あはは」という笑い声が聞こえることがある。",
              "source": "幻辞"
            },
            {
              "text": "運動会で子どもが親に「あはは」と笑いかけた。",
              "source": "幻辞"
            },
            {
              "text": "雑談の中で「あはは、そうですね」と返答した。",
              "source": "幻辞"
            },
            {
              "text": "料理中に家族の会話で「あはは」という笑い声が響く。",
              "source": "幻辞"
            },
            {
              "text": "旅行先で新しい友人と「あはは」と笑いながら過ごした。",
              "source": "幻辞"
            },
            {
              "text": "懐かしい思い出を思い出して「あはは」と苦笑いした。",
              "source": "幻辞"
            },
            {
              "text": "古典落語では登場人物が「あはは」と笑う場面が重要だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "女　あははははははは………嘘だわ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、べつに、そんなわけではないが、あははは、」とてれ隱しに無理に笑ひ、それから、ほつと小さな溜息をつき、ちらと乙姫のうしろ姿を眺める。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸は、兎がなぜ笑つたのかわからなかつたが、とにかく自分も一緒に、あはははと笑ひ、「まつたくねえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の上に俯伏して居れば雀のお宿に行けるなんて、あははは、馬鹿な事だが、でも、どれ、それではひとつお言葉に從つて、ちよつと行つてまゐりませうか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああははは、風の又三郎ぁ、いゝ事云ったな。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああはは、そいづぁ嘘ぞ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、これも生憎で、あははは、――無いんだ。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田島ですがね、こないだは、酔っぱらいすぎて、あはははは。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああはは、ああはは。",
              "citation": {
                "source": "かしわばやしの夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをば襟半に届けたなら何の禁厭になるかいな」「あははははは。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホッコリホッコリ」「あははははははは」「わははははははは」",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『あはははははばかを言ってる、お前に鉄砲が打てるものか、ただ見物に行くのだ。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "相変わらず元気のいいのが今井の叔父さんで、『君の鉄砲なら一つで外れたらすぐ後の一つで打つことができるが僕のはそう行かないから困る、なアに、中るやつなら一発で中るからなア』と言って『あははははは』と笑った。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言って『あははははッ』と笑ッた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "』そしてかれは『あはははは』と笑った。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれはただそわそわして少しも落ちつかないで、その視線を絶えず自分の目から避けて、時々『あはははは』と大声に笑った、しかし七年前の哄笑とはまるで違っていた。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "で「なんだい、河じゅうみんな泳げら」　爺やの直す下駄を穿いて出かけて行く蓑吉のあとから、爺やはあははと笑った。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山の峡は繁昌じゃ、あはは、」と洲の股の御前、足を挙げる。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸声に、「ふァふァふァ、」「うふふ、」「あはははは。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の影ならず、血だらけの抜刀を提げた、半裸体の大漢が、途惑した幟の絵に似て、店頭へすっくと立つと、会釈も無く、持った白刃を取直して、切尖で、ずぶりとそこにあった林檎を突刺し、敵将の首を挙げたるごとく、ずい、と掲げて、風車でも廻す気か、肌につけた小児の上で、くるりくるりとかざして見せたが、「あはは。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはははは、が、驚きました、露地口に、妓生のやうなのが三人ゐましたぜ、ふはり／＼と白い服で。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "えッ、いや、あ、あ、チ、あははははは、はッはッはッはッ、テ、ウ、えッ、えッ、えッ、えへへ、うふふ、あはあはあは、あは、あはははははは、あはははは。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おほほ、や、お尋ねでは恐入るが、あはは、テ、えッ。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂寞となると、笑ばかりが、「ちゃはははは、う、はは、うふ、へへ、ははは、えへへへへ、えッへ、へへ、あははは、うは、うは、うはは。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、切ない、あはははは、あはッはッはッ、おお、コ、こいつは、あはは、ちゃはは、テ、チ、たッたッ堪らん。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　胸を反して、仰向けに、「あはははは。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
