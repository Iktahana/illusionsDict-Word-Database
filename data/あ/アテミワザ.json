        "examples": {
          "standard": [
            {
              "text": "「わっ、危ない！『当身技』でかわした！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "柔道において、『当身技』は相手の体勢を崩したり、意識をそらしたりするために用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「『当身技』を『効果的に』使うには、相手の隙を見抜く洞察力が必要だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「練習では、投げ技だけでなく、『当身技』も正確に打てるように反復練習すること。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "試合中、相手のガードが下がった一瞬を捉え、『当身技』でポイントを得た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
