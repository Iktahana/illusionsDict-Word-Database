[
  {
    "uuid": "43e8bebd-8c69-52c9-8750-50ec46809d74",
    "entry": "あざ笑う",
    "reading": {
      "primary": "あざわらう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
