    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to laugh at",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は他人の失敗をあざ笑っている。",
              "source": "幻辞"
            },
            {
              "text": "そのコメディアンはあざ笑うキャラクターを演じている。",
              "source": "幻辞"
            },
            {
              "text": "相手をあざ笑うのは性格が悪い。",
              "source": "幻辞"
            },
            {
              "text": "彼女はそのジョークをあざ笑った。",
              "source": "幻辞"
            },
            {
              "text": "いじめっ子は被害者をあざ笑うことが多い。",
              "source": "幻辞"
            },
            {
              "text": "その映画のキャラクターはあざ笑う性格だ。",
              "source": "幻辞"
            },
            {
              "text": "虐待者は被害者をあざ笑う傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "プロパガンダはしばしば敵をあざ笑う。",
              "source": "幻辞"
            },
            {
              "text": "社会学の授業で笑いとしてのあざ笑うことを学んだ。",
              "source": "幻辞"
            },
            {
              "text": "人をあざ笑うことは良くない。",
              "source": "幻辞"
            },
            {
              "text": "その本のキャラクターは相手をあざ笑った。",
              "source": "幻辞"
            },
            {
              "text": "演技の中であざ笑う表情を作った。",
              "source": "幻辞"
            },
            {
              "text": "彼の悪い癖はすぐに人をあざ笑うことだ。",
              "source": "幻辞"
            },
            {
              "text": "そのコメディーはあざ笑う文化が前提となっている。",
              "source": "幻辞"
            },
            {
              "text": "あざ笑うことは相手に失礼である。",
              "source": "幻辞"
            },
            {
              "text": "古い物語ではあざ笑うシーンがよく見られる。",
              "source": "幻辞"
            },
            {
              "text": "デジタルメディアではあざ笑うコンテンツが拡散しやすい。",
              "source": "幻辞"
            },
            {
              "text": "他者をあざ笑う態度は孤立につながる。",
              "source": "幻辞"
            },
            {
              "text": "その役者はあざ笑う演技が得意である。",
              "source": "幻辞"
            },
            {
              "text": "テレビドラマであざ笑うシーンが話題になった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "中津は、傍で話をきゝながら彼を見て、好意をよせるような、又、あざ笑うような、複雑な微笑をした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとともに、頬に大きく付いていた恐ろしい傷痕もなくなり、そしてあざ笑うようにも見えたあのねじれ唇もなくなったのだ！",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりにも残念そうなので、私は心から同情したが、両刑事はこの試みに腹を立てるどころか、ただあざ笑うような微笑みを浮かべていた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして形見の片袖をとどけてよこすからは、やっぱりここを自分の家と思って、わたし達の回向を受けたいのであろうから、お寺へ納めてやるが好かろうというので、きのうすぐに菩提寺へ持ってまいりました」「そりゃあ飛んだ怪談だね」と、徳次はあざ笑うように云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "（青年を見てあざ笑う。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつら　（あざ笑う）いや、昔とは変らぬ。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は酒の酔いを醒ますためにこの川端へ降りていたことを言い訳がましく答えると、頼長はあざ笑うような眼をして黙って聞いていた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「歌物語など致しておりました」「恋歌の講釈か」と、彼はまたあざ笑うような眼をした。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あざ笑うのか、威嚇するのか、どっちとも取れる声音である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふふん」とあざ笑う声がした。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうなったら妾ヒョッとすると……」「縄で……首を……おつりなさいますか」「あきらめてしまうかも知れないよ」あざ笑うような声である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は僕が一行も書けないでいる原稿紙の上を冷やかにあざ笑うようにして見ていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだからと云って、癌を人間社会から絶滅されるようにと努力されているすべてのことを、あざ笑う誰がいるだろう。",
              "citation": {
                "source": "私の信条",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一方で、渡辺和也の注文を全面的に受け入れた格好のＩＢＭ ＰＣは、浜田の心の動きをあざ笑うように快進撃を続けていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の人たちは、それを半分は気の毒らしく、半分はあざ笑うように、「あんな旅のふうらい坊のいうことなどを当てにして、今更どうなるものではない。",
              "citation": {
                "source": "しっぺい太郎",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ何か毒づきたくてむかむかしていた彼らの頭の上を、今度は赤い餅があざ笑うようにとんで行った。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら何でもお聞きなさい」　　　あざ笑う博士　そこで検事は、型のとおりに昨夜お三根が殺される前後の時刻において、博士はどんなことをしていたか、叫び声を聞かなかったか。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ざまア見ろッ」　と子分があざ笑う、その鼻先へニューッとピストルの銃口が……。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国海軍の厳然たる命令をあざ笑うにひとしい怪物のずうずうしい態度だ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一たん本国に引き上げるよりほかはない」　そういっているうちに、八機の爆撃機を撃退した「鉄の水母」は、ラスキン大尉らをあざ笑うかのように、また海面にぽっかりと浮きあがった。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前のように、僕がとんちんかんなことをいっても、あざ笑うようなことはなくなった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "言わばフランス人でありながらナポレオンを知らず、アメリカ人でワシントンを知らないのをあざ笑うかのような有様をして、冷やかして言うには、「忘れたって、全くご身分の高いお方は目が肥えていらっしゃるからね……」「何そんなわけじゃないよ……、私は……」と私は恐れをなして、立ち上って言った。",
              "citation": {
                "source": "故郷",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "神尾のはわざとあざ笑うわけではなく、本来、薩摩の陪臣としての西郷などを、眼中に置いていないのですから、先天的に、鼻の先であしらい得るように生れついているのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、自分を犬の歩きつきに似ている、といってあざ笑う近所の子供たちの顔を目に描きました。",
              "citation": {
                "source": "酒屋のワン公",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあまあ、まあいい」　あざ笑うように師匠はいって、「蔭じゃ公方様の悪口だっていうんだ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎはズボン、そのつぎは服、恐怖に顔をひきつらして、かの女が部屋をうろうろと逃げまどうと、どこからともなく、からからとあざ笑うつめたい声がきこえてきた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「打明けて云えば、先刻君から電話がかかって来た時、僕は君の確信ありげな主張をあざわらう気持だったが、こころみに前科調書をつくって見ると、指紋がぴったり適合するではないか。",
              "citation": {
                "source": "殺人迷路",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　侍従は黙っていると、権右衛門はあざわらうように言った。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、清はあざわらうように言った。",
              "citation": {
                "source": "海亀",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「村では評判の容貌好しで、おとなしい孝行者でしたが、十五夜の晩に芒を取りに出たばっかりに、あんなことになってしまって……」「十五夜は朝から判り切っているのに、日が暮れてから芒を取りに出るということもねえじゃねえか」と、長次郎はあざわらうように云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
