    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heat (of a thing)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "焼きたてのパンの熱さを感じながら、ゆっくりと味わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "夏場の炎天下、アスファルトの熱さが足の裏に伝わってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "猛暑日となり、屋外での作業ではその熱さが作業員の体力を急速に奪っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "エンジンが高負荷で稼働した際、発生する熱さを効率的に放熱する設計が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「うわ、この鉄板の熱さ、すごいな！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「このスープ、ちょうどいい熱さで美味しいね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "物質の熱さを精密に測定するために、感温プローブが用いられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "野獣のやうな病熱さをもつた少年の日の情慾。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のこたあない、ストーヴの中のカステラ見たいな、熱さには、ヨウリスだって持たないんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学の知識はそれを求める熱さえあれば必ずしも講義は聞かなくても書物からも得られる。",
              "citation": {
                "source": "雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじっかなこと云い出せないもの」　じりじりと照りつける陽の光と腹匍いになった塚の熱砂の熱さとが、小初の肉体を上下から挟んで、いおうようない苦痛の甘美に、小初を陥れる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは加熱された水のようなものである。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山は、工人の気に喰わぬ奴に対しては、燐や、塩酸加里、硫黄、松脂などが加熱されて釜の中でドロ／＼にとけている頭薬を、柄杓ですくって、頭からピシャリとぶちかけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは一局部に適当な週期で交互に熱さと寒さを与えるのがいいかもしれない。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に灼熱された熔融塊の球がだんだんに生長して行く。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし日親は熱さを感じなかった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眼は、それを見ると、あやうく焼けただれ相になった熱さが拭われて、どんなに涼しく晴やかになったでしょう。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、火の熱さと、水の冷たさに堪えられなかった相違だけで」　と、青い小鳥が云いました。",
              "citation": {
                "source": "トシオの見たもの",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱湯は咽喉の熱さを我慢すればどうやら嚥み下す事が出来ます。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　渠はこの惨憺さと溽熱さとに面を皺めつつ、手荷物の鞄の中より何やらん取出して、忙々立去らむとしたりしが、たちまち左右を顧て、「皆様、これじゃ耐らん。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小風呂敷一つの空身の俺ですら、十足あるいては腰をのし、一町あるいては息を休めなければならない熱さでありました。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい、いいえ、一向に存じません、さようなことが、と申したものの、ちと変な気になって、下へ下りますと、暖簾から、内のおかみさんが半分からだを出していなすって、喜兵衛や、湯の熱さにかわりはないかい、大地震があるというから、と屈託そう、ちと血の道｜気な処、青ざめておいでなさる。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜美子はうれしさに胸が温まって、暫らく口も利けず、じっと妹の顔を見つめていたが、やがて、いきなり妹の手を卒業免状と一緒に強く握りしめた、その姉の手の熱さに、道子はどきんとした。",
              "citation": {
                "source": "旅への誘い",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すずの兵隊さんは、ほのおにあかあかと照らされて、おそろしい熱さを感じました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、その熱さは、ほんとうの火のための熱なのか、それとも、心の中に燃えている愛のための熱なのか、はっきりわかりませんでした。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからどうした」「それから兼は、その村の荒物屋を探し出して、風邪引きの妙薬はないかちうて聞きますと……この頃風邪引きが大バヤリで売り切れてしまったが、馬の熱さましで赤玉ちうのならある。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの赤玉の一粒に使ってある熱さましは、人間に使う分量の何層倍にも当るのだから、もし本当に利いたら心臓がシビレて死んで終う筈だ……どっちにしても今酒を呑むのはケンノンだから止めろと云って、私の手を押えました」「フーム。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吠えるところの犬は、その心靈に於てあきらかに白熱され、その心臟からは螢光線の放射のごときものを透影する。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神は理想である、人は神になるまへに硝子玉の如く白熱されねばならない。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁寧に言えば、象徴が知的の「頭脳」によってされないで、主観の感情によって温熱されたる、心情の意味としてされねばならない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「細工はりゅうりゅう、手並をごろうじろ」　と彼は抑揚をつけていったが、蓋の熱さに堪えなかったものと見え、ち、ちちちといって、蓋を急ぎ下に置いた様子も、逸子には壁越しに察せられた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手塩皿の溜醤油に片れの一角を浸し熱さを吹いては喰べた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のせいか、私の眉にさえ熱さを感じた。",
              "citation": {
                "source": "新樹の言葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　咽頭過ぐれば熱さ忘るゝ西　鑿といへば鎚　東のは懲りて復これを忘るゝものを云ひ、西のは人須らく智を運し功を速やかにすべきを云へり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蒜は肺の薬になるげじゃけれども、私はこう見えても癆咳とは思わん、風邪のこじれじゃに因って、熱さえ除れれば、とやっぱり芭蕉じゃ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の眉にさえ、刺されるような熱さを覚えた。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は生れつきの娥※靡曼に加えて当時ひそかに交通のあった地中海沿岸の発達した粉黛を用いていたので、なやましき羅馬風の情熱さえ眉にあふれた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
