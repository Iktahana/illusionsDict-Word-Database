  {
    "uuid": "d5f04576-a03a-5bd0-8003-0e0faf806280",
    "entry": "熱さ",
    "reading": {
      "primary": "あつさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
