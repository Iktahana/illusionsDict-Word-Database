[
  {
    "uuid": "e8dda8b4-9274-5039-bd08-e6f4ce9e0c50",
    "entry": "厚さ",
    "reading": {
      "primary": "あつさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
