        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はああやって毎日を過ごしている。",
              "source": "幻辞"
            },
            {
              "text": "営業チームはああやって売上を伸ばす。",
              "source": "幻辞"
            },
            {
              "text": "研究者たちはああやって実験を進める。",
              "source": "幻辞"
            },
            {
              "text": "作家はああやって作品を創作する。",
              "source": "幻辞"
            },
            {
              "text": "教師はああやって学習目標を達成させる。",
              "source": "幻辞"
            },
            {
              "text": "医者はああやって患者を治療する。",
              "source": "幻辞"
            },
            {
              "text": "弁護士はああやって事件を解決する。",
              "source": "幻辞"
            },
            {
              "text": "選手はああやってテクニックを磨く。",
              "source": "幻辞"
            },
            {
              "text": "自然はああやって循環している。",
              "source": "幻辞"
            },
            {
              "text": "歴史家はああやって真実を明らかにする。",
              "source": "幻辞"
            },
            {
              "text": "シェフはああやって美味しい料理を作る。",
              "source": "幻辞"
            },
            {
              "text": "観光ガイドはああやって説明する。",
              "source": "幻辞"
            },
            {
              "text": "セラピストはああやってクライアントを支援する。",
              "source": "幻辞"
            },
            {
              "text": "アーティストはああやって表現する。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトマネージャーはああやってチームを率いる。",
              "source": "幻辞"
            },
            {
              "text": "親はああやって子どもを躾ける。",
              "source": "幻辞"
            },
            {
              "text": "看護師はああやって患者の世話をする。",
              "source": "幻辞"
            },
            {
              "text": "検察はああやって事件を立証する。",
              "source": "幻辞"
            },
            {
              "text": "トレーナーはああやってアスリートを育成する。",
              "source": "幻辞"
            },
            {
              "text": "環境保護団体はああやって自然を守る。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ああやっている方が、急に飛出すときに身体の釣合をとるために好都合かとも思ってみる。",
              "citation": {
                "source": "浅間山麓より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "容色も悪くはなし年だって私と同じなら未だいくらだって嫁にいかれるのに、ああやって一生懸命に奉公しているんだからね。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（節子）（それにかまわず、遠くの歌声に耳を傾け）ああやって歌をうたって遊ぶのが、都会ふうで、そうして文化的とかいうもので、日本はこれから、男も女もみんな、菊代さんのようにならなければならないのでしょうか。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そして料理番は、この池のを大事にして、可愛がって、そのせいですか、隙さえあれば、黙ってああやって庭へ出て、池を覗いていますんです。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから、ああやって覚悟をして死んで行くのを待っておいでだ。",
              "citation": {
                "source": "吉原新話",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によるとああやって立ったままで眠るのではないかとも考えられるのであった。",
              "citation": {
                "source": "解かれた象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたみたいな方に、そう笠にかからずとも、わたしでもお相手になさればいいのに……でもあなたがいらっしゃればこそおじさんもああやってお仕事がおできになるんですのね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日｜釣りをやってね……ああやって水の流れを見ていると、それでも晩飯の酒の肴ぐらいなものは釣れて来ますよハヽヽヽヽ」　木部はまたうつろに笑ったが、その笑いの響きが傷口にでも答えたように急に黙ってしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代り学問にかけると非常に神経質だ」「当分ああやっておいでのつもりなんでしょうか」「わからない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきからどうも何かだいじな忘れ物をしているように思ったから、いっしょうけんめいああやって廊下を歩きながら考えていたんだが、よく考えてみりゃ、おら、おなかがへっているよ」　人を食ったことに空腹だといったものでしたから、出鼻をくじかれて、伝六が当然のごとくに鳴りだしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああやって、わざと雪駄をちゃらつかせて、いま通ったぞと知らして歩いたら、気のきいた下手人だったら、きっとそのすきに何かしでかすと思ったからな、ちょっとばかり誘いのすきをこしらえてやったのさ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなかわいい娘を、こんな美しい妹を、知らぬ他人にとられたらと思いましたら、もう矢もたてもたまらなくなりまして、――魔がさしたのでござりましょう、こうやって、ああやって、こっそりいれずみをしたら、一生わたしのそばから離れまいと、ついあのようなそら恐ろしいことをしたのでござります」「どういうわけじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああやって、九人なら九人という人間を、表に出すんでなかった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあいつも我儘者ですから、なまじっかの所へ嫁なんぞに行って苦労するよりも、ああやって家で精いっぱい威張り散らして終る方が、仕合せかも知れませんよ。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあいつも我儘者ですから、なまじっかの所へ嫁なんぞに行って苦労するよりも、ああやって家で精いっぱい威張り散らして終る方が仕合わせかも知れませんよ。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御勿体ない、法王様は御病気でござらしゃるだに皆を祝福してやるとこらえてああやってござらしゃる。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「すきだからだろう、　髪だって指環だって好きだからああやって居るんだろうさ、　気んなるんならきいて見るといい。",
              "citation": {
                "source": "蛋白石",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其那に朗らかとも美麗とも思ったことはなかったのだが、ああやって台所から聞くと、何か一種可憐な趣があった。",
              "citation": {
                "source": "或る日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがおまえの手下の者が毎日ああやってむだ骨をおっているのが気の毒ゆえにおまえに告げるが、あの木どもを伐り倒すには、毎日その伐り屑を火で焼くといいと、いうたかと思うとすでに老翁の姿は掻き消えてあとかたもなかった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "われもはやく別の奥山に連れていってああやってくれと夫を急きたてて夫婦で別の奥山をさしていきます。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "「静ちゃんも、ああやって病気して可哀そうですから、ちっとは落ち着いて、家にいて下すったっていいじゃありませんか。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お芳さんは、ああやっていて終いにどうするんでしょうね。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああやって機嫌を取って、私を掌中に丸めこもうとするんだよ。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの若さで、女買い一つするじゃなし、お前をお嫁にすることとばかり思って、ああやって働いているんだから。",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつよばれるかを知れないような連中なんだね、ああやっているの。",
              "citation": {
                "source": "祭日ならざる日々",
                "author": "――日本女性の覚悟――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が、さっきからああやって立ったまま根気よく、恐らく決して無い文鳥の万ガ一の気まぐれを待っているのも同じ原因からだろう。",
              "citation": {
                "source": "春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "安さんは、今朝早くやって来る予定なのに、こう夕方になっても顔を見せないから、おおいに歓迎しようと待ち構えていた同志たちは拍子抜けがして、ああやってたびたび訊き合わせに来るし、今度は、李先生まで心配して、さっき黄成鎬の家へ白基竜のやつを様子見にやったんだが――。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだって、ああやって冷静に構えて反対しながら、その反対することによって僕を煽って、僕を使ってあいつを殺させようとしているんだ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
