[
  {
    "uuid": "99f6444b-a682-5a69-a221-6ba38351c638",
    "entry": "ある種",
    "reading": {
      "primary": "あるしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
