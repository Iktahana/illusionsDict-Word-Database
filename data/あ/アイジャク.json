[
  {
    "uuid": "89a929b3-5f04-545f-bfc7-f81d97fc661d",
    "entry": "相酌",
    "reading": {
      "primary": "あいじゃく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "drinking alcohol while pouring it for each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "格式張った宴席も終わり、ようやく二人きりで地酒を相酌しながら、積もる話に花を咲かせた。",
              "source": "幻辞"
            },
            {
              "text": "二十年ぶりに再会した旧友と、囲炉裏を囲んで静かに相酌を楽しみ、過ぎ去った日々に思いを馳せた。",
              "source": "幻辞"
            },
            {
              "text": "割烹の奥座敷で、商談を終えた両社の代表は相酌を交わしながら、提携に向けた最後の手応えを確かめ合った。",
              "source": "幻辞"
            },
            {
              "text": "成人式を迎えた息子と初めて相酌をした父は、少し照れくさそうに徳利を傾け、感慨深げな表情を浮かべていた。",
              "source": "幻辞"
            },
            {
              "text": "秋の夜長、名月を愛でながら相酌に興じていると、日々の喧騒を忘れ、心が洗われるような心地がした。",
              "source": "幻辞"
            },
            {
              "text": "互いにお猪口を差し出し、相酌で酒を酌み交わす時間は、言葉以上に二人の心理的な距離を縮めてくれる。",
              "source": "幻辞"
            },
            {
              "text": "亡き恩師の遺影の前に盃を置き、門下生たちが代わる代わる相酌を繰り返しては、その慈愛に満ちた生前を偲んだ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そこでおれは時々自分の家で飲む時には必らず今の太郎坊と、太郎坊よりは小さかった次郎坊とを二ツならべて、その娘と相酌でもして飲むような心持で内々人知らぬ楽みをしていた。",
              "citation": {
                "source": "太郎坊",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐ろに相酌みつつ終にまた深更まで飮んでしまつた。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "きまりの悪いのは初めのうちだよ」　猫板をチャブ台にして、鶴吉とお千代という年増が、相酌でちびちび飲んでおりますと、この夜更けだというのに、ここの家はそれからが繁昌で、妙な女がぞろぞろと帰って来る。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
