        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "努力あるにしたがって成果が出た。",
              "source": "幻辞"
            },
            {
              "text": "経験あるに従って知識が増えた。",
              "source": "幻辞"
            },
            {
              "text": "学習あるに応じて理解が深まった。",
              "source": "幻辞"
            },
            {
              "text": "医学知識あるに応じて診断精度が上がる。",
              "source": "幻辞"
            },
            {
              "text": "教育レベルあるに従って就職機会が広がる。",
              "source": "幻辞"
            },
            {
              "text": "社会経験あるに応じて判断が正確になる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ訓練あるに従って成績が向上する。",
              "source": "幻辞"
            },
            {
              "text": "ビジネス経験あるに応じて決断が早くなる。",
              "source": "幻辞"
            },
            {
              "text": "技術開発あるに従って可能性が広がる。",
              "source": "幻辞"
            },
            {
              "text": "歴史知識あるに応じて視野が広まる。",
              "source": "幻辞"
            },
            {
              "text": "法律知識あるに従って権利認識が高まる。",
              "source": "幻辞"
            },
            {
              "text": "言語能力あるに応じてコミュニケーションが円滑になる。",
              "source": "幻辞"
            },
            {
              "text": "芸術経験あるに従って表現力が豊かになる。",
              "source": "幻辞"
            },
            {
              "text": "科学理解あるに応じて自然への認識が深まる。",
              "source": "幻辞"
            },
            {
              "text": "人生経験あるに従って人間関係が複雑になる。",
              "source": "幻辞"
            },
            {
              "text": "読書経験あるに応じて思考力が高まる。",
              "source": "幻辞"
            },
            {
              "text": "旅行経験あるに従って視野が広がる。",
              "source": "幻辞"
            },
            {
              "text": "料理経験あるに応じて味覚が繊細になる。",
              "source": "幻辞"
            },
            {
              "text": "運動習慣あるに従って体力が向上する。",
              "source": "幻辞"
            },
            {
              "text": "瞑想実践あるに応じて心が落ち着く。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "芭蕉は、一物と他物との合体の瞬間に於ける妙といふことを、非常に大切にしたのであるが、そして恐らく此の事こそ俳句の最高眼目たるものでもあらうが、その眼目が射当てられるためには、蓋し情理的であるよりもおのづと感覚的である方が適切であるに相違ない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し材料の少いことが表現の困難だとは限らぬし、私の今感じてゐる好い気持は、どうしても好い気持であるには相違ないのだ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処の景色を私は好きである、坂は段々勾配を増し、酔つて夕陽に照らされてスタコラゆけば、まるで我が身か、我が身が運ぶ箱か分らず、多分今飲んだビールを運ぶ容器であるに相違なからう。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の神経は、近代文明の病癖を受けて針のやうに過敏であり、その感覚は驚くべく洗練された者であるにも関らず、彼の精神は全く子供のやうな単純さと、野蛮人のやうな生生した原始的の驚きに充たされて居る。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にその同情は憐憫であり、侮辱であるにすぎないだらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は單に聰明であり、そして聰明であるにすぎないといふことが、私の芥川君に對する不滿であつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありとある微分値の間を駆け巡り、今日積分値にまで漸く辿りついてみると、案外に道は近きにあるに驚かざるを得ない。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度、基督教の伝導婦を妻君に持つ、丸顔の、袴など高く穿くが何だか自堕落な感じの、植物課の教師が訪ねて行つた時、校長は、妻が酷いヒステリーなので、随分私も学校で嫌な顔をしてゐる日があるに違ひないがと話した。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、人間印象があつて観念がないといふことはあるけれど、実際云つて観念があつて印象がないといふことはあり得べからざることであるに鑑み、詩が小説よりも観念寄りといふよりは寧ろ印象寄りの仕事であることからして、詩がもつとよく開拓せられてから小説が関心されに到ることが物の順序でもあつたであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉の書体が雄健で闊達であるに反して、蕪村の文字は飄逸で寒そうにかじかんでいる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の出席した四つのコロキウムのそれぞれの雰囲気は学科の性質から来る特徴もあるにはあるであろうが結局はその集会を統率する中心人物の人柄そのものによって濃厚に色づけられているのであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろこびの言葉もあるにはありますが、それにさへなほ、いやらしい工夫がほどこされてゐるぢやありませんか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して山を（高低の差別はあるにもせよ）未だ生れてから見たことがないという人は、盲目でない限りは、殆んどないようである。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それのみならず、日光の融解力を考えると、朝の日は東の方面に当るが、その光線の力が微細であるに反し、昼は北や南に、午後は主として西が強い光線を受ける、即ち東は融解の力を受けることが弱いから、雪が多量に留置されるのだ。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「極暑九十七度九分、山々に未だ雪あるに呆れ候、一昨夕、稀なる夕映、望遠鏡にて西山一帯を眺めいたるところ、駒ヶ岳の絶巓、地蔵の頭、間の岳、農鳥の絶頂なる、各三角測量標を、歴々と発見いたし候」（七月十八日）、この時の感じは、何だか自分が観て、Ｎ君に知らせているような気がした。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯場には吹き曝しであるにしても風呂が湧いていた。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "川上の方は、掘鑿の岩石を捨てた高台になっていて、ただ捲上小屋があるに過ぎなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京では運転手は器械の一部であり、乗客は荷重であるに過ぎない、従って詫言などはおよそ無用な勢力の浪費である。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上のような読み方をするのはアカデミックな言語学者から見れば言語道断な乱暴な所業であるに相違ない。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼りにして來た客を、假令それがどんな人體であるにしても、尋ねてくるのが始めから間違つてゐるかのやうに取扱ふのは少し可哀相であらう。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "稚気と未練に含まれて、そこに何かあるに違いない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く別の世界だぞ、　気を落ちつけて（黄のひかり）あるある、あるには有るがあの泥炭をつくったやつの甥か孫だぞ、黄のひかりうすあかり鳴れ鳴れかしは。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は何として越す、三｜之助を貰ひにやろかとあれば、ほんに夫れで御座んす、常日さへあるに大晦日といふては私の身に隙はあるまじ、道の遠きに可憐さうなれど三ちやんを頼みます、晝前のうちに必らず必らず支度はして置まするとて、首尾よく受合ひてお峰は歸りぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "己らは痘痕と濕つかきは大嫌ひと力を入れるに、主人の女は吹出して、夫れでも正さん宜く私が店へ來て下さるの、伯母さんの痘痕は見えぬかえと笑ふに、夫れでもお前は年寄りだもの、己らの言ふのは嫁さんの事さ、年寄りは何でも宜いとあるに、夫れは大失敗だねと筆やの女房おもしろづくに御機嫌を取りぬ。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此坂を下りてあしこへ行きて暫時やすまん、つかれては話しも厭やなればと仰せあるに、さらば歸りたまふか、厭々、今しばし遊ばんとて、苔なめらかなる小道を下らるゝに、おあぶなしと言へば、氣のどくなれど其肩をかし給へとてつと寄りて此處を下りぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方にも其おぼえはあるべしとあるに、誠に其通りとて直次も涙ぐまれぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてもお父樣は幾年の前にか失せ給ひし、お前さまの親御樣なれば御年もまだお若かりしならんと問へば、いや若しといふほどにはあらず、別れしは八年の前おもへば夢のやうな別れ成しとあるに、さらば御病氣は俄の病にてやありしと、たゝみかけて問へば、何の病氣かは、我が父はこれこの池に身を沈め給ひしなり。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "金は何として越す、三之助を貰ひにやろかとあれば、ほんにそれで御座んす、常日さへあるに大晦日といふては私の身に隙はあるまじ、道の遠きに可憐さうなれど三ちやんを頼みます、昼前のうちに必らず必らず支度はして置まするとて、首尾よく受合ひてお峯は帰りぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」が有価値的であるに対して下品は反価値的である。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに西洋の絵画では、湯に入っている女の裸体姿は往々あるにかかわらず、湯上り姿はほとんど見出すことができない。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
