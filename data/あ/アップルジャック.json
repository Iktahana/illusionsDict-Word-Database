        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "バーテンダーが「このカクテルには、隠し味として少量のアップルジャックを使っています」と説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ニューイングランド地方では、アップルジャックは冬の寒い夜に体を温める伝統的な飲み物として親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は一口含み、「うん、このアップルジャックは芳醇で深みがあるね」と満足げに呟いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "自家製のアップルジャックを作るために、庭で収穫したリンゴを丁寧に発酵させた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古いレシピ帳には、アップルジャックを使ったデザートの作り方が記されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "禁酒法時代、密造されたアップルジャックは隠れて取引されていたという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人が誕生日プレゼントに珍しい熟成アップルジャックを贈ってくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
