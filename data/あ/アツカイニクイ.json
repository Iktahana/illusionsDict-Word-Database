[
  {
    "uuid": "b325a878-9790-5276-aac2-81ce45efd2ce",
    "entry": "扱いにくい",
    "reading": {
      "primary": "あつかいにくい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
