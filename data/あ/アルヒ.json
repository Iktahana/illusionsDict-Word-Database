    "definitions": [
      {
        "index": 1,
        "gloss": "one day",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ある日、人生が変わる出来事が起こった。",
              "source": "幻辞"
            },
            {
              "text": "ある日、病院から重大な診断結果を聞いた。",
              "source": "幻辞"
            },
            {
              "text": "ある日、仕事をやめるという決断をした。",
              "source": "幻辞"
            },
            {
              "text": "ある日、新しい愛の予感を感じた。",
              "source": "幻辞"
            },
            {
              "text": "医学的には、ある日から症状が出始めた。",
              "source": "幻辞"
            },
            {
              "text": "学校では、ある日からいじめが始まった。",
              "source": "幻辞"
            },
            {
              "text": "職場で、ある日から役職が変わった。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ人生では、ある日から怪我で休場した。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスでは、ある日から経営が逆転した。",
              "source": "幻辞"
            },
            {
              "text": "技術開発では、ある日からブレークスルーが訪れた。",
              "source": "幻辞"
            },
            {
              "text": "歴史的には、ある日から戦争が始まった。",
              "source": "幻辞"
            },
            {
              "text": "法的には、ある日から新法が施行された。",
              "source": "幻辞"
            },
            {
              "text": "文学作品では、ある日から物語が急展開した。",
              "source": "幻辞"
            },
            {
              "text": "家庭では、ある日から家族構成が変わった。",
              "source": "幻辞"
            },
            {
              "text": "恋愛では、ある日から相思相愛になった。",
              "source": "幻辞"
            },
            {
              "text": "経済では、ある日から不況が始まった。",
              "source": "幻辞"
            },
            {
              "text": "科学では、ある日から新発見が報告された。",
              "source": "幻辞"
            },
            {
              "text": "宗教では、ある日から信仰が変わった。",
              "source": "幻辞"
            },
            {
              "text": "人生哲学では、ある日から価値観が反転した。",
              "source": "幻辞"
            },
            {
              "text": "社会では、ある日から革命が起こった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "ある日、街上を行く。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして『西洋の国々と同じく、ここにもやはり醜い生存競争があり、常々不義や奸計が行われている』と、地上の現実社会である日本を見ている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日二人は、例によって睦じく連れそいながら、牛込辺の売邸を探しに歩いた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ある日の新聞に、次のような記事が出ていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで式のある日などには、夫人が無理に押えつけ、女中までが手伝って騒ぎながら、まるで駄々ッ子を扱うように、あやしたりすかしたりして、厭がるのを強いて着せねばならなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日私は活動写真で、菊の生長の状況を見せられた事がある。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日二階の縁側に立って南から西の空に浮かぶ雲をながめていた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏のある日の午後、いつものようにそこへ英語を教わりに行った時に、自分には初めての珍しい飲料を飲まされた。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日宅の女中が近所の小母さん達二、三人と垣根から隣を透見しながら、何かひそひそ話しては忍び笑いに笑いこけているので、自分も好奇心に駆られてちょっと覗いてみると、隣の裏庭には椅子を持出してそれに楠さんが腰をかけている。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々｜宅の庭の手入れなどに雇っていた要太という若者があって、それが「鴫突き」の名人だというので、ある日それを頼んで連れて行ってもらった。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはたとえば東京の日比谷公園にある日を期して市民を集合させる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日「富士が見えますよ」と、隣の机から呼びかけられて、西日さす銀覆輪の雲間から、この山を見た、それが今まで、雨や、どんよりした花曇りに妨げられて、逢いたくて逢えない顔であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある日私の先輩の一人が老眼鏡をかけた見馴れぬ顔に出会した。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ティアガルテンの冬木立や、オペラの春の夜の人の群や、あるいは地球の北の果の淋しい港の埠頭や、そうした背景の前に立つ佗しげな旅客の絵姿に自分のある日の片影を見出す。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新学期がはじまつてから二ヶ月程後のある日、朝から二時間目の歴史の時間に起つたこと。",
              "citation": {
                "source": "ある男の死",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "息子の岳神は暇な暇な、父の祖神を山中に案内して見せて廻るうち、ある日、山ふところの日当りの小竹原を通りかかり、そこに二坪近くの丸さに、小竹之葉が剥げ、赤土が露き出ているのを見付けると、息子の岳神は指して笑いながらいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、土民の一人が瓜わらべを拾って持って来て呉れた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月のある日、しぶしぶ雨が降る昼でした。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いつ死のうかと逢う度毎に相談しながら、のびのびになっているうちに、ある日川の向うに心中｜態の土左衛門が流れて来たのだよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとある日いたちに見附かって食べられさうになったんですって。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、九月の末のある日曜でしたが、朝早く私が慶次郎をさそっていつものように野原の入口にかかりましたら、一本の白い立札がみちばたの栗の木の前に出ていました。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其方も早くに二親とも世をさりしとか、我れも母なりし人の顏はしらで、育ちしは父上の手一つなれば、戀しさなつかしさは又一倍におぼゆるぞかし、平常はともあれ由縁ある日はこと更におもひ出されて、まぎらさんとても氣のまぎれぬは今日なり。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、私がパリで散髪をしていると理髪師が私に向ってデ・ジャポネー（日本人）は騎兵は要らぬそうですねといった。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとまたある日本食堂で最近代的な青年二人と少女二人の一行が鯛茶を注文していたが、それが面前に搬ばれたときにこの四人の新人は、胡麻味噌に浸された鯛の繊肉を普通のおかずのようにして飯とは別々に食ってそうして最後に茶を別々に飲んでいた。",
              "citation": {
                "source": "雑記帳より（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうある日の快晴無風の午後の青空の影響を受けたものか、近頃かつて経験したことのないほど自由な解放された心持になって、あてもなく日本橋の附近をぶらぶら歩いているうちに、ふと昨日人から聞いた明治座の喜劇の話を想い出してちょっと行って覗いてみる気になった。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の暮方、時計を手にして花の咲くのを待っていた。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、どうした拍子であったか、とにかくＮ君とのある日の会話の経過で、いつか一度議会傍聴に案内してもらうという約束が出来上がってしまった、その約束がいよいよ履行される日が思ったよりも実はあまりに早く来たのであった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の午前に日比谷近く帝国ホテルの窓下を通った物売りの呼び声が、丁度偶然そのときそこに泊り合わせていた楽聖クライスラーの作曲のテーマになったという話があったようである。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日曜日の朝顕著な不連続線が東京附近を通過していると見えて、生温かい狂風が軒を揺がし、大粒の雨が断続して物凄い天候であった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　三二八頁にある日本に関する記事の中にこんな事がある。",
              "citation": {
                "source": "マルコポロから",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
