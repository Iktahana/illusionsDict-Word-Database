        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あらましについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あらましという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあらましの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあらましが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あらましを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあらましについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あらましの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあらましの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあらましが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あらましという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあらましという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあらましについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あらましを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあらましは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あらましについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあらましが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあらましは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあらましの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あらましは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあらましは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
