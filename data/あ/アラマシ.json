        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "これがこの話のあらましである。",
              "source": "幻辞"
            },
            {
              "text": "契約書のあらましを説明してください。",
              "source": "幻辞"
            },
            {
              "text": "映画のあらましを話してくれる係がいた。",
              "source": "幻辞"
            },
            {
              "text": "組織変更のあらましが通知された。",
              "source": "幻辞"
            },
            {
              "text": "歴史のあらましを学ぶことは重要だ。",
              "source": "幻辞"
            },
            {
              "text": "あらましを聞いただけでも事情がわかった。",
              "source": "幻辞"
            },
            {
              "text": "報告書のあらましは三ページ分だ。",
              "source": "幻辞"
            },
            {
              "text": "小説のあらましを目次で確認した。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトのあらましを社員に説明した。",
              "source": "幻辞"
            },
            {
              "text": "計画のあらましは次のとおりである。",
              "source": "幻辞"
            },
            {
              "text": "長い会議のあらましを簡潔にまとめた。",
              "source": "幻辞"
            },
            {
              "text": "あらましから詳細へと話を進めよう。",
              "source": "幻辞"
            },
            {
              "text": "実験のあらましを論文に記載した。",
              "source": "幻辞"
            },
            {
              "text": "新聞はニュースのあらましを一行で紹介した。",
              "source": "幻辞"
            },
            {
              "text": "状況のあらましを理解するのに時間がかかった。",
              "source": "幻辞"
            },
            {
              "text": "演説のあらましが公開された。",
              "source": "幻辞"
            },
            {
              "text": "法律案のあらましを国民に周知した。",
              "source": "幻辞"
            },
            {
              "text": "事件のあらましは犯人の逮捕で一応の決着がついた。",
              "source": "幻辞"
            },
            {
              "text": "あらましだけ知りたいので箇条書きで願いたい。",
              "source": "幻辞"
            },
            {
              "text": "史実のあらましから見えることは何か。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "要所、要所の手くばりもあらましここにすみぬれば手代が下知の一聲に家臺をゆする物音やたまたま晝の閑寂に庭の椿の落つる頃。",
              "citation": {
                "source": "煤掃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちにあらまし片付けてしまわなくちゃならないからね。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主人より聞きえしはそのあらましのみ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、多少でもまだ事実の記憶の消え残っている今のうちに、あらましのことだけをなるべくザハリッヒな覚え書きのような形で書き留めておくことにしようと思う。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の中で考えたのは、あらましこんな事であったように思う。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらましの本読みはこの通りだが、これだけじゃあ芝居も幕にならねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日の帰途気まぐれに自分はＥで電車を降り、あらましの見当と思う方角へ歩いて見た。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　兄の話のあらましはこんなものだった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いでいるからであろう、若僧は直にその手拭で泥足をあらましに拭いて、提灯を持ったまま、ずんずんと上り込んだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの來歴を告げて、それから、ケルリ、ケルリ、と檻に向つて二聲叫び、右手のむちを小粹に振つた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、燕尾服を着た仁丹の鬚のある太夫が、お客に彼女のあらましの来歴を告げて、それから、ケルリ、ケルリ、と檻に向って二声叫び、右手のむちを小粋に振った。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六一課　信仰生活のあらまし　仏教を信じたものは、どんな生活をするのでしょうか。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあらましを二つ三つ述べて見ましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男子にてあらましかばなど、言い効もなき意気地なさを憶い出でて、しばしはその恨めしき地を去るに忍びざりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしも御用のことですから委細承知して、その角右衛門という人の話を聞くと、そのあらましはこういう訳なんです」　きょうから八日前のことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　と、こんな風に詳しくは、さすがに弓子は鶴雄の前では云えなかったが、とにかく話のあらましだけは語った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年、彼が借衣までして恋人に逢いに行ったという、そのときの彼の自嘲の川柳を二つ三つ左記して、この恐るべきお洒落童子の、ほんのあらましの短い紹介文を結ぶことに致しましょう。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "傑作「人間万事嘘は誠」のあらましの内容は、嫌厭先生という年わかい世のすねものが面白おかしく世の中を渡ったことの次第を叙したものであって、たとえば嫌厭先生が花柳の巷に遊ぶにしても或いは役者といつわり或いはお大尽を気取り或いはお忍びの高貴のひとのふりをする。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが才気とカンと苦労で世間のあらましは、すでに結論だけを摘み取ってしまっている彼のような人間にとって、その過程を煩わしく諄く記述してある書物というものを、どうして迂遠で悪丁寧とより以外のものに思い做されようぞ。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、かの女は晩く、こんなことを話し合える夫と妻とについて内心不思議がりながら、逸作に規矩男と自分との経過のあらましを話した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、移転して三月目にその家が焼夷弾で丸焼けになったので、まちはずれの新柳町の或る家へ一時立ち退き、それからどうせ死ぬなら故郷で、という気持から子供二人を抱えて津軽の生家へ来たのであるが、来て二週目に、あの御放送があった、というのが、私のこれまでの浪々生活の、あらましの経緯である。",
              "citation": {
                "source": "十五年間",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで居るからであらう、若僧は直に其手拭で泥足をあらましに拭いて、提灯を持つたまゝ、ずん／＼と上り込んだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "行員はその日のゼッテルベルグ老人の樣子をあらまし語り終ると、何の用事でどこへ行つたかは分らぬが、その時老人がすぐ近所の町角に駐車してゐる辻自動車に乘つたといふことを傳へて、ひよいと傍の窓を開くと、「あア、あすこにゐるあの自動車ですよ。",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子は、京子を娘のように可愛がるお民に隠すほどの事でもなかろうと思って、あらましを話した。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ彼が第一の書のあらましなり。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小太郎から、事件のあらましを聴いたとき、これはいけないと思い、新子がこのまま去ってしまうことを考えると、身内のどっかを抉り取られるような気がした。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこれがいわゆる『ブルック・ストリートの秘密』として有名な事件のあらましなのであって、今日までまだ公に発表されたことのないものである。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　我々一同は深い興味を持って、昨晩行われたことのあらましを聞いた。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭領スマトラ会社やモーペルチュイ男爵の大計画といった件のあらましは、今も世間の記憶にたいへん新しく、また政治や金融とあまりに密接な関係があるため、この連載の題材には適していない。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「簡単に事件のあらましを述べてから、何か役立つ情報があるとうれしい、と打ちました。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
