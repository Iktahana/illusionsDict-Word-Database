        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "荷崩れを防ぐため、トラックの荷台に丈夫な当板を挟んで荷物を固定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ボルトを強く締め付ける際、部材の表面を傷めないよう厚めの当板を添えるのが鉄則だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「この薄い合板に直接ネジを打つと割れるから、裏側に当板を当てて補強しよう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "破損したフェンダーの裏側に金属の当板を溶接し、板金塗装の前に強度を確保した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ワイヤーロープが木材に食い込まないよう、荷の角にＬ字型の当板を配置して養生する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "クレーンで重量物を吊り上げる際、ワイヤーが直接触れて荷を傷つけないように当板をかませる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "方言が相当板についた（と思われる）点、勘次とおつうと爺とのトリオの優秀な点、云われている通りだ。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何かお手あていたしませう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何かお手あていたしましょう。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
