        "examples": {
          "standard": [
            {
              "text": "この山道はアップダウンが激しいので、体力に自信がないと厳しいだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の人生はアップダウンの連続で、波乱に富んだものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新興企業の株価はアップダウンを繰り返しながら成長していくことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このゴルフコースはアップダウンが多く、戦略的なプレーが求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "長期間にわたるプロジェクトでは、モチベーションのアップダウンは避けられない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「今日のプレゼンは、良いところと悪いところのアップダウンが大きかったな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "このキャンパスは、そこらじゅうアップダウンばかりで、平らな地面というのはグラウンドと野球場、そして舗装されたテニスコートや、バスケットコートなど、数えるほどしかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            }
          ]
        }
