[
  {
    "uuid": "adaa1788-38be-5c32-8a53-70ce8c436734",
    "entry": "あれっきり",
    "reading": {
      "primary": "あれっきり",
      "alternatives": [
        "あれきり"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "since then",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あれ以来、毎日ジョギングを続けている。",
              "source": "幻辞"
            },
            {
              "text": "あの事件あれ以来、警備が厳しくなった。",
              "source": "幻辞"
            },
            {
              "text": "卒業式あれ以来、クラスメートとは会っていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、彼との関係は気まずくなった。",
              "source": "幻辞"
            },
            {
              "text": "病気から回復したあれ以来、健康的な生活を心がけている。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、私の人生が変わった。",
              "source": "幻辞"
            },
            {
              "text": "引っ越したあれ以来、新しい友人ができた。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その地域は大きく発展した。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、この技術は急速に普及した。",
              "source": "幻辞"
            },
            {
              "text": "破産したあれ以来、再出発に必死だ。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、政策が大きく転換した。",
              "source": "幻辞"
            },
            {
              "text": "結婚式あれ以来、毎年会っている。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その工場は操業を停止している。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、気象パターンが変わった。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、この習慣は続いていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、不信感を払拭できていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、年1回の定期会議が始まった。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、技術革新が加速している。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、彼女とは連絡が途絶えた。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その価値観に疑問を持ち始めた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その身に懸ったことからして、あの婆様が死んでみりゃ、可哀そうに光子様はあれっきり……チョッ惜いことを。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あれは、あれっきりという事に、……」「それがそういかないんですよ。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうきっと、あなたと一緒になれるものと錯覚してしまって、心の中では、あなたをワイフと呼んで待っていましたのに、あなたは、あれっきりもう帰って来ない。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "北さんも中畑さんも、あれっきりまだ二階から降りて来ない。",
              "citation": {
                "source": "故郷",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話も、あれっきりかかって来ない。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好が、一番下手なんで、貴方が三好ばかりガミガミ云ったもんだから、あれっきり来なくなっちゃったんですが……」「ウム。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、あの縁談は、もうあれっきりだったのです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありゃあれっきりのお茶番と思ってましたが、じゃいくらかあいつにほしのにおいがするんですね」「においどころか、ばりばり障子をひっかいた音っていうのは、そのさるなんだよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血染めの手形",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴨南蛮というのはあるが、鳩南蛮はあれっきり食った事がねえ。",
              "citation": {
                "source": "里芋の芽と不動の目",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小学生　とうとう幼稚園へはあれっきり行かずに、それから約一年後、私はすぐ小学校へはいった。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれっきり、君は逢ったことはないんだろう。",
              "citation": {
                "source": "常識",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんもそう言ったが、あれっきりだ。",
              "citation": {
                "source": "田園の幻",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「石村さんへの面当て、あれっきりなの。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの事件の報道は、あれっきりのことで、杳として後日物語がうち断たれてある有様だった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "咲枝が畳んで行ったじゃないの、あれっきりよ、「どうもそうだと思った」六日に国府津へ二人さきにやって、自分だけは行かなかった由。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれっきり行かないから……」　といったが、お宮が、私が来たということを、もし柳沢に話していたら、すぐ尻が割れてしまう。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれは、あれっきりさ」「だってちょっと好い女じゃないか」「あんまりよくもない。",
              "citation": {
                "source": "うつり香",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそただ腹の中で思っていただけですが、あんな罪もなく思ってたようなことは、あれっきりありませんね。",
              "citation": {
                "source": "雪の日",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれっきりだんだんあんなことはなくなったねえ」「ええ、あのころは、あなたが先の連合と私との事についてよくいろんなことをほじって聞いた、前の事を気味悪がり悪がり聞いた」「ウム。",
              "citation": {
                "source": "雪の日",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　弘はあれっきりまだ帰って来ないのである。",
              "citation": {
                "source": "三つの挿話",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お喋りの弁信も、どうしたものか、あれっきり沈黙してしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうあれっきり、あのことをおっしゃって下さらないはずじゃありませんか」「いいよ、そう申しわけをしなくったって。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　やっとメグがいったのに、サリイは人のよさそうな、びっくりしたふうで、「あれっきり、まあ、」と、いいかけましたが、ベルは頭をふって、サリイの言葉をさえぎってやさしくいいました。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれっきり一度も行かないから。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「旦那はあれっきりか。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしのことなんか、あれっきりもうさばさばしたもんだけど、今度のソネートカにゃ油断しないがいいよ。",
              "citation": {
                "source": "ムツェンスク郡のマクベス夫人",
                "author": "LEDI MAKBET MCENSKOVO UEZDA",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれっきりいなくなった安さんのことが気になって、それどころじゃないんですって」「すまねえ。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、あれっきり、まだ御挨拶にも出ませんで」　そう愛想よく言いながら、お蓮様は先に立って、その表屋敷へ通ずる長廊下を、ぶらりと歩き出す。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれっきり客の部屋にはよりつく人もない。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「清野が毛織の襯衣を半ダース重ねて着たのは彼時だよ」「清野は驚いて、あれっきりやって来ない」　余は田中君と是公がこんな話をするのを聞いて、つい化物屋敷の事を忘れてしまった。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "only that much",
