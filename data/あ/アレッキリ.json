        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あれっきりについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あれっきりという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあれっきりの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあれっきりが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あれっきりを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあれっきりについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あれっきりの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあれっきりの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあれっきりが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あれっきりという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあれっきりという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあれっきりについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あれっきりを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあれっきりは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あれっきりについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあれっきりが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあれっきりは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあれっきりの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あれっきりは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあれっきりは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
