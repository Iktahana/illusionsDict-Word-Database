[
  {
    "uuid": "d35872e4-68a2-5fbc-9565-cc38644cc1e6",
    "entry": "あの方",
    "reading": {
      "primary": "あのかた",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "代名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "that gentleman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "会議室の入り口にいらっしゃるのが、本日のゲストスピーカーであるあの方です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの方、いつも熱心に本を読んでいらっしゃるわね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先日お話しした件ですが、あの方に直接ご確認いただけますでしょうか。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "遠くに見えるあの方が、この地域のNPO法人を立ち上げた方だと伺いました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの方は、その道の第一人者として、多くの若手から慕われています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「失礼ですが、あの方はどちら様でいらっしゃいますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のプロジェクトの成功は、ひとえにあの方のご尽力によるものです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「あの方は、いのち、いのちというが、ああ、いのちは、健康であるときにのみ有意義なのだ、この病める姿の醜さ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辛さ醜くさを続けてまで、いつまであの方はいのちを担って行けといわれるのだろうか」「こんなに痩せ細ってしまって、この先どうするのだろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い獣神はいう「この乳を、あの方は、生に対しても根が尽き果て、さればといって死へも急げない、生けるものに取っていちばん遣り切れないときに飲めと仰しゃるんです。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらあの方が神仙の乳を飲まして下すったって……」　いうことがどういうふうに女に響くか窃視したのち、「ねえ、お嬢さん。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は話の順序として『古言衣延弁』のことを前に述べましたが、実はあの方が少し後なので、発表された年月からいうとおよそ三十年も龍麿の方が前であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの方はもう内へは来られないでしょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの方の魂の行らつしやる処も、それで知れます。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでルラ蛙もやっと安心して、「あの方よ。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分でもいつでも低い方低い方と流れて行くでせう、私はあなたのやり方よりは、却ってあの方がほんたうだと思ひます。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自分でもいつでも低い方低い方と流れて行くでしょう、私はあなたのやり方よりは、却ってあの方がほんとうだと思います。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして中味が変っているか、抜けているかしている本の前に立っておられた方を、あの方、この方と思い出しているうちに、だんだんお人柄がわかって参りますから不思議なもンで……この間コンナのがありましたよ。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはあの方をどう思ってだえ」　おぬいがそうだと答えると、母はまたややしばらくしてからいった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私としてもあなたのようにあの方をいい方だとばかり極めるわけにはいかないと思うところもあるのだけれども、星野さんがおっしゃってくださるのだから私は信じていていいと思います。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人が帰ったあと、私は母に何気なく「あの方、結婚してなさるの」と訊きますと、母は「してなさるが、どうも奥さんと面白くない噂でね」と云いました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）娘　――（歩きつつ独白）あの方はわたしに餅を下さった。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢はあの方を罵った。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはあの方が決してえこひいきしたのではない事を知って居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方を袖で掩うて上げ度い程お気の毒に思うた。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方の心がわたしに傾いて居るようにお言われなさったのを悦んで居る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてともすればあの方が本当にわたしをえこひいきして下さったのじゃないかしらんと自惚れ心がつけ上って来る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方は禁慾離苦の御身だ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方を真に思って上げるなら、あの方を忘れて上げなければいけない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あきらめるということがあの方に向っての恋の真ごころでなければならない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　――………本当なら嬉しいけれど………でもあの方は、男女の分ちを超越なさる僧侶の御身の上で御座います。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしが宿命どおり進むならば、あの方を堕落おさせ申す事になりはしないでしょうか。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の心臓の小筥のなかへ、あの方を胡蝶のように擒にしよう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですからどうかお母さんの術を使って、あの方をここへお呼び下さい。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただあの方のお姿です。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、桜を見ていると、蛙の卵の、あのかたまりを思い出して、――」家内は、無風流である。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あたし、櫻を見てゐると、蛙の卵の、あのかたまりを思ひ出して、――」家内は、無風流である。",
              "citation": {
                "source": "春晝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
