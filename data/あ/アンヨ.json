        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "赤ちゃんがあんよを始めた。",
              "source": "幻辞"
            },
            {
              "text": "あんよで初めて階段を上った。",
              "source": "幻辞"
            },
            {
              "text": "子供のあんよはとても可愛い。",
              "source": "幻辞"
            },
            {
              "text": "保育園ではあんよの練習をする。",
              "source": "幻辞"
            },
            {
              "text": "あんよが上手になると親は嬉しい。",
              "source": "幻辞"
            },
            {
              "text": "医学的にあんよの発達段階は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "幼児教育ではあんよの発達を観察する。",
              "source": "幻辞"
            },
            {
              "text": "あんよがしっかりしてくると安定感が出る。",
              "source": "幻辞"
            },
            {
              "text": "赤ちゃんのあんよは両親の思い出になる。",
              "source": "幻辞"
            },
            {
              "text": "あんよを促進する運動を行うことがある。",
              "source": "幻辞"
            },
            {
              "text": "発達心理学的にあんよは成長指標だ。",
              "source": "幻辞"
            },
            {
              "text": "あんよの動きから性格も分かることがある。",
              "source": "幻辞"
            },
            {
              "text": "あんよが遅れると親は心配になる。",
              "source": "幻辞"
            },
            {
              "text": "あんよと同時に言葉の発達も進む。",
              "source": "幻辞"
            },
            {
              "text": "あんよの段階で転倒は成長の過程だ。",
              "source": "幻辞"
            },
            {
              "text": "あんよの動画を撮る親は多い。",
              "source": "幻辞"
            },
            {
              "text": "あんよで転んでも痛くない環境を用意する。",
              "source": "幻辞"
            },
            {
              "text": "あんよの発達には栄養も関係している。",
              "source": "幻辞"
            },
            {
              "text": "あんよが上手になるまでの期間は個人差がある。",
              "source": "幻辞"
            },
            {
              "text": "あんよを始めた日は家族の記念日だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「あんよが出来出す一寸前頃は、一寸の油断もならないので、行李の蓋底におしめを沢山敷いて、その中に入れといたものだが、するとそのおしめを一枚々々、行李の外へ出して、それを全部出し終ると、今度はまたそれを一枚々々、行李の中へ入れたものだよ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おいらは、ジュリーのあんよが大きくなることを、すっかりわすれていた。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまりかねて私は、それだけはやめてくれ、と口をとがらして抗議したら、周さんはけげんな面持ちで、だって日本では、子供に向っては、子供の言葉で、おてて、だの、あんよだの、そうでチュか、そうでチュか、と言うでしょう、それゆえ女性に対した時にも女性の言葉で言うのが正しいのでしょう、と答えた。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくここまで、あんよが出来たね。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから少女はその小さなあんよに何もはかないままでした。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "THE LITTLE MATCH-SELLER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんよは寒さのために赤くはれて、青じんでいます。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "THE LITTLE MATCH-SELLER",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さなあんよをぎゅっと引きよせましたが、寒さをしのぐことはできません。",
              "citation": {
                "source": "マッチ売りの少女",
                "author": "THE LITTLE MATCH-SELLER",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おっとと、あんよは上手。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野枝さんの膝に抱かれたぎりのルイゼはマダあんよの出来ない可愛いい子で、何をいっても合点々々ばかりしていた。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら達者だと云っても、なにしろこゝの主人にくらべると、丁度一とまわりも上なんですもの、口ばかり強そうなことを云っても、からだやあんよが云うことを肯きませんや。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い空母さん　来るまで姉さんと青い空　青いから見てゐませう二歳で　あんよが出来たから母さんゐなくもゐられるわネ青い空　見ておゐで青い空に夜になると　お星さま出て来るのよう母さん　帰りが遅いときは門へ出て　姉さんと待つてゐませう。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛いいよちよち歩きの幼な児の前にしゃがんで、あとじさりしながら手をたたき、よろこびで笑いながら、マア、坊やお上手ね、そら、あんよ出来るでしょう？",
              "citation": {
                "source": "未来を築く力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京へ出る日には、アトファンを、寝る前に飲んで、朝痛みの少いようにしておいて、あんよは御上手程度に歩く。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "四国町まで、三日もかからあ、そんな、あんよじゃあ――」　と、声高に、云った時、火の番小屋の中から、駕屋が、手拭を提げて、御辞儀しながら出て来ていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "可愛いあんよね」と兼子は云った。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おてて、あんよ、おそろしいようですわ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごきげんよう、あんよちゃん！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "）「ああ、おいたわしや、あんよちゃん、こうなったらどなたにくつやくつ下をはかせてもらおうかしら、ねえ？",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と考えて、「って、もうふきだしそう、自分のあんよにプレゼントだなんて！",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもあんよでおあるきで、たべるときゃ断食ゃいたさない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪いことはいわねえ、鼻面を北の方へ向けてよ、真っ直ぐに谷中の森へあんよしな」　八五郎は好い心持そうでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの左の足の昆布卷を解いたら、思ひの外の丈夫なあんよが出るに違ひない、――と」「兎も角も氣になるよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "茶汲み四人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "手早く解いてやると、「濟みませんね、親分、どうなるかと思ひましたよ」　八五郎は隨分長く縛られて居たらしく、手足關節などを念入りに揉んで、漸くあんよは上手と立ち上がりました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "からくり屋敷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
