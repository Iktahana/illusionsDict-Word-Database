        "examples": {
          "standard": [
            {
              "text": "私は毎日あんよについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あんよという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあんよの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあんよが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あんよを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあんよについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あんよの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあんよの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあんよが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あんよという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあんよという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあんよについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あんよを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあんよは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あんよについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあんよが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんよは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあんよの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あんよは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあんよは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      }
