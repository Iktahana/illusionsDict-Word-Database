        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "デビューしたての若手俳優が、その卓越した演技力で瞬く間に世界中の映画ファンから注目を集め始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「さあ、今のうちに署名を集め始めないと、法案の採決に間に合わなくなる」と、活動家は道行く人々に訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "独自の製法で作られたそのクラフトビールは、SNSで評判が広がり、都心のビアバーでも着実に人気を集め始めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「お、やっと趣味の古いレコードを集め始めたんだね。いい趣味を見つけたじゃないか」と、父は満足そうに頷いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その革新的なリサイクル技術は、環境負荷の低減を目指す欧州の自治体から強い関心を集め始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "捜査チームは、犯人の足取りを解明するため、周辺の防犯カメラの映像や目撃者の証言を集め始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒の中に佇むその古民家ギャラリーは、洗練された空間作りが話題を呼び、静かに人々の注目を集め始めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "また、ある年齢に達すると、実際登ることはやめ、文献を集め始める人もある。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
