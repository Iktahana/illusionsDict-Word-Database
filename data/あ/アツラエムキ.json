        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋の遠足は天気が「あつらえ向き」だった。",
              "source": "幻辞"
            },
            {
              "text": "その職務は私の経験に「あつらえ向き」である。",
              "source": "幻辞"
            },
            {
              "text": "商品発表の日取りが「あつらえ向き」に決まった。",
              "source": "幻辞"
            },
            {
              "text": "新映画の公開日が「あつらえ向き」の時期だ。",
              "source": "幻辞"
            },
            {
              "text": "就職活動は春が「あつらえ向き」だと聞く。",
              "source": "幻辞"
            },
            {
              "text": "会場の収容能力が「あつらえ向き」に計算されている。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトチームの構成が「あつらえ向き」だ。",
              "source": "幻辞"
            },
            {
              "text": "融資が「あつらえ向き」の金額で認可された。",
              "source": "幻辞"
            },
            {
              "text": "キャンプの季節は6月が「あつらえ向き」である。",
              "source": "幻辞"
            },
            {
              "text": "新入社員の配置が部署に「あつらえ向き」だ。",
              "source": "幻辞"
            },
            {
              "text": "野菜の生育期間は季候が「あつらえ向き」だ。",
              "source": "幻辞"
            },
            {
              "text": "予算配分がイベント開催に「あつらえ向き」だった。",
              "source": "幻辞"
            },
            {
              "text": "新商品の発売タイミングが「あつらえ向き」である。",
              "source": "幻辞"
            },
            {
              "text": "船舶の寸法が港湾設備に「あつらえ向き」である。",
              "source": "幻辞"
            },
            {
              "text": "防疫体制が感染症対策に「あつらえ向き」に構築された。",
              "source": "幻辞"
            },
            {
              "text": "育成期間が人材育成に「あつらえ向き」に設定されている。",
              "source": "幻辞"
            },
            {
              "text": "天候がマラソン大会に「あつらえ向き」である。",
              "source": "幻辞"
            },
            {
              "text": "スタッフ配置が営業活動に「あつらえ向き」に構成されている。",
              "source": "幻辞"
            },
            {
              "text": "建物の広さが用途に「あつらえ向き」である。",
              "source": "幻辞"
            },
            {
              "text": "物流網が事業展開に「あつらえ向き」だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "しかし、そんな風な、まるでおあつらえ向きの条件になった原因を考えると、小沢はやはりその娘の体に触れることが躊躇された。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜のような晩は丁度あつらえ向きであるから、これからかの百物語というのを催して、妖怪が出るか出ないか試してみようではないか。",
              "citation": {
                "source": "百物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも二畳と三畳と六畳の三間で家賃は一円二十銭と書いてあったので、これはおあつらえ向きだと喜んで、すぐにその路地へはいってみると、思ったよりも狭い裏で、突当りにたった一軒の小さい家があるばかりだが、その戸袋の上にかし家の札を貼ってあるので、かれはここの家に相違ないと思った。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったくあつらえ向きに出来ているんですが、こっちにどうもあつらえむきの種がないんですよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠に当日叱られたということが、かれらに取ってはおあつらえ向きの材料で、お紋の母はそれから趣向をうみ出して、一個の狂言作者となりすましたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おあつらえ向きにできてやがるね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "開運女人地蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご高家仕えのご用人さんだから荒っぽい痛み吟味もできねえし、どうしたもんだろうとひと汗絞るところだったが、万事がおあつらえ向きだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "明月一夜騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "距離はかれこれ一町近くもあるうえに、得物は同じ弓であっても大弓ではなく半弓でしたから、それほどあつらえ向きに命中するはずはあるまいと思われたのが、すこぶる意外でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "日にしたらちょうど十三日、普通ならば十三夜の月が、今ごろはまぶしいほどに中天高く上っているべきはずですが、おりからの曇り空は、かえって人さらいの下手人をおぴき出すにはおあつらえ向きのおぼろやみです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの芝居は幕間が長いから、こんな討論会にはおあつらえ向きです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お近さんという娘は子供のときからお父さんの仕付をうけていますから、こういう屋敷にはおあつらえ向きで、主人の首尾もよく、自分も満足して、忠義一図に幾年のあいだを勤め通して、薙刀や竹刀撃に娘ざかりの月日を送っていました。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "清吉は今年十九で、色の白い、細面の粋な男で、こういう商売の息子にはおあつらえ向きに出来上っていたんですが、唯一つの瑕というのは身体に刺青のないことでした。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体これからどうなるんだ、われわれ人間さまは……」「ビフテキ――いや人間テキにされちまって彼等にぱくつかれらあな」「君なんかは肥っていて肉が軟かで、人間テキにはおあつらえ向きだってね」「何をいうか、僕はテキになるまでこんなところにまごまごしてやしない」「ふうん。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「空駕籠だな、おあつらえ向きだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というから泥棒よけにはあつらえ向きだ」とある。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに頓着せずに、二人は真っ直ぐに進んでゆくと、一方の海は遠い干潟になっていて、汐干狩にはおあつらえ向きであるらしく眺められた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "吉良の脇指",
                "note": "青空文庫"
              }
            },
            {
              "text": "店の前には大きい榎が目じるしのように突っ立って、おあつらえ向きの日よけになっていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "小女郎狐",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧暦の二十三日の闇の晩を狙ってやった仕事ですから、おあつらえ向きに行ったわけです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "この目的には金星は特に全くあつらえ向きにできていた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も科学の民族的相貌は現象的に見てテーマ的に云って第一テーゼであるに過ぎないので、現象を本質にまで溯源する分析の建前から行けば、第一テーゼはその階級性であるのだが、こういう認識論上のデリケートな要点は逆上している民族主義者の素質にとっては、仲々呑み込むのにあつらえ向きでないかも知れない。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わぬ人物がその小説の中で、どうしても是非その場合に出現しなければ、役に立たぬと思うときあつらえ向きに、ひょっこり現れ、しかも、不意に唐突なことばかりをやるという風の、一見世人の妥当な理智の批判に耐え得ぬような、いわゆる感傷性を備えた現れ方をして、われわれ読者を喜ばす。",
              "citation": {
                "source": "純粋小説論",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ようこその御参詣で、今日はあつらえ向きの松茸日和で結構でんな。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜びと期待に満ちて寝台に入り、ぐっすり寝込んで五時に目をさまして見ると空はあつらえ向きに、からっと晴れ渡っている。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、これがおあつらえ向きに、研究所の上を通ってくれるときでも、それが博士の熱望している三千万ボルトを越す超高圧の雷でない場合ばかりであった。",
              "citation": {
                "source": "超人間Ｘ号",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「草のみじかさかげんも、これならおあつらえ向きだ。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が知り度いと熱望していた「さまよう町の、さまよう家の、さまよう人々」のいる所へ、そんな夜遊神が連れて行ってくれると、余りにおあつらえ向きに云ってくれたのですもの。",
              "citation": {
                "source": "さまよう町のさまよう家のさまよう人々",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、おあつらえ向きにヘリコプターが上に待っていて、綱だか縄梯子だかを下ろしてあった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれをするにはおあつらえ向きの場所だよ。",
              "citation": {
                "source": "骸骨館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだ、シナ人の詩にあるじゃないか――孤憤何関児女事、踏青争上岳王墳――丁度まあその頃で、場面は西湖、時候は春で月明の夜というのだから、美人と共に逍遥するにはおあつらえむきさ。",
              "citation": {
                "source": "女侠伝",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "富農に買われる酔いどれの悪党としてはあつらえむきの兵士コスチンがある。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
