[
  {
    "uuid": "2357c45f-a49d-5ffa-8713-49fb23e66cac",
    "entry": "あ段",
    "reading": {
      "primary": "あだん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "row of syllables on the Japanese syllabary table that ends with the vowel sound \"a\"",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あ行の文字を書く時は、まずあ段から始めます。",
              "source": "幻辞"
            },
            {
              "text": "あ段の発音は全ての基本です。",
              "source": "幻辞"
            },
            {
              "text": "小学校でひらがなを習う時、あ段が最初に教えられます。",
              "source": "幻辞"
            },
            {
              "text": "あ段、か段、さ段と順に学びます。",
              "source": "幻辞"
            },
            {
              "text": "日本語の五十音図ではあ段が最初の列です。",
              "source": "幻辞"
            },
            {
              "text": "あ段に属する文字は「あ、い、う、え、お」です。",
              "source": "幻辞"
            },
            {
              "text": "あ段とは、日本語音韻体系の基本的な分類です。",
              "source": "幻辞"
            },
            {
              "text": "あ段は最も基本的な行として認識されています。",
              "source": "幻辞"
            },
            {
              "text": "あ段の「あ」の音は開口度が最大です。",
              "source": "幻辞"
            },
            {
              "text": "あ段を発音する際の舌の位置を確認しましょう。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さあ段々絵を見ると其｜理解が聴きたくなつて、母が裁縫なんかして居ると、其処へ行つては聞きましたが、面倒くさがつてナカ／＼教へない。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツイこの頃まで生きていた太田｜道灌のお声がかりなんてえシミッタレた町たあ段式が違うんだ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは推量さ」「向うへ行って、もし間違っていたら引っ込みが付くめえ」「そりゃあ段取りがありまさあね」と、彼は半七の無経験をあざけるように答えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して君の為にならない様な事はしないから」「色々の事情た、どんな事情です」「夫が少し込み入つてるんだが、まあ段々分りますよ。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は徴兵検査も済み、体格は甲の合格でありましたが、抽籤でまあ段々と国民軍へ編入される様な具合になつて了ひました。",
              "citation": {
                "source": "燕枝芸談",
                "author": "談洲楼燕枝（二代）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（両手で顔を押える）……ああ段六公、おら帰ろうてや、連れてってくれ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ段六さん、あがって休んで――。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、モスク※観光も、あんまりいそがないおつもり、というわけでしょうか」「もちろんいろいろな場合、御助力いただかなければなりませんけれど、まあ段々に――。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにがいったい考えに落ちねえのかい」「だって、よくまあだんなにゃ、しょっぱなから化け右門があの一座にいるとおわかりでござんしたね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して君のためにならないような事はしないから」「いろいろの事情た、どんな事情です」「それが少し込み入ってるんだが、まあだんだん分りますよ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくまあだんどりよく、あいつの仮面をはぎ、そしてあいつの害心を叩きつぶしてくれたね。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○幾日たつても同じ太陽が同じ色どりの、あだん科のうは葉に明々と照つてゐるので、すつかり今年の夏は平凡にすぎて了ひました。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今そのあだんのかげのあしやげのうらに鶯がしきりに鳴いてゐます。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "○しばらくつゞいた雨が、昨日やつと晴れて、またあだんの青に日の照る日のつゞくことでせう。",
              "citation": {
                "source": "島の便り",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあだんだんお解りなさいますでしょう」　十分根拠はあるのだが、礼儀上控えておくのだと云った風な佃の答えが伸子に好奇心を起させた。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
