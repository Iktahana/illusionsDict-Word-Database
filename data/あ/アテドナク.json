        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼は約束の時間までまだあったので、駅前を当て所なく散歩した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "人生の岐路に立ち、当て所なく時間を浪費しているように感じていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "失くした携帯電話を探すため、街中を当て所なく歩き回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「週末は何するの？」「特に予定はないから、あてもなくドライブでもしようかな。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "被災者たちは、避難所への移動を待つ間、広場を当て所なく歩き回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "飼い主とはぐれた子犬が、不安そうに辺りを当て所なく嗅ぎ回っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "さうだ、常任の平賀のところへ行つて話を聞かう、と思ひついたのはその眞闇がりのなかをあてどなく一町ほどもあるいたのちのことだつた。",
              "citation": {
                "source": "黎明",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "乙姫様は、宮殿の中で美しく着飾って、今日か明日かとあてどなく帰りを待ちわびている――そこへ「雲」が戻ってきて、無慈悲にも起こったことを話した――そして、正装した長い服を着た海の生き物たちは愛らしいものの、不器用であるが乙姫様をしきりと慰めようとしている。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてどなく立ち去るのも自分の心でない。",
              "citation": {
                "source": "ルバイヤート",
                "author": "RUBA'IYAT",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は空しい思いであてどなくうろつきながら、「これゃ、知識階級の苦しみという奴だ」　とこう思った。",
              "citation": {
                "source": "厨房日記",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆき子は夜露に光つた広い路を降りて、あてどなく歩いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よろめきながら街をあてどなく歩いた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は身をもがき、何かを振り落そうとでもするように体をゆすって、胸を叩きながら、家を飛び出し、あてどなく往来を走った。",
              "citation": {
                "source": "魔性の女",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レミュはその夜、ひとりで苦しみ、あてどなく祈り、ジョルジュの不幸の原因になっているエモフィリーという病気はどんな性質のものかと、あらん限りの状態を思いだして想像してみた。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」信一が神経質な鋭い眼を、あてどなく挙げた。",
              "citation": {
                "source": "朧夜",
                "author": "犬養健",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてどなくどこかを漂い歩いて、一生念仏して暮すだけのことですもの」　それまで黙って聞いていた妓王は、思わず息を呑んだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第一巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "果てしもない空の中にわたしの目はあてどなく迷うのであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなくばあてどなく道を彷徨うでしょう。",
              "citation": {
                "source": "民藝四十年",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日がつづき、焼けつくような太陽の下、何日もあてどなく漂流した。",
              "citation": {
                "source": "ダゴン",
                "author": "DAGON",
                "note": "青空文庫"
              }
            },
            {
              "text": "縺れ合う殺伐とした巨塔の上を飛びながら、時として私の想像力はあらゆる限界を逃れ幻想的な連想の諸王国をあてどなく彷徨った――この失われた世界とキャンプで出会った狂える恐怖にまつわる私自身の最も放縦な夢との間に関連性を糾おうとさえしながら。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "想像の力のない人間は、思いやりも同情もまして人間に対する愛などもてようもありません」　保に向ってかいているうちに、みんなが旺な食慾を発揮しながら、あてどなく時間と生活力を濫費している動坂の家の暮し全体が伸子にしんからいやに思われて来た。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信二は、あてどなくホームを往復して、出陣して行く米軍の兵士たちの列を見ていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十九の春まで、ころびばてれんの娘として、茗荷谷の異人屋敷に縛りつけられていたのを、その宿命の牢獄を破って、見も知らぬ広い世間の暗へ、あてどなく彷徨い出した混血児のお蝶であります。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて為定の門を辞して、あてどなく町を行くうち、ふと、石の地蔵尊を路傍に見かけると、何やら袂の物を供物にささげてそれへ額ずいていた。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
