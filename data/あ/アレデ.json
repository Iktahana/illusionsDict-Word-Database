        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その方法であれば成功できるだろう。",
              "source": "幻辞"
            },
            {
              "text": "高い給料であれば働く意欲が出る。",
              "source": "幻辞"
            },
            {
              "text": "あれであれば十分な利益が期待できる。",
              "source": "幻辞"
            },
            {
              "text": "その手段であれば目標が達成できる。",
              "source": "幻辞"
            },
            {
              "text": "短期間であれば対応可能だ。",
              "source": "幻辞"
            },
            {
              "text": "予算があれば改善できる。",
              "source": "幻辞"
            },
            {
              "text": "彼の協力であれば実現可能だ。",
              "source": "幻辞"
            },
            {
              "text": "その技術であれば革新が起こせる。",
              "source": "幻辞"
            },
            {
              "text": "スポンサーの支援であれば成功に近づく。",
              "source": "幻辞"
            },
            {
              "text": "適切な人材であれば組織は活性化する。",
              "source": "幻辞"
            },
            {
              "text": "その戦略であれば市場を掌握できる。",
              "source": "幻辞"
            },
            {
              "text": "時間をかけるであれば完璧になる。",
              "source": "幻辞"
            },
            {
              "text": "共同作業であれば効率が上がる。",
              "source": "幻辞"
            },
            {
              "text": "その方針であれば問題は解決する。",
              "source": "幻辞"
            },
            {
              "text": "事前準備があれば失敗は少ないだろう。",
              "source": "幻辞"
            },
            {
              "text": "彼女の理解があれば両立できる。",
              "source": "幻辞"
            },
            {
              "text": "新しいシステムであれば業務が簡素化される。",
              "source": "幻辞"
            },
            {
              "text": "適切な指導であれば潜在能力が引き出される。",
              "source": "幻辞"
            },
            {
              "text": "十分な情報であれば判断を誤らない。",
              "source": "幻辞"
            },
            {
              "text": "その基準であれば合格できる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "からだの弱さうな、気の弱さうな人であるけれども、あれで却々野心家だとも思つてゐた。",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでもし勝ったら、私は今ほど日本を愛する事が出来なかったかも知れません。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしはねえ、あれで小説家になろうと思って勉強したこともあるんですよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ、兄貴の言葉ではないが、教育界にゐてそんなことをしたからこそ、失敗なので、あれで、當時の政黨にゐて動いてゐたなら、あるひは成功したのかも知れない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大隅君は、あれで、なかなかむずかしいのですよ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれでゐて、グラムやバットを、隣りに預けて置くやうな芸当が出来るんかなあ……如何いつてお主婦に話をつけたんだらう……いや、耕二が芸当が出来るんぢやないんだ、親達がやかまし過ぎるんだ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いやお父さん、あれで負けたことはやつぱり口惜しいんですよ。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まああたしまだ、仕度なんてしてやあしないわ、それに今晩はあれですもの……夜間（撮映）……ねえ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、輝き出でるや、諸君は云ひます、「あれでああなのかねえ、不思議みたいなもんだねえ」が、冗談ぢやない、僕は僕が輝けるやうに生きてゐた。",
              "citation": {
                "source": "酒場にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも二、三百匹はゐるんだらうね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも、まだ、色氣があると見える。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだあれで、何か色氣があるらしいんだね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると心は叫ぶのだ、あれでもない、これでもない、あれでもないこれでもない！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士の登山諸道に、壮麗な神社があるのと対照して、これはこれ、あれはあれでいいと思う。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛や豚の殘骸はあれでも自然の斷片である。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文展へ行つて見ろ、島村觀山とか寺岡廣業とか、あゝいふのはみんな大家だぜ、こんなのとはちがわあ」「あれでも何處かへ持つて行きあ、三十圓や五十圓にやあなるんだよ」などといふのも聞こえた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、あれで、なかなか女らしいところもあるんだよ」と。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いて訊くと「あんな伯母さんのことを気にかけるものではありません」「仔細あって私たちは交際ってはいません」「あれで、なかなか裏に裏のある女でね」「あんな大きな山に住えば誰だって評判はよくなるさ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも民さん、あなたをば大変ほめているよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたでいくら心配してもお母さんがあれでは駄目だ」　これが台所会議の決定であったらしい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚自身にとつてみれば、あれで悲しんでゐるかも知れないのだ。",
              "citation": {
                "source": "橋上",
                "author": "――詩壇の議論家に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "行って清水のお貸元の身内になるんだ」　「石松、お前ん処の父っつあんあれで中々昔はやくざ仲間で鳴らした男だってね」　「何んだって、父っつあんがやくざ？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにはどう筆をつづくべきか、どう描き現すべきか、あれでぴつたりしてゐるか、あれでは力が足りないではないか、そんなことが絶えず一杯になつてゐたのであつた。",
              "citation": {
                "source": "處女作の思ひ出",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、あれで若しどつちかが斷然強くでもなつたとしたら、恐らく進まぬ方は憤然町内を蹴つて去つたかも知れない。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれでも何もしないよりはましであろう。",
              "citation": {
                "source": "喫煙四十年",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……おじいさんがなくなったのに、お母さんもつれずに、たった一人っきり、お父さんが帰っちゃったでしょう、あれで、もうすっかり、すべてが分るじゃないの。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「こないだだって、靴直しに三円持って行って、あれで、一円くらいあまっとる筈だのに自分で取りこんどるんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
