        "examples": {
          "standard": [
            {
              "text": "手術後の患者さんの早期回復のため、専門医による詳細な後療法プログラムが組まれています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "がん治療後の定期的な後療法検診で、副作用の早期発見に努めています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「怪我の回復には、リハビリテーションだけでなく、その後の継続的な後療法が大切だと言われました。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "抜歯後の後療法として、患部を冷やし、激しい運動を避けるよう指示がありました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "美容外科手術の成功は、術後の適切な後療法にかかっています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "高齢者のための、特定の慢性疾患に対する後療法ガイドラインが策定されました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この治療が終わったら、次はどのような後療法が必要になりますか？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
