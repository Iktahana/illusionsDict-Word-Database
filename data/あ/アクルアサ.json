[
  {
    "uuid": "6242f252-506f-5968-9ea1-3f4c943ba838",
    "entry": "あくる朝",
    "reading": {
      "primary": "あくるあさ",
      "alternatives": [
        "あくるあした"
      ],
      "is_heteronym": false
    },
    "grammar": {
