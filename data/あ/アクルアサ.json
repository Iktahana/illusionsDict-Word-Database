    },
    "definitions": [
      {
        "index": 1,
        "gloss": "next morning",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "翌朝、事態は一変していた。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、彼女の返事を受け取った。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、新しい日が始まった。",
              "source": "幻辞"
            },
            {
              "text": "その事件のあくる朝、新聞が大きく報じた。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、鳥たちが鳴いている。",
              "source": "幻辞"
            },
            {
              "text": "約束の日のあくる朝、駅前で会った。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、医者の診察を受けた。",
              "source": "幻辞"
            },
            {
              "text": "事故のあくる朝、警察の捜査が始まった。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、雪が積もっていた。",
              "source": "幻辞"
            },
            {
              "text": "告白のあくる朝、返事がメールで届いた。",
              "source": "幻辞"
            },
            {
              "text": "その会議のあくる朝、決定が発表された。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、目覚まし時計が鳴った。",
              "source": "幻辞"
            },
            {
              "text": "戦いのあくる朝、戦地には静寂が戻った。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、誰もが疲れた顔をしていた。",
              "source": "幻辞"
            },
            {
              "text": "病気のあくる朝、症状が軽くなっていた。",
              "source": "幻辞"
            },
            {
              "text": "試験のあくる朝、結果が掲示された。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、太陽が昇る。",
              "source": "幻辞"
            },
            {
              "text": "祭りのあくる朝、街は片付けられた。",
              "source": "幻辞"
            },
            {
              "text": "告白のあくる朝、二人は顔を合わせた。",
              "source": "幻辞"
            },
            {
              "text": "あくる朝、仕事に向かった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あくる朝、私たちはかえりの自動車のなかで、黙っていた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まずこれでいい」　そう云って、長屋の平和を祝していた人達は、そのあくる朝、大工の女房の報告におどろかされた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はあくる朝すぐに愛宕下の熊蔵の家をたずねた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、半七は師匠の送葬の様子を窺いながら妙信寺へ出かけてゆくと、師匠の遺骸は駕籠で送られて、町内の者や弟子たちが三四十人ほども付いて来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んでもねえものに突き当るかも知れねえ」　あくる朝、松吉の誘いに来るのを待って、半七は二人づれで神田を出た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　あくる朝になって源次が来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "その効験は著しいもので、お豊はそのあくる朝から神気がさわやかになって、七日ほどの後には元の達者なからだに回復した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あくる朝、父は山仕事に出る前に、「今日は、もう仕事に行け！",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝は、うめく程であった。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる朝、尾野間から二里ほど西の湯泊という村の沖のかなたに、きのうの船らしいものが見えたが、強い北風をいっぱい帆にはらみつつ、南をさしてみるみる疾航し去った。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝大へん早く起きたものがありますから、太郎さんは飛び起きますと、お母さんが坐って、「太郎さん、今日は雨がふって運動会がお休みになったのだよ。",
              "citation": {
                "source": "寝ぼけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝松石君が眼を醒ますと、傍に知らない男が寝ている。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、太郎さんと花子さんは二人揃ってお父様とお母様の前へ出て、「どうぞも一ペン東京に連れて行って下さい。",
              "citation": {
                "source": "犬と人形",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あくる朝、再びその新聞を見ると、八百屋が買物の蒟蒻を包んで呉れた古新聞で、日附は一年半ほども前の出来事です。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、二人がふっと眼を覚しますと、枕元に、一郎さんの方のには真白な大きなごむ鞠が、たえ子さんの方にはそれより少し小さくて、絹の色糸でかがったきれいなきれいな鞠が一つずつ置かれてありました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　あくる朝、ホモイは七時ごろ目をさまして、まず第一に玉を見ました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あくる朝、命の水を汲まうとすると、釣瓶に一杯、汚い獸の毛が浮いて上る……三毛猫の死骸が投込んであつた。",
              "citation": {
                "source": "間引菜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝なくなりました。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは後生楽の人間ですから、床へ這入つたが最後、夜のあけるまで一息にぐつすり寝込んで、夜なかに何があつても知らない方ですから、その晩も好心持に寝てしまつたんですが、あくる朝起きてみると、かみさんや娘が頻りに不思議がつてゐるんです。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝になって、その死体が芦の茂みから発見された。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「や、三河町か」四　あくる朝、半七は八丁堀の槇原の屋敷へゆくと、けさも杉野の用人の角右衛門が来ていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、女中がストーブの灰をかきだすと、兵隊さんは、小さなハート形の、すずのかたまりになっていました。",
              "citation": {
                "source": "すずの兵隊さん",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝、船はおとなりの国の、美しい都にある港にはいりました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子が結婚すれば、そのあくる朝、お姫さまは死んで、海の上のあわとなってしまうのです。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる朝、学者は喫茶店へ、新聞をよみに出かけました。",
              "citation": {
                "source": "影",
                "author": "SKYGGEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝になると、ネコも、ニワトリも、すぐに、いままで見たことのない、アヒルの子がいるのに気がつきました。",
              "citation": {
                "source": "みにくいアヒルの子",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝になると、下男と下女がはいってきました。",
              "citation": {
                "source": "モミの木",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でないと、このナイフを横っ腹へつきさすよ」　あくる朝、ゲルダは、森のハトの言ったことを、のこらず山賊の娘に話しました。",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これをお行儀のわるい子供たちの上にひろげると、その子たちは、ばかみたいに眠りこんでしまって、あくる朝目がさめても、なんにも夢を見ていないのです。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくるあさ、にはとりが目をさまして、のはらにいつてみますと、まへのばんのおつきさまが、しろくすきとほつて、空にのぼつてゐました。",
              "citation": {
                "source": "たまごとおつきさま",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
