        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "店員は、どんな客にも「愛想よく」対応するよう心がけている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は初めて会う人にも「愛想よく」話しかけ、すぐに打ち解けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新入社員は、職場の先輩たちに「愛想よく」挨拶をして回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その犬は、通りかかる人に「愛想よく」しっぽを振っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はパーティーで、誰とでも「愛想よく」会話を楽しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困っている人がいたら、「愛想よく」声をかけるのが彼の良いところだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "面接では、「愛想よく」振る舞うことが好印象を与える秘訣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こういう事に馴れ切っているらしい監督はきわめて愛想よく事件を処理した。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣り同士でもあり、殊に庄太の商売を知っているので、お作親子はふだんから愛想よく彼に附き合って、いろいろの物をくれたりした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君……僕の部屋はドコだったけね」　女は両腕に抱えた十余枚の洗い立ての浴衣の向うから愛想よく一礼した。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、女房は愛想よく云つて、わたしの火鉢に炭を継いでくれたりした。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七は愛想よく迎えられて再び二階の小座敷へ通されると、甚右衛門もあとから上がって来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "信吉はこんな場合、神経質に気を使って愛想よくするか、むっとしているかの、どちらかだったが、薄井の自信たっぷりの容貌は、信吉に、後者の方を選ばせてしまった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "睫毛の長い、大きな眼を愛想よくクルクルさせながら、何か二言三言早口に言って、昂作の垢だらけの手に五十銭銀貨を一つ握らせると、チョットあどけなくお辞儀をした。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は君にとても会いたかった」　女は突然愛想よく云われたのでそれをかえって皮肉にとった。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女を連れ出して、この喫茶店のアカデミックな空気の中に游がせて置けば、かの女は、立派に愉快を取り戻せるものと信じ切っているらしく、かの女に茶を与え、つまみ物を取って与えた後は、ぽかんとして、勝手な考えに耽ったり、洋食を喰べたり、元気で愛想よくテーブル越しに知人と話し合う。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」愛想よく麻川氏に座蒲団をすすめた。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんだって、きょうの私のがまんして愛想よくしている態度を、嬉しそうに見ていたじゃないか。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "主翁と婢が出て来てこの壮い旅人を愛想よく迎えた。",
              "citation": {
                "source": "立山の亡者宿",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいか一寸僻み易い甲野氏が、寧ろ彼から愛想よく出て来た。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで愛想よく、「御気の毒さまですわね。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は花田の言ったことはちゃんと聞き取ったと見え、愛想よく、「あゝ、稼ぐよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は、加奈子の気兼ねを受け取るように愛想よく言った。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時まであたしがこの部屋に残っていたら、あたしあいつにどんな憎しみを持って居ても、腰元の様に愛想よく使われなけりゃならないから。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それは七兵衛夫婦の内相談だけで、まだ誰にも口外したわけではなかったが、お此のほうにはその下ごころがあるので、きょう尋ねて来た甥を愛想よく迎えた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新子とは幾度も会ったことのある美沢の母は、愛想よく蒲団から、身を退らせて、挨拶した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ホームズは愛想よく答える。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "第六章　医学博士ジョン・ワトソンの回顧録（続き）　捕らえられた男はすさまじい抵抗を見せたが、別段我々に敵意を抱いているわけではないらしく、詮無いと悟ると愛想よく微笑み、今の争いで怪我はなかったかとこちらを気遣ってまでくれた。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝶吉は莞爾々々しながら、愛想よく仔細を尋ねて、（そう、今日お引越なすったの、何でしょう、兵児帯をして、前垂を懸けた、肥った旦那と、襟のかかった素袷で、器量の可いかみさんとが居る内でしょう。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「こうおかみ、憚りながらそういっておくんなせえ、済まねえがね、私あ気に食わねえから勘定をして貰ったって、お礼なんざいわねえって、」　お賤は気が練れた苦労人、厭な顔はちっともしないで、愛想よく、「ああ、可いともね、また礼なんぞいわせるようなお方じゃありません。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛想よくいつもにこにこして、葉巻きのたばこを横にくわえ、ざる碁をうって不平もぐちもなかった。",
              "citation": {
                "source": "老獣医",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まだ店はあるのかえ」「どうぞお休み下さい」と、若い女が愛想よく迎えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七が二日もつづけてくるので、彼女もなんだか不安らしい眼付きをしていたが、それでも笑顔を粧って愛想よく挨拶した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、泉水の傍らで、私の妻と茶卓子を囲んでゐた倉が、変なわらひを浮べて厭に愛想よく呼びかけた。",
              "citation": {
                "source": "心象風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは晦日のお手当を持って来たのであるから、延津弥は取分けて愛想よく彼を迎えた。",
              "citation": {
                "source": "廿九日の牡丹餅",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあお上がんなさい」　相手がただの人と違うので、金次は愛想よく半七を招じ入れて長火鉢の前に坐らせた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お久し振りでござりました」　女房のお藤はいつもの通り愛想よく迎えた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
