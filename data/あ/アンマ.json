    "definitions": [
      {
        "index": 1,
        "gloss": "massage (esp. anma, a traditional form of Japanese massage)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あん摩マッサージ指圧師は国家資格を持つ。",
              "source": "幻辞"
            },
            {
              "text": "腰痛の治療であん摩を受けている。",
              "source": "幻辞"
            },
            {
              "text": "あん摩は中医学の伝統的な治療法だ。",
              "source": "幻辞"
            },
            {
              "text": "医学的にあん摩の効果は証明されている。",
              "source": "幻辞"
            },
            {
              "text": "老人はあん摩で疲労を取り除く。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ選手はあん摩で筋肉の疲れを癒す。",
              "source": "幻辞"
            },
            {
              "text": "あん摩は指の技術と体の知識が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "あん摩の技法には様々な流派がある。",
              "source": "幻辞"
            },
            {
              "text": "医療保険の対象となるあん摩もある。",
              "source": "幻辞"
            },
            {
              "text": "健康維持の為にあん摩を定期的に受ける。",
              "source": "幻辞"
            },
            {
              "text": "あん摩の施術には高度な訓練が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "古代中国からあん摩の技術が伝わっている。",
              "source": "幻辞"
            },
            {
              "text": "リハビリテーションの一環としてあん摩を行う。",
              "source": "幻辞"
            },
            {
              "text": "あん摩師の人手不足が深刻化している。",
              "source": "幻辞"
            },
            {
              "text": "あん摩には痛覚を緩和する作用がある。",
              "source": "幻辞"
            },
            {
              "text": "法律的にあん摩の施術は有資格者のみだ。",
              "source": "幻辞"
            },
            {
              "text": "あん摩の施設は病院や整骨院に多い。",
              "source": "幻辞"
            },
            {
              "text": "あん摩の技術は代々受け継がれている。",
              "source": "幻辞"
            },
            {
              "text": "あん摩が医学部で研究されている。",
              "source": "幻辞"
            },
            {
              "text": "あん摩の経験を通じて東洋医学を学ぶ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あなたはそんなにパラソルを振る　　僕にはあんまり眩しいのです　　あなたはそんなにパラソルを振るさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、心理的生活（要するに一般生活）を営んでゐる者が、文学的生活（文学でなくもともあれ何かに打込んでゐる生活）を営んでゐる者に会つたつて、あんまり話のあるものではないのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな熱病的なことがあんまり沢山だものだから、文学志望者をだけ読者に持つやうな、浅間しいことにもなるのだ。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人類は、あんまり孤独の内包性を無視して来たのだと思ふ。",
              "citation": {
                "source": "深夜の峠にて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "外もあんまり涼しくはなかつた、家の中よりか涼しいくらゐであつた。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ書くことはいくらでもあるのであるが、なにさま記臆のない時のことであるから、あんまり書いて筆力の覚束ないところを出してもなるまい。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつそ嬰児時代のことなぞ省いてしまはうかと思ふのだが、何分自分の事といふものは、何から何までいとしいもので、笑はれるとは知りつゝも、まづまづ右の分量くらゐは省きも出来ない、――然しま、あんまりお笑ひ下さるな。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、あんまり淋しいから、おととしの秋から、ひとりであんな手紙書いて、あたしに宛てて投函していたの。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私は、彼もさすがにてれくさそうにして眼を激しくしばたたかせながら、そうして、おしまいにはほとんど不機嫌になってしまって語って聞かせたこんなふうの手柄話を、あんまり信じる気になれないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがあんまり本を読みすぎた結果、なんにも書けなくなったのだそうです。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた、あんまり馬場を信じ過ぎると、あとでたいへんなことになりますよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "をばさんも、娘さんも、はじめのうちは、私の音無しさに、かへつて奇怪を感じた樣子で、あのお客さんは女みたいだ、と蔭口きいて、私は、それをちらと聞いて、ああ、あんまり音無しくしてもいけないのか、とくやしく思つた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんは、すると、落ちついて私の傍に坐つて、あたしも何かお話しようと思ふのですが、お客さんがあんまり默つてゐるので、つい、あたしも考へてしまつて、何も言へなくなります。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あんまり威張るな。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "棟方志功氏の姿は、東京で時折、見かけますが、あんまり颯爽と歩いてゐるので、私はいつでも知らぬ振りをしてゐます。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "棟方志功氏の姿は、東京で時折、見かけますが、あんまり颯爽と歩いているので、私はいつでも知らぬ振りをしています。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噂に依ると、二三日前から――さう、だから彼等の噂に一日と続くものはあんまりない筈である――竹山を辞職させようといふ社長の考へだといふ噂があつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　　　　　　　※　扨我等の生活はとみるに、　活動か、寄席か、酒か女か玉突か、トラムプか、棋か、どれにしたもんだらう……部屋の中でジツと話してれあいいんだけれど、どうもそれもパツとしないしなあ……読書か、あれはあんまり興味もないが、さうも云つてゐられんしなあ……困つたなあ。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　　　　　　　※　だいたい散文芸術で血迷ふ前に、あんまりせかせかしたり野望的であつたりしさへしなかつたらば、詩芸術はもつとゆつくりと培はれてゐたであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだかお道化てゐるなしかしあんまり哀しすぎる。",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり勉強し過ぎて神経を痛めているのではないかという気がした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それがねえ、あんまり自信ないのです。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "科學精神とかいふものも、あんまり、あてになるものぢやないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり、うまくもねえか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私にはね、小さい舟が一艘あるけど、あんまり小さすぎて私たちふたりは乘れないの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりやもう私は、育ちもよくないし學問も無いし、あなたのお話相手が出來ないかも知れませんが、でも、あんまりですわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり私を蹈みつけにしては、だめです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このごろ僕は、人をあんまり追ひつめないやうにしてゐるのだ。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ゐた所に、わざわざ行つて再びみるといふことは、概してあんまりよいことではない。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり強く、按摩をすると、彼女の胴体には穴が明くのであった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
