        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あん摩について考えている。",
              "source": "幻辞"
            },
            {
              "text": "あん摩という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあん摩の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあん摩が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あん摩を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあん摩について学習した。",
              "source": "幻辞"
            },
            {
              "text": "あん摩の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあん摩の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあん摩が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あん摩という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあん摩という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあん摩についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あん摩を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあん摩は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あん摩について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあん摩が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあん摩は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあん摩の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あん摩は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあん摩は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
