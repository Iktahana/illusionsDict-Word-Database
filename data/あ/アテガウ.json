[
  {
    "uuid": "e620fcbd-f0c2-5f40-9078-230d9b1f177a",
    "entry": "宛がう",
    "reading": {
      "primary": "あてがう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
