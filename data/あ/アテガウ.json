    "definitions": [
      {
        "index": 1,
        "gloss": "to allot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "新入社員には、オフィスの隅にある使い古されたデスクが宛がわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今夜はここの客間を宛がいますから、旅の疲れをゆっくり癒してください」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "止血のために、傷口へ清潔なガーゼをしっかりと宛がう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "限られた月給の中から、まずは家賃や光熱費などの固定費を優先的に宛がう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「とりあえずこのおもちゃを宛がっておけば、しばらくは機嫌よく遊んでいるはずだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家具のガタつきを抑えるため、浮いている脚の下に薄い板の切れ端を宛がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「こんなもの、たまにあたしの鼻薬に持って帰って、宛がうなんて、うちの人もあんまりすることが見え過ぎているじゃないかねえ――」　ご新造さんは溜息をつきます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　千蔵に庄司を再興させ、三十人組の支配を宛がうという案は紋太夫から出たものだ。",
              "citation": {
                "source": "評釈勘忍記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の頭に考え浮べ得られる事を授けないでその代りに六かしい「定義」などをあてがう。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二本の前足を掴んで来て、柔らかいその蹠を、一つずつ私の眼蓋にあてがう。",
              "citation": {
                "source": "愛撫",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛飾の箪笥の抽斗からピストルを出して来ると、悲劇役者のような恰好にそれを顳※にあてがう。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "書生さんはそこいらに散らばっている茶器を押し除けて、奥から座布団を持って来て私にあてがうと、「私は妻木というものです。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "場割りの親方が、他吉を新米だと思ってか、「唐辛子はバナナ敲きの西隣りや」　と、いちばんわるい場所をあてがうと、他吉はいきなり「ベンゲットの他あやん」の凄みを利かせて、良い場所へ振りかえて貰ったが、「ああ、七味や、七味や、辛い七味やぜ、ああ、日本勝った、日本勝った、ロシヤ負けた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "つと立ち上ってビクトロラの傍に行って、またスキーパの曲に、針をあてがうと、ビクトロラに寄りかかるような姿勢をしながら、嘲笑を浮べて新子に話しかけた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "医学士が頷いたので、橘が筆をあてがうと、わずかに枕を擡げ、天地｜紅の半｜切に、薄墨のあわれ水茎の蹟、にじり書の端に、わか※とある上へ、少し大きく、佳い手で脇屋欽之助つま、と記して安かに目を瞑った。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "匙であてがう薬液を、よく唇に受けてじゅうぶんに引くのであった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "少歳は愛馬の夜飼をあてがうて、歸りに貯の栗柿など採出でゝ、俄に變る一家の歡樂場は四隣の人を羨せる笑ひどよめきを漏らした。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家のひとたちのあてがうものをこころよく食い飲みして、なんのこともなく昨夜まで過ごしてきたところ、けさは何時になっても起きないから、はじめて不審をおこし、いろいろたずねてみるとようすがわるい、きゅうに医者にも見せたがまにあわなく、そのうちまもなく息を引き取った。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "利かない薬をあてがうのは、見す／＼病家に無駄な金を使わせるようなものだ。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　口へあてがう宮子のコップの底を見詰めながら、彼は片手で宮子の手を強く握った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの美しい哲学的詩に物理学の尺度をあてがうのは穏当ではあるまい。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は他人の勉強をしているとき教養ある女性ともあろうものが何ぜ邪魔をするのだと怒りながらリカ子の部屋へ這入っていくと、あなただからこそいつでも何んでも頼めるのだ、デアテルミイのように直接自分の皮膚へあてがう機械の狂ったのを直して貰うのもあなただからこそではないかという。",
              "citation": {
                "source": "鳥",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "民主主義文学における指導ということは、あの小説を読め、これこれの小説を書け、そして社会についてこう考えろとケイをひいた紙をあてがうことではないと思います。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳をのまされないから牛乳をあてがうが、赤ん坊の守をしている子は小さい。",
              "citation": {
                "source": "ソヴェト同盟の婦人と選挙",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろり／＼と臑皿の下へ手をあてがうて動かして見やうとすると、大盤石の如く落着いた脚は非常の苦痛を感ぜねばならぬ。",
              "citation": {
                "source": "九月十四日の朝",
                "author": "病牀に於て",
                "note": "青空文庫"
              }
            },
            {
              "text": "から乳をよろこんで吸うときの、乳房へあてがう小っちゃな手の感触が、悲しいほどの疼きで思い出された。",
              "citation": {
                "source": "鴻ノ巣女房",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　飯をもって乙女の床のところへ来てミツ子にあてがうのであった。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アヤは方面委員の世話で慈恵病院に入ったが、附添はこっち持ちで、そのための交通費がいったし、祖父ちゃんがもって行く弁当にうちで皆のたべているスイトンをあてがうわけには行かなかった。",
              "citation": {
                "source": "小祝の一家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしめたとそこに近づき、手套を取り、両掌をその下にあてがうと、「さア呑め」と一郎に呼びかけた。",
              "citation": {
                "source": "箱根の山",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような時、堅い物を後頭部にあてがうと気持ちがよい。",
              "citation": {
                "source": "聖女人像",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人女給といふものも甚だ月並なもので、御亭主と懇ろになれば店に居つくが、さもなければ、いつ誰と消え失せるか、ヒモがついたり、無断欠勤の温泉旅行等々、わがまゝ無礼、元来この節の日本人の飲み助どもときては、女よりは酒、少しでも安く酒、たゞもう欠食児童なのだから、女などあてがうのはモッタイない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕らが今どのような健康状態にあるかを知らないくせに、このとおり特別料理を僕らにあてがうのは、でたら目すぎるではないか」「いや、そんなことはありません。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "慢性の胃病で、足がだるくて、細君の注意で足の下にあてがう布団が発明されて、それが習慣になって、五六年続いて、寝台車では鞄まで使って、足をぶら下げるようなことになって……。",
              "citation": {
                "source": "足",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫にあてがう食事としてはこちらの飯を分けてけずり節を少しかけてやる程度だが、魚類があれば少し分けてやる、生がかったメザシよりは干物の方を好んで食う、またあんパンなんどをつまんでやると飯よりはかえってよろこんで食う、いまの処｜肴よりはかえってパンが好きらしい。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "好ましい鬘を子にあてがうためには、一｜分二｜朱ぐらいの金は惜しいとは思わなかった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、子供にあてがう菓子も自分で町へ買いに出たし、子供の着物も自分で畳んだ。",
              "citation": {
                "source": "嵐",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "to supply with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "被災地では、避難してきた人々に一人当たり畳一畳分ほどの居住スペースが宛がわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "新しく配属された部署では、実務の教育担当として入社三年目の若手社員が宛がわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「とりあえずこの古い雑誌でも宛がっておけば、しばらくは静かにしているだろう」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "予算が削られた結果、各研究室には最低限の消耗品しか宛がわれていないのが現状だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "独身寮に入った新入社員たちには、六畳一間の簡素な個室が平等に宛がわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ほら、新しいおもちゃを宛がっておいたから、その隙に夕飯の支度を済ませてしまいなさい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "急な来客に対し、主人は物置同然の離れの一室を当座の寝所として宛がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "to fit to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "避難所に到着すると、一人分として毛布二枚と畳一畳ほどのスペースが宛がわれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「とりあえず、この余っている古いパソコンを彼に宛がっておいてください」と課長が指示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "傷口から出血していたので、清潔なガーゼをそっと宛がって止血を試みた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定規を宛がって正確な寸法を測り、布を慎重に裁断していく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ライフルを右肩にしっかりと宛がい、遠くの標的に向けて照準を合わせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "テーブルの脚がガタつくので、薄い厚紙を数枚宛がって高さを調整した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「おい、彼に適当な仕事を宛がっておけ」という乱暴な命令が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
