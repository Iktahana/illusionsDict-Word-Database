    "definitions": [
      {
        "index": 1,
        "gloss": "later (on)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「ごめん、今ちょっと手が離せないから、後でかけ直してもいい？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「その件については、詳細を確認した上で、後で改めてご報告します」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "重要な決断だから、今すぐ決めずに後でじっくり考えよう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "先に宿題を終わらせなさい。ゲームは後でね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "あの時すぐに謝っていればと、後で何度も後悔した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「とりあえず先に進めてください。細かい修正は後でまとめて行います」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "今は全体像を掴んで、個別の問題は後で一つずつ検討していきましょう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "超現実派の詩論なぞも読んでをりますが、そして所々非常な卓見にも遭遇しますが、要するに読んだ後では「今時誰も結論には到達しないのだ」といふ何時も乍らの呟きを繰返さなければならない始末です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、二ヶ月も気持が腐つて、湯にも這入らない後で、偶々お湯に這入つてごらんなさい！",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の我々の感性に近いもの、寧ろ民謡でさへある殉情詩が、此の殉情的な国で、今迄読まれなかつたなぞといふことは不思議だと、今度此の全集の第一巻が出た後では、諸君も必ずやさうお思ひになることと思ひます。",
              "citation": {
                "source": "宮沢賢治全集刊行に際して",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なぞまだ何処にも発表しない頃のことだし、何れ高森の方が早く所謂詩壇に出るのであらうと思つてゐたが、游牧記の後では、石川道雄主宰の半仙戯、其の後は友野代三主宰の童説といつたあまり世間の表てに顔を出したがつてゐない雑誌に発表するだけで、一向に其の他に発表はしたがらないのであつた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の此の家だつて、後で叔母の云ふ所によると、信者が家主であるさうで、その家主老夫婦が自分達の隠居のために建てたんださうで、値段に比べたら却々立派な家である。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局それは、夫人の強硬な反対によって中止されたが、後でそれが有名な化物屋敷と解った時、夫人がほッと胸を撫でおろしたとは反対に、ヘルンは大変失望して、『ですからなぜ、あの家住みませんでしたか。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "駄目です』などと夫人にからかわれ、『あ、どうしよう、私この鼻』など言って悄気返り、『真ッぴら、真ッぴら』と、今おぼえたばかりの日本語を面白がって使ったりして、夫人や女中たちを大笑いさせたりしているのだが、その後で、『しかし、よく思うて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしよく解った後では、全く子供のように正直一途で、子供のように純情無比の人であったと言ってる。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど『美しいシャボン玉』を壊さないように、注意に注意して気をつけましたと、未亡人となった夫人が後で言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた是非に参る、と、話のお土産』など言いながら、後ではいつも少し凋れて『しかしあなたの帰り、十時、十一時となります。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、歸つた後で妻が言つた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつと甚だしくは、談話の後で舌を出す皮肉な惡漢――意地の惡い諷刺家――とさへ想像した。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さんは私の背後で床の間を拭きながら、ええ、惡くなつた。",
              "citation": {
                "source": "九月十月十一月",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれからしようと思つてゐる訓辞はまた後で、全部教師等の集つた上ですることにしようかとも一度は顧つたが、……もう堪らなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "拙く長々と喋舌り立てられた、偶に滑らかに出た一節の後では、面を上げて教師達を一渡り見廻した。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長の去つた後で、途中から来た者と初めからゐた者とは話合つた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼には何か云つた後で、「さう、なくちや――なくちやならぬ」と慌てるやうに附加す癖があつたが、殊に修身の時間にはそれが頻々として出された。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私が思ふに、彼の考へる習慣は彼の良心の義務観念が作つたのだから、彼は考へた後では「一個人としての実践」をすればよいのだ。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、印象といふものが、十分に見極められ処理された後でなければ、観念だの理知だのの活動は十分には出来ないし、出来てもそれは、屡々芸術としてではなく出来るのが自然の法則だからであらう。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星氏がいつか或る随筆で書いてゐたが、仕事の終つた後で、きれいに机を片づけ、硯に墨をすりながら静かに句想を練る気持は、何とも言へない楽しみだと。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は珈琲店の椅子で酒を飲み、大衆と共に「あなたと呼べば」を唄つた後で、自ら自分の髪の毛をむしりながら、自分に向つて「この大馬鹿野郎奴」と叫ぶのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の白昼の街路を、祭の鉾や車が過ぎた後で、一雨さっと降って来たのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに宮森氏は、外国人の賞讃した批評を自慢らしく列記した後で、この通り外国で好評を博して居り、外国人でさへ賞めてゐるのに、日本人たる小宮氏輩が非難するとは以ての外で、同胞らしくもなく怪しからんことだと言つて怒つてゐる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヱルレーヌの影響があると思ふのですが……」その詩を読み終つた後で私が答へた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに日本人は、歴史的に思想を持たない国民であるから、本来哲学的の思想を根とする西洋文学の輸入に際して一もそれに適応する原語がなく、日本語字典のあらゆる言海を探した後で、止むを得ず「現実」や「自然」などといふ訳語を、無理にこじつけて適当させた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る教官が新兵に教へて、「日本の陸軍は本質的に外国の軍隊とちがふのである」と言つた後で、無邪気な新兵が質問した。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "式の前であったか後であったか忘れたが、大学の玄関をはいって右側の事務室でいろいろの入学手続をすませた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "師と子規と親密になったのは知り合ってから四年もたって後であったが懇意になるとずいぶん子供らしく議論なんかして時々｜喧嘩などもする。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二※月くらゐして、やつぱりその同人の集りのあとで、谷君他三人ばかりが、円タクの中からオイデオイデをするから行つてみると、これから牧野さんを誘ひ出しに行くから乗れといふのである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
