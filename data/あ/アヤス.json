    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to cuddle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "母親は赤ちゃんをあやして寝かせた。",
              "source": "幻辞"
            },
            {
              "text": "保育士は子どもたちをあやすことが仕事だ。",
              "source": "幻辞"
            },
            {
              "text": "祖母は孫をあやしながら子守唄を歌う。",
              "source": "幻辞"
            },
            {
              "text": "幼稚園ではあやすテクニックが教えられる。",
              "source": "幻辞"
            },
            {
              "text": "教育学では、子どもをあやす方法が研究される。",
              "source": "幻辞"
            },
            {
              "text": "心理学は子どもをあやすことの発達的意義を研究している。",
              "source": "幻辞"
            },
            {
              "text": "育児書ではあやしの効果的な方法が説明されている。",
              "source": "幻辞"
            },
            {
              "text": "保育専門学校ではあやすテクニックが実践的に教えられる。",
              "source": "幻辞"
            },
            {
              "text": "医学的には、あやすことで子どもの心身が安定する。",
              "source": "幻辞"
            },
            {
              "text": "親のメンタルヘルスにとって、あやすプロセスは重要だ。",
              "source": "幻辞"
            },
            {
              "text": "文化人類学ではあやすという行為が普遍的だと指摘する。",
              "source": "幻辞"
            },
            {
              "text": "音楽療法では、あやすために音楽が活用される。",
              "source": "幻辞"
            },
            {
              "text": "社会学は親がどのようにあやすかを分析している。",
              "source": "幻辞"
            },
            {
              "text": "古い文献ではあやすための民間療法が記されている。",
              "source": "幻辞"
            },
            {
              "text": "児童虐待防止ではあやす方法の正しい知識が重要だ。",
              "source": "幻辞"
            },
            {
              "text": "発達心理学ではあやすという相互作用が乳幼児発達に影響する。",
              "source": "幻辞"
            },
            {
              "text": "保育園では多くのスタッフが毎日子どもをあやしている。",
              "source": "幻辞"
            },
            {
              "text": "家族関係の研究ではあやすという行為が絆を深める。",
              "source": "幻辞"
            },
            {
              "text": "祖父母とあやすという行為は世代間の交流を促進する。",
              "source": "幻辞"
            },
            {
              "text": "特別支援教育ではあやすテクニックが個別対応で工夫される。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "近所のお内儀さんなどが通りがかりに児をあやすと、嬉しそうな色が父親の柔和な顔に漲る。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次「泣くな泣くな」とあやす。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも僕はまあやすんでいた。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "晃　（百合を背後に庇い、利鎌を逆手に、大勢を睨めつけながら、落着いたる声にて）ああ、夜叉ヶ池へ――山路、三の一ばかり上った処で、峰裏｜幽に、遠く池ある処と思うあたりで、小児をあやす、守唄の声が聞えた。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学士が驚いた――客は京の某大学の仏語の教授で、榊三吉と云う学者なのだが、無心の小児に向っては、盗賊もあやすと言う……教授でも学者でも同じ事で、これには莞爾々々として、はい、今日は、と言った。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出てゆきがけに泥棒がお愛嬌に、べろべろべろといつてあやすと、手足をばたばたやつて喜んでゐる始末だ。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "うまかったかい」と子供をあやすような調子で言いました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨てられているのかと抱いてあやすと、泣きやんで笑った。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「三時、三時……」　三時になれば眠れるぞと、子供をあやすように自分に言いきかせて、――しまいには、隣りの部屋の家人が何か御用ですかとはいって来たくらい、大きな声を出して呟いて、書き続けて来たのだった。",
              "citation": {
                "source": "郷愁",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "是非聴かして下さい……その第六感というのを……」　黒木は赤ん坊をあやすように、鷹揚にうなずいた。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからトント赤子でもあやすように、お口の内で朧におっしゃることの懐かしさ！",
              "citation": {
                "source": "忘れ形見",
                "author": "若松賤子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雉は山鳥、山の木へ、人に知られぬ巣をかけて、やんがて雛をあやすとて、ほろろほろろと唄ひます。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子をあやす道を知らぬのじゃ。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　坊ちやんはあやす程悲しくおなりになつて、涙を頬に光らせて、いつまでもしやくり上げてお泣きになる。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、今この女から嬰児をあやすやうな態度をとられたことが、少し気に喰はなかつた。",
              "citation": {
                "source": "雲雀病院",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その始末に困って次郎吉のところへ相談に行く途中、泣く児をあやす為に河豚太鼓を買った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人は気の毒さうに、三毛猫でもあやすやうに大統領の頭を撫でて言つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、お蝶さんが、たまたま赤子を置いて、一寸外へ出た留守に、赤子が泣き出すと、白は赤子の傍へ飛んで行って、ゆすぶりながら、あやす真似をするくらいの智慧のある犬でしたから、或は主人が何のために発狂したかをよく理解して居たのかも知れません。",
              "citation": {
                "source": "狂女と犬",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "額に入染む脂汗を拭き取つたり頭をさすつたり、まるで赤ん坊をあやす慈母のやうな優しさであつた。",
              "citation": {
                "source": "和解",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が赤ん坊をあやすと、その子は「あァ、ばァ」と発声した。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には、仕立屋のカールが、不意とフランツをあやすのをやめた、そのやめかたが気になっていた。",
              "citation": {
                "source": "顔",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　斯う言つて、圭一郎は即座に千登世を抱き締め、あやすやうにゆすぶり又背中を撫でてやつた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲れすぎたせいなんだから少し横になってごらんな」　姉は子供をあやすように福の肩を叩いた。",
              "citation": {
                "source": "父",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――しかしああやすやす欺されるとは、あの王子も大莫迦じゃないか？",
              "citation": {
                "source": "三つの宝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お雪伯母もまたそんな風に子供をあやす様に言ふのであつた。",
              "citation": {
                "source": "世の中へ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、父は子供をあやすやうに言つて、冷かに笑つた。",
              "citation": {
                "source": "父の婚禮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤チャンをあやすような顔で、あっしの顔を覗き込みましたがね。",
              "citation": {
                "source": "人間腸詰",
                "author": "夢の久作（夢野久作）",
                "note": "青空文庫"
              }
            },
            {
              "text": "汗まみれになった自分の髪毛を房々に撫で上げながら、赤ちゃんをあやすように言って聞かせた。",
              "citation": {
                "source": "継子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
