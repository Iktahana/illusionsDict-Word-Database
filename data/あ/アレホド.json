        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あれだけの努力をすれば成功するはずだ。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの資金があれば十分だ。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの経験を積めば一人前になる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの人手があれば完成できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの技術力があれば市場を開拓できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの時間があれば完了する。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの材料があれば建設できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの才能があれば活躍できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの資料があれば研究できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの支援があれば再起できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの知識があれば理解できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの装備があれば登頂できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの契約金があれば生活できる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの作品があれば評価される。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの言及があれば明確だ。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの遺産があれば裕福に暮らせる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの実績があれば信頼される。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの支持があれば当選する。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの影響力があれば変化を起こせる。",
              "source": "幻辞"
            },
            {
              "text": "あれだけの機会があれば人生は変わる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "單にフイクジヨン作りの手腕の巧さなどと云ふよりも、とに角あれ程の面白さを持つた相當の長さの作品を續々産み出すルブランはよつぽど好い頭の持主であるに違ひない。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ程の大家の娘が、あられもない賭博なんどとは……ちと受取り悪いが……」「ところが間違い御座いませんので……元来あの蔵元屋と申しまするは、蔵元町と申しまして町の名前にもなっておりまする位で、土蔵の数も七戸前。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ程の容色にべらべらしたものでも着せて見たいが親の人情だ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎外や芥川龍之介などどのようにしてあれ程多読出来たのか、どのようにして読書の時間をつくったのか、そしてどのようにして読んだものを巧く身につけたのか、その秘法があれば教えて貰いたいと思うくらいである。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何時の間にか、今しがたまであれ程派手で威勢のよかったのに引きかえ、後姿ながらひどく元気を失い如何にも悲しげな恰好に首や肩をまるまるとすぼめているのであった。",
              "citation": {
                "source": "嘘",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであれ程の頁で済んで居るから低徊趣味のないのも無理はない。",
              "citation": {
                "source": "高浜虚子著『鶏頭』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに前者に於て、ある男とある女の性的関係の階級等差が、あれ程細かく書いてありながら、些とも卑猥な心持を起させずに、ただ精緻な観察其物として、他をぐいぐい引き付けて行く処などは、何うしても旨いと云わなければなりません。",
              "citation": {
                "source": "木下杢太郎著『唐草表紙』序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "著者はあれ程性格が書いてあれば沢山ぢやないかと云ふかも知れないが、余の云ふ性格は要吉の特色を指すのである。",
              "citation": {
                "source": "『煤煙』の序",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実私としては白日の下で近来あれ程高貴で美麗な顔立ちを見たことが無いのだ。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ程の年をしながら青年のように女に対して興味が充実してる男が羨ましかった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前も、気の弱い、どこか、いじけたところのある子でしたが、でも、あれ程ではありませんでした。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれ程の真黒焦の焼餅やきな位だから、吾が夫のことでヒステリーのやうになると、忽ちサイコメトリー的、千里眼になつて、「吾が行へを寝ぬ夢に見る」で、あり／＼と分つて後追駈けたものであらうかも知れぬ。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならば、自分達の團結力を頼みにして、故意に先生の神經を苛立たせ、無理に先生の講義を分らない物にしてしまふやうな意地惡さがなかつたとは云へないから……、そしてもう少し柔かく靜かに迎へたならば、先生の氣持をあれ程までに擾亂させなかつたに違ひないから……。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "周囲の高い西洋の町であれ程背低だった加奈子が今｜茲ではひどく背高のっぽになった気持だ。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年の二月三木雄と結婚した智子はあれ程ヒロイックな覚悟と感動とを持って三木雄との生活にはいったのであるけれど、いよいよ夫となり妻となった生活には其処に盲の夫の暗黒の世界と妻の開明な世界との差が直ぐ生じて、それはむしろ智子の方へ余計積極的な苦労となったのである。",
              "citation": {
                "source": "明暗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、あれ程つき纏った小田島が直ぐ眼の前に居ようが女は一瞥もしなかった。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "持前の放浪性が、時と場合で走馬燈のようにぐるぐると京吉の気持を変らせるのは、いつものこととはいいながら、しかし、人恋しさと親切な気持からさっきまではあれ程なつかしく、いたわりもしていた芳子を、急に見捨てる気持になったのも、実に陽子の声をドア越しに聴いたという現金な気持からであろう。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれも Alexander Selkirk とか云ふ水兵の實事譚を種子にして作つたものださうですが、西班牙の海上權を打ち破る程の海軍も、一人手放した時、あれ程の爲事をする水夫のゐる國だから、發展することが出來たのでせう。",
              "citation": {
                "source": "ロビンソン・クルソオ",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻があれ程淫奔で、娼婦が斯くも貞淑だという事実は、卑屈なギラ・コシサンにも竟に妻の暴虐に対する叛逆を思い立たせた。",
              "citation": {
                "source": "南島譚",
                "author": "夫婦",
                "note": "青空文庫"
              }
            },
            {
              "text": "よもや満月花魁が、俺達の顔を見忘れはしまい……あれ程の仲であったものを……という自惚れと、見咎められては生きながらの恥辱という後めたさとが一所になった心は一つ。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概にしなさい」　稽古腰のあれ程強い翁に白旗を上げさせたのは古往今来この人一人であろう。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "後妻には山の中から久美子を迎え出して、谷山夫人を名乗らしている……そ……それあ怪しからんじゃないですか……二人は今後、絶対に人間世界に帰らないと云って、あれ程固く約束していたのに……イヤイヤ。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜ警察がまご／＼してゐるかと思ふと、あの場合に人を殺すだけの動機はよしや推測することが出来るとしても、なぜあれ程惨酷な殺し態をしなくてはならなかつたかと云ふ動機がどうしても見付からないからだ。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに智慧のない動物があれ程のことをしようとは誰だつて容易には考へ付くまい。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "己の身の上に就いてどれだけの事を知つてゐるのだか知らぬが、己の物だと分かつてゐる猩々を、あれ程の高価の物なのに、わざと受け取りに行かなかつたら、却て嫌疑が己に掛かるかも知れない。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕があれ程言ったのに、何だって君は読売なんぞに吹聴するのだ」「僕が何で吹聴なんかをするものかね」「それではどうして出たのだ」「そりゃあこうだ。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければあれ程腕のさえた沢田が進路を過る筈は絶対にない。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今が今、あれ程多勢にさわがれて送り出された自分であるとは、どうしても考へられなかつた。",
              "citation": {
                "source": "月下のマラソン",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に、あれ程の大きな心配の前に動いてゐる私に――何の憂慮も起させず陽光に浸るが儘に夢心地に入らうとまでさせた、――その美しい光景は、想像にお任せいたすより他はありません。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンについての一不思議は、あれほど広く多方面の文献に亘って、日本人以上に日本のことを知っていながら、日本語をほとんど知らなかったということである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
