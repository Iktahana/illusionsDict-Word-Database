        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あっという間について考えてみました。",
              "source": "幻辞"
            },
            {
              "text": "あっという間の意味を理解しました。",
              "source": "幻辞"
            },
            {
              "text": "日常生活であっという間が使われています。",
              "source": "幻辞"
            },
            {
              "text": "あっという間に関する知識を深めました。",
              "source": "幻辞"
            },
            {
              "text": "辞書であっという間を調べました。",
              "source": "幻辞"
            },
            {
              "text": "あっという間の用法について学びました。",
              "source": "幻辞"
            },
            {
              "text": "様々な分野であっという間が活用されている。",
              "source": "幻辞"
            },
            {
              "text": "あっという間の応用例を見つけました。",
              "source": "幻辞"
            },
            {
              "text": "専門家があっという間について論じている。",
              "source": "幻辞"
            },
            {
              "text": "あっという間についての研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "教育の場であっという間が教えられている。",
              "source": "幻辞"
            },
            {
              "text": "あっという間の歴史を追うことは興味深い。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からあっという間を理解する。",
              "source": "幻辞"
            },
            {
              "text": "あっという間の変化に気づきました。",
              "source": "幻辞"
            },
            {
              "text": "言語や文化におけるあっという間の重要性。",
              "source": "幻辞"
            },
            {
              "text": "分析結果からあっという間の特性がわかった。",
              "source": "幻辞"
            },
            {
              "text": "一般的なあっという間の使い方を習得しました。",
              "source": "幻辞"
            },
            {
              "text": "複雑なあっという間の概念を説明する。",
              "source": "幻辞"
            },
            {
              "text": "あっという間に関連する他の用語がある。",
              "source": "幻辞"
            },
            {
              "text": "最新のあっという間に関する情報を入手した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "その途端に、今まで暗かった水の上が急に明るくなって、なんだか知らねえが金のようにぴかぴかと光ったものがあるかと思うと、大きい魚が跳ねかえる音がして、為さんはあっという間もなしにすべり込んでしまったので、おれもびっくりして押えようとしたが、もういけねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "律気らしく野暮にこぢんまりと引きしまった顔だが、案外に、睫毛が長く、くっきりした二重瞼を上品に覆って、これがカフェ遊びだけで、それもあっという間に財産をつぶしてしまった男の顔かという眼でみれば、なるほどそれらしかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、宮子は鶴雄の手を掴んで、あっという間に、その手を自分の胸のふくらみに当てようとした。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "弓子があっという間にホールを出て行ってしまうと、小郷は軽い当身をくらったような、すかされた気持になったが、すぐまた背中をむき出しにしたダンサーをつかまえて、踊り狂うて行った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はあっという間に川の中へ落ちてしまった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、中風やみのようにぶるぶる手足をふるわせながら、しょぼんと立っていたが、ふと小沢の足許に二、三粒の飯粒が落ちているのを見るとあっという間にしゃがんで、その飯粒を口に入れた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どないしよう」「食べよか」「うん」　眼で語って、二人は同時に手を出したかと思うと、あっという間に口の中へ入れてしまった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も考えずに、あっという間にパンを口の中へ入れて、のどにつまり、眼を白黒させていた。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あっという間に、蜂谷重吉は姿を消してしまった。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お部屋の用意をしてお待ち申しておりやんすによって、どうぞごゆるりお越し下されやんせッ」　あっという間に、闇の中へ走りだしてしまった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、自分自身でも驚いてしまったほど意外なことなのだが、その夕方、轡川が莨を買いに行くと言って部屋を出て行った時、廊下で明日子と肩を並べながら海をみていたぼくは、ふと、明日子の白い首筋を見ると、あっという間にその首筋に手をかけて顔を傾かせ、接唇してしまった。",
              "citation": {
                "source": "ひとりすまう",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一枚々々皺をのばして、胴巻きにしまっているものを、見す／＼あっという間の快楽のために失ってなるものか。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "待って」「この醜くさ、この恥かしさ、そなたの前にさらすのも、今宵限りじゃ」　さらばじゃと、大袈裟な身振りを残すと、あっという間に佐助は駈けだして、その夜のうちに、鳥居峠の四里の山道を登って、やがて除夜の鐘の音も届かぬ山奥の洞窟の中に身を隠してしまった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっという間のことだったから、次郎は腹を立てたり、まあ待ってくれと言う余裕もなく、あっけに取られてしまった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっという間もなかった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、あっという間といえば、すべては一瞬の出来事だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホールが引けたら、いらっしゃい」　きっと待っていますよと、言ったかと思うと、返辞も待たず、あっという間にホールを出て行った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "くるまなければ、この方帰れないんだ」「今時分、おくるまなンかおすかいな」　あっては困る春隆のはらを、むろん女中は見ぬいていて、これは上出来だったが、余り心得すぎて、春隆がだんだんに陽子をひきとめる技巧を使おうと思っているのも知らず、あっという間に、さアどうぞと別室の襖をあけてしまった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はあっという間に、デッキの外へ落ちてしまった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっという間にお光を連れて、寺田屋の三十石に乗ってしまった。",
              "citation": {
                "source": "螢",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのトンネルの長さも、白崎にはあっという間に過ぎてしまう短かさであった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、あっという間に、国じゅうを半分までも巻き込んでしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほどそう言われてみれば、かつて親友杉山平一君より、君のあの小説のあそこはシナリオだねといわれたこともあったっけと、私はあっという間にこのおだてに乗ってしまった。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、清子はあっという間に、新吉の足もとにしゃがんで、膝小僧の傷を見る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その凹の露地の一方の入口へはいった新吉は、新聞を露地の家々へ配って、あっという間に、別の入口から――出て来たところは、矢野名曲堂の表である。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一刻もじっとしていられない気持で、豹一はまるで逃馬のように卒然となぐり書きして、あっという間に答案を提出してしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、土門の顔を見つけると、いきなり頭に手をあてて、あっという間に鬘を取ってしまった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "良い役をつけて欲しさに、監督とくっつきやがった挙句、到頭カル焼みたいに肥り出して来たお腹を、あっという間にもとのスタイルに整形したというかどで、ちょっと来なさい――そんな奴だよ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっという間の出来事だったので、男も手も足も出せず、しばらくしてようやく捕まったことに気づく有様だった。",
              "citation": {
                "source": "踊る人形",
                "author": "THE ADVENTURE OF THE DANCING MEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あっという間に。",
              "citation": {
                "source": "株式仲買人",
                "author": "THE STOCK-BROKER'S CLERK",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
