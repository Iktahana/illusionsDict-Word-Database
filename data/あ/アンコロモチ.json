        "examples": {
          "standard": [
            {
              "text": "あんころ餅は懐かしい日本の菓子だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は餅にあんこを塗ったお菓子だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅はきなこで仕上げられている。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は小腹が減った時に重宝する。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は保存期間が短いのが難点だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は季節によって味が変わることがある。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は道路沿いで売られていることが多い。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は和菓子の入門的な食べ物だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は温かい抹茶と相性がいい。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は生地の食感が大事だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は製造方法が単純だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は地域によって形が異なる。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は手作りすると更に美味しい。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は春夏秋冬いつでも食べられる。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は贈り物としても喜ばれる。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は甘さが優しいのが特徴だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は餅の柔らかさが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は江戸の名物として知られている。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は食べやすい大きさが工夫されている。",
              "source": "幻辞"
            },
            {
              "text": "あんころ餅は子どもから大人まで好まれている。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "二　牛｜部屋のかげで、さざんかが白くさくころに、松吉、杉作のうちでは、あんころ餅をつくりました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園寄の辻に、屋台にちょっと毛の生えたくらいの小さな店で、あんころ餅を売っている娘だそうです。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その框へ腰をお掛けなされまして、盆にあんころ餅寄越せ、茶を持てと、この美津に御意ござります。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はッ、」「き様、逢阪のあんころ餅へ、使者に、後押で駈着けて、今帰った処じゃな。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもしろ狸のきぬた巻でも、あんころ餅でも、鹿子餅でも、何でもございじゃ、はい、何でもござい、人気おこし、お菓子はよしか。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんころ餅　松任のついでなれば、そこに名物を云うべし。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "城下金沢より約三里、第一の建場にて、両側の茶店軒を並べ、件のあんころ餅を鬻ぐ……伊勢に名高き、赤福餅、草津のおなじ姥ヶ餅、相似たる類のものなり。",
              "citation": {
                "source": "一景話題",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の宿直室に先生のとまっているのを知って、あんころ餅を重箱にいっぱい持って来てくれるのもあれば、鶏を一羽料理して持って来てくれるものもある。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに僕のは、しるこ屋の前を通る、いろんな色の餅菓子やあんころ餅などが店にならべてある、堪らなくなって飛びこむ、片っ端から平らげて行く、満腹どころかのどにまでもつめこんでうんうん苦しがる、というようなすこぶる下等な夢だ。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "名物あんころ餅は旅客の大方は憇ひて味ふところ、秋の紅葉の頃に至れば、來りて遊ぶもの踵を接し、欄干をめぐらしたる茶亭に酒を汲みて一日を暮すもの甚だ多しと。",
              "citation": {
                "source": "秋の岐蘇路",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へえ、名物あんころ餅でございます。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを済まなく思ったのであろう、母もまた毎朝、大福やあんころ餅を仕入れた箱を背負って、ぼくと共に家を出かけ、工事場で一日売りひさいで、夕方は一しょに帰った。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、三十五錢では、病父、母、幼い弟妹など八、九人の家族はどうやつても食べてゆけないので、母は大福やあんころ餅を仕入れてぼくと一しよに作業場へ賣りにゆき、夕方母と一しよに歸り歸りした。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けえりにあんころもちでも大福もちでもたんと買ってね、子どもたちのその落ちくぼんだ目玉をもとどおりに直させておやんなせえましな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "母が甘い物を好んだので、平民社の直ぐ隣の塩瀬で、よくあんころもちを買つて帰つた。",
              "citation": {
                "source": "幸徳秋水と僕",
                "author": "――反逆児の悩みを語る――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
