        "examples": {
          "standard": [
            {
              "text": "祖父が去年あの世に行った。",
              "source": "幻辞"
            },
            {
              "text": "おばあさんはあの世に行ってから３年が経ちました。",
              "source": "幻辞"
            },
            {
              "text": "彼はあの世に行く前に子どもたちに言い残した。",
              "source": "幻辞"
            },
            {
              "text": "父がついにあの世に行ったとの知らせが届いた。",
              "source": "幻辞"
            },
            {
              "text": "医者は患者が危険な状態だと、あの世に行く可能性があると説明した。",
              "source": "幻辞"
            },
            {
              "text": "宗教の教えによれば、生きた者はいつかあの世に行く。",
              "source": "幻辞"
            },
            {
              "text": "葬式で僧侶は故人があの世に行ったことを祈った。",
              "source": "幻辞"
            },
            {
              "text": "あの世に行く瞬間は人生で最も大切な瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "文学作品では、主人公がついにあの世に行くシーンが感動的だ。",
              "source": "幻辞"
            },
            {
              "text": "仏教ではあの世に行った後の来世を信じている。",
              "source": "幻辞"
            },
            {
              "text": "年配者との会話であの世に行くについて話されることがある。",
              "source": "幻辞"
            },
            {
              "text": "医学生はあの世に行くメカニズムを学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "医療倫理ではあの世に行く際の患者の権利を議論する。",
              "source": "幻辞"
            },
            {
              "text": "法律ではあの世に行った後の遺産相続について定めている。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ選手が事故であの世に行くと大きなニュースになる。",
              "source": "幻辞"
            },
            {
              "text": "自然界の動物はあの世に行くことで食物連鎖が成り立つ。",
              "source": "幻辞"
            },
            {
              "text": "人生はいつかあの世に行くまでの旅だという哲学者もいる。",
              "source": "幻辞"
            },
            {
              "text": "あの世に行く前に人は人生を後悔することがある。",
              "source": "幻辞"
            },
            {
              "text": "すべての命あるものはいつかあの世に行く運命にある。",
              "source": "幻辞"
            },
            {
              "text": "古い言い伝えでは、あの世に行くと家族の元に帰ると言われている。",
              "source": "幻辞"
            }
