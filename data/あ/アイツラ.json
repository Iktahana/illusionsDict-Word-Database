        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あいつ等のせいで計画が台無しになった。",
              "source": "幻辞"
            },
            {
              "text": "職場のあいつ等は毎日ざわざわしている。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等の音楽がうるさくて眠れない。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等はいつも遅刻する習慣がある。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等の悪口が回ってきた。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等の無責任な行動に呆れた。",
              "source": "幻辞"
            },
            {
              "text": "学校のあいつ等はいじめをしている。",
              "source": "幻辞"
            },
            {
              "text": "営業部のあいつ等は結果を出していない。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等はいつも自分勝手な行動をする。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等の態度には信頼が置けない。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等のグループは派閥を作っている。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等は口では大きなことを言う。",
              "source": "幻辞"
            },
            {
              "text": "スポーツチームのあいつ等はチームワークがない。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等の約束は守られたためしがない。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等は常に問題を起こしている。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等のミスで会議が延長した。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等とは関わりたくない。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等の意見は参考にならない。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等のやり方は古くて効率が悪い。",
              "source": "幻辞"
            },
            {
              "text": "あいつ等のメンタリティが理解できない。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "あいつ等は一体、護送されているのなら、捕縄をかけられていなけりゃならないんだのに。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに近くでやりゃあ、あいつ等が目星をつけられらあな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがあいつ等たあ一体何だ？",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等あ」　ブリッジを歩きまわっていた、一運（一等運転手）は、コーターマスターに云った。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等はまあ当分は生簀にして置いて、ほかから来る奴らに気をつけろ」　多吉は承知して帰った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達はすきこのんで、あいつ等をやっつける身分かい！",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、あいつ等が占領しているのか、だいぶ豊かと見えるな」　そして、声のする噴水のかげの隅に向って、のびのびした挨拶の手を挙げていった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アハハハと笑って、陽気に怯かす……その、その辺を女が通ると、ひとりでに押孕む……」「馬鹿あこけ、あいつ等。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつ等の爲めばかりに詰らない教師などをしてゐるのだ」と考へると、顏を洗ふにも食事を濟ませるにも氣が進まず、出勤の時間が後れかける程ぐづ／＼してゐて、わざと車を呼んで、たツた三四丁のところを驅けらせることもある。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何の目的で、あいつ等は私をわざわざここまで連れ出したんだろう。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "――君は、そこが実に怪しいとは思わないかね」「どうもよく分からないね」「じゃ、なぜあいつ等は、ピイクロフトにそんなものを書かせたんだろう？",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等はあなたの手跡の雛形をとりたいと苦心していたので、あの時、あなたにそうさせるより他に方法がなかったのだと云うことが、――」「だが、なぜそんなものがほしかったのでしょう？",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであいつ等は、あなたに給料の前払いをして、バーミングへ追っ払ったんです。",
              "citation": {
                "source": "株式仲買店々員",
                "author": "コナンドイル　Arthur Conan Doyle",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴクトウ、お前は知っとるじゃろう」　と、彼の息子のほうを見ながら「あの密猟者隊を解散させた時、あいつ等が私を殺ろすと云ったのを。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この船に乗ってる兵隊の服を、服屋がこしらえたより、もっと真赤に染めてやろうじゃねえか」「だが、あいつ等は武装してますよ」　私は云った。",
              "citation": {
                "source": "グロリア・スコット号",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうすりゃあいつ等は、僕がこんなにみっともない癖して自分達の傍に来るなんて失敬だって僕を殺すにちがいない。",
              "citation": {
                "source": "醜い家鴨の子",
                "author": "DEN GRIMME AELING",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等は抜け道から土台下へ這い込んで、地蔵をぐらぐら踊らせていたに相違ねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "地蔵は踊る",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の立ち去るのを見送つてゐた隣りの男は、その時、私に話しかけるともつかぬ独白めいた口調で、「振られた人形が、二つ首をならべてゐやがるなんて、あいつ等、抜しやがつた。",
              "citation": {
                "source": "病状",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等はみんな青蛙神の奇特を知らないのだ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等がつかまえに来れば、おらあすぐに水に飛び込んでしまうから大丈夫だ。",
              "citation": {
                "source": "蟹満寺縁起",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「馬賊ツて、別にやつて来るんぢやなくつて、あいつ等がすぐそれになるのかも知れないからな……こんなところにとても泊れないよ。",
              "citation": {
                "source": "草道",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "――金菱では自分の系統から重役や重だった役員を連れてきて、あいつ等を追っ払う積りらしいんだ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しあゝなると、あいつ等も案外モロイもんだ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――森君、佐伯あいつ等が盛んに何んか材料倉庫で相談しているよ。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつ等の着ているペラペラした着物なんて、俺達がみんな着せてやってるんだ位、もう分ってもええ頃だな。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「憎いのはあいつ等だ、あいつ等だ。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等がぐず／＼云ったら引っくゝって引摺って来い。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかん　なに、あいつ等へ面當てさ。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あいつ等はそつとして置くに限るぞよ。",
              "citation": {
                "source": "歸國",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつらはただ、自分の品位を落しやしないか、それだけを氣にしてわくわくして、さうして妙に客を警戒して、ひとりでからまはりして、實意なんてものは爪の垢ほども持つてやしないんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
