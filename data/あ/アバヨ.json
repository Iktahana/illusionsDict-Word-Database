        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "友人が「あばよ」と言って去っていった。",
              "source": "幻辞"
            },
            {
              "text": "彼は金髪に「あばよ」と呟いて身を投げた。",
              "source": "幻辞"
            },
            {
              "text": "昭和の映画では、登場人物が「あばよ」と別れを告げる場面がある。",
              "source": "幻辞"
            },
            {
              "text": "古い小説の中で登場人物が「あばよ、みんな」と言う。",
              "source": "幻辞"
            },
            {
              "text": "粋な登場人物は「あばよ」という言い方で去っていく。",
              "source": "幻辞"
            },
            {
              "text": "明治時代の言葉使いでは「あばよ」が一般的だった。",
              "source": "幻辞"
            },
            {
              "text": "戯曲では、登場人物が舞台から「あばよ」と言いながら去る。",
              "source": "幻辞"
            },
            {
              "text": "古い日記に「その男は『あばよ』と言い残した」と書かれている。",
              "source": "幻辞"
            },
            {
              "text": "昭和の庶民的表現では「あばよ」は別れの言葉だった。",
              "source": "幻辞"
            },
            {
              "text": "文学の教室では「あばよ」という古い別れの表現を学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "その時代は、友人同士が「あばよ」と言い合ったものだ。",
              "source": "幻辞"
            },
            {
              "text": "時代劇では武士が「あばよ」と言って去る場面がある。",
              "source": "幻辞"
            },
            {
              "text": "懐かしい漫画の登場人物は「あばよ」とよく言っていた。",
              "source": "幻辞"
            },
            {
              "text": "思い出の映画館で、スクリーンの中の俳優が「あばよ」と言った。",
              "source": "幻辞"
            },
            {
              "text": "古い演技の教本には「あばよ」という台詞の言い方が示されている。",
              "source": "幻辞"
            },
            {
              "text": "その家族の歴史では、親父が毎日「あばよ」と言って出かけた。",
              "source": "幻辞"
            },
            {
              "text": "旅の宿で見知らぬ旅人が「あばよ」と言ってチェックアウトした。",
              "source": "幻辞"
            },
            {
              "text": "学園祭の劇で、役者は「あばよ、この学園」と台詞を言った。",
              "source": "幻辞"
            },
            {
              "text": "歌詞の中に「あばよ」という古い別れの言葉が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "手紙の最後に「では、あばよ」と署名する人もいた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "春なれば茶摘みの様汽車の窓より眺めて白手拭の群にあばよなどするも興あるべしなど思いける。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その方がいい、あばよ、』と言って主人はよろめきながら出て来たが、火鉢の横にころりと寝たかと思うとすぐ大いびきをかいている。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「早く帰って汝等の主人に（あばよ）といえッて、お丹様のお言だい。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒　ぢや、あばよ。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の難儀も構はばこそ、瓢箪棚の下に陣取りて、坊やは何處だ、母ちやんには、見えないよう、あばよといへ、ほら此處だ、ほらほらはゝはゝゝおほゝゝと高笑。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いざというとき、たゞおっぽり出されの、あばよで塩花を撒かれてしまうんではつまらないよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若旦那」「もうたくさん」「ほんとよ、若旦那、聞かなくってもいいの」「たくさん、たくさん、あばよだ」「いやな人ね、ひとが云ってあげると云うのに」「たくさん、たくさん」　広巳は頭にかかっていた塵を払い落したような気になって歩いた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庵を上げた見世物の、じゃ、じゃん、じゃんも、音を潜めただからね――橋をこっちへ、はい、あばよと、……ははは、――晩景から、また一稼ぎ、みっちりと稼げるだが、今日の飲代にさえありつけば、この上の欲はねえ。",
              "citation": {
                "source": "山吹",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "九郎助　もう行くのか、あばよ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こまつちやくれた尼つちよめ、へへへのへ、のんだくれの御本尊、掏摸や狗のお守番、猫の戀のなかうど、あばよ、さばよ。",
              "citation": {
                "source": "牧羊神",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばよ」そう言捨てて光子は行ってしまった。",
              "citation": {
                "source": "先生の顔",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あばよ、おととい来いだ！",
              "citation": {
                "source": "都の眼",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼は、もう少しの間見物人が静かだつたら――そこに悪童が現れて、袋竿で憐れな蝉を捕獲しようと忍び寄る風情を、鳴き続けてゐる蝉の細い思ひ入れで現し、悪童の接近を意識した蝉は、未だ／＼大丈夫だといふ風に歌ひながら静かに梢を回り、いよ／＼袋が近付いた瞬間に、（どつこい、さうはゆかない、あばよ。",
              "citation": {
                "source": "蝉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい加減遊ぶと忠公はぷいと、「あばよ、パいよ」と云って引こむ。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生犬め、それと見るなり、初めはおれの脹脛に咬みつきをつたが、紙束をおれに取りあげられてしまつたと感づくと、いやに哀れつぽい金切聲をたてたり、おべつかを使つたりしはじめたけれど、おれは構はず、『へん、お氣の毒さま、あばよ！",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あばよ、芝よ、金杉よ。",
              "citation": {
                "source": "芝、麻布",
                "author": "小山内薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あばよ……」　私はこの電話がまだ済まないうちに、いつの間にか窓から三尺ばかり離れて突立っていた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前が、よく、寄席でいうのう、虎と見て、石に矢の立つためしあり――人間の一心って通じるもんだよ――又、来らあ、あばよ」　庄吉が、立上った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええ――師匠」「うん」「あばよ」　庄吉が、一足踏み出した時「庄さん」　と、深雪が、叫んで、膝を向けた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戯談、云うねえ」　庄吉が、振向いて、笑うと同時に「あばよ」　と、吉松が云って、足早に、歩いて行ってしまった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、ここまで来て手ぶらであばよは助五郎の世話役趣味がどうしても許さなかった。",
              "citation": {
                "source": "助五郎余罪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あばよ」と言って、蓮葉にカラコロと歩いて行く姿が瞭然と私に残った。",
              "citation": {
                "source": "山の手の子",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とんちきめ、尋ねる人は、もうとッくに楽々と、蒲団の中で楽寝をしていらあ――あばよ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃあ刑事さん、あばよ」　貫一は、窮屈な恰好で捨台辞を重傷の刑事に残し、すたすたといってしまった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばよ」　そういって河合は、食料品を抱え直すと、マートン技師の許へ走り戻った。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先をいそぐから、これであばよ」　さしこ頭巾の老人は、そういうとすたすたと向うへ行ってしまった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げるだけ投げた手を、ぱたぱたとはたき上げたかと見る間に――　袋はそのまま杖槍は腰に、猿が猿まわしに取っつくように、がんりきの背中へ御免とも言わずに飛びつくと、心得たもので、がんりきの百が、そのまま諸に肩をゆすり上げて――「あばよ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、あすこの屋根の上に、ぼくの白ねこがあがっていて、あばよしているから。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤　じゃ、あばよ。",
              "citation": {
                "source": "渡鳥いつかへる",
                "author": "軽演劇一幕四場",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
