[
  {
    "uuid": "87e48490-4b85-5aa2-aec6-9428412ddff7",
    "entry": "哀訴",
    "reading": {
      "primary": "あいそ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
