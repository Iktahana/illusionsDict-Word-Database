        "examples": {
          "standard": [
            {
              "text": "新人にあたぼうと言ってしまった。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうというスラングは古い。",
              "source": "幻辞"
            },
            {
              "text": "その映画であたぼうというセリフが出てきた。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうは若い世代には理解されないだろう。",
              "source": "幻辞"
            },
            {
              "text": "言語学であたぼうのような古いスラングを研究している。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうといった時代の言葉を使う必要はない。",
              "source": "幻辞"
            },
            {
              "text": "その小説ではあたぼうという言い方が登場する。",
              "source": "幻辞"
            },
            {
              "text": "親世代はあたぼうという言葉をよく使っていた。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうは東京の下町言葉だったかもしれない。",
              "source": "幻辞"
            },
            {
              "text": "その演技ではあたぼうというセリフが活かされていた。",
              "source": "幻辞"
            },
            {
              "text": "昭和の時代劇ではあたぼうがよく聞かれた。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうという言葉の意味は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "その人物はあたぼうという古い言い方をしている。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうは時代遅れな表現である。",
              "source": "幻辞"
            },
            {
              "text": "その著作ではあたぼうについて説明されている。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうと言う習慣は消えつつある。",
              "source": "幻辞"
            },
            {
              "text": "言葉の歴史としてあたぼうは興味深い。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうをカジュアルに使う人はいなくなった。",
              "source": "幻辞"
            },
            {
              "text": "その歴史小説ではあたぼうというセリフが多い。",
              "source": "幻辞"
            },
            {
              "text": "あたぼうの語源について研究している。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "」「冗談いうな、あたぼうめ、そいつを教えてなるものか。",
