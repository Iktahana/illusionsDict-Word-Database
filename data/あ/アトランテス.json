        "examples": {
          "standard": [
            {
              "text": "バロック建築の正面を飾るアトランテスたちが、重厚なバルコニーをその肩で力強く支えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "優美なカリアティードに対し、アトランテスは筋骨逞しい男性の肉体美を強調した彫刻柱として好まれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "エルミタージュ美術館の入り口に並ぶ巨大なアトランテス像は、サンクトペテルブルクの象徴的な景観の一つだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「見て、あの柱。男の人が屋根を担いでいるみたい」「あれはアトランテスといって、古代ギリシャの神話に基づいた意匠なんだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "マニエリスム期の建築家たちは、あえて苦悶の表情を浮かべたアトランテスを配置し、視覚的な緊張感を演出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "神殿の崩落を免れた一本のアトランテスが、今も虚空を支え続けるかのように毅然と立っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
