        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "顧客へのあしらいが重要なサービス業の技術。",
              "source": "幻辞"
            },
            {
              "text": "その店員の丁寧なあしらいに感心した。",
              "source": "幻辞"
            },
            {
              "text": "営業のあしらいが上手い人がいる。",
              "source": "幻辞"
            },
            {
              "text": "医療現場での患者への適切なあしらいが大切。",
              "source": "幻辞"
            },
            {
              "text": "そのホテルのあしらいは最高級である。",
              "source": "幻辞"
            },
            {
              "text": "相手をあしらうのは簡単ではない。",
              "source": "幻辞"
            },
            {
              "text": "営業トレーニングではあしらいについて学ぶ。",
              "source": "幻辞"
            },
            {
              "text": "彼のあしらいは雑で失礼だ。",
              "source": "幻辞"
            },
            {
              "text": "社交の場でのあしらいのコツを知っている。",
              "source": "幻辞"
            },
            {
              "text": "その医者の患者へのあしらいは親切である。",
              "source": "幻辞"
            },
            {
              "text": "ウェイターのあしらいが神経質だ。",
              "source": "幻辞"
            },
            {
              "text": "異文化でのあしらいの違いを学ぶ必要がある。",
              "source": "幻辞"
            },
            {
              "text": "その営業マンのあしらいで契約を決めた。",
              "source": "幻辞"
            },
            {
              "text": "相手をあしらう時の言葉遣いが重要。",
              "source": "幻辞"
            },
            {
              "text": "その美容師のあしらいでリラックスできた。",
              "source": "幻辞"
            },
            {
              "text": "カスタマーサービスのあしらいスキルを向上させる。",
              "source": "幻辞"
            },
            {
              "text": "外交官はあしらいの技術に長けている。",
              "source": "幻辞"
            },
            {
              "text": "ホテル業界ではあしらいが競争力になる。",
              "source": "幻辞"
            },
            {
              "text": "その先生のあしらいは学生に好評である。",
              "source": "幻辞"
            },
            {
              "text": "店舗でのあしらいの質が顧客満足度に影響する。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "嘉門次はふと草原を切り靡けたような、路のあるのを見出して、太い短かい杖で、猪独活をあしらいながら、「熊が通った路だあ」と言った、草はよほどの重量を、載せたように、右に左に押し倒されて、その凹んだ痕が、峰の方へ、斜に切って、するすると登って行く。",
              "citation": {
                "source": "谷より峰へ峰より谷へ",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "室ごとに請わるるままに、金剛杖に焼印を押すが、不二の象形の下に、合目や岳の名を書いたり、不二形の左右に雲をあしらい、御来光と大書して、下に海抜三千二百何メートルと註してあったり、富士とうずまく雲を下に寄せて、その上に万年雪の詠句を題したものなど、通俗的の意匠が施されている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギャルソンの客あしらいに多少の薄情さはあっても、それがいつも芝居の舞台のように陽気に客を吹き流して行くロン・ポアンの店が、妙に春に似合う。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋盃へついで果物をあしらい盆にのせる。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人はよくよくあしらいかねたか、盗むように私を見てさっと顔を赭らめて初心らしい、そんな質ではあるまいに、羞かしげに膝なる手拭の端を口にあてた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやくいましめはゆるされたれど、なお心の狂いたるものとしてわれをあしらいぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷い挽割飯と、大根ッ葉の味噌汁と、塩辛く煮た車輪麩と、何だか正体の分らぬ山草の塩漬の香の物ときりで、膳こそは創だらけにせよ黒塗の宗和膳とかいう奴で、御客あしらいではあるが、箸は黄色な下等の漆ぬりの竹箸で、気持の悪いものであった。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の客あしらいかたがたどこからか借りて来たので、私が来たら聞かせようと言って待っていたとの事であった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "モンタージュはすなわちモンテーであり、マウンティングであり、日本語では取り付け、取り合わせ、付け合わせ、あしらいである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで山の中から拾ってきた猿のようなあしらいを受けた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの枯木寒巌のごとしと言って澄まし返った僧のような態度、言葉を実際にしたなら、相手の女性は一生恨み切るか、反撥的に自殺もしかねまじきあしらい方です。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人｜懸を悠々とあしらいながら、「ここ構わずに、ソレ入った入った。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥のままのと、一笊は、藍浅く、颯と青に洗上げたのを、ころころと三つばかり、お町が取って、七輪へ載せ、尉を払い、火箸であしらい、媚かしい端折のまま、懐紙で煽ぐのに、手巾で軽く髪の艶を庇ったので、ほんのりと珊瑚の透くのが、三杯目の硝子盃に透いて、あの、唇だか、その珊瑚だか、花だか、蕾だか、蕩然となる。",
              "citation": {
                "source": "古狢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　と鷹揚で、按摩と女房に目をあしらい。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに高慢たれで、腕はともかく客あしらいは存分にわるいと母親のおたかにも心細くわかり、かたがた百円の道供養はこの際の処置ではなかったか。",
              "citation": {
                "source": "婚期はずれ",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうするとあなたたちはまた、東京で暮して来た奴等は、むだ使いしてだらしがないと言うし、それかと言って、あなたたちと同様にケチな暮し方をするともう、本物の貧乏人の、みじめな、まるでもう毛虫か乞食みたいなあしらいを頂戴するし、いったい、あなたの奥さんなんて、どこが偉くてあんなに気取っているの？",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "私だって昔は浅草の父の屋台で、客あしらいは決して下手ではなかったのだから、これからあの中野のお店できっと巧く立ちまわれるに違いない。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの新聞社もやっぱり「鶴」をほめては呉れなかったし、友人たちもまた、世評どおりに彼をあしらい、彼を呼ぶに鶴という鳥類の名で以てした。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉は政宗に侵掠の地を上納することを命じ、米沢三十万石を旧の如く与うることにし、それで不服なら国へ帰って何とでもせよ、と優しくもあしらい、強くもあしらった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくぞ男に生れたる、と云う陽気でもなく、虫を聞く時節でもなく、家は古いが、壁から生えた芒も無し、絵でないから、一筆｜描きの月のあしらいも見えぬ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツルは女だからさすがに花をうまくあしらい美しいパノラマをつくる、また彼女はそれをつくり私たちにみせるのがすきだった。",
              "citation": {
                "source": "花をうめる",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この狂人は、突飛ばされず、打てもせず、あしらいかねた顔色で、家主は不承々々に中山高の庇を、堅いから、こつんこつんこつんと弾く。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……天麸羅のあとで、ヒレの大切れのすき焼は、なかなか、幕下でも、前頭でも、番附か逸話に名の出るほどの人物でなくてはあしらい兼ねる。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "妙にお客あしらいで、私をばお大事のもののようにして、その癖ふざけるから、皆が種々なこと云うんじゃアあるまいかね。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほうずきやら筒長の提灯の蔭のショーウヰンドウには、活動の人気俳優がふだん着に着て、そこらを散歩しそうな袷衣をマネキン人形に着付けさしたものが、五月｜菖蒲の造花をあしらいに鋭い燭光で男々しく照り光らされてあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体の加減のよいときは、わたくしを木の端か竹の端かのようにあしらいながら、病気が重って来ますとどういうものかまた周章てわたくしを重んじて来まして、「神様からの預りものを、今まで粗末にして勿体ない／＼」　と言って、ときには震える手を合せて、わたくしを拝むような真似をすることがあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を自分｜許りのものだと引っ張り寄せるように右腕で女の左腕を抱き寄せて居るが、女はそれがまんざらでもないらしくあしらい乍ら強いて彼に引き寄せられまいとしてジョーンの左腕にすがって居るようにも見える。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうだったのか――先刻からのこの医師の政枝に対するあしらいも矢張り死病の患者への気安めのあしらいだったのか。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "流石患者のあしらいに馴れた医師の態度だと、多可子は華岡を見直した。",
              "citation": {
                "source": "勝ずば",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
