        "examples": {
          "standard": [
            {
              "text": "彼は感謝の気持ちでありがた涙を流した。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙が頬を伝った。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙が止まらなかった。",
              "source": "幻辞"
            },
            {
              "text": "その瞬間ありがた涙が出た。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙を拭いながら礼を言った。",
              "source": "幻辞"
            },
            {
              "text": "人生で初めてありがた涙を経験した。",
              "source": "幻辞"
            },
            {
              "text": "深い感謝の気持ちがありがた涙になる。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙は心の底からの感謝である。",
              "source": "幻辞"
            },
            {
              "text": "この上ない幸運にありがた涙が出た。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙という言葉は日本語らしい。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではありがた涙が多く描かれる。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙は人間の最高の感情だ。",
              "source": "幻辞"
            },
            {
              "text": "恩人に出会ったときありがた涙が出た。",
              "source": "幻辞"
            },
            {
              "text": "人助けを受けてありがた涙を流した。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙は誰しもが経験するものだ。",
              "source": "幻辞"
            },
            {
              "text": "苦労の末にありがた涙が出た。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙は喜びと感謝が混ざった涙だ。",
              "source": "幻辞"
            },
            {
              "text": "奇跡を目の当たりにしてありがた涙が出た。",
              "source": "幻辞"
            },
            {
              "text": "ありがた涙は心が成長する瞬間だ。",
              "source": "幻辞"
            },
            {
              "text": "人生最良の時にありがた涙を流した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それを聞くと、アリ・ババは、ありがた涙にくれて、モルジアナをだきしめました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "三、アリ・ババと四十人のどろぼう",
                "note": "青空文庫"
              }
            },
            {
              "text": "ありがた涙もこぼさずに済む。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして彼らがこれほど長老を愛慕するのか、なぜ、彼らは長老の顔を見るやいなや、その前に身を投げてありがた涙にむせぶのか、それは、アリョーシャにとってはなんの疑問にもならなかった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点において彼自身も、これらのありがた涙に暮れる百姓や、子供を長老の方へ差し出す病的な女房などと変わりはなかった。",
              "citation": {
                "source": "カラマゾフの兄弟",
                "author": "上",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いお髯も泥ンこだい」　子供たちはそれを見て、囃したり手を叩いたり、よろこび廻ったが、救われた子の親たちは、決して信徒でもないだろうに、「神さま」　と、鯰たちの足もとへ額ずき、掌を合わせたままありがた涙にくれていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何にいたせおせっかいといえばいえなくもござりませぬがそれがみんな欲得をすてた姉おもいから出ていることがわかってみればお遊さんも父もありがたなみだにくれるよりほかはござりませなんだ。",
              "citation": {
                "source": "蘆刈",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
