    "definitions": [
      {
        "index": 1,
        "gloss": "hey!",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あいや、ちょっと待ってくれないか。",
              "source": "幻辞"
            },
            {
              "text": "あいやあいや、そりゃまずいな。",
              "source": "幻辞"
            },
            {
              "text": "「あいや、何言ってるんだ」と彼は笑った。",
              "source": "幻辞"
            },
            {
              "text": "喧嘩の最中、あいやと叫ぶ声が聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "あいやと驚いて彼女は後ずさった。",
              "source": "幻辞"
            },
            {
              "text": "運動会で掛け声「あいや、あいや」が響く。",
              "source": "幻辞"
            },
            {
              "text": "あいやと言いながら親父は電話を切った。",
              "source": "幻辞"
            },
            {
              "text": "舞台ではシーン転換時にあいやと叫ぶ。",
              "source": "幻辞"
            },
            {
              "text": "工事現場であいやという掛け声が響く。",
              "source": "幻辞"
            },
            {
              "text": "あいや、こんなところに落とし物があった。",
              "source": "幻辞"
            },
            {
              "text": "昔話ではあいやと驚く場面がよく出てくる。",
              "source": "幻辞"
            },
            {
              "text": "あいやあいやと相槌を打ちながら話を聞く。",
              "source": "幻辞"
            },
            {
              "text": "剣戟の音とともにあいやという叫びが上がった。",
              "source": "幻辞"
            },
            {
              "text": "あいやと言って老人は席を立った。",
              "source": "幻辞"
            },
            {
              "text": "江戸映画ではあいやという掛け声がよく使われる。",
              "source": "幻辞"
            },
            {
              "text": "あいや、そっちから来たのか。",
              "source": "幻辞"
            },
            {
              "text": "武道の稽古中あいやという掛け声が何度も聞こえた。",
              "source": "幻辞"
            },
            {
              "text": "あいやと返事して彼は奥へ向かった。",
              "source": "幻辞"
            },
            {
              "text": "江戸時代の商人はあいやと返すことが多かったという。",
              "source": "幻辞"
            },
            {
              "text": "あいやと言う仕草は関西方言の特徴だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "やあいやあい」　といって出て行った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば流氷のようなものでも舷側で押しくずされるぐあいや、海馬が穴から顔をだす様子などから、その氷塊の堅さや重さや厚さなどが、ほとんど感覚的に直観される。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　まあいやな瀬古さん。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子　まあいやだ、誰がひとの食べかいたものなんか食べるもんですか。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいや、しばらく待て。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はあいや匂やなにかは悪いでせうが生えることは沢山生えましてございませうね。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　同一年の、あいやけは、姉さんのような頷き方。",
              "citation": {
                "source": "女客",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……手前ことは江戸、下六番町に住居致しまする友川｜三郎兵衛次男、三次郎｜矩行と申す未熟者……江戸勤番の武士に父を討たれまして、病弱の兄に代って父の無念を晴らしに参りまする途中、思いもかけませぬ御力添えを……」「ああいやいや……」　平馬は非道く赤面しながら手をあげた。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とまあいやな奴なのだらうと云ふやうな意味がかいてあつたので、（そんなことがかいてあつたのかしらん、ほんたうに！",
              "citation": {
                "source": "秋が深い頃だ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあいやだ私は、どうしてこんなことまで、お話してしまったのでしょう！",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいや、敵討のお武家、ちとお話が反れましたようですが、加茂川が何か君に恥辱でも与えたというのかい、」「そうです、恥を掻かしやがったんで、対手は女ですよ。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一万円がほしいか、おとよさんがほしいかといや、おいら一秒間も考えないで……」「おとよさんほしいというか、嬶にいいつけてやるど、やあいやあい」　で話はおしまいになる。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "不二屋へ行っちゃあいやよ。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後には九郎助と弥助だけがのこる）九郎助　（にぎりめしを、まずそうに食ってしまった後）ああいやだ、いやだ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供は聲を嗄して一層烈しく、「いやあいやあ、あつち！",
              "citation": {
                "source": "輝ける朝",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――うん、でも、あんなことをして、かえってあの子があとでひどい目にあいやしないかしら、いま内儀さんたちもそう言ってたよ。",
              "citation": {
                "source": "夏の夜の冒険",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、判りました……つまり、富士山は、不二さん、に通ず……なんですね」「いいえ、そう云うわけでは」「ああいや、よく判りました……こりゃ、すっかり考え直しだ」　そう云って司法主任は、椅子の中へそり反りながら、「お蔭で、何もかも判り始めました。",
              "citation": {
                "source": "闖入者",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいやお武家、袴氏とやら。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あいや方々出ておいでなされ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああいやいや広太郎殿。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナーニ、だからさ、目前によ、悲鳴をあげている女だって、あさってになるとガラリと変り、『逃げちゃあいやよ、逃げちゃあいやよ』などと男にいうだろう、あさっての声が聞きてえものだ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、「まあいやだ！",
              "citation": {
                "source": "雲母片",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい二三日前も、おせきと行った茅屋根の家」「ええ」「大丈夫だね、よそへなんか置いて来ちゃあいやだよ」「あのう、畑んとこの家でしょう？",
              "citation": {
                "source": "小村淡彩",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばあさん曰く「憐れとも何とも云えたものじゃあありませんや、一寸此処に待っておいで、おいでと云っても、可怖いから行っちゃあいやーとつかまえてはなさないんでしょう。",
              "citation": {
                "source": "大正十二年九月一日よりの東京・横浜間大震火災についての記録",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいやだなと人を呼びにゆくところで、目がさめた。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのしみにしてその話、　中に一人赤いリボンの腕時計をし、お下げどめのしかたも東京風　「まあいやだ」などというのも東京風で色も白い、一寸リボンのついた靴をはき目立つ。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして一わたりすむと中入りには菓弁寿の御馳走、娘達はお世辞の言いくらやら、申訳のしあいやらで、小鳥の百々囀り、良時はただ喧ましく賑わしく、さて再び柝を入れると俄に鎮まりかえって満場ただ水を打ったよう……と見るもほんの一時すぐに又どこやらでヒソヒソ話が始まって、それが彼方此方へと移ってゆく。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度山から来た僧も大男で、恐ろしい目つきをして荒々しく陀羅尼を読んでいるのを、衛門督は、「ああいやになる。",
              "citation": {
                "source": "源氏物語",
                "author": "柏木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「魔ですって、まあいやな、そんなものにどうして憑かれておいでになるものですか。",
              "citation": {
                "source": "源氏物語",
                "author": "総角",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
