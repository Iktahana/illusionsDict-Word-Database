        "examples": {
          "standard": [
            {
              "text": "あっと驚くについて考えてみました。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くの意味を理解しました。",
              "source": "幻辞"
            },
            {
              "text": "日常生活であっと驚くが使われています。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くに関する知識を深めました。",
              "source": "幻辞"
            },
            {
              "text": "辞書であっと驚くを調べました。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くの用法について学びました。",
              "source": "幻辞"
            },
            {
              "text": "様々な分野であっと驚くが活用されている。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くの応用例を見つけました。",
              "source": "幻辞"
            },
            {
              "text": "専門家があっと驚くについて論じている。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くについての研究が進んでいます。",
              "source": "幻辞"
            },
            {
              "text": "教育の場であっと驚くが教えられている。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くの歴史を追うことは興味深い。",
              "source": "幻辞"
            },
            {
              "text": "文化的背景からあっと驚くを理解する。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くの変化に気づきました。",
              "source": "幻辞"
            },
            {
              "text": "言語や文化におけるあっと驚くの重要性。",
              "source": "幻辞"
            },
            {
              "text": "分析結果からあっと驚くの特性がわかった。",
              "source": "幻辞"
            },
            {
              "text": "一般的なあっと驚くの使い方を習得しました。",
              "source": "幻辞"
            },
            {
              "text": "複雑なあっと驚くの概念を説明する。",
              "source": "幻辞"
            },
            {
              "text": "あっと驚くに関連する他の用語がある。",
              "source": "幻辞"
            },
            {
              "text": "最新のあっと驚くに関する情報を入手した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それではほんとうに取りに行ったのかとは云ったが、よもやと思って笑っていると、やがてお糸がお待ち遠さまでございましたと持ち出して来た皿の上には、眼の下一尺あまりもあろうという大きな鯉が生きていて、しかもその鱗が燭台の灯にも紫に映ったので、みんなもあっと驚く。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがあっと驚くタメゴロウもびっくり。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同あっと驚く、東山もいつのまにかそこへやってきて群集の中に混じっている。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明に麻痺したる文明の民は、あっと驚く時、始めて生きているなと気がつく。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この工費を予算に出して現在の大蔵省に示したなら、恐らくあっと驚くであろうと観測される。",
              "citation": {
                "source": "増上寺物語",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそのつもりでこの時代の物語を読んで行くと、時々あっと驚くような内容のものに突き当たる。",
              "citation": {
                "source": "埋もれた日本",
                "author": "――キリシタン渡来文化前後における日本の思想的情況――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金助を川へ抛り込んだ米友は、物凄い面をして橋の上に置いた杖を拾い取ると、あっと驚く見物を見向きもせず、跛足の足を、飛ぶが如くに向う両国を指して走せ行ってしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "安房の国の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっと驚く人々、中には已に入口へと駈け出すものもあった。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっと驚くようなものなんだよ」　いくらたずねても、高橋さんは種あかしをしてくれません。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これはあっと驚くほどな出来事に違いない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっと驚くような、まったく、えたいのしれないものでした。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "将門は、大宝八幡の社家を宿営とし、さて、新年宴会をかねた戦捷祝賀の大饗には、「ひとつ、常総の諸氏が、あっと驚くように、盛大にやろうではないか」　と、彼らしい豪放さで、左右の者に計った。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人のしょうじょがにげ出そうとしていますと、あっとおどろくようなことがおこりました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、どんなおとなでも、あっとおどろくような発明だよ。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界じゅうの人が、あっとおどろくようなものだ。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごくなんでもないことの中から、じつにふしぎな、あっとおどろくような問題を探し出して、見せてくれるのです。",
              "citation": {
                "source": "智恵の一太郎",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがわかったとき、読者諸君は、あっとおどろくにちがいありません。",
              "citation": {
                "source": "灰色の巨人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、あっとおどろくようなことが、おこりました。",
              "citation": {
                "source": "おれは二十面相だ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
