        "examples": {
          "standard": [
            {
              "text": "その手紙はあぶり出しで秘密のメッセージを隠していた。",
              "source": "幻辞"
            },
            {
              "text": "スパイ映画ではあぶり出しの技法が使われる。",
              "source": "幻辞"
            },
            {
              "text": "警察はあぶり出しで証拠書類を検出する。",
              "source": "幻辞"
            },
            {
              "text": "科学捜査の教科書ではあぶり出しの方法が説明される。",
              "source": "幻辞"
            },
            {
              "text": "化学の授業ではあぶり出しを通じて見えない文字が現れる。",
              "source": "幻辞"
            },
            {
              "text": "美術の授業ではあぶり出しを使った表現技法が教えられる。",
              "source": "幻辞"
            },
            {
              "text": "法医学者はあぶり出しで改ざんされた文書を暴露する。",
              "source": "幻辞"
            },
            {
              "text": "古い手紙からあぶり出しで隠されたメッセージが発見された。",
              "source": "幻辞"
            },
            {
              "text": "スパイ小説ではあぶり出しが物語の重要な道具だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史の研究ではあぶり出しで古い文書の真実が明かされた。",
              "source": "幻辞"
            },
            {
              "text": "図書館の企画展ではあぶり出しの実演が人気を呼ぶ。",
              "source": "幻辞"
            },
            {
              "text": "子ども向けの工作ではあぶり出しが楽しい実験として紹介される。",
              "source": "幻辞"
            },
            {
              "text": "大学の美術科ではあぶり出しの応用について研究される。",
              "source": "幻辞"
            },
            {
              "text": "刑事ドラマではあぶり出しで犯人の企みが露見する。",
              "source": "幻辞"
            },
            {
              "text": "博物館では、あぶり出しの古い技術が保存されている。",
              "source": "幻辞"
            },
            {
              "text": "暗号学の研究ではあぶり出しが通信秘密の一例として研究される。",
              "source": "幻辞"
            },
            {
              "text": "心理学の実験ではあぶり出しで潜在意識を探る。",
              "source": "幻辞"
            },
            {
              "text": "教育学ではあぶり出しが創造的思考を促進する効果を研究している。",
              "source": "幻辞"
            },
            {
              "text": "アートセラピーではあぶり出しが治療的役割を果たす。",
              "source": "幻辞"
            },
            {
              "text": "社会学ではあぶり出しで隠された格差が可視化される。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "さーっと鏡の中の顔が消えて、あぶり出しのようにまた現われたりする。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辻占は、あぶり出し式になって居ります。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが新聞では駆落が平面になって、一枚の紙に浮いて出るだけで、云わばあぶり出しの駆落だから、食べたって身にはならない。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い頃より地質学、天文学、化学における赫赫たる奇妙な新発見を学び、大自然が懐中に隠す幽かな秘密をあぶり出し、天と地に記された言葉を見いだして愛読してきた。",
              "citation": {
                "source": "犬酸漿",
                "author": "Ａ. キングスフォード　A. Kingsford",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、あぶり出し、隠顕インクの使用による秘密通信、音楽による代用法、楽譜の暗号、縄や紐の結び目による代用暗号法、暗号としての神代文字など、いろいろあるが、大体の種目は以上につきると思う。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか二日まえに――あの蜻蛉売りの久助の家に泊った晩――そこの行燈に書き残してあった日本左衛門の文字が、ともすると、お蝶の胸に、あぶり出しのようにういて出ます。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今、ある薬品をかけてあぶりだしたら、こんな絵があらわれたのです。",
              "citation": {
                "source": "深夜の電話",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍と薄曇美しき水だしあぶりだしの包装紙、縁日の葡萄餅屋が絵行燈の朱と萌黄と薄むらさき、大経師が店先の組上燈籠三枚続きのいのちにも似ると云つたら分るか。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更、師匠の底知れぬ心づくしのほどがあとからあとからあぶりだし玩具にあらわるる絵のごとくマザマザと眼先に描かれてきた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
