        "examples": {
          "standard": [
            {
              "text": "友人の転勤を聞いてああ無情と思った。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトがキャンセルされてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "長年の研究が無駄になってああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "主人公の悲劇的な最期にああ無情と感じた。",
              "source": "幻辞"
            },
            {
              "text": "優秀な学生が進学できなくてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "患者の状態が悪化してああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "判決が予期しない厳しいものでああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "才能ある選手が怪我でキャリアを失ってああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "貴重な生態系が破壊されてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "歴史的建造物が失われてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "レストランが閉店してああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "旅の目的地に行けなくなってああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "親友と別れることになってああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "展覧会が中止されてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスパートナーとの関係が破談してああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "可愛い子どもが成長して離れていくことにああ無情を感じた。",
              "source": "幻辞"
            },
            {
              "text": "治療不可能と診断されてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "裁判に負けてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "オリンピック選手団から外されてああ無情だ。",
              "source": "幻辞"
            },
            {
              "text": "野生動物が絶滅寸前でああ無情だ。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "『一八六一年、ユーゴウはこの家に滞在して、あの「｜ああ無情」のなかのウォタアルウのところを書いたんです。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "無宿者の歩みつく道一面の広野と化した巷の風ああ無情の風と歎く我身なり。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "★　その時のセリフは、メモに曰く、「ああ無情、ああ……」　三高泣く。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ無情、ああ……」　三高手足をバタつかせて、もがき、また泣く。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ああ無情の著者ビクトルユーゴーは、自殺者ではなかった。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きながら「ああ無情」と喚いたのは、酔ッ払いの単なるウワゴトとは思われない。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだん通俗な雑誌しか読まない男が、俄かに「ああ無情」や芥川や太宰を読むのはタダゴトではない。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺文士の本に何らかの読む理由があったように、ああ無情も読む理由があったのは云うまでもないね。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ無情と云ってるだけじゃないか」「放さないでくれ、ああ無情と云ってますよ」　と巨勢博士はニヤニヤ笑った。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "とヤケの演説をしながらも、酔えば、ああ無情、話してくれるな、と泣くのです。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
