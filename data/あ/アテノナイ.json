      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "aimless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「明日はどこへ行こうか」と、彼は地図を広げたまま、当てのない思索にふけっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "大学を卒業したものの、将来への希望を失い、当てのない日々をただ漫然と過ごしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「どうしようもないなあ」と、彼女はただ当てのない足取りで部屋の中をうろうろと歩き回った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "主人公は、過去の過ちから逃れるように、どこかへ向かうでもない、当てのない放浪を続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "激しい変化の時代において、多くの人々が自分の進むべき道を見失い、当てのない不安を感じている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「結局、何が言いたいんだ？」と、彼は議論が当てのない方向に進んでいることに苛立ちを覚えていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "彼のまわりはどっちを見ても無智と当てのない悔恨、泥酔、飽き飽きする程お互に傷け合うような惨酷さが充満している。",
              "citation": {
                "source": "逝けるマクシム・ゴーリキイ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで雲を掴むような当てのないことであるが、私はそれから小村方を出て、寒い空に風の吹く砂塵の道を一心になって、女に食べさすために口馴染みの祇園のいづ宇の寿司などをわざわざ買いととのえて三条から大津行きの電車に乗った。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな思いをして毎日じっとして欝いでばかりいるよりは、当てのないことでも、往って探してみる方がいくらか気を慰めると思って、私は、十二月のもう二十九日という日に、わざわざそちらの方へ出かけていった。",
              "citation": {
                "source": "狂乱",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼は当てのない呪いの言葉を口走った。",
              "citation": {
                "source": "火葬国風景",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "出がけにちやうど道で一緒になる機会をまたつかまへればつかまへるのだが、彼は、当てのないことを待つといふのが嫌ひである。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとをいふとだよ、本校の復旧工事は、まつたく当てのない金をあてにして計画を立てたんだ。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　姉に許されて恋しい小次郎と、夫婦になるということは、浮藻にとって、例えようもない、嬉しいことには相違なかったが、この乱れた世に二人ばかりで、当てのない旅へ出るということは、辛い悲しいことであった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ひとつ生きる目当てのない人だ。",
              "citation": {
                "source": "ワーニャ伯父さん",
                "author": "ДЯДЯ　ВАНЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまよい疲れ、当てのない望みに疲れ、にんじんは、とてもだめだと諦めた。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てのない希望をもたせて、解決をできるだけ遷延させてゐるといふ印象を受けますね」「あら、どうして？",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "無罪になることがあると言つてくれるひともございますけれど、それこそ当てのない望みで、じつさいに罪がなければ、一応の取調べで裁判までにはならぬという話が、ほんとうのように思われます。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、彼もいささか気色ばみ、「わしは、まだ職権をもつていうわけじやないですが、当てのない金で長逗留をするのは、あとで悶着の種になる……」　と、増田が言いかけると、「職権をもつて言うんでなけれや、それや、君、余計なお節介だ。",
              "citation": {
                "source": "この握りめし",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は六兵衛の当てのない忿怒を見捨て、ガラッ八と一緒に奥へ通りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "女としての誇りのためにだけでも、私は、私の当てのない貞操は守らなきゃならない」「――――」　それは恐ろしい矛盾でした、婦人の言葉は真剣で熱心で、少しの偽瞞があろうとも思われなかったのです。",
              "citation": {
                "source": "法悦クラブ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の手紙につきまとった或る当てのない痛心や卑屈さやについて。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは彼女だけの問いかけではない、この家族と同じような、切りぬける当てのない貧困に追われ続けて、疲れはてた人間ぜんたいの叫びであろう。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ながら、書生さん、あんたにこんなことはなかったかね……その……まあ早い話が、当てのない借金をしようとなさったことが？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャズ山の森でぶらぶらして、当てのない迎え便を待つよりずっといい。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにあるものは恰も霧、この手で掴もうと思うても掴みどころのない霧ですね、靄、霧を相手に格闘しているような、渾沌とした、目当てのない、intellectual disturbance ――知的混乱、――なんかこうもやもやしている。",
              "citation": {
                "source": "悦しき知識",
                "author": "――停年講義（昭和三十三年九月十六日）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は相当著名な詩人だそうだが、数年前に国を離れ、詩も捨てて、当てのない旅に出、日本へも来たのであった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来丈五郎は傴僂息子に命じて、春代の行衛探しに努めたが、当てのない探し物故仲々目的を達しなかった。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ貧しくてお金の当てのないときも、父はいつもにこにこして幸せでした。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蝶は足のつま先に物欲しい目を落としながら当てのない心を抱いて歩きました。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼に妻子がなかったら、日本に幻滅した最初の日に、再度また『まだ知らぬ新しい国』を探すために、あてのない漂泊の旅に出発したにちがいなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば家なき児レミがミリガン夫人に別れを告げて船を下りてから、ヴイタリス老人とちょっと顔を見合せて、そうしてあてのない旅路をふみ出すところなどでも、何でもないようで細かい情趣がにじんでいる。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは冬になってからの初めての寒い日で、その忍従な母親にもあてのない憤りを起させる程の寒さだった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから船便を求めてあてのない極東の旅を思い立ったが、乗り組んだ船の中にはもうちゃんと一人スパイらしいのが乗っていて、明け暮れに自分を監視しているように思われた。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは山の温泉場であてのない祝言をした。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら賃銀は貰ったって、こんなあてのない仕事は厭だ、今年はもうだめなんだ、来年神官でも呼んで、よくお祭をしてから、コンクリーで底からやり直せと、まあ私たちは大丈夫のやうなことを云ひながら働いたもんです。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あてのない消息あてのない詩でも書かうよ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
