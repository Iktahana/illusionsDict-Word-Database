[
  {
    "uuid": "2ba61b0a-c301-5e17-9b19-7ba7c6e00629",
    "entry": "当てのない",
    "reading": {
      "primary": "あてのない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
