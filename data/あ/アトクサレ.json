[
  {
    "uuid": "0ac84f7c-83f6-572f-b940-db79f0a8a489",
    "entry": "後腐れ",
    "reading": {
      "primary": "あとくされ",
      "alternatives": [
        "あとぐされ"
      ],
      "is_heteronym": false
    },
    "grammar": {
