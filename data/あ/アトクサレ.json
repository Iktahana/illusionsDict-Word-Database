    },
    "definitions": [
      {
        "index": 1,
        "gloss": "future trouble",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "退職する際は、後腐れがないように、引継ぎをしっかりとしておきたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "別れるにしても、お互い後腐れのないように、きちんと話し合って円満に解決したい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "親の遺産相続は、後腐れを残さないよう、専門家を交えて話し合うべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "「金銭の貸し借りは、どんなに親しい間柄でも後腐れの元になるからやめた方がいい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "今回の契約は、双方納得の上で、後腐れなく解消することができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "一時の感情で共同事業を解消すると、後々まで後腐れが残るものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            },
            {
              "text": "個人間での高額な品の売買は、後腐れがないように書面で契約を交わすべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-pro"
              }
            }
          ],
          "literary": [
            {
              "text": "自殺は人の勝手のやうなものだが、華嚴飛び込くらゐ智慧の無い、後腐れの多い、下らない死方は無い。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿沼さんらしいやり方だけれど、後腐れがなくていい。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "気持ちに何の後腐れもなくさっぱりとした。",
              "citation": {
                "source": "擬体",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしあなた、私の現在の立場ぢやアこれを一晩であしらふ手だてがむづかしい、九分九厘後腐れ、四谷怪談になりかねないところだから、こゝはつらいところだな。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局自分にまつはりつく後腐れだけが厭なのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "後腐れだつて、実はちつとも怖くないのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "金のかかる売笑婦には然し気持の後腐れといふものがないが」　どこまで喋つたらきりがあるといふのであらう。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハハハ、無頼一匹、うまく斬っても、斬られてもだ、よしんば捕えられても後腐れはないからなあ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ切つて、皆んな言つた方が、後腐れがなくて宜くはないかね」　平次は俯向いた佐太郎に斯う促しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "娘と二千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「断るにしても、しかし、下手なことをすると後腐れが面倒だ。",
              "citation": {
                "source": "春泥",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度はイヤな思ひをなさるつもりで、この書き手を搜し出し、後腐れのないやうになさいませ」　平次はかうでも言ふ外はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "紅筆願文",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも出会ったら最後、息の根を止めるだけじゃなくって、お前や坊主まで、後腐れを怖がってバラすにきまっている。",
              "citation": {
                "source": "沓掛時次郎　三幕十場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪い野郎ですけどこんな時の役には立つ素盲の金五郎が、またやって来ましてね、この一件を小耳に挟むと、止めるを肯かずに飛び出しましたが、此方が頼んだ訳ではなし、金五郎が勝手に買って出たのですから、おかみさんは高見で見物していれば後腐れなく片付きます。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "後腐れといえば金五郎の方だが、此奴はあッしの親分に口をきいて貰い、五両か十両で片付けます。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人から後腐れないやうな挨拶をされちや、男の方から未練を言ふ筋はあるまい。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、外の男は、此方から押し掛けて行つて、後腐れのないやうに斷つたお由良が、八五郎だけは懷ろに突つ張つてゐる十手の手前もあるから、今日半日神妙に附き合つてよ、天神樣の藤を眺めながらお前に止めを刺さうといふ段取りだつたのさ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人から後腐れないような挨拶をされちゃ、男の方から未練を言う筋はあるまい。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、外の男は、こっちから押し掛けて行って、後腐れのないように断ったお由良が、八五郎だけは懐に突っ張っている十手の手前もあるから、今日半日神妙に付き合ってよ、天神様の藤を眺めながらお前に止めを刺そうという段取りだったのさ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お由良の罪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度はイヤな思いをなさるつもりで、この書き手を捜し出し、後腐れのないようになさいませ」　平次はこうでも言う外はありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "紅筆願文",
                "note": "青空文庫"
              }
            },
            {
              "text": "――でもあつしのは、すぐ忘れるから、後腐れがありませんよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花嫁の幻想",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人に行先まで教えてしまっては、命の鍵を握られているも同様、それに、二人の仲を薄々嗅ぎつけた様子だから、後腐れのないように、バッサリやって、何処か遠くへ飛ぶ工夫が肝心だと思うが――」　およつの肝の太さ、あまり気の進まぬ日下部欽之丞を説き伏せて、底の知れない悪魔の淵へと誘い入れる積りでしょう。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "役者を買って、それを殿様に仕立てたり、お小姓にしつらえたり、或る時は奴にしておともにつれて歩いたりなんぞすれば、好きと自由で、後腐れがなくて面白いじゃないの。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ行くと、後腐れのない相手を選んで、思う存分、遊んだり遊ばれたりするのが、いちばん賢い――とはいうものの、あの穀屋のイヤなおばさんのようでも困りますねえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "不破の関の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そう後腐れがあるようじゃ困るから、百さん、気のどくだが、この話はまず、破談だな」　金貸の七兵衛は、そういって、もう、さっさと戻りかけた。",
              "citation": {
                "source": "野槌の百",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その演奏に接すると、常勝将軍が兵をやるごとく、いささかの不安も、こだわりも、後腐れもない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "龜と子供ぢやあ、その間にはひつて仲裁しても、あとくされがありませんからね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしはそのお礼によって、あとくされと紛議をかもさないように奥さんにご用立てしましょう。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀と子供ぢやあ、その間にはひつて仲裁しても、あとくされがありませんからね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとくされのない生活、さういう生活をしたい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ屋のおかみさん来庵、すまなかつた、梯子酒のあとくされである。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
