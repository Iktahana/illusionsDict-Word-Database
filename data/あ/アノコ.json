[
  {
    "uuid": "a98df71b-388c-5093-98f2-26bc32be81b1",
    "entry": "あの子",
    "reading": {
      "primary": "あのこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
