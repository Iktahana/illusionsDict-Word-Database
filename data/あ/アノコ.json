    "definitions": [
      {
        "index": 1,
        "gloss": "that child",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「見て、あの子、ブランコに乗るのが本当に上手ね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "いつも図書館で熱心に本を読んでいるあの子は、きっと文学に興味があるのだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "去年の運動会で選手宣誓をしたあの子の姿が、今でも鮮明に思い出される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "迷子になっていたあの子を保護し、無事に親元へ返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「もし、あの子が困っていたら、いつでも声をかけてあげてね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "初めて会った時、あの子の澄んだ瞳に引き込まれるような感覚があった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "近所のあの子は、毎日元気いっぱいに遊び回っていて、見ているとこちらも笑顔になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……「併しあの二番目の子は良かつた、あの子が生きてさへゐれば……」――　渡り廊下を駆け寄つて来る看護婦の足音がした。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事にならないうちに、あの子が早く出て行つてやればよかつたのに。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつたい、あの子は、どうしたのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子は、決して怒りやしない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何をあの子等は考へてゐるであらう――　だが、私は子等の心の中へだけ入り込んで終ふと云ふことは出来なかつた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "子等の心の中に入り切る事は出来なかつたが、あの子たちよりも、もつともつと不幸な子供たちが沢山あるし、又、これからはもつと、ずつと殖えるに違ひない、と私は思つた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの子も、おつな真似をすることを、ちょんぼり覚えたね」　柚木にはだんだん老妓のすることが判らなくなった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、あの子の口や齒はおまへに似てるよ。",
              "citation": {
                "source": "氷と後光",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹽花こそふらね跡は一まづ掃き出して、若旦那退散のよろこび、金は惜しけれど見る目も憎ければ家に居らぬは上々なり、何うすれば彼のやうに圖太くなられるか、あの子を生んだ母さんの顏が見たい、と御新造例に依つて毒舌をみがきぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩花こそふらね跡は一まづ掃き出して、若旦那退散のよろこび、金は惜しけれど見る目も憎ければ家に居らぬは上々なり、どうすればあのやうに図太くなられるか、あの子を生んだ母さんの顔が見たい、と御新造例に依つて毒舌をみがきぬ。",
              "citation": {
                "source": "大つごもり",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子は容易に素足にならなかったから下駄をはいて池へはいったかどうか、池のどのへんからはいったか、下駄などが池に浮いてでもいるか、あなたちょっと池を見て下さい」　妻のいうままに自分は提灯を照らして池を見た。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "半五郎、フト思い出して、　「じゃ源兵衛さん、うちの親分の身内になりてえと云う石松ってなァ」　「そうよ、俺の伜だ」　「ほう、じゃ、あの当時、いつも姐さんに抱かれてたあの子供が、そうかい？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子もおとなしく稼ぐようだから阿母もまあ、安心だ」「いえ、実はそのお蝶のことに就きまして、今晩お邪魔にあがりましたのでございますが、どうもわたくし共にも思案に余りましてね」　四十女のひたいの皺をみて、半七は大抵想像がついた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「他の事ではない、あの子も喜ぼう。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」口早に言って花束を手渡してやっても、あの子はぼんやりしていますので、私は、矢庭にあの子をぶん殴りたく思いました。",
              "citation": {
                "source": "兄たち",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは、いかにも不機嫌そうに眉をひそめ、それから仕方無さそうに笑い出し、「話にも何もなりやしないんですよ、あの子のそそっかしさったら。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おかみから、いま聞いて来たんですけどね、」　と橋田氏も、まじめな顔をして、「あの子は、腎臓結核だったんだそうです。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子は、ねばねばして、気味がわるいから、あなたに一度うんと叱っていただきたいと思いまして、と奥さんが言い、旦那さんは、そうか、どこにいるんだ、と言い、奥さんは平然と、どこかそこらにいるでしょう？",
              "citation": {
                "source": "男女同権",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな事で、もう、わかれてしまうなんて、あの子も、意久地が無いね。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子だなんて、失敬な呼び方は、よしてくれ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついぢに凭れてあつち見て、あの子がひとり　　まつてゐる。",
              "citation": {
                "source": "輪まはし",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜があけたから、あの子どもを起さなけあいけない。",
              "citation": {
                "source": "水仙月の四日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ああさっきから歌っていたのはあの子供らだ。",
              "citation": {
                "source": "マグノリアの木",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子規の「仰臥漫録」には免れ難い死に当面したあの子規子の此方の世界に対する執着が生々しいリアルな姿で表現されている。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子供のように澄んだ眼でじっとラムプを見つめながら、ぷつりぷつりと乾いた西洋紙に孔を明けている園の様子が見えるようだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして船頭に渡賃を云われて小銭を船頭の掌に渡すあの子は、もう一度船頭の掌の中の小銭を覗き込むだろう。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの子は多少ケチな性分だから――丁度その頃を見計らって、自分が知らん顔をして、艇を渡船と平行に、すいすい持って行く。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころは、私自身も、ほんとに、少し、おかしかったのでございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と彼女は云つた、奴はもうあのことを修道院の中に云ひふらしてゐる！",
              "citation": {
                "source": "山間秘話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのころはよかったなあ。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "you",
