    },
    "definitions": [
      {
        "index": 1,
        "gloss": "all (there is)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "可能な限り努力するつもりです。",
              "source": "幻辞"
            },
            {
              "text": "生きている限り希望を持ち続けたい。",
              "source": "幻辞"
            },
            {
              "text": "学べる限り新しい知識を取得しましょう。",
              "source": "幻辞"
            },
            {
              "text": "医療技術が進歩する限り治療法の選択肢は広がる。",
              "source": "幻辞"
            },
            {
              "text": "学生である限り研究に専念できる。",
              "source": "幻辞"
            },
            {
              "text": "社会人である限り責任を果たす必要がある。",
              "source": "幻辞"
            },
            {
              "text": "健康な限り仕事を続ける予定だ。",
              "source": "幻辞"
            },
            {
              "text": "時間がある限り家族と過ごしたい。",
              "source": "幻辞"
            },
            {
              "text": "資金が続く限りプロジェクトを進める。",
              "source": "幻辞"
            },
            {
              "text": "科学が進歩する限り謎の解明は続く。",
              "source": "幻辞"
            },
            {
              "text": "歴史が繰り返される限りパターン認識は有効だ。",
              "source": "幻辞"
            },
            {
              "text": "技術が発展する限り新しい可能性が生まれる。",
              "source": "幻辞"
            },
            {
              "text": "人間が存在する限り葛藤は存在する。",
              "source": "幻辞"
            },
            {
              "text": "地球が存在する限り生命は進化し続ける。",
              "source": "幻辞"
            },
            {
              "text": "法律が効力を持つ限り秩序が保たれる。",
              "source": "幻辞"
            },
            {
              "text": "ルールが守られる限りゲームは成立する。",
              "source": "幻辞"
            },
            {
              "text": "記憶がある限り過去を語ることができる。",
              "source": "幻辞"
            },
            {
              "text": "愛情がある限り関係を維持できる。",
              "source": "幻辞"
            },
            {
              "text": "感情がある限り人間は動き続ける。",
              "source": "幻辞"
            },
            {
              "text": "夢が持てる限り人生に意味がある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そしてさうである限り、新短歌も短歌と共に今後の発展を約束されるものではないとみねばなるまい。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "期待がこれと口に云へない場合にも期待がある限り期待が期待してゐるなんらかの型、といふものはあるのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が、詩歌といふ「ああいふもの」を欲しくなる時がある限り、詩歌といふものは存するのである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、而も生活だけするといふことは出来るが、芸術だけするといふことは芸術家も人間である限り出来ぬ。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も興味以外の目的がある限りに於て、芸術能力は減殺されることは自然法則である。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、芸術家たる芸術家が、芸術作用を営みつつある時間内にある限りに於て、芸術家は他に敵対的ではなく、天使に近い。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての訳詩は、それが翻訳者自身の創作であり、翻案である限りに於て価値を持つてる。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから彼の文庫を渉獵して、日本語の飜譯がある限り、一つ殘さず讀み耽つた。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意を打たれて芳は危く昏倒せんとして、僅に身を支へた、其處を、勝に乘じた群衆はなほ、執念強く、取り包んで、凡そ息のある限り、滅多無性に打ちすゑんとする、刹那の急。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」忽ち先を爭つて、手のある限りの者は四方八方から走り集つた。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は皆、知ると知らぬに拘らず、そのことを希望してをり、勝敗に心｜覚き程は知るによしないものであれ、それは誰も知る、放心の快感に似て、誰もが望み誰もがこの世にある限り、完全には望み得ないもの！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとよりその成立上の存在規定が異性的特殊性である限り、「いき」のうちには異性に対する措定が言表されている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いき」が霊化された媚態である限り、「いき」な姿は細っそりしていなくてはならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在ある限りの学校を卒業したところで、それで一人前になれるはずがない。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなる文芸といえどもその取扱う資料が常識を具えた人間界のものである限り、あらゆる知識中の科学的な分子を排出する事の出来ないのは明らかな事である。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それが単なる地貌学的ないし生物学的の記述でなく、文学的作品と呼ばれ得る所以は、これらの対象中に作者の人格が滲潤している点にあるが、その作者から流出したものを盛るべき容器が科学的事実である限り、その容器に科学的｜破綻があっては工合が悪いのである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合の標準になるものは勿論単に心理学的なものの外に非科学的なものがむしろ大部分を占めているのは通例ではあるが、そうかと云って作者は、この種の作物の構成方法が上の通りである限りは、全く科学的要素を度外視する訳には行くまいと思う。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは或る時チェエホフが雜誌の編輯者に言つた冗談だと言ふが、原稿が眼の前にある限りチェエホフは文章を簡潔に適確にしようと努めてやまなかつたらしい。",
              "citation": {
                "source": "氣質と文章",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　文学のことは年齢によってのみはかることは出来ないが、しかし、文学がその作家の置かれた環境と切り離して考えられない関係がある限り、環境は時間によって変化するので年齢はその作家の人間にも、またその作家の作り出す文学にも変化を与えるのは否まれないように思われる。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "課長は、鉱石の存在する区域をある限り、隅々まで掘りおこすことを命じた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどんなむつかしい理論でもそれが「物理学」に関したものである限り、素人にどうしてもなんらの説明をもする事もできないほどにむつかしいものがあるとは信じられない。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学的論文を書く人が虚心でそうして正直である限りだれでも経験するであろうことは、研究の結果をちゃんと書き上げみがきあげてしまわなければその研究が完結したとは言われない、ということである。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これがある限り日本はやはり日本である。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして声のある限り、アヤ子の名を呼びながら、砂浜の方へ馳け出して、そこいらを見まわしました…………が…………。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……台所で働く女中の身体のこなしまでも、しかもそれが練達洗練された三昧に入っている所作である限り……その心境がその仕事に対して純一無雑である限り……そこに能楽の型と同じ真実味の横溢した「人間美」が後光を放っているではないか。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己分析がなされることはそれが必然的であるかぎり結構な状態であるが、その分析の結果が、直ちに行為に移らないで、その分析過程の記録慾となる時悲惨である。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々の身のまはりにあり、そして役に立つてゐるところの自然とか、事物とかは、假初のものであり、脆弱なものではありますが、それらのものは、我々がこの世にあるかぎり、我々の所有物であり、我々の親友であります。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いこの帆船には船底と甲板との間に、この昇降口一個あるのみなれば、ここぞ余のためにはサーモピレーの険要とも云うべく、この険要破れざる限りは、余の生命続かん、生命のあるかぎりは、いかでかここを破らすべきと、余は必死なり、海賊等も必死なり。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おびえる船員を叱咤し、激励し、みずからは上甲板に立って銃を構え、弾丸のあるかぎり撃ちまくったのです。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "加ふるに山はくづれ、崖はなだれ、海嘯は起り、暴風雨は襲ひ、物資の窮乏、流言蜚語、それ等は絶えざる余震とともに災害のあるかぎりを以て生き残りの人人を試した。",
              "citation": {
                "source": "竹林生活",
                "author": "――震災手記断片――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
