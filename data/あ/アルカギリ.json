[
  {
    "uuid": "0ca5e86e-e238-57c0-aa7d-08afe9971184",
    "entry": "ある限り",
    "reading": {
      "primary": "あるかぎり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
