        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あら、こんなところにいたんですか。",
              "source": "幻辞"
            },
            {
              "text": "あら、失敗してしまいました。",
              "source": "幻辞"
            },
            {
              "text": "あら、大変なことになったね。",
              "source": "幻辞"
            },
            {
              "text": "あらという感動詞は日本語の特徴的な表現だ。",
              "source": "幻辞"
            },
            {
              "text": "言語学ではあらという感動詞が分析される。",
              "source": "幻辞"
            },
            {
              "text": "日本語教育ではあらを自然な反応として教える。",
              "source": "幻辞"
            },
            {
              "text": "心理学はあらという感動詞が表現する驚きを研究している。",
              "source": "幻辞"
            },
            {
              "text": "文学作品ではあらが人物の個性を表現する。",
              "source": "幻辞"
            },
            {
              "text": "会話分析ではあらが話者の感情状態を示す。",
              "source": "幻辞"
            },
            {
              "text": "文法的には、あらは感動詞として独立している。",
              "source": "幻辞"
            },
            {
              "text": "古典文学でもあらが登場人物の台詞に出てくる。",
              "source": "幻辞"
            },
            {
              "text": "江戸語ではあらが頻繁に使われた。",
              "source": "幻辞"
            },
            {
              "text": "現代日本語ではあらが標準的な反応表現だ。",
              "source": "幻辞"
            },
            {
              "text": "言葉遣いの教科書ではあらが敬意を示す表現として扱われる。",
              "source": "幻辞"
            },
            {
              "text": "放送作家はあらを効果的に台詞に入れる。",
              "source": "幻辞"
            },
            {
              "text": "劇作法ではあらの使用がキャラクターを立たせる。",
              "source": "幻辞"
            },
            {
              "text": "アナウンサー訓練ではあらの自然な言い方が練習される。",
              "source": "幻辞"
            },
            {
              "text": "映画の字幕ではあらが翻訳の工夫を要する。",
              "source": "幻辞"
            },
            {
              "text": "社会言語学ではあらの使用が世代や性別により異なる。",
              "source": "幻辞"
            },
            {
              "text": "多言語比較ではあらのような感動詞の普遍性が研究される。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "格別、先生の口唇が、鼻腔が可笑しいといふのぢやない、起立して、先生の後から歌ふ生徒等が可笑しいといふのでもない、それどころか、俺は大体、此の世に笑ふべきものがあらうとは思つちやゐなかつた。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――記憶も、去るにあらずや……湧き起る歓喜のためには　人の情けも、小さきものとみゆるにあらずやああ、神様、これがすべてでございます、　尽すなく尽さるるなく、心のままにうたへる心こそ　これがすべてでございます！",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "空のもと林の中に、たゆけくも　仰ざまに眼をつむり、白き雲、汝が胸の上を流れもゆけば、　はてもなき平和の、汝がものとなるにあらずや",
              "citation": {
                "source": "夏は青い空に……",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか彼はただ徒らに気を弱くされてゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野は酔ふと仕方がないといふのが牧野さんの周囲の人達の定説であつたのでもあらう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の如き男にとつて、世間は荒いか、さもなくば衒学的に思はれたであらう。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りればよい人達は、不景気なれば、尚更ボヤボヤしてはゐられないといふので、景気のよい時よりも当然意志的になるのであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、芸術家は、昔日よりも、一層の孤独を必要とするであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ宮沢は、自分が死ねば全集が出ると、果して予測してゐたであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が認められること余りに遅かつたのは、広告不充分のためであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が東京に住んでゐなかつたためであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人として以外に、職業、つまり教職にあつたためであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂文壇交游がなかつたためであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それともそれ等の事情の取合せに因つてであらうか。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分その何れかであり又、何れかの取合せの故でもあらう。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "認められること余まりに遅かつたためには、もつと作品の実質に関係ある、謂はば有機的理由ありとする人々があるであらうが、恐らくそれは間違つてゐる。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでその現状が、仮りに不安な現状であらうとあるまいと、学問、芸術の興隆に適してゐようとゐまいと、所詮致し方もないことである。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それかあらぬか、猫の瞳孔が紋むやうに、海は急劇に曇つて来て、今にも時化でもやつて来さうだ。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場であらうと屋台であらうと、その場に眠つてしまふ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕なぞまだ何処にも発表しない頃のことだし、何れ高森の方が早く所謂詩壇に出るのであらうと思つてゐたが、游牧記の後では、石川道雄主宰の半仙戯、其の後は友野代三主宰の童説といつたあまり世間の表てに顔を出したがつてゐない雑誌に発表するだけで、一向に其の他に発表はしたがらないのであつた。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日も彼は紺の背広を着て熊のやうにしづ／＼と南国の夏の町を歩いてゐるのであらう。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔われかのひとをこととふに〕宮沢賢治われかのひとをこととふになにのけげんもあらざるをなにゆゑかのとき協はざるクラリオネットの玲瓏をわらひ軋らせわらひしや",
              "citation": {
                "source": "〔われかのひとをこととふに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔甘藍の球は弾けて〕宮沢賢治甘藍の球は弾けて青ぞらに白雲の房呑屋より二人の馬丁よろめきてあらはれ出づる",
              "citation": {
                "source": "〔甘藍の球は弾けて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗谷〔一〕宮沢賢治まくろなる流れの岸に根株燃すゆふべのけむりこらつどひかたみに舞ひてたんぽゝの白き毛をふく丘の上のスリッパ小屋に媼ゐてむすめらに云ふかくてしも畑みな成りてあらたなる艱苦ひらくと",
              "citation": {
                "source": "宗谷〔一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨今後その中の若干なり未知の人なりが点睛を示し始める時、詩壇ははじめて面白くなるのであらうと私は思つてゐる。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は此の後詩が点睛を得るためには、どんなことが必要であらうかといふことを、考へてみることにしたいと思ふ。",
              "citation": {
                "source": "詩壇への願ひ",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
