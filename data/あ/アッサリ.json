    },
    "definitions": [
      {
        "index": 1,
        "gloss": "easily",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "今日の夕食はあっさりした味が良さそうです。",
              "source": "幻辞"
            },
            {
              "text": "あっさりしたうどんをいただきました。",
              "source": "幻辞"
            },
            {
              "text": "塩あんかけはあっさりした仕上がりです。",
              "source": "幻辞"
            },
            {
              "text": "野菜スープはあっさりした味わいです。",
              "source": "幻辞"
            },
            {
              "text": "彼はあっさりとその誘いを断りました。",
              "source": "幻辞"
            },
            {
              "text": "問題はあっさり解決しました。",
              "source": "幻辞"
            },
            {
              "text": "あっさりした性格の人が多いこの地域。",
              "source": "幻辞"
            },
            {
              "text": "あっさりした付き合い方を好みます。",
              "source": "幻辞"
            },
            {
              "text": "あっさりした装いで出かけました。",
              "source": "幻辞"
            },
            {
              "text": "メイクはあっさり済ませました。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "弟は諾いたが声はあっさりしていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛙は寧ろラードのようなものでからりと揚げた方があっさりしていてよくはないだろうか。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっさり、すっきり、瀟洒たる心持でなくてはならぬ。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "裸体を回想として近接の過去にもち、あっさりした浴衣を無造作に着ているところに、媚態とその形相因とが表現を完うしている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに「いき」な味とは、味覚のほかに嗅覚や触覚も共に働いて有機体に強い刺戟を与えるもの、しかも、あっさりした淡白なものである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎はチラっとこんな念におそわれて少し不快を感じたが、万事につけて村上の心もちを呑込んでいる山崎はそんなことくらいを深くとがめる気にはならないですぐあっさり忘れて、その日は夕方まで敏子を中心に面白く話し合った。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮪の中とろから始って、つめのつく煮ものの鮨になり、だんだんあっさりした青い鱗のさかなに進む。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅夜に瀟洒な鉄線を組み立てている清洲橋を渡って、人形町の可愛らしい灯の中で青苦い香気のある冷し白玉を喰べ、東京でも東寄りの下町の小さい踊り場を一つ二つ廻って、貝原はあっさり小初の相手をして踊る。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その時の私の腹の虫の居所がよほど悪かったと見えて、どうもそういうあっさりした気になれなかった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いっそ、荒療治で、あっさりと無断で失敬して行っちまおうか？",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中津は、この家のあっさりとして、華やかな、日本娘の着物や、四国｜訛のある日本語や、若々しい鶏の胸肉のように軟らかい、ふるいつきたくなる娘の肉体を、視覚で享楽しながら、一家の不安に同感し、心配げな顔をしたり、また、特別、力になってやるようなことを云ったりした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわりまたなんとなくあっさりした野の花のような趣はあった。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、虎もさすがに、「これは少し相手が悪い」といったようなふうで、あっさりと見切りをつけて結局このけんかはもの別れになるらしい。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画の「筋」はわりにあっさりしているので「馬」を見るのに邪魔にならなくていい。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "媚びず怒らず詐らず、しかも鷹揚に食品定価の差等について説明する、一方ではあっさりとタオルの手落ちを謝しているようであった。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり小説を書くほどの男には、どこか、あっさりしたところがある。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉というのはもう、初老のあっさりしたおかみさんだった。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『わしはね、ごくあっさりとやって貰ひたいぢゃ。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の少しばかりの身の廻り品を纏めて小風呂敷包みにして、それを抱えおじさんのように私に附添って母のところへ送り返した及川は、ごくあっさり「お嬢さまは私が行った時、蒟蒻を煮ておいでになりました」　と報告しました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "久し振りにあっさりした詩偈を一首作ってほのかに心の隅に波紋を描く悲しみの情を写し現した。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふみからお涌の仲人口を聞いたとき島谷は「だが、皆三君の方は」　と聞き返すと、おふみは「なに、あれとは、ただ御近所のお友達というだけで、それに皆三は、当分結婚の方は気が無いというから」「では、僕の方、お願いしてみましょうか」　島谷はあっさり頼んだ。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢って見る眼には思いの外、あっさりして白いものの感じの人でございます。",
              "citation": {
                "source": "愛",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このお嬢さんは……いや、ママさんはあっさりしている。",
              "citation": {
                "source": "オペラの帰途",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜目には黄と黒の横縞に感じられる四階建ての店で素手に指環だけ一つ残したような小さい入口の上に foyot の屋号と二筋三筋のイルミナシヨンの細描きがあっさり浮き出ている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
