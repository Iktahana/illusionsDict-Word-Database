        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あなじ風が吹き荒れ、古い家屋を激しく揺らした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "漁師たちは、荒れる海と強いあなじ風を警戒し、出航を控えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "山間部では、あなじ風が吹き始めると決まって深い雪が降る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「いやぁ、今日のあなじ風は骨身に沁みるな。」と、畑仕事の老人が肩をすくめた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬の日本海側では、あなじ風が砂浜に独特の風紋を描き出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地方の天気予報では、あなじ風による吹き荒れに注意が促された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冷たいあなじ風が吹く中、子供たちは凍えながらも外で遊んでいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
