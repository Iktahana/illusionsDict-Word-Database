    "definitions": [
      {
        "index": 1,
        "gloss": "someone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ある人が素晴らしい発明をした。",
              "source": "幻辞"
            },
            {
              "text": "ある人のアドバイスが人生を変えた。",
              "source": "幻辞"
            },
            {
              "text": "医学界では、ある人の研究成果が医療を変えた。",
              "source": "幻辞"
            },
            {
              "text": "学校で、ある人が優秀で目立つ存在だった。",
              "source": "幻辞"
            },
            {
              "text": "職場で、ある人がリーダーシップを発揮している。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ界では、ある人の努力が伝説になった。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスで、ある人の経営手腕が会社を救った。",
              "source": "幻辞"
            },
            {
              "text": "技術開発では、ある人の才能が業界を革新した。",
              "source": "幻辞"
            },
            {
              "text": "歴史では、ある人の決定が時代を変えた。",
              "source": "幻辞"
            },
            {
              "text": "法律界では、ある人の判例が法を作った。",
              "source": "幻辞"
            },
            {
              "text": "文学では、ある人の著作が文化財になった。",
              "source": "幻辞"
            },
            {
              "text": "音楽界では、ある人の作品が世界的評価を得た。",
              "source": "幻辞"
            },
            {
              "text": "芸術では、ある人のスタイルが新派を生んだ。",
              "source": "幻辞"
            },
            {
              "text": "科学では、ある人の理論が業界を揺るがした。",
              "source": "幻辞"
            },
            {
              "text": "政治では、ある人の政策が社会を変えた。",
              "source": "幻辞"
            },
            {
              "text": "教育では、ある人の教育法が教育界に影響を与えた。",
              "source": "幻辞"
            },
            {
              "text": "経済では、ある人の投資判断が市場を動かした。",
              "source": "幻辞"
            },
            {
              "text": "人生で、ある人との出会いが人間を成長させた。",
              "source": "幻辞"
            },
            {
              "text": "社会で、ある人の行動が運動を起こした。",
              "source": "幻辞"
            },
            {
              "text": "人類史では、ある人の思想が世界を変えた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "これは、一つには私が今迄に、詩人である人と余りおつきあひして来なかつたといふことに過ぎないのかも知れません。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ個性のある人間といふものは、個性のない人間からみると、フーチヤンと見える理由があるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "個性のある人間の、慾の対象は、一般的ではないからだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故ある人々は、ヘルンがもし悪妻をめとり、意地悪の姑等と同居したら、彼の神国日本観は、おそらく顛倒した結果になったろうと言っている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕がまだ芥川君を知らない中、よく室生君は僕に話して「彼の如き文明人種、彼の如き禮節ある人物を見たことが無い。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気の弱さ――これのある人間はいつたい善良だ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、芸術といふものが、生れるものであつて、拵へようといふがものではないといふことは、如何にも芸術の説明にはなつてゐないやうであるけれど芸術家である人には、かう聞けば安心のつくことである点に留意されたい。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術よりも、その日暮しは千倍も豊富である人、多情多恨夢は荒野を駆け廻りながら、実はといへば陋巷の一室に暗然影を抱いて寝ぬる人、――所詮ヂェラルドは陶酔の一形式として存する。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "肺結核でそこに転地しているある人を見舞いに行って一晩泊まった時がちょうど旧暦の盆の幾日かであった。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は「南門殿還幸」を意味すると言っていたがそれはあまり当てにはならない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "須崎のある人から稲荷新地の醜業婦へ手紙を託されたとか云って、それを出して見せびらかしている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貯金のたくさんある人には、やつぱりどこか犯しがたい雅操がある。",
              "citation": {
                "source": "金錢の話",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年ほど前にある人から私の頭の頂上に毛の薄くなった事を注意されて、いまに禿げるだろうと、予言された事があるが、どうしたのかまだ禿頭と名の付くほどには進行しない。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような疑問の岐路に立ってある人は何の躊躇もなく一つの道をとる。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして爪先下りのなだらかな道を下へ下へとおりて行く、ある人はどこまでも同じ高さの峰伝いに安易な心を抱いて同じ麓の景色を眺めながら、思いがけない懸崖や深淵が路を遮る事の可能性などに心を騒がすようなことなしに夜の宿駅へ急いで行く。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし少数のある人々はこの生涯の峠に立って蒼空を仰ぐ、そして無限の天頂に輝く太陽を握もうとして懸崖から逆さまに死の谷に墜落する。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人はこの夫婦の関係を一種のソフィスティケーションと見ている。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかかわらずそういう計画をたてるというのは現代の為政の要路にある人達が地を相することを完全に忘れている証拠である。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は天体の星は扁平な薄い長方形の中に散布していて、その中ほどに我が太陽系が居るものと想像した。",
              "citation": {
                "source": "天河と星の数",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人はこれを一種の保護色の例であると論じている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の智慧　ある人の飼猫は主人の居室で椅子の上に登って呼鈴のボタンを押しボーイを呼出す癖があった。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つは既に新聞に載ったこともあるからある人々には旧聞に属するかも知れない。",
              "citation": {
                "source": "偶然の産んだ駄洒落",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の正月ある人に呼ばれて東京一流の料亭で御馳走になったときに味わった雑煮は粟餅に松露や蓴菜や青菜や色々のものを添えた白味噌仕立てのものであったが、これは生れてから以来食った雑煮のうちでおそらく一番上等で美味な雑煮であったろうと思われる。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人はこれを社会経済状態の欠陥のせいだと信じ、またある人は唯物論的思想の流行による国民精神の廃頽のせいだと思い込む。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピタゴラス派の哲学というものはあるが、ピタゴラスという哲学者は実は架空の人物だとの説もあるそうで、いよいよ心細くなる次第であるが、しかしこのピタゴラスと豆の話は、現在のわれわれの周囲にも日常頻繁に起りつつある人間の悲劇や喜劇の原型であり雛形であるとも考えられなくはない。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを治療するにはやはり余裕のある人を模倣する事によって習性を改める外はない」と論じている。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、既に博士である人達にとっても、また自分で博士になることに関心をもたない一般世人にとっても耳に入りやすい口触わりの好い言葉だからである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人は言語の有無をもって人間と動物との区別の標識としたら宜いだろうと云い、またある人は道具あるいは器具の使用の有無を準拠とするのが適当だろうという。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "松岡などに逢ったら、多少でも良心のあるひとなら誰でも、へどもどしますよ。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このひとは、きつと、實のあるひとだわ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
