    "definitions": [
      {
        "index": 1,
        "gloss": "(state of) having got rid of something (e.g. bad taste)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あく抜けした野菜は安全に食べられる。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けがまだの山菜は口に入れてはいけない。",
              "source": "幻辞"
            },
            {
              "text": "完全なあく抜けを確認してから調理する。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの程度を味わいで判断する。",
              "source": "幻辞"
            },
            {
              "text": "十分なあく抜けがなされていない食材は避ける。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの確認は重要な調理ステップだ。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの失敗は料理全体の失敗につながる。",
              "source": "幻辞"
            },
            {
              "text": "水でのあく抜けとアルカリ性物質でのあく抜けの違いがある。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの過程で野菜の栄養が失われることもある。",
              "source": "幻辞"
            },
            {
              "text": "完全なあく抜けを確認するため試し食いをする。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの状態を見た目で判定することもある。",
              "source": "幻辞"
            },
            {
              "text": "昔はあく抜けの方法が限定されていた。",
              "source": "幻辞"
            },
            {
              "text": "科学的なあく抜けのメカニズムが解明されている。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの効率を高める新しい方法が開発されている。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けなしで食べると苦味が残る。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの時間は野菜の種類で決まる。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けを確認した後に調理開始する。",
              "source": "幻辞"
            },
            {
              "text": "伝統的なあく抜けの知識が世代間で引き継がれている。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けした食材は冷蔵庫で保管できる。",
              "source": "幻辞"
            },
            {
              "text": "あく抜けの工程を省くと危険な場合がある。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうとでも仮定しなければ他に説明のしかたのないほどに、あく抜けのしたヤンキータイプを見せていた。",
              "citation": {
                "source": "LIBER STUDIORUM",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主税がまた此地へ来ると、ちとおかしいほど男ぶりが立勝って、薙放しの頭髪も洗ったように水々しく、色もより白くすっきりあく抜けがしたは、水道の余波は争われぬ。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "地金の軟かさと刃金の硬さとが不可言の調和を持っていて、いかにもあく抜けのした、品位のある様子をしている。",
              "citation": {
                "source": "小刀の味",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、貴公の青年振りは素敵に立派なものじゃの、あく抜けがしているわい。",
              "citation": {
                "source": "純情狸",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあく抜けのした話し口に小圓太は心を魅かれた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "図がらもまたいかにもすっきりとあくぬけがして、斑女の面がたった一つ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し飄然とした、あくぬけたところがなければいけない。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの方ばかりはどこからどこまで、きれいに枯れ切って、すっかりあくぬけがして居られます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その片方の男は遊び人ふうで、年も女より五つ六つ若く、ちんと手洟をかむところなどはなかなかあくぬけがしていた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
