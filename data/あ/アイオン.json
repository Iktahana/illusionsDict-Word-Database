          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "秋の夜長、隣家から漏れ聞こえる横笛の哀音が、独り身の寂しさをいっそう深めている。",
              "source": "幻辞"
            },
            {
              "text": "落日の荒野を吹き抜ける風が、古戦場の跡地に残された折れた旗竿を震わせ、何とも言えぬ哀音を立てていた。",
              "source": "幻辞"
            },
            {
              "text": "老いた琵琶法師が語りの中で奏でる弦の哀音は、滅びゆく一族の無常をまざまざと現代に蘇らせる。",
              "source": "幻辞"
            },
            {
              "text": "霧深い海を彷徨う豪華客船が鳴らす霧笛の哀音は、救助を待つ人々にとって唯一の道標であり、希望でもあった。",
              "source": "幻辞"
            },
            {
              "text": "かつて炭鉱で栄えた村の路地裏には、錆びついた遊具が風に揺られて軋む哀音だけが虚しく響いている。",
              "source": "幻辞"
            },
            {
              "text": "バイオリンの弓が弦を激しく擦るたびに溢れ出す哀音は、作曲家が晩年に抱いた深い絶望を雄弁に物語っていた。",
              "source": "幻辞"
            },
            {
              "text": "処刑場へと続く石畳の道には、引き立てられる囚人たちのすすり泣く哀音が絶え間なく響き、見守る群衆の心に暗い影を落とした。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "食糧を貯蔵しなかった怠け者の蟋蟀が木枯しの夜に死んで行くというのが大団円であったが、擬音の淋しい風音に交じって、かすかなバイオリンの哀音を聞かせるのが割に綺麗に聞きとれるので、これくらいならと思って安心したのであった。",
              "citation": {
                "source": "ラジオ雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はほとんどその哀音悲調を聴くに堪えなかった。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ人共に、何をもってしても癒し難い無限に続く人生の哀音なるものが僕の弛緩した精神の鎧の合せ目から浸み込むためか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、そのメロデーには、たとえ人間の持つあらゆる節廻しは浮世の暴風雨の音声に吹き消されても、これだけは一脈残ってどうしても人々の心に徹り響くという人間最後の哀音の抑揚がありました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何時も桐の花が咲くと冷めたい吹笛の哀音を思ひ出す。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにも哀音悲調と謂つた風の、うるほひのある澄み徹つた聲であるのだ。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これで死んでしまってはつまらない」　もがく力も乏しい最後の哀音、聞いたほどの人の耳には生涯消えまじくしみとおった。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この章においてヨブは初めて、友に向って「我を憐め」との哀音を発するに至ったのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの意味で、あのおどけた壬生狂言から深い人間の遺傳や性の悲哀を知り、堀川や西陣の場末の安い席亭にかゝる「大津ぶし」に人生の哀音をきいたことを忘れません。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "滝は、「ナンシー・リー」の単純な朗らかさに加へて、独特なそこはかとない一脈の甘苦い哀音が漂うてゐる韻律に酔はされて、今もなほそれが口笛を吹く時の習慣になつて遺されてゐた。",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふこともなく、事件もなく、日々は左様に、奏楽に適さない玩具の笛ですら三つ位ひの音色はもつてゐる、土細工の鳩笛の音は単調ではあるが一脈の哀音をもつてゐる、が彼の胸にも頭にも喉にも何の響きはなかつた。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い函の横に供へられた桔梗二三輪、鳩が二三羽飛んで来て、空にひるがへる、すすり泣きの声が聞える、弔銃のつゝましさ、ラツパの哀音、――行列はしゆく／＼として群集の間を原隊へ帰つて行つた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　れんめんとして尽きない哀音だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝霧に友惑はせる鹿の音を大方にやは哀れとも聞く私の心から発するものは二つの鹿の声にも劣らぬ哀音です。",
              "citation": {
                "source": "源氏物語",
                "author": "椎が本",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのタローガッタの音は、初めは荒野をさまよう生活の音のようだったが、それが漸次に地にひれ伏す呻きのように陰に籠り、太い遠吠えの底おもくうねる波となり、草叢を震わせる絶え絶えな哀音に変ったかと思うと、押し襲ってくる雲霞の大群のふくれ雪崩れるような壮大な音になった。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "チロルの唄は咽喉の擦り枯れたような哀音を湛え、「ころころころ、」と同じリズムで聞えていたが、そのうちに、「るくるくるく、」と次第に高く明瞭になって来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍に南鮮から引き上げて来たばかりの三人の婦人が語っている哀れな話も、紅葉の色に照り映って哀音には響かず、汽車は混雑しながらいよいよ錦繍の美に映えてすすむ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと、何か悶々として彼に訴える、清らかな哀音を耳にした。",
              "citation": {
                "source": "橋",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切々たる哀音は、尊を守って海神に身を贄と捧ぐる乙橘媛の思いを伝えるのだった。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一種悲愴な哀音を聞くやうである。",
              "citation": {
                "source": "頼杏坪先生",
                "author": "中村憲吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女子　（水門の中にて、ただ僅かに聞きとれるばかりの哀音にて）ヨハナーン、……さよう……なら……。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南のは東覚院、宝性寺、安穏寺、北のは――寺、――寺、東にも、西にも、おのがじし然も申合わせた様に、我君｜眠りませ、永久に眠りませ、と哀音長く鳴り連れて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝な夕な波は哀音を送って、蕭瑟たる秋光の浜に立てば影なき人の姿がつい眼前に現われる。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「駒さんよ――」「聞えたかえ、もう一ぺん戻って下さいよう、聞えたかえ、駒さんよう」「早く戻らさんせよう」「早く帰らさんせよう」　極めて単調の声で、野卑な哀音が夜をこめて、やや遠いところから、絶えず呼びつづけられていたらしいが、急に目ざめたお雪には、今となってはじめて聞えて来たものです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "半ば習慣的に繰返される野卑なる哀音も、竜之助の耳に、「帰るに如かず」と囁くようです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那蕎麦屋の夜陰に吹き鳴す唐人笛には人の心を動す一種の哀音がある。",
              "citation": {
                "source": "巷の声",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀音　　　　　――故渡久地政佐君を悼みて奥津城の闇をもりたる、その底に君ねむる時、あやなくも時雨るゝまなこ、悲哀はたえず雫きぬ、年若かき愁ひをおびし、臨終のほそき泣き声――身動も得ならぬ思ひ、君ならで誰か知るべき。",
              "citation": {
                "source": "小曲二十篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やかな自然よ君と、今日も又、かくて暮れゆく、哀音の鐘の響きは、痛みたる君が胸より、傷た振るる、苦患の声か。",
              "citation": {
                "source": "哀詩数篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
