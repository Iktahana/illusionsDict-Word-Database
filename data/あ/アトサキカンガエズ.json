    "definitions": [
      {
        "index": 1,
        "gloss": "without thinking of the consequences",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
