[
  {
    "uuid": "96e85310-4c49-5291-963b-ad3e50b54b05",
    "entry": "哀願",
    "reading": {
      "primary": "あいがん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
