    },
    "definitions": [
      {
        "index": 1,
        "gloss": "that sort of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんな簡単な問題ができないなんて。",
              "source": "幻辞"
            },
            {
              "text": "あんな大きな建物をどうやって壊すのだろう。",
              "source": "幻辞"
            },
            {
              "text": "あんな美しい風景は滅多に見られない。",
              "source": "幻辞"
            },
            {
              "text": "あんな高い山に登るのは危険だ。",
              "source": "幻辞"
            },
            {
              "text": "あんな古い本は図書館でも見つけにくい。",
              "source": "幻辞"
            },
            {
              "text": "あんな有名な人が近所に住んでいるなんて。",
              "source": "幻辞"
            },
            {
              "text": "あんな暑い日は外に出たくない。",
              "source": "幻辞"
            },
            {
              "text": "あんな難しい法律を誰が理解できるだろう。",
              "source": "幻辞"
            },
            {
              "text": "あんな深い話を子供に説明するのは難しい。",
              "source": "幻辞"
            },
            {
              "text": "あんな綺麗な花は毎日見られない。",
              "source": "幻辞"
            },
            {
              "text": "医学的にあんな症状は稀である。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあんな出来事は二度と起きないだろう。",
              "source": "幻辞"
            },
            {
              "text": "物理学的にあんなことは不可能だ。",
              "source": "幻辞"
            },
            {
              "text": "あんなに高速で走る乗り物は危ない。",
              "source": "幻辞"
            },
            {
              "text": "料理の世界であんな技術を習得するのに十年かかる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ史にあんな記録は前代未聞だ。",
              "source": "幻辞"
            },
            {
              "text": "文学作品の中であんな展開は予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "建築学的にあんな構造は珍しい。",
              "source": "幻辞"
            },
            {
              "text": "天文学的にあんな現象の発生確率は非常に低い。",
              "source": "幻辞"
            },
            {
              "text": "あんな言い方をされたら誰だって傷つく。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "近代といふ今は尠くも、あんな具合な元気さでゐられる時代ではないのです。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は思ふ、「あんなにアラがあるから、あのアラが契機となつて、却て奴等は仕事が出来るのであらう……」　ところでさういふ場合に彼のアラと云つてゐるものは、概ね処世的要領の稚拙の如きを指してゐるのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな奴が、段々偉くなりやがる」、ハテ面妖なとＡの方で思ふのだが、Ｂとしたら、変な話ぢやないか。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "右は、Ａが金持でＢが貧しい場合だが、もしそれが反対であつても、必竟ＡがＢを、「あんな奴でも偉いのかなァ」と思ふ、つまり交際の上でＡがＢより優勢になることは同前なのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いいかオイ……あんな奴と共同で仕事をして好いことがないのは分りきつてらあ……いいかオイ、俺が出来るだけは助けてやるからなあオイ」「うんうん」　それから猶暫らく彼は同じやうなことを繰返してゐたが、やがて其処を出ようと云ひだした。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "信用しないのに何もかも彼の云ひなりに返事をしたといふのも変なものだが、尤もあんなに三田村が感激してゐる時には……どうも困る。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の方は急を要する場合だし何時まで待つてもゐられないから、三田村の「あんな奴と共同で云々」のそのあんな奴に、私は私の最初の計画通り相談することに肚をきめる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな奴とならさう美事にいかないまでも全然まづくなりつこはないのだ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな奴はさういつた男だ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "と少し後れてあんな奴もゐる。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「暫くでした」とあんな奴が三田村の肩越しに挨拶した。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お差支へなければ、ぢや、お宅へ参りませう」とあんな奴が促した。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "信者でないからあんな裸かの女の絵なぞ掛けてゐたり、信者でない者はどうしても不可ない。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんなことを言つてるよう！",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　（続けて読む）「『労働の中でもあんな嫌なのはないね』と、散歩してゐる時友は私を促す様に言つた。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "女　まだあんなこと言つてるよ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれやああんな男だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の肥つた女達は、私のや私の前の男のネクタイを見ながら、「まあ勉強しますわねえ、八十銭であんな物まで附けるのですものねえ……ええェ」と云つた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に室生君には特殊の驚異を感じたらしく、常々「あんな珍しい男を見たことがない」と言つてゐた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな、いいところは無い。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、あんな有様でしかもなお日本が勝ったら、日本は神の国ではなくて、魔の国でしょう。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中に、あんなにグロテスクな嘘をさかんに書き並べて、こんどはくるりと裏がえしの同様の嘘をまた書き並べています。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷電に打たれたときの気持って、あんなものかも知れませぬ。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いても立ってもおられぬ、とはあんな思いを指して言うのでしょう。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし、あんまり淋しいから、おととしの秋から、ひとりであんな手紙書いて、あたしに宛てて投函していたの。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな奴と喧嘩したら、倒立ちしたってこっちが負けだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなたちの男が、ひとの女房を易々と手にいれたりなどするんだねえ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあんなふうの男とは肉体的に相容れないものがあるようだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説家ってのは、皆あんな工合いのものかねえ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
