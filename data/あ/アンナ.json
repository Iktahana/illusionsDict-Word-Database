        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日安和について考えている。",
              "source": "幻辞"
            },
            {
              "text": "安和という言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼は安和の意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文には安和が含まれている。",
              "source": "幻辞"
            },
            {
              "text": "安和を使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちは安和について学習した。",
              "source": "幻辞"
            },
            {
              "text": "安和の使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生は安和の定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化では安和が大切だ。",
              "source": "幻辞"
            },
            {
              "text": "安和という概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中に安和という表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社では安和についての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "安和を正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によると安和は複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "安和について詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野では安和が使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的に安和は重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展により安和の意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "安和は様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的に安和は興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "安和　「アパ」入口。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀郷の後の千晴は、安和年中、橘繁延僧｜連茂と廃立を謀るに坐して隠岐に流されたし、秀郷自身も前に何かの罪を犯してゐるし、時代の風気をも考へ合せて見ると、或は盛衰記の記事、竹堂の論の方が当つて居るかと思へる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "元亨釈書に、安和の上皇、勅して供奉と為す、佯狂垢汗して逃れ去る、と記しているが、憚りも無く馬鹿げた事をして、他に厭い忌まれても、自分の心に済むように自分は生活するのを可なりとした人であった。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡板の松は墨絵で、シテ座後方の鴨居に「安和堂」と達筆に墨書した木額が上げて在った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「追日向暑、倍起居御安和可被成御座奉恭賀候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "近代といふ今は尠くも、あんな具合な元気さでゐられる時代ではないのです。",
              "citation": {
                "source": "酒場にて（定稿）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と彼は思ふ、「あんなにアラがあるから、あのアラが契機となつて、却て奴等は仕事が出来るのであらう……」　ところでさういふ場合に彼のアラと云つてゐるものは、概ね処世的要領の稚拙の如きを指してゐるのである。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんな奴が、段々偉くなりやがる」、ハテ面妖なとＡの方で思ふのだが、Ｂとしたら、変な話ぢやないか。",
