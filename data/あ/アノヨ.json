[
  {
    "uuid": "6cb56823-d9e9-5845-92c6-5c4e9e91c877",
    "entry": "あの世",
    "reading": {
      "primary": "あのよ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
