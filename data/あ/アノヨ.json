        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the other world",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "祖母は「あの世でまた会おう」と言い残し、静かに息を引き取った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は生前、あの世の存在を信じておらず、常に現実主義者だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "事故で命を落とした友人は、きっとあの世で安らかに眠っているだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あの世には美味しい食べ物があるのかな」子供は純粋な目で尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの世まで持っていく財産などない、と彼はいつも笑っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの世からのメッセージだと信じる人もいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この世の苦しみから解放され、あの世で幸福になれると願う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そうして、自分は地獄へ行って見物して来たと宣言して、人々に見て来たあの世のさまを物語って聞かせたら聞くものひどく感動して号泣し、そうして彼はいよいよ神様だということになった。",
              "citation": {
                "source": "ピタゴラスと豆",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子はあなたが情の力を便りにあの世へゆきます。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち、そのやうな關聯は、我々が死者たちやこれから生れて來るものたちと何等のけぢめもなしに分たうとしてゐる、深い、感化力のある、あの世の中心への新しい結合なのであります。",
              "citation": {
                "source": "ドゥイノ悲歌",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの世へ行ったら太宰さんの御両親様にも御あいさつしてきっと信じて頂くつもりです。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "土匪は遉がに、あの世へ持って行けない金銀の器物はほしがらなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊も肉もあの世もこの世も一であって二ではない。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの世話方の顔と重って、五六人、揚幕から。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、そこで、せめてその上の我儘な願と云うのはたとえ仮初であるにせよ、幸子さんが自分の天地をかけての恋人であると信じながらあの世へ行けたなら、どんなにか幸せであろうかと思うのだ。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「向うで懇意になった映画界の人がいますから、あの世界へ入ってみようかとも思っています。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは七月革命のときのこと、あの世にも輝かしい勝利の日の夕暮だったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、牧師さまが、その人の右手をおまえの右手に置きながら、この世でもあの世でも、いついつまでも、ま心はかわりませんと、かたいちかいをたてさせてくださる。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは、お金を受取り、それから、へへん、というように両肩をちょっと上げ、いかにもずるそうに微笑んで私のところへ来て、「御本人は、あの世へ行ったでごいす。",
              "citation": {
                "source": "親という二字",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここでは泣いてもよろしいが、あの世界では、そんなことで泣くなよ。",
              "citation": {
                "source": "フォスフォレッスセンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ならお坊さんのお話といふのは、この世で嘘をいふと、あの世で閻魔さんに、舌べろを釘抜でひつこぬかれるとか、この世で猫や犬や、鳥なんかを殺すと、あの世で血の池地獄におとされて、苦しめられるといふやうな、夜一人で憶ひ出すと便所にゆくのが嫌になる話が多かつたからである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、やがてあの世で、わしがきょう迄くるしんだ同じ苦しみを嘗めるのだ。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんがしっかりしているから、お父さんも、あの世で、安心しているだろう。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お二方に、これだけに思われて、縫は世界中のしあわせです――貴方、お詫は、あの世から……）　最後の言葉でございました。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも一粒種、いい月日の下に、生れなすったんですけれど、廃藩以来、ほどなく、お邸は退転、御両親も皆あの世。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しきものは命短しというをモットーとするように豪奢と絢爛が極まると直ぐ色｜褪せてあの世の星の色と清涼に消え流れて行きます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お上人さま』蓮如『まあ待ちやれ、おくみ、そなた何ぞ、も一つ忘れたものはありはせんかの』おくみ『はて、忘れたものとは』蓮如『さあ忘れたものとは』おくみ『何のことでございます』蓮如『そなたに取ってあの世の往生は定まった。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の世のお礼やら、あの世のお頼みやら、仏様にお燈明なとあかあかあげて、親子夫婦が訣れのお念仏唱えさせて頂きましょう』源右衛門『よいところへ気が付いた』（二人で仏壇の扉を開け、礼拝の支度）　　　　　舞台半転（源右衛門宅の裏の浜辺。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ表向き夫婦となって、共白髪まで添い遂げようとしても、無常の風に誘わるれば、たちまちあの世と此の世の距て。",
              "citation": {
                "source": "取返し物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "王はあの世もこの世も別に変ったことはないとおもいながら見ていると、二人の小役人が二三人の囚人に縄をかけて前の方からきた。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王ははじめて兄が死んであの世へ連れて往かれていたということを知った。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王はあの世から兄の魂を連れて戻ってきた話をした。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、あの世の人であるが、生きていた時とすこしもかわらない、寡婦になったお前と小児のことを思うとなつかしくてたまらないからやってきたのだ」　細君はそれを聞くと一層悲しくなって慟哭した。",
              "citation": {
                "source": "陸判",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの世の人が、人の死ぬるのをいいことにしているのは、死後にいっしょになりたいからだというのですが、ほんとう」　李は言った。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことはないのです、あの世の人ばかりが逢ったところで、なんにも楽しみはないのです、あの世の人でよければ、若い方はいくらでもあります」　蓮香は言った。",
              "citation": {
                "source": "蓮香",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も、ごぞんじ無いのだ、と私は苦しさを胸一つにおさめて、けれども、その事実を知ってしまってからは、なおのこと妹が可哀そうで、いろいろ奇怪な空想も浮んで、私自身、胸がうずくような、甘酸っぱい、それは、いやな切ない思いで、あのような苦しみは、年ごろの女のひとでなければ、わからない、生地獄でございます。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山を石膏細工の人形とすれば、雲は衣裳で、あのようにまで、モデルの肢節にぴったり合って、屈伸するものとは思っていなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
