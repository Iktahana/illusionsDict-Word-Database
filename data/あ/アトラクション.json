        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "遊園地の開園を待っていた来場者たちは、目当てのアトラクションへ一斉に走り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "結婚披露宴のアトラクションとして、新郎の友人たちが趣向を凝らしたダンスを披露した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あのアトラクション、見た目は地味だけど実際に乗ってみると凄く怖いよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "地方自治体は、観光振興の目玉として最新の体験型アトラクションの誘致を検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「うわあ、このアトラクション、急降下するときの浮遊感がたまらないね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "万博のパビリオンでは、デジタル技術を駆使した没入型のアトラクションが人気を博している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「せっかく並んだのに、機材トラブルでアトラクションが中止になるなんて残念だね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ショッピングモールのイベント広場では、子供たちが参加できる工作のアトラクションが用意された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "アトラクションに出演している望月三郎の名を見つけたのだ。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　小郷が望月三郎のアトラクションの掛っているその映画館へはいったのは、むろん嫉妬から出た自虐的な好奇心だった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに、小郷にとって、ますます気の毒なことは――、　小郷が君勇と並んで座席に腰を掛けた時、まだアトラクションははじまっていず、見たくもない映画を見なければならなかったのである。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "休憩があり、やがてアトラクションの幕が上った。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、この地の活動写真館のアトラクションで見た暹羅のあのすばらしく捌きのいい踊りを眺めていた時の彼女に、私はその踊りを習わせて、名踊子にしたい慾望さえむらむらと起ったほど、それにも相応しいものがあった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にも私がチャームされたのは水芸の始まる前のアトラクションのような形で、ピエロを対手におどって見せたダンスであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽音楽　ダンス・ホール、キャバレー、ショウ、アトラクションなどとしての軽音楽は大流行で、無数の小軽音楽団体が出来ている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "目下の選手の技術では、これも仕方のないことだから、せめて、アトラクションをつけてはどうかと思った。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "前哨戦に、見物人にプロ投手の投球を打たせる余興をやったそうだが、こういう余興はいかにも手頃なアトラクションではないか。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "中等野球は情熱自体がたくまざるアトラクションであり、要するに試合そのものがアトラクション的魅力を具えているからである。",
              "citation": {
                "source": "神経衰弱的野球美学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして大ゲサなアトラクションだが、飲ませるものときたら、ひどいね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日でいうならアトラクションで、十日ずつ演題を改めてちょうど二カ月出演したが、なにしろこの小屋、日本一台詞のとおりが悪く、どんな怒号する剣戟役者でも必ず一度は調子をやる（声を潰す）という折り紙つきのところの上に、文字どおりの幕間余興で、遠慮なく大道具の金槌の音が噺の最中に響いてくる。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四話　続々落語家時代　金竜館もやはり今日のアトラクションで、九郎とか五蝶とか扇蝶とか、子供の時分五九郎一座の舞台で顔馴染みの人たちばかりが喜劇春秋座で常打ちに出演しており、他に木下八百子に三河家荒二郎合同の歌舞伎劇がひと幕あった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "浪曲の間で落語を演るのは辛かったが、かつての大阪楽天地や金竜館でのアトラクションを思えば、よほど気が楽だった。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらアトラクションの語は当時未だこの日本の興行用語として渡来流布されてはゐなかつた。",
              "citation": {
                "source": "浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトラクションの語は、未だ当時の日本には、海越えて渡来してゐなかつたが、茹蛸のごとき禿頭をそのまゝ己の芸名とするこの江戸生粋の老芸人はげ亀は、ビール瓶の曲技に長じ、また先代岩てこバンカラ辰三郎に比肩する洗練軽快の都々逸をよくした。",
              "citation": {
                "source": "異版　浅草燈籠",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月九日　毎日新聞釣り映画のアトラクションに出演する連中、江戸家猫八、三増紋也、小金馬を青山浩氏が招待する。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "法隆寺の方では、その声に応じるがごとくすべてがアトラクション的になる。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十数年前の、世間を知らず酒を知らず恋をも知らぬ学生時代から、三十の坂を越してすでに二人の親になっている今日にいたるまで、夏が来ると山を思い、山に行けぬと鬱々として楽しまぬのは、実に山が偃松のカウチというアトラクションを持っているからである。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々がヤンガー・ジェネレーションの為に、アルプスの冬季の魅力と富源とを発見して教えたことは事実だが、復活祭の休暇に於けるアルプスは僅かなアトラクションと多くの危険とを持っている。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都ムーランよりももっと上手の活動小屋へ這入ったら、偶然アトラクションにレビューをやっていた。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな活動小屋のアトラクションだから、レビューは甚だ貧弱である。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、雲をつかむような話で所詮分る筈がないだろうと思ったけれども、同じ頃、活動小屋のアトラクションにでた男の名前が分らないかと訊いてみた。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時京都の活動小屋へアトラクションに出たのはモリシン以外にない。",
              "citation": {
                "source": "青春論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一座を組んで、出しものを用意して、映画館のアトラクションとして売り込もうというのであった。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か話しかけないとまずい感じで、「この間、惚太郎の二階で、稽古していたアトラクションの方は、どうなったですか」と、私は言った。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "末弘春吉が、アトラクションがうまく行かないので、漫才に転向しようと思っていると言った。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "（注一）　私がひとりで「王道」を読んでいるところへ、末弘春吉が、アトラクションの交渉に諸所を駆け回ったのだろう、いかにも疲れた蒼い顔をして帰ってきた。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二九年にはヴィクターでレコードをつくり、三〇年から三四年にかけて、オートリイは、ＷＳＬ局『ナショナル・バーン・ダンス』のメイン・アトラクションになって人気をたかめ、通信販売デパートのシアズ・ローバック社のレーベルで、レコードをつくった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
