    "definitions": [
      {
        "index": 1,
        "gloss": "you (plural)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あんたら全員で作業を分担してください。",
              "source": "幻辞"
            },
            {
              "text": "営業のあんたらが今月の目標を達成した。",
              "source": "幻辞"
            },
            {
              "text": "あんたら学生のうちに基礎をしっかり学べ。",
              "source": "幻辞"
            },
            {
              "text": "工事班のあんたらはいつ完成させるつもりですか？",
              "source": "幻辞"
            },
            {
              "text": "あんたら管理職にもっと責任を持ってほしい。",
              "source": "幻辞"
            },
            {
              "text": "警察が犯人グループに「あんたら、何を考えているんだ」と尋問する。",
              "source": "幻辞"
            },
            {
              "text": "運動部のあんたらは団結力が素晴らしい。",
              "source": "幻辞"
            },
            {
              "text": "あんたらのチームワークが試合に勝つカギだった。",
              "source": "幻辞"
            },
            {
              "text": "営団地下鉄の工事にあたるあんたらの安全を最優先に。",
              "source": "幻辞"
            },
            {
              "text": "研究班のあんたらが新しい発見をした。",
              "source": "幻辞"
            },
            {
              "text": "あんたらの世代は新しい技術に適応できる。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ選手としてあんたらには多くの期待がある。",
              "source": "幻辞"
            },
            {
              "text": "あんたら医療スタッフの献身的な仕事に感謝する。",
              "source": "幻辞"
            },
            {
              "text": "歴史的建造物を守るあんたらのボランティア活動は素晴らしい。",
              "source": "幻辞"
            },
            {
              "text": "料理人のあんたらが作るこの味は最高だ。",
              "source": "幻辞"
            },
            {
              "text": "あんたら若い世代が社会を変えていく力になる。",
              "source": "幻辞"
            },
            {
              "text": "法律を守るあんたら警察官の役割は重要だ。",
              "source": "幻辞"
            },
            {
              "text": "農家のあんたらが育てた野菜は新鮮だ。",
              "source": "幻辞"
            },
            {
              "text": "機械工場であんたらのような技術者が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "あんたら全体で力を合わせれば何でもできる。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そうした経緯を、あんたらも知らないわけじゃないだろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどあんたらが、ゼロックスでアラン・ケイたちが進めた研究の成果をそのままいただいてきたのと同じだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに翻って、「なら後発のあんたらはもっと安くしなくてはいかんよ」などと言い出すかも知れないではないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、あんたらが、その三分の二位の地代でも出してくれると云うのなら格別として……」　群山は、他の二人の地主に代って返事を与えた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたら、そのときまだ生れてなかったぞ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "おや、変なことになったと三人が思っている時、うしろから三助が旦那、あまり覗かぬように頼んまっせ、あんたらの顔も向う側へよう映ってまっさかいと注意した。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたらええ商売や、ちょっと筆先きでガシャガシャ塗りさえすれば百円とか五百円とかになるねがな、気楽な身の上や。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたら、栗ひろひに行つたの？",
              "citation": {
                "source": "栗ひろひ週間",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへらに衝き込まれるやうなことは少しもして居らぬ積りぢや』　勝『貧乏人がみな飢ゑ死にしても、あんたらは知らぬ顔を為とつてのだつか？",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "誤解なら誤解でもええが、サァちゃんは、ですな、あんたらがどんなことをやっているか、みィんな見とおしとるんよ。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ギヴミーとはいわんけれども、人民から金銭をハタリ取ることにかけちゃ、あんたらは天才やからね。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「話は、いま聞いたが、豚の件にしても、あんたらのやり方はいかんと思うな……どこが、いかんのか。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、聞きなさい……この家にエルマンという悪いやつがいて、あんたらに検挙られて、マニラへ送還されたが、あれは純粋なポリネシアやから、誰が豚を飼っていたか、推して知るべきでしょう。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処から一里に少し欠ける――ユックリ行っても、さようさ、あんたらの足なら、一時間というとこだらず。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高利貸しが義理の人情のと言うと、あんたらの眼で見りゃ、狸が衣冠束帯で出て来たように見えるのかいな！",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな、そんな、あんたらが、腹を合わせて、私を妨害するならば、私にも覚悟があるぞ！",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "韮山　あんたらから、舐められている韮山かどうか、まあ見ているが――。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事言ふてもあんたらにや本当になるまい。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆　いえさ、あんたらが、死んだ伜の事で手当をドツサリ取つてくれようと色々と骨折つて下さるのは有りがたいけどさ、私達のことをダシにして、又段々とイザコザが大きくなつて来ると――。",
              "citation": {
                "source": "地熱",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサ　お辻の奴とグルになつて、あんたらが何をたくらんでゐるか位、おらちやんと知つてゐるんだよ！",
              "citation": {
                "source": "彦六大いに笑ふ",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "金吾　すまねえなあ、あんたらにまで、こんな心配かけて。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実あ川合の壮六が居てくれりゃ、多少は相談にも乗ってくれていようが、ちょうど半月前から試験場の用事で青森の方へ出張してて――とんだ、どうも、あんたらに苦労をかけやす。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村子　ずいぶん神経質になってんのねえ、あんたらしくもない。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　あんたら、自由党とかでいまの政府を倒すそうなが、……そいで、政府ば倒したら、そん後、どうなさいまっす？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたらがこんだ大臣やなんどにおなりけ？",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お孃樣方だつてそんなに私の面をいやがつてご覽になるが、あんたらのスカートの下、つつまれた大きい盛り上つた二匹のうはばみは、なんといつてもお孃樣方の生がいはなれずにゐなければならない二匹、その二匹は何時も二匹でなければゐられないやうに出來てゐる。",
              "citation": {
                "source": "末野女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたらも私も毎日髭といふものを剃る。",
              "citation": {
                "source": "末野女",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたら東京のお人やが、何をしてゐるお方やと女だちが言ひ、何をしてゐる人に見えるかねと言つたが、そんなこと分りはしまへんと言つた。",
              "citation": {
                "source": "京洛日記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙太　あんたら、自由党とかで今の政府を倒すそうなが、……そいで、政府をば倒したら、そん後、どうなさいまっす？",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたらがこんだ大臣なんどにおなりけ？",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
