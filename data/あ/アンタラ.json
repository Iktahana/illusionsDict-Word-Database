        "examples": {
          "standard": [
            {
              "text": "私は毎日アンタラについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "アンタラという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はアンタラの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはアンタラが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "アンタラを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはアンタラについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "アンタラの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はアンタラの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではアンタラが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "アンタラという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にアンタラという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではアンタラについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "アンタラを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとアンタラは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "アンタラについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではアンタラが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にアンタラは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりアンタラの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "アンタラは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にアンタラは興味深い例である。",
              "source": "幻辞"
            }
          ],
