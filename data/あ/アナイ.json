    "definitions": [
      {
        "index": 1,
        "gloss": "that sort of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "報道されたあないな事件の再発防止に、政府は全力で取り組むべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "次世代の半導体には、あないな高耐熱特性が不可欠となるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「いやあ、まさかあないな誤解を招くとは、まったく予想外だったよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の事業計画は、あないな非現実的な収益予測に基づいている点で問題がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "滅多にお目にかかれない、あないな卓越した技術力に感銘を受けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "現代社会において、あないな過度な情報への依存は、新たな課題を生んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "二度とあないな失敗を繰り返さないよう、今回の教訓を深く心に刻むべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "女　さうね、………だけど先づダンスする方が好かあないかしら。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――大したこたあないんだ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな下層民の寄り集りぢやあないか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ程必要な本があれば図書館に行かなくつたつて、私が買つてやると言つてるぢやあないか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それぢやあない、私は学校以外には一切出すまいかとさへ思つてゐる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も私は絶対に旅行させないといふのぢやあない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "切角此の頃にない午前中に今日は時間の余裕があつたのぢやあないか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「神経屋ぢやあない、あんたが間違ひぢや。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して悪い積ぢやあないのだから。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それは分つてるけれど、併し他所の親は皆々お母さん程極端ぢやあない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「英国の商業学校の中で、殺されでもするのぢやあないか知ら……」三　やつぱり何にも手には着かなかつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は母や私の間の気色を見ると、「また何か何か、Ｍさんとでも遊んどれば文句はないぢやあないか。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやいや、そんな大したことぢやあないから……」　カタクナなくせに甘い奴だ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッ、そんなに鼻ばかりピクピクさせる事あないよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のこたあない、ストーヴの中のカステラ見たいな、熱さには、ヨウリスだって持たないんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男の変った所説の一例を挙げると、自分が風邪を引いて熱を出したりしたとき「アンマリ御馳走を喰べ過ぎるんじゃあないですか」と云ってはにやにや笑うのであった。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おしまいだというじゃあないか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "人に面倒な紹介をして貰ったわけじゃあない。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "己が見せたいのだから、好いじゃあないか。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそんなこと聞きたかあないんだよ……」電車が全速力で走つてくる。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "香料は今晩はミモザがよかあないか。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "千円かの無尽にあたつて発狂したといふおぢいさんが……」「はははは、僕達はそんなに※が小さかあない。",
              "citation": {
                "source": "夢",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから見たまえ、あの五十｜面のばあさんが、まるで恥も外聞も忘れていたじゃあないか。",
              "citation": {
                "source": "あの時分",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お婆さん、吉蔵が眠そうにしているじゃあないか、早く被中炉を入れてやってお寝かしな、かわいそうに。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか僕の方で聞いてもらいたいような心持ちになって来たから妙じゃあないか。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時運転だからコースが変わったのかと思っていると、運転手が突然「オーイ、オイ、冗談じゃあないよ」とひとり言を言ってぐるりと車を引き返して呉服橋のほうへあともどりした。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い葛飾の江戸川じゃあない、江戸の小石川と牛込のあいだを流れている江戸川で……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし江戸時代には、あの辺はみな武家屋敷で、夜桜どころの話じゃあない、日が落ちると女一人などでは通れないくらいに寂しい所でした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "為さんのことばかりじゃあない、内にも忌なことがあったんだよ」「どんな事があったんだ」と、藤吉は不安らしく慌てて訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤吉だって悪い人間じゃあない、根は正直者なんですから、たとい粗相とは云いながら相手を殺した以上は、自分も下手人に取られなければならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
