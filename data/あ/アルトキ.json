    "definitions": [
      {
        "index": 1,
        "gloss": "on one occasion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "ある時、彼は突然辞職を決めた。",
              "source": "幻辞"
            },
            {
              "text": "ある時、病気が判明した。",
              "source": "幻辞"
            },
            {
              "text": "ある時、人生が大きく変わった。",
              "source": "幻辞"
            },
            {
              "text": "医学的には、ある時から症状が現れた。",
              "source": "幻辞"
            },
            {
              "text": "学校生活において、ある時から友人関係が変わった。",
              "source": "幻辞"
            },
            {
              "text": "社会人として、ある時から責任が増えた。",
              "source": "幻辞"
            },
            {
              "text": "スポーツ人生では、ある時から転機が訪れた。",
              "source": "幻辞"
            },
            {
              "text": "ビジネスキャリアでは、ある時から昇進した。",
              "source": "幻辞"
            },
            {
              "text": "技術進歩では、ある時から革新が起こった。",
              "source": "幻辞"
            },
            {
              "text": "歴史的には、ある時から時代が変わった。",
              "source": "幻辞"
            },
            {
              "text": "法制度では、ある時から新しい規則が施行された。",
              "source": "幻辞"
            },
            {
              "text": "文学作品では、ある時から登場人物の心境が変わった。",
              "source": "幻辞"
            },
            {
              "text": "恋愛経験では、ある時から感情が芽生えた。",
              "source": "幻辞"
            },
            {
              "text": "経済状況では、ある時から好転した。",
              "source": "幻辞"
            },
            {
              "text": "個人成長では、ある時から自信がついた。",
              "source": "幻辞"
            },
            {
              "text": "家族関係では、ある時から親子の絆が深まった。",
              "source": "幻辞"
            },
            {
              "text": "科学研究では、ある時からブレークスルーが訪れた。",
              "source": "幻辞"
            },
            {
              "text": "人生哲学では、ある時から価値観が変わった。",
              "source": "幻辞"
            },
            {
              "text": "社会運動では、ある時から世論が変わった。",
              "source": "幻辞"
            },
            {
              "text": "人類史では、ある時から文明が進化した。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "之を倫理的にいひ直してみれば、信義ある時代にこそ芸術は容易に発展するものなのである。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに、都にある時よりも、手紙は遥かに書きたいのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もその不平たるや、独りで文学を思ふ時と、Ｂが面前にある時とだけのものであつて、一般生活、つまり彼の畑に帰れば、あつてなきが如きものでさへあるのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで私自身では、いくら元気である時にでも、もしその時に佗しげな夢を見てゐたとしたら、尠くとも直ぐにニコニコはしないであらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある時、ヘルンが案内して連れ出した所は、暗い闇夜の野道の中に、小高い丘があるばかりで、周囲は一面の稲田であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時は下宿をしたり、ある時は間借りをしたり、ある時は借家をしたりして、常に住居を転々としていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の老僧とも懇意になり、ついにある時、自分がその住持になりたいと言い出し、夫人と次のような問答をした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時ヘルンから万葉集の歌を質問され、答えることができなかったので、泣いてその無学を詫び、良人に不実の罪の許しを乞うた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あなた学問ある時、私この本書けません。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで学校に式のある時など、他の教師は皆礼服で列席するのに、ヘルンは一張羅の背広で押し通していた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時夫人が、江の島に遊んだ土産として、大きな法螺貝を買って帰った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に、芸術家たる芸術家が、芸術作用を営みつつある時間内にある限りに於て、芸術家は他に敵対的ではなく、天使に近い。",
              "citation": {
                "source": "芸術論覚え書",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんたがたでも、仮令｜他人と他人との喧嘩でも、喧嘩である時は何でも好いから其処から遠去かることですよ。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体に食う方にかけては贅沢で、金のある時には洋食だ鰻だとむやみに多量に取寄せて独りで食ってしまうが、身なりはいつでも見窶らしい風をして、床屋へ行くのは極めて稀である。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに懐に金のある時にそうである。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時山奥のまた山奥から出て来た病人でどの医者にも診断のつかない不思議な難病の携帯者があった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしよく見るとそういうのでも、どこかちゃんと一つの全体を形作って一人の作者のある時期の心の世界の断面を見るような気がすることもしばしばあります。",
              "citation": {
                "source": "書簡（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時｜颱風の話からそのエネルギーの莫大なこと、それをどうにかして人間に有益なように利用するようにしたいというようなことを話したら、大変にそれを面白がった。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ある時西洋の小説の話から始まってゾラの『ナナ』の筋も私に話して聞かせた。",
              "citation": {
                "source": "子規の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫時水瓜を上げておいてからすればいいのだけれど、先生は今日のみならず、何時でも水瓜を冷やしてある時は、冷やしたまんまで水を汲まれるのが常らしいから、一寸それを変更してはならないものの如くである。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時はまたやはり「花物語」の一節にある幼児のことを、それが著者のどの子供であるかという質問をよこした先生があった。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時たまたま逢った同窓と対話していた時に、その人の背後の窓から来る強い光線が頭髪に映っているのを注意して見ると、漆黒な色の上に浮ぶ紫色の表面色が或るアニリン染料を思い出させたりした。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしある程度の不連続な生理的変化がある時期に起る事もよく知れ渡った事実である。",
              "citation": {
                "source": "厄年と etc.",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またある時は「あなた、かくしているでしょう、きっとそうだ、あなたそうでしょう」とうるさく聞きながら、余の顔色を読もうとする、その祈るような気づかわしげな目づかいを見るのが苦しいから「ばかな、そんな事はないと言ったらない」と邪慳な返事で打ち消してやる。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘時代のある時、歌舞伎の舞台で見た若い芸妓のちりめん浴衣にすつかり魅せられました。",
              "citation": {
                "source": "縮緬のこころ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその根株のまわりから、ある時私たちは四十近くの半分｜炭化したくるみの実を拾いました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る口の惡るきお人これを聞きて、扨もひねくれし女かな、今もし學士が世にありて札幌にもゆかず以前の通り生やさしく出入りをなさば、虫づのはしるほど嫌やがる事うたがひなしと苦笑ひして仰せられしが『ある時はありのすさびに憎くかりき、無くてぞ人は戀しかりける』とにも角にも意地わるの世や意地惡るの世や。",
              "citation": {
                "source": "經つくゑ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ明白な誤謬は一つもない論文であっても、一人の人間が限りある時間に仕遂げた仕事であってみれば、あらゆる批評家のあらゆる方面から見たとき考え得らるべきあらゆる要求を満足させるようにあらゆる釘と栓を挿しあわせるということはほとんど不可能なことである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋宮沢賢治草穂のかなた雲ひくきポプラの群にかこまれて鐘塔白き秋の館かしこにひとの四年居てあるとき清くわらひけるそのこといとゞくるほしき",
              "citation": {
                "source": "恋",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまの背広服のほかに、学生服を着たり、菜葉服を着たり、あるときには角帯に白足袋という恰好で私を狼狽させ赤面させた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
