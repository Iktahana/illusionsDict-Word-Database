        "examples": {
          "standard": [
            {
              "text": "古い洋館のアティックを改装し、自分専用の静かな書斎として活用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「アティックにしまってあったクリスマスの飾り、そろそろ出してきてちょうだい」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "傾斜した天井が特徴的なアティックの子供部屋は、まるで秘密基地のような趣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夏場のアティックは熱気がこもりやすいため、断熱材の施工と換気ファンの設置が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アティックの天窓から差し込む月光が、埃の舞う室内を幻想的に照らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「もしかして、昨夜のアティックの物音はネズミの仕業かしら」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "建築家は、デッドスペースになりがちな屋根裏をアティック収納として最大限に活用するプランを提示した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "「その夕、アドリアティックの海は菫色であった。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど、陽の輝いている間は、アドリアティックの海は竹色であり、夕暮れるに従って菫色に変って来る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階――と言ってもアティックだが――に酒の空瓶がゴロゴロしているには驚いた。",
              "citation": {
                "source": "可愛い山",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
