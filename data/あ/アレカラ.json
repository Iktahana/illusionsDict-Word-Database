    "definitions": [
      {
        "index": 1,
        "gloss": "since then",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "あれ以来、毎日ジョギングを続けている。",
              "source": "幻辞"
            },
            {
              "text": "あの事件あれ以来、警備が厳しくなった。",
              "source": "幻辞"
            },
            {
              "text": "卒業式あれ以来、クラスメートとは会っていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、彼との関係は気まずくなった。",
              "source": "幻辞"
            },
            {
              "text": "病気から回復したあれ以来、健康的な生活を心がけている。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、私の人生が変わった。",
              "source": "幻辞"
            },
            {
              "text": "引っ越したあれ以来、新しい友人ができた。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その地域は大きく発展した。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、この技術は急速に普及した。",
              "source": "幻辞"
            },
            {
              "text": "破産したあれ以来、再出発に必死だ。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、政策が大きく転換した。",
              "source": "幻辞"
            },
            {
              "text": "結婚式あれ以来、毎年会っている。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その工場は操業を停止している。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、気象パターンが変わった。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、この習慣は続いていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、不信感を払拭できていない。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、年1回の定期会議が始まった。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、技術革新が加速している。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、彼女とは連絡が途絶えた。",
              "source": "幻辞"
            },
            {
              "text": "あれ以来、その価値観に疑問を持ち始めた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "キツトその蘭人があれから先づ己の国に帰つて又日本に来る途中で自分の戦勝を聞き、取り敢へず祝の品を持つて来たのだらうと思つた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はあれからは大分老いて見えた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、かう見えても、あなたに御恩がへしをしたくて、あれから毎日毎晩、この濱へ來て若旦那のおいでを待つてゐたのだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう、誰かにいたづらされて口に怪我をしたやうだが、あれから、さつぱりこのへんに姿を見せんぢやないか。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に久し振りだなァ」　「あれから丁度二十年経つよ」　「二十年、そんなになるかな。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてあれから我々は長いこと騎つてきた。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのうもあれから万年町の方をすっかり猟ってみたが、どこにもそんな御符売りらしい奴は泊っていねえんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから毎日張り込んでいるんですけれど、野郎は影も形も見せないんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あれから親爺の転落が始まったのだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物を着かえてお母ちゃんを待っとろと言うたりしてなあ」「お祖母さんがぼけはったのはあれからでしたな」姉は声を少しひそませて意味の籠った眼を兄に向けた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、僕もあれからいろいろ深く考えましたがね、結局、ですね、僕が女たちと別れて、小さい家を買って、田舎から妻子を呼び寄せ、幸福な家庭をつくる、という事ですね、これは、道徳上、悪い事でしょうか。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから、五分たちました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うております故、あれから毎晩、腰から下、血だらけになった娘のお熊が枕上に立ってサメザメと泣きまする』とか何とか言うて高声を立てて泣き崩れたとか言う話じゃが……」「ふうむ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれからどうなつたのかしらない……あゝ、『あの時』はあゝして過ぎつゝあつた！",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあれから宿へ帰りあなたが交換して下さった短冊の歌を繰返し繰返し読んで、わたくしの心の一部はあなた同様純潔な寂光の世界が望まれるような気がいたしました。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦だたしさに、あれから今までたった僅の時間の間に、私の心は経廻り得られるだけのあらゆる境地を探し廻ったということが出来ます。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "）摩登伽尼　――もうあれからまる三年経ちまして御座いますね。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　電車を赤十字病院下で下りて、向うへ大溝について、岬なりに路を畝つて、あれから病院へ行くのに坂がある。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――おお沢山な赤蜻蛉じゃ、このちらちらむらむらと飛散る処へ薄日の射すのが、……あれから見ると、近間ではあるが、もみじに雨の降るように、こう薄りと光ってな、夕日に時雨が来た風情じゃ。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから旅籠町へ抜けて、東四十物町を突切って、橋通りへ懸って神通を飛越そうてえ可恐い逸れ方だ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはあれからもう何べんも来てわかっているから。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四）　あれから丁度、今夜で三日になるのです。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（五）　あれから六日たちました。",
              "citation": {
                "source": "葡萄水",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あれから岩手山へ行ったな。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふら孑孑のようだわね……あれから、上へ上へと見霽の丘になって、段々なぞえに上る処……ちょうどここと同じくらいな高さの処に、」　振袖姿は、塚と斜めに立っている。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙斎の話は、あれからなお続いて、小一の顕われた夜泣松だが、土地の名所の一つとして、絵葉書で売るのとは場所が違う。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから柴又へお詣りしたが、河甚の鰻……などと、贅は言はない。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たま／＼の旅行だし、靜岡まで行程を伸して、都合で、あれから久能へ※つて、龍華寺――一方ならず、私のつたない作を思つてくれた齋藤信策（野の人）さんの墓がある――其處へ參詣して、蘇鐵の中の富士も見よう。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした場所と、身の上では、夜中よりも人目に立たない、静な日南の隙を計って、岐路をあれからすぐ、桂谷へ行くと、浄行寺と云う門徒宗が男の寺。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘い涙の飴を嘗めた勢で、あれから秋葉ヶ原をよろよろと、佐久間町の河岸通り、みくら橋、左衛門橋。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
