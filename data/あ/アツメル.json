    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to collect",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "趣味で世界各地の古い硬貨を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼の斬新なアイディアは、多くの投資家から高い関心を集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "週末のボランティア活動に参加してくれる人を、SNSを通じて広く集める。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "論文を執筆するにあたって、まずは信頼できる統計資料を集める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "教室のワックスがけをするため、全ての机と椅子を廊下に集めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "警察は、事件当日の現場周辺の目撃情報を重点的に集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "その若手政治家は、SNSを駆使した独自の戦略で若年層の支持を集めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その頃を見計らって箒で掃き集めると米俵に一俵くらいは容易に捕れるというのである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの樂しみは、お天氣のよい日、腰に一瓢をさげて、劍山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳を組立てている繊維の表面はよせ集めるとなかなか広い。",
              "citation": {
                "source": "蚊帳の研究",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は帯の間からハンケチを取り出して膝の上へ広げ、熱心に拾い集める。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また少し種類が違っているが、品物を集めるのではなくて、古い書物や論文を愛読してその中からその価値の如何によらず人のあまり知らぬ研究や事実を掘出して自ら楽しみまた人に示すを喜ぶ趣味もある。",
              "citation": {
                "source": "科学上の骨董趣味と温故知新",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことばの事実を拾い集めるのが言葉の科学への第一歩である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作品の取捨に當り、懷郷の匂ひの強い作品のみを集めるといふ事を、根本方針とした。",
              "citation": {
                "source": "『老ハイデルベルヒ』序",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "地主の下男は、地子を集めるのに、まず第一番に、おりくの家へ荷車を引いてやって来た。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルキシズムその他いろいろなイズムの立場から蜜蜂に注文をつけるのは随意であるが、蜜蜂はそんな注文を超越してやっぱり同じように蜜を集めるであろう。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨のときはテントの屋根から集めるという。",
              "citation": {
                "source": "小浅間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それじゃ、お前は、僕の名前の出ている本を、全部片っ端から買い集めることが出来るかい。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの男は東京に居る時分から俺の好敵手で、どうして集めるんだか判らないが、俺の狙っている本を片端から浚って行ってしまいやがる。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "句切れ句切れの頭の字を拾い集めると『はしかかるい』となっておるだけの袁許禁厭じゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの松倉さんに遣った歌の句切れ句切れの一字一字拾い集めるとのにしはるとなっとる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この近在の百姓が御料地の森へ入って、枯れ枝を集めるのは、それは多分禁制であろうが、彼らは大びらでやっているのである。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ふん、大将が鈴蘭の実を集めるなんておかしいや。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……つい此の間、さんが……實は剩錢を集める藁人形に鎧を着せた智謀計數によつたのださうである。",
              "citation": {
                "source": "九九九會小記",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家が広くないので、招待を二日に分けまして、最初の晩は近所の人達をあつめ、次の晩は剣術のお弟子たちを集めることにしたのです。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔流行った小唄を口ずさむ外は、余りパッとしないがのっぺりとした美男子の活動俳優の写真を集めるのが唯一の趣味である。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "分家も方々に散らばっており、息のかかった人たちも多いので、その附近の地盤を堅めるのに、その勢力はぜひとも必要であり、投票を一手に集めるのにその信望は利用されなければならなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "アルヒ　アサカラ　ヨイテンキヤマヘ　ユキマス　シバカリニ　このお爺さんの楽しみは、お天気のよい日、腰に一瓢をさげて、剣山にのぼり、たきぎを拾ひ集める事である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の懐都合のいい物を集めるので、智識は悉無である。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今になつてこの絵葉書を見て僕は思ふんだが、君が外国でこれを買ひ集める時は、単に君が自分で興味を牽かれた景色だの、芝居だの絵だの、陶器だの人形だのの絵葉書だらうが、こつちへ送つて呉れた時の趣意は、結局、僕を啓発して呉れるつもりのものになつてゐるらしいね。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（泣き声になる）節子、無言で、その辺に散らばった肴を皿の上に拾い集める。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この鐘がなしになると、これから報恩講のときなんかに、人を集めるのに困るわなア。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラッパで爺さん婆さんを集めるなどと、ほんな馬鹿な。",
              "citation": {
                "source": "ごんごろ鐘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "出席者が十人として、酒を二斗、これは俺が集める」「それは悪くないけど、二斗はすこし多くないか」「いや、多くない。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "材料を集めるに当って、何かと親しく相談に乗って下さった方は、私の先輩に当る小説家、小田｜嶽夫氏である。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田ミサコは売あびせのために底値を入れた××新株の反撥を予想して買いあつめると、雑株安をねらって、引たたぬ××百貨店株を後場引値で、これを指名人に買わすとさっさと場内を引あげた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に祈祷にことよせて、多分の金銀をあつめるなどとは聞き捨てにならない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
