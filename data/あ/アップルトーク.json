    "definitions": [
      {
        "index": 1,
        "gloss": "AppleTalk (group of networking protocols developed by Apple)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔のMacintoshネットワークでは、ファイル共有にAppleTalkがよく使われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "AppleTalkは、TCP/IPが普及する以前のApple製品における標準的なネットワークプロトコルだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この古いネットワークプリンタは、AppleTalk接続にしか対応していないため、現在の環境では使用が難しい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいmacOSでは、セキュリティ上の理由からAppleTalkのサポートが完全に廃止された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の研究は、初期のローカルエリアネットワーク技術、特にAppleTalkの効率性に焦点を当てていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      }
