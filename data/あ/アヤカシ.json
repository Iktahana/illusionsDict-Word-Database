        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "私は毎日あやかしについて考えている。",
              "source": "幻辞"
            },
            {
              "text": "あやかしという言葉は日本語で重要だ。",
              "source": "幻辞"
            },
            {
              "text": "彼はあやかしの意味を理解している。",
              "source": "幻辞"
            },
            {
              "text": "この文にはあやかしが含まれている。",
              "source": "幻辞"
            },
            {
              "text": "あやかしを使って文を作ってみた。",
              "source": "幻辞"
            },
            {
              "text": "学生たちはあやかしについて学習した。",
              "source": "幻辞"
            },
            {
              "text": "あやかしの使い方は難しい。",
              "source": "幻辞"
            },
            {
              "text": "先生はあやかしの定義を説明した。",
              "source": "幻辞"
            },
            {
              "text": "日本の文化ではあやかしが大切だ。",
              "source": "幻辞"
            },
            {
              "text": "あやかしという概念は興味深い。",
              "source": "幻辞"
            },
            {
              "text": "この本の中にあやかしという表現がある。",
              "source": "幻辞"
            },
            {
              "text": "会社ではあやかしについての会議があった。",
              "source": "幻辞"
            },
            {
              "text": "あやかしを正しく使うことが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "研究によるとあやかしは複雑だ。",
              "source": "幻辞"
            },
            {
              "text": "あやかしについて詳しく知りたい。",
              "source": "幻辞"
            },
            {
              "text": "医学分野ではあやかしが使われている。",
              "source": "幻辞"
            },
            {
              "text": "歴史的にあやかしは重要な役割を果たした。",
              "source": "幻辞"
            },
            {
              "text": "技術の発展によりあやかしの意味が変わった。",
              "source": "幻辞"
            },
            {
              "text": "あやかしは様々な場面で使われる。",
              "source": "幻辞"
            },
            {
              "text": "言語学的にあやかしは興味深い例である。",
              "source": "幻辞"
            }
          ],
          "literary": []
        }
      },
