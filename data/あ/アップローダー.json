        "examples": {
          "standard": [
            {
              "text": "動画共有サイトのアップローダーが仕様変更され、ファイル形式の選択肢が増えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この写真投稿サイトのアップローダーは、ドラッグ＆ドロップに対応していて使いやすい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人気アーティストの最新曲をフライングでアップロードしたアップローダーが、著作権侵害で訴えられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、このブログのアップローダーって、最大何MBまで対応してるの？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "匿名性の高いアップローダーを通じて、機密情報が流出する事件が相次いでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "新しいバージョンのOSにアップデートしたら、今まで使っていたアップローダーが動かなくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
