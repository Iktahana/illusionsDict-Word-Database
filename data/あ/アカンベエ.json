    "definitions": [
      {
        "index": 1,
        "gloss": "pulling down one's lower eyelid and sticking out one's tongue (as a taunt or gesture of contempt or rejection)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "子どもがあかんべえをして笑った。",
              "source": "幻辞"
            },
            {
              "text": "親に叱られてあかんべえと言い返した。",
              "source": "幻辞"
            },
            {
              "text": "舌を出してあかんべえのジェスチャーをする。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえは子どもらしい悪ふざけだ。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえをするなと先生が注意した。",
              "source": "幻辞"
            },
            {
              "text": "昔の子どもたちはよくあかんべえをしていたという。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえは反抗の意思を表現する仕草である。",
              "source": "幻辞"
            },
            {
              "text": "写真であかんべえをしている子どもが写っている。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえの起源については諸説ある。",
              "source": "幻辞"
            },
            {
              "text": "漫画のキャラクターがあかんべえをするシーンがある。",
              "source": "幻辞"
            },
            {
              "text": "彼はジョークであかんべえをしてみせた。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえは世界中にある同様のジェスチャーと比較できる。",
              "source": "幻辞"
            },
            {
              "text": "子どもの行動学ではあかんべえが研究対象になることもある。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえという言葉の語源は不明だ。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえは年配の人にとっては無礼な行動だ。",
              "source": "幻辞"
            },
            {
              "text": "子ども時代、友達とあかんべえの競争をした。",
              "source": "幻辞"
            },
            {
              "text": "映画ではあかんべえをするシーンがコミカルに撮られている。",
              "source": "幻辞"
            },
            {
              "text": "文化人類学ではあかんべえが興味深い研究対象だ。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえをして親に叱られたことがある。",
              "source": "幻辞"
            },
            {
              "text": "あかんべえという言葉は日本文化特有の表現である。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「奧さん、氣を確かに持つて、……」と、今度は京子があかんべえをした。",
              "citation": {
                "source": "天滿宮",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして部屋の隅の洗面器の前に立って、鏡に顔をうつして、あかんべえをやった。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、左眼の瞼がひどく損傷して、全くあかんべえの眼になっていました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この火傷の跡に対して、殊にあかんべえの眼に対して、人々が取る三つの態度に、笠井直吉は気付きました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔ってくると、直吉の顔は赤くなると共に、その火傷した半面が光沢を浮き出させ、あかんべえの眼が細工物のように見えました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "反撥とか敵意とかそういう気持ちではなく、なにか下らない忌々しいものにぶっつかった気持ちで、それが、あかんべえの眼玉を更に大きくむき出させるようなのを意識しながら、へんにじっと見やりました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその中に、自分の火傷の跡、ひきつった皮膚や、ちぢれた耳や、赤光りの禿げや、殊にあかんべえの大きな眼が、まざまざと浮き上ってきました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように考えながらなお様子をうかがっていると、それとも知らぬ主人は思う存分あかんべえをしたあとで「大分充血しているようだ。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が重なると、赤裸になって陣門の近くに群れ、尻振り踊りをしたり、瞼をむいてあかんべえをしたりして、蜀兵を憤らせた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
