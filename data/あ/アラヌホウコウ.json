        "examples": {
          "standard": [
            {
              "text": "計画はあらぬ方向に進んでしまった。",
              "source": "幻辞"
            },
            {
              "text": "議論があらぬ方向へと向かっている。",
              "source": "幻辞"
            },
            {
              "text": "組織があらぬ方向に進めば衰退する。",
              "source": "幻辞"
            },
            {
              "text": "経営方針があらぬ方向に動くと社員も混乱する。",
              "source": "幻辞"
            },
            {
              "text": "物語があらぬ方向に展開するのは予想外だった。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトがあらぬ方向へ向かわないよう管理が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "投資があらぬ方向に流れないよう注視している。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ方向に行かないようブレーキをかけた。",
              "source": "幻辞"
            },
            {
              "text": "改革案があらぬ方向を示していないか検証すべき。",
              "source": "幻辞"
            },
            {
              "text": "感情的になるとあらぬ方向に思考が向かう。",
              "source": "幻辞"
            },
            {
              "text": "キャリアがあらぬ方向に進むことを避けたい。",
              "source": "幻辞"
            },
            {
              "text": "研究があらぬ方向に流されてはいけない。",
              "source": "幻辞"
            },
            {
              "text": "恋愛があらぬ方向に走らないよう気をつけている。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ方向に行きかけたときは立ち止まることが重要だ。",
              "source": "幻辞"
            },
            {
              "text": "方向性があらぬ方向にズレていないか定期的に確認する。",
              "source": "幻辞"
            },
            {
              "text": "あらぬ方向へ進むリスクを評価してから決定した。",
              "source": "幻辞"
            },
            {
              "text": "文化的風潮があらぬ方向に流れてしまった。",
              "source": "幻辞"
            },
            {
              "text": "技術進化があらぬ方向に向かわないよう倫理が必要だ。",
              "source": "幻辞"
            },
            {
              "text": "政策判断があらぬ方向を向いていないか厳しく監視する。",
              "source": "幻辞"
            },
            {
              "text": "関係があらぬ方向に進む前に話し合った。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "だから、じっとこちらを見ているようで、ふとあらぬ方向を凝視している感じであった。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今はもう葉子の神経は極度に脆弱になって、あらぬ方向にばかりわれにもなく鋭く働くようになっていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はそれには頓着なしでずん／＼あらぬ方向へ行つた。",
              "citation": {
                "source": "煤煙の臭ひ",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十、永遠の愛　思い切って私はここに懺悔しますが、四辺に神さん達の眼が見張っていないと感付いた時に、私の心が急にむらむらとあらぬ方向へ引きづられて行ったことは事実でございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　驚いた馬たちは、あらぬ方向へ手綱を引き進み、皆が叫び声を上げる中、後ろ足を蹴り上げていななきました。",
              "citation": {
                "source": "コロロッチョ",
                "author": "GRILLINO",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然に尻尾がさがり、今日はまたなんていやな空模様だろう、とでも云いたげに、天のほうを見あげたり、または急に用を思いだしたといったようすで、あらぬ方向へ走り去ったりするのだ。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、あらぬ方向を不気味に凝視して、精神が錯乱したか。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がふと、あらぬ方向へ一｜跳足しかけたのは、自然だった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
