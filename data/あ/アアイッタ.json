    "definitions": [
      {
        "index": 1,
        "gloss": "that sort of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昨日の会議で彼はああ言った。",
              "source": "幻辞"
            },
            {
              "text": "大臣はそのようにああ言った。",
              "source": "幻辞"
            },
            {
              "text": "物理学者はああ言ったが、後で訂正した。",
              "source": "幻辞"
            },
            {
              "text": "小説の中で主人公はああ言った。",
              "source": "幻辞"
            },
            {
              "text": "教授がああ言ったので学生たちは注意深く聞いた。",
              "source": "幻辞"
            },
            {
              "text": "医者がああ言ったことで患者は安心した。",
              "source": "幻辞"
            },
            {
              "text": "判事はああ言って判決を述べた。",
              "source": "幻辞"
            },
            {
              "text": "監督はああ言ってチームを励ました。",
              "source": "幻辞"
            },
            {
              "text": "自然学者がああ言った時、皆が同意した。",
              "source": "幻辞"
            },
            {
              "text": "歴史上の人物はああ言ったと記録されている。",
              "source": "幻辞"
            },
            {
              "text": "有名シェフはああ言って調理法を説明した。",
              "source": "幻辞"
            },
            {
              "text": "観光局の職員はああ言ったので安心した。",
              "source": "幻辞"
            },
            {
              "text": "心理学者はああ言ったことが理に叶っている。",
              "source": "幻辞"
            },
            {
              "text": "芸術家はああ言ってコンセプトを説明した。",
              "source": "幻辞"
            },
            {
              "text": "CEO がああ言ったので社員は動揺した。",
              "source": "幻辞"
            },
            {
              "text": "先輩がああ言ったので後輩は従った。",
              "source": "幻辞"
            },
            {
              "text": "研究チームの長がああ言った。",
              "source": "幻辞"
            },
            {
              "text": "弁護士がああ言ったことは無視できない。",
              "source": "幻辞"
            },
            {
              "text": "選手はああ言ったことを実行した。",
              "source": "幻辞"
            },
            {
              "text": "環境保護団体がああ言ったことは警告だった。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "そして私の風体を見てから、「旦那はああ言ったが、わしが頼んで泊めてあげるから水を汲んで帰るまで待ってな」と言い捨てて霧の中に歩み去った。",
              "citation": {
                "source": "木曾駒と甲斐駒",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三好　近頃の若い男なぞ、大概、ああ言った、女には、おかしく見えるんじゃないかね。",
              "citation": {
                "source": "好日",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時々でああ言ったりこう言ったり、メチャメチャじゃないか。",
              "citation": {
                "source": "炎の人――ゴッホ小伝――",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はガレノス＊＊が何か価値あることを言ったかどうかと問わずに、彼はこう言ったか、ああ言ったかと問う。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも尺取だ、雲霧のやつがああ言ったこともあるから、意地でも人手は借りねえ。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も、日本左衛門がああ言ったからって、そんな生々しいものを、土産にかかえてゆくこたアありゃあしません。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいった性分の人には……それで焦れてついいろんなことを云ったり仕たりしちまうんだな。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼君なんかはまたいつもああいったふうのことをよくないよくないと小言に言うほうだから、聞かれては恥ずかしくてならない」「山の坊さんたちにもまるで話を変えてしてございます」　と惟光が言うので源氏は安心したようである。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいった関係は私に経験のないことだったから、ばかに世間がこわかったのだ。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょッとああいったようなね、頚つきでしたの。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ああいった武子さんは、自分で綿入れを縫って隠れ家へ届けている。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいったい、それは誰なんでしょうかね」と再三真斎の自供を促しても、相手は依然として無言である。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその後、約一ヶ月も経ってからのことであったと記憶するが、たまたま今私の在住しているこの諏訪郡およびそれに含まれた岡谷市とからなる、いわゆる市町村吏員会の幹事の方がお見えになり、「自分は過般木曾での会合に直接話を聴いた一人であるが、ああいった話をわれわれにだけでなく、吏員の全部で聴きたい。",
              "citation": {
                "source": "自力更生より自然力更生へ",
                "author": "三澤勝衛",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は今ああいった。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいった軽いものの方がいいわね。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ちょうどああいった工合に何か愉しくて愉しくてならないように、無数の小さな雪が空の奥のほうで微かにごおっという音を立てながら絶えず涌いているような気がせられるのである。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そんなようなことは、どちらがどうあろうとも、お角にはあんまり興味を惹かない――ただ、ああいった種類の男同士は、ああいった種類の男同士で、また相当の意気張りずくで争っているだけのものだろうと思う。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、長浜の市中を横に走るところの、素敵に足の早い旅人を、遠目に見かけると、それが、がんりきの百という見知越しのやくざでない限り、ああいう気取り方と、ああいった走り道具を持ったものはないということでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から四十年ばかり昔の事だから、もうこの村でもああいった葬式のやり方は廃れてしまっているだろうが、弥之助は思わずその昔の風俗を思い出したのである。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、ああいった研究は、どんなかたちにおいてであろうと、もう、二度とくりかえしてやる気にはなれなかった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェリクスはまもなく、自分とその家族がそのためにああいった前代未聞の圧迫を受けた腹黒いトルコ人が、恩人がこんなふうに貧窮と破滅に陥ったのを知ると、善良な感情や体面を裏切って、娘を伴れてイタリアを去り、今後の生計を立てるうえにお助けすると称して、無礼にもはした金をフェリクスに送ってよこしたのを知った。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの年ごろ、またああいった気性の女として、男が必要な程度にはね。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは社会の四分の三が奴隷ども――つまりああいった猿の手合いから成り立ってるからなのだよ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋建物にああいったものは不調和だという議論があっての事か。",
              "citation": {
                "source": "丸の内",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいった管で、しっかりとあなたに結びついていたの。",
              "citation": {
                "source": "雲の小径",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、ああいったものなんで、苛めたり迫害したりする意図はぜんぜん含んでいないのですよ。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、ていねいにいわなければならないのにたいして、あいては、「きさまは、ああいった、こうしろ。",
              "citation": {
                "source": "福沢諭吉",
                "author": "ペンは剣よりも強し",
                "note": "青空文庫"
              }
            },
            {
              "text": "山国であるため、ああいったもので勝利を博そうとしたものであろうか。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何より先に、あのお夏さんというお嬢さんのことを伺いたいのですが」「飛んだ出過ぎたことをしたそうで、ああいった気性者も親譲りでございます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "橋場の人魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、そもそもああいった若い恋人の亡霊には君に語るべきことなどあるかなあ？",
              "citation": {
                "source": "長い部屋",
                "author": "O. H. ダンバー　O. H. Dunbar",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
