        "examples": {
          "standard": [
            {
              "text": "デザートには、甘口のアップルワインがよく合いますね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この地域の特産品であるアップルワインは、リンゴの豊かな香りが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "友人とのホームパーティーで、自家製アップルワインを振る舞ったら好評だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「冷えたアップルワインが、こんなに口当たりがいいなんて！」と彼女は感嘆した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "クリスマスの食卓を彩るため、限定醸造のアップルワインを取り寄せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "発泡性ではないアップルワインは、食前酒としても楽しめる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "林檎園の収穫祭で、フレッシュなアップルワインの試飲が行われていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
