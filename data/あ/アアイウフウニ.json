          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼はああいう風に堂々と話すことができる。",
              "source": "幻辞"
            },
            {
              "text": "会社の方針をああいう風に決めるのは異例だ。",
              "source": "幻辞"
            },
            {
              "text": "この化学反応はああいう風に進む。",
              "source": "幻辞"
            },
            {
              "text": "作者はああいう風に物語を描いた。",
              "source": "幻辞"
            },
            {
              "text": "先生はああいう風に学生を指導する。",
              "source": "幻辞"
            },
            {
              "text": "症状はああいう風に進行する傾向がある。",
              "source": "幻辞"
            },
            {
              "text": "裁判はああいう風に進められた。",
              "source": "幻辞"
            },
            {
              "text": "トレーニングはああいう風に計画される。",
              "source": "幻辞"
            },
            {
              "text": "季節はああいう風に移り変わる。",
              "source": "幻辞"
            },
            {
              "text": "古い記録はああいう風に保存されていた。",
              "source": "幻辞"
            },
            {
              "text": "パスタはああいう風に調理する。",
              "source": "幻辞"
            },
            {
              "text": "旅程はああいう風に組まれた。",
              "source": "幻辞"
            },
            {
              "text": "人間はああいう風に成長する。",
              "source": "幻辞"
            },
            {
              "text": "アーティストはああいう風に表現する。",
              "source": "幻辞"
            },
            {
              "text": "プロジェクトはああいう風に管理される。",
              "source": "幻辞"
            },
            {
              "text": "知識はああいう風に習得される。",
              "source": "幻辞"
            },
            {
              "text": "治療はああいう風に行われる。",
              "source": "幻辞"
            },
            {
              "text": "判決はああいう風に言い渡された。",
              "source": "幻辞"
            },
            {
              "text": "選手はああいう風に鍛えられる。",
              "source": "幻辞"
            },
            {
              "text": "自然界はああいう風に機能している。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "わたくしももうやけくそになって、ああいう風に酔っていたのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人たちは、ああいう風に酒を呑まなければ、淋しくて寒くて生きていられないようなときに生れたのだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は、ああいう風に考えて、自分が一家のために奮闘するといったような気持を味わいたいのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、窪川稲子さんに会ったら、或る若い勤労婦人のひとで、この小説を読んだ感想に、アグネスがどうしてああいう風に男を反撥してゆかなければならないのか、その点があの小説ではよくのみこめなかったと云ったという話が出た。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "プチト・ファデットが自分の特別に荒い境遇を変化させて自分の真情からの愛をも完うしてゆく勤勉で精気にみちた姿は、人生への知性というものは、ああいう風にも現れるという活々としたよろこばしい見本の一つである。",
              "citation": {
                "source": "知性の開眼",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際聴きわける耳もないのに謡と思うとああいう風に気を張るのかと思うと、暗い一念、という印象が強く私に遺されていた。",
              "citation": {
                "source": "祖母のために",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界の現実に対して、理性が主体的な角度に立つリアリズム――社会主義的リアリズムについて考えている作家は、スタインベックがソヴェトの人々の合理主義を扱ったああいう風にそれを扱おうとはしないだろう。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロンドンのいりくんだ下街のゴチャゴチャを、外国人のレーニンがああいう風に精密に我ものにしたところに、そして、また地図を書いてやるその書きかたに彼の指導者としての器量をつよく感じた。",
              "citation": {
                "source": "スモーリヌイに翻る赤旗",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "コムソモールカが昔のバレーの白鳥のようにやっぱりああいう風に爪立って、チョチョチョチョと歩いて、キュッと片脚をのばしている。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああいう風にして立派な人を死なせたその力はわれわれを堕落させて碌な評論も書けない人間にしてしまったと反省するでしょう。",
              "citation": {
                "source": "婦人の創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女同志だとああいう風にならぶんだ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が今まで観察した所によると二人づれの若い女は必ずああいう風にすわる。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ずと云つて悪ければ、十組の中八組まではああいう風に位置をとるものだよ」「そうかな」「そうさ。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い婦人同志はボックスにまずああいう風に坐る。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "じや君、女同志だと何故ああいう風に腰かけるか、その理由を説明して貰いたいな」　私は藤枝がいつもの通り、何か吹きはじめるかと期待しながらこうきいたのである。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなければ何故父がああいう風にずつと恐怖しつづけているのでしよう。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画としてああいう風に彩描して行く事の一番底に流れている要求は何か？",
              "citation": {
                "source": "想像と装飾の美",
                "author": "それを持つ特殊の個性によって生かさるべし",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問なりその他の名誉を得て傲る者を見ると、彼奴も近ごろ一円｜貰ったばっかりだな、ああいう風にやっては明日の日の登る前に形無しになるであろうと思う。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでなければああいう風に私語合ってはくすくす笑う訳がない。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の中では一昨日の晩会った田口の態度を思い浮べて、今日もまたああいう風に無雑作な取扱を受けるのか知らん、それとも向うで会うというくらいだから、もう少しは愛嬌のある挨拶でもしてくれるか知らんと考えなどした。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はどうしたらこの未練らしい執着の根を絶って、ああいう風になれるのだ？",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ自分もああいう風に語れたら。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "木彫の中にも色々変っているものがあるが、なる程、ああいうようにやるからああいう風に出来るのだということが見ると夫々分るのである。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時代に、ああいう風にこなすとああいう工合になるのは当然である。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんなことを云ったって、ああいう風になったのだから、仕方がないではありませんか。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこっちでも大砲や機関銃をもっていて、空中のギャングをああいう風におっぱらうんだ」「そうかね」丁坊は、よく分らないけれど、分ったような返事をした。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（おれは、ああいう風に、ぽんぽん叱りつける幽霊の話を、きいたことがないぞ。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにあの針と来たら、少し曲ってはいるが、ああいう風にだんだんと尖端の方にゆくにつれて細くするには、とても骨を折った。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「避雷針を持っている者は、誰だって、ああいう風に平気で安全でいられますよ。",
              "citation": {
                "source": "雷",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父さん、障子が張れましたネ」「その額を御覧、正太さんがああいう風に掛けて下すった」「真実に、正太さんはこういうことが御上手なんですねえ」　とお雪は額の前に立って、それから縁側のところへ出てみた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
