        "examples": {
          "standard": [
            {
              "text": "あわてん坊の田中は期限を忘れていた。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な彼は報告書に誤りが多い。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊の性格が仕事ミスを増やしている。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊だから細部を見落としている。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な行動で信用を失った。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な返答は相手を怒らせた。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な判断が失敗を招いた。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な性格を直す必要がある。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊では医学分野では危険だ。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な診断は医療事故につながる。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な警察官は市民の信頼を失う。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な教員は指導の質が低い。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な経営判断は会社を傾かせる。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な調理は味を台無しにする。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な運転は事故の原因になる。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な手術は患者を危険にさらす。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な投資で損失を被った。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な建築で欠陥が発生した。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な分析で結論が誤った。",
              "source": "幻辞"
            },
            {
              "text": "あわてん坊な対応は状況を悪化させた。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "それはまず第一に年が若いために、古いものにあうとごまかされやすいこと、どんどん走りすぎて足もとに注意しないために、溝へおっこちるようなことがあること、すこしあわてん坊であること、それからタバコをすいすぎることなどであった。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は後で考えて、「ぼくは、あのときは、なんてあわてん坊であったろう」と苦笑したことだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "義眼だろう、きっと」　彼は、自分があわてん坊だったのに気がついて、おかしくなり、ひとりで笑った。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだん何ごともない時には、いつも駈けたり跳ねたり、つまずいたり、たんかをきったり、とても騒々しいあわてん坊で、一人で町内をさわがしているんだが。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
