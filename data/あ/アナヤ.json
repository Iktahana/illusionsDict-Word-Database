    "definitions": [
      {
        "index": 1,
        "gloss": "whoa",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「あなや、敵襲か！」と、不意を突かれた兵士が叫んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あなや、大事な書物を雨に濡らしてしまった！」と、彼は天を仰いだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古文書を読み解き、「あなや、この謎は斯くの如きか！」と、学者は膝を打った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "茂みから突如現れた獣に、「あなや！」と、旅人は後ずさりした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "物語は佳境に入り、「あなや、まさかの裏切りか！」と、読者は息を呑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "進退窮まり、「あなや、最早これまでか…」と、武将は覚悟を決めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あなや、この道は崩れて通れぬわ！」と、先頭を行く者が声を上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "あなやの間ではあるが、消えてはまた生まれ、あちらと思えばこちら、連続と隠顕と、ひととき眼を忙失させるけれども、なお眼を放たないなら、眺め入るものに有限の意識を泡にして、何か永遠に通じさすところがある。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなや否とよ立てきみと、　　博士が云へばたちまちに、けりはねあがり山つ祇、　　　をみなをとりて消えうせぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲のわだつみ洞なして、　　青野うるうる川湧けば、あなや春日のおん帯と、　　もろびと立ちてをろがみぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "七面鳥はさまよひて、　　　　　ゴブルゴブルとあげつらひ、小き看護は窓に来て、　　　　　あなやなにぞといぶかりぬ。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時小犬ほどな鼠色の小坊主が、ちょこちょことやって来て、あなやと思うと、崖から横に宙をひょいと、背後から婦人の背中へぴったり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなやと思うと更に、もとの顔も、胸も、乳も、手足も全き姿となって、浮いつ沈みつ、ぱッと刻まれ、あッと見る間にまたあらわれる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "したしたとながれにじむをあなやと両の拳もてしかとおさえたれど、留まらで、とうとうと音するばかりぞ淋漓としてながれつたえる、血汐のくれない衣をそめつ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなやと振返ればわが家の後見せる奈四郎といえる力｜逞ましき叔父の、凄まじき気色して、「つままれめ、どこをほッつく。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂｜青光して、はたたがみ堂の空をまろびゆくに、たまぎりつつ、今は姉上を頼までやは、あなやと膝にはいあがりて、ひしとその胸を抱きたれば、かかるものをふりすてむとはしたまわで、あたたかき腕はわが背にて組合わされたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母は、あなや、と叫んで私を畳のうえに投げ飛ばした。",
              "citation": {
                "source": "玩具",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人あなやと叫びてその手を執りぬ。",
              "citation": {
                "source": "詩想",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　といまは苛てる状にて、はたとばかり掻退けたる、雪は辷り落ちて、三ツ四ツに砕けたるを、少年のあなやと拾ひて、拳を固めて掴むと見えし、血の色颯と頬を染めて、右手に貴女の手を扼り、ものをも言はで引立てつ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白糸あなやと飛び退る遑もなく、「偸児！",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母體は昇天す、このときみなそこに魚介はしづみ、いつさいに哀しみの瞳をあげて合唱しあなや合讚したてまつる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "青酸い滋味が漿液となり嚥下される刹那に、あなやと心をうつろにするうまさがお絹の胸をときめかした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は一足跳ねたダンス足の左の靴の踵に、床を滑って右の踵が追い迫り、あなやと思う間にひらりと新吉の膝の上に彼女は乗っかった。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "したしたとながれにじむをあなやと両の拳もてしかとおさへたれど、留まらで、たふたふと音するばかりぞ淋漓としてながれつたへる、血汐のくれなゐ衣をそめつ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなやと振返ればわが家の後見せる奈四郎といへる力逞ましき叔父の、凄まじき気色して、「つままれめ、何処をほツつく。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "本堂｜青光して、はたたがみ堂の空をまろびゆくに、たまぎりつつ、今は姉上を頼までやは、あなやと膝にはひあがりて、ひしとその胸を抱きたれば、かかるものをふりすてむとはしたまはで、あたたかき腕はわが背にて組合はされたり。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、冷いので、あなやと驚き、膝を突かけ、背を抱くと、答えがないので、慌てて、引起して、横抱きに膝へ抱いた。",
              "citation": {
                "source": "縁結び",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなやと思ふと更に、もとの顔も、胸も、乳も、手足も全き姿となつて、浮いつ沈みつ、ぱツと刻まれ、あツと見る間に又あらはれる。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなやと見れば、対岸なる山の腰に一ツ消えて、峰の松の姿見えつ。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その青い倦怠の中からわれ知らず罪咎の魔神の力を藉りても生き上ろうとするわが身の内の必死の青春こそ、あなや、危うくあります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あな、見よ、青き大月は西よりのぼり、あなや、また瘧病む終の顫して東へ落つる日の光、大ぞらに星はなげかひ、青く盲ひし水面にほ薬香にほふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ、また、わが立つ野辺の草は皆色も干乾び、折り伏せる人の骸の夜のうめき、人霊色の木の列は、あなや、わが挽歌うたふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなや、また呻吟は洩るる。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "はた、あかあかと蒸気鑵音なく叫び、そこここに咲きこぼれたる芹の花、あなや、しとどにおしなべて日ぞ照りそそぐ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さと燃えあがる間こそあれ、飜ると見れば手に平む吸取紙の骸色爛れぬ――あなや、血はしと、と卓に滴る。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
