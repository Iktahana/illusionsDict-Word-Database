[
  {
    "uuid": "2a029fb1-40bb-5f04-9667-35ab5a655601",
    "entry": "後追い",
    "reading": {
      "primary": "あとおい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
