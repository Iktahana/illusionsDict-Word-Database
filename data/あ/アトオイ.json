      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "trailing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "生後八ヶ月になり、母親の姿が見えなくなると激しく泣くといった後追いが始まった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "先行する競合他社の製品を単に後追いするだけでは、市場での優位性は確立できない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "著名人の突然の訃報を受け、ファンによる後追い自殺を防ぐための相談窓口が設置された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "他紙のスクープ記事が出た直後から、各メディアが一斉に後追い報道を始めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "先発隊が残した目印を頼りに、我々も後追いで険しい山道を登っていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "過去の判例を後追いするだけでなく、現代社会の実情に即した新たな法解釈が求められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その後追いおいに気づいていったことなのであるが、この美しい水音を聴いていると、その辺りの風景のなかに変な錯誤が感じられて来るのであった。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういうこともない例ではありませんが、飽までも練れた客で、「後追い小言」などは何も言わずに吉の方を向いて、　「帰れっていうことだよ」と笑いましたのは、一切の事を「もう帰れ」という自然の命令の意味合だと軽く流して終ったのです。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、それにしても、もう少し愛情の籠った態度を見せてくれてもよかりそうなものだと、後追い掛けた咄嗟の恨みだった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いえ、知っとります、横浜へ、あんたさんの後追いかけて、その太夫さんがお出やしたことも。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "後追いかける服部兄妹！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ女は直ぐ大きなよく出来たのをもいで、後追いかけました。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし御跡に残りとどまって戦う兵なくば、敵｜審かしみ、御後追いかけ申すべし。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたが父の後を追うようなことをなさるかと……いやな言葉だけど、後追い心中をするかと、そればかりを心配しているんです」　久美子は露骨に皮肉な調子で浴びせかけた。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャンプ村のバンガローへ移りたいんだけど、いいでしょうか」「バンガロー……いいだろう」「あたしはＫ・Ｕじゃないから、頼まれたって後追い心中なんかしません。",
              "citation": {
                "source": "肌色の月",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "門を出た時、ポチが後追いをしたので、「好い犬だね」　と大場君が振り返った。",
              "citation": {
                "source": "好人物",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争中われわれを追いつめて来た、そして戦後追いつめて来ているニヒルは、それだけに、根本的に深く永いものであったし、今後も深く永いものであろう。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに今夜という今夜、柳小路で見かけた怪しの者、見えがくれに後をつけると、要法寺の墓地へ入って行衛が知れず、引返そうとした時に、かねて謀し合せておいたこの男、同じような怪しい者が、たった今、古城の方へ行ったと申す故、二人で後追いかけて、たしかに姿を認めたのが当屋敷の裏手。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後追い追い山高帽子や洋服の礼者も殖え、足取りも大分せわしく、二十五、六年代には電信電話の線もゆきわたり、交通も繁しくなって、追羽子や凧揚げは横町か空地に限られ、娘子供は大不服。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "マザロフは後追いを止めて、庭の離れで煙草を吸うと言った。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "おーい」「謙三郎どのう」「お兄様あっ……」　後追いかけて来たのだった。",
              "citation": {
                "source": "剣の四君子",
                "author": "高橋泥舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし重蔵様、どうなされたのでござります……」「ちちッ……」　重蔵は身を顫わせ、血の出るほど、糸切歯で唇を噛みしめたまま、「し、知れたこと、新九郎の後追いかけて、彼奴の迷夢を覚してくれる。",
              "citation": {
                "source": "剣難女難",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はなおも　節おもしろく、街から街へと　吹きたてゆけば、おくれちゃならぬと　一生けんめい、町のねずみの　おどりの行列、ぞろぞろがやがや　あとおいかける。",
              "citation": {
                "source": "魔法の笛",
                "author": "ロバアト・ブラウニング",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "imitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "他紙のスクープに対し、各メディアが一斉に後追い取材を始めたことで、事件の全容が徐々に明らかになってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "競合企業のヒット商品を後追いして似たような製品を市場に投入しても、先行者利益を覆すのは容易ではない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "生後十ヶ月を過ぎた頃から赤ん坊の後追いが激しくなり、母親は少しの間も部屋を離れられず苦労している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "会議で決議された施策が現場で確実に実行されているかどうか、管理職が定期的に後追いして進捗を確認する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "海外の最先端の技術トレンドを単に後追いするだけの開発戦略では、真のイノベーションを生み出すことはできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            },
            {
              "text": "敬愛する恩師の突然の訃報に深く悲しみ、一部の門下生が後追い自殺を図るのではないかと周囲から危惧されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3.1-pro-preview"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "clinginess (in babies, toddlers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "乳幼児期に見られる激しい後追い行動は、愛着形成の健全な証拠とされることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "うちの子は後追いが激しくて、仕事に行く準備を始めるとすぐに泣き出してしまうんです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「先生、〇〇ちゃんがずっと後追いしてきて、他の子と遊んでくれないんです。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "後追いというのは、親や特定の大人が離れることへの不安からくる、子どもの自然な行動です。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この月齢では、後追いがピークを迎える時期で、親としては大変ですが、成長の証でもあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "保育園に預ける際、母親の後追いをする子どもの姿に胸を痛める親は少なくない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": []
        }
      }
    ],
