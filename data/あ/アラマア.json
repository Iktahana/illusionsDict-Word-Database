        "examples": {
          "standard": [
            {
              "text": "あらまあ、雨が降ってきたね。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、予定が変わってしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、子どもたちがもう寝てしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、そんなことになってたんですか。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、どうしましょう。",
              "source": "幻辞"
            },
            {
              "text": "おばあさんはあらまあとぼやいて肩をすくめた。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、今日も忙しい一日だった。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、仕事が思ったより長引いた。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、花子さんが来てくれたんですね。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、困った状況ですね。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、物価がまた上がっているのね。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、もう夜中じゃないですか。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、ご報告ありがとうございます。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、大変ですね。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、そういうことでしたか。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、時間がもう来てしまった。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、皆さん無事でよかった。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、思わぬ展開ですね。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、そんな話があったんですか。",
              "source": "幻辞"
            },
            {
              "text": "あらまあ、今はどうしようもありませんね。",
              "source": "幻辞"
            }
          ],
          "literary": [
            {
              "text": "「まあ、この鳥、たくさんですわねえ、あらまあそらのきれいなこと。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、この鳥、ずゐぶんだわねえ、あらまあそらのきれいなこと。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まあ、この鳥、たくさんですわねえ、あらまあそらのきれいなこと」女の子はジョバンニにはなしかけましたけれどもジョバンニは生意気な、いやだいと思いながら、だまって口をむすんでそらを見あげていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらまあそらのきれいなこと。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、なんて、ぐずぐずしてしまったんでしょう！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は、「あらまあ、しばらく。",
              "citation": {
                "source": "女人創造",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜も僕の顔を見て、「あらまあ！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあどうでもようござんすよ」　おいよさんは構はずに衣物を私に引つ挂けさせて、後で膝をついて裾を合せて引張つて見たり、前へ立つて袖を横に引つ張つて見たりして白いしつけ糸をとつて口に入れては歯で噛みながら「もう何処へ行つてもようござんすよ」　おいよさんは衣物をとりながら私を見て嫣然とした。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、兼ツつあんはこんなに小麥踏ンぢやして怒られべえな」　おいとがこんどは苦情を持ち出す。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、どうするんだらう」　顏には左程の驚もなく然かも聲高に不遠慮にいつた。",
              "citation": {
                "source": "商機",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、私随分妙ね。",
              "citation": {
                "source": "駒鳥の胸",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、貴方はあんなに泣いてゐらしたのに――もうお忘れになつたのですか。",
              "citation": {
                "source": "嘆きの孔雀",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　八重は鞴の把手と一処に、わざと床とすれ／＼になる位に仰け反つて、「あらまあ、父さんたら、妾が不服だなんて云つたら、あんな心配さうな顔なんてしてゐるわ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、つまんないことを云つてゐるうちにすつかり火が出来過ぎてしまつたぢやないの。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒猫「おまへさんなんざあ器量は好いし、おとなしいから人に可愛がられて幸福といふものさ」斑猫「あらまあ、あんなことを、おなじ猫でも女になんぞ生れてはつまりませんわ」黒猫「どうしてなか／＼、私なんざあ、自分で自分の糊口をしなきやあならないんですからやりきれやせんや」斑猫「それだから結構ですわ。",
              "citation": {
                "source": "コドモノスケッチ帖",
                "author": "動物園にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "青い空とみどりの木の梢を見ながら娘が垣根に欲しがって居た花がひっかかって居るのを見つけたらきっと、　あらまあ――一寸お祖母様あの花が有る事よと云うに違いない。",
              "citation": {
                "source": "グースベリーの熟れる頃",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、貴方でしたの……」と目を瞠って会釈した後で、「昨夜はどうも……」と、恥かしそうに身体をねじるようにして挨拶をした。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、あたし初めてお目にかかってたいへん失礼をいたしまして……」と彼女は紹介者に負けず朗らかに謳った。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、玄さん、珍しいですこと」「へへえ、これは又｜至極面白いところで……」　と近附くや、玄竜は彼女の向い側の方にどっかりと坐り込んだ。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、お供さんが片っぽおちて――」　お婆さんは歯のない口を一ぱいにあいて笑った。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "町の構成",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、濟まなかつたねえ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さかんに壊すんです」「あらまあ、どうしてでしょう」向うへいったら、さかんに物を壊せ、気をつけて物を壊せといわれて、光枝はひどく愕いた。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、またオギンさんが壊したの。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このハンカチでおさえて、そして医者を呼べ」「あらまあ、オギンさん、怪我をしたの。",
              "citation": {
                "source": "什器破壊業事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらまあとお房さんが驚いている。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼子　　あらまあ、さう云へば、お兄さまの寝台は、うちが掠奪しちやつたわけね。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、大へんなおもちやですね。",
              "citation": {
                "source": "かぶと虫",
                "author": "槇本楠郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらまあ、一体いつなの、それは。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
