    "definitions": [
      {
        "index": 1,
        "gloss": "the year following an inauspicious year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本厄が無事に過ぎたとはいえ、後厄の今年もまだ気を引き締めて生活しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あぁ、ようやく本厄が終わったのに、後厄の今になって大きな病気が見つかるなんてね」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "厄年の締めくくりとなる後厄を迎え、改めて家族の健康と安全を祈願した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そうだね、後厄はお礼参りも兼ねて、もう一度厄除けの祈祷を受けておこうか」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前厄から後厄までの三年間、彼は大きなトラブルに見舞われることもなく平穏に過ごした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "後厄の期間中ということもあり、住宅の購入や大規模な投資は慎重に見極めるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「ふぅ、ようやく後厄が明けたから、来年からは心機一転して新しいことに挑戦したいな」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "親分の鐘五郎は四十三歳、後厄の大事な誕生日を迎へた上、新に大々名二軒の出入りを許されて、押しも押されもせぬ、江戸一番の人入稼業になつた心祝ひの酒盛だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分の鐘五郎は四十三歳、後厄の大事な誕生日を迎えた上、新たに大大名二軒の出入りを許されて、押しも押されもせぬ、江戸一番の人入れ稼業になった心祝いの酒盛りだったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鐘五郎の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ来年こそはと言っていても、その時になるとまた、今年は後厄だから――と、際限もなく祝言を延されることでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "死相の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "それさえ無事に過ぎれば後は六十ぐらいまで大丈夫ですから、矢張り気をつけるに越したことはないと仰有いましたわ」「前厄本厄後厄と三年網を張って待っていれば何か病気が引っかかるよ。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
