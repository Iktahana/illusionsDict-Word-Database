    "definitions": [
      {
        "index": 1,
        "gloss": "large-flowered lady's slipper (Cypripedium macranthos var. speciosum)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "亜高山の湿った草地に、袋のような形をした敦盛草が紅紫色の花を揺らしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敦盛草の名は、大きく膨らんだ唇弁を、若武者・平敦盛が背負った「母衣」に見立てたことに由来する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あ、あそこに咲いているのは敦盛草ですよ。この辺りでも滅多にお目にかかれない珍しい花なんです」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "特定国内希少野生動植物種に指定されている敦盛草は、許可なく採取や譲渡を行うことが法律で厳しく禁じられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "盗掘から敦盛草の自生地を守るため、開花時期に合わせて地元住民による夜通しの監視活動が続けられている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "礼文島にのみ自生する白い敦盛草は、その気品ある姿から「北の妖精」とも称され、多くの登山客を魅了している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "熊谷草、敦盛草、弁慶草や雪の下がねえ、虹のように咲いていましたの。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "敦盛草を摘んで来ました。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……敦盛草をお持ちですか」「持っているとも持っているとも。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いいえ、それ熊谷草、敦盛草って言いましょう、あれです。",
              "citation": {
                "source": "北国の人",
                "author": "水野葉舟",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方馬を追って村へくだるこどもが手にした敦盛草の花が眼に残る。",
              "citation": {
                "source": "山岳浄土",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
