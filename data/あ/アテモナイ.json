          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "就職先も決まらぬまま、当てもない日々を過ごしていると、焦りばかりが募っていく。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「どこへ行くんですか」「いえ、特に目的地があるわけではなく、当てもなく歩いているだけですよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目的地を一切定めない当てもない旅に、日常を忘れて身を任せてみたいと思うことがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "有力な手がかりを失った捜査員たちは、当てもなく周辺住民への聞き込みを続けるしかなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "確かな勝算もなく、当てもない勝負に打って出るのは、勇敢というよりは無謀と言うべきだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "帰る場所を失った彼は、当てもないまま冷たい雨が降りしきる夜の街へと消えていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「当てもなく電車に揺られていると、不思議と心が落ち着いて、新しいアイデアが浮かんでくるんだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東へ行ってどうしようという当てもなかったが、同時に、西へ行ってどうしようという当てもない。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへという当てもないが、月にアバタをまごまご曝していては、お主の繩目に掛らざなるまい」「法螺だ、法螺だよ。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どこへ行こうとするのか、妻子を探す当てもなく、また、今夜の宿を借りる当てもない。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てもないままに、赤井はひょこひょことさまようていたが、やがて耳の千切れるような寒さにたまりかねたのか、わずかの温みを求めて、足は自然に難波駅の地下鉄の構内に向いた。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもただ女房を持たせられると聞いたばかりで、どこの誰という当てもないのに、二三日の間はそわそわして物が手に附かなかった。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして無理矢理母の手から受取ると、眼鏡の隙間からポタポタ涙を落しながら、家を飛び出したが、どこへ行くといふ当てもないと判ると、急に気の抜けた歩き方になり、家出の決心がふと鈍つた。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二十五日の夜、やっと大阪駅まで辿りついたが、さてこれからどこへ行けば良いのか、その当てもない。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てもない咳払いを一つして反り身になった。",
              "citation": {
                "source": "空を飛ぶパラソル",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ようし、そんなら、せめて俺だけでも、金の馬鹿野郎を粗末にしてやれ』と思って、有りもしなければ当てもないのに、入ったら最後、悪妻よりも残酷に叩き出してやる。",
              "citation": {
                "source": "山谿に生くる人々",
                "author": "――生きる為に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "行く当てもないのに急ぐ旅路かな　といふ句がふと目を引いた。",
              "citation": {
                "source": "歯痛",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、どこという確かな目当てもないのであるが、さしあたりは父に教えられた心あたりの四、五カ所をたずねることにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜の泊るべき当てもないので、先きの男と分れて、教へられた道を左へ左へと歩いて行つた。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　逃げ出したものの、どうする当てもないので、今にも鬼が追っかけて来るかとはらはらしながら、川の岸をはなれて山の方へどんどん逃げて行きました。",
              "citation": {
                "source": "鬼六",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭い檻の中で、何処へ行く当てもない群集が、閉じこめられてゐる。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "直吉は腹が空いたが、何処で食事をすると云ふ当てもない。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまゝ歩いてみたところで、何処へ突き抜けて行ける当てもない。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへ行く当てもない。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てもないのに立ち上りながら異口同音に、「……帰ろう帰ろう。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "当てもない妻の霊に対して、おんなじような詫びごとを繰返し繰返し良心の呵責を胡麻化しているのであった。",
              "citation": {
                "source": "木魂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、どこへ行ったら、沙金に会えるという、当てもない。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし当てもない旅に出るのは現在の伝吉には不可能である。",
              "citation": {
                "source": "伝吉の敵打ち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "がまた自分の、今といってどこへ行くべき当てもないことを考えた時、その恐怖に似たものは、いつか知らずうすれていって、やがて流し場へあぐらをかいた氏は、もう老人の背を流したり、老人から背を流されたりしていた。",
              "citation": {
                "source": "地図にない街",
                "author": "橋本五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初に企業整備のことを持ち出したもんだから、兄さんはそれにばかりこだはつてるけれど、僕は、続けて出版をやつて行く自信もあるし、軍需工場の新設は、ほかに金の当てもないことはないんです。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればとて、何をする、何事をしたい当てもない。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "男爵自身も長靴をはき、剣を吊って、馬にまたがり、見つかる当てもない探索にくりだそうとした。",
              "citation": {
                "source": "幽霊花婿",
                "author": "ある旅人の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "野見　　そんな売りこむ当てもない翻訳なんかしたつてなんになる。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞き込みの当てもないのであった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぬしたちの亡骸のことだが、こうしていてもいつ陸地へ着くという当てもない。",
              "citation": {
                "source": "重吉漂流紀聞",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰に贈るあてもないが一枚を五十銭で買った。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅へ帰ってどうすると云うあてもないので、銀座通りをぶらぶら歩き、大店のガラス窓の中を覗いてみたり雑誌屋の店先をあさってみたり、しばらくはほとんど何事も忘れていた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
