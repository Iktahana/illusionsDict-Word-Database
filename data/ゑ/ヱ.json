  {
    "uuid": "52482d5a-e9e7-599b-9227-a289a0979a8f",
    "entry": "ヱ",
    "reading": {
      "primary": "ヱ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "未分類"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "katakana \"we\" (historical kana)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ボオドレヱルは「自我崇拝閣下」と綽名された。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らばボオドレヱルは――ボオドレヱルのは、彼が彼自身の部屋に於ける、天才的狂爛の、それが対他するに際して、即ち狂爛が諦念の形式にまで置換されるに際して、その瞬間線上に於ける「自我崇拝閣下」であつたのだと、君が若しボオドレヱルを好きなら考へなければなるまい。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本武尊が古事記中に叫ばれた歌は、明かに一呼吸中に歌はれたものであつて、一呼吸中のものとしては実に絶品であるが、デヴヱロッピングではない。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、余り善良なものは却つて悪人であるかの如く怯えるものだといふシヱクスピヤの言事は高橋に当｜箝るだらう。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで堀口君の訳した詩は、ヱルレーヌでも、シモンズでも、コクトオでも、すべてみな堀口君自身の詩であつて、どれを読んでも、一つの同じ堀口的スタイル、一つの同じ堀口的抒情詩の変化に過ぎない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで堀口君の訳詩を通して、ヱルレーヌを愛読し、ヱルレーヌに私淑してゐるといふ一青年が、かつて私に自作の詩を示して言つた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヱルレーヌの影響があると思ふのですが……」その詩を読み終つた後で私が答へた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヱルレーヌの影響なんか一つもない。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　かつて日本の詩壇に、象徴派の詩人ヱルハーレンの流行した時代があつた。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時或る若い新進の詩人が、ヱルハーレンの影響を受けてると言ふので評判された。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして当時川路君は、ヱルハーレンの詩を盛んに訳してゐたのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春宵一刻、――」などと、つまらぬ事を呟きながら木の虚から這ひ出ると、オヤ　ナンデセウ　サワグコヱミレバ　フシギダ　ユメデシヨカ　といふ事になるのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず仮名を附ける場合にも「エ」という仮名を附けるのであって、ワ行の「ヱ」ではないのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはちょうど契沖阿闍梨が古書における仮名の用法を調査して、昔はア行の「イ」「エ」「オ」と、ワ行の「ヰ」「ヱ」「ヲ」と区別があったということを明らかにしたのと全く同じ手続であります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから平安朝の半過ぎからまた「いろは」の中で「イ」と「ヰ」が同音になり、「エ」と「ヱ」と、「オ」と「ヲ」とも同音になって、四十四だけの音が区別せられるということになります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワ行は、「ヰ」（wi）「ヱ」（we）「ヲ」（wo）の三つだけが今よりも多いのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この音が平安朝において語の中および終において「ワヰウヱヲ」の音に変ったのですが、ワ行の音はｗで初まる音で、ｗは唇を合せて発する音ですが、唇音の「ファフィ」などの音も、やはり唇を合せて発する音で、ハ行音がワ行音にかわったのは、唇の合せ方が緩くなったのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故ですか僕が居ては不都合ですかヱ居てもわるひことはあるまい。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴嬢は何をおつしやいます今まで彼れ程お待遊ばしたのに又そんなことをヱお心持がおわるひのならお薬をめしあがれ阿母さまですか阿母さまはうしろに。",
              "citation": {
                "source": "闇桜",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の室生は勿論、全體に於て昔の金澤時代の彼とは變つて居るが、とにかく彼の容貌には、どこかヱルレエヌやベトーベンに見るやうな、藝術的の「深みある美しさ」があることを、近來になつてしみじみと感じてゐる。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホイツトマンでも、ヱルレエヌでも、詩人の性格にはどこか皆純樸な子供らしさや、ナイーヴな野蠻めいた所や、エゴの強いお坊つちやんらしい所のある者だが、とりわけ室生にはさうした方面の傾向が烈しいやうだ。",
              "citation": {
                "source": "室生犀星の印象",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはヱルダー先生に Fisher Women の譜を借して貰つて稽古した。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "レモンヱロウの繪具をチユーブから搾り出して固めたやうなあの單純な色も、それからあの丈の詰つた紡錘形の恰好も。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヱホバ、アブラハムを試みんとて、　アブラハムよ、　と呼びたまふ。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヱホバ言ひたまひけるは、　汝の愛する独子、すなはちイサクを携へ行き、かしこの山の頂きに於て、イサクを燔祭として献ぐべし。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、ヱホバの使者、天より彼を呼びて、　アブラハムよ、　アブラハムよ、　と言へり。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は、私とその夜はじめてカフヱで落ち合つたばかりの、犬の毛皮の胴着をつけた若い百姓であつた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
