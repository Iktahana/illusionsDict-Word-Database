        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "途中、麦が一寸ほど伸びている麦畑の傍にさしかかり、突然、ぐしゃっと涙が鼻にからまって来て、それから声を放って泣いた。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく気がるに、またも二、三円を乱費して、ふと姉を思い、荒っぽい嗚咽が、ぐしゃっと鼻にからんで来て、三十前後の新内流しをつかまえ、かれにお酒をすすめたが、かれ、客の若さに油断して、ウイスキイがいいとぜいたく言った。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには先刻取落した鰈が、ぐしゃっと潰れたようなみじめな顔付で、蟹江をしずかに見上げているのでした。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしドリルが……、あれっ」　ドリルが不意に前のめりになり、パイプがぐしゃっとなった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐしゃっと、顔がぬかるみへ埋まったとき、彼は屈辱と怒りのために嚇となった。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐしゃっと、濡れ雑巾のようなものが、その顔へ貼りついた。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏の方から飛んで来た青い柿の実が一つ、ぐしゃっと、彼の顔に当ったのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すかさず相手が背中に飛びつき、強力な大ハサミで頭をぐしゃっと砕くと、敵は砂にドンと倒れ、完全に動かなくなり、どうやら死んだようで、一方の勝者はさっと自分の隠れ場へ引き、無傷のようだ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然の恐怖によって、神経と心臓が、褐色包装紙のようにぐしゃっとなった。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "するうちに、ぐしゃっとした物に触った。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
