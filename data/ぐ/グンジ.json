  {
    "uuid": "c0ccfbd6-281f-5206-ba7b-5a706e36ee04",
    "entry": "軍持",
    "reading": {
      "primary": "ぐんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "water bottle (of a monk, nun, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "拾った金なら届けるわい」「じゃ、掏った金なら持ってるの……」「そや」「本当に掏ったの……」「当りきシャリキ、もちろん……おまけに、掏ったのが紙一枚、それが二千円とはごついやろう」「また担ぐんじゃない……」「まア、聴け……」　そして亀吉の喋ったのは、こうだった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "善光寺辰の野郎め、どうやら陽気に当てられやがって、気がふれたようですぜ」「なにッ※　まさか、かつぐんじゃあるめえな」「こんなことでかついで、なんの得になりますか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "京人形大尽",
                "note": "青空文庫"
              }
            },
            {
              "text": "（退場する）おきん　この大根と粟とで、春まで命をつなぐんじゃ。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これ、次郎、そう騒ぐんじゃ無いッて言うに。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何も御幣を担ぐんじゃありませんがね。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろしく担ぐじゃねえか」「担ぐんじゃねえよ。",
              "citation": {
                "source": "難船小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり騒ぐんじゃねえよ。",
              "citation": {
                "source": "男ぎらい",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼吸ができなければ死んでしまう」「じゃあ、ぼくは空気帽をぬぐんじゃなかった。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そちの教訓によって悟ることができた」「これはアレかしら」「そうだ」「かつぐんじゃないでしょうね」「ほれ、ごらんの通りだ」　朝之助は前をまくって松ヤニをつめた傷口を示した。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いそぐんじゃない。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "階下に残った与助は、すぐ二、三の男衆を呼び集めて、「今ちょっと二階で騒ぎが持ち上がるかもしれねえ、お前たちに関係のあることじゃあねえから、があがあ音を上げて騒ぐんじゃあねえぞ。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さん、お前さんまた担ぐんじゃあないだろうねえ」「ばかッ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「またいつもの伝で担ぐんじゃねえか。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "怪談抜地獄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ奥の方から足音がして、主人がこっちへ出て来たらしかったが、次の間へ入るや否や、「さあ、御前達はここで騒ぐんじゃない。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ねえ、仙波さん、あなた、かつぐんじゃありますまいね。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "かごやの客",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ドウナルド、そんなに噪ぐんじゃアありませんよ。",
              "citation": {
                "source": "小公女",
                "author": "A LITTLE PRINCESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「伯父さんが――殺されたのよ」「えッ、あの人が、――かつぐんじゃないだろうな。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえには関係のないことだ」とその若侍は云った、「なにもなかったつもりで煮物を続けろ、いいか、騒ぐんじゃないぞ」　おすえは口をあけ、なにか云おうとしたが、言葉にはならなかった。",
              "citation": {
                "source": "失蝶記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も急ぐんじゃない。",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえさん、ぼくをかつぐんじゃないだろうね。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さわぐんじゃない。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、よし、そう、さわぐんじゃない。",
              "citation": {
                "source": "魔法博士",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
