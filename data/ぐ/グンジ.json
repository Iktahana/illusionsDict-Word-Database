  {
    "uuid": "69bf1d7c-fb42-506a-8d40-204dc78d3163",
    "entry": "郡司",
    "reading": {
      "primary": "ぐんじ",
      "alternatives": [
        "こおりのつかさ"
      ],
      "is_heteronym": true
    },
    "grammar": {
