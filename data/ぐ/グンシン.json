[
  {
    "uuid": "4784e83b-722d-5b25-9420-2d9dbcdeca38",
    "entry": "軍神",
    "reading": {
      "primary": "ぐんしん",
      "alternatives": [
        "いくさがみ",
        "ぐんじん"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "god of war",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからヴィナスに訴えて、どうかその愛人たる軍神マルスが、自分のこの詩を書く邪魔をしないように心配してくれと頼んでいる。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ああ偉いなる敗将、軍神の選びに入れる露西亜の孤英雄、無情の風はまことに君が身にまこと無情の翼をひろげき、と。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "桑山修理亮の足軽共が、馬の足を冷そうと、湖の磯に出て居るのを見付けた盛政は、馬上から、討取って軍神の血祭にせよと命じたので、忽ち数名が斬られた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "本朝にも住吉は軍神たり、世に事あればそこに飼う神馬見えず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してわが邦に行わるる大黒と鼠を合せた崇拝も、実はこの毘沙門から移ったもの多く、初め厨神だったものが軍神として武士に祈らるるに及んだは、その親元たる毘沙門が富の神たると同時に軍神たるに基づく。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "この緑雨の死亡自家広告と旅順の軍神｜広瀬中佐の海軍葬広告と相隣りしていたというはその後聞いた咄であるが、これこそ真に何たる偶然の皮肉であろう。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにどんな瓦斯が出るか、どんな飛んでもない変化が起るか、それを調べあげて一つの確針をつかむのに、資本家は「モルモット」より安く買える「労働者」を、乃木軍神がやったと同じ方法で、入り代り、立ち代り雑作なく使い捨てた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう悪趣味の物語作者は、軍神広瀬中佐などをも、やがては幽霊に化かすだろう。",
              "citation": {
                "source": "妖異むだ言",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事の外見は大きくないが、大王こそ持久戦争指導の最大名手であり、七年戦争は正しく軍神の神技と云うべきである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオン当時の人々は中々この真相を衝き難く、ナポレオンを軍神視する事となり、彼が白馬に乗って戦場に現われると敵味方不思議の力に打たれたのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後の大観　ナポレオンの天才的頭脳が新戦略を生み出し、その新戦略に依ってナポレオンはたちまち軍神として全欧州を震駭した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍神西住大尉の記事、私は胸をうたれた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには軍神広瀬中佐の例が出て来た。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "広瀬中佐は日露戦争のときに、閉塞隊に加はつて斃れたため、当時の人から偶像視されて、とう／＼軍神と迄崇められた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、四五年後の今日に至つて見ると、もう軍神広瀬中佐の名を口にするものも殆んどなくなつて仕舞つた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔トラファルガルの海戦でスペイン、フランスの連合艦隊を一挙にしてほとんど全滅させ、自分もその場で戦いに倒れた英国海軍の軍神ネルソン卿の銅像が、灰色の空に突き立って下界を見おろしているのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "チチコフが社会的にどれだけ大きな勢力を持っていようと、たとえ彼が百万長者で、いかに堂々として軍神マルスを思わせるような頼もしい顔附をしていようとも、世には相手の何人たるを問わず、婦人がたの断じて許容しない事柄があって、それにぶつかったら、まったく万事休すである！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊８　ガロパード　非常にステップの急調子舞踏の一種＊９　マルスの神　ローマ神話に於ける軍神。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "市村座で菊五郎、吉右衛門の青年俳優の一座を向うへ廻して、松居松葉氏訳の「軍神」の一幕を出した、もう引退まえの女優生活晩年の活動時機であった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍神マーズの血なまぐさい姿をさえも理想化した。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人公のヘルギがルキューレは、軍神オージン Odhin の侍女たちで、常に戰場の空をかけめぐつて戰死者があると、その傷を見て勇怯をたしかめ、勇者ならばオージンの住むルキューレは全然スカンヂナヴィアのもので、それと、ヘルギとの戀愛的關係を持たせたところに、固有の面白さがあります。",
              "citation": {
                "source": "スカンヂナヴィア文學概觀",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広瀬中佐は日露戦争のときに、閉塞隊に加わって斃れたため、当時の人から偶像視されて、とうとう軍神とまで崇められた。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、四五年後の今日に至って見ると、もう軍神広瀬中佐の名を口にするものも殆んどなくなってしまった。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども同時に火星は軍神（ローマのマルス）でもあり、勝利者を意味するということに故事つけて、カヒラは以後「勝利の町」として理解されるようになった。",
              "citation": {
                "source": "七重文化の都市",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千葉県香取郡香取町に鎮座する官幣大社香取神宮（祭神｜経津主命即ち伊波比主命）と共に、軍神として古代から崇敬至ったものであった。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "英雄も軍神もありはせぬ。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十七日◯昨夜から、軍神杉本五郎中佐の遺稿「大義」を読みつつあり、段々と心にしみわたる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉本中佐遺稿の「大義」山岡荘八君著「軍神杉本中佐」江部鴨村著「維摩経新釈」、「名作文庫」、「芭蕉の俳句評註」。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
