        "examples": {
          "standard": [
            {
              "text": "新作映画の予告編で、伝説の怪獣の姿をほんの数秒だけグリンプスすることができた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "都会の喧騒の中に、かつての美しい自然のグリンプスを見いだし、彼は思わず足を止めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今の、見た？」一瞬のグリンプスだったが、彼女の瞳には確かな決意が宿っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ところが、これが、だいたい私の想像する、名探偵シャーロック・ホームズのグリンプス〔一見、一瞥〕である。",
              "citation": {
                "source": "ホオムズの探偵法",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「或る女のグリンプス」という題で『白樺』に二年にわたって発表されたらしい。",
              "citation": {
                "source": "「或る女」についてのノート",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては小さな行為のグリンプスである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今そういう永遠のグリンプスを得ようとならば、瞬間を見るが好い、瞬間は永遠に這入る閭門である、とそう人々は云うのである。",
              "citation": {
                "source": "現代哲学講話",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
