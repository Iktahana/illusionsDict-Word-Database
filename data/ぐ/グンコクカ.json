        "examples": {
          "standard": [
            {
              "text": "隣国の軍国化が進む現状に対して、国際社会からは強い懸念の声が上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "教育現場への政治介入が、国の軍国化を加速させる要因になると批判された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての歴史を振り返り、二度と軍国化の道を歩んではならないと誓った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "続いて小国の独立、ボルシェヴィキの軍国化、ファシストの擡頭、各国社会党の過渡的消沈、など目まぐるしいばかりに推移って行く欧州の劇的な変化を目撃した後、Ｆはフランスに入って、パリに暫く足を停める事になった。",
              "citation": {
                "source": "二人のセルヴィヤ人",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
