        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天井を縦断している二条のレールをワイヤー・プレーをギリ／＼と吊したグレーンが、皆の働いている頭のすぐ上を物凄い音を立てゝ渡って行った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ボール盤の側に、四五人の職工とパンパン帽をかぶった職長が集って、ワイヤー・プレーを跛に吊したグレーンがガラ／＼と寄ってくるのを見ていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーンがとまると、ワイヤー・プレーは余勢でゆるく揺れた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーンが喧しい音をたてゝ、チエンを捲き上げた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が見たって、秘術を見破る眼力は全然ないのであるが、それに私が最も見たいのは養殖の秘術じゃなくて、御木本家に蔵するところの百七十グレーンという日本一の真珠なのだ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "御木本の百七十グレーンという真珠は白蝶貝やアコヤ貝じゃなくてアワビの中から現れたというから日本的である。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "安吾・伊勢神宮にゆく",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に三百グレーンの世界に無二の黒色大真珠であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に五百三十グレーン。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "三〇〇グレーンの黒真珠も、五三〇グレーンの白銀の真珠も、失われてしまったのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブゾーニの弟子にも、ペトリのような精微な技巧家と、グレーンジャーのような、少し荒っぽい主情的な演奏家とあるのは面白い。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペトリはブゾーニの形を伝え、グレーンジャーはその心を伝えたのかも知れない。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーンジャー　Percy Grainger　一八八二年オーストラリアに生れ、ドイツに学び、ブゾーニとグリークの感化を受けて、アメリカに定住した作曲者だ。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "国産真珠というのは、「志摩の女王」と名づけられた、その道の人は誰でも知っている、日本随一の大真珠で、産地は志摩国｜大王崎の沖合、鮑貝中から発見された珍らしい天然真珠、形は見事な茄子形、三百何十グレーンの逸品である。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが目的で、ロングレーンの小さな鉱山事務所をボナンと登録して、そこでは自分をジェームズ・ジョーンズと称しているんだ。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "取り調べを受けて、ジェームズ・ジョーンズは二度とロングレーンに戻れない」　　　　　＊　アシャトン・スミスは帰宅して、夕食を取り、酒を飲んだが、その晩は寝付けなかった。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            },
            {
              "text": "このボナンはジェームズ・ジョーンズなる人物であり、事務所がロングレーンにあることが判明しました。",
              "citation": {
                "source": "バブル崩壊",
                "author": "A BUBBLE BURST",
                "note": "青空文庫"
              }
            }
          ]
        }
