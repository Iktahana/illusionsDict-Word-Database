          "standard": [
            {
              "text": "ファッション誌の写真は、色の再現性が高いグラビア印刷で行われることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "グラビア印刷特有の重厚な質感が、広告の高級感を演出している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大量印刷に適したグラビア印刷は、パッケージのデザインなどにも広く使われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "なぜ私が五シリングで花絵を買わねばならないですか、ワッツのグラビア印刷画が半値で売れるのに。",
              "citation": {
                "source": "煉獄",
