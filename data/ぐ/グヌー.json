        "examples": {
          "standard": [
            {
              "text": "GNUプロジェクトはフリーソフトウェアの推進を目的としている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くのLinuxディストリビューションはGNUツールを使用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "GNUという名前は「GNU's Not Unix!」の再帰的頭字語である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "みんなで七人、「先生」とガスパールおじさんに、三人の坑夫のパージュ、コンプルー、ベルグヌー、それからカロリーという車おしのこぞう、それにわたしであった。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、おまえの言いたいことを言えよ」とベルグヌーがさけんだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはおれの寝台の下にはいっている……おお……」「あいつを水の中にほうりこめ」とパージュとベルグヌーがさけんだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "水の中にほうりこめ」とパージュとベルグヌーが、「先生」　の後ろに丸くなっていた罪人にとびかかって行きそうにした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはくい改める」　やがてパージュとベルグヌーがさけびだした。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生」と、ガスパールおじさんだけはわたしを食べようとは思えなかったが、パージュとカロリーと、ベルグヌーは、とりわけベルグヌーは長ぐつの皮を食い切るあの大きな白い歯で、ずいぶんそんなことをしかねないと思った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとパージュとベルグヌーが、とんきょうな様子でかれとおしゃべりを始めた。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ベルグヌーは、いよいよ死ぬなら、そのまえにわれわれは書置きを残して行こうと言った。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルグヌーがみんなのために代筆した。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
