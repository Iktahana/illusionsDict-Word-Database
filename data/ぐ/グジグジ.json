        "examples": {
          "standard": [
            {
              "text": "彼は不満をぐじぐじとつぶやいているだけで、具体的な行動を起こさない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "なんでそんなにぐじぐじ言ってるんだい？もっとはっきり話してよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "部長はいつもぐじぐじと文句ばかり言っているから、誰もまともに聞かない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だから多賀ちゃんにしろ、ぐじぐじした生活態度にすぐなって。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
