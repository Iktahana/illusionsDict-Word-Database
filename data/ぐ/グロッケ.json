        "examples": {
          "standard": [
            {
              "text": "実験室では、グロッケの中に植物を入れて観察していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "グロッケを使って真空状態を作り出す実験を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "精密な機械を保護するため、グロッケで覆った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "アクースティック・ギターと、グロッケンシュピールのイントロが流れる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘には山羊を野飼いにして、ツィーゲングロッケのからからと鳴るのが、澄み切った空に高く響く。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいくたびとなく、シュピーツベルクの上に立った、刈草の香のこもる牧には、まばらに白く、キュムメルが咲きのこって、森かげに、からころと、ツィーゲングロッケの響くのも、もの寂しい。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            }
          ]
        }
