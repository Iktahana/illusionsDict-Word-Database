        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "河向ひから池までの熊笹を切開いた路はぐしよ／＼に水浸しになつて歩きにくかつた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河向いから池までの熊笹を切開いた路はぐしょぐしょに水浸しになって歩きにくかった。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「水無瀬女よ、めぐし姪姫よ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでに心身の緊張をほぐし、徐ろに食欲に呼びかける時間なのだ。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶然のように顔を見合して、ただ一通りの好感を寄せる程度で、微笑して呉れるときはともよは父母とは違って、自分をほぐして呉れるなにか暖味のある刺戟のような感じをこの年とった客からうけた。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐしゃッと人間の肉体が××××音が薪の崩れ落ちる音にまじった。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小路の奥の、石塀の中の一ツの家では、すゞが、安物の手ミシンにむかって、ドレスを縫ったり、ほぐしたり、また縫ったりやっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "張子の人形を立っているまゝ頭からぐしゃりと縦に踏みつけたようなのや、××も、ふくよかな肉体も全く潰されて、たゞもつれた髪でそれと分る女が現れてきた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "外ではすぐしずまった。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）嘉吉は用があったからこっちへ廻れといった風で口をもぐもぐしながら云った。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この友一人がそれを見はぐしていたからです。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、小鼻の両傍から頤へかけて、口のまはりを、ぐしやりと輪取つて、瘡だか、火傷だか、赤爛れにべつたりと爛れて居た。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東枕の白い切に、ほぐしたお髪の真黒なのが濡れたやうにこぼれて居て、向ふの西向の壁に、衣桁が立てゝあります。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人もし試に仲秋船を泛めてこのあたりに月を賞しなば、必ずや河も平生の河にあらず月も平生の月にあらざるを覚えて、今までかゝる好風景の地を知らで過ぐしゝを憾むるならん。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧の中を降って来たそうで、みんなぐしょぐしょにぬれていた。",
              "citation": {
                "source": "小爆発二件",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、人の三倍も四倍も復讐心の強い男なのであるから、また、そうなると人の五倍も六倍も残忍性を発揮してしまう男なのであるから、たちどころにその犬の頭蓋骨を、めちゃめちゃに粉砕し、眼玉をくり抜き、ぐしゃぐしゃに噛んで、べっと吐き捨て、それでも足りずに近所近辺の飼い犬ことごとく毒殺してしまうであろう。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめの數頁でぐるぐる渦を卷いた雰圍氣をつくつて置いて、それを少しづつのどかに解きほぐして行きたいと祈つてゐたのであつた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森へ入りますと、すぐしめったつめたい風と朽葉の匂とが、すっとみんなを襲いました。",
              "citation": {
                "source": "狼森と笊森、盗森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃ、じゃ、噛じらえだが、痛ぐしたが。",
              "citation": {
                "source": "鹿踊りのはじまり",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　仔牛は云はれた通りまづ前肢を折って生え出したばかりの角を大事にくぐしそれから後肢をちゞめて首尾よく柵を抜けました。",
              "citation": {
                "source": "黒ぶだう",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はげしい風と雨にぐしょぬれになりながら二人はやっと学校へ来ました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」セロ弾きはおっかさんの野ねずみをセロの孔からくぐしてやろうとしましたが顔が半分しかはいりませんでした。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて治子は都に近きその故郷に送り返され、青年は自ら望みて伯父なる人の別荘に独居し、悲しき苦しき一年を過ぐしたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがぼくの手にさわったらぐしょぐしょにぬれているのが知れた。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
