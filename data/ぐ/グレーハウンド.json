        "examples": {
          "standard": [
            {
              "text": "グレーハウンドは全犬種の中で最も足が速く、時速70キロ近くで走ることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ドッグレースの会場で、流線型の体型をしたグレーハウンドたちが猛スピードで駆け抜けていった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "アメリカを縦断する長距離バスの「グレーハウンド」に揺られながら、車窓の景色を眺めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "要するに競犬をやるのはよろしいが、犬種向上改良などと美名をつけずに、グレーハウンドを海外から買いもとめて、本来バクチ的公衆娯楽として競犬をやりなさい。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その五　衆生開眼",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち犬をセッター、ポインター、テリヤー、グレーハウンド等に分けて、これらの名称を用いればまたセッターをすべて同じ物、ポインターをすべて同じ物と思う傾きが生ずるゆえ、事実を模型化するという点は前にひとしい。",
              "citation": {
                "source": "我らの哲学",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な競馬ウマの骨格や高位の人が飼っていたグレーハウンドの骨格もある。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
