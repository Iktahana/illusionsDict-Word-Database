    "definitions": [
      {
        "index": 1,
        "gloss": "having fun in groups",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただの神女群遊には、七処女を言い、遊舞には八処女を多く用いる。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯の神女群遊には、七処女を言ひ、遊舞には八処女を多く用ゐる。",
              "citation": {
                "source": "水の女",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "都人士女堵ヲ傾ケ袂ヲ連ネ黄塵一簇雲集群遊ス。",
              "citation": {
                "source": "上野",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に＊跛行の神工の盾のおもてに鑄るところ、一の美麗の谷の中、白き羊の群遊ぶ廣き牧場、更に又＊小屋と羊舍と園庭と。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "太古、この松林には夥しい鹿が、野生群遊していたという。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大和の奈良の春日山の神鹿の祖、ここに数千の野生の、しかも柔順な、その頭には雄健なる角をいただいて、その衣裳にはなだらかな模様を有し、その眼には豊富なるうるみを持った神苑動物の野生的群遊を、その豪宕な海と、閑雅なる松林の間に想像してみると、これも、すばらしい画題だ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
