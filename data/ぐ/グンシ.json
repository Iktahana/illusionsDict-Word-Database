  },
  {
    "uuid": "cfb5dabe-8f4d-5dd7-884d-ef2173aca6f3",
    "entry": "軍資",
    "reading": {
      "primary": "ぐんし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "war materiel",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "燕兵追いて真定城下に至り、驍将、陳※等を擒にし、斬首六万余級、尽く軍資器械を得たり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍資器械、倶に※燼となり、河水｜尽く熱きに至る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍資金は、たっぷりです。",
              "citation": {
                "source": "花火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴の手に渡ると十二万円が赤の地下運動の軍資金になっちまうぜ」「ウン。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に俺の軍資金調達が不可能になって、この話はオジャンになった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンヌンチオも日本だったら義兵を募る事も軍資を作る事も決して出来なかったろう。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたをあけてみると、さすがは切支丹伴天連の一味だけあって、実にその犯行は巧みな計画にもとづき、あくまでも宗門｜一揆の再挙を計るために、まずかれらは軍資金の調達に勤めました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "三百両紛失事件は、これももちろん軍資金調達の一方法で、一味があげられたと同時に例の駒の持ち主はまもなく判明いたしましたが、右門のにらんだごとく三段の免許持ちで、天草から江戸へ潜入以来、賭け将棋専門で五十両百両といったような大金を軍資金としてかせぎためていた伴天連の催眠術者でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "南蛮幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、城中の軍資を入れてある庫のなかから銀数百両と銭数千｜緡が紛失したことが発見されて、その賊の詮議が厳重になった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、軍資と祝福を分け合ったのち、私達はその人混みのルウレット室で銘々の信ずる道に進むことにした、五時間後に出口で落ちあう約束。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで彼女は要求するだけのコカインを楽しみ、「２３」はまた毎晩の「二十三」の軍資にこと欠かないわけでしょう。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍資を募るには手段がある。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "目星を付けていた人物やフェアーで知り会った関係者を訪ね、用意した軍資金を使い切って豪勢な旅を終えた西は、五月に日本に戻った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "寮生活で軍資金を蓄えては休日を使って浮川が上京する日々を経て、入社二年目には結婚にこぎ着けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　私がやつと湿つぽい蒲団から首を出すと、「高等乞食」は、その顴骨が突出た顔を私とおみくじ屋とへかはるがはる向けて、「――どうだね、けふは、我輩が二人に飯をおごらう、幸ひ、軍資金はたつぷりあるから、安心してついて来給へ」　彼はきのふ、女房と姉に、新年の小遣をも加へた今月の送金を終つたのだ。",
              "citation": {
                "source": "大凶の籤",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その計画の第一は、先ず、目下満洲に勢力を張っております張作霖に軍資金と、十数台の優秀なる飛行機を貸し与え、従来の親日傾向を放棄させて日本を圧迫させる一方に、一時平静に帰しております支那の内治を再び攪乱し、その虚に乗じて、支那各地の利権と、金融機関の中心を掌握するにありました。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に船舶や軍資に不足勝なる宋軍は、泉州に於て蒲壽庚所屬の船舶資産を強請的に徴發した故、蒲壽庚は大いに怒つて、その年の十二月に斷然元に降り、宋に對して敵對行動をとることとなつた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "杭州は蒋政権軍資の源泉の一つでもあったし、また抗日意識の最も旺盛な土地の一つでもあったし、最近まで軍事上の前線的地域に位置してもいた。",
              "citation": {
                "source": "中支生活者",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば相国寺に交渉して立所に薩兵三千人の陣所をしつらひたる、伏見鳥羽の戦ひ初まれる中に、一夜にして参万金の軍資を調達したるたぐひ、一一に挙ぐべくもあらず。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "方今の形勢にて最も急要なるものは軍資なり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また行先ごとに国情を探りて報告し、兼ねて軍資の献納を勧誘すべしと。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち各地に於て日夜前条の御趣旨を演説し、また諸藩の重臣と会して朝旨を誤解せざると共に王事に奮励すべきことを勧めしが、加賀国大聖寺に到る間に於て、寺院及び民家より軍資を献納したるもの参万金に達せり。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、三万円の軍資金を使って大穴狙いを専門にすると、この三日間の競輪に於ては、元はとれたが、モウケもなかったワケだ。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "三万円の軍資金を使えば、大穴のでる限りは、必ず大穴が当る。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ軍資金が乏しくなったので、中穴狙いに転向したら、トタンに二万何千円かの大穴がでて、バカをみた。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、私が先ほども述べた通り、八百長レースが多いほど穴狙いの確率は多くなるのであって、素人でも、軍資金を豊富に持って、穴を狙えば、もうかる確率が多くなる。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方、天狗党では、幹部として相応名の聞こえた田中｜源蔵が軍用金調達を名として付近を掠奪し、民心を失ったことにもよると言わるるが、軍資の供給をさえ惜しまなかったという長州方の京都における敗北が水戸の尊攘派にとっての深い打撃であったことは争われない。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "三、飯田町にて軍資金三千両を醵出すること。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、とつぜん、つり糸が水底ふかくぐんぐんしずんでいきました。",
              "citation": {
                "source": "漁師とそのおかみさんの話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はぺったり尻を落としたが、またはね上がり、車を引き出そうと最後の力をふるいながら、ぐんぐんしゃくるように四方へはねた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
