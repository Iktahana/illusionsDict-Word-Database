[
  {
    "uuid": "8f73e3a5-83c4-5e72-840c-9d2fa9926852",
    "entry": "具合が悪い",
    "reading": {
      "primary": "ぐあいがわるい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
