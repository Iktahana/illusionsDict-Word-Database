    "definitions": [
      {
        "index": 1,
        "gloss": "lively group (esp. of young people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ここまで書いた時に私はふとあの有名な西郷の銅像や広瀬中佐の群像を想い出した。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井氏の「二科同人群像」には単なる似顔の集成でなく、各メンバーの排置のみならずそのポーズや服装によって各自の個性を表現しようという苦心の痕が覗われる。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、このような同人群像を試みるとしてはおそらく最も適任な石井氏が更に研究を重ねてこの絵の完成に勉められることを希望する。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒアガルの絵のように一幅の画面に一見ほとんど雑然といろいろなものを気違いの夢の中の群像とでもいったように並べたのがある。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、其の一名、弘法の湯の露呈なことは、白膏の群像とまでは行かないが、順禮、道者、村の娘、嬰兒を抱いた乳も浮く……在の女房も入交りで、下積の西洋畫を川で洗濯する風情がある。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはラオコーンの群像を照らしました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、わたしの光はナイルの群像のところに、あの巨大な神のところに、いちばん長くとどまっていました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてすぐさまわたしは、ナイルの群像やあらゆる大理石の神々のあるバチカン宮のことを思い浮べました。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の才能の不足もさることながら、虚構の群像が描き出すロマンを人間の可能性の場としようという近代小説への手の努力も、兎や虫を観察する眼にくらべれば、ついに空しい努力だと思わねばならなかったところに、日本の芸術観の狭さがあり、近代の否定があった。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚、覊旅以外の人事生活篇「童子群像」「風騒四部唱」等は彼の集の「砧村雑唱」の続篇たるべきもの故是に附加した。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "野崎の原頭、四条畷には群像の如き三十余騎の姿が、敵軍に遠く囲まれながら茫然として立ちすくんで居る。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "○川崎栄一氏――大作であつたが、肝心の距離感が喪失してゐた、テーマの上では難はなく、意志と恐怖と哀愁とは現代の三つのテーマとも言へるものであるが、川崎氏の群像はその時代的な象徴を語るものであつた。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "群像としての像のつながり関係も自然なまとめ方である。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の男は、丘の中腹に段々となつてゐるスタンドで横隊に肩を組んで並んだまゝ、群像のやうになつて凝つと娘達の遊戯を視詰めてゐた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ美しい群像である。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、忽然滝壺の中へ、群像が現われた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ああ行方さえわからない」　ユラユラと群像が動き出した。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と群像がちぢまった。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦橋に立つ艦長以下の群像は、濃いかげに区切られて、くっきりと照らしだされた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "和服に長袴をつけた少女が八、九人、正面の高い壇を中心にして、或る者は右手を高くあげ、或る者は胸に腕をくんで、群像のように立っていた――が、一せいに、扉のあいた入口の方へふりかえった。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際的には石や石膏をいじるより、例えば「文化と休みの公園」の広場に飾られてるような大骨板張の大労働者像、一九三〇年のメーデーに赤い広場に飾られた大群像、または示威運動の張りものみたいな非写実的な、応用美術の方が手に入ってる。",
              "citation": {
                "source": "プロレタリア美術展を観る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "群像の浮彫に、深い明暗があるとおり、立体的に把えられるべきものだが、「わが胸の底のここには」は、いわば鋳ものの裏の方からそのへこみばかりを辿って人間性のもり上りを見てゆこうとしているような作品に思えます。",
              "citation": {
                "source": "一九四六年の文壇",
                "author": "――新日本文学会における一般報告――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『群像』十二月号の創作月評座談会で、林房雄が、深刻ぶり、ということについて語っている気分、ポーズに、はっきりあらわれている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "林房雄は、『群像』十二月の座談会で宇野浩二の「文学者御前会議」にふれている。",
              "citation": {
                "source": "五〇年代の文学とそこにある問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "福田恆存にとっては、中国の人民が革命に勝利したこともどこまでがほんとかわからないこと（群像十二号）であったし、日本の国内で、日本の学者たち二十七名が非日委員会に反対の声明を行い、ひきつづき広汎な層をふくむ学者、有識人の全国的な「平和を守る会」を組織した画期的な事実も無視されている。",
              "citation": {
                "source": "五月のことば",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨年十二月号『群像』の月評座談会で、林房雄は、宇野浩二の書いた「文学者御前会議」（文学者が天皇に会ったときの記録）にふれ、宇野という作家の私小説的作家性をやっつけた。",
              "citation": {
                "source": "現代文学の広場",
                "author": "――創作方法のこと・そのほか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけのことでしょう」（群像十一月号「創作合評会」中村光夫）と総括して、その上での批評が果して現代文学の貧困を救う何事かであり得るだろうか。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "有名な昔の首切台の中には、雲つくような労働者の群像が飾られている。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強烈なアーク燈に照らされ、群像の上にひるがえる幾流もの赤旗は夜に燃える火のようだ。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーデーに赤い広場の歴史的首切り台に飾られた労働者の大群像は祭の後にモスクワ河の河岸にある「文化と休養の公園」の丘の上へ移された。",
              "citation": {
                "source": "インターナショナルとともに",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
