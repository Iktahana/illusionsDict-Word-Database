        "examples": {
          "standard": [
            {
              "text": "夕焼けの空がオレンジから紫へと変わる見事なグラデーションに見惚れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "プレゼン資料の図解にグラデーションを使い、情報の流れを可視化した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "自然界には、言葉では区切りきれない無限の色のグラデーションが存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "けれども、大部分は同じ色合いではなく、緑色のグラデーションで彩られている。",
              "citation": {
                "source": "石仏",
                "author": "THE STONE BUDDHA",
                "note": "青空文庫"
              }
            }
          ]
        }
