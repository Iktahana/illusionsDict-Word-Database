        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その夜のメインディッシュはグラタンだった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、グラタンは好きだが、冷えかかったグラタンは好きじゃないな、と考えた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スプーンから、盛りすぎたグラタンが崩れて落ちた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ハーレー・グラタン氏の調査）日本の軍部は、太平洋戦争で百八十五万人を死なせた。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第八巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お昼は昨夜のチキンの残りをきざんで、マカロニのグラタンにしておくれ。",
              "citation": {
                "source": "落葉日記",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "此んな所で、ニヨキのグラタンがあったのには驚いた。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、舌平目グラタン、スコットライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時迄かゝり、それからリッツで食事、フィレソールのグラタンとチキン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜食、新大阪のグリルより、マカロニ・グラタンをとりうんと食った。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オニオン・グラタンが先づ及第。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリルで朝食、ポタージュにフライと玉子のグラタン、それにオレンヂ・ジュースをふんだんに飲んだ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとオニオングラタンとビーフピカタ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリルで、オルドヴルとオニオングラタン、コールドラブスターを食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "逢はうと思ってた森岩雄も発熱して帰っちまったので、すっかりあぶれ、ホテルのニューグリルで一人で食事、オルドヴルに、オニオングラタン、雛のココット、こいつはうまかった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラタンとオルドヴルで満腹。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタージュはオニオングラタン。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "憂鬱になり、ホテルニューグリルで、オニオングラタンに、オルドヴル、コールビーフで食事し座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝塚ホテルへ食事しに行く、グラタン入のポタージュうまし、マカロニとハンバークステイキを食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとオニオングラタン、舌平目の洋酒煮に、クラブハウスサンドイッチ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴル、チキンスープ、平目のグラタン、クラブハウス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューグリルでオルドヴルとグラタンとソール洋酒煮とプディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラタンと何を食ったっけか（二十九日夜記、忘れた）夜の部も大満員、大いに熱演し、ハネ後銀座だったらう。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終ってプランタンのサンドウィッチと豆のグラタンをとって食べる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルドヴルとポタアジュ、サワラのグラタンにモカ・プディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューグリルで、ポタージュ、マカロニグラタン、コールビーフ、苺のタルト。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュ、野菜グラタン、ビフテキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "又南のタカザワへ行き、ポタージュ、魚のグラタンと肉。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "速水氏とその妹、川口・三益を招待し、おやぢ自慢の料理食はせる、コンソメに魚のグラタンとビフテキにカレーライス。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポタアジュの魚のグラタンとビフテキ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
