        "examples": {
          "standard": [
            {
              "text": "この地域には多くの軍事産業が集まっており、街の経済は防衛予算に大きく依存している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍事産業と政治の癒着、いわゆる「軍産複合体」の弊害がしばしば指摘される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新鋭の戦闘機の開発には、国内の軍事産業が総力を挙げて取り組んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "軍事産業も、縮小されるかあるいは平時のそれに転換されなければならなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニュー・ディールのあいだ、本来なら失業者になるはずの人たちは、軍事産業ですくわれていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事産業で高い賃金をとっていた労働者たちは、平時にきりかえられると、賃金がさがった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
