        "examples": {
          "standard": [
            {
              "text": "彼はいつも仕事量について文句を言っているが、解決策は決して提案しない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "雨について文句を言うのをやめて。どうせ出かけなければならないんだから。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "彼女は何週間も、隣人について文句を言っている。",
              "citation": {
