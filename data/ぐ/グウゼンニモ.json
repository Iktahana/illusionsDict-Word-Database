[
  {
    "uuid": "1e19485f-98af-5dad-a49a-6479a847e892",
    "entry": "偶然にも",
    "reading": {
      "primary": "ぐうぜんにも",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
