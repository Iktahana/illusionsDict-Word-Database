        "examples": {
          "standard": [
            {
              "text": "小麦アレルギーの人は、グルテンに含まれるグリアジンに反応することがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "グリアジンは、小麦タンパク質の一種で、パンの弾力性に寄与する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "セリアック病患者は、グリアジンを含む食品を避ける必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "オズボーンとメンデルは小麦から単離したグリアジンを使うとカセインに比べて成長が遅いことを、既に観察していた（図４）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｂ）小麦のグリアジン、他の食品成分は同一。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
