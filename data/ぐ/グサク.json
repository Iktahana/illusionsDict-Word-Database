[
  {
    "uuid": "f15b7037-3463-5f96-990b-83c566d2431b",
    "entry": "愚作",
    "reading": {
      "primary": "ぐさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
