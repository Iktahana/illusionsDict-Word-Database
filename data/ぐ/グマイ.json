    },
    "definitions": [
      {
        "index": 1,
        "gloss": "stupid",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "民衆は賢明なところもあるが愚昧なところもある。",
              "citation": {
                "source": "外来語所感",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら貴様が風景に愛情を与え、冬の蠅を活気づけても、俺を愚昧化することだけはできぬわい。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、この世の愚昧の民を愛する。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねがわくは先輩諸氏｜愚昧小生の如きをも清き諸氏の集会の中に諸氏の同朋として許したまえ。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに詩壇は自由詩の本体を日本に見ないで外国に見、彼の「韻律」や「韻文」等の語を輸入し、これを半可通の理解で使用した為、却って知っている事が解らなくなり、自分の顔を他人に教えてもらうような、愚昧な混乱に陥ったのだ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日おいでの折、男子の面目は在武術と説き、諸卿の素直なる御賛同を得たるも、教訓する者みずから率先して実行せざれば、あたら卓説も瓦礫に等しく意味無きものと相成るべく、老生もとより愚昧と雖も教えて責を負わざる無反省の教師にては無之、昨夕、老骨奮起一番して弓の道場を訪れ申候。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も、盲目の垣覗きよりもそッと近い、机覗きで、読んでおいでなさった、書物などの、お話も伺って、何をなさる方じゃと言う事も存じておりますが、経文に書いてあることさえ、愚昧に饒舌ると間違います。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ心配なのは、この休憩の幕間に相応しいあの愚昧とも渾沌とも名のつけようもない謎の心情と謎の表情とがわたくしに出来るでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして、愚昧な原住民の驚嘆を前に、到る處に小ピラミッドやドルメンや環状石籬を築き、瘴※な自然の中に己が強い意志と慾望との印を打建てたのであらう。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に、その鈍重・難解な言葉をよくよく噛分けている中には、我々にも、この男の愚昧さの必然性が――「何故に彼が常にかくも、他人の目からは愚かと見えるような行動に出ねばならないのか、」の心理的必然性がはっきりのみ込めて来るのではないだろうか。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、愚昧な原住民の驚嘆を前に、到る処に小ピラミッドやドルメンや環状｜石籬を築き、瘴※な自然の中に己が強い意志と慾望との印を打建てたのであろう。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僅か一年の間に大金を作ろうなぞと約束したのがこっちの愚昧であった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だが、土地の奴らも愚昧ですよ」と、庄太は笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "唐人飴",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓といへば什※に愚昧でも凡ての作物を耕作する季節を知らないことはない。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼ノ愚昧ナル善人ガ斯ル惡魔ノ喇叭卒ニ使役セラレテ其レヲ日本ニ向ツテ吹キシコトハ米國史上空前ノ恥辱ナリトス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "何がな金にせんと目論み、一つの鐘に二つまで瑕の由来を作った売僧輩の所行微笑の至りだが、欧州の耶蘇寺にも、愚昧な善男女を宛て込んで、何とも沙汰の限りな聖蹟霊宝を、捏造保在した事無数だ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚昧な心の動きを、狡猾な昆虫に譬へて、木の葉にかくれ、陽を見ず、夜陰に乗じて、滑稽な笛を吹く――詩を、作つて悲し気な苦笑を洩らしてゐた頃だつた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "小説的と思つて「彼は――」とするのではなくて、自分があまり親不孝で、そして愚昧過ぎるのがわれながら醜く思はれて、せめて主人公だけは「彼は――」として、セヽラ笑つて見逃すより他はなかつた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる形の似よりから凡ての現われと同じものと見るのは、甚しき愚昧な見断である。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又或る仏僧は皇帝の愚昧なる一言を聞くと、一拶を残したまま飄然として竹林に去ってしまった。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、実際の彼の頭は、彼が、病気だなどと思ふ程神経的でもなく、その言葉からうける繊細な鋭さからは反対な――だからその意識外の半面は甚しく茫漠とした白々しい愚昧さのみであつた。",
              "citation": {
                "source": "公園へ行く道",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚昧の過剰から、私は彼の女等の頬へ、非現実的、骨董的な磨きを掛けて、自分丈の置物にしようと試みたが、花瓶には罅が入って了ったのである。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、この愚昧な妹のお蔭で、母からさんざんな泣言を聞され、断腸の想ひに苛められることも屡々だつた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "……などと云うような予言なら、愚昧の評者でも云い切ることが出来る。",
              "citation": {
                "source": "日本探偵小説界寸評",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この少年とその兄達のどす黒い愚昧は、實に深いところに根ざしてゐると駿介には感じられた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし駿介には、僅か一代で今日の大を爲したといふ、その富の蓄積の過程と、その家の子供等の愚昧と云ふことは、全然無關係ではなく、そこには何かのつながりがあるやうに考へられてならなかつた。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は思ふべきを思ひ、思ふべからざるを思はぬといふことを、自分の意志通りには出來ない點で、愚昧な一農夫にも劣つてゐる。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、私は愚昧な民衆を見下し軽侮した。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだは、活きたは、本宅の主人へ電報を、と蜘蛛手に座敷へ散り乱れるのを、騒ぐまい、騒ぐまい。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛色のかわった犬｜一疋、匂の高い総菜にも、見る目、※ぐ鼻の狭い土地がら、俤を夢に見て、山へ百合の花折りに飄然として出かけられたかも料られぬを、狭島の夫人、夜半より、その行方が分らぬなどと、騒ぐまいぞ、各自。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
