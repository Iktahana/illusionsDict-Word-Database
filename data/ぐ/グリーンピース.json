        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "「もう、シュウマイの上のグリーンピースだけ残さないの！」と母に叱られた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "春先にスーパーに並ぶ生のグリーンピースは、冷凍のものとは香りが全然違う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "豆ご飯を作るために、子供と一緒に鞘からグリーンピースを取り出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ハネてから明日の新喜劇まつりのけい古へ、その前にホテルへ寄り、オルドヴル、グリーンピースのスープ、フィレソール。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
