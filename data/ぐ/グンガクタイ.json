    "definitions": [
      {
        "index": 1,
        "gloss": "military or naval band",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軍楽隊は、音楽をかなでながら、通りを行進しました。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼は、土地の軍楽隊に籍を置いたり、けちな管弦楽団の臨時雇の指揮をしたりして、口を糊しながら、娘の寿子を殆ど唯一人の弟子にして「津路式教授法」のせめてものはけ口を、幼い寿子に見出して来たのであった。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――そのためには、軍楽隊もやめます。",
              "citation": {
                "source": "道なき道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから乗り込んだ青島守備隊の軍楽隊が艫の甲板で奏楽をやる。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何も彼も忘れるといふやうな恍惚の想ひに打たれるなどゝいふ機会に、凡そこれまで出遇つた験もなく、終ひにはふら／＼病になつてゐた折から、はじめてこの街に移り艦を眺め戦闘機を見あげ、軍楽隊の大行進に力一杯のテープを投げ……いつかわたしは何の不安も疑惑も知らぬ偉大なる感激家に化してゐた。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――軍楽隊の響きが遠方の空から巻き寄せると、街は一勢に鬨の声を挙げて花やかな津浪と化した。",
              "citation": {
                "source": "緑の軍港",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど日清戦争のあとで、西洋音楽が一時パッタリと流行らなくなりまして、軍楽隊と、唱歌だけしか残っていないような有様で御座いましたが、ちっとも構いませずに大学のケーベル先生のお宅や宮内省の山内先生のお宅へ日参致しておりました。",
              "citation": {
                "source": "押絵の奇蹟",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入つての余興には青年軍楽隊や少年剣舞が番組された。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩私は、軽便鉄道が今や濛々たる煙りを吐いて出発する一巻や、祝賀の行列が軍楽隊を先頭にして繰り出す光景などを映写した。",
              "citation": {
                "source": "熱海線私語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍楽隊の演奏があってたいへんいいということだぜ」「そう。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに日比谷の陸海軍の合同軍楽隊の演奏がもう始まるころだから、もうここを出なくちゃならない。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラックに乗った一団の英国軍楽隊が、屋根の高さのままで疾走した。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "早くも観衆は場外にあふれ、勇ましい軍楽隊の合奏が天地に響き渡りました。",
              "citation": {
                "source": "国際射的大競技",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "庸三も、ずっと前から軍楽隊の野外演奏の管弦楽や、イタリイのオペラなど聴いたり見たりしていたが、レコオドの趣味もようやく濁みた日本の音曲が、美しい西洋音楽と入れかわりかけようとしていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔡家溝駅長オグネフ、同駅駐在中隊長オルダコフ大尉、同隊付セミン軍曹、チチハル・ホテル主人ヤアフネンコ、露国蔵相ココフツォフ、随行員、東清鉄道関係者、露支顕官、各国新聞記者団、写真班、ボウイ、日本人警部、日露支出迎人、露支両国儀仗兵、軍楽隊、露国憲兵、駅員。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど守備兵の交替時間で、中庭で軍楽隊の奏楽につれて、奇妙な軍服の兵士たちが木製の機械人形のように直線的に四肢を振って動きまわっていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "開演の迫った合図――軍楽隊のＯＮＥ・ＳＴＥＰだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍楽隊は一度に闘牛楽の調子を高め、旗はいっせいにひらひらし、人は歓呼の声を上げて――この闘牛士入場式の光景！",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この少年は小学校を出て後、軍楽隊を志願して海軍に入り、軍艦に乗り組んで、方々の外国の港などへも行った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日比谷交叉点　十文字に馳る電車、赤い旗、青旗　白ズボンに赤すじの入った洋袴をつけた海軍軍楽隊の男が、三人ぬかるみをとびこえ公園に入った。",
              "citation": {
                "source": "一九二七年春より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそこには年の若い軍楽隊の楽手が一人甲板の上に腹ばいになり、敵の目を避けた角燈の光に聖書を読んでいるのであった。",
              "citation": {
                "source": "三つの窓",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……帝国ホテルが真赤な血の色に染まって行く……飛行船も大火焔を噴き出して独楽のようにキリキリと廻転し初める……それを日比谷の大通りから米国の軍楽隊が囃し立てる……数万の見物が豆を焙るように拍手喝采する……それを警視の正装した私が馬に乗って見廻りながら、これは困った事になって来た。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは軍楽隊の服装を撮った写真であったが、綺麗な服装ときらびやかな楽器の中央に立って、指揮棒を振っている隊長の姿は、烈しい憧憬を静三に植えつけてしまった。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「軍楽隊長、軍楽隊長」と彼は弟の修造と囁き合った。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じような熱狂が弟の眼にも宿り、二人はどうかして、すぐにも軍楽隊長になりたかった。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "静三はよく小さな紙片に軍楽隊の絵を描いては娯しんだ。",
              "citation": {
                "source": "昔の店",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗艦の後甲板から、軍楽隊の奏する『別れの曲』、ロング・ザインのメロデーが、波の音にまじって、ながくながく聞えてくる。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "『最上』の軍楽隊は、悲しい悲しい送葬の曲を奏した。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
