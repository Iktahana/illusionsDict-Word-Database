  {
    "uuid": "98e79172-549f-5703-bb83-f6c6c8ae933b",
    "entry": "軍記",
    "reading": {
      "primary": "ぐんき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
