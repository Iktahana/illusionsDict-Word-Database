    "definitions": [
      {
        "index": 1,
        "gloss": "war chronicle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "海軍記念日は、ことしも、また、そろそろやってまいります。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十三年四月十八日山中貞雄従軍記×・二八――　小津氏曰くの「靖国神社の門鑑」なるものを戴く。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "国木田独歩は、明治二十七八年の戦争の際、国民新聞の従軍記者として軍艦千代田に乗組んでいた。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三章　日清戦争に関連して　　　　　　―独歩の「愛弟通信」と蘆花の「不如帰」　国木田独歩の「愛弟通信」は、さきにもちょっと触れたように、日清戦争に従軍記者として軍艦千代田に乗組んで、国民新聞にのせた、その従軍通信である。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○七月十六日、東京府民有志の発企にて、来朝中の米国前大統領グラント氏を新富座に招待し、新作の史劇「後三年奥州軍記」と芸妓の手踊を演ず。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて新作「太閤軍記朝鮮巻」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "永慶軍記といふ古書にも、「奥羽両州の人の心、愚にして、威強き者にも随ふ事を知らず、彼は先祖の敵なるぞ、是は賤しきものなるぞ、ただ時の武運つよくして、威勢にほこる事にこそあれ、とて、随はず。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かの式や遠足の時と云ふと軍服を着けて來て、日清日露役の從軍記章と、功六級の金鵄勳章と、勳七等の青色桐葉章を得意氣にぶら下げた動物學の先生の稚氣、それ等は寧ろ氣持の好い先生達の愛嬌だつた。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来いかなる戦史、軍記にも、薙刀を倒についた方は負である。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天よりは降りけん地よりは湧き出でけん、誠に天魔の所行なりとさしもに雄る武田の勇将猛士も恐怖の色を顕し諸軍浮足立つてぞ見えたりける」（『甲陽軍記』）　謙信は、一万三千の内旭山城に五千を残したから、精兵八千で、人数は同じであるが、不意に出られた武田勢は、最初から精神的な一撃を受けたのである。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、軍記作者のヨタでもないらしく、実際川中島に於ける謙信の陣立は水車の如く、旗本を軸としてまわって陣し、全軍が敵軍に当った。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時東京日日の新聞社長であった福地源一郎氏が、従軍記者として、田原坂戦闘の模様を通信して居るのがある。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "賤岳合戦記　　太閣記　　川角太閣記　　豊鑑　　豊臣記　　蒲生氏郷記　　佐久間軍記　　清正記　　脇坂家伝記　並に　　近世日本国民史　　豊臣時代史　　日本戦史　　柳瀬役",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏れ多い限りではあるが『慶長軍記抄』に依れば「万乗の天子も些少の銭貨にかへて宸筆を売らせ給ひ、銀紙に百人一首、伊勢物語など望みのまゝをしるせる札をつけて、御簾に結びつけ、日を経て後｜詣づれば宸筆を添へて差し出さる」とある。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「織田軍記」には義竜のことを記して、「今はあらそふ者もなければ、義竜自ら濃州の守護となつて、悪人ながら威勢ありしに、ためしすくなき大罪人のむくいにや、幾程なく永禄四年に義竜たちまち悪病を煩ひ、死去しけり」と、云ってある。",
              "citation": {
                "source": "赤い土の壺",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――再び鬱々の日来たり、約一年半、父や叔父の読み古した軍記、文学、講談などの雑誌に埋れて夢を見続けていた。",
              "citation": {
                "source": "簡略自伝",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『芸者諸君、さう喰つて許りをらんで、何か余興をやらんか、陸軍記念日の兵卒達の余興より、おぬし等は本職だから、うまいぢやらう、槍さびがいゝぞ』　と客は芸妓達に所望するのであつた、爾来この三人組は『資本』にやつてきた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "杉山平助氏に　死ぬ覚悟の押売　▼婦人公論十二月号で杉山平助氏が、『漢口攻略従軍記』を『戦線より吾子に送る手紙』の形式で書いてゐる、この戦地通信は相当枚数の原稿紙を、雑誌社に手渡してゐるから、文章で飯を喰つてゐる人間が、量的に原稿を売る目的はまづ達成してゐるわけである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽州の八郎潟の由来書に、八郎という樵夫、異魚を食い大蛇となったという（『奥羽永慶軍記』五）。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる詐欺が行わるべしとは今の人に受け取れぬが、『義残後覚』七、太郎次てふ大力の男が鬼面を冒り、鳥羽の作り道で行客を脅かし追剥するを、松重岩之丞が斫り露わす条、『石田軍記』三、加賀野江弥八が平らげた伊吹の山賊鬼装して近郷を却かした話などを参ずるに、迷信強い世にはあり得べき事だ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは『奥羽永慶軍記』二に最上義光、延沢能登守信景の勇力を試みんとて大力の士七人を選出す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ女流キリスト教徒の先覚者として、キリスト教婦人同盟の副会長をしていた葉子の母は、木部の属していた新聞社の社長と親しい交際のあった関係から、ある日その社の従軍記者を自宅に招いて慰労の会食を催した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その席で、小柄で白皙で、詩吟の声の悲壮な、感情の熱烈なこの少壮従軍記者は始めて葉子を見たのだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本橋の釘店にある葉子の家には七八人の若い従軍記者がまだ戦塵の抜けきらないようなふうをして集まって来た。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体馬琴は史筆｜椽大を以て称されているが、やはり大まかな荒っぽい軍記物よりは情緒細やかな人情物に長じておる。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍記物語の作者としての馬琴は到底『三国志』の著者の沓の紐を解くの力もない。",
              "citation": {
                "source": "八犬伝談余",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に軍憲から発表された大杉外二名の一人がマダ可憐な小児であると思うと、三族を誅する時代の軍記物語か小説かでなければ見られない余りの残虐に胸が潰れた。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "源平時代の軍記物には貴族に對する武士階級の革命的思想が現われ、維新前後の志士の言論には行き詰つた封建制度に對する新興階級の革命的思想が現われている。",
              "citation": {
                "source": "唯物史觀と文學",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ある日の高座で前講のなんとかいう若い講釈師が朝鮮軍記の碧蹄館の戦いを読んだのです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝鮮軍記の講釈で、小早川隆景が貝を吹く件をきいている時には、自分のむかしが思い出されて、もう一度貝をふく身になりたいと思いましたが、それはその時だけのことで、武家奉公はもう嫌です。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
