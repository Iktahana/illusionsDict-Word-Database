[
  {
    "uuid": "dc4d57f4-80ec-5c15-808d-0fc85d84c203",
    "entry": "グー",
    "reading": {
      "primary": "グー",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "感動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "good",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "万々　「メム」は沼またラグーン。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると頬つぺたを脹まし、ガマのやうに顏をふくらして、何か喉の邊でグーグーといふ奇聲を出してる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　少し一所に歩いてゐると、急に彼は默つてしまつて、またグーグーといふ奇聲を出してる。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「木ッ葉役人の二十三十束にして」　とづかづか近寄り乍ら、Ｔ「なりひら小僧を召し捕るたァ」　と言って、Ｔ「虫が好すぎるぜ大将」　で主膳グーの音も出ない。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの映画であったか忘れたが東洋物の場面の間に、毒蛇とマングースとの命がけの争闘を写したものをはさんだのがあった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで二人はもうグーとも云はず、まん円になって一目散に逃げました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで二人はもうグーとも云わず、まん円になって一目散に逃げました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘がグーッと下って来る。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂から上がり、姿見に向かい三人相顧みて、「随分黒くなったなあ」　この夜、吉岡髯将軍ビール二杯呑んだところが早速酔っ払ってしまい、自分から注文した名物の羊羹が来たのも知らずに、鼾声雷のごとくグーグームニャムニャ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人たちは外国のホテルに泊って、見識らぬ人たちからグード・モーニングなどを浴せかけられたら、びっくりして宿換えをするかも知れない。",
              "citation": {
                "source": "温泉雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランクリン・ホールの源蔵は、努めて日本人の癖を学ぼうとして前屈みになり過ぎるのが眼障りでしたが、小太郎を見て「オオ、グード、ボーイ」とじっとその顔を眺めるあたりは大芝居でした。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたは見物が一パイに来るに違いないから、みんな早く起きて来るんだぞ」　あくる朝になりますと、見世物小舎の主人は、前の晩に豚吉夫婦を捕えて檻の中へ入れたり何かしたものですから疲れたと見えまして、たいそう朝寝をして眼を覚ましましたが、見ると雇人もまだみんなグーグーと睡っています。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に豚吉とヒョロ子は町の宿屋に帰ってグーグー寝ておりましたが、そのうちに二人共眼がさめて、「これからどうしよう」　と相談を初めました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶先生はその樽の栓を取ると、両手に抱えてグーグーグーグー一息に呑み初めましたが、やがて飲んでしまいますと、「アー。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その踊りが済めば、おれが一人一人に死なないように療治をしてやる」　と云いながら、無茶先生は又一つの樽に口をつけて、中のお酒をグーッと飲み干します。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり腰が抜けたのか」　とゆすぶって見ましたが、もうグーグーとねむってしまって返事もしません。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも飲もう」　と、二人で樽を抱えてグーグー飲んでいるうちに、いつの間にか酔い倒れてしまいました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "無茶先生は、その時町を出てだいぶあるいていましたが、右手に持ったお酒の樽へ口をつけてグーグー飲みながら、「ウーイ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
