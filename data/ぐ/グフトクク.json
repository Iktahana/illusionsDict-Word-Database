        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "どんなに富を得ても満たされない彼の心は、まさに求不得苦の淵にあった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "愛する人の心が手に入らないもどかしさに、彼は求不得苦の何たるかを悟った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "人生はままならぬもので、誰もが求不得苦の試練を避けては通れない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "強いていえば「求めて得られざる苦しみ」（求不得苦）でしかありません。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
