  {
    "uuid": "b6b115ab-6acd-5efc-a9bc-4eb7377097f3",
    "entry": "群盗",
    "reading": {
      "primary": "ぐんとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "group of robbers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シルレルもまた十八歳、「群盗」に筆を染めた。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "純友は伊予掾で、承平年中に南海道に群盗の起つた時、紀淑人が伊予守で之を追捕した其の事を助けてゐたが、其中に賊の余党を誘つて自分も賊をはじめたのである。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "往年関東の群盗が一時に戮に遇ったとき、その妻子等が逐われて西辺に遷り住んだ。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは少し前に、シルレルの『群盗』を読んだところだったのである。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸といえば、素朴な印象にこだわるようであるけれども、「群盗」の初日に滝沢氏の演じられた弟の独白の場面で、舞台の一隅に置かれた枝蝋燭立てから一本の燃えているローソクが舞台の上に落ちました。",
              "citation": {
                "source": "一つの感想",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "初日で十二時になる（群盗。",
              "citation": {
                "source": "情景（秋）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を見たら泥棒と思へ、といふのが昔の農村の生活であつて、事実、群盗横行し、旅人は素性の良くないものと決めてかゝるのが賢明であつたから、旅人に宿などはかさない風である。",
              "citation": {
                "source": "地方文化の確立について",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を見たら泥棒と思えというのが王朝の農村精神であり、事実群盗横行し、地頭はころんだときでも何か掴んで起き上るという達人であるから、他への不信、排他精神というものは農村の魂であった。",
              "citation": {
                "source": "堕落論〔続堕落論〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦後の日本は、乱世の群盗時代でもあるが、反面大マジメな社会改良家の時代でもあり、ともに風流を失した時代でもあるのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが日本に於ては、このサンタンたる敗北、この焼野原、そして群盗の時代にも拘らず、戦争によって受けた利益は、非情なる歴史的観察に於ては、被害以上となる筈である。",
              "citation": {
                "source": "戦争論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠江の橋本宿は吾妻鏡にも見える遊女の本場だが、気がむけばそのまま遠江まで足をのばすという寛濶さで、馬が疲れると自分のを捨てて通りがかりの馬をひったくり、群盗の野館のあるところは、「中納言大蔵卿藤原ノ泰文」　と名乗りをあげて通って行く。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちあけ話を聞くと、犬養ノ善世はもとは鬼冠者といい、伊吹の山にいた群盗の一味で、首の傷は五年ほど前、山曲の暗闇で泰文とやりあい、腰刀をうちこまれたものだということだった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "延暦十七年二月に、群盗を停宿して百姓を侵犯したという罪で淡路に流された美濃の国人村国連悪人という人がある。",
              "citation": {
                "source": "時勢と道徳観念",
                "author": "大賊小賊・名誉の悪党",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときに、田畑や源泉を所有しているということ、群盗横行しても、田畑や源泉は盗まれませんよ。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜陰に跳梁する群盗の一｜味！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が斬りたいばかりに天狗へ走った大之進も理窟が嫌いなところからまた江戸へ舞い戻ってみると、天下は浪人の天下、攘夷の冥加金を名として斬奪群盗が横行している始末に、大之進つくづく考えると徳川三百年の余命幾何とも思われない。",
              "citation": {
                "source": "早耳三次捕物聞書",
                "author": "霙橋辻斬夜話",
                "note": "青空文庫"
              }
            },
            {
              "text": "子弟の或る者は博奕にふけり群盗に伍している。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海には海賊の禍があるとするも、陸上とても群盗所在に出没した。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また群盗の横行に徴してこれを秩序｜紊乱の時代だとする。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつずっと古い時代の記録に地方群盗の記事の少ないのは、必ずしもその事実上稀少であったという証拠とはならぬ。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "また時代が次第に降るにしたがって、群盗の記事の記録に多く見ゆるようになるのは、これを今まで少なかったものの増加したがためと解するよりも、かえりて社会の秩序が立ちかけて、擾乱者が目立ってきた、ないしは秩序を欲する念が、一般に盛んになってきたためと説明することもできよう。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおその上に足利時代の方がかえりてそれ以前の時代よりも、群盗横行の害少なかったろうと思われる他の理由もある。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず悲観論者は、群雄割拠になると、その群雄の各々の領内には数多の群盗が横行して、その秩序はいやが上に乱脈になると想像するらしいが、これが果して肯綮にあたった想像であろうか。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに一揆も群盗には違いがないが、一揆というほどに多勢でない群盗の横行もまた頻繁であった。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文治二年に北条時政が京の名物ともいうべき群盗を追捕し、使庁へわたさずに勝手に斬ってしまった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠江の橋本宿は吾妻鏡にも見える遊女の本場だが、気がむけばそのまま遠江まで足をのばすという寛濶さで、馬で疲れると、行きあう馬をひったくり、群盗の野館のあるところは、「中納言大蔵卿藤原ノ泰文」　と名乗りをあげて通って行く。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬養ノ善世はもとは鬼冠者といい、伊吹山にいた群盗の一味で、首の傷こそは、五年ほど前、山曲の暗闇で泰文とやりあい、腰刀をうちこまれたものだということだった。",
              "citation": {
                "source": "無月物語",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は其の時から遥か年を経て、津の国の昆陽寺から黄金の交って居る釣鐘を盗み出す群盗の話を読んだ。",
              "citation": {
                "source": "こがらし",
                "author": "――南駅余情――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何々五人男という群盗が、江戸の綱紀の乱れに乗じて、勇侠者流のような顔をして跳梁した頃のことです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
