        "examples": {
          "standard": [
            {
              "text": "反逆罪に問われた兵士たちは、重々しい雰囲気の軍事裁判所へと引き立てられた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍事裁判所は基地の最も奥まった場所にあり、一般人がその中を見ることはできない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "裁判長は軍事裁判所の名において、被告に対して厳格な判決を言い渡した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それによって、ドイツでも、日本でも、国際軍事裁判所が設けられることになった。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが日本では、東京に、その国際軍事裁判所が設けられた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本における国際軍事裁判所は、右に述べたように、文明式の裁判をなさなかったのである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
