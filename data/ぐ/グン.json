  {
    "uuid": "d6909084-da72-5ca0-9704-34c0139db719",
    "entry": "郡",
    "reading": {
      "primary": "ぐん",
      "alternatives": [
        "こおり"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
