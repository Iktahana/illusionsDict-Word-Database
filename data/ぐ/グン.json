    },
    "definitions": [
      {
        "index": 1,
        "gloss": "district",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎者太宰治　私は、青森県北津軽郡というところで、生れました。",
              "citation": {
                "source": "田舎者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあこれから、俺はこれを改めなくちや……」　だが今迄のやうに、自分のすることは直ちに郡視学の耳に入り、県視学に聞達するやうなことは、都会ではあるし、それに私立中学のことだからないだらうと思はれた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「菜の花や月は東に日は西に」「菜の花の中に城あり郡山」などいうのは、春げしきの中で、私が永久に保存したく思っている風景画である。",
              "citation": {
                "source": "菜の花",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田だけは、江戸時代から、郡内の甲斐絹の本場を控えて、旅人の交通が繁かっただけあって、山の坊のさびしさが漂うと共に、宿場の賑わいをも兼ねて見られる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山郡のところどころに高い山が見えた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（万葉仮名として用いた漢字において、ｍで終る「南」「瞻」「覧」をナム（またはナミ）、セミ、ラムに宛て、ｋで終る「福」「莫」「作」「楽」を、フク、マク、サク、ラクに宛て、ｎで終る「散」「干」「郡」をサニ、カニ、クニに宛てたなどを見てもそう考えられる）。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「俺ァ駿河の国は有度郡清水港の長五郎だ」　次郎長の背後の二人が名乗る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "海道一の親分は今あるじゃねえか」　「誰です」　「駿河の国は有度郡清水港に住む山本長五郎。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父　滋賀県神崎郡八日市町二四四山崎晴弘姉　神奈川県鎌倉市長谷通り二五六　　　マ・ソアール美容院山崎つた友達本郷区森川町九〇加藤郁子淀橋区戸塚町一ノ四〇四宮崎晴子",
              "citation": {
                "source": "雨の玉川心中",
                "author": "遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "をさけびたけり足ぶみて、　　をどりめぐれるすがたゆゑ、老いし博士や郡長、　　　　　やゝ凄涼のおもひなり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "酸虹鵞黄の柳いくそたび、　　窓を掃ふと出でたちて、片頬むなしき郡長、　　　酸えたる虹をわらふなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時しも土手のかなたなる、　　郡役所には議員たち、視察の件を可決して、　　はたはたと手をうちにけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は郡で調べたのをちゃんと写して予察図にして持っていたからほかの班のようにまごつかなかった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡のも十万分一だしほんの大体しか調ばっていない。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（郡から土性調査をたのまれて盛岡から来たのですが。",
              "citation": {
                "source": "泉ある家",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡山まで行くと……宵がへりがして、汽車もパツと明く成つた。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うつかり夢でも視たやうで、――郡山までは一｜度行つた事があるものですから……」　園も窓を覗きながら、「しかし、何うも済みません、第一｜見た事もありませんのに、奥州二｜本松と云ふのは、昔話や何かで耳について居たものですから、夢現に最う其処を通つたやうに思つたんです。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは、八｜月七｜日の午後、秋田県鹿角郡、生出を駕籠で上つて……これから三｜瀧街道を大湯温泉まで、自動車で一｜気に衝かうとする、発荷峠、見返茶屋を、……なごりの湖から、向つて右に見た、三岐の一｜場面である。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "水源は秋の日など隅田堤より遠く西の方に青み渡りて見ゆる秩父郡の山※の間にて、大滝村といへるがこの川の最上流に位する人里なれば、それより奥は詳しく知れねど、おもふに甲斐境の高山幽谷より出で来るなるべし。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "文徳実録に見える席田郡の妖巫の、その霊｜転行して心を心の二字が祇尼法らしいから、随分と索隠行怪の徒には輾転伝受されていたのだろうと思われる。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝説に依ると、水内郡荻原に、伊藤｜豊前守忠縄というものがあって、後堀河天皇の天福元年（四条天皇の元年で、北条｜泰時執権の時）にこの山へ上って穀食を絶ち、何の神か不明だがその神意を受けて祈願を凝らしたとある。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は飯綱神社で、式内の水内郡の皇足穂命神社である。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨董が黄金何枚何十枚、一郡一城、あるいは血みどろの悪戦の功労とも匹敵するようなことになった。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また火山の名が同時に郡の名や国の名であったりすることがしばしばある。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "国郡のごとき行政区画のできるはるかに前から、火山の名が存し、それが顕著な目標として国郡名に適用されたであろうとは思われるが、これも確証することはむつかしい。",
              "citation": {
                "source": "火山の名について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郡役所の技手の、乗馬ずぼんをはいた足よりまだりっぱだ。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は今、右のことが分つたので歓喜にむせぶ気持でゐるが、又一方、長年求めあぐんで、暗中模索してゐたものが、一時に分つたので、慄へてもゐるといつた状態である。",
              "citation": {
                "source": "詩壇への抱負",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十通あまりの、その手紙を、まるで谷川が流れ走るような感じで、ぐんぐん読んでいって、去年の秋の、最後の一通の手紙を、読みかけて、思わず立ちあがってしまいました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　父は涙ぐんでゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
