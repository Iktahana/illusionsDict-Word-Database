[
  {
    "uuid": "7f5fd323-d498-5dee-913a-62f0234e314d",
    "entry": "ぐるぐる巻き",
    "reading": {
      "primary": "ぐるぐるまき",
      "alternatives": [
        "グルグルまき"
      ],
      "is_heteronym": true
    },
    "grammar": {
