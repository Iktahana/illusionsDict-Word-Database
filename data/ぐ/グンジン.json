[
  {
    "uuid": "7a991bf4-6da2-5cec-9126-295fe158b964",
    "entry": "軍人",
    "reading": {
      "primary": "ぐんじん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "serviceman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "大船にて横須賀行の軍人下りたるが乗客はやはり増すばかりなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "板垣退助を戴いた自由党が全盛の時代であったので、軍人の子供である自分は、「官権党の子」だという理由でいじめられた。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから軍人も嫌であった。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以来軍人と云うものはすべてあんなものかと云うような単純な考えが頭に沁みて今でも消えぬ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな訳だから、学校でも軍人希望の者などとはどうしても肌が合わぬ、そう云う連中から弱虫党と目指されて、行軍や演習の時など、ずいぶん意地悪くいじめられたものだ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理の圧迫が劇しい時には弱虫の本性を現してすぐ泣き出すが、負けぬ魂だけは弱い体躯を駆って軍人党と挌闘をやらせた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧嘩を慰みと思っている軍人党と、一生懸命の弱虫との挌闘にはたいてい利口な軍人の方が手を引く。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなのもおおかた軍人党になるだろうと思って、過ぎたわが小半生の影が垣の外にちらつくように思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其著者を誰とかする、即ち當時廷臣とし、軍人とし、政治家として夙に盛名あるも、未だ文筆の人としては左までに顯はれざりしラロシフコー公爵其人なりとす。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いかにも、「廷臣とし、軍人とし、政治家として夙に盛名ある」ラロシフコー公爵その人の息吹が感ぜられる尊嚴盛大の文章である。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に彼は、教育に關する御勅語、軍人に賜りたる御勅諭までさかのぼつて考へるやうになります。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲を持たせてる限り、軍人が人を殺して悪いと云ふ法はない。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人を見てもやつぱりさうであるらしい。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今から三十五年の昔のことであるが或る田舎の退役軍人の家で大事の一人息子に才色兼備の嫁を貰った。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある軍人の話によると、重爆撃機には一キロのテルミットを千箇搭載し得るそうである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中襲撃の防禦は軍人だけではもう間に合わない。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらかじめ気象学者の意見を徴すればよいのに、工学者や軍人だけで土地を選定しいよいよ工事を始めてみると気象方面の不都合な点が出て来て中止する事となり、約五百万円くらいの金を棒に振ったという事である。",
              "citation": {
                "source": "戦争と気象学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人や軍人の男装をした踊り子までがみんな女の子のきいきい声を出すので猶更そういう「毀れやすい」感じを起こさせるようである。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃英国の某新聞で陸海軍人の待遇を論じたのについて某科学雑誌記者は次のような事を云っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年振で軍人の云ふことにも變りが見える。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも親達は軍人にする積で、十ばかりの奴を掴まえてウィインの幼年学校に入れたのだそうです。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも、軍人の氣もちでゐまい。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人精神の結晶である。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの行爲、あの精神は正に軍人精神を立派に發揚したもので、誠に軍人の鑑である。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、中根は正しく軍人の、歩兵の本分を守つたものだ。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "村の在郷軍人や、青年団や、村長は、入営する若ものを送って来る。",
              "citation": {
                "source": "入営する青年たちは何をなすべきか",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今手あたり次第に饗庭篁村の「従軍人夫」（太陽、明治二十八年一月）、江見水蔭の「夏服士官」「雪戦」「病死兵」（中央新聞二十七年十二月─一月）、村井弦斎の「旭日桜」（報知新聞二十八年一月─三月）等を取って見るのに、恐ろしくそらぞらしい空想によってこしらえあげられて、読むに堪えない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酒中日記」の如き、日清戦争後の軍人が、ひどく幅をきかした風潮を、皮肉りあてこすっている作品でも、将校はいゝのだが、下士以下が人の娘や、後家や、人妻を翫弄し堕落させるとしている。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
