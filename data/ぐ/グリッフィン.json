          "literary": [
            {
              "text": "ぼくはグリッフィンなんだよ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら大学で同級だったグリッフィンだよ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おぼえてるだろう」「グリッフィンだって……なにをばかなことを……この化けものめ！",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはまちがいなくグリッフィンなんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくは大学にいたときと同じグリッフィンなんだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "心も体も昔のままのグリッフィンなんだよ」　博士は物わかりのいい人だったし、頭の慟きのするどい人だったので、姿の見えないほうたいの化ものの言葉に真実のあることを見ぬき、「ずいぶんきばつな話だが、話をきけばあるいはわかるかもしれん。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいいち、透明人間がグリッフィンだと言ったところで、たしかにかれだという証拠はないわけだ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔をみることもできんし……もっとも声はグリッフィンらしいが」「きみ、まだそんなことを言うのかい……ぼくはまちがいなくグリッフィンだよ。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、グリッフィンが大学生のころから、ひどくおこりっぽい感情のはげしい男だったのを思いだして、一生けんめいになだめた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにやつは、昔の友だちのグリッフィンだというのだから……」　博士は机のまえに、どっかりと腰をおろすと、ながい間、頭をかかえて考えこんでいた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」グリッフィン透明になる　つぎに透明人間が話しだしたのは、いよいよかれ自身の体が、どのようにして透明にかわっていったか、ということだった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに友人のグリッフィンがいる。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "目に見えない怪物に、あばれられては大変ですからな」「あの男は、むかしのグリッフィンとは人が変わってしまった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "差出人の名は書いてないが、透明人間、すなわちグリッフィンからの手紙にちがいなかった。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明人間グリッフィンの最期である。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            }
          ]
        }
