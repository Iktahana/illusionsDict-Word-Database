    "definitions": [
      {
        "index": 1,
        "gloss": "soundly (sleeping)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
