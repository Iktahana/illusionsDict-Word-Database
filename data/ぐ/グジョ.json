        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昔の物語では、愚女がたびたび困難に巻き込まれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は愚女だと見下していたが、実際は賢い女性だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その愚女の行動は、周囲の笑いを誘った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
