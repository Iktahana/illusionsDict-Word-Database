[
  {
    "uuid": "42cc200e-d777-5c7c-a824-ddb8d1986cb4",
    "entry": "軍法",
    "reading": {
      "primary": "ぐんぽう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
