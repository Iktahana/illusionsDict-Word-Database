[
  {
    "uuid": "ba796ca9-4ff7-5d48-aaf3-6795e380f856",
    "entry": "軍容",
    "reading": {
      "primary": "ぐんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
