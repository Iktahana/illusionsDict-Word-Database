      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "military accouterments",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "江｜乃ち兵を率いて※沱を渡り、旗幟を張り、火炬を挙げ、大に軍容を壮にして安と戦う。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、此の時の武田の軍容は、信玄死後と雖も、落ちていたのではない。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二篇の饗庭篁村の『掘出し物』は丁度｜新店の見世開きに隣家の老舗の番頭を傭って来たようなものであるが、続いて思案の『乙女心』、漣の『妹背貝』と、予定の如くに第三陣第四陣と順々に繰出して、盛んに軍容を整えて威武を張った。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが兵庫へ到着し、愈々決戦近しといふので、山上へ馬を走らせ山下の軍容を一望に眺めてみると、奇妙である。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、秀吉は石垣山の楼上から小田原包囲の軍兵二十六万の軍容を眺め下して至極好機嫌だつた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペリイは大いに軍容を示して、日本人の高い鼻をへし折ろうとでも考えたものか、脅迫がましい態度がそれからも続きに続いた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "一行の大砲や武装したいでたちを見るものは来たるべき東山道軍のさかんな軍容を想像し、その租税半減の旗を望むものは信じがたいほどの一大改革であるとさえ考えた。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "その勢強く、官軍容易にこれを鎮定する事が出来ません。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵旅を解き云云は、此れ所謂軍容、國に入らざる也。",
              "citation": {
                "source": "國譯史記列傳",
                "author": "司馬穰苴列傳第四",
                "note": "青空文庫"
              }
            },
            {
              "text": "また衆軍を無花果樹のほとりに留めよ、其ほとり防禦薄くて敵の軍容易に中に入り得べし。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日――安土城下から立って行った秀吉の軍容は、実に威風堂々たるものだった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけ明智の軍容は強化され、光秀の横奪した天下を天下にゆるしておくことにもなる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、敵秀吉の軍容は、圧倒的な優勢にあるといわなければならない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう観て、一益は内心、（秀吉を破ること難からず）　となし、（ひき寄せて、散々に撃ち、機を計って、信孝を再蹶起せしめ、岐阜の兵を合わせて長浜へ殺出せん）　と、期しているかのごとき軍容だった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍容、陣気、静、動――すべて、“位”の光揚である。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍威軍容を万全にそなえてからいつもものをいうのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "坪井山本陣の佐々成政は、一夜に、戦況は逆転し、自身の周囲すら浮き足たって来たのを見て、「ふがいなき奴どもよ」　と、かれらしい激怒のもとに、軍容をたて直し、末森城への再攻撃を計った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉を思うとき、新しい大坂城を中心とする文化、軍容の興隆を思う時、数正は、ふらふらと、上方が恋しくなった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、袁術はここにわかに、帝位につかんという野心から、急激にその軍容を膨脹させました。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その軍容はまさに、呉にのみ見られる壮観であった。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　絢爛たる軍容粛々とあたりを払って、潼関にまで進んだ。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやその軍容の物々しさ、何万騎やらただ真ッ黒になって漢水を越えてきます」　すると趙雲は炬のごとき眼をして、張翼の卑怯を叱った。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずか四日間の合戦で、夏侯楙の軍容は、半身不随になりかけてきた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような英雄児が、この片田舎にもあろうとは」　と、痛嘆して、自身、軍容をあらためて、他日、慎重に城へ迫った。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに三郡の戡定も成ったので、蜀は軍容をあらためて、大挙、長安へ進撃することになったが、それに先だって孔明は諸軍をねぎらい、まず降将梁緒を天水の太守に推し、尹賞を冀城の令とし、梁虔を上※の令に任じた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて西平関に着くや、孔明は、直ちに出迎えた馬岱を案内として、高地にのぼり、※軍の軍容を一｜眄した。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "徐晃勢だけではなかったか」　あわてて引っ返しにかかった時は、彼の率いていた軍容は全く隊伍をみだしていた。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、「やがて今までにない猛烈な軍容をもって魏が攻撃を取ってくるにちがいない。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
