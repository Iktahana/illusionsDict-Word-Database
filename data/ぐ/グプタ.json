    "definitions": [
      {
        "index": 1,
        "gloss": "Gupta (dynasty of India; approx. 320-600 CE)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
