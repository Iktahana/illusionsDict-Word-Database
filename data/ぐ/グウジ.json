    "definitions": [
      {
        "index": 1,
        "gloss": "chief priest",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "父親は太郎からそれを聞いて、「他よりあらわれなば、この家をも絶されん、祖の為子孫の為には、不孝の子一人｜惜からじ、明は訴え出でよ」と云って大宮司の許へ訴えさした。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮司の許へ来て盗人の詮議をしていた助の君文室広之は、武士十人ばかりをやって豊雄を捕えさした。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと思って覗いてみると勿体らしい衣冠束帯をした櫛田神社の宮司が、拝殿の上に立って長い髯を撫でながら演説をしている。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "季忠は此時二十七歳であったが、信長あわれんでその子孫を熱田の大宮司になしたと云う。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前の斎宮司の役人などで親しく出入りしていた者などがわずかに来て葬式の用意に奔走するにすぎない六条邸であった。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人のあとについてその集落を横切り、この島の郷社八幡宮の下に宮司三宅其部氏を訪うた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大社の宮司は西田さんの知人でありまして、ヘルンの日本好きの事を聞いていますから、大層優待して下さいました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高角山にある柿本神社の境内は人麿が墳墓の地ではないまでも、古くからその靈が祭られたところで、私達はその話を神社の宮司からも、高津の町長隅崎君からも、そこまで同行した益田の大谷君からも聞いた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮司に導かれて私達は松風の音の聞えて來るやうなところに腰掛けた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "參詣者も多いと見えて社殿の前の柱といふ柱には男や女の名前が一ぱいに書きつけてあつたが、それを押し止めもしないところに宮司の人柄も見えてゐた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろ／＼とよく話す人で古典にも親しみ、和歌の趨勢にも通じ、かうして職務にたづさはる中での新人と見えたが、高津の町の盛衰を一身に負はなければならないやうな宮司としての立場も容易ではないらしい。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、父は平田｜篤胤の門人であったというし、維新の際には家を忘れて国事に奔走したというし、飛騨の国にある水無神社の宮司にもなったというし、それから郷里に退いて晩年を子弟の教育に送ったともいうことである。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを彼は思い出して、あの水無神社の宮司として飛騨の山中に籠っていた頃が父の生涯の中でも寂しい時であり、懐しみの多い時ででもあることを想って見た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年ほど前に神戸湊川神社の宮司が私の宅に見えて、「楠公夫人の像を描いて奉納してもらいたい」　と言われた。",
              "citation": {
                "source": "楠公夫人",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は本名を重兵衞と言つたのだが、祝詞なぞで、「宮司重兵衞｜鵜自物鵜奈禰突拔天白」も可笑しいからと言つて別に仲臣といふ名を命けてゐたのである。",
              "citation": {
                "source": "ごりがん",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "この松原貴速という人は、長州の俗論党の錚々たる人であったらしく、旧姓山県九郎右衛門という（この人について、御存じの方は御一報願いたい）、後に、石清水八幡の宮司となり、生玉神社にも仕えたが、遂に、浪々の身となって、何ういうのか、父が世話することになったのである。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "長州藩の家老｜山県九郎右衛門、後に男山八幡の宮司をしてゐた人の落魄してゐたのを引取つて、世話をしてゐたし、何んなに、ぴい／＼してゐても、痩我慢一つで、押通してゐた。",
              "citation": {
                "source": "貧乏一期、二期、三期",
                "author": "わが落魄の記",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿田彦が通り、美くしく化粧したお稚児が通り、馬に乗つた禰宜が通り、神馬が通り、宮司の馬車が通り、勅使が通り、行列は終になつたが、神輿はまだ大和橋を渡つたとか渡らぬとか群衆が云て居る。",
              "citation": {
                "source": "住吉祭",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "社のついでにいうが、私の家の持主の味酒神社は大山祇の神を祭ったもので、久しい以前から唯一神道でいて、社は皆｜檜皮葺、神官も大宮司と称して位も持っており、その下にも神官が数々居て、いずれも一家を構えて住んでいた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はよくこの大宮司の内へも遊びに行った。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日大宮司の内で遊んでいた時、私のそばにそこの長男が居た。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮司は従五位上肥後守といっていたが、藩の士に対しては卑下していた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大宮司へは国学者などがよく来たもので、ある時長く逗留して何か調べ物をしている人があった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "大宮司の子等があれは国学の先生で三輪田綱一郎という人だと私に話したが、それが後年京都で足利の木像の首を切って晒し物にした浪士の筆頭となったのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し倖に余命があつたら、松平春嶽の推挙で、明治政府治下の官吏・助教・宮司のいづれかになつて居たかも知れぬ。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人なる山の宮司が肝をいってくれて、夕饗は二の膳に到るまで、一切山の物ばかりであった。",
              "citation": {
                "source": "山の湯雑記",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "神宮司庁の大麻暦さへ忘れた様な古暦のくり言も、地震の年をゆり返した様な寂しい春のつれ／″＼を、も一つ飜して、常世の国の初だよりの吉兆を言ひ立てる事になるかも知れない。",
              "citation": {
                "source": "若水の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱崎の芳野家の「神国愚童随筆」といふ本に、壱岐の神人の事を書いて、命婦は女官の長で、大宮司・権大宮司の妻か娘かゞなるとある。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は酔っぱらってぐうぐうじゃ、何かまじまじとして私あ寐られん、一時半ばかり前に、恐しく風が吹いた中で、確に聞いた、しかも少い男の声よ。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
