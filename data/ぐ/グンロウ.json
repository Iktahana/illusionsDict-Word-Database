        "examples": {
          "standard": [
            {
              "text": "暗い夜の森で、群狼が獲物を追い詰めるような低い唸り声が聞こえた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "群狼はリーダーの合図一つで、一糸乱れぬ動きを見せながら獲物に襲いかかる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつてこの地方では、家畜を襲う群狼を駆除するために多額の報奨金が出された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "サウシの書（前出）に若いポルトガル人が群狼に襲われ樹上に登って害を免がれ後日の記念にその樹を伐り倒し株ばかり残して謝意を標した。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は群狼と熊とであった。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯くして去れる彼の魂――彼を※りてトロイアと、アカイア二軍、猛烈の技を演じて群狼の　470如く、人々飛びかかり人々互に相撃てり。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯山の正受老人は、群狼の中で坐禅をしたということを米友は知らないが、これは油断がならない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
