        "examples": {
          "standard": [
            {
              "text": "「このぐい呑みは、手にずっしりと馴染む、趣のある形だ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「お気に入りのぐい呑みで飲む日本酒は、格別な味がする。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「ちょっと、このぐい呑みに日本酒を注いでくれる？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "私は残ったお酒をぐいぐい呑み、ひとりでごはんをよそって食べましたが、実にばからしい気持でした。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "否、ひとり、棒ぐいのみではない。",
              "citation": {
