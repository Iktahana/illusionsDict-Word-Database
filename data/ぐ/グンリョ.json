[
  {
    "uuid": "2b0ca378-62e0-58d5-bf37-ac627f4310d0",
    "entry": "軍旅",
    "reading": {
      "primary": "ぐんりょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "army",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軍旅の暦は夏秋をすぎゆうべ上海を拔いて百千キロ。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ適以て軍旅の鋭を殺ぎ、貔貅の胆を小にするに過ぎざるのみ、智なりという可からず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "播種耕耘の事を學ぶとしても、經營建築の事を學ぶとしても、操舟航海の事を學ぶとしても、軍旅行陣の事を學ぶとしても、畫を學ぶとしても、書を學ぶとしても、着手の處、着手の處と逼り詰めて學ぶので無くては、百日過ぎてもまだ講堂の内に入らぬので有る、一年經つても實踐の域に進まぬので有る。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば猶支那の占卜の道の書たる易が軍旅の事を説くこと甚だ多しと雖も、戀愛婚媾の事をも説かざるに非ざるが如しで有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "武帝は李陵に命じてこの軍旅の輜重のことに当たらせようとした。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時正に秋も半、軍旅の好期である。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『氏郷記』に、少時間で早く物を煮得る鍋を、宝物に数えたり、秀郷の子孫に限り、陣中女房を召し仕わざる由を特書したので、件の竜宮入りの譚は、早鍋世に極めて罕に、また中古の欧州諸邦と等しく、わが邦でも、軍旅に婦女を伴れ行く風が存した時代に出来たと知らる。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時とても軍旅、労働、斎忌等の節一定期間男女別れて群居する民少なからず、古ギリシアやマレー半島や南米に女人国の話あるも全く無根でない（一八一九年リヨン板『レットル・エジフィアント』五巻四九八頁已下。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から学者は軍旅の慰めに、家妻を伴うたものと解している。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヂンギスカンとは日本人の命名ださうだが、沙漠に開かれる軍旅の夜宴は連想としてまづくない。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から学者は軍旅の慰めに、家妻を伴うたものと解して居る。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "九つ半時に、姫君を乗せたお輿は軍旅のごときいでたちの面々に前後を護られながら、雨中の街道を通った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "御通行の際は、白地の錦の装束に烏帽子の姿で、軍旅のいでたちをした面々に前後を護られながら、父岩倉公の名代を辱かしめまいとするかのように、勇ましく馬上で通り過ぎて行った。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "季康子がそれについて尋ねると、冉有は軍旅のことを孔子に学んだと答えた。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子｜対えて曰く、俎豆の事は則ち嘗て聞けるも、軍旅の事は未だ学ばずと。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔子曰く、仲叔圉（ちゆうしゆくぎよ）は賓客を治め、祝※（しゆくだ）は宗廟を治め、王孫賈は軍旅を治む。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍旅の事は未だ之を学ばざるなりと。",
              "citation": {
                "source": "論語物語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍光の目のアテーネー、神女今はたかの者を　405擧げて汝に向はしむ、愚かや彼の胸中にヂオメーデース悟り得ず、神と戰ふ人間は壽命長きを得べからず、戰爭軍旅の間より、歸らん時に其膝に寄りてあまゆる子は無しと。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』アガメムノーン、衆の王その時答へて彼に曰ふ、『かなたに留まれ、往復の中に恐らく共々に　65相見失ふことあらむ、軍旅の間に道多し。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩乃は、ことによると主人の八雲はとうに安中城に入っているかも知れないと考えたので、急にこの軍旅へついて来る気になった。",
              "citation": {
                "source": "篝火の女",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、凱旋早々、軍旅をここに駐めて、挙行したことでもあるから。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹童があいずの狼煙をみて、この地方に敵ありと知った武田伊那丸は、白旗の森に軍旅をととのえ、裾野陣の降兵をくわえた約千余の人数を、星、流、騎、白、幻の五段にわかち、木隠、巽、山県、加賀見、咲耶子の五人を五隊五将の配置とした。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ござります――それは裾野よりご帰参の上部どのが、一月あまりお屋敷にこもって、苦心のすえ作戦された、秀吉袋攻めの奇陣、必勝の布陣、軍旅の用意にいたるまで、お書付としてご家老徳山どのへお渡しになっております」「そんなものがあったか。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田方としてみれば、この国境の遠くまで、事あるたびに甲府から出動して来ることは、並たいていな軍旅ではない。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄の病気は、浜松城を包囲して、いよいよ、三河にまで働きかけていた軍旅のうちに起ったものである。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃、わが良人には、三成とは、お心も合わず、また、その良人やわが子は今、三成の敵とする徳川殿に従いて、上杉攻めの軍旅におわすものを、何でこの身が、大坂城へ質として足を運ぼうぞ。",
              "citation": {
                "source": "日本名婦伝",
                "author": "細川ガラシヤ夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その治部大輔義元には、こんどの軍旅は、少なからぬ苦痛であったに違いない。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、陣中だし、夕方までに、なお大高まで前進する予定なので、誰も、酒の量をすごして、軍旅の疲れを呼び出すことは、誡めながら飲んではいた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に、「一挙、伊勢を併合せん」　という意気ごみで、信長自身、約五千の軍旅を整え、伊勢へ向って、出陣してくるとの報もあった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月五日まで、約三万の軍旅は整え終った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第三分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
