    "definitions": [
      {
        "index": 1,
        "gloss": "foolish undertaking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
