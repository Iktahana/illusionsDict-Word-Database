        "examples": {
          "standard": [
            {
              "text": "子供の頃、冬休みに親戚が集まると、こたつでよく軍人将棋をして遊んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍人将棋は、相手の駒が何か分からないという心理戦が非常に面白い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "押し入れの奥から、色あせた軍人将棋の駒とボードが出てきて懐かしくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "仕方がなくなると、紙に線をひいて、皆で軍人将棋をやった。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "）時々、腹逼ひになつて私に軍人将棋をすゝめたり、トランプの手合せを求めたりした。",
              "citation": {
                "source": "毒気",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
