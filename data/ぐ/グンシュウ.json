[
  {
    "uuid": "b337232a-b21f-592b-990e-e547875aa5b1",
    "entry": "群衆",
    "reading": {
      "primary": "ぐんしゅう",
      "alternatives": [
        "ぐんしゅ",
        "ぐんじゅ"
      ],
      "is_heteronym": false
    },
    "grammar": {
