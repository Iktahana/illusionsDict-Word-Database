      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "group (of people)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さうして眞黒の群衆が、何十萬とも數知れずに押し合ひながら、お玉杓子のやうに行列して居る。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不意を打たれて芳は危く昏倒せんとして、僅に身を支へた、其處を、勝に乘じた群衆はなほ、執念強く、取り包んで、凡そ息のある限り、滅多無性に打ちすゑんとする、刹那の急。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりではない、足利時代の『鷹筑波集』からも、猿楽狂言からも、また貞徳の「独吟百韻」からも、富士｜詣の群衆のざわめきは、手に取るように聞えるが、それらの参詣者は、皆この村山口を取ったものであるらしい。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐るべきは権威でなくて無批判な群衆の雷同心理でなければならない。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見物人の群衆の中に交じった自分の息子を発見した時、眼をパチパチとさせて眼くばせをした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫んだのをきっかけに、平土間の群衆騒然たり。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ジロリと、進藤等の方一睨して又群衆に向って、Ｔ「むかつく奴　居ないのか？",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆ワイワイ言っている。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉、半次を振り返り、Ｔ「喧嘩らしい」　とズカズカと群衆の方へ。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二には群衆の使い方が拙である。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今度は大きいぞ大きいぞ」と云う声が、群衆の中で、そこからもここからも起った。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅前の処刑場へ引っぱって行かれる土匪が、保安隊士に守られて、蠅のように群がる群衆や丸腰の兵士に俥上から口ぎたない罵声をあびせつつ通りかかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎馬士官と、丸腰の兵士たちが、街上になだれる群衆を制して道をあけた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惨酷な情報で、群衆の熱情をあおり立てる、その沸騰する有様を、夢中に想像していた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "群衆心理というもので御座いますかな……そのアトから又一人フラフラっと……てな訳で……。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛皮市場や祭礼の群衆の中にわれわれの親兄弟や朋友のと同じ血が流れている事を感じさせられ、われわれの遠い祖先と大陸との交渉についての大きな疑問を投げかけられるのであった。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場面の群衆の運動の排列が実際非常に音楽的なものである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそれが雑然たる群衆ではなくて、ほとんど数学的「鋼鉄的」に有機的な設計書の精細な図表に従って、厳重に遂行されなければならない性質のものである。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はあなた方の仕事をする番が来た」と言いながら、悪魔のように殺気立った群衆に取り囲まれて保安裁判所に引かれていく……　仏国革命に現われでる代表的人物の中でことに気に入ったマラーの最後のありさまは、これだけ込み入った光景をただ一瞬間に集めて、ともすれば西山の頭にまざまざと浮びでた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘心はおびただしい群衆のぞよめきに軽く酔ったらしく頬のあたりを赤くしていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこらにいる群衆の眼は申し合わせたように奥さんの方に吸い寄せられていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十七「晩方で薄暗かったし、鼻と鼻と打つかっても誰だか分らねえような群衆だから難かしいこたあねえ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町々の町役人は鉄棒でそれらの群衆を制してゐたが、見物人はあとからあとからと押寄せてくるので、迚もそれを追ひ払うことは出来なかつた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんばそれが耳かきですくう程のささやかな己惚れにせよ、人はそのかけらにすがって群衆の波に漂うているのではなかろうか。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻の先にぶら下げていた眼鏡を、群衆の波にもまれているうちに失ってしまって間誤まごする人のようになってしまうのだ。",
              "citation": {
                "source": "僕の読書法",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの大道芸人が群衆の前にその醜い髯面をさらすように！",
              "citation": {
                "source": "雑信（二）",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも急がしく、あわただしく、群衆によつてもまれてゐる、不思議な物悲しい郵便局よ。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女は目も眩むほど不快の気持に堪えて歩いて行くと、やがて二つの感情はどうやら、おのおのの持場持場に納まり、沖の遠鳴りのような、ただうら悲しい、なつかしい遣瀬なさが、再びかの女を宙の夢に浮かして群衆の中を歩かした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
