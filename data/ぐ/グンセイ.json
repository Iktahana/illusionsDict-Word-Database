      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "county system",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "国と言うと、国郡制定以後の国と紛れやすいゆえ、いまこれを村と言うておこう。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの当主はもう七十近い老人だが、まだ郡制のあつた先年まで郡の医師会長だつた人で、この地方での一二と云はれる有力者でもあつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国と言ふと、国郡制定以後の国と紛れ易い故、今此を村と言うて置かう。",
              "citation": {
                "source": "最古日本の女性生活の根柢",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "各郡ではまた郡制廃止の記念とし、やはり厖大な郡誌などを編輯公刊して、その序文にはいずれも郷土研究の抱負が掲げてある。",
              "citation": {
                "source": "地名の研究",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
