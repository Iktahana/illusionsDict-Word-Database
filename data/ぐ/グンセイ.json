[
  {
    "uuid": "c75cf139-b68c-5ea7-9e60-73231d40b5f5",
    "entry": "群生",
    "reading": {
      "primary": "ぐんせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
