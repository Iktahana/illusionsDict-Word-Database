[
  {
    "uuid": "83c68486-bcac-5ce8-accb-4b771f26eb58",
    "entry": "愚痴",
    "reading": {
      "primary": "ぐち",
      "alternatives": [
        "グチ"
      ],
      "is_heteronym": false
    },
    "grammar": {
