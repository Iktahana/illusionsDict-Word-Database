        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日劇を、ぐるりと取り巻いている入場者の長蛇の列を見ると、私は、ひどく重い気持になるのである。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつはからだのぐるりを趣味でかざっているのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "植木が好きで、學校のぐるりに樣々の植木を、優雅に配置し、ときどき、ひとり、兩手をうしろに組んで、その植木の間を、ゆつくり縫つて歩いてゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼津の濱にあがつたのならば、まあ、ぐるりと日本海のはうにまはつて、丹後の濱においでになつてもらつても、そんなに生物學界の大騷ぎにはなるまいだらうと思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しもう少し好い處をと思つて歩いて居る中に、とう／＼ぐるりと一※りして元の公園の入口へ出てしまつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもし一室の内をぐるりと取り巻く大きな硝子管の中が一体に光るようなものが出来れば、この不便をよほどなくする事が出来るだろう。",
              "citation": {
                "source": "ムーア灯",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸の外を、桜｜樹立がぐるりと囲む……桜が……しんしんと咲き静まった桜樹立が真夜中に……棟を圧して桜樹立が……桜樹立がしんしんと……私は、ぞっとして夜具をかぶった。",
              "citation": {
                "source": "病房にたわむ花",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い光束が低い雲の底面を撫でてぐるりと廻るのが見える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、女からそむけた視線をそのままにぐるりとあたりを見まはした。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十秒、二十秒、三十秒、私は部屋の中をまたぐるりと見廻した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は堪りかねて部屋の中をぐるりと見廻した。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨時運転だからコースが変わったのかと思っていると、運転手が突然「オーイ、オイ、冗談じゃあないよ」とひとり言を言ってぐるりと車を引き返して呉服橋のほうへあともどりした。",
              "citation": {
                "source": "破片",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼いた手を痛そうに、他の手で押えながら顔をあげて、ぐるりをはゞかるように見わたした紅は、小山の視線に出会すと、すぐ、まだ煙が出ている木箱の方へ眼を伏せた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、百姓はぐるりへたかってくる人々へ説明した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家のぐるりを一周して納屋へ這入って見た。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその人達はそれらしく動きまわる気配もなく依然として寝台のぐるりに凝立していた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは寝台のぐるりに立ちめぐっていた先ほどの人びとの姿が、ある瞬間一度に動いたことであった。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きている窓はなく、深夜の静けさは暈となって街燈のぐるりに集まっていた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぐるりに人がたくさん集まって見ていましたよ。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその娘の家のぐるりを歩いてはその下のベンチで休むのがきまりになっていました。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　いうことば半ばにして海野はまた感謝状を取直し、ぐるりと押廻して後背なる一団の軍夫に示せし時、戸口に丈｜長き人物あり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "銅色の太陽がもうよほど低く垂れ下がって、葉をふるった白樺の梢にぐるりぐるりと廻っているように見えた。",
              "citation": {
                "source": "夢",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "親熊は突然あと足を折って尻もちをつくような格好をして一度ぐるりと回るかと思うと、急いで駆け出すが、すぐに後ろを振りむいて何かしら自分の腰に食いついている目に見えぬ敵を追い払おうとする様子をする。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "両方でかみ合ったままで、ぐるりぐるりと腹を返して体軸のまわりに回転する。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あのぐるりぐるりと腹を返して引っくり返る無気味さは、やはり、虎よりも鰐の属性にふさわしく思われるものである。",
              "citation": {
                "source": "映画「マルガ」に現われた動物の闘争",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
