    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) humble opinion",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
