        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "マクスウェル付きの demonstrator が辞任したあとへグレーズブルックとショー（R. T. Glazebrook & W. N. Shaw）が就任した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "B. A. の方法によって一八八一年に得た結果は、これと同時にグレーズブルックが他の方法でやったものとよく一致した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室ではグレーズブルックとショーが引受けていて時々病床へ何かの相談に来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究所長にグレーズブルックが推挙されたのは、レーリーの考えから出たに相違ない。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一九年彼の死ぬる少し前に辞表を出し、間もなくグレーズブルックも停年で退職した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ味もそっけもないイギリス風（ア・ラングレーズ）の食事をすすめる。",
              "citation": {
                "source": "ブイヨン・ドンゾール",
                "author": "――十一時の肉の煮出し――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
