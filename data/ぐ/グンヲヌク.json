        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の描く絵の繊細さは、同年代の学生の中でも群を抜いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "今年の新人王候補の中で、彼のバッティングセンスは群を抜いて素晴らしい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このレストランのサービスの質は、近隣の競合店と比べても群を抜いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "東　にくまれ子は世にはびこる西　おなじ　舐犢の愛を受けて長ずるものを貶して、祖母育ちは三百｜廉いといへる諺に引かへ、憎まれ子の世に立ちて名を成し群を抜くことを云へる、東西共に同じきもおもしろし。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに二十万円を切ると同時に、群を抜く小型、軽量化を実現して日本市場に新しい領域を開いたダイナブック開発においても、横綱のリーダーシップは貫き通された。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ知能が世に先だって群を抜く人は、多くこれ等の光景に遭遇してこの滋味を知り、他人が視てそして難しいとするところを為し得たのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "群を抜く鋒杉が見えると思うと茜色に梢を染められ、それがまた非常に鮮かに虚空にうかんで見える。",
              "citation": {
                "source": "茸をたずねる",
                "author": "飯田蛇笏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
