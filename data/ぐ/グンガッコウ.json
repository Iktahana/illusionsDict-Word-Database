        "examples": {
          "standard": [
            {
              "text": "彼は国を守るという強い決意を胸に、厳しい選抜を勝ち抜いて軍学校に入学した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍学校での生活は規則が非常に厳しく、毎朝決まった時間に起床しなければならない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍学校の卒業式では、若き将校たちが誇らしげに制服を身にまとっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ここに海軍学校あり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、三隅氏と同行して、中学校および陸軍学校を一覧す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八二九年には、ロンドン郊外のウールウイッチにある王立の海軍学校に講師となり、一年に二十回講義を引き受けた。",
              "citation": {
                "source": "ファラデーの伝",
                "author": "電気学の泰斗",
                "note": "青空文庫"
              }
            },
            {
              "text": "競技は帝国海軍学校の近くの広い練兵場で行われたが、これは広々した平坦な原で、そこに立った時私は、どうしても米国にいて野球の始るのを見ようとするのだとしか思えなかった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "海軍学校に属する日本人の軍楽隊が音楽を奏したが、非常に上手にやった。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
