[
  {
    "uuid": "2665e335-5469-513a-9148-7d4de1ea9579",
    "entry": "軍学",
    "reading": {
      "primary": "ぐんがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "military science",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "宇平太の嫡子順次は軍学、射術に長じていたが、文化五年に病死した。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世、由比正雪が楠木流の軍学などと称したものも、武田の兵法を太平記に結びつけたものである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神道も仏道も儒教も軍学も、この場合にはなんの値いもない。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも足りずば篠崎流折紙つきの縦横無尽なる軍学智略で行くのだ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らばそろそろ篠崎流の軍学用いて、否やなく開門させて見さしょうぞ。",
              "citation": {
                "source": "旗本退屈男　第四話",
                "author": "京へ上った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが右門流の軍学というやつだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "よいよい、信徒を荒し霊地を荒す鼠賊めを、霊地を預かり信徒を預かる院代が匿もうて、五万石の寺格が立つと申さるるならば、久方ぶりに篠崎流の軍学大出し致してつかわそうぞ。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが僧衣の陰に隠して、飽くまでも匿まおうと言うなら、まことに篠崎流の軍学以外にひと泡吹かする途はない。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "篠崎流軍学の必要もない。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、久方ぶりに篠崎流の軍学小出しに致して、ゆっくり化物屋敷の正体見届けてつかわそうぞ。",
              "citation": {
                "source": "旗本退屈男　第九話",
                "author": "江戸に帰った退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしも軍学習うたつもりじゃが、若い者の智慧には敵わぬわい。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい槻の板に「実用流軍学兵法指南　相馬大作将実」　と、書いたのが、門にかかっていた。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔｜武田信玄と上杉謙信はたがいに覇業を争うた、その結果として双方はたがいに研究しあい、武田流の軍学や上杉風の戦法などが日本に生まれた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の父はさほど漢学を深くも修めていなかったが祖父なるものは徂徠派の学を究め、旁ら甲州派の軍学も印可を受るまでになっていた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃藩でもいよいよ戦備をせねばならぬことになったので、軍学をも奨励して、従来あった源家古法の野沢家と、甲州流の某家とに意を嘱して弟子を奨励せしめた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この曾祖母は向井氏で藩では有名な軍学者三鶴の孫だが、戸主たる兄が或る不心得から家名断絶となって、実兄の竹村家に養われ、そこから私の家へ嫁したのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この祖父は経書では徂徠学を修め、甲州流の軍学にも達していて、旁ら文章や詩も作っていたので、その遺稿は今も存している。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜しかも同じ時刻に、旗本近藤｜石見守は、本郷妻恋坂の坂の上に軍学の道場を構えている柴田三郎兵衛の宅へ押し寄せた。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍学者などの浅まな物識りぶつた説明に縋らずとも、旗さし物の起り位は説け相に思ふ。",
              "citation": {
                "source": "幣束から旗さし物へ",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、軍学者一流の事始めを説きたがるてあひに、其がある時、ある一人のだし抜けの思ひつきによつて、今のまゝの姿をして現れた、ときめられ勝ちであつた。",
              "citation": {
                "source": "まといの話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "よっぽど出来る先生かって、左様、よくは知らんがな、土佐の人だとかいったよ、真影だ、それと甲州流の軍学を心得ていたということだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "畜生谷の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
