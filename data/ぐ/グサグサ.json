        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "犯人は凶器で被害者の体をグサグサと刺し、そのまま闇に消えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "庭の雑草を抜くために、土にフォークをグサグサと突き立てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "穴だらけになったクッションには、針がグサグサと刺さったままだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "こういう手際がワフタンゴフになると、こうゆかないでグサグサしてしまう。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "(words) cutting to the heart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
