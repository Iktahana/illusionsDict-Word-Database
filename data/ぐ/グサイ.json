[
  {
    "uuid": "585ecccb-dcc1-52fd-9575-121c7ceedec3",
    "entry": "供祭",
    "reading": {
      "primary": "ぐさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "offerings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それからそれへと連想して、古田の天神様の子供祭には自分が一年隊長になつて、一晩あの鎮守の森の祠で大勢の子供と寝て騒いだ事など思ひ出す。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、祭日又は季節に基づく名稱節供祭　　　　　　舊三月三日、播磨北條住吉神社たのも祭　　　　　八月朔日、羽前三山神社等つゆの祭　　　　　栗花落祭、飛騨栗原神社等雪祭　　　　　　　正月十五日、信州新野伊豆神社だら／″＼祭　　　　七日間の祭、下總千葉神社など二、祭地祭場　是には明かに二通りの式がある。",
              "citation": {
                "source": "祭禮名彙と其分類",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "つめたい汁のやうなものが感じられた、そのとき指と指とのあひだに生ぐさい液体がじくじくと流れてゐるのをかんじた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまぐさい春のにほひがする。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血なまぐさい軍服や、襦袢は、そこら中に放り出された。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまぐさい臭いが人々の立ち騒ぐ袖や裾にあおられて鼻を打つ。",
              "citation": {
                "source": "忘れえぬ人々",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等が戦線からロシヤバーに帰って来る時、皮下の肉体にまで、なまぐさい血と煙硝の匂いがしみこんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生ぐさい血に染った土が薄気味悪く足に触れた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死者の女房は、群集の中から血なまぐさい担架にすがり寄った。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛肉屋の前を通つた時のやうな一種の血なまぐさい香が忽ちに清淨な空氣を汚なくした。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生ぐさいものを食うと、反吐が出る」「ほな、何を食うんや」「人を食う。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日は、どうも、少しなまぐさいね。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、劈頭の手紙の全文から立ちのぼる女の「なま」な憎悪感に就いては、原作者の芸術的手腕に感服させるよりは、直接に現実の生ぐさい迫力を感じさせるように出来ています。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左様した立場から眺めると、如何に凄じい光景でも、如何に腥ぐさい舞台でも、それに相応した内面的背景を具へて居ないといふ点に於て、又それに比例した強硬な脊髄を有して居ないといふ意味に於て、浅薄な活動写真だの軽浮なセンセーシヨナル小説だのと択ぶ所がないやうな気になる。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助君はしばらくのぞいていると、なまぐさいいやなにおいが鼻につきはじめた。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その着物に、家の中のあの貧乏のにおいや、ポンツクのなまぐさいにおいをつけて、学校へやってくる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前にも申す通り、なにぶん血なまぐさい世の中ですから、人間の首も今ほどには珍らしく思われない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――をしっかりと、あのあらゆる力と情とをこめて、彼女を抱き締めることの回想と予想とで、血なまぐさい、汚れた、現実的な、ボーイ長の問題などは、その余地を頭の中へ置き得ようはずがないのであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然は、生きている、という当り前の事が、なまぐさいほど強く実感せられた。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「慶長元和の血なまぐさい世の中と、太平百余年の今日とは、世のありさまも違えば人の心入れも違うぞ。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまぐさい血の匂いがかれの鼻にしみた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなまぐさい血の臭いを避けるように、かれは鼻をしかめながら采女の方をうかがうと、まぼろしの人はそれを飲めと勧めるようにうなずいて見せた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "獣のなまぐさい生き血を啜って、小坂部はなんだか眼がくらんで来たように感じられた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分ですらそっと手もつけないで済ませたい血なまぐさい身の上を……自分は老人ではない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏道に帰依して、二、三十年の間は、少しもなまぐさいものを口にしなかったが、あるとき、友だちの一人が松江の鱸を煮ているところへ往き合せたことがあった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は張風のように、別になまぐさいものを断っているわけではないが、春になって、そこらの海がぼんやり霞んでいるのを見ると、生れ故郷の瀬戸うちの海を思い出して、そこで捕られた魚の金粉を吹いたような鱗をなつかしがることがよくある。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――長らく吹きすさんでいた血なまぐさい風は、その御一新の大号令と一緒に、東へ、東へと吹き荒れていって、久方ぶりに京にも、平和な秋がおとずれたかと思ったのに、突如としてまたなまぐさい殺気が動いて来たのである。",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたをあけてみると、中はぐっちゃり……なまぐさい異臭がぷうんと鼻を刺しました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "血の降るへや",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜その女優の楽屋を訪れると、女ばかりが肌ぬぎになって鏡台に対ってゐる生ぐさい光景に少し圧倒されてゐると、ドロドロドロと太鼓が鳴った。",
              "citation": {
                "source": "移動",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
