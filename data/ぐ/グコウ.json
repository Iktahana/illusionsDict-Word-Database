[
  {
    "uuid": "9866a48a-8540-5974-8865-17da519a9f27",
    "entry": "愚行",
    "reading": {
      "primary": "ぐこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
