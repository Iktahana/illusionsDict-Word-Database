    "definitions": [
      {
        "index": 1,
        "gloss": "Gramophone (UK music magazine)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
