        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たしか浅井和田両画伯の合作であったかと思うがフランスのグレーの田舎へ絵をかきに行った日記のようなものなども実に清新な薫りの高い読物であった。",
              "citation": {
                "source": "明治三十二年頃",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクスウェル付きの demonstrator が辞任したあとへグレーズブルックとショー（R. T. Glazebrook & W. N. Shaw）が就任した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "B. A. の方法によって一八八一年に得た結果は、これと同時にグレーズブルックが他の方法でやったものとよく一致した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験室ではグレーズブルックとショーが引受けていて時々病床へ何かの相談に来た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "研究所長にグレーズブルックが推挙されたのは、レーリーの考えから出たに相違ない。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九一九年彼の死ぬる少し前に辞表を出し、間もなくグレーズブルックも停年で退職した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレートヘンである。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は前庭の日なたで繭を※ながら、実際グレートヘンのように糸繰車を廻していることがある。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シャン／＼／＼と雪ぞりの鈴が聞こえ、村の楽隊のセレネードに二階の窓からグレーチヘンが顔を出す。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、シューベルトの歌曲「糸車のグレーチヘン」は六拍子であって、その伴奏のあの特徴ある六連音の波のうねりが糸車の回転を象徴しているようである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の音楽隊がセレナーデを奏して通るのを高い窓からグレーチヘンが見おろしている、といったようなきわめて甘いたわいのない子供らしい夢の中からあらゆる具体的な表象を全部抜き去ったときに残るであろうと思われるような、全く形態のない幻想のようなものである。",
              "citation": {
                "source": "詩と官能",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうサ、僕はその頃は詩人サ、『山々｜霞み入合の』ていうグレーのチャルチャードの飜訳を愛読して自分で作ってみたものだアね、今日の新体詩人から見ると僕は先輩だアね」「僕も新体詩なら作ったことがあるよ」と松木が今度は少し乗地になって言った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうサ、僕はその頃は詩人サ、『山々霞み入合の』ていうグレーのチャルチャードの飜訳を愛読して自分で作ってみたものだアね、今日の新体詩人から見ると僕は先輩だアね」「僕も新体詩なら作ったことがあるよ」と松木が今度は少し乗地になって言った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともちゃんが家を出ようとすると、お母さんが「ともや、ここにこんなものが取ってあるから食べておいでな」といって、鼠入らずの中から、ラーヴェンダー色のあんこと、ネープルス・エローのきなこと、あのヴェラスケスが用いたというプァーリッシ・グレーの胡麻……戸部うなり声を立てる。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしに残つてゐるものはグレー・ハウンドの犬一｜疋と紋章旗だけだ。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は犬小屋できゆう／＼鳴いてゐるグレー・ハウンドを引出してちよつとブラシュをかけ、それからそれを連れて牛乳を買ひに街へ出た。",
              "citation": {
                "source": "雪",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三「グレープ・ジュース、氷沢山入れてね。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私は、私の友人でニューヨークの警務局の、ウィルソン・ハーグレーブに、海底電信を打ってやったのです。",
              "citation": {
                "source": "暗号舞踏人の謎",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャコールグレーの小さなマシンは、白地の画面に黒い文字を浮かび上がらせました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ通訳のお姉ちゃんはアラン・ケイのあまりに翔んだお言葉に何が言いたいのかさっぱり訳分からないようで、白と言ったのが黒になったりグレーになったりと、かつてのオレの「幸せなら手をたたこう」の演奏もかくやと思わせる迷調子（ああ、お姉ちゃんの悪口言うと胸が痛む）。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時王の使｜喚いて彼を海へ追い込み、牝馬を伴れ帰って介抱すれば、海馬生まると（一八一四年版ラングレー仏訳『シンドバード航海記』一二頁）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せた坊主は終夜休まず走って朝方｜荘官方へ著き、怪しからぬ屠家へ宿った、同伴は続いて来ぬから殺されたは必定と訴え出たので、荘主フォルス卿、急ぎ人を馳せて検察せしむると右の始末と、聞いた者一人も泣かずに済んだと、後日フォルス卿がフランシス一世王の母アグレームン女公の臍に茶を沸かしめて語った由。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、この古井戸がどうなろうとも、この中坂はグレート馬琴が半生を暮した故居の地として永久に記念されべき史蹟である。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "クロスビーと、グレース・スリックと、あとひとりはだれだっけ、ポール・カントナーだったかな」　tri- は三を示す接頭辞で、triad というのは、たとえば「三和音」のように、なんであれ、三つでひと組のものをいう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年前に長い賜暇期日が終わったので、グレーヴセントからボンベイへ帰る船中で、ボンベイ地方の士官の妻のアグネス・ケイス・ウェッシントンという女と一緒になったのが、そもそも私の運命――わたしの大きな不運であった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "天井を縦断している二条のレールをワイヤー・プレーをギリ／＼と吊したグレーンが、皆の働いている頭のすぐ上を物凄い音を立てゝ渡って行った。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "横ボール盤の側に、四五人の職工とパンパン帽をかぶった職長が集って、ワイヤー・プレーを跛に吊したグレーンがガラ／＼と寄ってくるのを見ていた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーンがとまると、ワイヤー・プレーは余勢でゆるく揺れた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレーンが喧しい音をたてゝ、チエンを捲き上げた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
