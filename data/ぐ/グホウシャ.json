        "examples": {
          "standard": [
            {
              "text": "真理を求める若き求法者は、険しいヒマラヤの山道を越えて聖地を目指した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古代の求法者たちが持ち帰った経典は、翻訳を経て東アジアの文化形成に寄与した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は自らを一介の求法者と称し、名声や富には目もくれず修行に励んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "此等支那の大徳は、そのあらゆる蘊蓄を傾けて、海外の求法者を啓沃した。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            }
          ]
