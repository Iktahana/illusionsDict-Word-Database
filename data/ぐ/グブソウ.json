        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "本尊の護持を任された供奉僧が、静寂の中で読経を続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "寺院の重要な法要では、供奉僧たちが色鮮やかな法衣を纏って列をなす。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "彼は若くして供奉僧に抜擢され、先代の住職から厳しい指導を受けてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
