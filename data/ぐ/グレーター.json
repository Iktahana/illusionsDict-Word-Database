        "examples": {
          "standard": [
            {
              "text": "パスタの仕上げに、チーズグレーターでパルミジャーノを惜しみなく削り落とした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "生姜をすりおろす時は、この目の細かいグレーターを使うと口当たりが滑らかになる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "キッチン雑貨店で、レモンの皮を薄く削れるゼスタータイプのグレーターを購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "かのパンジャーマニズムとか、パンスラヴィズムとか、グレーターブリタニズムとか、パンアメリカニズムとかいうの類は、すべてこの民族的国家が帝国主義を行わんとする思想を説明したるものに外ならぬ。",
              "citation": {
                "source": "文明史上の一新紀元",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            }
          ]
        }
