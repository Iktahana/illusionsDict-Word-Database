[
  {
    "uuid": "9bb083cb-06b7-545f-b8f7-57081f4bc97d",
    "entry": "愚兄",
    "reading": {
      "primary": "ぐけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "(one's) older brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "愚兄がいつもお世話になっておりますと、妹は深々と頭を下げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "愚兄は昔から詰めが甘く、今回もまた投資で失敗したようです。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "正月に帰省した際、愚兄と酒を酌み交わしながら昔話に花を咲かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "愚兄の内　此佐井ハ北奉行人町杉山佐井虎次郎幸助方ニて御尋可被遣、此杉山にも私の咄御なし可被遣候。",
              "citation": {
                "source": "続　手紙",
                "author": "宛先き、年月日、未詳（推定、慶応二年春）",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍馬が乳母此うバわ私しお、きづかいおり候ものゆへ、何卒此ぶじなる事を御直ニ御申、愚兄が家（へ）御出被下候時に御まねき被成候得バ、早※参上仕候。",
              "citation": {
                "source": "続　手紙",
                "author": "宛先き、年月日、未詳（推定、慶応二年春）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……愚兄より」こんな意味の事が書き記されてあった。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "コルシカの伝統というもので、族長風で、ナポレオンはあんなに愚兄愚弟及び愚妹をひき立てた。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "愚兄と賢弟一　出稼ぎの遠征軍は、風のままにうごく。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "海鳥のひなは、卵から出ると、おしりに卵の穀をつけたまま、すぐに歩く練習をはじめ、少し歩けるようになると、ろくに羽ものびないのに、もう飛ぶ練習をはじめ、なぎさでおよぐけいこする。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "foolish older brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "成績優秀な弟に比べて、ギャンブル好きの愚兄にはほとほと愛想が尽きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "愚兄のしでかした不始末を、家族全員で必死にカバーしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「あんな愚兄の言うことなんて真に受けるな」と父が吐き捨てた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
