        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と、彼は土器の水呑みでグビグビやりながら語をついだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "久助はグビグビと咽喉を鳴らした。",
              "citation": {
                "source": "忠僕",
                "author": "池谷信三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は喉をグビグビ云わせながら家へ帰った。",
              "citation": {
                "source": "罠に掛った人",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か言おうとして咽喉をグビグビさせたけれど、幸いに、ちょうどその時に合図の花火が揚りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん」　うなずいてグビグビと一気にあおって、「サ、お前たちも大きいものでどんどんおやり」　ホホー、これは面白い。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "また新しい悲しさ腹立たしさに全身を煮え返らせながら、グビグビグビと今松は湯呑の酒を咽喉へ流し込んだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一升ビンとチヨコを持つてグビグビ飲んでゐる。",
              "citation": {
                "source": "おスミの持参金",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱燗を頼んでグビグビやりながら、隅の方を見ると、一人の洋服青年が、こちらに顔を向けて、ニヤニヤ笑っていた。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはもう、喉をグビグビ云わせながら、嬉しさに夢中になって、その髪の毛を握りしめ、グイと持上げようとした。",
              "citation": {
                "source": "白髪鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "女が立ち去った途端、少佐が部屋を横切り、ブランデー瓶を取り出し、手酌でグビグビ飲んだ。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "宅助の仲間根性が、喉をグビグビさせて怨んでいるのに、三人は朝酒の酔いを顔に発して、さいつおさえつ話の興に入っている。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
