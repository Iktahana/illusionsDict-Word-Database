        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彫像の眼球をグサリと刺した。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死に切っている男の左の背後には、鋭い短剣らしいものがグサリとつき刺さっている。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は口腔内にも光があるのを確かめてから、死体を俯向けて、背に現われている鮮紅色の屍斑を目がけ、グサリと小刀の刃を入れた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後から抱えられて、グサリと突き立てられたとき、屍体には、屈むのと、伸びる反射運動とが連続して起るのだ。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、滝人の手が――こうも一つの殺人が神経を鈍麻させたかと思われるほど――機械的に動いていって、振子の上に布片を幾重にも捲き、その先の剣針を歯齦の間に置いて、狙いを定めくらの咽喉深くにグサリと押し込んだ。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "グサリと短刀を頬へつきさす。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな仕掛にたよるよりも、短刀でグサリと突きさす方が確実である、ピストル、毒薬、直接、自ら手を下してジカに殺す方が間違いの少いのは明かだ。",
              "citation": {
                "source": "推理小説について",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら考えても直接グサリとやるよりも失敗率のすくない仕掛などは殆どない。",
              "citation": {
                "source": "推理小説について",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この短刀で、心臓をグサリと突くことも出来るし、お好みなら、指一本一本切ってもいい。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして不思議なことに、翅も六本の足も※りとられ、そればかりか下腹部が鋭利な刃物でグサリと斜めに切り取られている変な蠅の死骸だった。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を罵倒する無数の汚らしい言葉が発達している上に、実にエゲツなくグサリと人の弱点を突き刺す言い方が自在に口から出る仕組みになっているらしい。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "道頓堀罷り通る",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにもグサリと喉元へきそうだった。",
              "citation": {
                "source": "金狼",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "鷲や鷹ならば、爪でグサリと掴みかかるにちがいないから、一つや二つの爪傷ではすみますまい」「無学な徒と応対していると世話がやけてやり切れない。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "母猿は子猿を抱えて立ちむかってくるが、目つぶしを食わされ、網をかぶされて、地べたへころがされる……そこを、乳の下を目がけて、銃剣でグサリと突くんだ。",
              "citation": {
                "source": "蝶の絵",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、親父の非難にはグサリと来た。",
              "citation": {
                "source": "もしも世界",
                "author": "THE WORLDS OF IF",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮腫の治療にはサルトリイバラ、サンシキヒルガオ、キングサリ、など、が試みられる。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "その辺の砂が血のりでドロドロになっていたが、なお掻きのけると、短刀は丁度心臓の部分に、根元までグサリと突きささっていた。",
              "citation": {
                "source": "孤島の鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が死んだという衝撃はまだ胸にグサリと来ておらず、なお自分のことを考える余裕があった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "この革のうしろから、鋭いナイフで、彼の心臓を目がけて、グサリと一突きしたなら、どんな結果を惹起すであろう。",
              "citation": {
                "source": "人間椅子",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "一挺の短剣がわらのしんまでグサリと突きささっているではないか。",
              "citation": {
                "source": "吸血鬼",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "右腕のつけ根に、グサリ突刺って、まだブルブル震えている短刀。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶねえあぶねえ、うっかり起き上がろうものなら、こんどは光ったほうで、グサリとほんとにやられるかもしれない）　こう考えて、死んだまねをしているらしい。",
              "citation": {
                "source": "神州天馬侠",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのための首カセや腰グサリだ。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして程なく、武松の身柄は、この地からさらに遠い、　恩州牢城送り、　となって、即日、腰グサリ首かせの身を、二人の獄役人の手で押送されて行ったのだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "“白石毛”とよぶ白馬にまたがり、赤地錦の直垂に、緋おどしのよろいを着、兵庫グサリの丸鞘の太刀をはき、重籐の弓をお手に、鵠の羽の征矢をえびらに負っておられたという。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
