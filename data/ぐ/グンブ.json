    "definitions": [
      {
        "index": 1,
        "gloss": "military authorities",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「大本営陸海軍部発表。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に一個の秘密がある、此秘密は私と、私の腹心の三十七｜名の水兵と、帝國海軍部内の某々有司の他には、誰も知つて居る者は無いのです、また、决して、他に洩すまじき秘密ですが、今斯くなつて同じ境遇に、長き月日を暮す間には、何時か君等の前に、其事の表顯ずには終るまい。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、軍部の奴らは、戦争の名に於て殺人を奨励している。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに、軍部は国民を皆殺しにしようと計画していたのだが、聖上陛下が国民の生命をお救い下すったのであると、私は思った。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、国民に懺悔を強いる前に、まず軍部、重臣、官僚、財閥、教育者が懺悔すべきであろうと思った。",
              "citation": {
                "source": "終戦前後",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三井物産の重役が来ると不景気の救済策を授け、外務大臣が来ると軍部の実力を説いて感心させ、軍部の首脳部と会談すると外交の妙諦を説法して頭を掻かせる。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間、一九三二（昭和七）年の五・一五事件、一九三六年の二・二六事件と軍部の青年将校によるクーデターが繰り返される中で、政治に対する軍の影響力は強まっていきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼軍当局が「従軍作家よ、まあ焦らずに悠つくりと先に行つてから傑作を書くさ――」と言つたとしても、それを早呑込してはいけない、従軍作家はどうも軍部の親心や、軍部の真意を解してゐないやうだ。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "故老の話によると、郡中にはこの怪物が居りまして、軍部に何か異変のあるたびに、かれは姿をあらわします。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん軍部をはじめ諸官省や諸機関においては、最大の注意力を傾けて、この恐るべき外敵の攻撃を防ぐことを考えている。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなら紅国軍部は税関本部に通牒して鼠の輸入を黙許させればよかったと思うかもしれないけれど、そこがそれ軍機の秘密であった。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "計略ハ密ナルヲ良シトスだの、敵ヲ図ラントスレバ先ズ味方ヲ図レなどという格言は紅国軍部といえどもよく心得ているのであった――というような結末まで、ゆっくり探偵小説に書いていると、いくら枚数があっても……。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしドイツ軍部もこの頃は国防の根本に対する熱情が充分でなく、ややもすれば行き詰まりの人事行政打開に重点を置いて軍拡を企図した形跡を見遁す事が出来ない。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくてドイツは統帥部の「こうなった以上は徹底的に」と云う主張に引きずられ、軍部も実は自信を失い政治はもちろん信念はなかったに拘らず、遂に行く所まで行ってベルサイユの屈辱となったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしてかくの如き厖大な兵器の生産は宜しく政治家、経済人に一任すべく、軍部は直接これに干与することは却って迫力を失う事となる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "防空総司令官を任命（成し得れば宮殿下）し、これに防空に任ずる陸海軍部隊および地方官憲、民間団体等を総て統一指揮せしめる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日、数日ぶりに新聞を読んで政界の風雲急なるに驚いた、たうとう軍部と政党とが正面衝突して、解散か総辞職かで緊張しが、脆くも広田首相は辞表を捧呈した、まことに日本の現在は『疾風怒濤時代』である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（上海日本海軍部公報）大空澄みわたる　　日の丸あかるい涙あふるる　　（山生）　十二月十五日　快晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府対議会（軍部対議会といつた方が痛切だらう）、その接触交渉がなか／＼微妙らしい、大西少佐の失言、政党本部占拠事件、右翼（？",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "武器を支那へ売りこもうとして失敗して以来、日本の軍部でも次第に独逸製品を拒むような機運が向いて来た。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "未組織の文学愛好者、特に婦人の間に多くの読者をもっている三上於菟吉、直木三十五などというブルジョア作家たちは手をつないで軍部の雇作家になった。",
              "citation": {
                "source": "国際無産婦人デーに際して",
                "author": "――作家同盟各支部に婦人委員会をつくれ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（追記・日本軍部による張作霖の爆死事件につづく侵略）　異国情調を求めて来ていた群司次郎正は一躍、「ハルビン脱出記」の筆者となった。",
              "citation": {
                "source": "プロレタリア文学における国際的主題について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拙劣な真似に、日本の軍部の方式があった。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍部がその部落に二百円の強制献金を割り当てた。",
              "citation": {
                "source": "一連の非プロレタリア的作品",
                "author": "――「亀のチャーリー」「幼き合唱」「樹のない村」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファシズムというと、わたしたちはすぐ戦争中のままの形で超国家的な大川周明の理論や、憲兵の横暴や、軍部、検事局その他人民を抑圧した天皇制の機構全体を頭にうかべて、なんとなしその全体に体当りで抵抗するのがファシズムへの抵抗という感じをもって来ていると思います。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの「秘史」「ルポルタージュ」が真実の軍部批判と戦争批判、日本の平和建設の誠意をどの程度までたたえているでしょうか。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍部の「怪文書」が乱れとんで、出所も正体もわからないまま、五・一五、二・二六と人心をかきみだして行って、遂に、無判断無批判にならされた人民を破滅的な戦争に追いこんで行ったいきさつは、こんにちあらわれる二・二六実記と称するものをよんでさえ、よくうかがえます。",
              "citation": {
                "source": "新しい抵抗について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍部の暴圧をしのんで艱難な日々をしのいでいた何の抵抗力ももたないおとなしい人民の男女、老人子供たちが、日本列島を戦略地点として確保することをいそいだ原爆によって、屍を重ねたのだった。",
              "citation": {
                "source": "「人間関係方面の成果」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこの杉浦というやつが、図々しくって押しが太くて、鼻柱が強くて、大臣宰相でも、公爵でも、何の遠慮もあらばこそ、ぐんぐんぶつかって行く男なのです。",
              "citation": {
                "source": "Ｍ侯爵と写真師",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いマント家鴨は水飲んでつめたからうぐんぶぐんぶ水飲んでつめたからう家鴨に赤いマント買つて着せよう赤いマント　可愛から買つて着せようマント屋の　赤いマント買つて着せよう。",
              "citation": {
                "source": "十五夜お月さん",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
