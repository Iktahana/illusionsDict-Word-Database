        "examples": {
          "standard": [
            {
              "text": "「じゃあ、そろそろ寝るね。グッドナイト！」と彼女は電話を切った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供たちはベッドに入り、母親に「グッドナイト」と言って眠りについた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "会議が終わり、皆が「グッドナイト」と互いに言い合って解散した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "警官が要領を得ずに引きあげて行くと、やがてラストのグッドナイトの曲が聴えて来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の子供達は、床につきます前に、必ず『パパ、グッドナイト、プレザント、ドリーム』と申します。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "バンドは、ラストの「グッドナイト・スイートハート」を奏でていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルイジアナ刑務所から一九四〇年に出所してきたレッドベリは『グッドナイト、アイリーン』をレコードにした。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
