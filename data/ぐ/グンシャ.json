        "examples": {
          "standard": [
            {
              "text": "重厚な装甲に覆われた軍車が、爆音を響かせながら市街地を行進していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敵の攻撃で炎上した軍車が、道路を塞いで後続の部隊を足止めしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新鋭の通信設備を備えた軍車が、作戦の司令塔として機能している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それから彼の死骸を自分の軍車に縛りつけてまたトロイの城壁を三度｜引き摺り廻した。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はぺったり尻を落としたが、またはね上がり、車を引き出そうと最後の力をふるいながら、ぐんぐんしゃくるように四方へはねた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
