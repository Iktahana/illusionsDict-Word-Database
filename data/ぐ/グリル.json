    "definitions": [
      {
        "index": 1,
        "gloss": "grill (esp. fish grill)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "――フジ・グリルのビフテキは？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "地下室のグリルで食事を済ませると、信吉は、ロビイへ新聞を取りに行った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴子はほのぼの笑って、「あとで……」　地下室のグリルへはいって、向い合って坐ると、「――二箱持って来たわ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "例によって、グリルで食事をすまして、「『赤と黒』を取りに、部屋へ来る……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "アウル・グリル・エンド・レストラントか？",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十分も経った頃、座員の一人が美和子のところへ来て、「お姉さんから、ホテルのグリルにいるから、君にもすぐ来い！",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」美和子は、雀躍りして演芸場からは近い、ホテルのグリルへ駈けつけりた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと六時を過ぎたばかりなので、広いグリルには、お客の影が少く、姉と見知らない一人の婦人とが、入口から左の少し小高くなっている床の卓子に着いているのが、すぐ眼にはいった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏に伴れられてアルバート・グリルへ赴く。",
              "citation": {
                "source": "サフランの花",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、グリルルームで三人で食事をするときなど、倭文子は村川には、直接には一言も口をきかなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "テラス下は舗装され、コンクリートのベンチと大谷石のグリルのある、バーベキューガーデンになっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一の部屋が七人部屋のおかげで、問題なく、じぶんの部屋のグリルに、先生を招くことができた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "教師の席には三人、すくなくとも性別は男ではない人がいたが、生徒のグリルでは、二〇四だけが女性を迎えていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、慶一が目をあげると、ふたつグリルをはさんだ向こうで、高志が親指の腹をこちらにむけ、垂直に立てて、ニヤリと笑った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――私は本日午後一時に銀座のＳ喫茶店へ行って二時までそこで過ごし、二時三十分に東京駅の二等待合室で三時三十分まで汽車の発車をまち、四時に帝国ホテルのグリルで食事をとることになっています。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＳ喫茶店と、東京駅の待合室と、ホテルのグリルとへ行っている時刻を知らして、その時刻に、どの場所かへ妾に来てくれという意志を知らしてきたのにちがいないのです。",
              "citation": {
                "source": "華やかな罪過",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏に伴はれてアルバート・グリルへ赴く。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたの午後レインボー・グリルで待つ。",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "グランパが桜の花を書き、エニシアルを研究し、十二時過に、グリルでランチをとる。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこれもアニはからんや、このオバコ、つまり旅館の女中さんは、戦争までレーンボーグリルの女中さんであったそうな。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーンボーグリルとはその上の文藝春秋の本寨だもの。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後にお訪ねしたのは文藝春秋社の二階で、下のグリルに下りてアイスクリームを頂きながらお話をした。",
              "citation": {
                "source": "菊池さんのおもひで",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行機がハワイに着くと、与田さんが迎えに来てくれて、ホノルルの本町通りで自身経営しているシティ・グリルというのへ連れて行かれ、ここでアメリカにおける最初の食事をとったわけです。",
              "citation": {
                "source": "ハワイの食用蛙",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "食用ガエルは、日本でも盛んに使われていますが、なんのこともなく、別においしいとも思ったことはありませんでしたが、シティ・グリルで試食してからというもの、食用ガエルに対する認識を新たにしました。",
              "citation": {
                "source": "ハワイの食用蛙",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、アメリカ本土へ渡ってからも、興味を持って機会あるごとに食べてみましたが、サンフランシスコ、シカゴ、いずれもだめ、食用ガエルはシティ・グリルにとどめをさします。",
              "citation": {
                "source": "ハワイの食用蛙",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "グリル食堂が美味いもの食いからよろこばれますのも、この理由にほかなりません。",
              "citation": {
                "source": "料理する心",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "外廊や炉辺でそういう噂が焦げつくようになったある日の午後、老人がめずらしく一人でホテルのグリルへやってきて、給仕に、Spiter というむずかしい英語で昼食を命じた。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでグリルにいた一人がすばやくすり寄って行って会話のきっかけをつかんだ。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は私に、グリルドリッグという名前をつけてくれました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "このグリルドリッグという言葉は、イギリスでなら、マニキン（小人）という言葉と同じ意味でした。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            }
          ]
        }
