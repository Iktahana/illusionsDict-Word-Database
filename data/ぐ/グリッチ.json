          "standard": [
            {
              "text": "最新のアップデートを適用してから、画面に奇妙なグリッチが発生するようになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "この動画のグリッチ演出は、サイバーパンクな世界観をうまく表現している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "ゲームの進行を妨げる重大なグリッチが見つかり、開発チームが修正に追われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": []
