    "definitions": [
      {
        "index": 1,
        "gloss": "glyme",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼の怒号の声はエグライムにまで達す。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "エルヴィスが東テュペロ・スクール（現在はローホーン・スクール）の五年生だったとき、担任の先生、ミセス・Ｊ・Ｃ・グライムズが、「みなさんのなかでおいのりの文句をちゃんと知っている人はいますか？",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日目にも、グライムズ先生は、おなじことを訊いた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "グライムズ先生はこれを非常にうれしく思い、母親のグラディスに伝えてほめたたえ、校長のＪ・Ｄ・コールにも話しておいた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もよおし物のひとつとして、歌やフィドリングのアマチュア・タレント・コンテストがおこなわれることになり、グライムズ先生から聞かされたエルヴィス・プレスリーのことを覚えていた校長は、エルヴィスにこのコンテストに出てみることをすすめた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
