  {
    "uuid": "a7a14c7e-292f-5c20-8dd4-aafdd7cce9e3",
    "entry": "軍属",
    "reading": {
      "primary": "ぐんぞく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
