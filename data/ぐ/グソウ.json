[
  {
    "uuid": "c2980e32-a0fb-5735-a091-a316697c479b",
    "entry": "愚僧",
    "reading": {
      "primary": "ぐそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
