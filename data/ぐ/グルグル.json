    "definitions": [
      {
        "index": 1,
        "gloss": "(turning) round and round",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雨にびっしょり濡れたそのレンコオトを脱ぎもせずに部屋をぐるぐるいそがしげに廻って歩いた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四ツ角を曲る時は、いつも三遍宛ぐるぐる回った。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ずんだ血潮の色の幻の中に、病女の顔や、死んだ娘の顔や、十年昔のお房の顔が、呪の息を吹くやもりの姿と一緒に巴のようにぐるぐるめぐる。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻にそこから十町も下流の河口を船で通りかかった人が、何かしら水面でぼちゃぼちゃ音がしていると思ってよく見ると、一匹の「えんこう」が、しきりにぐるぐる廻転運動をしているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてじっと蹲ったままで可愛い首を動かして自分のまわりをぐるぐる廻って行く不思議な人影を眺めているようである。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌る日、起きて、ふたりで顏を洗ひに井戸端へ出て、そこでもう藝術論がはじまり、一時間ちかく井戸端をぐるぐるめぐり歩いて最近の感想を述べ合ひました。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお見ているとこれが次第に大きくなって突然ぐるぐると廻り出す。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなければ、麓の丸の縁に取り付いてぐるぐる廻りをしているのではあるまいかとも思った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きながらぐるぐるぐるぐる空をめぐったのです。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」そして、カムパネルラは、円い板のやうになった地図を、しきりにぐるぐるまはして見てゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしの大事なタダシはいまどんな歌をうたってゐるだらう、雪の降る朝にみんなと手をつないでぐるぐるにはとこのやぶをまはってあそんでゐるだらうかと考へたりほんたうに待って心配してゐらっしゃるんですから、早く行っておっかさんにお目にかゝりませうね。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その葉はぐるぐるに縮れ葉の下にはもう美しい緑いろの大きな苞が赤い毛を吐いて真珠のやうな実もちらっと見えたのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三郎ひとり、上をまわって泳いで遁げたら、しゅっこはすぐに追い付いて、押えたほかに、腕をつかんで、四、五へんぐるぐる引っぱりまわした。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまわりがまっ蒼になって、ぐるぐる廻り、とうとう達二は、深い草の中に倒れてしまいました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空がまっ白に光って、ぐるぐる廻り、そのこちらを薄い鼠色の雲が、速く速く走っています。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車が方向をかえるたびに、そういう建物が真闇い空にぐるぐる廻転するように見えた。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで再びまた同じ階段を下りて、方角のわからぬ廊下をぐるぐる廻って行った。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは結局いつまで論議しても纏まりの付かないような高次元の迷路をぐるぐる廻るようなことになるかもしれない。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて私は、長く住んでいた家の廻りを、塀に添うて何十回もぐるぐると廻り歩いたことがあった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして樹木の多い郊外の屋敷町を、幾度かぐるぐる廻ったあとで、ふと或る賑やかな往来へ出た。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は一処にじっとしているとひどく不安に襲われるものですから、立上ると、まるで発作を起した女のように、部屋の中をぐるぐると廻りました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "三ヶ月の支那旅行を終つて、いよいよ明日は日本へ歸ると云ふ前夜、向うで知り合つた二三の友人と別宴を交し可成り醉つてゐた處を例の黄苞車でぐるぐる引きまはされたあとなのでどこのどう云ふ處にあつたのか覺えてゐないが、とにかく法租界の暗い裏町にある二流どこの阿片窟だ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
