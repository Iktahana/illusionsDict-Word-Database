        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はその瞬間そんな恰好をせずにゐられないその兒の氣持が、私自身の氣持の樣に、ぐんと胸へ來た。",
              "citation": {
                "source": "矛盾の樣な眞實",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、外套の肩を張りぐんぐんと大股つかつて銀杏の並木にはさまれたひろい砂利道を歩きながら、空腹のためだ、と答へたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のこぶしが横からぐんと飛んで來たので、私は首筋を素早くすくめた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、外套の肩を張りぐんぐんと大股つかって銀杏の並木にはさまれたひろい砂利道を歩きながら、空腹のためだ、と答えたのである。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のこぶしが横からぐんと飛んで来たので、私は首筋を素早くすくめた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　女は男の膝をぐんとついた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原に寢るこの感情の伸びてゆくありさままつすぐに伸びてゆく喬木のやうにいのちの芽生のぐんぐんとのびる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "草木は草木でいつさいにああ　どんなにぐんぐんと伸びてゆくことか。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐんぐんぐんぐんと上の方へ、とめどもなく高く昇る。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、今までの百倍もの力がぐんぐんと湧いて来ました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、ぐんと役者はひつぱつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭一面にぐんと射当てゝ、ぐんと射返す初夏の陽光は、椽側にも登り、金魚の硝子箱を横から照らして、底の玉石と共に水を虫入り水晶のやうに凝らしてゐる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうです、この植木鉢一つで舞台が、ぐんと引き立って見えるじゃありませんか。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生御自身の失敗談など、少しも飾らずに聞かせて下さっても、僕たちの胸には、ぐんと来るのに、いつもいつも同じ、権利と義務の定義やら、大我と小我の区別やら、わかり切った事をくどくどと繰り返してばかりいる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとでまた遊ばうと思ふと気持に張合ひが出て、仕事の能率もぐんと上るね。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　助七に、ぐんと背中を押され、青年は、よろめき、何かあたたかい人間の真情をその背中に感じ、そのままふらふら歩いて、一人で劇場の裏にまわっていった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　助七に、ぐんと背中を押され、青年は、よろめき、何かあたたかい人間の真情をその背中に感じ、そのままふらふら歩いて、一人で劇場の裏にまはつていつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃墟になってから、ぐんと姿がよくなるように設計して置くのである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "折りかさなって岩からてんらく、ざぶと浪をかぶって、はじめ引き寄せ、一瞬後は、お互いぐんと相手を蹴飛ばし、たちまち離れて、謂わば蚊よりも弱い声、『海野さあん。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "建振熊命は見る見るうちに宿禰の軍勢を負かし崩して、ぐんぐんと、どこまでも追っかけて行きました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜が中秋であったという月夜空、雲がぐんぐんと動いていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして並んで四ツ橋を渡り、文楽座の表まで来ると、それまでむっと黙っていた彼女は、疳高い早口の声で、「こんど店へ来はったら、一ぺん一緒に寝まひょな」とぐんと肩を押しながら赧い顔もせずに言った。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "金蓮は強い力でぐんぐんと引張った。",
              "citation": {
                "source": "牡丹燈記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し嘉三郎は、ぐんぐんと箪笥の前へ寄って行って曳き出しを開けた。",
              "citation": {
                "source": "栗の花の咲くころ",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然に激しい白光を感じて、神経の立っていた花房は狂奔的に首をぐんと上げて、五、六歩ほど後退った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴郎よ、奥さまが、お待ち申しておりますわ」「お、く、さま、奥さまって、どうした方です」「いらしてくだされば、すぐお判りになります」　少女は憲一の手を執ってぐんぐんと引っぱった。",
              "citation": {
                "source": "藤の瓔珞",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
