        "examples": {
          "standard": [
            {
              "text": "初夏になると、この岬はウミネコの大きな群生地として多くの観光客で賑わう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "希少なトンボの群生地を守るため、開発計画が見直されることになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "案内に従って森の奥へ進むと、突然ミズバショウの群生地が目の前に広がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "又、六寸七寸の巨大な黒蝶貝の群生地帯もあるという。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今や世界に比類ない真珠貝の群生地帯へ自ら急ぎ行く身になっては、猛然として頭をもたげてくるものは、現実的な慾念であり、情熱であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その六　血を見る真珠",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
