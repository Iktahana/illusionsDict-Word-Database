    "definitions": [
      {
        "index": 1,
        "gloss": "(lip) gloss",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
