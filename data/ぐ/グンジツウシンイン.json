          "standard": [
            {
              "text": "軍事通信員として戦地に赴いた彼は、命の危険を感じながらも真実を伝え続けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "前線の悲惨な状況を伝える軍事通信員の手記が、国民に大きな衝撃を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "軍事通信員には、戦場の混乱した状況を冷静かつ正確に描写する高い能力が求められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それは、後の自然主義運動に於いて作家としての生長を示した徳田秋声の、この時の作品「通訳官」を見ても、また、小栗風葉の「決死兵」、広津柳浪の「天下一品」、泉鏡花の「外国軍事通信員」等を見ても、その水っぽさと、空想でこしらえあげたあとはかくすべくもない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
