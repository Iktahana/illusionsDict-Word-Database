          "literary": [
            {
              "text": "酔えば女給を相手に何ごとかをぼそ／＼と愚痴るのだ。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と愚痴るやうにいふ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日も君の母様が来て、つくづく若様の不始末を愚痴るのが、何だか僕が取巻きでもして、わッと浮かせるようじゃないか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "楓は泣けもせず、三好に愚痴るよりほかに成すすべもなかった。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも気に食わぬ女を抱いたものだと思ったら、帰り途にさえこんなに手古摺るわいと彼は愚痴るのだった。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、赤耀館にフラフラ迷い込んで来たことを一代の失敗のように愚痴るひともありましたし、又、医師は心臓麻痺で頓死したというからには普通の病死であるものを、なぜ犯罪事件らしい取扱いをし、我々の迷惑をも顧みず、この夜更けに留め置くのかと、不平を並べる人もありました。",
              "citation": {
                "source": "赤耀館事件の真相",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼もしかった弟の死を、どんなに諦めようとしても諦らめられぬと愚痴る。",
              "citation": {
                "source": "案内人風景",
                "author": "百瀬慎太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ寄付するなら、十年前に手放せば、財産税を取られなくて済んだのに……と、愚痴るつもりもさらさらない。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとそこに若年の一朝臣が、独りで杯をあげ、白面に紅潮をみなぎらせて、人々が泣いたり愚痴るのを、さっきからおかしげに眺めていた。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの声が耳を離れねえ」「ぐちるなってことよ」「しかし、兄貴の前だが、水っぽい女だったなあ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
