        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがグルジアの首府チフリスに三日いるうちに、バクー行を実現することになった。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日雇い仕事でパンを稼ぎながら秋までほとんどロシアの南半分を歩きまわり、最後にチフリス（グルジアの首府）スターリンの故郷に落着いて鉄道工場に入った。",
              "citation": {
                "source": "マクシム・ゴーリキイの人及び芸術",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "がグルジンスカヤ・ダローガ〔グルジア軍用道路〕は惜しかった。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十七日　火　グルジアの国立ドラマ劇場を見た。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　筋のカンタンなところ、それから、もって居るリズムが横にのびる線でやっぱりグルジアの自然に似て居るところ、感情表現が顔面表情というより声と手足の動きで主としてやるところ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月十七日　第二芸術座　グルジア第一国立ドラマ劇場（オリムピアードに来た。",
              "citation": {
                "source": "日記",
                "author": "観劇日記（一九二九―一九三〇年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、レーニングラードのジプシーの音楽をききながら食事をする店でのことで、素子と伸子とはスタンドのついた小卓にさし向い、素子はグルジア産の白い葡萄酒をのんでいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウラジカフカアズから一日コーカサスの山越えをしてグルジアのチフリスという都会へ出ます。",
              "citation": {
                "source": "ロシアの旅より",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
