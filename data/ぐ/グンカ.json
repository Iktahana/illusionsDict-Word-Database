[
  {
    "uuid": "c702c392-dc9b-52a8-b8f1-0947b2126470",
    "entry": "軍歌",
    "reading": {
      "primary": "ぐんか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
