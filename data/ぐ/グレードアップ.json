        "examples": {
          "standard": [
            {
              "text": "パソコンの動作が重くなってきたので、メモリを増設してグレードアップを図った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "最新の調理器具にグレードアップしたおかげで、毎日の料理が格段に楽しくなった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "航空会社のマイレージを使って、エコノミークラスからビジネスへグレードアップした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＰＣ―８００１からＰＣ―８８０１、さらにＰＣ―９８０１とシステムをグレードアップしているユーザーが多いのもこういった理由による物であろう。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "システムをグレードアップする場合、従来のソフトウエアが継承できるということにより、ユーザーは安心してシステムを導入でき、また、将来新しいシステムが発売されても容易にシステム移行が可能となる」（『ＡＳＣＩＩ』一九八三年四月号）　そう書いた時点で、渡部はＰＣ―９８０１の成功に確信を抱きはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
