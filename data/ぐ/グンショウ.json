[
  {
    "uuid": "4e8b46e1-d363-548e-ba6c-dda8acec3936",
    "entry": "軍将",
    "reading": {
      "primary": "ぐんしょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "army commander",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ベルリンの下宿はノーレンドルフの辻に近いガイスベルク街にあって、年老いた主婦は陸軍将官の未亡人であった。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行軍将棊でもな、間者は豪いぜ、伴内阿魔。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一枚のマントはプリンス・オヴ・ウエルスの、海軍将校としてのあの御姿を美しいと思って、あれをお手本にして造らせました。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この外套には、白線の制帽も似合って、まさしく英国の海軍将校のように見えるだろうと、すこし自信もあったようです。",
              "citation": {
                "source": "おしゃれ童子",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "開州の軍将に冉従長という人があって、財を軽んじて士を好むというふうがあるので、儒生や道士のたぐいは多くその門に集まって来たが、そのなかに※采という画家もまじっていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、不幸にして二年間の経験によれば、予は教育家として、殊に未来の海軍将校を陶鋳すべき教育家として、いくら己惚れて見た所が、到底然るべき人物ではない。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは嘗て森氏が友達の海軍将校から贈られたもので、村に着いた当座は見物人が群がり寄せて大変な騒ぎであつた。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼兄弟　軍将の陳守規は何かの連坐で信州へ流されて、その官舎に寓居することになりました。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事に動じないわが海軍将兵も、この飛行島の大工事には少からず驚いた。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、いつも身のまわりの世話をしていた杉田二等水兵の話によると、彼は機関大尉に連れられて、その日の午後飛行島に上陸したが、その時機関大尉はちゃんと海軍将校の服装をしていたという。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは日本海を向こうへ越えた国境附近で、御国のために生命を投げだして働いている、わが陸海軍将兵のために敬意を表していたのかと思ったんだが、そうじゃなかったのかね」「ええ、敬礼は太陽にしていたんです。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "俘虜の紹介状５・４（夕）　英国の陸軍将校をたんとぶち込んでゐる独逸の俘虜収容所に、一人の軍曹がある。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十二歳の下士官６・２（夕）　米国のある陸軍将校が、最近仏蘭西軍の兵站部を訪ねると、そこに居合はせた司令官の一｜人、四十恰好の髯の美しい陸軍大佐は、愛想よく出迎へて、何くれとなく打明けて話してくれた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日も某方面から帰つて来たある海軍将校などは、「こんな事では、欧羅巴の檜舞台で目ざましい働きが出来ようとも思はれない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころは、海軍将校の女房達は、良人が外国勤めに出掛けるときには、たいてい同伴を許されて、艦隊が行く先々の遠い港へ、海を越えて旅立ちしたものだつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来海外の勤務先に同伴せる各海軍将校の夫人は、この際急速に合衆国内にある各自の家庭に帰還すべきものなり。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海外勤務にある海軍将校が同伴せる夫人達を、至急本国の家庭に帰還せしむべしとの貴電は確かに拝命せり。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "「派遣軍将兵に告ぐ」「戦陣訓」の重大意義もここにありと信ずる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年天長の佳辰に発せられた総軍司令部の「派遣軍将兵に告ぐ」には、事変の解決のため満州建国の精神を想起せしめ、道義東亜連盟の結成に在る事を強調せられた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは軍艦ですよ」「軍艦をどうするの」「これでもって海軍将棋を拵えようというんです」「海軍将棋だって？",
              "citation": {
                "source": "あらくれ",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ましてや、新たに召集された新兵たちには、熊本の地そのものがかの偉大なる軍将の伝説によって神格化されており、驚嘆すべき場所と思えただろうし、また、この城そのものも清正が朝鮮で猛攻撃した要塞のプランも取り入れて築城されており、世界の驚異とも見えたであろう。",
              "citation": {
                "source": "男子の本懐",
                "author": "A WISH FULFILLED",
                "note": "青空文庫"
              }
            },
            {
              "text": "マクシムの父親というのは陸軍将校であったが、或る時その部下を虐待した廉でシベリヤに流されたという男である。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "急進的な勤労人民の民主化を防ぐため、いわゆる力の均衡を保つため秘密のうちに旧陸軍将校、憲兵、ファシストを中心とする反動勢力が培養されている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎標準時計　絶対に狂わず正確なもの　と云う　それを或日本の海軍将官が英国で買った。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は佐倉にある陸軍将校に仏語を授けむがためであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
