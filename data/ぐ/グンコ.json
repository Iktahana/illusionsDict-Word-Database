        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軍鼓の音も惨として響かぬ。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから、鼕々と軍鼓の音が揚った。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に二人の目の向うの、月光散りしく城内｜遥かの広場の中を騎馬の一隊に先陣させた藩兵達の大部隊が軍鼓を鳴らし、法螺の音を空高く吹き鳴らし乍ら、二｜旒の白旗を高々と押し立ててザクザクと長蛇のごとく勇ましげに進んでいった。",
              "citation": {
                "source": "十万石の怪談",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金鼓」は軍鼓で、但し紅い紐がついてゐるから女持の軍鼓である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさらば」　とばかり軍鼓堂々と、東南の道へくだッて行き、その歓呼と狼煙の下に、慕蓉もまた手を振ってその征途を見送ったものだった。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍鼓の音ではないか」「いや、波の音です。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　尊氏は、軍鼓の武士をこう励ました。",
              "citation": {
                "source": "私本太平記",
                "author": "湊川帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "虚空の軍鼓と地の波濤を、坐ながら呼ぶような彼の作戦構想は、例によってすこぶる大きい。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐんぐんこっちへ近づいてくるぜ。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時の間に漕ぎ出したか、極彩色を施した小舟が鋭い舳を揃へてぐんぐんこつちへ近づいて来る。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたがこわい顔をもして私のまわりからいろんなケチくさいつきものをぐんぐんこわさせていらしたことの価値も、今にして十分わかります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらへ向けている老人の痩せた背中が、云いようのない大きな圧力をもって、ぐんぐんこちらへのしかかって来るようだった。",
              "citation": {
                "source": "晩秋",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに離れていたモーターボートが、またしても、ぐんぐんこちらへ近づいてくるではありませんか。",
              "citation": {
                "source": "鉄人Ｑ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
