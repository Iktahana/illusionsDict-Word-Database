        "index": 1,
        "gloss": "type of stew, usu. fish or vegetables in a mild broth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
