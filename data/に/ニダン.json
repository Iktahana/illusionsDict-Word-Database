    "definitions": [
      {
        "index": 1,
        "gloss": "double",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　まさか、こんなばかげた問答は起るまいが、けれどもこの場合の柿にしろ、窓にしろ、これこれだからこうだ、という、いわば二段論法的な、こじつけではないわけだ。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "車内が上下二段に仕切られたその上下に、生きてゐる肥つた白い豚がぎつしり詰まつてゐる。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して、甘味は第二段たる「反」の段階を形成する。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが源因の第二段階である。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは「かい（橈）」「まうく（設）」「まうす（申）」のごとき二、三の語と、ヤ行上二段の語尾の場合とだけで、極めて少数である。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に上二段活用にもまた「キ、ヒ、ミ」があらわれて来ます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に下二段活用ですが、ここにも「ケ、へ、メ」があらわれます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは未然・連用に「ヒ」の乙類を用いる活用は他にないかというに、ちょうど上二段活用があります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすれば、これらの語は、上二段活用でなかったかとも考えられるのでありますが、『日本書紀』巻七景行天皇十二年の条を見ると、「乾此云賦」とあって「乾」を「フ」と読ませてあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かように「乾」を「フ」と読んだり「フレ」と読んだりしたとすれば、それは「ヒ」「ヒ」「フ」「フル」「フレ」と活用したもので、すなわち上二段活用の語であったと考えられます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると、宣長翁も上二段活用であったと考えておられたと思われます。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに「ク（またはコ）、ホ、ム」などに変ずる「キ、ヒ、ミ」は、皆揃って乙類に属します（上二段の未然・連用と同音）。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由に達して始めて物の本末を認識し、第一義と第二義を判別し、末節を放棄して大義に就くを得るということを説いたのには第百十二段、第二百十一段などのようなものがある。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば第九十二段に弓の修業の心得から修道者の覚悟を説くのでも、直ちに移して以て吾等科学研究者の坐右の銘とすることが出来る。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また第百十二段に大事の前に小事を棄つべきを説く条でも同様である。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "花火そのものは第二段として、あの安つぽい繪具で赤や紫や黄や青や、樣ざまの縞模樣を持つた花火の束、中山寺の星下り、花合戰、枯れすすき。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、二段、三段と、大股に階段を駈け降りながら、苦苦しさ一杯に、自分を踏みくちやにしたいやうな氣持で、私は心の中に呶鳴り續けてゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃熱心なのは將棋で菊池寛二段の飛香落とどうやら戰へる。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身も、自分の所有地は、Ｓ町の方に田が二段歩あるだけだった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほいたって、あれと野上の二段とは、もう年貢を納めいでもえゝ田じゃが。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花火そのものは第二段として、あの安っぽい絵具で赤や紫や黄や青や、さまざまの縞模様を持った花火の束、中山寺の星下り、花合戦、枯れすすき。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高等学校ではさらに詳しく繰り返して第二段の「理解」を授けられる。",
              "citation": {
                "source": "相対性原理側面観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二段ずつ飛ぶこともあり五六段ずつ飛び上がるときもある。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴中から右と左の二段にタッタ一討ちの腕の冴えようは、当節の黒田様の御家中でも珍しかろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この比較の当否は二段としても、試みにこういう考えを仮設してもう少し比較を進めてみたらどうなるか。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで材料は第二段の淘汰を受けることになる。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このようにして選択された分析的要素の撮影ができた上で、さらに第二段の選択過程が行なわれる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になると曇るので気づかずにいたが、もう九日ぐらいだろうかと思われる上弦というより左弦ともいうべきかなり肥った櫛形の月が、川向うの密生した木立の上二段ほどの所に昇っていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は掌の上に載せた火山弾にだんだん切ない重みを感じながら、その娘に対し氷にもなれというような呪詛をかけたことのおよそ見当違いでもあり、無慈悲な仕打ちであることが悔まれた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女にだんだんもの心がつき、比較によって自分と他とを評価する力が生れて、福慈岳の評判を聞いてみると、その秀でさ加減はあまりにも自分の資格とはかけ離れたものであった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
