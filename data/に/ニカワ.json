[
  {
    "uuid": "c4be97c0-cbea-5ecf-98e9-11868e4f20d7",
    "entry": "膠",
    "reading": {
      "primary": "にかわ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
