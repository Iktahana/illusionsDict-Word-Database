    "definitions": [
      {
        "index": 1,
        "gloss": "obligation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "孤高を以て任ずるなどといふのぢや尚更ない。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば茲に一農学士があり、非常に立派な耕作法を学び、百姓に教へに行く任務を帯びるとする。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞けばその後また横浜の小学校に転任したさうであるが、ナニ、ブラ公なぞが訪ねた所で誰が喜ぶものでもあるまい。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）、終列車にて父の任地なる旅順に赴いたのださうである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "後に買った大久保の家に、書斎を新しく建て増しする時、一切の設計や事務を妻に一任して、自分は全く無頓着で居たが、それでも妻が時々相談を持ちかけると、『もう、あの家よろしいの時、あなた言いましょう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は妻の為す通りに任せている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて病気の発作が起った時、ヘルンは自己の運命をすっかり自覚し、死後における妻子の保護と財産の管理とを、親友の法学士に一任して、後に心がかりのないようにした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひと一人、くらい境遇に落ち込んだ場合、その肉親のうちの気の弱い者か、または、その友人のうちの口下手の者が、その責任を押しつけられ、犯しもせぬ罪を世人に謝し、なんとなく肩身のせまい思いをしているものである。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "せめて、妹さえ丈夫でございましたならば、私も、少し気楽だったのですけれども、妹は、私に似ないで、たいへん美しく、髪も長く、とてもよくできる、可愛い子でございましたが、からだが弱く、その城下まちへ赴任して、二年目の春、私二十、妹十八で、妹は、死にました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、それを僕自身の正義の責任感からと解していました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "就任早々、一週を五日として、六日目毎に休日を與へ、授業も毎日午前中だけにしたい、それゆゑに生徒が怠けるとは思はれない。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、大隅君だって、決して無責任な男じゃございませんから。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その料理屋には、神前挙式場も設備せられてある由で、とにかく、そのほうの交渉はいっさい小坂氏にお任せする事にした。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の新人諸君に対して、責任を感じましたので、一言申し開きを致します。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が此の中学に転任と定つた際、最初此の学校のことゝして聞いたのはそのことであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は往診して他人といふ無責任な人達にもてなされて帰つて来ると苦労性な皆が不快だつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――いつたい此の会社の社長といふ男は、会社としての収入のみを考慮の中に入れたが、俳優其の他の傭入や解雇は、全然竹山俳優監督係に任せ切りだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女はそれを当然と任じ、寧ろ自明とさへ信じた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、それだけでも何だか、彼は客として来る者に対する責任を感じてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "單にその通用的便宜のために、疾患を疾患として放任し、惡に則つて惡を準用する如きは、一國文化の將來を憂ふる者の、斷じて贊與しないところであらう。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして自ら芭蕉の直系を以って任じ、死後にもその墓を芭蕉の側に並べて立てさせた。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜなら、日本の文学者等は、彼等の翻案化された似而非の自然主義文化や、似而非のレアリズム文学を以て、自から外国思潮のそれと同列させ、資本主義末期の近代文学を以て自任しつつ、笑止にも得意でゐるからである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "換言すれば著者は、すべての藝術的意圖と藝術的野心を廢棄し、單に「心のまま」に、自然の感動に任せて書いたのである。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しだいに暮れゆく海波の上既に分列の任務を終へて艦等みな歸港の情に渇けるなり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな太鼓や鐘があぜ道にすえられて赤裸の人形が力に任せてそれをたたく。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椎茸少々｜宜しからぬ事があって途中から免職になったのはよかったが、その後任の爺さんがドーモ椎茸でなかったので坊チャン一通りの不平でない。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の五歳の頃から五年ほどの間熊本｜鎮台に赴任したきり一度も帰らなかった父の留守の淋しさ、おそらくその当時は自覚しなかった淋しさが、不思議にもこの燈下の寒竹の記憶と共に、はっきりした意識となって甦って来るのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "無責任に大げさな、甘い觀念論で、諸君を騙さうとして居るのでは無い。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は無責任なことは言つて居ない。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦島は、さんざん迷つた末に、たうとうかの龍宮のお土産の貝殼をあけて見るといふ事になるのであるが、これに就いて、あの龜が責任を負ふ必要はないやうに思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
