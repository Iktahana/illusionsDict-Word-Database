        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "忙しいビジネスマンも、芸術家も、ニューヨーカーは皆それぞれのスタイルを持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は典型的なニューヨーカーで、早口でユーモアのセンスに溢れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「あのカフェ、いつもニューヨーカーでいっぱいだね。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ニュー・ヨークで私たちは親愛な鹿島丸と別れ、まづホテル・ニューヨーカーにトランクを持ち込んだが、すぐ船に呼び返されて、朝日の國際電話で同行の數名の人たちと久しぶりで日本との通話をした。",
              "citation": {
                "source": "大戰脱出記",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ニューヨーカー』といったかな。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
