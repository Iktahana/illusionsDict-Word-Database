    "definitions": [
      {
        "index": 1,
        "gloss": "period before the Lotus Sutra was preached",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "帝曰く、爾前日諸王を裁抑す、今｜復我に臣たらざらんかと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "大覚世尊（釈迦）が年七十二の時、法機｜漸く熟して法華｜爾前に於ける権実両教の起尽を明かにするため無量義経を説き「四十余年｜未顕真実」と喝破して静かに禅定に入つた話は仏者の間に有名であり、わが弘法大師は現にまだ禅定のうちにありとさへ或る一部の人々に信ぜられて居る。",
              "citation": {
                "source": "毒と迷信",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しよき学生ならば観経はこの爾前の教えである。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "童子さまの脳はもうすっかり疲れて、白い網のようになって、ぶるぶるゆれ、その中に赤い大きな三日月が浮かんだり、そのへん一杯にぜんまいの芽のようなものが見えたり、また四角な変に柔らかな白いものが、だんだん拡がって恐ろしい大きな箱になったりするのでございました。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの大事な問題にぜんぜん証拠が挙がっていないのだ。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず自己の講義のうちにぜんぜん埋没している。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代芸術にぜんぜん欠如しているところのものは階級意識ある労働者にとって生命中の生命である、かの喜ばしき闘争要素である」　この間題はかつてプロレタリア文学における明るさの問題として、日本でも論じられたはずであるし、現在でも、悲観派と楽観派、暗黒派と光明派、現実派と理想派との対立となって存続している。",
              "citation": {
                "source": "二つの文学論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言つて、指頭で器用にぜんまいを捲いた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、それ以来彼は芝居や動物の見世物にぜんぜん興味をうしなってしまった。",
              "citation": {
                "source": "或る精神異常者",
                "author": "モーリス・ルヴェル",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人は彼の雄弁と諧謔とにみせられて、哄笑をするたびに、そのかげにおれという被害者がはぎしりしていることにぜんぜん気がつかなかった。",
              "citation": {
                "source": "蜘蛛",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "議事堂の塔の上に怪魔がいるというのか」　長戸検事は今は金属Ｑ捜査隊長に任命せられていたので、これを聞くとただちにぜんぶの隊員へ放送した。",
              "citation": {
                "source": "金属人間",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人氣のない軒下にぜんざいは抑も何を待ちつゝ赤く染まつて居るのかしらん。",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "体も四肢もへんにくねくねして、骨の代りにぜんまいでもはいってるように見える。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このお皿の中に入ったエンドウまめ、これを灰の山の中になげるから、にじかんいないにぜんぶひろいなさい。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このにまいのお皿の中に入ったエンドウまめ、これを灰の山の中になげるから、いちじかんいないにぜんぶひろいなさい。",
              "citation": {
                "source": "アッシェンプッテル",
                "author": "ASCHENPUTTEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "人気のない軒下にぜんざいはそもそも何を待ちつつ赤く染まっているのかしらん。",
              "citation": {
                "source": "京に着ける夕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアのところで、ちっちゃな金の鍵をわすれたことに気がついて、鍵をとテーブルに引き返してみると、今度は上にぜんぜんとどかない。",
              "citation": {
                "source": "アリスの地底めぐり",
                "author": "ALICE'S ADVENTURES UNDER GROUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドアのところで、ちっちゃな金の鍵をわすれたことに気がついて、取ろうとテーブルに引き返してみると、今度は上にぜんぜんとどかない。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにぜんたい百姓の子どもじゃあない。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにぜんたいどうしてあの人たちが子どもを探すためにそんなにたくさんの金が使えたろうか。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい、われ／＼が肉体的にぜん／＼無為な生活をしながら、刺激性の食物を過度に摂取しているのは、組織的な性欲挑発でなくてなんでしょう。",
              "citation": {
                "source": "クロイツェル・ソナタ",
                "author": "KREITSEROVA SONATA",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、すべての事件、たとえば犯罪などでも皆、それが現実に発生するやいなや、直ちにぜんぜん特殊な一個の場合になってしまうからです。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の中が恐怖心でひどくざわめいて、彼はこれらの質問にぜんぜん答えることができなかった。",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうことにきめて、笑い話にしていたら、秋になって急にぜんそくが起った。",
              "citation": {
                "source": "日めくり",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するにぜんたいとして、杉浦氏が彼女のとった行動を世間に対して恥じている、なにをしたかということも、どこにいるかということも人に知られたくない、その事実のほかは来太にはなに一つ知ることができないのだ。",
              "citation": {
                "source": "花咲かぬリラ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖の波間のコンクリート桶も、土手の上に光っているレールも、いつも窓から見える光景の一部分として、完璧にぜんたいに溶けこんでいる。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳を越えても撮っていき、いまから四年ないし五年あとに、一冊の写真集を作りたい」「作るといいわ」「四十代前半のお母さんの写真に、四十歳前後のきみの写真を加え、巧みにぜんたいを配列する。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「恵子さんはいきさつを説明してくださって、私はすぐにぜんたいを理解しました。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしのドロマイト弾の尻にぜんまいスクリュウを付けてあの岩を狙うぞ」　興味津々で見物人たちは小さなスクリュウ弾が海中を進むのを見つめた。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            }
          ]
        }
