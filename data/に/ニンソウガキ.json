        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "場合によっては抽象的な人相書きによったほうがかえって安全かもしれない。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ甲乙二人の描いた人相書きがちがう場合にどっちも自分のかいたほうが「正しい」と言って、主張するのはいいとしてもおしまいにはにがにがしいけんかになるのはどんなものだろう。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手人の人相書きはすでに上がっているゆえ、二日とたたぬうちに、きっとこの右門が、ご主人のかたきを討ってしんぜましょうよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじの話した人相書きによると、その若い野郎は右ほおに刀傷があるといいましたからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きに丹念に書いたのはいいが、丹念なところは女の子の顔ばかりで、ホシの野郎はどんなやつか、肝心かなめの下手人の人相書きは、毛筋ほども書き止めていらっしゃらねえじゃねえかよ、だいじなことが抜けているというな、そのことなんだよ」「はてね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もあっしゃ、むろんのことに、もうそいつめが人さらいのほしだとにらんでいますが、だからね、いろいろと番頭や主人にも当たって、そいつの人相書きから探りを入れてみるてえと、やっぱりしばや者で、久しいまえから家へも出入りの源公というやつなんだそうでがすよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんぞ人相書きで目にたつようなところ、覚えちゃいねえか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "――みなの者も人相書きのことを聞いたであろうな」　宰相伊豆守は、かたわらに居流れていた近侍の面々を顧みると、猪突に命じました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとの四人は市中の一町目付けへ、いま右門が申した人相書きの浪人を目あてに、ぬかりなく動静探ってまいれよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "若衆は無言で受け取って月の光で透かして見たが、「や、これは某が人相書き！",
              "citation": {
                "source": "紅白縮緬組",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その様追はるる予言者の如し」　勿論父の人相書きではなかつたが、年齢を訂正すればそつくり父に当てはまる人相でもあつた。",
              "citation": {
                "source": "狼園",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今まではそれほどでもなかったが、毎週テレビのオビ番組を三年間も持つようになってからは、日本全国へ人相書きがまわっているようなものだ。",
              "citation": {
                "source": "江戸前の釣り",
                "author": "三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論市内の各巡査派出所へも、この人相書きが廻る。",
              "citation": {
                "source": "二銭銅貨",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
