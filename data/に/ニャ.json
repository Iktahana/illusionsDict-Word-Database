        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕はあいつを最初｜瞥見したとき、こんにゃくの舌で顔をぺろっと舐められたような気がしたよ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘッ、俺より一足だって先にゃ行かねえや。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺にゃ覚悟が出来てるんだ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、お前がいくら頑張ったって、船長も云ったように、一億円の船会社にゃ、勝てっこないんだから」　セコンドメイトは、デッキの上と橋板の上とでは、レコードの両面見たいに、あべこべの事を云い始めた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからな、お前さんは、番頭さんにゃ見えねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ奴等にゃどいつもこいつも泥坊に見えるんだからね」　彼は、ベンチへ横になった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「喧嘩にゃならねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、此車にゃスパイが二十人も乗ってるんだからな。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うだって引継ぎの時にゃ、間誤つくだろうよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この車にゃ居ない！",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺にゃ、残念だが解らねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ピークは、病人の入る処じゃねえや」「ピークにゃ、船長だけが住めるんだ」　彼等は、足下から湧いて来る、泥のような呻き声に苛まれた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "おらにゃ、ダイナマイトを抑えつけるてな、芸当は打てねえんだからってな。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「穴ん中にゃいないや、捲上小屋にいるかも知れないよ」　小林の子が、小さな心臓を何物とも知れぬ不安に締めつけられながら言った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると猫がにゃあと鳴く。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美代はこの夜三時過ぎまで結びごんにゃくをこしらえていた。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労もほどほどの分量にゃ持ち合せているもんだよ」　それから二三日経って、老妓は柚木を外出に誘った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈々子は水鉢の縁に小さな手を掛け、「きんご、おっちゃんきんご、おっちゃんきんご」「もう金魚へにゃしないねい。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねいおんちゃん、へにゃしないねい」　三児は一時金魚の死んだのに驚いたらしかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、まだ寝てンのね、兄さん起きてよ」　石松、むにゃむにゃ言って起きない。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なにしろあたしたちは、銭のかかる贅沢はできないからね」「おとっさん、なぜこれを、店に出さないんだ」「冗談いっちゃ、いけない、これを出した日にゃ、他の鮨が蹴押されて売れなくなっちまわ。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この頃、パルチザンがちょい／＼出没するちゅうが、あぶないところへ踏みこまないように気をつけにゃいかんぞ！",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「会社へ勤めるのに新の洋服を拵えにゃならん云うて来とるんじゃ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "家にゃもうなんにも有りゃせんのに！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これゃ常着にゃよすぎるわい。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとなんぞ珍らしい物をこしらえにゃ！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと取調べにゃならんかもしれん。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺等にゃ、その掴ます偽札も有りゃしないや。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「貰わにゃ引き合いません。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
