    "definitions": [
      {
        "index": 1,
        "gloss": "inhuman person",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もとより郷里の事情も知らぬではないがあまりに薄情だと思って一時はひどく憤慨し人非人のように罵ってもみた。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "召連れたる下男は銀平という、高田が気に入りの人非人。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬、畜生、人非人、四這になれ、尻尾を掉れ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、お放しなさいまし、この大それた人非人。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『仮名手本忠臣蔵』の作者｜竹田出雲に斧九太夫という名を与えられて以来、殆ど人非人のモデルであるように洽く世間に伝えられている大野九郎兵衛という一個の元禄武士は、ここを永久の住家と定めているのである。",
              "citation": {
                "source": "磯部の若葉",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もうジキだと思うんだけれど……」「おのれ……コノ人非人。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々は単に、空想、情熱、主観等の語を言うだけでも、その詩的の故に嘲笑され、文壇的｜人非人として擯斥された。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっちゃん、ごらん、ここに僕のことを、人非人なんて書いていますよ。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人非人でないから、あんな事も仕出かすのです」　私は格別うれしくもなく、「人非人でもいいじゃないの。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "莫迦でなけれあ人非人だ。",
              "citation": {
                "source": "道",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このうちに植田の者はおらんか、なんと云う人非人じゃ、こうして成敗をせられようとしておる者が、可哀そうじゃないか、この怨みはどうしても忘れんぞ」　住職はこう云って腰へ手をやった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦女を誘拐した愚劣漢であると同時に、二重結婚までした破廉恥極まる人非人……。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の私の心理状態を、あの人非人でしかあり得ない戦場泥棒の根性と同じものに見られても、私は一言の不服も申し立て得ないでしょう。",
              "citation": {
                "source": "死後の恋",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがその全開目玉パワーに一点の陰りを与えるような心ない質問を当の横綱にぶつけてしまった人非人が、実は何を隠そうこのオレなのであった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「間さん、貴方、私の申上げた事をば、やあ道ならぬの、不義のと、実に立派な口上を有仰いましたでは御座いませんか、それ程義のお堅い貴方なら、何為こんな淫乱の人非人を阿容活けてお置き遊ばすのですか。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人非人の盛遠は、忽ち刄を拔いて、袈裟御前の胸にもさしつけた！",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "人非人の盛遠に、見染められたを運とあきらめ、夫に代り母に代り、操を守つてはてられた袈裟どのは、日本一の貞女よな。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その袈裟どのを、害したるこの盛遠は、日本一の人非人ぢや。",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この盛遠を打つにも足らぬ人非人とさげすむと見えるな！",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "盛遠のやうな人非人は、相手にする丈でも汚はしい！",
              "citation": {
                "source": "袈裟の良人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "と申しただけでは、なんのことやらおわかりではござりますまいが、そちらの大口三郎さまは、いうも身の毛のよだつ人非人でござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっそくにお出役くださいましたゆえ、もうだいじょうぶと心ひそかに喜んでおりましたら、依田様もいいようのない人非人でござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "子持ちすずり",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「紋には暇とらすぞよ」「ははッ」「まったこれなる人非人――」　不興げに治右衛門の上を走ったお目が、うしろへ流れました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこのような冷酷な商売をする人非人が、果して約束通り残らず回向院へ納めたかどうか怪しいものである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「仮名手本忠臣蔵」の作者｜竹田出雲に斧九太夫という名を与えられて以来、ほとんど人非人のモデルであるように、あまねく世間に伝えられている大野九郎兵衛という一個の元禄武士は、ここを永久の住み家と定めているのである。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "怨を死骸にまで及ぼさうとは、墮地獄の人非人め、引立つる、尋常に從いて來い。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人非人だ、Ｈがいふやうに穀つぶしだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "穢らわしい人非人奴！",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
