    "definitions": [
      {
        "index": 1,
        "gloss": "to be boiled",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかしながら蕪村の場合は、侘びが生活の中から泌み出し、葱の煮える臭いのように、人里恋しい情緒の中に浸み出している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入の夢や小豆の煮えるうち　藪入で休暇をもらった小僧が、田舎の実家へ帰り、久しぶりで両親に逢ったのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには葱の煮える生活がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして葱の煮える生活！",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪入りの寝るや小豆の煮える中　という句を作り、さらに春風馬堤曲を作る蕪村は、他人の藪入りを歌うのでなく、いつも彼自身の「心の藪入り」を歌っているのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち料理番が肉なり野菜なりを竈に仕かけて煮えるのを待っていると丁度よい時分には電気仕掛けのピアノが鳴り出す、その煮物に相応したような曲を奏するというのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の武士の中の変人達が酷暑の時候にドテラを着込んで火鉢を囲んで寒い寒いと云ったという話があるが、暑中に烈火の前に立って油の煮えるのを見るのは実は案外に爽快なものである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……称名の中から、じりじりと脂肪の煮える響がして、腥いのが、むらむらと来た。",
              "citation": {
                "source": "国貞えがく",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「可、と打込んで、ぐら／＼と煮える処を、めい／＼盛に、フツフと吹いて、」「山賊々々。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "炎天のもとに煮えるような深い泥を踏み分けては、よくこの蒲の穂を取りに行ったものである。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角死んでも、それを食べて呉れる人もなし、可哀そうに、魚はみんなシャベルで釜になげ込まれ、煮えるとすくわれて、締木にかけて圧搾される。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「は、」「あなたは、おはぐろの煮える音は御存じでありますまいね。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お互に時代が違いますが、何ですか、それ、じ、じ、じ……」「虫ですかしら……油が煮えるのでしょう。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日中の暑さに、酒は浴びたり、血は煮える。",
              "citation": {
                "source": "祭のこと",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "極暑の、旱というのに、たといいかなる人気にせよ、湧くの、煮えるのなどは、口にするも暑くるしい。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の疲労した身心は、静かな茶間の一室で、鉄瓶の湯の煮える音を楽しんだ。",
              "citation": {
                "source": "病床生活からの一発見",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾が心の平衡が保てぬというほどでは無いが、硬粥が煮えるときにブツブツと小さな泡が立っては消え、消えては復立つというような、取留めのない平らかならぬものが腹中に間断なく起滅するのを免れなかったことだったろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（寒い風だよ、ちょぼ一風は、しわりごわりと吹いて来る）と田越村一番の若衆が、泣声を立てる、大根の煮える、富士おろし、西北風の烈しい夕暮に、いそがしいのと、寒いのに、向うみずに、がたりと、門の戸をしめた勢で、軒に釣った鳥籠をぐゎたり、バタンと撥返した。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これよりして、私は、茶の煮える間と言うもの、およそこの編に記した雀の可愛さをここで話したのである。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ややしばらく、魂が遠くなったように、静としていると思うと、襦袢の緋が颯と冴えて、揺れて、靡いて、蝋に紅い影が透って、口惜いか、悲いか、可哀なんだか、ちらちらと白露を散らして泣く、そら、とろとろと煮えるんだね。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "粥は高粱の中へ豚の肉を入れたもので、その煮えるのを待ちかねて四、五椀すすり込むと、堀部君のひたいには汗がにじみ出して来た。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "極暑の、旱と言ふのに、たとひ如何なる人気にせよ、湧くの、煮えるのなどは、口にするも暑くるしい。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それは……　何だといって、六つずつ十二の煙が、群りまとい這いまつわる、附木の硫黄は、火の車で、鉄の鍋の中に、豆府と菎蒻がぐらぐらと煮える……申しますまい。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その、彼の前に立っている労働者が彼からその「煮える」ような眼光を放さなければ、彼は立てなかったのだ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "命なんです」　といううちにも、その目からはほろほろと煮えるような涙が流れて、まだうら若いなめらかな頬を伝った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の頭には、何とも我慢のならぬ想念が、ふつふつと煮えるように湧き起こってきた。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒石油は重く、泥が煮えるように湧き立っているのである。",
              "citation": {
                "source": "石油の都バクーへ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その性急なことは、鍋に仕掛けた芋でも人參でも十分煮えるのを待つて居られないといふ程でした。",
              "citation": {
                "source": "幼き日",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は酒はあまり遣らない方だから、すこし甘口ではあるが白葡萄酒の玻璃盃に一ぱい注いであるのを前に置いて、それをすこしづゝ遣つたり、乳色のした牡蠣の汁を啜つたり、それから暖簾の奥の方でコックのさせる物音や脂肪のヂリ／＼煮える音を聞いたりしながら、夢のやうに過ぎ去つた年月のことを胸に浮べて見た。",
              "citation": {
                "source": "犬",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏台に腰をかけ、料理台に両肱をもたせ、電燈の下で、煮える鍋の番をしながら、彼女は自分の気持を考えた。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
