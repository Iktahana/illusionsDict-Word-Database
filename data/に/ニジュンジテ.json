    "definitions": [
      {
        "index": 1,
        "gloss": "in accordance with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小説の稿料に準じて、詩の稿料を定めるのである。",
              "citation": {
                "source": "よもやまの話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "悠揚としてこれに準じて流れるのだ。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『春告鳥』は「主女に対する客人のいで立ち」を叙して「上着は媚茶の……縞の南部縮緬、羽織は唐桟の……ごまがら縞、……その外持物懐中もの、これに準じて意気なることと、知りたまふべし」といっている。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃私の居た地方の高等学校では、真紅色のリボンに二本の白線を入れた帽子を、一高に準じて制定して居た。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他はこれに準じて知る可しである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "止むなくわたしは通俗に準じてわたしの生命を賭けたばかりだ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の真中を横断する散歩道の両端には、殊にも巨大な桜が枝を張り、それに準じて中背の桜が何十本か整列している。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "而もいづれも生活に準じて、編纂せられた。",
              "citation": {
                "source": "夢殿",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "風も、それに準じて、勢いを収めて、見る内に、山の頂きには青空が顔を出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桂枝のもとには草｜生ぜず、麻黄の茎には雪積らず、これに準じて、注意しながら山を廻っておると、自然に薬が知れてくる」　照道寿真はそれを発端として玄妙な仙道の秘訣を教えはじめた。",
              "citation": {
                "source": "神仙河野久",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "他はこれに準じて知るべし、である。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "入道の宮をまた新たに御母后の位にあそばすことは無理であったから、太上天皇に準じて女院にあそばされた。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "多数の縉紳は皆きらびやかに風采を作っているが、源氏に準じて見えるほどの人もないのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "初音",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓が山小橋の西念寺にあるといふこと、その寺が昔の富豪平野屋五兵衛の創建であるといふこと、直好翁はその平野屋の番頭であつたといふこと、平生主家に忠実であつたがために、死んでから、平野屋の一族に準じて、その西念寺に葬つたのであるといふこと、さうしたことをいろいろと話してきかせて呉れた。",
              "citation": {
                "source": "大阪で",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに準じて官辺はもとよりすべての事が民衆化しつつある事は云う迄もないが、これにカブレて軍人までが官服を嫌うようになったそうである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、それに準じて、僕達の決死的な用意を、ミツキイの男振りに関しては、仔細に保ち続けてゐたのだが――。",
              "citation": {
                "source": "山男と男装の美女",
                "author": "ミツキイのジヨンニイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "教室の建物がすでに狭く、それに準じて運動場も狭かった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の芝居がなぜ儲からなかったかというと、その原因は実に簡単明瞭で、所詮は芝居を観る人の範囲が狭く、それに準じて観客が少なかったためである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "附て云く、余が地名を考定する方針は和名鈔の郡郷等につきて聲音の類せる者を彙集し、其中に就きて地望に準じて然るべき者を擇び取るに在れど、こゝには唯だ其の擇び取れる結果を示すのみ。",
              "citation": {
                "source": "卑彌呼考",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかまへて見た上で、また数に準じて、値段は改めて相談しても好いが、「お売りにならないでせうね、然しまあそれ位ひの値打ちのものなんですつてさ。",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「…………」　云はれて見れば、次第に朝の目醒め時が伸び夜の寝つきがそれに準じてゐるのに！",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "思想もそれに準じてゐたからこの一廓では一切のたくらみごとが計られることはなく、そして名誉心や不平心や貯蓄心を持つ者がなく、天に向つては屡々不平の舌打ちをするが、政ごとに対して不満を持つ者はなかつた。",
              "citation": {
                "source": "円卓子での話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天候に準じて、夫々の日の記録を捏造しなければならなかつたのである――その頃から頭も筆も到つて自由でなかつた彼は、その捏造記録の困難と云つたら、たしかに地獄の苦し味だつた。",
              "citation": {
                "source": "貧しき日録",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もつとも役人や法律家にいわせれば、映画の場合も既存の著作権法に準じて判定すればいいというかもしれないが、それは映画というものの本質や形態を無視した空論にすぎない。",
              "citation": {
                "source": "著作権の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋愛や結婚についても、それに準じて、親の利害に反対しない範囲で、ひとに選んで貰った対手と、婚約時代には交際もするという程度のところが穏当とされたのであった。",
              "citation": {
                "source": "若き世代への恋愛論",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに準じて変更される民法の結婚の規定は、これまでの民法の矛盾をとりのぞいた。",
              "citation": {
                "source": "世界の寡婦",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "故にこの場合に於ける運動の様相――可能性――は運動学に準じて決定されるとカントは云う。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に今の場合、運動の様相は動力学に準じて決定されるものである。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
