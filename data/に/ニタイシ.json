    "definitions": [
      {
        "index": 1,
        "gloss": "towards",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たゞ眠りに入る一寸前、小さい声で十分か二十分間位呟くくせがあり、その呟きに対して答へると聞きちがへてダダをこねはじめたりすることがあるのは欠点だ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ音楽やリズムといふことに対しては優れた感覚を有してゐた。",
              "citation": {
                "source": "デボルド―※ルモオル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に対して或人は理智の欠乏がその原因だといひ、或人は共通信条の不在を嘆いてゐる。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　それや退屈つてことに対しては、大変同情は感じてるさ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆつくりいつくしめば、いつくしんだだけ人様に対して反動を廻すとかなんとか、さういふ自他のけぢめを掻き毟つたやうな行為は少くなるんだし、自分としてもコクのある気分でゐられるんだ。",
              "citation": {
                "source": "私の事",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし夫人はあくまで良人に対して謙遜だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は田舎の程度の低い学校を出たばかりで、充分の高等教育を受けなかったので、常に自分の無学を悲しみ、良人に対して満足な奉仕ができないことを嘆き詫びた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際彼の妻のように、良人に対して忠実な奉仕をする女性は、普通の西洋婦人の中にはほとんどなく、これほどまた男が殿様扱いにされる家庭生活も、西洋では考え及ばないことであるから、ヘルンの手紙をよんだ外国人たちが、いかにその日本の友人を羨望したかが想像される。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの小動物に対して、彼はいつも『あなた』という言葉で呼びかけ、人間と話すようにして話をした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどにも情深く、心根のやさしい人があるかと思い、ヘルンに対して、何かいじらしく涙ぐましいものさえも感じたというのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いが既に来り、死の近づいて来たことを知った彼は、すべての自然を感傷的に眺めることから、万象に対して愛以上の深いものを注いだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようなこと、決してないのです』と夫人が言うに対しても、『心からの話、真面目のことです』と言い、『仕方ない！",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "またかつて私たちの敬愛の的であった田舎｜親爺の大政治家レニンも、常に後輩に対し、「勉強せよ、勉強せよ、そして勉強せよ」と教えていた筈であります。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "講談社がキングという雑誌を復活させたという新聞広告を見て、私は列国の教養人に対し、冷汗をかきました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に外国からやって来た素見の客（たとえば、松岡とか大島とかいう人たち）に対しては、まるでもう処女の如くはにかみ、顔を真赤にしたという話を聞きました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、あなたに対して完璧の人間になろうと、我慾を張っていただけのことだったのです。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、帽子をあみだにかぶっても気になるし、まぶかにかぶっても落ちつかないし、ひと思いに脱いでみてもいよいよ変だという場合、ひとはどこで位置の定着を得るかというような自意識過剰の統一の問題などに対しても、この小説は碁盤のうえに置かれた碁石のような涼しい解決を与えている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども人は、その十分の一以上の発表に対しては、必ず顔をしかめる。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の無礼な嘲笑に対して、堪忍出来なかった。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人に対しても鑑賞眼がきびしいのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人の富や名声に対しては嘗つて畏敬の念を抱いた事は無いが、どういうわけか武術の達人に対してだけは、非常に緊張するのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小坂氏一族に対して、ひそかに尊敬をあらたにしたのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍の名人の子孫に対して私は極度に用心し、かじかんでしまったのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、どうせ、駄目な男と思われているのだから、先生に対して少しも気取る必要は無い。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の新人諸君に対して、責任を感じましたので、一言申し開きを致します。",
              "citation": {
                "source": "自信の無さ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る正直な人から聞いた話であるが、双葉山という男は、必要の無いことに対しては返辞をしないそうである。",
              "citation": {
                "source": "横綱",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が、真率にして齢を重ねる時、「習慣」の存在に対して次第に寛容になることは、自然なことである。",
              "citation": {
                "source": "夭折した富永",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「散文が結果的に一つのイデーの下に凝集してゐるに対し、詩は一つのイデーから出発する」といふ河上氏の言を借用するとして、その真偽如何を問はず、詩が欲しくなる時、詩人は「一つのイデーから出発」してゐるもの即ち詩に赴くのであつて、他の物へではない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　要するに芸術の泉とは徒然草に、心の鏡が澄んでゐれば全ての物が正しく映る云々の裡にあるのであつて、東洋人は自然に対しては非常に心澄ませたが、人に対しては未だ澄むことなく、卑下しすぎたり頑なだつたりしてゐる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく直接観測し得らるべき与件の僅少な問題にたいしては種々の学説や仮説が可能であり、また必要でもある。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
