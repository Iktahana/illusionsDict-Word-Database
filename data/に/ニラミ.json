        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "両足を拡げ、反射鏡に手をかけると、今度こそ本調子に赤坊の口中を睨み込んだ。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから客の方で黙っていると、結局睨み合ってしまう。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの睨み合いが苦しいのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘をはたっと睨み、焦げつく声でいった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　黄は睨み朱は吼える、プルシアンブルーはうめく。",
              "citation": {
                "source": "二科狂想行進曲",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "爆撃でヒビのイツた病室の天井を睨み乍ら寝苦しい夜つれ／″＼に考えた事、酒の席で武山オジサンにでも談して見て呉れ。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "父っつあんは何故ッ、何故お貸元をッ」　「五月蝿えッ」　親子の睨み合い――　「石松、今夜はもう遅いから寝ろ」　「父っつあん、一と言云っとくが……お前が何んと云ったって、俺ァ清水のお貸元の身内になるんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　半次、ジロリと仲蔵を睨み、Ｔ「何から何まで　俺の先生そっくりだァ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "観衆をハッタと睨み、Ｔ「喧しいやい！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉花道から、大刀片手に大跨にヅカヅカと舞台へ来り、平土間に向って、Ｔ「文句が有ったら　上って来い」　観衆睨み乍ら舞台の端を行ったり来たり「文句ある奴何奴だァ」と怒鳴って歩く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「學校では、藪睨みした。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "店員の怪しむような眼を睨みかえして油絵を見た。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "たたなわる葡萄畠や古い町々を涙を流して過ぎるかわりに、巡査と睨みあいながらバビロンをほっつきまわってるんだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて暫く空を睨みいて、忽ち激しき運動にて両手を顔に覆い、両肱を机に突き、死人の如く動かずに坐りいる。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ツの市街が岸のはなで睨み合って対峙している。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」藤二は睨みつけられた。",
              "citation": {
                "source": "二銭銅貨",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この探索をはじめる時に、わたくしはきっとこの事件には魚屋が係り合っていると睨みました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しまだそのままに済ませそうもない嶮しい顔色で、相手を屹と睨み詰めていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、縛られるとも、牢へ入れられるとも、勝手にするが好い」　くやし涙の眼を瞋らせて、お登久は男の顔を睨みつけると、彼はその眼を避けるように顔をそむけたが、その方角にはまた半七の眼がひかっているので、彼はもういっそ消えてしまいたいように俯伏して、稜毛の逆立った古畳に顔を埋めてしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く申し立てろ」　そばにはお登久が執念深そうな眼をして睨みつけているので、千次郎も少しためらっているらしかったが、半七に催促されて彼はとうとう思い切って白状した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こいつら、おぼえていろ」　睨みまわして立ち去ろうとする中間を、半七は呼び止めた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「町人、これはなんでござる」「御覧の通りでございます」「どういうわけで、かようなものを持ってまいられた」と、式部は箱のなかの品を睨みながら云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故、こんな男に睨みがきくのか、幹太郎は、一寸解せなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大陸のかくしゃくたる太陽は、市街をも、人間をも、工場をも、すべてを高くから一目でじり／＼睨みつけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "副官は、剣吊りボタンをはずして、ぞろぞろ押しよせた十四人を、いぶかし気に睨みまわした――何ごとだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中尉は、時を、六角の眼でじいッと睨みつけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "睨み合いと、石の飛ばしあいをやっていた方向で銃声がした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中隊長は、通訳からその意味をきくと、じろりと、いかつい眼で暫らくその男を睨みつけた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "再び中隊長は、じいっとその男を睨みつけた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "動物が巣にいる幼い子供を可愛がるように、家畜を可愛がっていたあの温しい眼は、今は、白く、何かを睨みつけるように見開れて動かなかった。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
