    "definitions": [
      {
        "index": 1,
        "gloss": "suddenly (stick out, appear, extend, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」あの人は無理に笑ってみせようと努めたようだが、ひくひく右の頬がひきつって、あの人の特徴ある犬歯がにゅっと出ただけのことである。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くだんの新内、薄化粧の小さな顔をにゅっと近よせ、あたりはばかるひそひそ声で、米屋、米屋、と囁いた。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝っぱらから酒がはいっているらしく、顔じゅうあぶらが浮いていて、雨でもないのにまくり上げた着物の裾からにゅっと見えている毛もじゃらの足は太短かく、その足でドスンドスンと歩いて行く。",
              "citation": {
                "source": "四月馬鹿",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "江戸の山の手に住んでいる侍の一人が、某日の黄昏便所へ往って手を洗っていると手洗鉢の下の葉蘭の間から鬼魅の悪い紫色をした小さな顔がにゅっと出た。",
              "citation": {
                "source": "通魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "八重ちゃんはいつもエプロンの袖から白い腕をにゅっと出して、それが生々しく魅力があった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "指をもぞもぞさせていると思えば、手がにゅっと出てきた。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂「落ち」を、ひた隠しに隠して、にゅっと出る、それを、並々ならぬ才能と見做す先輩はあわれむべき哉、芸術は試合でないのである。",
              "citation": {
                "source": "如是我聞",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにはお秋お冬おふたりの評判娘がおるはずだがと思っておりましたら、にゅっと障子の穴から女の手が出たんでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "たったひとりのかわいい妹、日ごろわたくしが母代わりになっておりましたゆえ、当夜もこのわたくしが片ときも目を離さず、なにから何まで世話をしたのでござります」　だのに、障子の穴からにゅっと手が出たとすれば、怪奇の雲はいよいよ怪奇な雲に包まれてきたのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "手が障子の穴からにゅっとのぞいたというつるはある。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "りっぱにいいましたよ」「しかるに、障子の穴からお冬の手がにゅっと出ているんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "己は濡れた枯蘆の中の小さな祠の傍へ寝ていたが、枯蘆のさきには一｜艘の小舟が着いていて、白髪の老人が水棹を張ってにゅっと立っていた。",
              "citation": {
                "source": "牡蠣船",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その拍子に彼女の裸体の上半身が、鼠色の毛布の中からにゅっと出たのをはっきりおぼえています。",
              "citation": {
                "source": "アパートの殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると橋の上へ一尺ほどの黒いものがにゅっと現れた。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔だけ出たのではなく、びっくり箱のふたがあいたように、蓬々の頭と大きい黒い顔と、ぼろをまとった半分むきだしの肩とが、いちどに、にゅっと深い草の中から現われた。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "院長はシャツの袖を高々とまくりあげ、にゅっと伸ばした腕に波をうたせながらやって来て、『麻酔はいいかね？",
              "citation": {
                "source": "麻酔剤",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "セリファンが門を敲きだすと、間もなく耳門があいて、上っ張りでも頭から被ったらしい人の姿がにゅっと現われて、嗄がれた女の声で『誰だね、門を敲いてるのは？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、もし、どこからともしれず、にゅっとばかりに馬の鼻面が彼の肩の上へのしかかって、その鼻口から彼の頬にふうっと一陣の風でも吹きつけないかぎり彼は自分が書きものの行の中にいるのではなくて、往来の真中にいるのだとは気がつかなかったであろう。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、もうそろそろ広場の端へ来たのではないかと思って目をあげたとたんに、突然、彼の面前、ほとんど鼻のさきに、何者か、髭をはやしたてあいがにゅっと立ちはだかっているのを見た。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイソイ・パフヌーチエヴィッチだの、マクドナルド・カルロヴィッチだのといった、これまでついぞ聞いたこともないような人々が顔を見せたり、これまで見たこともないような、おそろしく背の高い、手に貫通銃創のある長身の男がにゅっと客間へ現われたりした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "新宿の甲州屋の陳列のなかの万年筆が、電信柱のようににゅっと眼に浮ぶ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がしょんぼりしたかっこうで、私を見るので、私はにゅっと舌を出してみせた。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っぱらって唄をうたっているところへ、にゅっと野村さんが這入って来た。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまにいいことがあるぞと云ってくれているのではないかと、にゅっと首をあげている亀の表情をじいっとあきずに眺めている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "みな一様にカーテンが引かれて、その一つ一つに数字が際立ってる、ひっそりしたなかに、丁度私の顔の真正面に、にゅっと、裸の足が一本つき出て、ゆらゆらと動いてるのである。",
              "citation": {
                "source": "奇怪な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして空間ににゅっと片手を白くさしあげてがっくりもとのままに倒れてしまった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんに風呂場の入口の硝子戸が開くと、腐った梨のような貌がにゅっと出て来た。",
              "citation": {
                "source": "いのちの初夜",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "塔の屋根が丸くて、そして中で機械をまわすと割れ目が出来、そこからでかい望遠鏡がにゅっと出るのさ。",
              "citation": {
                "source": "火星探険",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
