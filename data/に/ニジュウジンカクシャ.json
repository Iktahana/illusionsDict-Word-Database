        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "酒飮み共の人生は、二重人格者としての人生である。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二重人格者の甲乙の性格が交代で現われるような気がした。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐでりんは研究の余地ある二重人格者ではないでせうか。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼がどうしてこのような二重人格者となったかは、はっきりわかっていない。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　右の次第であるから、二重人格者河村八九郎の、人格交替の時間短縮をさまたげるために、鬼頭博士が推薦されたのも当然のことであった。",
              "citation": {
                "source": "二重人格者",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔悪魔は神の二重人格者である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の点では彼は二重人格者であると云う事が云える。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はひどい二重人格者ではあったが、決して偽善者ではなかった。",
              "citation": {
                "source": "ジーキル博士とハイド氏の怪事件",
                "author": "THE STRANGE CASE OF DR. JEKYLL AND MR. HYDE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
