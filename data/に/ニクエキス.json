          "literary": [
            {
              "text": "蚊取線香、靴篦、歯ブラシ、征露丸、梅肉エキス、蚤とり粉、毛筆、紙挟み、殆ど使用に堪へさうもない安全剃刀、パイプなど畳一杯に展げられてゐたが、ゲートル、帽子、雑嚢などになると、一層奇妙なものが多かつた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はクレオソート玉がどこにもないし、梅肉エキスだの水を消毒するものだの持たせました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワインやブランデーの木箱、肉エキスの缶詰やボブリルの瓶などがあり、さながらトリガーセン島を兵站病院に指定して、敵侵入に備えるが如し。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
