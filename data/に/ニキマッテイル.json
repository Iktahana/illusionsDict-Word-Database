    "definitions": [
      {
        "index": 1,
        "gloss": "sure to ...",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういうあんまりうま過ぎるのはたいていうそに決まっていると言って皆で笑った。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなに強いポチが殺される気づかいはめったにないし、ぬすもうとする人が来たらかみつくに決まっている。",
              "citation": {
                "source": "火事とポチ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死にさえすれば、ことに若死にさえすればたいていの奴は天才になるに決まっているんだ。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、本当でないに決まっている。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、何時でもそれに決まっている正午の汽車に、晃一の姿は見えなかった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにいれば大抵の患者は健康になるに決まっているよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし自分の取るべき方嚮について、親たちに相談しようというはっきりした考えもなかったし、話してみてもお前の好いようにと言うに決まっているのだったが、何となし家を見たいような気がして、一と思いに乗ってしまった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "私をそうやっておいて、どこかのお嬢さんと結婚するに決まっているわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房で亭主に浮気をされることを考えてごらん、株屋のように体が閑で金にもそう困らない割に絶えず頭脳をつかっているものは、どうせ遊ぶに決まっているよ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も巻き添えを受けてお払い箱になるのに決まっている。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん今までわたくしが意識して故意にしたつもりのものとては一つもありませんですけれども、東京で池上と交際えばその青年を妙な神秘憧憬病患者のようなことにしてしまうし、それをそのまゝ置いて、こんな風に旅出の日数を重ねたら、一層彼は拗れるに決まっているのに、ついと旅出をしてしまったのです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその復讐のために堂島を探して銀座に出るなどと話したら、直に足止めを食うに決まっている――加奈江も明子も口に出さなかった。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、それほど貴重な物ではないに決まっているがね。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時代の習いとして、どこの藩でも隠密が入り込んだと覚れば、彼を召捕るか、殺すか、二つに一つの手段をとるに決まっているのであるから、叔父は早々に身を隠して、その危難を逃がれるのほかはなかった。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "行き着く先は、電脳社会をどうデザインするかとなるに決まっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが見たこともない新しいものが誕生するのは、タマゴの中からに決まっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "有象無象の知恵が集まって、どんどん乗り越えられていくに決まっているじゃないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなもの一目見れば、二つともマックのぱくりに決まっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし逃げるようならば、いよいよ怪しいに決まっているから、容赦なしに挙げてしまえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことが長く続いていれば、店は次第にさびれるに決まっているので、番頭の金兵衛もひどく心配していたが、幸いにお藤の足の痛みはだんだんに薄らいで、もう此の頃では馬道へ通わないでも済むようになった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こう云うと、たいそう侠気があるようですが、これをうまく片付けてやれば、屋敷からは相当の礼をくれるに決まっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "薄雲の碁盤",
                "note": "青空文庫"
              }
            },
            {
              "text": "即座に成敗されるに決まっている。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって今度のお直の家出も、内輪の事情からではないに決まっていると、お粂は保証するように云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半七先生",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい私から哀訴したところで、上でお取りあげにならないに決まっているから、こればかりは私の力にも及ばないと諦めてもらいたい」　それを聞いて、王婆は手を戟にして罵った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "酉陽雑爼（唐）",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊び歩くという以上、どうで碌なことはしないに決まっているし、叔父さんは随分お金を遣うそうで、叔母さんは大変に心配しているんだよ。",
              "citation": {
                "source": "蜘蛛の夢",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、大隅君には友人も少いし、いまはもう私が引受けなければ、せっかくの縁談もふいになってしまうにきまっているし、とにかく私は北京の大隅君に手紙を出した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはどちらがいいか、議論をするとわからなくなるにきまっている。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに対しては出来るだけの応急救済法を講じなければならないことは勿論であるが、同時にまた将来いつかは必ず何度となく再起するにきまっているこの凶変に備えるような根本的研究とそれに対する施設を、この機会に着手することが更に一層必要であろうと思われる。",
              "citation": {
                "source": "新春偶語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが猫の毛皮は大抵の物と摩擦すれば陽性になるにきまっている。",
              "citation": {
                "source": "猫六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が山崎であってもきっとあの通りの誤解をするにきまっている。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
