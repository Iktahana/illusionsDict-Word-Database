  {
    "uuid": "47cf6131-b41a-5bef-9ca8-0a501d74038c",
    "entry": "日帝",
    "reading": {
      "primary": "にってい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese imperialism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "諸王不穏の流言、朝に聞ゆること頻なれば、一日帝は子澄を召したまいて、先生、疇昔の東角門の言を憶えたもうや、と仰す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁宗の洪されて逍遙城に内れらるゝや、一日帝の之を熟視するにあう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時オレが与太を飛ばしていた広島の片田舎にも、「アメリカはベトナムから出ていけ」だの「東大解体」だの「日帝打倒」だのの胴間声は響いていた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワープロの辞書にもない「日帝」が打倒されるとは、十六歳のオレにも思えなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の時代の観客は、その騒々しい粗野な平土間席で、昨日帝劇の見物がそれを見て大いに笑ったその笑いの内容で、笑って見物したであろうか。",
              "citation": {
                "source": "現代の主題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母「だってすえ子はもう土曜にかえしてあったじゃあありませんか」「ハハハハ本当にそうだったな」私「一寸お忘れになったのね、そのとき」「ふーうむ」　これは母コウヅに女中ととまり　かえって、その日帝劇で父と会ったとき、父上の話されたこと。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日帝国議会停会を命ぜられし時の記事あり。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日帝は碁を打っておいでになった。",
              "citation": {
                "source": "源氏物語",
                "author": "宿り木",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃フィルムに現われる諸俳優について、一々の批評をして見た所で、その俳優に対する好き好きがあろうから無駄な事だが、私は過日帝国館で上場された改題「空蝉」の女主人公に扮したクララ・キンベル・ヤング嬢などは、その技芸において頗る秀でたものであると信じている。",
              "citation": {
                "source": "活動写真",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "偶々、先日帝大劇講演会に列して、林和氏の講演を聴き、文芸座の上演戯曲選定方針について興味ある意見に接し、更に、今日築地小劇場が、来年度より創作劇を上演するといふ、歓ぶべき報道を読んで、もう一度、此の問題を考へて見たくなつた。",
              "citation": {
                "source": "上演目録",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彦太君は帝大生で、前途に嘱望せられた青年であったが、この日雨を冒して東京の親戚まわりをした後に間もなく病気にかかって、十月三十一日帝大病院でついになくなられた。",
              "citation": {
                "source": "震災後記",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "有楽座過日帝国劇場に合併し久米秀治氏事務を執れり。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之四大正九年歳次庚申",
                "note": "青空文庫"
              }
            },
            {
              "text": "音次の車は翌日帝大の構内にすててあった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その四　ああ無情",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日帝室博物館に所藏される昌造作の字母は鋼鐵に彫刻したものであるが、それはこのときより數年後、安政年間の作である。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで昌造が日本活字創造のこの第二期で、「流し込み活字」に努力したことは、たとへば今日帝室博物館に所藏される昌造作の鋼鐵製日本文字字母が、安政年間の作だといふ由緒によつても理解できよう。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの顛末を書く代りに、昭和十年七月十五日帝國圖書館發行の册子『小泉八雲先生記念碑成りて』中の一文を轉載させて頂く。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで脇本さんに紹介を願って、一日帝大の美術史研究室に藤懸教授を訪ね、泉石の遺品を見せて貰い、かつ泉石のことについて色々の話を承った。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吾人は昨日帝都中に一種の不可思議なる風聞あるを耳にせしが、幾ばくもなくして、その風聞の事実なる事を確認したり。",
              "citation": {
                "source": "鰐",
                "author": "ドストエウスキー　Fyodor Mikhailovich Dostoevski",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕達はあの日帝国ホテルのグリルで飯を食った。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "内務大臣はナポレオンに言った、「陛下、私は昨日帝国において最も勇敢な男に会いました。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三日帝王、賀名生に御着二十八日吉野｜金峰山に入御　と、見える。",
              "citation": {
                "source": "私本太平記",
                "author": "黒白帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、済まないがとにかく明日の朝まで待ってくれるようにっていって、そのまま寝てしまいなすったわ」「ああ、いいよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところが、僕はあれから君を逃がさないようにっていいつかってあるんだぜ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどお金はあたしたち貴族は貴族だけど、いま急にっていったって、ないものはないんですからね。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の脚がほとんど股のつけ根のところから切れており、左の腋の下にっていた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどの日曜日にっていうやつさ。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは、弟のようにっていうほうがよけりゃ、それでもいい。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじがこいつをくれたについては、きっと、わたしも使うようにっていう腹だったろうと、こう思ったもんですから、そのうち、これで嗅ぐようになったわけです」「そんならまあ、君は好きで嗅ぐわけじゃなく、お父さんの記念を尊重して嗅ぎたばこを嗅ぎ始めたんだね」「慣れるのにちっとも骨は折れませんでしたよ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「急にっていうわけにも行きますまいが、いずれ母の考えもききました上で、手紙ででもご返事いたしますから。",
              "citation": {
                "source": "次郎物語",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもことばでも思想でも、一つがまた一つを誘い出すものでしてな――ほらあなたは先ほど正式にとおっしゃいましたね、つまり尋問の態度について……しかし、正式にっていったいなんでしょう！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
