    },
    "definitions": [
      {
        "index": 1,
        "gloss": "schedule",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伯林にちらほら街路樹の菩提樹の葉が散り初めたのは十日程前だった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「四日程前よ」　「何しに行ったんだ」　「おはんさんから手紙が来たの」　「おはんさんって……誰だ」　七五郎が、　「お前の女房じゃねえか？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その病室にはアメリカへ出稼ぎに行つて、肺結核に罹つて、故國で死にたいと云ふ望みから重體のまま歸朝して來た中年の紳士が、その十日程前からはいつてゐたのだつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十日程のなやみで、げっそり痩せた女の頬。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮月　――では十日程したらまた陶器が溜りますから、差引残りの価だけのものを持って、あなたお宿まで届けに行って下さい。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日程経った頃だったろうか、千日前のお午の夜店で、夜店外れの薄暗い場所に、しかもカーバイト代を節約した一層薄暗い店を張っていると、おっさん一杯くれと若い男が前に立った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから十日程のち、二十二歳の良寛さんは、ただ一人の長い旅にのぼつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子からして疑へば、このＱ――芸館を借りることに就いて、既に約定されてゐたものを反対側の連中の策謀と思はれる力で、貸すとか貸さぬとか、開会ももう十日程の目睫に迫つて、故障が持ち上つた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "会津から佐沼への路は、第一日程は大野原を経て日橋川を渡り、猪苗代湖を右手に見て、其湖の北方なる猪苗代城に止まるのが、急いでも急がいでも行軍上至当の頃合であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日から十日程たって、千日前へ行くと「花屋」の主人がせっせと焼跡を掘りだしていて、私の顔を見るなり、「わては焼けても千日前は離れまへんねん」　防空壕の中で家族四人暮しているというのである。",
              "citation": {
                "source": "神経",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "果然雨天順延となって、私の旅行日程にもまた一日の狂いが生じて来たので、無聊に苦しむよりは雨の日本ラインの情趣でも探勝しようかとなった訳である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "犬は、七日程前に、恁した機會かで此曠野の追分へ來た。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日程前に、高い空の上を鳥が一羽飛んで行つて、雲に隱れた影を見送つた限。",
              "citation": {
                "source": "散文詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日程前の午過ぎ、友人に頼まれた或る本を探すために、本郷通りの古本屋を一通り漁った私は、かなり眼の疲れを覚えながら、赤門前から三丁目の方へ向って歩いていた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近処の島民に聞くと、二日程前｜本島の何処とかへ行くと言って出掛けたきり帰って来ないのだという。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "十日程たって今度は娘が死んで東京に帰るとの話でしたので、私は一層同情しました。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝が漫遊の日程は、よも變更を容さぬにはあらざるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてその金の催促に来るごとに、役人を近村の料理屋へ連れ行き乱酔せしめ、日程尽き、役人｜忙て去ること毎度なり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七〇年を前後する時期、日本の電算機市場の自由化が政治日程に上ったときのことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "用はそこ／＼に達して三日程の猶豫があつたから急いで上京した。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしのために一行は日程を変へて、上井出村に二、三日を費やすことになり、叔母の家に来て見ると、案の条わたしの描いた画は離室の欄間にかゝつてゐた。",
              "citation": {
                "source": "湖の夢",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "元々風来居士であるから、おそらく日程は解らず、この村の生れの癖にこの風が大嫌ひで、どうかすると春凪の候でなければ戻らぬことも屡々だ――と家人はそれとなく私の帰京を促した。",
              "citation": {
                "source": "冬物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから五日程して、よく沼岸の砂地にあそびにくる、尻尾の短い赤い小鳥が姉さんの居処をしらしてくれました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大15・９愛国婦人）------------------------------------------------------------------或る手品師の話　老人の手品師が、河幅の広い流れのある街に、いりこんで来たのは、四五日程前でした。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大15・９愛国婦人）或る手品師の話　老人の手品師が、河幅の広い流れのある街に、いりこんで来たのは、四五日程前でした。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論二日程前の夜、Ｇ――とＩ子とが寿美子をつれて銀座を歩いてゐたとき、武村が新橋駅で寿美子とゐるところを見られたといふ、雑誌記者Ｓ――君と其友人とに出逢つて、一緒にフルーツパラアへ入つた。",
              "citation": {
                "source": "彷徨へる",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、済まないがとにかく明日の朝まで待ってくれるようにっていって、そのまま寝てしまいなすったわ」「ああ、いいよ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところが、僕はあれから君を逃がさないようにっていいつかってあるんだぜ。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけどお金はあたしたち貴族は貴族だけど、いま急にっていったって、ないものはないんですからね。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "左の脚がほとんど股のつけ根のところから切れており、左の腋の下にっていた。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
