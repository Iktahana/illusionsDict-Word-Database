        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから客は低くかがんで、高さ三尺ぐらいの狭い入り口〔にじり口〕からにじってはいる。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は路地をはいってゆき、にじり口ではなく、玄関のほうへまわった。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶席のにじり口から出て、そちらへまわっていたのだろう。",
              "citation": {
                "source": "薊",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今、にじり口の外まで来て、沓ぬぎの前に額ずいた庭番はそれであろう。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "使いの僧は、待たせておけ」　閉めてあるままのにじり口へ向って庭番は、「かしこまりました」　と、ていねいに礼をして、草履の音も偸むように、露地の木の間を戻って行った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
