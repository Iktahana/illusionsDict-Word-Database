      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "meat and matrimony (Buddhism)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その寺は肉食妻帯の寺でその住職には妻子があった。",
              "citation": {
                "source": "鷲",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は肉食妻帯の本願寺だ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "精神的になって来ると――そうですね、古臭い例を引くようでありますが、坊さんというものは肉食妻帯をしない主義であります。",
              "citation": {
                "source": "模倣と独立",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧侶であって肉食妻帯するものが現われるであろう。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "親鸞は例えば肉食妻帯を時代の故に当然であるとして弁護しようとはしなかったであろう。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時｜在所の者が真言の道場であつた旧地へ肉食妻帯の門徒坊さんを入れるのは面白く無い、御寺の建つ事は結構だが何うか妻帯を為さらぬ清僧を住持にして戴きたいと掛合つた。",
              "citation": {
                "source": "蓬生",
                "author": "與謝野寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、肉食妻帯が僧侶に禁ぜられてゐた時分の事であるから、表向きはどこまでも出家ではない。",
              "citation": {
                "source": "孤独地獄",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉食妻帯はけっして真宗信者の特色ではない。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉食妻帯しても救わるるであろう。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺生や姦淫を予想する肉食妻帯について、あまりに鈍感になることは真宗信徒の恥辱である。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗い寺院に肉食妻帯の厳禁を廃し、多くの僧尼の生活から人間を解き放ったというのも、虚偽を捨てて自然に帰れとの教えから出たことである。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "この際に当って、献身的に彼らの教導に従事したものは、肉食妻帯をすら忌まなかった一向宗、すなわち浄土真宗の僧徒である。",
              "citation": {
                "source": "特殊部落と寺院",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体僧侶の肉食妻帯は、我が僧尼令の厳禁するところで、酒を飲み、肉を食い、五辛を服するものは三十日苦使せよ、僧寺に婦女を停むる一宿以上ならば十日苦使せよ、五日以上ならば三十日苦使せよ、十日以上ならば百日苦使せよとある。",
              "citation": {
                "source": "特殊部落と寺院",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "濫僧とは前記餌取法師の徒で、肉食妻帯の下司法師ではあるが、もちろんそれ自身餌取ではない。",
              "citation": {
                "source": "旃陀羅考",
                "author": "日蓮聖人はエタの子なりという事",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家に妻子を蓄へ、口に腥※を啖ふ」とあって、すなわち肉食妻帯の在家法師であり、その「形は沙門に似て、心は屠児の如し」とあって、もちろん仏教信仰からの出家ではなかった。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて遂には自身屠殺を業とせずとも、肉食妻帯を常習とするいわゆる濫僧の徒をも、餌取法師というようになった。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる有様であったから、僧侶は自身肉食妻帯が出来なかったのみならず、屠者に近づくことも出来なかった。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて親鸞は自身肉食妻帯を体験して、破戒の行業を辞せず、非僧非俗の愚禿と称して、在家法師、俗法師の徒を以て任じ、社会のドン底に沈淪した最下層民たる餌取法師、非人法師の徒をも疎外することなく、いわゆる御同朋御同行として、世間から最も罪業深いものと認められた、かの屠者の輩をまでも済度された。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その落伍者が国司の誅求から逃れんが為に、或いは生活の便を得んが為に、肉食妻帯をも辞せぬ俗法師となったので、濫僧と呼ばれ、声聞師と呼ばれ、或いは非人法師、餌取法師などと呼ばれても、つまるところはいわゆる「下司法師｜原」である。",
              "citation": {
                "source": "賤民概説",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは法師でありながら、令条に厳禁したところに背いて公然と肉食妻帯をあえてし、俗道場を設けて禁厭巫呪卜筮を行い、家門に経を誦して衣食金銭の報捨を受け、遊芸を事とし、雑職に従い、もってこれを生計の方便として不思議と思われていなかったのである。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして戒律のやかましかった時代において、肉食妻帯公許の宗旨を発明したのが、必ずしも親鸞上人を始めとするものではないことを示しているのである。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊の外愚僧を愛せられ、是非とも満行寺に立寄れよと御勧めなされ候により、そのまゝ御厄介に相なり候処、当山は申すまでもなく西本願寺派丸円寺の分れにて、肉食妻帯の宗門なり。",
              "citation": {
                "source": "榎物語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "この戒めは昔のことであったが、肉食妻帯が許されてある今日では、もし碑を建てれば、多分その碑面へ「歓迎葷酒入山門」と刻するのであろうか。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにおいて前者は僧に肉食妻帯を許して僧俗の区別を緩やかにし、後者はこの間に最も厳格な区別を立てる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一五、仏教者の肉食妻帯　友人、船中にありて問うて曰く、仏教は必ずしも肉食妻帯を禁ずるをもって一宗の要旨とするにあらず。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに、今日の宗旨の肉食妻帯せざるものをもって真の仏者となすはいかん。",
              "citation": {
                "source": "欧米各国　政教日記",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "偖この※蓄の事たるや、夫々宗旨社会に仏の制度、祖師の厳規のある有れば、元来政府より出令すべき事柄にあらざるに、遂に出令ありしは、その意旨を察するに、只僧侶に対し、不律不如法の処刑を廃すと云う迄に止まりて可なるべき事なるに、肉食妻帯勝手たるの令出しは、本と政府の好心より出るにあらず。",
              "citation": {
                "source": "洪川禅師のことども",
                "author": "鈴木大拙",
                "note": "青空文庫"
              }
            },
            {
              "text": "禅刹をみな真宗に改めるも亦妙ではないか、肉食妻帯お構いなしの処などは、今時の禅坊さんの尤も歓迎するところである。",
              "citation": {
                "source": "僧堂教育論",
                "author": "――禅僧の友人に与う――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな人々が自分の寺に帰ると、直ちに肉食妻帯の和尚さん又は葬式屋さんにはならずして、その村々のために文化的施設をやろうと思う、自己の向上のために益※学問でもやろうと思う人々が出来る。",
              "citation": {
                "source": "僧堂教育論",
                "author": "――禅僧の友人に与う――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
