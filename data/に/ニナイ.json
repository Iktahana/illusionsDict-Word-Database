    "definitions": [
      {
        "index": 1,
        "gloss": "carrying (on one's shoulder)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（立ちながら休むときは、脊の担い梯子へ、息杖を当てがって、肩を緩めるので「一本立てる」というのである。",
              "citation": {
                "source": "槍ヶ岳第三回登山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "次ぎのランナーは、みんな年が若かつたので、元気にまかせて、担いでゐるのが肥えの筈であることを忘れて、ポチャポチャやりながら駆け出し疾走し始めた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "後ろ頭か、首筋に寒気でもするんかい」　私は又、実際、セコンドメイトが、私の眼の前に、眼の横ではいけない、眼の前に、奴のローラー見たいな首筋を見せたら、私の担いでいた行李で、その上に載っかっている、だらしのないマット見たいな、「どあたま」を、地面まで叩きつけてやろう！",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、その役にも立たない、腐った古行李をもう担いで歩くのが、迚も重くて、足に対して堪えられない拷問になって来た。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が仕度して来るから」「そうかい」　秋山は見張りへ、小林は鑿を担いで鍛冶小屋へ、それぞれ捲上の線に添うて昇って行った。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "咄嗟に小林は、秋山を引っ担いだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前担いでおいでよ」「うん」「ほら、こんなに釣れたよ」　魚籠を解いて腰から外し、子等に持たせた。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母さんにはまた伯母さんとしてのたくさんな担いものがあるらしいから」　胸にこう自問自答して、女は洞の中の男の傍に介抱すべくとどまった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじゃ野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人の側を八百屋が荷を担いで通り過ぎる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "強い男、半次を肩に担いでズドンと投げた。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝山道――夜　葛籠を担いで村人が上って行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と待ってました、とばかり　団九郎、刀担いで、逃げ出した。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "薫との辛い気持も尾をひいているのに、父を見れば父を見るで、また父の気持ちを兼ねなければならない……小初は心づかれが一身に担い切れない思いがする。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく語る我身すらおりおり源叔父がかの丸き眼をなかば閉じ櫓担いて帰りくるを見る時、源叔父はまだ生きてあるよなど思うことあり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつもわたくしの留守を狙って来て、否応なしに担いで行ってしまうんだそうで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は、小さい子供は籠に担い、少しおおきいのは、歩かして、街へ子供を売りにくる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（どッこいしょ、）と暢気なかけ声で、その流の石の上を飛々に伝って来たのは、茣蓙の尻当をした、何にもつけない天秤棒を片手で担いだ百姓じゃ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と挨拶して、裏へ廻って自ら竿を取出して※網と共に引担いで来ると、茶店の婆さんは、　おたのしみなさいまし。",
              "citation": {
                "source": "蘆声",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉藤平太はそこで仕方なく自分でその大トランクを担いで歩きました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "法界節の文句通りに仕方がないからネエエ――てんで、月琴を担いで上海にでも渡って一旗上げようかテナ事で、御存じの美土代町の銀行の石段にアセチレンを付けて、道楽半分に買集めていた探偵小説の本だの教科書の貰い集めだのを並べたのが病み付きで、とうとう古本屋になっちまいましてね。",
              "citation": {
                "source": "悪魔祈祷書",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこであの死骸を蔵元屋から担い出いた大風呂敷か何かが、そこいらに棄てて在りはせんかと一所懸命に探しまわったが、怪しい縄一筋、細引一本見当らんじゃった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「キイキイキイキイ助けてくれ」　と一所懸命もがいておる処へ、最前ドブに落ちた鳥さしがモチ棹を追っかけて来てこの様子を見ると、「雀が鵙を取ってくれた」　と喜んで鵙の首をキュットひねって袋に入れてモチ棹を担いで帰って行きました。",
              "citation": {
                "source": "鵙征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々から借り集めたボロラケットの五、六本を束にした奴を筆者が自身に担いで門を出た時には、お負けなしのところ四条｜畷に向った楠｜正行の気持がわかった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただただ赤裸々な一男性と、一女性とがお互いの愛と、ともに担い合う意力とを吟味するのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家扶は、何か云って紳士夫妻に二三度頭を下げるとまた一たん車から下りて、今度は、かなり厖大なトランクを二つ担いで来て、それぞれの位置にそれを置いて、自分は、一行の一番｜端れに老紳士と並んで坐り、頻りに何か話し初めた。",
              "citation": {
                "source": "動かぬ女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むすこは巴里の花形画家で、おやじや野原のへぼ絵描き……」　こんな鼻唄をうたいながら、お父様はこの頃、何を思ったかおまえの美術学校時代の壊れた絵の具箱を肩に担いでときどき晴れた野原へ写生に出かける。",
              "citation": {
                "source": "巴里のむす子へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "獲物の有無でおもしろ味に変はないで、またこの空畚をぶらさげて、蘆の中を釣棹を担いだ処も、工合の可い感じがするのじゃがね。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大高源吾とか云う、ずんぐりむっくりした人がね、笹を担いで浪花節で歩行いては、大事な土地が汚れるって。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端で水を浴びたり、合長屋の障子を、ト唾で破いて、その穴から舌を出したり、路地の木戸を石※でこつこつやったり、柱を釘で疵をつけたり、階子を担いで駆出すやら、地蹈鞴を蹈んで唱歌を唄うやら、物真似は真先に覚えて来る、喧嘩の対手は泣かせて帰る。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
