[
  {
    "uuid": "e189c543-c127-5cf8-a2fd-80d4b7fb22b0",
    "entry": "煮しめ",
    "reading": {
      "primary": "にしめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
