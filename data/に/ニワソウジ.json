    "definitions": [
      {
        "index": 1,
        "gloss": "tidying a garden",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それがために庭掃除をする仲間が三人いて、夏になると毎日、庭の草を抜き捨てるのに忙しかったそうです。",
              "citation": {
                "source": "江戸の化物",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまつてゐても庭掃除の者が來たり、レコード屋が御用聞きにうかゞつたりするのであつた。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはずかしい心持で病室の窓から延び上って眺めると、時には庭掃除をする男がその窓の外へ来た。",
              "citation": {
                "source": "ある女の生涯",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い頃の母は小さい子供らを腰のまわりにつけて沢山の洗濯物もしたし、台所でも働いたし、庭掃除もしたし、私の小さい頃の日々の思い出の中には、いつも総領娘である五ツ六ツの私をおだてては、自分の助手にして働いていた生々とした美しい母の面影があります。",
              "citation": {
                "source": "わが母をおもう",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高はいつものように庭掃除に忙しく、祖母は台所で朝御飯の仕度をし、叔母は私の役目である部屋の掃除に障子や置物をバタバタとはたいていた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまの休日には庭の草ひき、草刈り、庭掃除で、小牛と山羊をひっ張り廻して遊ぶのが何より愉しみなようである。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑を着て庭掃除をしている農婦。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａは、例によって、庭掃除。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく御庭掃除のじいやさんが、あの松一本でも千円の値うちがあるなんて云ってましたけれど。",
              "citation": {
                "source": "果樹",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身は絵かきにも似合わぬ木強漢だの」　と、言う折から、先程から庭掃除をしていたかの老人が、軒下に来てうずくまり、露月に向って言いました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭掃除に頼んだ植木屋が、御嬢さん、ここいらが好いでしょうと云っている。",
              "citation": {
                "source": "文鳥",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日私がそんな散歩から帰って来ると、庭掃除をしていた宿の爺やに呼び止められた。",
              "citation": {
                "source": "美しい村",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは丁度、若葉が風にゆらいでいきいきとしており、モスの着物が少しあつすぎる入梅前のこと、素足にエナメル草履の古いのをつっかけて庭掃除に余念がなかった。",
              "citation": {
                "source": "入梅",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで境内で鹿を放し飼いにしておくような要領で、この神社の山上高くて広々した境内のあッちこッちに、白衣赤袴の娘さんの幾群かが庭掃除をしていたり、サイセン箱をのぞいていたり、散歩していたり、放し飼いにしてあるね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "伊達政宗の城へ乗込む――仙台の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもなお天部の小法師と称するものは、禁裏御所のお庭掃除のお役をつとめておりました。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「京都御役所向大概覚書」に、余部村小法師勤方一、禁裏御目通御庭掃除、余部村小法師八人え被仰付候訳、左に記之。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小法師は禁中お庭掃除の外、藁箒及びお召の草履を献上する例で、御紋付の提灯をも許されておった。",
              "citation": {
                "source": "エタ源流考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代にはお庭掃除は小法師と称して、もとは丹波の山国から出ておったが、中頃は三条余部村のエタ六人と、寺町今出川下ル町及び上立売下ル瓢箪図子から各一人、都合八人でこれを奉仕し、享保十二年以後は大和丹波市外六人のエタ村から出役し、さらに後には京都蓮台野からもこれを勤めておった。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小法師の称は、徳川時代を通じて禁裏のお庭掃除のお役をつとめたエタの小法師と関係のあるものと認められる。",
              "citation": {
                "source": "俗法師考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり書斎に居る時、また来客を迎える時の衣服をぬいで、庭掃除や煤払の時のものに着替え、下女の古下駄を貰ってはけばよいのだ。",
              "citation": {
                "source": "※東綺譚",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "世田ヶ谷の家には庭掃除の下男と雇婆がいるものの、鶴子は老人が日々の食事を始め衣類や身のまわりの事に不自由しているらしいのを見て、それとなく陰へ廻って気のつくかぎり世話をするようになった。",
              "citation": {
                "source": "つゆのあとさき",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭掃除の下役人が、翌朝あたり一面散らばった紅葉をきれいに掃除した。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第六巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭掃除のときに草を刈りても、その根までことごとくみな取りはらわぬ間は、幾遍となく生い繁りてもとの草となります。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "門番の老爺が庭掃除をしていたが、隙を覗って乃公は会堂に飛込んだ。",
              "citation": {
                "source": "いたずら小僧日記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "垣越しに隣の寺に、年老った和尚さんが庭掃除をしていられるのが見えた。",
              "citation": {
                "source": "幼年時代",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　その侏儒は、京都から雇ってきた蜘蛛太とよぶ男で、庭掃除の小者として使っていたが、側女の山吹とのあいだに、おかしな噂があったので、年景が怒って、先ごろ、牢へ押し籠めてしまった者である。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ裏手の方から、音吉という最近雇入れた庭掃除の爺やがやって来るのが見えた。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「近頃雇入れた、庭掃除の爺やで音吉というのだ」「あの人、さっき門の所で逢いました。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "楽屋口に佇んでいた男というのは、意外千万にも、或は当然至極にも、彼が数日来疑い恐れていた、あの庭掃除の音吉爺やであったのだ。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなくて、庭掃除の爺やが、何の為に今時分、こんな所へ来ているのだ。",
              "citation": {
                "source": "魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
