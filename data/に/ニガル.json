    "definitions": [
      {
        "index": 1,
        "gloss": "to feel bitter",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二十年ばかり前にはそうでもなかったが、近年になるに従って百姓の暮しは苦るしくなっていた。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老人は、圧えつけられた、苦るしげな声で何か云った。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は苦るしげに、引きつっているような舌を動かしている。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲劇になる、痛切な、身を以て苦るしんだ、そのことを喜劇として表現し、諷刺文学として表現して、始めて、価値がある。",
              "citation": {
                "source": "愛読した本と作家から",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、近頃になるに従って、百姓の社会的地位、経済的地位が不利になって生活が行きつまって苦るしくなって来ている。",
              "citation": {
                "source": "小豆島",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼主が――それはシベリア土着の百姓だった――徴発されて行く家畜を見て、胸をかき切らぬばかりに苦るしむ有様を、彼はしばしば目撃していた。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一本しかない一輪車の車軸は、巨大な麻袋の重みを一身に引き受けて苦るしげに咽びうめいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "幹太郎は、小山の下顎骨の落ちこんだ口元が、苦るしげに歪むのを見た。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "驢馬は小さい胴体や、短かい四本の脚に似合わず、大きい頭を、苦るしげに振り振り、六頭が、六頭とも汗だくだくとなっていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当初、売行が悪いのに、苦るしんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、肉体と精神と、両方で苦るしんでいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここの生活はのんきなようで、一番苦るしい。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "連日の勤務、不自由と、過労と、苦るしみによって、工場は守られている。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……英吉利人、米国人、独逸人、日（云いかけたが、時以礼は口を噤んだ）……みな、支那、百姓、工人、苦るしめる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ここにも、彼等が、内地の工場や農村で生活をした、それと同じような、――もっとひどい、苦るしい生活があった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、すゞには、窮屈で、息苦るしかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の、しッかりした顔つきの歩哨は、それでは、小哨長のところまで行って呉れ、と通りのさきの狭ッ苦るしい暗い支那家屋につれて行った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、監視の若い巡査の軽蔑と、冷笑をあびながら、唸き死ぬばかりに、ばたばたと肉体的にもだえ苦るしんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」悔恨のようなものに苦るしめられた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自分達が苦るしめられるために、働いてやりたくはないんであります。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ふむ、――苦るしめられたくはないと云うんだな。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦るしまぎれに、両手でむちゃくちゃに空気を引ッかいた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺等が支那を叩きつける役に使われて、工人や百姓の運動を、邪魔すりゃ、邪魔するほど、俺等の内地の暮しが苦るしくなるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　のんきな軍医は、兵士の苦るしみや、わめきや、怺えきれなくなって手足をばた／＼やるのが快よいものゝように、にこ／＼しながら、平気で処置をつゞけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　トシエは、家へ来た翌日から悪阻で苦るしんだ。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、一段ひくい納屋の向う側にある便所から帰りに、石段をあがりかけると、僕は、ふと嫂が、窓から顔を出して、苦るしげに、食ったものを吐こうとしている声をきいた。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　信用組合からの利子の取立てと、頼母子講の掛戻と、女房と、息子の反対は、次第に親爺を苦るしくして行った。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は若旦那に顔を見られるのが妙に苦るしかった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦るしい中を算段して、いやいやながらも母と妹とに淫酒の料をささげたもこれ又当然。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで僕は、リンピイの鞄と暗黒と一しょにがるしあ・もれの号へ漕ぎ寄せてみると、長い大西洋を済ました船員達は、上陸番なんか無視して誰もかれも「七つの丘の灯」へ逃げてったあととみえて、船尾の綱梯子が公然の秘密のようにこんなにぶらぶらしていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
