    "definitions": [
      {
        "index": 1,
        "gloss": "staring-out (down) game",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "痩我慢を張っているとすれば、倒された拍子に地面と睨めっこをしている時の顔付は、いったいどんなだろう。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は書物を離れ、ただ一つの文字を前に、終日それと睨めっこをして過した。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡の前で、さんざん睨めっこや、変な表情や滑稽な身ぶりをして楽しんでいると、背後に突然人声がしたのだった。",
              "citation": {
                "source": "不思議なる空間断層",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一太と忠公とは四尺ばかり離れたあっちとこっちで、睨めっこしたり、口の中に両方の小指を突こんでベッカンコをしたりして遊んだ。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "或時は蟇と睨めっこしながら盥の中にかしこまっている。",
              "citation": {
                "source": "チンコッきり",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛んでもない事が初まらなけあいいがと気が付くトタンに、二人とも何となく呉羽さんに一パイ喰わされて、睨めっこをさせられているような気がし初めたんだね。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこれから、鹿子の目撃談を解剖しますかな」　と、法水は窓際に立って、暫く中腰になり、硝子盤と睨めっこしていたが、やがて莞爾と微笑んで腰を伸ばした。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンパスや海図と睨めっこして待っていると、やがて、機関室へ降りて往った陳君が、出帆を僕に促すために、不意に勇ましく汽笛を鳴らした。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "がなおおかしなことには、父はいつのまにか仏壇の方へにじり寄って、新らしい位牌と睨めっこをしていた。",
              "citation": {
                "source": "黒点",
                "author": "――或る青年の「回想記」の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前の手でも我慢してやるから、若いうちはコマメにやりなよ」「よせやい」「ボンヤリ睨めっこしてるよりも、一方が後へ廻って肩をもむのが時にかなっているッてことが分らないかな。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜一晩中無言の行、星と睨めっこをしているがいい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、顎十郎は、そういう馥郁たる匂いを嗅ぎながら、ややしばらくのあいだ、文鳥のような優しい眼と睨めっこをしていた。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、睨めっこといっては少し違うかも知れない。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "いきおい、睨めっこのような工合になる。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "菊香水",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはあの紙片と一と晩睨めっこをしていたんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら、獲物だ」「オウ」　とゆるぎ出たのは、今まで時計と睨めっこをして居た蜂屋文太郎、ズカズカと傍へ寄ると、僅に井戸の縁にかかった兇漢の両手を取って、軽々と上へ引上げます。",
              "citation": {
                "source": "古城の真昼",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「笑っちゃいけませんよ、親分」「笑やしないよ、子供の時から、俺は睨めっこの名人さ、可笑しくたって笑わないから」「弱ったなア、親分、からかっちゃ話が出来ねえ」「贅沢な男だな、さア、言いねえ」　そんな事を言われながら、八五郎はとうとう三日前の晩の事を、一伍一什話させられてしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "身投げする女",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、こうなりゃ始めからやり直しだぞ」　高々と腕を拱いて、朝っから軒の釣忍と睨めっこをしております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "幽霊にされた女",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこから槍が来るか、どこから鉄砲が来るか、それは全く不安極まる四半刻（三十分）でしたが、平次は小判形の迷子札と睨めっこをしたまま、大した用心をするでもなく控えております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "迷子札",
                "note": "青空文庫"
              }
            },
            {
              "text": "女三人で親分を真ん中に、睨めっこのお通夜なんざ洒落たものだね」　お町はすっかり喜んでおります。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次女難",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、銭形の親分さん」「お早う、昨夜は夜っぴて打ったそうだね、佐吉は一度も席を外さなかったかい」「一と晩睨めっこでしたよ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "碁敵",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次は畳の上へ置いた半紙へ、変哲なものを書いて一生懸命それと睨めっこをしているのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "平次屠蘇機嫌",
                "note": "青空文庫"
              }
            },
            {
              "text": "おっと承知の助、皆まで言うな――か何んかで、大呑込で引受けたのは、此間親分に頼まれた、あの病人の身体のことでしょう」「フーム」「中風で口もきけない病人と、半日｜睨めっこをして暮すのはあまり楽じゃないが、その代りお比奈坊にイヤな思いをさせずに、何も彼も調べられるでしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴様の面も変らねえ」「殿様もこのごろはおいとしゅうございます」「はははは」　睨めっこをして淋しく笑う。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白根山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、その金は、そっくり故郷の足利にいる妻子に送り届けることにしておいて、またも例の額面と睨めっこです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "流転の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生米五升を海神の知己に届けると称し、十分間担げるかどうか時計を見つつ耐力試験を行わんと、座敷内に米袋を背負って時計と睨めっこしおりたり。",
              "citation": {
                "source": "同居人荷風",
                "author": "小西茂也",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりすると睨めっこでも始めそうな恰好だった。",
              "citation": {
                "source": "雨あがる",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画面とにらめっこしたままの一年が過ぎて、ふと顔を上げてはじめて、魚岸さんの顔が浮かびました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "革命児ダイナブックの背後に潜む目玉パワーの真実　パーソナルコンピューター業界の関係者を集めて勝ち抜きにらめっこ大会を催す企画は、どう考えてみても魅力に乏しい。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもおっさんのにらめっこがとても面白いとは思えないという基本的欠陥に加えて、この企画には決定的な弱点がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
