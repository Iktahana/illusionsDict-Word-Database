        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "昼は会社員、夜は小説家と、彼は二足のわらじを履いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「二足のわらじを履くのは大変だけど、やりがいがあるよ」と彼は語った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は、二足のわらじを履きながらも、どちらの分野でも成功を収めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "それから、おなじ社の四十代の人から、二足のわらじ、という言葉を僕は初めて受けた」　二十七、八歳の頃から、川島は文章も書き始めた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが他社の媒体にも広がり、個人の活動として認められてはきたけれど、このあたりが限度かなと自分でも思い始めたとき、二足のわらじ、という言葉を受けた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サラリーマンの二足のわらじ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
