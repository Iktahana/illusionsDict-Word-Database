        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本中、いや世界中、このセリフは共通してゐるだらう。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中にも世界中にもこれに似たところはないであろう。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭二君は明治十年十月二十四日東京で生れ、芝桜田小学校から日本中学校に入り故杉浦重剛氏の薫陶を受けた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　日本中の大工業家が寄り合って飯を食ったり相談をする建物がある。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人正風会長になって日本中の婦人の憧憬を、御一身にお集めになる一面には、あらゆる方法であらゆる紳士方の裏面を御研究になったのですからね。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と余儀無く問えば、打笑いて、「私の家は日本中サと謂えば豪気だが、どこと定って屋根は持たぬ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中残らずとは思うが、この夏は、山深い北国筋の、谷を渡り、峰を伝って尋ねよう、と夏休みに東京を出ました。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中を、いや世界を見よう。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――聞きねえ、親なり、叔父なり、師匠なり、恩人なりという、……私が稼業じゃ江戸で一番、日本中の家元の大黒柱と云う、少兀の苦い面した阿父がある。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "）定重　　これは又思ひもよらぬこと、佐々木四郎高綱と日本中にきこえたる弓取が、にはかに浮世を捨てられたは……。",
              "citation": {
                "source": "佐々木高綱",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは宝の木といわれた綾模様の木目を持つ赤樫の古材で、日本中に私の鑿しか受け付けない木だ。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生が死なれるまで介抱をして御恩報じをしたら、あとは坊主になって日本中を旅行してやろう――なぞと思っていたから、なおのこと大飯を喰って元気を養った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪一流の浜村銀行が潰れた時に、日本中で店を閉めたのはこの薄キタナイ※善の事務所一軒だけという事がわかれば、相場師としてこれ以上の名誉はないじゃないか。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてよく考へて見ますと、日本中の奉行さまといふ奉行さまが、多かれ少なかれ、みなさうに違ひありません。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖代々の血統を吟味したら日本中に確たる家柄は一軒もなくなる譯だ。",
              "citation": {
                "source": "鈴木三重吉宛書簡―明治三十九年",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "大鰐は、津軽の南端に近く、秋田との県境に近いところに在つて、温泉よりも、スキイ場のために日本中に知れ渡つてゐるやうである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと、日本中に類のない愚劣｜頑迷の御手簡、ただいま覗いてみました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政治家より頭いいわ」「うちが頭よかったら、日本中みな頭ええわ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "けど、政治家が日本中の人間の一人一人のことを考えてたら、演説してまわるひまもないくらい、忙しいさかいに、だれのことも考えんと、自分のことばっかし考えてるンやろ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば、あれでいけなければこれで来いと、あやしげな処方箋をたよりに、日本中の病人ひとり余さず客にして見せる覚悟をころころと調合したのである。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "うむ、日本中の何処行たっちゃ売っとる。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中を真半分に割って東の方に在るものは皆、満月に買うてやりたいほどの意気組であった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "島原一帯の茶屋の灯火は日の暮れぬ中から万燈の如く、日本中から大地を埋めむばかりに押寄せた見物衆は、道中筋の両側に身動き一つせず。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中の薄情女を震え上らせて見せようでは御座らぬか……と固く固く誓い固めたのであった。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "京大阪の良いお医者というお医者を尋ね求め、また別に人をお遣わしなされて日本中にありとあらゆる癆※のお薬をお求めになりました。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは架空の話だから御差し合いの方には真平御免下さいであるが、田中という人物が唾棄すべき悪党であったり、林という美人が自動車に轢き潰されたり、中村という先生が八ツ切りにされたりしたら日本中の田中氏、林氏、中村氏は、作者に対して報復しようのない怨恨を抱き、不浄を感じ、嫌悪の情を以て本を投出す虞がある。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな馬鹿騒ぎの出来る町が日本中のどこに在るか探してみろ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "博多は日本中の諸芸の都だ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来この棕梠箒売という人種は、日本中、どこへ行っても他国の者が多い。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本中で鯨の事を本格に知っとる者なら私一人かと思っておったが、アンタもいくらか知っとるなあ」「失敬な事を云うな仁三郎。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
