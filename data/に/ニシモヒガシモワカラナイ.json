        "examples": {
          "standard": [
            {
              "text": "突然の事態に直面し、彼は西も東もわからない様子だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この複雑な問題に対して、私はもう西も東もわからない気分だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "多くの情報に囲まれて、何から手をつけていいのか西も東もわからない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
