    "definitions": [
      {
        "index": 1,
        "gloss": "not knowing one's way around",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
