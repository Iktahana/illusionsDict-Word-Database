          "literary": [
            {
              "text": "ホテルへ荷を下ろす。",
              "citation": {
                "source": "踊る地平線",
                "author": "ノウトルダムの妖怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五六歩よろけると、息が詰まる様で、たまりかねて荷を下ろす。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐはじめてください」　ポーニン氏は、平靖号の荷を下ろすのを、たいへんいそいでいる様子だ。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷を下ろすより早く彼らは各自仕事にとりかかった。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "「座り物」という咄家、講釈師、浪花節の興行は、一度この人のところへ「ワラジ」を脱ぐ、「荷を下ろす」つまり世話になる。",
              "citation": {
                "source": "符牒の語源",
                "author": "三代目　三遊亭金馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫売の荷を下ろすとき喧しき秋の蚊を手もて払へばなかりけり九月五日　句謡会。",
              "citation": {
                "source": "六百句",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに同夕刻までに、添田知道氏の依頼による一俳人の句碑、また一読者の墓碑、そのほか、色紙額面などの依頼物の揮毫を一気に果し終わって、心の荷を下ろす。",
              "citation": {
                "source": "年譜",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユスティニアヌス帝の法律は主としてキリスト教の教えの影響により、奴隷の重荷を下ろすための多くのことを行った。",
              "citation": {
                "source": "ギリシャおよびローマ医学の概観",
                "author": "OUTLINES OF GREEK AND ROMAN MEDICINE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜は、積荷を下ろすため、泊りとなろう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "円明の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
