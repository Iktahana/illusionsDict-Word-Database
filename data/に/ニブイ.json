[
  {
    "uuid": "c6b76b42-22a8-51c5-9cc1-7f22007c7a82",
    "entry": "鈍い",
    "reading": {
      "primary": "にぶい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
