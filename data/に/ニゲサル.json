    "definitions": [
      {
        "index": 1,
        "gloss": "to take flight",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「生を棄てて逃げ去るのは罪悪だと人は言う。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年は情ない顔をして逃げ去る。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝庭　久六、裏木戸から逃げ去る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松なんか居るもんか」　石松、逃げ去る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎遂に足に傷付き倒れ、伝八郎は生き残った浪人と逃げ去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、浪人者サンザンの態にて逃げ去る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "侍は急ぎ散らかされた文を箱に入れて一目散に逃げ去る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏秋の頃山中叢林にこれを懐中すれば蝮蛇逃げ去るという、云々」と、書いてあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫と女は、だまって居れば名を呼ぶし、近寄って行けば逃げ去る、とか。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だまつて居れば名を呼ぶし、近寄つて行けば逃げ去るのだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまつて居れば名を呼ぶし、近寄つて行けば逃げ去るのだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だまって居れば名を呼ぶし、近寄って行けば逃げ去るのだ」これはメリメのつつましい述懐ではなかったか。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまって居れば名を呼ぶし、近寄って行けば逃げ去るのだ。",
              "citation": {
                "source": "猿面冠者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『本草』に虎が狗を食えば酔う狗は虎の酒だ、また虎は羊の角を焼いた煙を忌みその臭を悪んで逃げ去る、また人や諸獣に勝つが蝟に制せらるとある。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫属の輩は羞恥という念に富んでいるもので、虎や豹が獣を搏ち損う時は大いに恥じた風で周章て首を低れて這い廻り逃げ去るは実際を見た者のしばしば述べたところだ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分が波止場から逃げ去るだけではなく、そのボートもそこに残しておきたくなかったろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声が哀れにさびしく、この世の人とは思われないので、気の弱い者は耳をふさいで怱々に逃げ去るのである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽衣を奪われた一人だけは逃げ去ることが出来なかったので、男は連れ帰って自分の妻にした。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僥倖にも卵膜を膨脹させた液體が自分から逃げ去る途を求めて其の包圍を破つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "八つ股の袖ガラミ捕物道具を、そのトゲだらけのものをわが肉体にうちこめ私は肉を裂いてもまんまと逃げ去るだらう。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "『和漢三才図会』に蝮甚だ勇悍なり、農夫これを見付けて殺そうにも刀杖の持ち合せない時、これに向って汝は卑怯者だ逃げ去る事はならぬぞといい置き、家に還って鋤鍬を持ち行かば蝮ちゃんと元のままに待って居る。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは蜥蜴の尾にも能く見るところで切った尾が跳り行くのに敵が見とれ居る間に蜥蜴は逃げ去るべき仕組みだ。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に土人闇夜外出するに必ず錫杖を突き蛇その音を聴いて逃げ去ると。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしワリスの『巫来群島記』（一八八三年板、一三三頁）に、スマトラに多い体長く痩せ、尾甚だ長いセムノビテクス属の猴二種は、随分大胆で土人を糸瓜とも念わず、しかるに予が近づき瞰めると一、二分間予を凝視した後逃げ去るのが面白い。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくすれば蛇は奇妙に逃げ去るとなりと（『人類学雑誌』第三二巻十号三一三頁）。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "因って次の呪言を唱えるとハブ必ず逃げ去る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はかなわじと見て逃げ去る。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（形勢非なりと見て、第二の男は袋を投げ捨て、窓より表へ飛び出して、下のかたへ逃げ去る。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて竹薮よりおいよは口のまわりに血を染めて出で来り、月明りに善助を見てじっと睨めば、善助はわっと驚き、一目散に下のかたへ逃げ去る。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そんなことで爆弾からにげさることはできなかった。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
