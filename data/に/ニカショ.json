        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "かように、五十音図に、発音ばかりでなく仮名も全く同じ「い」「う」「え」の三つがそれぞれ二箇所に分れて出ている。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちア行の「イ」とヤ行の「イ」と、ア行の「エ」とヤ行の「エ」と、ア行の「ウ」とワ行の「ウ」と、この三つは仮名の形は同じでありながら二箇所に分れて出ている。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二箇所の津呂いずれも国の突端に近い。",
              "citation": {
                "source": "土佐の地名",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペエテルの観察した所では、このクリストフと云ふ男はひよろ長い枯木のやうなもので、それが頸と足首との二箇所で丈夫な杙に縛り附けてあるのである。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "緑のゴブラン織のやうな蔦の茂みを背景にして背と腰で二箇所に曲つてゐる長身をやをら伸ばし、箒を支へに背景を見返へる老女の姿は、夏の朝靄の中に象牙彫りのやうに潤んで白く冴えた。",
              "citation": {
                "source": "蔦の門",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "編輯所は便宜上東京芝區濱松町一の十五土岐方及び發行所内の二箇所に置き投稿、書籍雜誌の寄贈を受く。",
              "citation": {
                "source": "無題",
                "author": "月刊文藝雜誌　樹木と果實　初號三月一日發行",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは新宿、品川二箇所の引手茶屋に借財を生じたためである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "使徒及師父　共産主義の文は使徒行傳に二箇所あつて人の皆知る所である。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "友の差し出された手を灯火のあかりで見てみると、指の関節二箇所が裂けて出血していた。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "學校を出て、一箇所二箇所と新聞社にも出て見たが、何處でも半年とはよう勤めなかつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "水出しは煙管の羅宇のような竹を管として、それを屈折させるために、二箇所又は三箇所に四角の木を取り付けてある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "少年少女の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜脱臼したのなら、直ぐに整復が出来る見込です」「遣って御覧」　花房は佐藤にガアゼを持って来させて、両手の拇指を厚く巻いて、それを口に挿し入れて、下顎を左右二箇所で押えたと思うと、後部を下へぐっと押し下げた。",
              "citation": {
                "source": "カズイスチカ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二箇所を断つて一箇所に往くといふやうな日もある。",
              "citation": {
                "source": "追儺",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "謙介は成長してから父に似た異相の男になったが、後日安東益斎と名のって、東金、千葉の二箇所で医業をして、かたわら漢学を教えているうちに、持ち前の肝積のために、千葉で自殺した。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "室には二箇所に、ストーブを据つけ、煙筒も燃えてしまふほど石炭をしつきりなしに投り込んだ。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりでなく、沼津の留守宅から※送して來る郵便や新聞等も途中一二箇所の郵便局の手を經るよりもこの船に頼んで持つて來て貰ふ方がずつと速かつたのです。",
              "citation": {
                "source": "樹木とその葉",
                "author": "海邊八月",
                "note": "青空文庫"
              }
            },
            {
              "text": "――何れも皆踊の輪に加つたので――二箇所の篝火は赤々と燃えに燃える。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カサのない電球が天井から二箇所にぶら下って室内を照している。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「売れきれです」「それは三階の後から二番目の席しかありません」そんなことでやっと二箇所の切符が買える段になって、窓口の女が云うんだ。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食堂の入口二箇所に小机を前においた女がいる。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝには八十八箇所の霊場のある処で、一箇所参れば一人喰ひ殺した罪が亡びる、二箇所参れば二人喰ひ殺した罪が亡びるやうにと、南無大師遍照金剛と吠えながら駈け廻つた。",
              "citation": {
                "source": "犬",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしの検した所を以てすれば、黄葉夕陽村舎詩に蘭軒に言及した処が凡そ十箇所あつて、其中澹父と書したものが四箇所、憺父と書したものが一箇所、蘭軒と書したものが二箇所、都梁と書したものが二箇所、辞安と書したものが一箇所ある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖書には、年次若くは干支と年齢とを併せ載せた処が僅に二箇所あるのみである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼年生室二箇所各二畳。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "別構正宗院部屋二箇所四畳五畳。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書には二箇所に「森氏」の篆印がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時の水戸家は上屋敷が小石川門外、中屋敷が本郷追分、目白の二箇所、下屋敷が永代新田、小梅村の二箇所で、此等は火事に逢つてゐないやうである。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときおりうは、仲次郎に金子五十両を呉れ、なにかしょうばいに取り付くように、と云ったそうである。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
