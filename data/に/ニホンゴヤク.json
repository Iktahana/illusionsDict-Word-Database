          "literary": [
            {
              "text": "日本語訳が出ていないというだけではありません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃ日本語訳の方で、二村定一ばりでやろうかな、アア」なんて、達者なところを見せた。",
              "citation": {
                "source": "人造物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この言語の日本語訳までが必要になる始末である。",
              "citation": {
                "source": "「草野心平詩集」解説",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十七日　日　晴　アンドレーフの Anathema、昔よんだ日本語訳を出して英訳と比較して見たら、なって居ないこと夥しい。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語訳というテクストが自由になったわけではありません。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大著の日本語訳が未だ一種も出て居ないことは、日本の文化の為めにどれだけ損失であるかわからない。",
              "citation": {
                "source": "読書と著書",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語訳は例えば 壺齋散人さんの「ユーラリューム」があります（http://poetry.hix05.com/Poe/poe19.ulalume.html）。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日にクルムスの解剖学書の日本語訳が始まった。",
              "citation": {
                "source": "近代医学の興隆",
                "author": "イェール大学で1913年に行った一連の講義",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵書、兵学に関するものとては手にだも触れないで、またその次に漁り出したのが、形は洋装になっているが、標題は漢字で、「約翰福音書」――「あ、それは切支丹の書物でございます」　一学がいうまでもない、これは千八百三十九年（天保十年）新嘉坡で出版された日本語訳の最初の聖書。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時はまだ日本語訳のなかった「カラマゾフ兄弟」などはひどく気に入ったようだった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語訳は無いようだが原文はグーテンバーグ・プロジェクトで読むことができる。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "二〇一五年八月　訳者より参考文献一覧１．底本と日本語訳・Hemingway, Ernest (1952) THE OLD MAN AND THE SEA, London: Jonathan Cape.・福田恒存訳（1966）『老人と海』（新潮文庫、2003年改版）。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語訳では『なつかしのデンヴァー』となっている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本語訳のあるものはその題名を、ないものは直訳的な題名を、書いておこう。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この翻訳にあたっては、H.Tsubota さんの「【日本語訳】ジョージ・オーウェル評論集」（http://blog.livedoor.jp/blackcode/archives/Orwell-essays.html）を参考にいたしました。",
              "citation": {
                "source": "ファシズムとは何か",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
