        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "滑稽なのは、いつだつたか「人形の家」を見たことがある。",
              "citation": {
                "source": "文藝作品の映畫化",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言は「人形の家」にて、松井須磨子のノラ好評。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ「人形の家」をまた読み返し、重大な発見をして、頗る興奮した。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろ人形の家をまた読み返し、重大な発見をして、頗る興奮した。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘッダ・ガブラーや人形の家の芝居を眺め「日本にもかかる思想がなくてはならぬと思ったくらいだ」。",
              "citation": {
                "source": "歴史の落穂",
                "author": "――鴎外・漱石・荷風の婦人観にふれて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱のなかにはいつもするように、屏風などを立て、人形の家族が寝かされてあった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "イプセンの「ノラ、人形の家」はもうふるいと一部にいわれるが、そのふるくない解決へ何歩私たちは歩み出し得ているだろうか。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イプセンの「人形の家」が書かれたのは日本の明治十一年であった。",
              "citation": {
                "source": "三つの「女大学」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イプセンの「ノラ」は、ノラが人形でなくなろうとして人形の家を出てから先にこそ、女性の社会的問題があった。",
              "citation": {
                "source": "離婚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近の芝居で「人形の家」をやっておりますが、あの主人公のノラは、いままで夫に玩具にされていたということが不満であり、どうかして、玩具の生活から逃れたいといって、家出をする。",
              "citation": {
                "source": "幸福について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "須磨子は舞台に情熱を傾けつつ、「『人形の家』を人間の家とするの」は、抱月在って初めて可能なことと思えたであろう。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『中央公論』のその号に、須磨子は「人形の家」を上演した感想と別に、「雌蝶」という短篇をのせている。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "水中花、ナフタリンの花、サスペンダー、ロシヤパン、万能大根刻み、玉子の泡立器、古本屋の赤い表紙のクロポトキン、青い表紙の人形の家。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "も一人いつぞや「人形の家」のノラを演じたときに、幼ない末子を勤めた女の子があった。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に「人形の家」のノラに異常な成功をした彼女は、驚異の眼をもって眺められた。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人形の家』と『人民の敵』とが載つてゐたといふ。",
              "citation": {
                "source": "イプセンの日本語譯",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も多くの人により譯されたのは『人形の家』であらう。",
              "citation": {
                "source": "イプセンの日本語譯",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人形の家』の初めの方に、ヘルメルがノーラの耳を引つ張つて冗談をいつてゐるところがある。",
              "citation": {
                "source": "イプセンの日本語譯",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に『人形の家』は完膚なきまでにやつつけられた。",
              "citation": {
                "source": "イプセンの日本語譯",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "原書とくらべたのではないが、これはうまいな、他とは段違ひの譯だと私が思つたのは、中村吉藏の『人形の家』であつた。",
              "citation": {
                "source": "イプセンの日本語譯",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへばイブセンは「人形の家」の中に何を書いたかを知らうと思へば、あなたがたの夫婦生活を、――或はあなたがたの両親の夫婦生活を考へて御覧なさい。",
              "citation": {
                "source": "文芸鑑賞講座",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二『人形の家』と言へば、誰でもすぐ婦人問題ということを想ひ出す。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "イブセンの社會劇は多く問題劇で、『人形の家』はすなはち婦人問題を材料にした劇であるといふ。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人形の家』には婦人問題が材料として用ひられてゐる。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヱドマンド・ゴッス氏がその『イブセン傳』（Ibsen : Edmund Gosse）の中で、『人形の家』はイブセンが始めての無條件的成功の作である。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "アーサー・シモンズ（Arthur Symons）君が「人形の家はイブセンの劇中傀儡をあやつる針金の用ひられなくなつた第一の作である。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "『人形の家』が非凡の演劇であつたことをあんなに突然認められたのは珍らしいことである。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そもそもそれがあればこそ、一篇の『人形の家』もあれほどの刺戟力を有し得たのである。",
              "citation": {
                "source": "『人形の家』解説",
                "author": "島村抱月",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
