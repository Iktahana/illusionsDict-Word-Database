    "definitions": [
      {
        "index": 1,
        "gloss": "cooking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "母親は老人の家の煮炊き洗濯の面倒を見てやり、彼はちょうど高等小学も卒業したので老人の元に法帖造りの職人として仕込まれることになった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "食べものも菓子以外は自分で煮炊きをしたものでなければ口にしません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮炊きするのに水の代りに葡萄酒を使うのよ、それで贅沢じゃないことよ。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその心は一着手の可否の考慮に向かって煮炊きの作用を少しもしてはいない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊尹（中国、殷の宰相）が煮炊きの小技を能くしたなどと云う話『呂氏春秋』が伝わるのも、信ずるに足りない伝説だが、自然とそうである様なことである。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一に朝晩の煮炊きにも困ります。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮炊き一切はこれでするのだ。",
              "citation": {
                "source": "東旭川村にて",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "副食物も悉く内で煮炊きをしなくてはならぬといふ事はない。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし病人の好む場合には特に内で煮炊きする必要が起る事もある。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何ぞ、煮炊きのもンは持つとらんのかや？",
              "citation": {
                "source": "暗い花",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三个日の間は、村人以外の者と、一つ火で煮炊きしたものを食はない。",
              "citation": {
                "source": "三郷巷談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、鳥や獣と同様、太陽といっしょに起きて、太陽といっしょに眠り、天然の水を飲み、煮炊きしない生の物を食うのさ。",
              "citation": {
                "source": "自由人",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "敗戦後の物資も人手も不自由な時であるから、入院患者は自分の食物を自分で煮炊きしなければならない。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ二つで煮炊きができると思ったのだろう。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮炊きさせても、かれこれ役に立つ者もないではないが、ただ憾むらくは人間の出来ている者がない。",
              "citation": {
                "source": "世界の「料理王逝く」ということから",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "露天風呂には天水がたまって、蛙が棲んでおり、私は煮炊きの水を谷川まで往復して運ばなければならなかった。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちもとは海水を使って煮炊きしたことがわかるのであります。",
              "citation": {
                "source": "言語と文化史",
                "author": "――アイヌ文化の探究にあたりて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイヌの家の中にはいりますと、室の中央に焚火して物を煮炊きする大きな炉が切ってあります。",
              "citation": {
                "source": "言語と文化史",
                "author": "――アイヌ文化の探究にあたりて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事な廊下で、男の手だけで煮炊きをするやら、洗濯をして松の木にほすやら……当家の主人は、こっち側とばかり、梃子でも動かぬ気組み。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "副食物には砂糖、胡麻汁、ジャム等を用い、見事それで凌いで行けたし、煮炊きの手数は要らぬし、突然の来客の時などことに便利に感じられた。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大名は滅多に他所で煮炊きした物を食べません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "玉の輿の呪い",
                "note": "青空文庫"
              }
            },
            {
              "text": "お芳は最初のうち、自分で煮炊きまでやっていたが、鶏舎の増築につれて次第に手がまわらなくなり、とうとう、お金ちゃんという近所の小娘を雇い入れて、台所のことを手伝わせることにしたのだった。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月中旬の風の強い日で、五カ所を回診したあとだから、もう日は昏れかかってい、路地の中は煮炊きの煙でいっぱいだった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬でも粉炭の量り買いだし、煮炊きの薪に困ることなどしょっちゅうだった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、煮炊きにも湯茶にも、しぜん、氷に含まれた草木の葉や実、蘚苔、地衣の類いが煎じ出されて、いやでもそれを服用するわけ。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮炊きも、もう楽だろう。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おけいが覚えてからでも、煮炊きや洗濯などはたいてい父親の七造がやった。",
              "citation": {
                "source": "追いついた夢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またこちらから問いただせることでもなかったが、不平らしい顔もせず煮炊き洗濯をする父のようすや、そういう良人に寝床の中から喰べ物の註文をしたりする母の態度を見ると、質屋の養女とその店の者という関係を証明するようで、おけいはしばしば哀しいような切ないような気持を感じたものであった。",
              "citation": {
                "source": "追いついた夢",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "修業者たちは掃除をし水を汲み、煮炊きをしてくれる。",
              "citation": {
                "source": "似而非物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長屋のそこ此処で煮炊きをする匂いや、泥溝や、ごみ溜の刺戟的な匂いが漂っていて、平五は空腹を感じると同時に、胸がむかむかした。",
              "citation": {
                "source": "末っ子",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
