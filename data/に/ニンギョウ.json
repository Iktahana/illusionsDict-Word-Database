        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで女の子が、人形を玩具にするようである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのことはない、あやつり人形の所作でも見ているような心地がした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牡丹燈籠とかの活人形はその脇にあり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏見人形に思い出す事多く、祭り日の幟立並ぶ景色に松蕈添えて画きし不折の筆など胸に浮びぬ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の前に坐って傍の障子を見ると、姪がいつの間にか落書したのであろう、筆太に塗りつけた覚束ない人形の絵が、おどけた顔の横から両手を拡げている。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな太鼓や鐘があぜ道にすえられて赤裸の人形が力に任せてそれをたたく。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "起き上つてあたりを見廻してゐると、すつと襖があいて、身長二尺くらゐのお人形さんが出て來て、「あら、おめざめ？",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とそのお人形さんみたいな可愛い女の子が、お爺さんの前にお行儀よく坐り、まんまるい眼をぱちくりさせて答へる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鈴さんよりも、さらに上品な美しいお人形さんで、少し顏色が青かつた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "藪の中に、小さいお家があつて、そこにお人形みたいな可愛い娘さんがゐて、うつふ、そんな子供だましのやうな事を言つて、ごまかさうたつて駄目ですよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その不思議な宿の大きい葛籠でも脊負つて來て下さつたら、それを證據に、私だつて本當にしないものでもないが、そんな稻の穗などを持つて來て、そのお人形さんの簪だなんて、よくもまあそのやうな、ばからしい出鱈目が言へたもんだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みやげ、印伝、水晶だの、百草だのを売ってる町家に交って、朴にして勁なる富士道者の木彫人形を並べてあるのが目についた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "山を石膏細工の人形とすれば、雲は衣裳で、あのようにまで、モデルの肢節にぴったり合って、屈伸するものとは思っていなかった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日のやうな日に見ると其の醜さが更に強められる、此んなものや菊人形などゝいふものに比べると例へば屠牛場の内部の光景の方がまだいくらか美しい位だと思ふ。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の中に建てた妙な屋臺作りに活人形が並べてあつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の人形の色彩から何からが何とも云へない陰慘なものである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "風のない日は縁側の日向へ出て来て、紙の折り鶴をいくつとなくこしらえてみたり、秘蔵の人形の着物を縫うてやったり、曇った寒い日は床の中で「黒髪」をひくくらいになった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人形が人間らしく動く飾物を見ようとするのだ。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飾窓の二面は普通の新衣裳の飾人形だが、残った一つの入口に向って右の飾窓のがみんなの目あての「エッフェル塔見物」の機械人形だ。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして今見た人形のように手を上げ下げした。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蝶が天地大に姿をフォーカスし去ると、そこに二階の窓々で飾人形を掃除している並木越しの商店街を見出した。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は、好きな道を役立てて歌舞伎の小道具方の相談相手になり、デパートの飾人形の衣裳を考証してやったり、それ等から得る多少の報酬で学費を補っていた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯れてまでどこ迄もデリカを失わない木の葉のなかへ、スマートな男女｜散策の人形を置いたりしている。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "掛布団の端で撥ねられた寝床人形が床に落ちて俯向きになっていた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことを考えているうちに人形町辺の停留場へ来るとストップの自働信号でバスはしばらく停車した。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカレビューやウィンナ舞踊を見た眼で見た少女歌劇は実に綺麗で可愛らしいものではあったが、如何にもか弱く、かぼそく、桜の花と云うよりはむしろガラス製の人形でも見るような気のするものであった。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと反対に、例えばザッキンの妙な人形の絵など、随分形式的にはグロテスクに出来ているが、感じの内容には、どこかある明るさと愉快さがある。",
              "citation": {
                "source": "二科会展覧会雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば人形が電灯を持って立っているのならば灯が点ると同時に電灯を高く振りあげる。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで人間かと思われるほど、くりくりした目のにんぎょうが、葉と葉のあいだにぶらさがっていました。",
              "citation": {
                "source": "もみの木",
                "author": "GRANTRAEET",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
