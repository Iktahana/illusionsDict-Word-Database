    "definitions": [
      {
        "index": 1,
        "gloss": "fixed or appointed date",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "研究題目は上長官の命令で決まっており、その上に始めから日限つきでその日までにはどうでも目鼻をつけなければならないこともある。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」Ｔ「仲蔵は、今日限り　舞台へ上げぬぞ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんたは、わしが今日限り抵当ながれにならなくてはならないわしの土地についてはよく承知なんだ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日限り、あいつにゃひまをやって呉れい！",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し見所があると思ったのに牛につっかかれたくらいで職務も忘れて遁げるなんてもう今日限り免官だ。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬四郎尚も大声で、Ｔ「離縁じゃ、今日限り離縁する」　下ではウロウロして居ります。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小暇を得て、修善寺に遊んだ、一――新聞記者は、暮春の雨に、三日ばかり降込められた、宿の出入りも番傘で、ただ垂籠めがちだった本意なさに、日限の帰路を、折から快晴した浦づたい。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし本官がそのほうの贔屓であったなら、今日限り愛想を尽かして、以来は道で遭おうとも唾もしかけんな。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "就ては其後の詮議仕りたく存じ候え共、何分にも帰参の日限切迫いたし居り候まま、其意を得ず候こと残念至極に存じ候。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、挙句の果に大そう御機嫌を害ねて、到頭今日限り妾はお払い箱になってしまったのです。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども今日限りその因縁はなくなります。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "剣道の先生も、一日限りでたくさん也。",
              "citation": {
                "source": "みみずく通信",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初號分締切二月十日限り。",
              "citation": {
                "source": "無題",
                "author": "月刊文藝雜誌　樹木と果實　初號三月一日發行",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんは憤って、膳の上の茶碗を投げつけて、「汝のような奴は、もう許さん、今日限り離縁する」　老婆はお爺さんのことを思いだし思いだししていた。",
              "citation": {
                "source": "地獄の使",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の幼馴染みに、楓という美女がおったが、同じ楓でもピンから数えて、キリまであろうよ」　そう断ったが、三好は言いだしたらあとへ引かぬ男で、しまいには、「出てくれねば、今日限り口をきかぬ！",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで元文四年三月二日に、「京都において大嘗会御執行相成り候てより日限も相立たざる儀につき、太郎兵衛事、死罪御赦免仰せいだされ、大阪北、南組、天満の三｜口御構の上追放」ということになった。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその日限り、元親の前へ出仕することを止められた。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僅かの日限に二百枚以上の原稿を書いた爲め、耳を痛めて、今でも左りの方の聽えが遠いのです。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうともして」とは、実際、何とか工面をしなければならないのだ、「必らず御心配はかけませんが、青木さんの方が成り立っていても、今月一杯はかかるんでしたから――そこいらの日限は、どうか、よろしく」と、念を押した。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに金はまだイクラカ残っているがカンジン・カナメの二週間の日限が切れそうになって来た。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の血を吸いよるけに……」　　　　　　　　　　◇　そんな目に毎日毎日、会わせられるので筆者は、「もう今日限り稽古には来ぬ」　と思い込んで走って家に帰っても、又あくる日になると祖父母に叱られ叱られ稽古に行った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "早速ですが私の精神状態も、御蔭様でヤット回復致しましたから、今日限り退院さして頂こうと思いまして、実は御相談に参りました次第ですが……どうも永々｜御厄介に相成りまして、何とも御礼の申上げようがありません。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕は今日限り廃めさせていただきます」わりに丁寧な声が出たので、われながら気持良かった。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "門衛のほうの名簿ですと、松島さんは昨日限り退職されたことになっておりますがね」　門衛は落ち着いて帳簿を繰るのだった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "親類も糞もあるもんか、懇意も糸瓜もねいや、えい加減に勝手をいえ、今日限りだ、もうこんな家なんぞへ来るもんか」　薊は手荒く抑える人を押し退けて降りかける。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と一喝された者や、あまりに愚かな質問を発して「君は今日限り退学した方が好いでせう。",
              "citation": {
                "source": "文学とは何ぞや",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈祷はこの日限りでとどこおりなく終った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "蝶合戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体江戸にいるか居ないか確かに判りもしないものを、日限を切って探し出せというのが無理であるが、それも屋敷の命令であるから仕方がない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "次いで元文四年三月二日に、「京都に於いて大嘗會御執行相成候てより日限も不相立儀に付、太郎兵衞事、死罪御赦免被仰出、大阪北、南組、天滿の三口｜御構の上追放」と云ふことになつた。",
              "citation": {
                "source": "最後の一句",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
