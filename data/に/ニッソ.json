    "definitions": [
      {
        "index": 1,
        "gloss": "Japan and the Soviet Union",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
