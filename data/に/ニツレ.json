    "definitions": [
      {
        "index": 1,
        "gloss": "as (X, then Y)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
