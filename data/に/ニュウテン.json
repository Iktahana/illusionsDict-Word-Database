    "definitions": [
      {
        "index": 1,
        "gloss": "entering a store",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、その完成祝いには恋人の女神を連れて来て初入店の式をさせるのです。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玉屋の昔の建物はおとなしい明治味の洋館で、また油絵々具の最初の輸入店の一つとしてわれ／＼が忘れられない店である。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの長束実は、中村屋が私のものになった最初に入店したもので、まだ小僧であったが、常から真面目で勤勉で研究心に富み、じつに感心な少年であった。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅野は宮城県涌谷町の呉服屋の二男であったが、親の反対を押し切って、救世軍に身を投じた青年で、その純情と努力と熱と、彼は入店の初めから、興味ある※話を中村屋に残している。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に、各工場の職長に日本一の技術者を招聘したいという私のかねての宿望を実現することになり、二月初旬には日本菓子部に荒井公平、洋菓子部に高相鉄蔵、食パン部に石崎元次郎の三君の入店を見ることが出来た。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆえせっかく入店しても結局中途で退店するものが多く、私どももまことに遺憾に思うことである。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて入店後の給与および待遇については、諸君のすでに経験するところであるが、一通り順を追うて記して見ると、入店後徴兵検査までの約六年間を少年級として、少年寄宿舎に入れ、衣類医療等いっさいを主人持ちとして、小遣いは初め月に十四、五円（給与いっさいにて）、漸次増して三十円以上となる。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "主婦の言葉（相馬黒光）主婦の言葉　今年もまた春が来て、二十三人の少年がこの中村屋に入店しました。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "店葬のはじめ　留吉さんは鋳造の大家山本安曇氏の弟で、中年で入店し、販売部で働いていた。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも商売見習いは口実で、他に何か曰くがあるらしく、果たして入店早々私の予感の間違いないことを示す行動がありました。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから途中から入店した人で全然顔を見たことのないのも出て来て、毎月、月給の袋に名を書く時いつも済まない済まないと心の中にお詑びをしています。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現れた力と潜んでいる力　江戸ツ児は総じて早熟で、敏捷で物わかりが宜しいから、入店するやただちに何かしら役に立ちます。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "学科、体格の試験はもちろんだけれども正直試験といって、家庭の事情、本人の趣味とか愛読書、入店志望の理由等詳細に正直に書かせる。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして入店した少年諸君は全部寄宿舎に収容する。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "入店と同時におよそ人格的に人物養成の方針でやっている。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の店員達の内であるから、入店の時ずいぶん慎重な考査をしたつもりであっても、時に心掛けの悪い店員が居ないでもない。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは入店の際に厳選が利いているから、その必要を認めないばかりでなく、家族的の朗さのためでもある。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから誕生祝いなどあって、昨日入店した者でも、誕生日なら今日は誰さんの誕生日というので、幾らか違った御馳走をする。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は入店に際しパンツと地下足袋を買った。",
              "citation": {
                "source": "安い頭",
                "author": "小山清",
                "note": "青空文庫"
              }
            }
          ]
        }
