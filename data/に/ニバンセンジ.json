        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どの新聞でも、「オリンピア」に於ける彼女をインタヴィユしていたが、もはやそれでは二番煎じだから、「オリンピア」がカンバンになってからの彼女の尾行記をものするのだ。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "魯菴の其頃の話題は、主として西鶴の作の評、芭蕉論、内外の文学論、とりわけロシャ小説の礼讃、二葉亭の噂、紅、露の比較、硯友社のわる口、文壇一般のアラさがし、時としては二葉亭との談論の二番煎じかと思ふやうな社会政策の断片。",
              "citation": {
                "source": "斎藤緑雨と内田不知菴",
                "author": "坪内逍遙",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロコンピューターの生産においては、セカンドソースの奨励という、いわば二番煎じを積極的に認める方針がとられている。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "所がそこへ又づぶ京伝の二番煎じと来ちや、呆れ返つて腹も立ちやせん。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそこへまたずぶ京伝の二番煎じと来ちゃ、呆れ返って腹も立ちやせん。",
              "citation": {
                "source": "戯作三昧",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちで話したから二番煎じのやうな気もするが、棄て難いものなので、こゝに収録する。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "その彼の味わうその醍醐味を、大衆は見て、また彼らは彼らの娯楽ともいえるところの悦楽にひたるのであって、悦楽としては、二番煎じであることはまぬがれない。",
              "citation": {
                "source": "脱出と回帰",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その詩は流麗雄弁で、よく長句を駆使してゐるうへに作意にも一ふしはあり、それに流行歌調の二番煎じだといふ点に解り易く人気の出る理由は十分にあつたが、決して上乗のものとは云ひ難からう。",
              "citation": {
                "source": "新詩社と石川啄木",
                "author": "――一つのおぼえ書き――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラグビー」は同趣向で少し二番煎じになる。",
              "citation": {
                "source": "楽聖物語",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
