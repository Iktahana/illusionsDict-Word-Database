[
  {
    "uuid": "7837635e-0af1-5191-a529-701ee33e6984",
    "entry": "入御",
    "reading": {
      "primary": "にゅうぎょ",
      "alternatives": [
        "じゅぎょ"
      ],
      "is_heteronym": false
    },
    "grammar": {
