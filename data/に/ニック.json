    "definitions": [
      {
        "index": 1,
        "gloss": "nick",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "幼稚園のピクニックで来た時に、嘗てすべつてころんだ所も、そのまゝであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――ダウンとは、先生が「ン」の字を「ウン」と発音したことによつて、「オミヤノダンダン」と読本にあるのを「ダウンダウン」と読んでから私がつけたニックネームだつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君も知つてるだらうが、Ｓ子はデカタンのやうでピューリタニックなところを持つた女だし、それにあんな処で遊廓町で歌ふやうな歌を歌つちやあ困るぢやないか。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このように、読者を欺すという悪意は少しもなくて、しかも結果において読者を欺すのが新聞のテクニックなのである。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃え尽した書物がフィルムの逆転によって焼灰からフェニックスのごとく甦って来る。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "詐欺師や香具師の品玉やテクニックには『永代蔵』に狼の黒焼や閻魔鳥や便覧坊があり、対馬行の煙草の話では不正な輸出商の奸策を喝破しているなど現代と比べてもなかなか面白い。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実験上のテクニックでも人の真似をするよりは何かしら一工夫するのが好きであった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで自分にはどうもロスの勝利というのが呑込めなかったが、テクニックを知らないからだろうと思っていた。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、アメリカにおけるプロレタリア自身、パニックの最中において米国産業組織の同伴者であった。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スマ子女史はワイシャツの縫目からミス・フランセのコバルトの細巻をとりだして火をつけると、蒸気のこもった部屋に水沫のように緑色の煙を吐き出して、――だが、人に聞くと君はちかごろ恋のテクニックに夢中なんですって？",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "未来の映画のテクニックはどう進歩するか。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも紅茶の滓が溜っているピクニック用の湯沸器。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方朝鮮語やウラルアルタイ、チャムモンクメール、オセアニック等の語系との関係についての論文は往々われわれの目にも入ったが、正面からマライとの関係を論じて、そうしてそれが一般学界ひいては世人の注意をひくほどに至ったもののあった事は寡聞にしてまだ知らなかったのである。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはあまりにも勝手な空想であるが、こうした実験も現在の進んだ音響学のテクニックをもってすれば決して不可能ではないであろう。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は拳闘については全くの素人で試合の規則もテクニックもいっさい知らないのであるが、自分が最初からこの映画でおもしろいと思ったのはこの二人の選手の著しくちがった個性と個性の対照であった。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピクニックよりもダンスよりも、婦人何々会で駆け回るよりもこのほうがはるかに身にしみてほんとうにおもしろいであろうということは、「物を作り出すことの喜び」を解する人には現代でもいくらか想像ができそうである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現象の本性に関する充分な知識なしに、ただ電気のテクニックの上皮だけをひとわたり承知しただけで、すっかりラディオ通になってしまったいわゆるファンが、電波伝播の現象を少しも不思議と思ってみる事もなしに、万事をのみこんだ顔をしているのがおかしいと言った理学者がある。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば極貧を現わすために水道の止まった流しに猫の眠っている画面を出すとか、放免された囚人の歓喜を現わすのに春の雪解けの川面を出すとか、よしやそれほどの技巧は用いないまでも、とにかく文学的の言葉をいわゆるフォトジェニックなフィルミッシな表現に翻訳しなければならない。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラトニックラヴね」　女って皆そう言うと思った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「プラトニックだけで済むかね」「ベーゼ……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一流の恋愛とはどんな恋愛ですか」「プラトニックに、お互いを向上させて行く恋愛だね。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "置手紙によれば、プラトニックラヴを双方しているそうですよ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "信じられますか」「あなたはどう思うんです」「わざわざプラトニックだと断ってますからね」「かえって、怪しい……？",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "九分九厘まで行って、ギリギリの一点を残して、あとは大いに享楽して、それでプラトニックだと称している手合いが多いんだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "トルストイやゲーテのように、中年期を過ぎてまでも、プラトニックな恋愛を憧憬したり、モノマニアの理想に妄執したりするような人間は、すくなくとも僕らの周囲にはあまりいない。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい徳に反対する主義――例せば悪魔主義や本能主義――のようなものであっても、本質はやはり、別のユニックな正義を信ずるところの、同じ倫理線の上に立っているので、この本質の点から言うならば、世に無道徳的なるいかなる主義もないわけである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし日本は、三千年来世界と孤立した特殊国で、文物と国風の一切がちがっており、全くユニックに発育した国であるのに、最近外国からの文化が渡来した為、何もかも無茶苦茶の混線となってしまったのである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）外国に於て見れば、バイロンは正義に殉じた熱血児で、ハイネはプラトニックに恋愛を歌いつつ、革命に熱した人生の戦士であった。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これによって立体派や未来派は、彼等独自のユニックな意匠によって、別の新しいクラシズムを創見した。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
