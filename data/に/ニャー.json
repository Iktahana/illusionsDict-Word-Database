        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そのとき、道ばたで、「にゃーお」と、猫のなき声がした。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「にゃーお」また猫は、道ばたで鳴いた。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこへにげこんだのだろうと思っていると、また「にゃーお」と猫はないた。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「にゃーおん」猫はまたないた。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「にゃーお」返事が、同じところからきこえた。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（目玉のようだが、いったいなんだろう）　とたんに、また「にゃーおん」とあまえるような声がきこえた。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾輩もいささか賛成の意を表するためににゃーにゃーと二声ばかり鳴いて見せる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度は仕方がないからにゃーにゃーと二返ばかり鳴いて起こそうとしたが、どう云うものかこの時ばかりは咽喉に物が痞えて思うような声が出ない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず腹の中でこれだけ主人を凹ましておいて、しかる後にゃーと注文通り鳴いてやった。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "博物館員は思わず恋する猫のにゃーごと泣く声にも似たパリの鳴き声を再生してみたい気を起こした。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
