          "literary": [
            {
              "text": "六月二十九日の昼休み、慶一、高志、ワラ、というＫＷＴＳトリオと、柾生、山崎の五人は、校舎の前庭の日本庭園にある、紫陽花に囲まれた東屋で、丸太のベンチに寝ころがったり、ベンチに足をのせ、背板に腰掛けたり、てんでんばらばらのかっこうで、ビートルズの話をしていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も読者が日本庭園で見られるような飛石の一列が真中にある、砂を敷いた広場へ坐らされた。",
              "citation": {
                "source": "術数",
                "author": "DIPLOMACY",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰路トリジュリー公園を散歩し、その中に日本庭園あるを一覧す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその前後、緑樹紅花、石頭に懸かり、宛然日本庭園の趣を有するはまた妙なり。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
