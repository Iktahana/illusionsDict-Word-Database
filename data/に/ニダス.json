    "definitions": [
      {
        "index": 1,
        "gloss": "to extract essence by boiling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
