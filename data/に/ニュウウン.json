        "examples": {
          "standard": [
            {
              "text": "乳癌の自己検診では、乳暈の色の変化も確認するポイントとなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "赤ちゃんが乳房に吸い付く際、乳暈全体を口に含むように指導される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "乳暈の大きさや色は個人によって大きく異なる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "小さな肩、胸のふくらんだまるみと、薄い樺色の乳暈、ゆたかな腹部の抉ったような窪みと、それに続く隆まりの上の僅かな幅狭い墨色、広くなった腰から重たげな太腿へ、そうしてすんなりと細くしなやかに伸びている脚。",
              "citation": {
                "source": "鵜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仄かな行燈の光りの中で、彼女の胸のなめらかな白さと、乳暈の鴇色をした豊かな張りきった乳房とが、どきっとするほど嬌めかしく色めいてみえた。",
              "citation": {
                "source": "夜の蝶",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
