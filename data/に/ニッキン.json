        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "或る日勤め先から帰って来た逸作がかの女に云った。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おなじ門葉の一人で、手弁で新聞社へ日勤する。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると、今日は一日勤め先でかなり運動のつく仕事をし頭脳の疲れる仕事をした。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥間巡査は講習を終へると隔日勤務になった。",
              "citation": {
                "source": "奥間巡査",
                "author": "池宮城積宝",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田は毎日勤めから帰つて来ると、唯物史観を、無産者政治教程を講義した。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "花で人が浮れても、お若は面白いこともなくて毎日勤行を怠らず後世安楽を祈っているので、近所ではお若の尼が殊勝なのを感心して、中にはその美しい顔に野心を抱き、あれを還俗させて島田に結せたなら何様であろう、なんかと碌でもない考えを起すものなどもござりました。",
              "citation": {
                "source": "根岸お行の松　因果塚の由来",
                "author": "三遊亭圓朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "郵便局は所謂三番勤務で、日勤の日は終日ですが、次の宿直の日は午後四時から出ればよろしいし、次の宿明の日は午前九時から退出してきました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日勤の日にも、月に二回は閣令休暇があり、十日に一回は特別休暇がありました。",
              "citation": {
                "source": "土地に還る",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "求家庭教師その他（１）　日勤家庭教師朝三時間、当方娘十六歳、ケンブリッジ大学生を求む。",
              "citation": {
                "source": "日記",
                "author": "一九二九年（昭和四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は毎日勤勉に学校へ出かけるだろう。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったい、助郷人足が宿場の勤めは一日であっても、山を越して行くには前の日に村方を出て、その晩に宿場に着き、翌日勤め、継ぎ場の遠いところへ継ぎ送って宿場へ帰ると、どうしてもその晩は村方へ帰りがたい。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が毎日勤めに出てゐた頃からさうだ。",
              "citation": {
                "source": "長閑なる反目（三場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかのように、小間物店を並べられちゃ叶わないが」「大丈夫、仲人のお役目が済むまでは、これでも大事な身体で」「その仲人の役目を、明後日勤めて貰おうと思うが、どうだえ」「御舎弟の初七日が済んだばかりですぜ」「それでいいじゃないか。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日勤めを休んで、翌る日から又勤めに出て見ましたが、自分は精一杯気を付ける積りでも、妙な失神状態に襲われて、時々飛んでもない失策を演じては、組頭に眼の玉の飛出るほど叱られたりするのでした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "夢幻の恋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと親父が日勤のつとめ故に、うちにはいないから、毎日毎日わがままばかり言うて強情ゆえ、みんながもてあつかったと、用人の利平治という爺が話した」　神尾は自分の事を書かれたように共鳴する点もある。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分でも遅れると、守衛口で遅刻を取られ、支払い日の日勤票には、ちゃんと半時間の割でも日給から差引かれてある。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこには些かの誇張もないのです」没頭社長が念を押した、「――貴方はやがて埴谷邸へ日勤するわけであるから、この点をくれぐれもお忘れにならぬよう、いいですか、どんなばあいにも決して令嬢の機嫌を損ぜぬように、さもないと……おわかりでしょうな」　その日の会食はそれで終った。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
