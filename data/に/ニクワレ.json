        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「旦那さん、蚤にくわれても、女ッ子は可哀相だと言ったが、ほんとかね。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ穴のお螻どもが、反対に鴨にくわれて、でんぐりかえしを打ったんですね。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そこのバラは、虫にくわれてらあ！",
              "citation": {
                "source": "雪の女王",
                "author": "――七つのお話からできている物語――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠こそ地蔵なら、何して猫にくわれべ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾里の登り阪を草鞋のあら緒にくわれて見知らぬ順礼の介抱に他生の縁を感じ馬子に叱られ駕籠舁に嘲られながらぶらりぶらりと急がぬ旅路に白雲を踏み草花を摘む。",
              "citation": {
                "source": "旅の旅の旅",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "進歩党や自由党の首領たちは、得票を婦人にくわれたと表現しているのである。",
              "citation": {
                "source": "春遠し",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "温和で正直で忍従的な人民の多数が、その温和で生産的な社会生活を継続し発展させてゆく可能を保つために、それらの人々がファシズムにくわれつくさずに生きてゆけるだけの自主的余地をこの社会に拡げる力として、日本のレフティストの存在意義は小さくないことがわかってきている。",
              "citation": {
                "source": "世紀の「分別」",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽りのない文化を宮本百合子-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）膿汁：入力者注　主に外字の説明や、傍点の位置の指定（例）しらみにくわれながらも。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのときの彼女たちは、断髪に日の丸はちまきをしめて、日本の誇る産業戦士であった――寮でしらみにくわれながらも。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦時中予算のこの部分はすべて軍事費にくわれていた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "か弱い小さな労働者、馬にくわれる一本の草のような」ひろ子の小ささに目をつけて言葉をかける労働者は「親しげな顔付をした。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――南京虫にくわれねえだけでもハアちっこい者にゃ楽だよ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "不図太鼓の音が南京虫にくわれて痒い耳についた。",
              "citation": {
                "source": "刻々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが幸いで、ようやく恐竜にくわれるだけは助かった。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鱶にくわれる方が、恐竜に食われるよりは、ましだというのかい」　伯爵も負けずにやりかえした。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまでは考えなかった」「人間をくうとは、まだはっきり断定できないだろう」「いや、あの小さい総督が今いった話によると、ラツールとかいうフランス人がくわれ、ポチという犬が恐竜にくわれたそうじゃないか」「目下行方不明だというんだろう。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯爵のされこうべ……」　伯爵は恐竜にくわれて、こんななさけない姿になってしまったのかと思った。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも小鳥にくわれるかしら。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "下におちるか、どんな鳥にくわれるか、それとも……。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨に打たれ、蚊にくわれ、私は毎晩、あなたのお力をひろめるために尽しました。",
              "citation": {
                "source": "こほろぎの死",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱりアドロ彗星にくわれてしまうんじゃないかなあ」「けっきょく、ちえくらべさ。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから武力をもって彼奴を追払うという手段は、すくなくとも表面からいったのでは、住民たちの同意を得ることはむずかしい」「だがおとなしくしていれば、君たちは彼等にくわれてしまうばかりだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、三人で出かけて〔以下空白〕二月二十二日　土　南京虫にくわれたあとがかゆかったのをかいたら、はれていたくなった。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "靴は泥沼にくわれる。",
              "citation": {
                "source": "日記",
                "author": "一九五〇年（昭和二十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いっそ森の中で、もうじゅうにくわれたほうが、よかったわ。",
              "citation": {
                "source": "ヘンゼルとグレーテル",
                "author": "HANSEL UND GRETEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのまま母は、妹は森のなかでおそろしいけものにくわれてしまい、にいさんのほうは子ジカになって、狩人たちに射殺されてしまったものとばかり思いこんでいました。",
              "citation": {
                "source": "にいさんと妹",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "銃身は錆だらけで、銃機はおちかかり、台尻は虫にくわれている。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、たとえ自分の芸は未熟ながら、考えずにいられようか、平常はたんすや、行李の中へしまいこまれて、お気にいらなければ、そのまま虫にくわれ、永久に捨てられるのである。",
              "citation": {
                "source": "心の芽",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫にくわれた老樹の幹は年々うつろになって行きながら枯れたかと思う頃、哀れにも芽を吹く事がある。",
              "citation": {
                "source": "砂糖",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな恋愛は犬にくわれろだ。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
