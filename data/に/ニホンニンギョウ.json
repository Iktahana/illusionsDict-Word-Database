        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、世界文化のなかにあっても特殊に優雅である日本文化の典型として茶の湯、生花、能楽、造園、日本人形や日本服があげられる。",
              "citation": {
                "source": "偽りのない文化を",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは日本人形劇であります。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで、生きた日本人形のようでしたよ。",
              "citation": {
                "source": "キャラコさん",
                "author": "鴎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本人形の名産地はソヴェトで云えばキエフのようなキヨトであること。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬川の日本人形が出されてさえ、夫人が、若い女性である伸子たちに、くつろいだ一言もかけないということは珍しいことだった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
