    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese puppet theatre in which recited narrative and dialog is accompanied by a shamisen (forerunner of bunraku)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芝居は歌舞伎劇や文楽の人形浄瑠璃なぞ好きです。",
              "citation": {
                "source": "身辺打明けの記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪では博覧会見物をすますと父は大好きな鴈治郎の芝居と、文楽の人形浄瑠璃を見せてくれた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弱法師」では、古浄瑠璃を越して後の人形浄瑠璃と同じく、俊徳であるから、此名に就いての問題は、かなり昔まで、遡つて行く訣である。",
              "citation": {
                "source": "玉手御前の恋",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　大阪文楽座の人形浄瑠璃は、私は一度しか見ないが、いかにもすぐれた芸術価値を持つたものであると思ふ。",
              "citation": {
                "source": "実物と模型",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、人形浄瑠璃の飛躍期に提携して、今に続いてゐる楽器三味線との関係を遠くすることである。",
              "citation": {
                "source": "文楽の光明",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三味線によりながら、従来どほりに「ことば」を発声してゐる限りは、新しい人形浄瑠璃は出て来ない。",
              "citation": {
                "source": "文楽の光明",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ人形浄瑠璃から採入れたもの、最初人形浄瑠璃の為の脚本であります。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆さん多分お聴きでありませうが、仮名手本忠臣蔵は人形浄瑠璃から採つた題目であります。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優が人形浄瑠璃の振りをするのであります。",
              "citation": {
                "source": "日本演劇の特質",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "オペラや能と違って人形浄瑠璃においては音楽は純粋に音楽家が、動作は純粋に人形使いが引き受ける。",
              "citation": {
                "source": "文楽座の人形芝居",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪の通人に聞いた話に、文楽の人形浄瑠璃では明治になってからも久しくランプを使っていたものだが、その時分の方が今より遙かに餘情に富んでいたと云う。",
              "citation": {
                "source": "陰翳礼讃",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その十一淡路の人に云わせると人形浄瑠璃はこの嶋が元祖であると云う。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京生れの人形芝居西川伊三郎と吉田国五郎　人形浄瑠璃は本場だけに大阪の文楽が一手占め、東京方は昔から振わなかった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京生粋の人形浄瑠璃で文楽の向うを張ろうという計画、三十年頃神田の新声館に旗揚げした人形芝居がそれであった。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時頃出て、文楽座へ行き、生れて初めて人形浄瑠璃を見る、中途で出て、南一食堂で食事、日本食飯一杯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
