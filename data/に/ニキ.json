[
  {
    "uuid": "3139f43c-59af-5dbf-a00b-70396bb71c8e",
    "entry": "二期",
    "reading": {
      "primary": "にき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
