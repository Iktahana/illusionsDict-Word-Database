        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「あんたトラックに一緒に乗つて行つて荷物を運び入れてゐて頂戴、そのうち私も行くから」と云ふ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガタガタ／＼トラックの荷物の中に挟まつて揺られながら、僕は久々で午前の西武電車の沿線といふものを眺めたのだ。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を、運転手と僕とで運び入れて、運転手と助手とが帰つて行くと、僕一人になつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても先生の荷物だけ先に運んであるといふのはどうしたことだらう……。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の女を私から奪略した男の所へ、女が行くといふ日、実は私もその日家を変へたのだが、自分の荷物だけ運送屋に渡してしまふと、女の荷物の片附けを手助けしてやり、おまけに車に載せがたいワレ物の女一人で持ちきれない分を、私の敵の男が借りて待つてゐる家まで届けてやつたりした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階に上ると、荷物が来てゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗合わせた農夫農婦などは銘々の大きな荷物に腰かけているからいいが、手ぶらの教授方以下いずれも立ったままでゆられながら、しきりに大気の物理を論じ合っていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの曲り角の処で荷物をほごしている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "早く行て船室へ場を取りませねばと立上がれば婢僕親戚｜上り框に集いて荷物を車夫に渡す。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷物を上げ座もかまえ、まだ出帆には間もあればと岩亀亭へつけさせ昼飯したゝむ。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず荷物を預けんとて二人のを一緒に衡らす。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠公へでも行くべしとて出立たんとせしがまてしばし余は名古屋にて一泊すれども岡崎氏は直行なれば手荷物はやはり別にすべしとて再び切符の切り換えを求む。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "道傍の氷店に入ってラムネ一瓶に夜来の渇望も満たしたればこゝに小荷物を預けて楠公祠まで行きたり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多門通りより元の道に出てまた前の氷屋に一杯の玉壺を呼んで荷物を受取り停車場に行く。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「御荷物はこれだけで。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲板へ上がってボーイに上等はあいているかと問うとあいているとの事、荷物と帽を投げ込んで浜を見ると、今端艇にのり移ったマントの一行五、六人、さきの蝶々髷の連中とサヨーナラといっているのが聞える。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは荷物を持つて歩くのは、きらひです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「おれは、荷物はいやだ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札口でなしに、小荷物口の方に向って、三四十人の人の群が、口々に喚き、罵り、殴り、髪の毛を引っ掴みながら、揺ぎ出した岩のようにノロノロと動いて行った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に、（見当のつかなかった小僧）が小荷物受渡台の上に彼自身でさえ驚くような敏捷さで、飛び上った。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と同時に彼の足は小荷物台から攫われて、尻や背中でゴツンゴツンと調子をとりながら、コンクリートの上へ引きずり下された。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る小驛で停り合はせた荷物列車の一臺には生きた豚が滿載されて居た。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、歸ることは歸るとしても兎も角も其處らを少し歩いてから歸つても遲くはないだらうとＳがいふので、厄介な荷物を一時バスの待合所へ預けておいてぶら／＼と坂道を上つて行つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "構外のＷＣへ行つて其處の低い柵越しに見ると、丁度其の向側に一臺の荷物車があつて人夫が二人其の上にあがつて材木などを積み込んで居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "表通りの店屋などでも荷物を纏めて立退用意をしている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、茶いろの少しぼろぼろの外套を着て、白い巾でつつんだ荷物を、二つに分けて肩に掛けた、赤髯のせなかのかがんだ人でした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は、ひげの中でかすかに微笑ひながら、荷物をゆっくり網棚にのせました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながら、立って荷物をとったと思ふと、もう見えなくなってゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて、芸術にもつと観念が必要だなぞと云ふ人も、せんないことを云つてゐるに過ぎない。",
              "citation": {
                "source": "山羊の言",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
