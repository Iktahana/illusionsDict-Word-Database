    "definitions": [
      {
        "index": 1,
        "gloss": "double bottom (ship, trunk, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
