        "examples": {
          "standard": [
            {
              "text": "人類は直立二足動物として、進化の道を歩んできた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "恐竜の中にも、二足動物として獲物を追いかける種がいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この動物、二足動物だけど、飛び跳ねるように移動するんだね」と子供が観察した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「いや二足動物、だちょうだ」　とドノバンがいった。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも二足動物の汚ならしさをぶちまけろ。",
              "citation": {
                "source": "グーセフ",
                "author": "ГУСЕВ",
                "note": "青空文庫"
              }
            },
            {
              "text": "別のばあい、彼はプラトンの「人間」の定義――羽毛のない二足動物という――と、ある男が羽をむしった雄鶏を示してプラトンの「人間」だといったという話を聞いて、彼は膝がちがった方向にまがっているのが重要な相違だと思うといった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
