        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうかした場合に麦畑の中で汗ばんだ手を握り合う事が出来る位の事であった。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "確と握り合うそのことが生活の看板でもあるように、また、継ぎ合わして一人前のいのちとなるその大事な結び目のように。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日、久し振りに板垣と会うて来たが昔の通りに立派な男で、手を握り合うて喜んでくれた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は牛がどうとかいふことを符貼交りに云うて平内さんが相手の袂へ手を入れて二人で握り合うたと思つたら平内さんは其癖の大聲を出してそりやあんまり安く買つたなあといひながら口を鉗んで向鉢卷した頭を横に曲げた。",
              "citation": {
                "source": "佐渡が島",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな堅い約束を交していても、しっかり手と手を握り合うまでは安心が出来なかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヤア」「ヤア」といいながら、互いに堅く手を握り合う。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人の女は云い合わせた様にかたまって家のわきにピッタリと体をもたせかけてお互に手を握り合う。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで、この人たちが、影の聖餐祭に集まって、手と手を握り合うことを許されています。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "聖餐祭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうとても二人きりでは手を握り合うことも出来まいと思ったのに、思いがけない機会を見出したことがうれしくもあり、かえって悲しくも思われた。",
              "citation": {
                "source": "わがまま",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」接吻を知らない人にはただ溢れる熱情をしっかり双手を握り合うことによってのみ表わし得た。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "中国は中国と、生活の上で一番関りの深い国と手を握り合うことでしか独り立ちは出来ませんよ。",
              "citation": {
                "source": "女の一生",
                "author": "五幕七場",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前らもめいめいの手をシッカリ握り合うのだ。",
              "citation": {
                "source": "山の神殺人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "強制的ね」「二人を誘って銀座へクリスマス市を見にお出掛けになるとか、元旦を利用して二人をお招きになるとか、頭の働く人なら、策が幾らもあるんですから」「まあ／＼」「要するに、二人が手を握り合う機会を提供して戴きます」「俊彦さん、それは御依頼？",
              "citation": {
                "source": "求婚三銃士",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
