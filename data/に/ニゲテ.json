        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たまらなくなって便所へ逃げて行った。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいいち」と私は思ふのだつた、「あの女は、俺を嫌つてもゐないのだし、それにむかふの男がそんなに必要でもなかつたのだ……あれは遊戯の好きな性の女だ……いつそ俺をシンから憎むで逃げてくれたのだつたら、まだよかつただらう……」　実際、女は慥かにさういふ性の女だ。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "序でに言ふが、物質文明にいちばん卑さを刺戟された奴が、すつかり物質の中に逃げて行つて、その中でばかり生きてゐるために卑しいと一寸見做しがたくなつてゐる奴が珍しくない。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手は逃げて向うの電柱の頂へ止まる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺さんの留守をねらつて、あの婆さんを、えい、とばかりにやつつけて逃げて來た。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "べつに怪我も無い樣子だが、よくあの火の中を無事で逃げて來られたね。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのたいへんな火事場に、私ひとりを置いてどんどん逃げて行つてしまふんだもの。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まくら辺に子を坐らせて、まじまじとその顔を見れば、逃げてゆきしかな。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論僕とは大の仲好しで、座敷を掃くと云っては僕の所をのぞく、障子をはたくと云っては僕の座敷へ這入ってくる、私も本が読みたいの手習がしたいのと云う、たまにはハタキの柄で僕の背中を突いたり、僕の耳を摘まんだりして逃げてゆく。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "時には僕が余り俄に改まったのを可笑しがって笑えば、民子も遂には袖で笑いを隠して逃げてしまうという風で、とにかく一重の垣が二人の間に結ばれた様な気合になった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると昼間せっかく太陽から貰った温熱の大部分は人の知らぬ間に音もなく地面から抜け出して虚空へ逃げて行く。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち風が多く沖の方へ吹く年は海岸の潮流も陸を遠く距れ、魚類の卵は逃げてしまうのでその後は不漁がつづく。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "訪問者のないのは此方から逃げてゐるからで、自分で孤獨を求めてゐるやうなものである。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして急に背中を向けると、そのまま一散に逃げてしまつた。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いッそエノケンの孫悟空と逃げて満州辺へロケに来てやろうかとも考えたり、とりとめが無い。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近　多少負傷して居る次郎長と、　石松、逃げて来る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近の通り　三次走って来て三四郎を見失ってウロウロして居ると、一方、道から五六人ばたばたと逃げて来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝附近――元の場所　逃げて来た仲蔵は、其処に待って居た駕籠に乗る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五郎蔵が、Ｔ「娘さん　俺の所為じゃ無えぜ」　「馬鹿な事しちゃ困る」と云って、Ｔ「恨むんなら　先生を恨みな　此村大吉をな」　と言い残して仲蔵の方へ行かんとした時、　児分連、典六に追われて逃げて来た。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと見るや、逃げて来た文六、突然、立ち止ってクルッと振り返る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近　逃げて来た団九郎、武蔵の姿を見て、　やれ有難や、とその背後に隠れる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝元の川端――夜　文六逃げて来た。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急速にＦ・Ｏ）Ｓ＝同じ神社の表　侍五名が物凄うやられた形で、フラフラで逃げて行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "投げ出されてフラフラの二人の侍、這う様にして逃げて行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しどうしたことだらう、私の心を充してゐた幸福な感情は段々逃げて行つた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新京極から逃げて来てからあまり時間を経たとも思わない。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "けふでもあしたでも、少し収入があるやうになりさへすれば、あなたと一しよにどこか遠い所へ逃げて行きませうね。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのあなたがわたくしを連れて逃げて下さると仰やるのは、いつ頃でせうか」と、娘はたゆたひながら尋ねた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕と一しよに逃げて下さい。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前はその腕を闇の方へ向けて私にそれを振つて見せながら、私がお前から切り離して自分と一しよに持つて來たものを私から更に切り離して、逃げて行つてしまはせた……お前のその別離の手振りは、永い別離の印なのではなかつただらうか？",
              "citation": {
                "source": "窓",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
