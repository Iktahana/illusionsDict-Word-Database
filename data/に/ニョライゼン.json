        "examples": {
          "standard": [
            {
              "text": "彼は如来禅の修行を通して、悟りを開こうと努めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この寺は、如来禅の伝統を今に伝える数少ない場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "如来禅の教えは、心の平静を重んじる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "形骸に拘々せず、小智に区々せず、清濁のまに／＼呑み尽し、始めて如来禅を覚了すれば万行体中に円かなり。",
              "citation": {
                "source": "唯心的、凡神的傾向に就て（承前）",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            }
          ]
