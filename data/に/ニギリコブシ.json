        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが小さな、可愛らしい、夏夜の妖精の握り拳とでも云った恰好をしている。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、可愛い握り拳を出した。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年が重い鉄門を開けかねていると、博士の荒々しい怒鳴り声が聞こえ、怒って握り拳を振り回しているのも見えた。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに奥さまは目をめらめらさせて通りを下ってきて、猫背の男が街灯のそばに立って、怒り狂うかのように握り拳を宙でぶんぶんしているのが見えました。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ホームズは両の握り拳で空を引っ掻く。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "これぢあ、どうも……」などゝ呟きながら私は、物欲しさうな眼つきをして、胸の、くすぶつた銀色をした自由女神の握り拳の飾針をつまぐつてゐた。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "蜀山人の狂歌に「さ蕨が握り拳をふり上げて山の横つら春風ぞふく」、支那にも蕨の異名を『広東新語』に拳菜、『訓蒙字会』に拳頭菜など挙げいるから、これは一番野猪と蕨を題して句でも作れという事だろうと言うと、妻が横合からちょっとその電信を読みおわり、これはそんなむつかしい事でない。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちを、明い方を向いて……ああ碁石を呑んだじゃないの」　というと、握り拳をかためて、八っちゃんの脊中を続けさまにたたきつけた。",
              "citation": {
                "source": "碁石を呑んだ八っちゃん",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "外部では握り拳で続けさまに戸をたたいている。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "握り拳はぶる／＼とわなゝいてゐた。",
              "citation": {
                "source": "初夏",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "身體全體がまるで握り拳位にしか見えなかつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々爺は、小さい赭ら顔を握り拳のようにクシャ、クシャにしながら追従笑いをした。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "永年の間あの水門の把手を担ぎ慣れてゐる彼等の肩には、恰度握り拳大の力瘤がむつくりと盛りあがつてゐるではないか！",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "せいの高さは五尺にも足らず、握り拳ほどの小さい顔、色は蒼く皺だらけ、口を見ればみつくちである。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とりかえしがつかない」　そういって、杜はわれとわが頭を握り拳でもってゴツンゴツンと殴った。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「外でもありません、御註文と申しますのは、海のなかにかう島が二つ並んでるところなんですな、島が二つ……」と言つて、客は大きな握り拳を二つ自分の鼻先に列べてみせた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "小夜子は握り拳で紫檀の卓を叩きながら、廻らない舌で何か熱を吹いていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸棚の箱の中には、いつも握り拳大の玉が二十以上あった。",
              "citation": {
                "source": "光のない朝",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄はその顎を、火鉢のうへの方で、ちよツと、手の握り拳に受けて見せた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "外の奴は外の奴で、鼾をかきながら、握り拳を拵へて食卓の下に寝そべつてゐる。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふもので分るのか、それは文吾も知らないが、兎に角、源右衞門の汚い握り拳を透いて、中の紙捻がギヤマンの鉢に浮く慈姑の根のやうに見えてゐた。",
              "citation": {
                "source": "石川五右衞門の生立",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査の握り拳の上に芸者のお尻がノシかかって来る。",
              "citation": {
                "source": "爆弾太平記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かいい得物はないか……といった格好でそこいらを見まわしていたが、その中に右手の握り拳でボンと左の掌を打った。",
              "citation": {
                "source": "芝居狂冒険",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　馬方は握り拳をかためて、河童の頭の上に振り上げました。",
              "citation": {
                "source": "竜宮",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧がうまく自分を説き伏せ、家中の人々を感心させてくれたら――玄白斎は、自分の老いたことを感じたり、心弱さを感じたり、兵道家の立場の辛さを感じたりしながら「疲れた――疲れたのう」　と、眼を閉じたまま、額を、握り拳で叩いた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "重い方こそ、なるべく、法の表に従うようになさるのが、順でござりますが、上よりこれを乱して、何んとして、下を取締りますか」　川上は、左肩を聳かして、右手を、膝の上へ握り拳にして突き立てた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "と握り拳で二度叩くと、グツと餅が通つたが鼻の障子が抜けてしまつた。",
              "citation": {
                "source": "大仏餅。袴着の祝。新まへの盲目乞食",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「では何で遊ぶ、握り拳でか、貝殻でか。",
              "citation": {
                "source": "茗荷畠",
                "author": "眞山青果",
                "note": "青空文庫"
              }
            },
            {
              "text": "小六は大きな伸を一つして、握り拳で自分の頭をこん／＼と叩いた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "其斷然たる樣子と、其握り拳の小さゝと、之に反して主人の仰山らしく大きな拳骨が、對照になつて皆の笑を惹いた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
