        "examples": {
          "standard": [
            {
              "text": "指定された期日までに、銀行振込で入学金を納入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「入学金って意外と高いんだね。家計を圧迫しちゃうよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "合格を辞退した場合でも、一度納めた入学金は返還されない規則だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "白旗新聞店に這入ると、すぐ私は入学金その他に必要なだけの金を店主から前借りして、学校に通い始めた。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方針を徹底すれば、入学金の納入高の多い者から採るのが合理的で、そして入学金を試験以前に前払いするという形式を取れば、所謂不正入学ということになるのであるが、莫大な入学金を試験前に前払い出来るような家庭の生徒を採用することは、学校自身の営業方針から云って、少しも不正なことでも何でもない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でも明治の中葉頃まで、この言葉は入学金の意味に使われていた。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "月謝五円五十銭、入学金二円、本代二円五十銭也。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日、私達が事務室へ行って入学金と授業料を納めているところへ、又一人の同級生が着いた。",
              "citation": {
                "source": "凡人伝",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
