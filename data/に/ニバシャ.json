    "definitions": [
      {
        "index": 1,
        "gloss": "(horse-drawn) cart",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "赤ン坊の泣声や、おひきずりの靴の音や、昆布や烏賊や洟紙や首巻や、みんなみんな、街頭沿ひの電線の方へ荷馬車の音も耳に入らずに、舞ひり吁！",
              "citation": {
                "source": "暗い天候",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山麓帯の裾野で、日に焼けて、疲労をひどくしたくないので、定めの行程は短いにもかかわらず、翌十日は朝｜出立した、馬を五頭、一頭は荷物を積んで、案内者の、チャアルス・グーチという男が、裸馬に乗り、アルペン杖を横たえながら、片手で荷馬車を曳いて先登に立って行く。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "其内に荷馬車の音がして大勢の人夫がやつて來て、材木を轉がしては車に積み始めたので、私はしばらく畫架を片よせて避けなければならなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か物好きに荷馬車にでも乗せて連れて行ったらしい。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジメ／＼した田の上に家を建てゝ、そいつを貸したり、荷馬車屋の親方のようなことをやったり、製材所をこしらえたりやっていた。",
              "citation": {
                "source": "自伝",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒橇や、荷馬車や、徒歩の労働者が、きゅうに檻から放たれた家畜のように、自由に嬉々として、氷上を辷り、頻ぱんに対岸から対岸へ往き来した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒竜江にはところどころ結氷を破って、底から上ってくる河水を溜め、荷馬車を引く、咽頭が乾いた馬に水をのませるのを商売とする支那人が現れた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木材を満載したその荷馬車の車輪が道路の窪みの深い泥に喰い込んで動かなくなったのを、通行人が二人手を貸して動かそうとしていた。",
              "citation": {
                "source": "断片（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれどもいつか私は道に置きすてられた荷馬車の上に洋傘を開いて立ってゐるのだ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに荷馬車の持ち主だ。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中が迎えに来て荷馬車で帰る途中で、よその家庭の幸福そうな人々を見ているうちににんじんの心がだんだんにいら立って来て、無茶苦茶に馬を引っぱたいて狂奔させる、あすこの場面の伴奏音楽がよくできているように思う。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、町の人は、こんなふうに、魂をぬかれたように、きょろんきょろんとあたりを見ていたり、荷馬車にぶつかりそうになって、どなりつけられたりはしません。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるすぎ、野原の向ふから、又キラキラめがねや器械が光って、さっきの四人の学者と、村の人たちと、一台の荷馬車がやって参りました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながら包みを、荷馬車へのせました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるすぎ、野原の向うから、又キラキラめがねや器械が光って、さっきの四人の学者と、村の人たちと、一台の荷馬車がやって参りました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云いながら包みを、荷馬車へのせました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに荷馬車の音がしておおぜいの人夫がやって来て、材木をころがしては車に積み始めたので、私はしばらく画架を片よせて避けなければならなかった。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳めしく道庁や鉄道管理局や区役所の役人が見て居る前で、少し型の変つた荷馬車が、わざと造つた障害物をがたん／＼音を立てながら動いて行くのは、面白くも何ともなかつたけれども、久し振りで野原に出て学校友達と心置きなく遊ぶのは、近頃にない保養だつた。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭めいた屋前の芝生の先に木柵があって、木柵に並行した荷馬車の通うほどな広さの道の向こうには、かなり大きな収穫小屋が聳えて見えた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにおれは野原でおかしな風に枯草を積んだ荷馬車に何べんもあってるんだ。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それに酒屋の主人のはなしでは近頃は道路もよくなったし荷馬車も通るのでどこの家でもみんな町から直かに買ふからこっちはだんだん商売がすたれると云ひました。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "会社から毎日荷馬車の便りがあるだらうか。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みちは谷に沿った細いきれいな台地を進んで行ったがまだ荷馬車のわだちははっきり切り込んでゐた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると荷馬車が一台おいてある。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてどっこいといふ風に荷馬車にのっけてあたりをじっと見まはした。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして荷馬車の上に立って川下の方を見てゐる。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんどは月十二石だ、それからこんどは十四石十六石十八石、二十石とそこまで署長が夢のやうに計算したときは荷馬車の上はもう樽でぎっしりだった。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷馬車がうごき出した。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとさっきの若い男は荷馬車のあとへついた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうの少し小高いところにてかてか光る茶いろの馬が七匹ばかり集まって、しっぽをゆるやかにばしゃばしゃふっているのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
