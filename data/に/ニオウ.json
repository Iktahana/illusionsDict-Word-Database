[
  {
    "uuid": "0483cb26-07fb-5e56-a8b5-c9ef4bb82ad4",
    "entry": "仁王",
    "reading": {
      "primary": "におう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
