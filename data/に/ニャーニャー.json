        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "猫が喉をゴロゴロ鳴らしながら、にゃーにゃーと甘えた声で私にすり寄ってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "公園の片隅で、子猫が母親を探すようににゃーにゃーと鳴いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夜中に、どこからか隣の家の猫のにゃーにゃーという鳴き声が聞こえてきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "吾輩もいささか賛成の意を表するためににゃーにゃーと二声ばかり鳴いて見せる。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度は仕方がないからにゃーにゃーと二返ばかり鳴いて起こそうとしたが、どう云うものかこの時ばかりは咽喉に物が痞えて思うような声が出ない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
