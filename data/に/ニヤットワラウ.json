        "examples": {
          "standard": [
            {
              "text": "彼のニヤッと笑う顔を見ただけで、何か企んでいることが分かった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "予想外の成功に、チーム全員が顔を見合わせてニヤッと笑った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は私が仕掛けたジョークに気づき、面白そうにニヤッと笑って見せた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "……（サツのかんじょうをやめて、佐山の顔を見ていたが、不意にニヤッと笑う）佐山　……うん。",
              "citation": {
                "source": "胎内",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが女は目をひらかず、ニヤッと笑うと腕をのばし、私の首を抱えた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
