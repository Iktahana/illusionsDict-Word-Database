        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煮え湯をあびせられたような悲鳴が聞えて来た。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮え湯をあびせられた蟻のように支那兵は到るところに群をなして倒れていた。",
              "citation": {
                "source": "チチハルまで",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮え湯を呑ませられたようなものだ。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮え湯を飲むような気がした。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺される甥は不憫であるが、家には替えられない、親類縁者の大勢には替えられないと、こう決心した五郎三郎の眼からは煮え湯のような涙がこぼれた。",
              "citation": {
                "source": "箕輪心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "やい、バカ野郎ッ、こんな煮え湯をこしれえておいて、おいらをゆであげておいてから、あとで酢だこにでもする了見かい、と、こういってやったらね、三助の野郎がまたとんでもねえ啖呵をきりやがったんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卒塔婆を祭った米びつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「まるで降誕祭まへの豚か何ぞのやうに、頭から煮え湯をぶつかけをつて！",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "実はその男も拙者と同じく、探し廻っている筈で」「などと安心していると、貴殿、煮え湯を飲まされますぞ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホン・クルベーの家から、彼女を引っ張り出したのも、かつては煮え湯を呑まされた彼の復讐だったことも解った。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが患者にはくらくらに煮え返った熱湯と思われ、その狂った脳裡を、煮え湯や灼熱した鉄棒を使う拷問についての脈絡のないきれぎれの考えが、稲妻のように閃き過ぎた。",
              "citation": {
                "source": "紅い花",
                "author": "КРАСНЫЙ ЦВЕТОК",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちは今にも気絶しそうな時に、煮え湯を足に注がれることもあろう。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、鍋を持ちあげて井戸端の溝のところまでもって行き、溝に煮え湯をこぼそうとした。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "むつは太郎へ煮え湯をかけて殺してしまおうかと思いました。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠い昔、母親がかにを買って來て煮え湯へほうりこんだのだが、すぐ水色の蟹がいんにくのように朱くなってしまいました。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎も煮え湯へほうりこんだら、かにのように美しい子になるだろう。",
              "citation": {
                "source": "クララ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしここまで来て煮え湯を呑まされるような事ああるめえと思うよ。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、煮え湯が霧にならないで、かたまったまま飛び出してくるようなことはないかい。",
              "citation": {
                "source": "眼帯記",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮え湯を飲ませてどうするものかね？",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こりゃ、おのれ、こないだは、ようも煮え湯を呑ませたな！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが迂濶に立ち廻わると、今度も煮え湯を飲まされそうだよ。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ容易に猟り尽せるもんじゃないぜ」「煮え湯で洗濯したらよかろう」「煮え湯？",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮え湯ならいいかも知れない。",
              "citation": {
                "source": "二百十日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「煮え湯をぶっかけろ。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに違いはございますまい」「わしはな」と客は物うそうに、「五年以前あの賊のために、ひどく煮え湯を呑ませられましてな。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠小僧に相違ないと、かつて私が目星をつけ、あべこべに煮え湯を呑ませられた、ある人間の足跡が、ここにはっきりついているとな。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガマ六のように腕力に物を云わせるヤクザではないが、どこに秘訣があるのか、雨坊主の政治力にはガマ六がいつも煮え湯をのまされる。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十二　愚妖",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしがお前に飲まされた煮え湯の味が、いま貴様にわかったか」　かさなる意外な出来ごとに、長屋の連中は潮が引くように、外の路地へしりぞいて、土間に静かに立っているのは、田丸主水正ただ一人。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう思うと鉄斎老人、煮え湯をのまされた心地で、栄三郎の意中をかってに見積もってあんな告げ紙を貼り出したことが、今はただ弥生にすまない！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
