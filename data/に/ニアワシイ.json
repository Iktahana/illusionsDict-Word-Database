[
  {
    "uuid": "896f4750-f972-5525-b933-48d9171893bb",
    "entry": "似合わしい",
    "reading": {
      "primary": "にあわしい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
