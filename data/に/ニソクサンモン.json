    },
    "definitions": [
      {
        "index": 1,
        "gloss": "dirt cheap",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "坪五円にゃ、安いとて売れるせに、やっぱし、二束三文で、買えるだけ買うといて、うまいことをやった。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初会社側では相場が分らぬまゝに、二束三文で売り渡した。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "商売といっても家財を店先に並べて古道具屋を出す位で、それも一般家庭に役立つ物は少く、已むを得ず二束三文に売り飛ばすと、あとは商品を仕入れる余裕がないから、屑屋同様になって店を仕舞うという有様であった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童横町は昔河童が棲んでいたといわれ、忌われて二束三文だったそこの土地を材木屋の先代が買い取って、借家を建て、今はきびしく高い家賃も取るから金が出来て、河童は材木屋だと蔭口きかれていたが、妾が何人もいて若い生血を吸うからという意味もあるらしかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その足許を見て二束三文で買いとってやるのだと、随分前から安二郎は此の商売をやりたがっていたのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもほんの暫くでいやになり、二束三文で全てを賣り拂つた金で大盡遊びを續け、金が盡きると或る炭鑛の鑛夫になつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "島三題",
                "note": "青空文庫"
              }
            },
            {
              "text": "置かば立派で神威を増し、伐らば二束三文の神林を、ことごとく一時に伐り尽させたところが、思うほどに売れず、多くは焚料とするか空しく白蟻を肥やして、基本金に何の加うることなき所多し。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに維新後、漢医法｜癈れて一向この果売れず、黴だらけになって詮方なきところから、大阪でも東京でも辻商人にその効能を面白く弁じさせ、二束三文で売らせてもさっぱり捌けなんだと聞く。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "住居は住居で、葉子の洋行後には、両親の死後何かに尽力したという親類の某が、二束三文で譲り受ける事に親族会議で決まってしまった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この売るということが、お話しのほかで、買い手もないといった頃、その頃の堂々たる大名、旗本の家屋敷、あるいは豪商大家の寮とか別荘とかいうものでも、いざ、売り払うとなると二束三文、貰ってもしようがないと貰い手もない時節であるから、この蠑螺堂を、壊し屋が買った値段も想像されます。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "本所五ツ目の羅漢寺のこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "気味のわるいところをお目にかけてやるから、てめえのその二束三文のおしゃべり虫ゃ油で殺して、黙ってついてきな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "御承知でもございましょうが、明治初年の書画骨董ときたらほんとうの捨て売りで、菊池容斎や渡辺崋山の名画が一円五十銭か二円ぐらいで古道具屋の店ざらしになっている時節でしたから、歌麿も抱一上人もあったものでございません、みんな二束三文に売払ってしまったのでございます。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが今日、二束三文で買えるのです。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "奈良や、京都などでは特にそれが甚かった中に、あの興福寺の塔などが二束三文で売り物に出たけれども、誰も買い手がなかったというような滑稽な話がある位です。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "神仏混淆廃止改革されたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "圭一郎は郷里の家の大きな茅葺屋根の、爐間の三十疊もあるやうなだゝつ廣い百姓家を病的に嫌つて、それを二束三文に賣り拂ひ、近代的のこ瀟洒した家に建て替へようと強請んで、その都度父をどんなに悲しませたかしれない。",
              "citation": {
                "source": "崖の下",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「雑作なんて、家主に家賃のかただぜ、がらくた売つた処が二束三文で、せいぜい一晩泊りで、近かくの温泉へ行ける位のもんだらう‥‥」「温泉か、温泉もいゝわね。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌る日、人目にたゝぬやうに、嘉吉は通りすがりの年寄りの屑屋を呼び、台所道具から寝具に至るまで二束三文に売り払つてしまつた。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿も今年はいつになく豐年だつたけれど、釘が手にはいらないので箱がつくれないし、運輸が思ふやうにゆかないので、柿も二束三文に賣つた話をしてゐた。",
              "citation": {
                "source": "玄關の手帖",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "邦子の蒲団や身のまはりのものは、二束三文に売り払つて、死者の思ひ出を、一切合財吹き払つてしまつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「金にあかしてこしらえたものも、こうやって二束三文に手離しておしまいなさるんですよ。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "現物の俸禄米を持てあました役人は、これを二束三文に売りはらって、痛飲馬食して持てはやされた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄は夫から道具屋を呼んで来て、先祖代々の瓦落多を二束三文に売つた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄はそれから道具屋を呼んで来て、先祖代々の瓦落多を二束三文に売った。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "この兄は大の放蕩もので、よく宅の懸物や刀剣類を盗み出しては、それを二束三文に売り飛ばすという悪い癖があった。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢の炭のカケラにまで御不自由のていたらくで、かねて多少の貯えなどもインフレと共に二束三文に下落して、明日の希望もないようなものだ。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二束三文に売り払った始末で、神尾が生きて帰ったら、さだめし悲しい思いを致すでしょうと一時は案じたほどでした」「欲しい人には貴重な書物ばかりでしたのに、まとめて古本屋へお売りでしたか」「近所の小さな古本屋へまとめて売ってしまったのです。",
              "citation": {
                "source": "アンゴウ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちが売りに持っていった品物は二束三文に値ぎりたおす。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "株と云つたつて、大部分は例の赤城製氷で、こいつは二束三文にもならん。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "変化に乏しい楽茶碗、あるいは黒無地塗りの茶器棗の如きに於ても一つは芸術として燦然たるものあり、一つは二束三文取るに足らざるものあり、驚くべき賢愚高低があるのである。",
              "citation": {
                "source": "私の陶器製作について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
