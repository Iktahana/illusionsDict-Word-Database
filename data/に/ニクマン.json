        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さてわが家へ帰るとお茶になって、味つきパンや色んなジャムが出たあとで、仲よく｜肉まんに舌つづみをうつ。",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "……まずはじめが、パンと、チーズの緑色になったかたい皮、それから、肉の切れはしや、肉まんじゅうの半かけや、めんどりの骨などをくれたが、カシタンカは、たださえひもじくてたまらないところだったので、味わうひまもないほど早く、みんなぺろりとたいらげてしまった。",
              "citation": {
                "source": "カシタンカ",
                "author": "КАШТАНКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに肉まんじゅうが出るはずだ。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一度クリスマスの時、獄の囚人全部に、肉まんじゅうと丸パンを贈っただけである。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って入浴し、毛利の肉まんと、大阪のビフシチュウに飯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひる終って入浴し、大阪屋のハヤシライスと毛利の肉まん。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉まん、胡麻まん各一個、胡麻まんよし。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉まんにつけるソースを持って来たのが、トンカツソース。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の了り、亀井おばあちゃん又々蓬莱の焼売と肉まん持参。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断するな」　慕蓉は兵を鼓舞するために、自身、城外の鼓楼へ床几を移して、兵一人｜宛てに酒三杯、肉まんじゅう二箇ずつを供与して、その行を壮にした。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
