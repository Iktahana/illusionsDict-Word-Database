    },
    "definitions": [
      {
        "index": 1,
        "gloss": "manual or physical labor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冬の水は冷たい、だから肉体労働をしたことのない私の手はヒビだらけだ。",
              "citation": {
                "source": "私の生活",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "人力車夫と同じ肉体労働者です。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "身体の調子は頗る良いのだが、肉体労働が少し過ぎるらしい。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼よりはげしい肉体労働に堪え得る人間はほとんどなかったし、また確かに彼は、彼と同体量の拳闘家としては私の会ったことのある人のうちでは最も優れた拳闘家の一人だった。",
              "citation": {
                "source": "黄色な顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、はげしい肉体労働に彼ほど耐えうる人間はほとんどなく、また確かに同じ重量級では、私の見たうちでも拳闘家として一流の部類に入るだろう。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "行乞は一種の労働だ、殊に私のやうな乞食坊主には堪へがたい苦悩だ、しかしそれは反省と努力とをもたらす、私は行乞しないでゐると、いつとなく知らず識らずの間に安易と放恣とに堕在する、肉体労働は虚無に傾き頽廃に陥る身心を建て直してくれる、――この意味に於て、私は再び行乞生活に立ちかへらうと決心したのである。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働と消費とがそれぞれに違った階級に属していること、肉体労働と精神労働とが極端に分裂していること、労働の極端な専門化、都会と農村との分裂など資本主義そのものが本質的に持っている諸矛盾が文化の上にも強力に反映して来ている。",
              "citation": {
                "source": "今日の文化の諸問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭教師、通訳、翻訳その他の知的労働の範囲から、生活の必要は学生たちを肉体労働へ追いたてている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東大の職業を求めている学生の三六パーセントは、肉体労働をもいとわぬとしている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんざ濡れて働らく、かういふ人々の間を通り抜けて行乞する、私も肉体労働者であることに間違いない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十三日　晴、行程二里、前原町、東屋（二五・　）からりと晴れ、みんなそれ／″＼の道へゆく、私は一路東へ、加布里、前原を五時間あまり行乞、純然たる肉体労働だ、泊銭、米代、煙草銭、キス代は頂戴した。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "△肉体労働にはまことに、まことに尊いものがある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来講演と云ふものは肉体労働に近いものですから、腹に力のない時には出来ないのです。",
              "citation": {
                "source": "無題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大連其他の苦力（肉体労働者）は一日の食費が日本貨の五銭乃至十銭で足ると云ふ事である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の眼から見ればいわゆるぶらぶらしていたその頃の彼についてエマスンはこういっている、「彼は決して怠惰でも放縦でもなく、長期の職業にしばられるかわりに、金が入用になると、小舟や柵をつくること、植樹、接ぎ木、測量のような何か短期の肉体労働の仕事でそれを獲た。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "訳者の言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八五四年に出版された『ウォールデン』の成功は彼に経済的余裕と名声とをあたえ、講演の依頼も多くなり、肉体労働の必要もほとんどなくなった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "訳者の言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、肉体労働者と精神労働者は声が非常に違う。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械にたよつて肉体労働の美徳を忘れるのは堕落だといふ。",
              "citation": {
                "source": "デカダン文学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺四五寸の普通の体格をしているが、肉体労働をしている人間ではなさそうだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "機械にたよって肉体労働の美徳を忘れるのは堕落だという。",
              "citation": {
                "source": "デカダン文学論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "お品は一人子で十九歳、肉体労働をするところから、体は発達していたが、心持ちはほんのねんねえであった。",
              "citation": {
                "source": "名人地獄",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは学者の精神労働が、植字工の肉体労働に比して、甚だ高尚なものと考えられているからである。",
              "citation": {
                "source": "校正の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカふうの校正は、最後のところは、著者の精神労働と、植字工の肉体労働とを、同列に見るというところに、その基盤がありそうである。",
              "citation": {
                "source": "校正の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村恐慌への対策と村民の団結のために、封建遺制の底に沈湎している彼等に理論を説く事は、なかばは肉体労働的なつもりでいなければならない。",
              "citation": {
                "source": "地方文化運動報告",
                "author": "――尾道市図書館より――",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちこちへ頼んである就職口もなかなかラチがあかぬので、思いきつて肉体労働でもしようかと思つている。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉体労働以外の口は、おおかた怪しげな、人を小馬鹿にしたような仕事か、さもなければ、採用者の顔を見ただけで虫ずの走るような、職場しか廻つて来なかつた。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどい労働で疲れ切っていた私は、いくぶん肉体労働にはうんざりしていた。",
              "citation": {
                "source": "私の履歴書",
                "author": "――放浪の末、段ボールを思いつく",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドミン　マリウス、肉体労働型ロボットをサンプルとして連れてきなさい。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
