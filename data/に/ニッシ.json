    },
    "definitions": [
      {
        "index": 1,
        "gloss": "journal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "機関長室には顔の赤い人の好さそうなのが航海日誌と云いそうなものへ何か書いている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、葛原勾當日記の、假名文字活字日誌を土臺にして、それに私の濁創も勝手に加味し、盲人一流藝者の生活を、おぼつかなく展開してみたものでした。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御住所を搜し、こちらからお訪ねして、なほ精しく故人の御遺徳をも伺ひ、それから、私ごとき非文不才の貧書生に、この活字日誌の使用を御許可下さるかどうか、改めてお願して、そのおゆるしを得て、はじめて取りかかるべき筋合ひのものであるとは、不徳の小文士と雖も、まづは心得て居りました。",
              "citation": {
                "source": "文盲自嘲",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｎ監獄懲罰日誌　（林房雄氏）　林氏に對する私の豫備知識は貧弱である。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "懲罰日誌そのものゝなかには囚人の悲慘がユーモアに包まれて寫されてゐる。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく私は懲罰日誌には心を打たれた。",
              "citation": {
                "source": "『新潮』十月新人號小説評",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　妊婦は、あとで「脳振盪」と、病床日誌に死の原因を書きつけられていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日誌、日誌、ぼくはこの書きつける日誌がなかったら今夜どうしているだろう。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、近年勾当の令孫君、余が学校を訪われ君が祖父故葛原勾当自記の四十余年間に亘れる仮名文字活字日誌を示され、且、其生存中に於ける事業の大要及び勾当の趣味等につき、詳に語らる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　これは『創作』といふ短歌專門の雜誌で去月十六日誌友小集を開いた時の記事の一節で同誌八月號に載つてゐるものである。",
              "citation": {
                "source": "女郎買の歌",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがこの航海日誌を付けてきたのはまことに幸いである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれが彼をどんな種類の監禁のもとに置くにしても――この手段は最後のものとして、私は承認するのみであるが――われわれの行為を正当なるものと証拠だてる場合には、この日誌がどれほど役に立つことになるかもしれないからである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの日誌の初めの方にそれを挙げたと思うが、船長の奇癖のうちに、彼はけっして他人を自分の部屋へ入れないことがある。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "この航海日誌をつけ始めたとき、私はそれを終わりまで書かなければならないとは考えていなかった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを不思議な証跡の連鎖となるべき最後のものとして、私は「北極星号」のこの航海日誌の筆を擱く。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "――わたしは自分の忰の航海日誌に書かれている、北極星号の船長の死に関する不思議な出来事を通読した。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは船長がやや少し若く描かれているほかは、この日誌に記されたところと、まったく符合しているのである。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さながら歩く犯罪日誌といったところかな。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでの出来事については、このハンターの供述よりも、すでに世話になっているワトソン博士の日誌、正しく記されたものを引くのが順当だろう。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手へ知らすためのでなく、乗組船員をごまかし、同時に海事日誌をごまかすための。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そこまで読んで私は、その夕顔日誌を閉じ、木の箱にかえして、それから窓のほうに歩いて行き、窓を一ぱいにひらいて、白い雨に煙っているお庭を見下しながら、あの頃の事を考えた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ご牢屋日誌、送り込み帳、ご吟味記録。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達の、わけても勉の成長と進歩は、彼女の生活の生きた日誌であつた。",
              "citation": {
                "source": "悔",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして今やその日誌は、新しい頁をもつて始まらうとしてゐるのである。",
              "citation": {
                "source": "悔",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもその三枚を仔細に見わけると、明暗の微かな相違が認められ、全々の白紙と、積乱雲の影らしいものと、また一尾のアメンボウの姿らしいものが発見出来るので、夫々に、水や倒さまの雲やアメンボウを写すのが目的ではなかつたといふ言葉を附けたして、採集日誌のスクラツプにはさんだ。",
              "citation": {
                "source": "ベツコウ蜂",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　これは新吉が成年に達してから、英介の歿後にその書類を整理した時読んだ彼の日誌の一部である。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "遺書は小園と新吉に宛てゝ一通宛だつたが、新吉への文面の最後に、その内容は誰にも告げずに、日誌と共に焼却することが望まれてあつた。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな時には僕は面白くて思わずメガホンを執って荒武者たちに声援を浴せたりするのであるが、舟ばかりを欲しがっている友達の胸の中を思い返すと直ぐに僕も変になって、事務的に旗の上げ下しを手伝ったり、黙々として気象観察や潮流図の日誌を記したりするのであった。",
              "citation": {
                "source": "吊籠と月光と",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
