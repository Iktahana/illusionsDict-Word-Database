    "definitions": [
      {
        "index": 1,
        "gloss": "elm tree (esp. the Japanese elm, Ulmus davidiana var. japonica)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "武蔵野に見るような黒土を踏んで、うら若いひのきの植林が、一と塊まりに寄り添っている、私たちの足許には釣鐘草、萩、擬宝珠、木楡が咲く。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "楡やいろいろの槲やいたやなどの大木は内地で見たことのないものである。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋場のさる人の庭のいと濶きに此花のいと多く咲きたるを見しそれの年の秋の夕暮、かゝるところにてこそさる男も泣きけめと、楸楡颯々｜蓬艾蕭々として夕月の光り薄く西風の音の淋しかりしまゝ、勝れて艶なる此花を見る／＼徘徊りて想ひやりたることありき。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "市街のここかしこに立つ老いた楡の樹を見るごとに、彼はそれによって自分の心を励まそうとした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも省みられないけれども、春が来るごとに黙って葉を連ねているあの楡の大樹、あの老木が一度でも分外な涙を流したか。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はまた酔い心地にほほえみながら、楡の花のほろほろと散る間をぬけて台所口の方に廻った。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "樫も、楡もいたやもすべての葉はライラックの葉ほどに軟らかくて浅い緑を湛えていた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が身を倚せてゐる若木の楡の梢からは、秋の野葡萄のやうに色づいて卷きちゞれた葉が、そよとの風もないのに、果てしもなく散りつゞいて、寒さのために重くなつた空氣の中を靜かに舞ひ漂つて、やがて霜の上にかさこそと微かな音をたてゝ落着くのだつた。",
              "citation": {
                "source": "秋",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "建物の後は、楡やら楢やら栗やら、中に漆の樹も混ツた雜木林で、これまた何んの芬も無ければ色彩も無い、恰で枯骨でも植駢べたやうな粗林だ。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "※や楡の木にも別れをつげそれから毛布に荷物をくるんでわたしはぼんやりと出かけてきた。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰路｜楡木川に次し、急に病みて崩ず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕王範を垂れて反を敢てし、身｜幸にして志を得たりと雖も、終に域外の楡木川に死し、愛子高煦は焦熱地獄に堕つ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "永楽亭楡木川の崩を記する、鬼母の一剣を受くとなし、又｜野史を引いて、永楽帝｜楡木川に至る、野獣の突至するに遇い、之を搏す、攫されてたゞ半躯を剰すのみ、※して而して匠を殺す、其迹を泯滅する所以なりと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝勇武を負い、毎戦｜危きを冒す、楡木川の崩、蓋し明史諱みて書せざるある也。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して楡木川の客死、高煦の焦死、数たると数たらざるとは、道衍｜袁※の輩の固より知らざるところにして、たゞ天｜之を知ることあらん。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どっちみち、塀の前の楡の木の下で私が銃殺の刑に会うことは知れ切ったことなのよ。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九年八月　　凋落寂光土、はたや、墳塋、夕暮の古き牧場はなごやかに光黄ばみてうつらちる楡の落葉、そこ、かしこ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヨンキナ、チヨンキナ、チヨンキナ踊を、楡の羽蟻がひとをどり。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あの涼しい楡の新芽を御覧。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトニ・ウエンユク（悪楡）よ去れ。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "燦爛と木は笑ふ、楡、やちだも、恍として、夢ならず。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに大学や植物園の楡がいいです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑の向うの楡の木はいい形だなと、やっている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんと抒情的な異国風景、　ああ、春楡、山査子、白樺、　広い広い牧草の原、　あ、羊だ、羊だ、遠くを人が追って来ている。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔭の深い楡の二、三本の木立が、其処には幽雅な雨霧をまだ梢の緑に保っていた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "何という完全な楡の象であったろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "楡ほど枝ぶりの整った木は珍らしい。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たち――Ａさんと、医専の二人と庄亮と私とは、その楡の根方に座をしめた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "平然と立ち上つて、狸の火傷にれいの唐辛子をねつたものをこつてりと塗る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三か月ほどのち、丘の上のにれの木の下には、りっぱなハンスの銅像がたちました。",
              "citation": {
                "source": "丘の銅像",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
