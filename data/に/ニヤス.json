    "definitions": [
      {
        "index": 1,
        "gloss": "to cook inside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "事件の推移はこんな風で卵屋が業を煮やすことのある外表面甚だ平靜のうちに時日が經過して行く。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、小説虐殺の場合は十遍でも二十遍でも引立てられていっては念入の虐殺をうけるのであるから、たまったものではない、尤もいくたび殺されても執念深く生き換わるのであるから、執行人の方でも業を煮やすのであろうが。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、そんな場合には、終ひには知らず識らず走る、己れの菲薄性を宿命的に踏みつけるやうな妄想に駆られて、極めて漠然と業を煮やすのであつた。",
              "citation": {
                "source": "蔭ひなた",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは業を煮やすはずでしょう。",
              "citation": {
                "source": "或恋愛小説",
                "author": "――或は「恋愛は至上なり」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何もそれ程に業を煮やす事は無え。",
              "citation": {
                "source": "鼠小僧次郎吉",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、また一方、その「反省」の考のあまりにもかまびすしいのに、やゝ業を煮やすという、もつともな現象もなくはない。",
              "citation": {
                "source": "いわゆる「反省」は我々を救うか",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "米友は、道庵に心服しておりながらも、どうかすると、そのいけずうずうしいことに業を煮やすことはありながら、人命を扱うことにおいて、茶飯を食うような手軽さと、周到にして抜かりのなかりそうな用意のほどを見ると、おらが先生はエライ、と舌を捲かないということはありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "めいろの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな総立ちになり、いっぽう腹ばいになったまま、頑としていうことをきかない犬に業を煮やす。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と時折木寺君や海野君が業を煮やす。",
              "citation": {
                "source": "妻の秘密筥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯一人の息子でこんなに業を煮やすかと思うと俺もツク／″＼厭になる」「申訳ありません」「一体ならお前は士族平民の話が出た時に考えてくれる筈だ。",
              "citation": {
                "source": "脱線息子",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "御註文を」　と特に仲人道楽の一知人は業を煮やすくらいだった。",
              "citation": {
                "source": "嫁取婿取",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうこうする間に、月日は過ぎて行くが、時政のいう謝罪の立証は、すこしも事実となって来ないので、山木家側の業を煮やすことは甚だしく、「政子どのの首は、いつご持参あるのか」「親として知らぬはずはあるまいが」「それで、北条家の御館といわれるのか、武門の親としてすむのか」「大たわけ殿。",
              "citation": {
                "source": "源頼朝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は又新らしくたばこをくはへてにやにやする。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大学士は又新らしくたばこをくわえてにやにやする。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何すれば船客等は船底にやす／＼と眠る事が出來るのだらう。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすこを通った日は丁度お天気だったけれど、そうそう、その時は丁度日本では入梅だったんだ、僕は観測所へ来てしばらくある建物の屋根の上にやすんでいたねえ、やすんで居たって本当は少しとろとろ睡ったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "左翼の連中が右翼にやすやすと転向したり、大政翼賛会の中に左翼くずれがうじゃうじゃといてしきりに右翼ぶっているのは、左翼と右翼に共通した情熱があるからではないでしょうか」　信吉は田村の演出している時局劇が、ふと左翼劇と同じようなアジ的雰囲気を持っていることを、想い出した。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、ほんとうにやすらかな、気持のよい眠りでした。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "――はにやすのヒサこと貰れば、どうだべ？",
              "citation": {
                "source": "雀こ",
                "author": "井伏鱒二へ。津軽の言葉で。",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童路地はむかしこのあたりに河童が棲んでいたという噂からそういう名がついたほかに俗に只裏ともいい、家賃は只同然にやすいさかいやと、日の丸湯の主人は言っていたが、それさえ誰もきちんと払えた例しはなく、かたがた煙突の苦情も言うて行けなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桃子はん、あんた、おいやすか、おいにやすか。",
              "citation": {
                "source": "大阪の可能性",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庭の鶏頭にやすみませう、鶏頭もいつぱい火事になる。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうわけであるから、家賃も無論にやすい。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "船山「もうお帰にやすか」船山、扉をあける。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "河童路地は只裏ともいい、家賃は只同然にやすかったが、それさえ誰もきちんと払えた例しはなかったのだ。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　船乗りは立ち止まると、じっと目を据え、だらしなく口を開いてにやにやする。",
              "citation": {
                "source": "グローリア・スコット号",
                "author": "THE \"GLORIA SCOTT\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども陛下は、まだおかくれになったというわけではなく、やせほそり、色は青ざめながら、ながいびろうどのとばりをたれて、どっしりとおもい金のふさのさがった、きらびやかなしんだいの上にやすんでおいでになりました。",
              "citation": {
                "source": "小夜啼鳥",
                "author": "NATTERGALEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖の畔に降りゆきて、葡萄蔓纏へる「プラタノ」の古樹の、長き枝を水の面にさしおろしたる蔭にやすらひたる時、我等は纔に涼しさを迎へて、編みものに心籠むることを得つ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　五月の末にだれひとり待つ者もないのにやすやすと赤子は生まれた。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜、お蒲団はもう荷造りをすましてしまったので、お君は二階の洋間のソファに、お母さまと私は、お母さまのお部屋に、お隣りからお借りした一組のお蒲団をひいて、二人一緒にやすんだ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
