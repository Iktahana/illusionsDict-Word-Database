[
  {
    "uuid": "37e42029-3607-543b-9e23-727260e17f85",
    "entry": "人情",
    "reading": {
      "primary": "にんじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
