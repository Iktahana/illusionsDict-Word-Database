[
  {
    "uuid": "c5e71727-fd85-5a0d-88ca-f6e9c9aa7428",
    "entry": "賑わう",
    "reading": {
      "primary": "にぎわう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
