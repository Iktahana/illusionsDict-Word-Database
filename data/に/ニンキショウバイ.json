[
  {
    "uuid": "0b2c96b9-ad1f-5e78-9707-814b2600ec5b",
    "entry": "人気商売",
    "reading": {
      "primary": "にんきしょうばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
