        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "宮本武蔵は二天一流の開祖として有名だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は剣術の達人で、二天一流の技を完璧に習得している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "二天一流は、二刀を用いる独特の剣術である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "岩流を独創した小次郎と二天一流を発明した武蔵とは、武道に携る者として知らない者の無い名である。",
              "citation": {
                "source": "巌流島",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本に落ちついた翌十八年、武蔵は忠利の命によって、彼の生涯にわたって研鑽してきた兵法二天一流の事――つまりその集大成を系列して、書いたものを、主家へさし出した。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、あの五輪書の序は、その文にも見えるとおり、兵法の道、二天一流と号し、数年鍛錬のこと、書物に書き顕はさんと思ふ。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の「地の巻」は、兵法の総論、二天一流の基盤を説いているので、これを、地と名づける。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五輪書」序（原文）　兵法の道、二天一流と号し、数年｜鍛錬のこと、初て書き顕はさんと思ふ。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
