    "definitions": [
      {
        "index": 1,
        "gloss": "(Imperial) Japanese Navy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何ぞ恐れむ日本海軍。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "武村兵曹と云へば快活な事と、それから砲術に巧な事と、また腕力の馬鹿に強い事とで、日本海軍の水兵仲間には少なからず顏の賣れて居つた男なので、今や圖らずも、天涯萬里の此帝國軍艦の艦上にて、昔馴染の水兵等に對面したものと見える。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "新造軍艦は獻納される、海底戰鬪艇は現はれて來る、日本海軍益々榮え――。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "松島海軍大佐も微笑を帶びて『洵に兵曹の言の如く日本海軍の爲に慶賀すべき事である。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本海軍の一万｜噸巡洋艦でも追駈けることができますよ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜捕虜にした日本海軍の水兵をあなたに見せましょうか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "油断のならぬ日本海軍のことですから、何をはじめるか分からないではありませんか」「わしにもそれくらいのことは、ちゃんと分かっているよ、そうくどくどしゃべらなくとも、……それでどうだというんだ」　少将閣下は、たたみかけて叫んだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほら、いつか現れたホ型十三号という日本海軍が誇る最新型のやつだ」「うん、あれか。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇夜のことだし、相手はなにしろこの前も手を焼いた日本海軍の潜水艦だぜ」　光弾はひっきりなしに空中から投下される。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――（上海日本海軍部公報）大空澄みわたる　　日の丸あかるい涙あふるる　　（山生）　十二月十五日　快晴。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "同志小林は「蟹工船」において、日本資本主義の植民地的搾取の真相と、日本海軍がどのように人民収奪を援助する任務をもっているかということを、生産面においてくまなく描こうとした。",
              "citation": {
                "source": "同志小林の業績の評価に寄せて",
                "author": "――誤れる評価との闘争を通じて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二・二六事件の秘史というものが、当時の内部関係者であったファシスト軍人によって主観的に合理化してかかれたものが公表されるし、日本海軍潰滅前後の物語も、当時の連合艦隊参謀長というような人々によって執筆されはじめた。",
              "citation": {
                "source": "ことの真実",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、比律賓附近に於ける日本海軍の大演習。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本日天気晴朗なれども波高し、というのが日本海軍の海戦記の常套語だと聞く。",
              "citation": {
                "source": "情意の干満",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、二十八年二月、日本海軍が威海衛を占領した時に、丁汝昌は従容と自殺してしまったのだ。",
              "citation": {
                "source": "モルガンお雪",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしても、艇長の死と死体の消失が厳然たる事実であることは、その後に艇を引き揚げた、日本海軍の記録的に明記するところなのです」　風はなぎ、暁は去って、朝｜靄も切れはじめた。",
              "citation": {
                "source": "潜航艇「鷹の城」",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本海軍が赤道以北の独領諸島を掃蕩しつくしたけれど、まだドイツ東洋艦隊が南太平洋にいるという頃。",
              "citation": {
                "source": "「太平洋漏水孔」漂流記",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうだ、この僕の設計図を日本海軍へ売ってみないか。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや『最上』は、岩とたたかい、流とたたかい、死力をつくして、日本海軍の航海術の手並のほどを見せているのだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに日本海軍だッ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、もしも昭和遊撃隊がここで負けたら、日本海軍はどうなるのだろう？",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か日本海軍の秘密が聞き出せるかも知れないぞ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ、日本海軍最初の、紅玉島砲撃である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君、見よ、いよいよはじまった勇ましい生命知らずの日本海軍の戦法を！",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本海軍のためには悪魔だ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の魚雷攻撃は、日本海軍のお得意である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "降伏しろなんて、日本海軍を侮辱しているぞ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本海軍の字引には――降伏――の二字なし。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本海軍の汚のない歴史である。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
