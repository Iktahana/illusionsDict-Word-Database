        "examples": {
          "standard": [
            {
              "text": "彼は優しい顔の裏に、冷酷な二面性を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人間は誰しも、多かれ少なかれ二面性を持っているものだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "その事件の真相は、彼の二面性が引き起こしたものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十七八の頃からそういう二面性はつづいているのです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "常に彼女自身であると同時に、ほんの少しだけ演技の加わった彼女でもあるという二面性は、写真のなかに固定された彼女にとって、謎としての奥行きに転換された。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
