        "examples": {
          "standard": [
            {
              "text": "今日の水族館は、外国人観光客を含め多くの入園者で賑わっていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コロナ禍では、感染対策として入園者の人数が厳しく制限された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "年間パスポートを持つ入園者は、優先的に入場できるシステムになっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一体、園には、春から夏にかけて入園者が大変多いのですが、秋からかけて酷寒となるとウンと減つてしまひます。",
              "citation": {
                "source": "入庵雑記",
                "author": "尾崎放哉",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の人口が少かったから、日曜日だというのに、入園者は多くはなかった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
