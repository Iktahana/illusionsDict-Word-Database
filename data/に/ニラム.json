    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to glare at",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と言わぬばかりの非難の目つきで私を睨むのである。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして翌朝になって銘々の絹帷子を調べ「少しも皺のよらざる女一人有」りそれを下手人と睨むというのがある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前も、何時迄もこんな汚ねえ家の二階を借りて居ねえで……」　親爺、睨む。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジロッと三次を睨む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言った顔で其の男を睨む。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「厭や、厭や、そんなに茶化しておしまひになるの‥‥」　妻はちよつと夫を睨むやうにしながら、「ほんとにあたし眞劍に言つてるのよ。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、素直に何もかも云っちまえ」と、半七は彼の男を睨むように視た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしゃ、どうも、そう睨む。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、舞袴にぴたりと肱を張つて、とろりと一｜睨み睨むのがお定り……　と其を思出して、……独りで笑つた。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は座敷に上がると母は眼に角を立て睨むようにして「お前さんまで逃げないでも可いよ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮の空ほの暗い時に、柱に靠れて居た僕が突然、眼を張り呼吸を凝して天の一方を睨む様を見た者は母でなくとも逃げ出すでしょう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の高価い炭を一片だって盗られちゃ馬鹿々々しいやね」とお源を見る、お清はお徳を睨む、お源は水を汲んで二歩三歩歩るき出したところであった。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "父がよろしくと申されました」　というと、いつもの癖の眼鏡の上の方から眼を覗かせて、睨むようにこっちを見ていた奥様は、「父がよろしくと申されましたかね。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その席がもし他の客に占られていたなら睨む。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく立並んで呪いの眼で睨む。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心の切り方が悪いからよ」と婆やはたしなめる様に云うと、おすめは其には答え無いで突立ったまま、何処を睨むか見当の付かない様な斜視の眼を据えて、「婆やさんの長湯にも呆れるなあ、やあ垢擦りだ、やあ糠だのって」と云って口を尖らした。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと斉しく、どろんとしつつも血走った眼を、白眼勝に仰向いて、赤熊の筒袖の皮｜擦れ、毛の落ち、処々、大なる斑をなした蝦蟇のごときものの、ぎろぎろと睨むを見たのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "中から縁へしがみついた、面を眞赤に、小鼻をしかめて、目を白く天井を睨むのを、熟と視めて、「豪え、豪え。",
              "citation": {
                "source": "錢湯",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆の中に眼の輝く、顏面凡て髯なるが、兩腿出した毛むくぢやら、蝟の大胡坐で、蒋生をくわつと睨む、と黒髯赤く炎に照らして、「何奴だ。",
              "citation": {
                "source": "麥搗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何ですって、」「どうだ、、蟷螂、」といいながら、お雪と島野を交る交る、笑顔で※しても豪傑だから睨むがごとし。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、踏留まって、睨むかと目をみはった。",
              "citation": {
                "source": "若菜のうち",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "睨むように顔を視めながら、「高いがな高いがな――三銭や、えっと気張って。",
              "citation": {
                "source": "小春の狐",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "とトロンコの据眼で、提灯を下目に睨む、とぐたりとなった、並木の下。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "行年その時六十歳を、三つと刻んだはおかしいが、数え年のサバを算んで、私が代理に宿帳をつける時は、天地人とか何んとか言って、禅の問答をするように、指を三本、ひょいと出してギロリと睨む……五十七歳とかけと云うのさ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私あ若気だ、襟巻で顔を隠して、睨むように二人を見たのよ、ね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはかの重兵衛で、今ここへ駆けつけて来る足音を聞くと、かれはにわかに起ち上がって睨むように源吉を見た。",
              "citation": {
                "source": "深川の老漁夫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに帰ったかえ」と、半七は相手の顔を睨むように見た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――うむも言わさずに、刺青をするなんて、実際ひどいことをするのね」　針助を睨むように見ると、針助はふと狼狽の色を見せたが、やがて急に笑い出して、「あはは……。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜさうこっちをにらむのだ、うしろから。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだにらむのか、勝手にしろ。",
              "citation": {
                "source": "沼森",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
