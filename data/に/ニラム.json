[
  {
    "uuid": "b5d00704-9749-5bda-9aa1-44bfa74abb3b",
    "entry": "睨む",
    "reading": {
      "primary": "にらむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
