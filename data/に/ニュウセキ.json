    "definitions": [
      {
        "index": 1,
        "gloss": "registering (a marriage, etc.) in the family register",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
