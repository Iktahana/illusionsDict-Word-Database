        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これはあとで分つたのだが、ゆつくり吸ふのでは、火焔で煮え立つ半液體が孔をふさいでしまふからなのだ。",
              "citation": {
                "source": "阿片の味",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日か山の中に寢泊りして出て來た三人が思ひがけぬこの匂ひの煮え立つのを嗅いで胸をときめかせてゐるのもよく解つた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾日か山の中に寝泊りして出て来た三人が思いがけぬこの匂いの煮え立つのを嗅いで胸をときめかせているのもよく解った。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思うと、瑠璃子は、女ながらにその小さい胸に、相手の卑怯を憤る熱い血が、沸々と声を立てゝ、煮え立つように思った。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天プラ屋の煮え立つ油のにおいを嗅いだり、ころもの色をながめたりした。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれたばかりの嬰児の四肢をもぎとって煮え立つフライパンの中へ投げこむほど惨忍にもなります。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思ふと、瑠璃子は、女ながらにその小さい胸に、相手の卑怯を憤る熱い血が、沸々と声を立てゝ、煮え立つやうに思つた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "信一郎は、夫人の白々しい態度に、心の底まで、憎みと憤怒とで、煮え立つてゐた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「味噌汁を拵へるのに、味噌の煮え立つ前に、滑つこい焼石を鍋に衝込むものがある。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーリキイは自分の心にも似たような黒い、激しいものが答えられない疑いとして煮え立つことを既に幾度か経験しているのであった。",
              "citation": {
                "source": "マクシム・ゴーリキイの伝記",
                "author": "――幼年時代・少年時代・青年時代――",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜で煮え立つ湯の音ばかりが、ただシンシンと聞こえている。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――爺さんはその時のことを思うと肚が煮え立つのである。",
              "citation": {
                "source": "神楽坂",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "王は譫言に止度なく、煮え立つてゐる大鍋と谷あひの苔の事とを云ふのである。",
              "citation": {
                "source": "バルタザアル",
                "author": "BALTHASAR",
                "note": "青空文庫"
              }
            },
            {
              "text": "客間からの話声をききながら湯がやっとたぎり出して来てだんだん煮え立つ音がしずまって行き、将にふきこぼれようとするところで瓦斯を消す迄の我知らず固唾をのんでいる間の心持。",
              "citation": {
                "source": "海流",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "魔法つかひは腰に大きな鍵のたばをぶら下げて、火にかけたまつ黒な鍋の中に、何やらグチヤ／＼煮え立つてゐるものを、しきりにかき廻してゐました。",
              "citation": {
                "source": "虹猫の大女退治",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮え立つやうな心は、鋭い語になつて、沸き上つた。",
              "citation": {
                "source": "身毒丸",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはづみに、鍋がひつくり返つて、くらくら煮え立つたスープを、頭からひつかぶりました。",
              "citation": {
                "source": "カルナツクの夏の夕",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "もやあ、時々此奴め……と煮え立つような思いをひとにさせるが、しんにきたないものない故、からりとあとする。",
              "citation": {
                "source": "日記",
                "author": "一九二七年（昭和二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうモスクは地図の上で赤ぼっち、モスク、モスクを考えると、煮え立つ鍋にさわるような感じだ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひだすと、煮え立つ怒りにやりきれない。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事と言つても何時も心で苛苛と煮え立つてゐながら、毎日の隋勢でずるずると泥沼に陷り込むやうで、這ひ上ることさへできないやうな氣がするのであつた。",
              "citation": {
                "source": "蒼白き巣窟",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "お六が煮え立つた二度目の湯を持つて來てくれたので、直ぐ使へるやうにいつもの通りその大釜を井桁の上へ置いたのが惡かつたんです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際、鰯の大群は煮え立つように南の方へすこしずつ動いているのでした。",
              "citation": {
                "source": "不思議な魚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "三藏は今朝から北湖先生のコンパスの長い脚で大股に歩かるゝのについて歩いておまけにもう一時を過ぎてゐるし、願くは牛肉か何かのぢやあ／＼煮え立つ強い匂をかぎ度いのであるが「私は此宇治の里が昔から好きでやしてな。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸のまん中が火のようになり、頭脳がぐらぐら煮え立つように感じた。",
              "citation": {
                "source": "思い違い物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが人間はついに、われからその棲み家を業の窯として、自分も他人も、煮え立つ釜中の豆としてしまった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬鹿者」　主膳は肩先に療治を受けて布を捲いてもらいながら、そのにえたつような憤懣を、犬殺しどもの頭から浴びせかけました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてぼくのすることはそのにえたつのを見るだけだ。",
              "citation": {
                "source": "家なき子",
                "author": "SANS FAMILLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "まつ白にこほりついた、ぼろござをきせられた馬は、にえたつた湯気のやうな息を、ひゆう／＼はきつゞけました。",
              "citation": {
                "source": "そり（童話）",
                "author": "オイゲン・チリコフ",
                "note": "青空文庫"
              }
            }
          ]
        }
