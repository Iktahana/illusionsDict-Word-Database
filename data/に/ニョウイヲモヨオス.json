          "literary": [
            {
              "text": "まず第一に尿意を催す。",
              "citation": {
                "source": "地獄街道",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところでそのバーを出てから尿意を催すと、どこかで始末をつけねばならぬが、適当なところがない。",
              "citation": {
                "source": "地獄街道",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "試合になれない初心のころは、試合開始に先立ってしきりに尿意を催すものだから、この連中は勝てないぞ、と私は思う。",
              "citation": {
                "source": "安吾巷談",
                "author": "今日われ競輪す",
                "note": "青空文庫"
              }
            },
            {
              "text": "このレントゲンのせいか、病勢が昂進したのか、五月になってからは夜になると、殆ど三十分おきに尿意を催すため熟睡が出来ず、昼間は一日中うとうとしていた。",
              "citation": {
                "source": "三浦環のプロフィール",
                "author": "吉本明光",
                "note": "青空文庫"
              }
            },
            {
              "text": "十時過ぎに尿意を催す。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
