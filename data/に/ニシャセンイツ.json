        "examples": {
          "standard": [
            {
              "text": "提示された二者選一の選択肢は、どちらも私にとって好ましいものではなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の提案は、二者選一を迫るような厳しい内容だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "人生には、二者選一の決断を迫られる場面が何度かある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "つまり、自分には、二者選一の力さえ無かったのです。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二者選一の場合に於ても、つねに私は自分の排する方に心をひかれる小説家だった。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
