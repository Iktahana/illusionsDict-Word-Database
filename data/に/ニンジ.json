[
  {
    "uuid": "6e1be95b-c399-5459-b286-93b2913c046e",
    "entry": "人時",
    "reading": {
      "primary": "にんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "man-hour",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして、この家で芝中學校時代、慶應義塾文科時代、三年間の「三田文學」編輯人時代を經てから文筆生活に入り、結婚し二人の子の父となる現在に及んだ。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも当人時ならず、春風｜胎蕩として、今日｜九重ににおい来る、菊や、菊や――酒の銘。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「尾羽うち枯らした浪人時代――いや、今とても浪人ではござるが、もっとミジメな浪人時代、食うに困って浅草へ出、習い覚えた皿廻し、大道芸を売りましてな、日々の生活を得てござるよ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "世人時にこれを徳育と混じいふ、しかれども勇猛心忍耐心は善悪邪正の感とは異なり。",
              "citation": {
                "source": "病牀譫語",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの人時々東京へ来るのよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「Ｍ―夫人時代から見ると、変つたものだね。",
              "citation": {
                "source": "質物",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本でいう大作家の風格というものの内容は、古い文人時代の内容から、社会性においてそう大して新しくなっていると思われないのである。",
              "citation": {
                "source": "冬を越す蕾",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十歳前後には社会時評、婦人時評その他の評論をもかいて『太陽』に発表し、「男子を瞠若たらしめる」と評された。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「立ち立つ」と二つ重ねて物の多き有樣を現すなど極めて巧なる語なるを、後世の人時に此語を襲用して其儘に「立ち立つ」と使ふも、他の語に此語法を應用するの機轉すらなし。",
              "citation": {
                "source": "萬葉集を讀む",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「木王園主人時々御陪遊被成候哉。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "現実には、松本は浪人時代を秋葉原に入りびたって過ごした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "松本が浪人時代を過ごした一九七二（昭和四十七）年ごろ、猛烈な勢いで電卓が小さく、安くなる中で、秋葉原にはすっかり時代遅れとなった初期のＩＣ電卓がジャンクとなって流れはじめていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "行人時に古を弔へば、榛名湖の名物なる菖蒲の花、徒らに美人の俤偲ばしむるのみなるべし。",
              "citation": {
                "source": "冬の榛名山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこの雑誌はその以前の日本人時代から私も俳句欄を担当していたのだから、改称して大雑誌となると共に、俳句欄は、私と碧梧桐氏と二人で各別に担当する事になって、保守主義欄と、新傾向欄とのあることは誰れも知る通りである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、中にたゞ一人時間が過ぎても、ぼんやり何か考へ込んでゐて何も作らない生徒があつた。",
              "citation": {
                "source": "幽霊の足",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ才人時に遇ひたる眩ゆさを思はしむ。",
              "citation": {
                "source": "『行く春』を読む",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せて黄色になつた顔には、もとの面影がもはや無いと謂つても、白きを交へて疎らに延びた鬚髯のあたりを見てゐると、※の村人時代の顔容をおもひ起させるものがあつた。",
              "citation": {
                "source": "島木赤彦臨終記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物　親鸞　唯円　僧二人　小僧一人時　　同じ日の宵親鸞寝床にすわって僧二人と語っている。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物　唯円　かえで　女の子、四人時　　春の午後　第三幕より一年後唯円一人。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人物　唯円　僧数人　小僧一人時　　晩い春の夕方　第四幕より一月後僧六人、仏壇の前に座して晩のお勤めの読経をしている。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――黒幕――第二場親鸞聖人居間舞台　第三幕、第二場に同じ人物　親鸞　唯円　僧三人時　　同じ日の夜僧三人、親鸞と語りいる。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかの即興詩人時代の情趣｜濃かなＭ博士がなつかしい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人時々往来して談笑す、常に※を解かざることなし。",
              "citation": {
                "source": "北村透谷君",
                "author": "山路愛山",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのセンセーショナルなところが軍人時代に反撥され、良俗に反するからといふやうな、よけいな刑期の憂目を見た原因であつたと思ふ。",
              "citation": {
                "source": "阿部定さんの印象",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍人時代がそうであった。",
              "citation": {
                "source": "風流",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸い余が軍人時代に老父母のために新築したのが今日わが身の役に立っているのであるが、そのほかには蓄えというものもない。",
              "citation": {
                "source": "中庸",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "批判禁止の軍人時代とちがって、批判自由の時代に於ても特権階級の専横は軍人時代と同じ程度であるから、いかに性温良とは云え、泣く子と地頭に勝てないという日本気質の哀れさは、当代の奇習のうちでも万世一系千年の伝統をもち特に珍らかなもののように思われる。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし地方に依りますと、彼らがまだ非人時代からのもとの部落に住んでいるが為に、依然として付近のものからは、特殊民の待遇を受けている例がないでもありません。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「松虫草」と「なべな」、「ほたるぶくろ」と「つりがねにんじん」といったようなものである。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "登場人物の中でいちばんじょうずな役者は主人公のにんじんである。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
