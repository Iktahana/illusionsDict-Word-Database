    "definitions": [
      {
        "index": 1,
        "gloss": "(typically) Japanese",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
