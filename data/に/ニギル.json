    "definitions": [
      {
        "index": 1,
        "gloss": "to clasp",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "娘は意外に思うらしく慌ててそっと手を出し、一秒間程相手の手を握る。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "素人の母親の握る鮨は、いちいち大きさが違っていて、形も不細工だった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "電気の光りで大きい手を右のポケットに突っこんで拳銃を握るのがちらっと栗本に見えた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の眠｜催す様なるこの水音を源叔父は聞くともなく聞きてさまざまの楽しきことのみ思いつづけ、悲しきこと、気がかりのこと、胸に浮かぶ時は櫓握る手に力入れて頭振りたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして他郷に遊学すると同時にやめてしまって、今日までついぞ絵筆を握る機会はなかった。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猿がやって来て片手を穴に突っ込んで米を握ると拳が穴につかえて抜けなくなる。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『ナニあの男の事だからいったんかせぎに出たからにはいくらかまとまった金を握るまでは帰るまい、堅い珍しい男だからどうか死なしたくないものだ。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れは驚き慌てゝ探るやうに手舵を握ると、夫れを包んだカンバスはぐつしより濕つてかん／＼にこはばつてゐた。",
              "citation": {
                "source": "潮霧",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "カロラインが堅く私の手を握ると私もファニーの手を堅く握らねばならぬ。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いて白髪を握ると、耳が暖く、襖が明いて、里見夫人、莞爾して覗込んで、「もう可いんですよ。",
              "citation": {
                "source": "伊勢之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「構わず、ぐっと握るべしさ、」「しっかり頼むぜ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "可うがす、何そりゃ好いた女のためにゃあ世の中を打棄るのも、時と場合にゃ男の意地でさ、品に寄っちゃあ城を一百一束にして掌に握るのと違わねえんでございましょうが、何ですぜ、野郎の方で、はあと溜息をついて女児の膝に縋るようじゃあ、大概の奴あそこで小首を傾げまさ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛狒怒つて刀身を双手に握ると、水兵は焦つて其胸先を蹴上げる、此大奮鬪の最中沈着なる海軍士官は靜かに進み寄つて、二連銃の筒先は猛狒の心臟を狙ふよと見えしが、忽ち聽ゆる一發の銃聲。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "艦橋には艦長松島海軍大佐をはじめとし、一團の將校は月に燦爛たる肩章に波を打たせて、隻手に握る双眼鏡は絶えず海上を眺めて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叫んだまゝ、空拳を振つて本艦々頭に仁王立、轟大尉は虎髯逆立ち眦裂けて、右手に握る十二｜珊砲の撃發機は唯だ艦長の一令を待つばかり。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "若旦那の手を、美少年の方から迎へるやうに、じつと握る、と其の手の尖から雪と成つて、再び白衣の美女と變つた。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、内海の青畳、座敷へ入ったも同じじゃ、と心が緩むと、嘉吉｜奴が、酒代を渡してくれ、勝負が済むまで内金を受取ろう、と櫓を離した手に銭を握ると、懐へでも入れることか、片手に、あか柄杓を持ったなりで、チョボ一の中へ飛込みましたが。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "結び目の押立って、威勢の可いのが、弁慶｜蟹の、濡色あかき鋏に似たのに、またその左の腕｜片々、へし曲って脇腹へ、ぱツと開け、ぐいと握る、指と掌は動くけれども、肱は附着いてちっとも伸びず。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と身を悶えて騒げば、車中いずれも同感の色を動かして、力瘤を握るものあり、地蹈※を踏むもあり、奴を叱してしきりに喇叭を吹かしむるもあり。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二月経ったが、手一つ握るのも躊躇される気の弱さだった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――』　そう云いながら、その手を握ると、冷たく汗ばんで慄えていた。",
              "citation": {
                "source": "或る母の話",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "其は假りにお房に手を握る資格のあるものとして、果してお房が手を握らせて呉れるかどうかといふ氣懸だ。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから戸棚をあけて、一梃の大きな金槌とギラギラ光る出刃庖丁を持ち出して、まず金槌を握ると、馬の鼻づらをメカクシの上から力一パイなぐり付けましたので、馬はヒンとも云わずに床の上に四足を揃えてドタンとたおれました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の青い鳥を今度こそほんとに握ることができるのだ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもいま一分間の後には、凡てそれらの謎の祕密と幸福の實體とは、疑ひもなく彼等自身の手の中に握ることができるのである。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "破り棄てなさるなど、それまで一度も無かつた事でございましたので、お傍の私たちはその度毎に、ひやりとして、手に汗を握る思ひが致しました。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無念骨髄に徹して歯を咬み拳を握る幾月日、互に義に集まる鉄石の心、固く結びてはかりごとを通じ力を合せ、時を得て風を巻き雲を起し、若君尚慶殿を守立てて、天翔くる竜の威を示さん存念、其企も既に熟して、其時もはや昨今に逼った。",
              "citation": {
                "source": "雪たたき",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやそれについて話しのある、其十兵衞といふ男の親分がまた滅法えらいもので、若しも些なり破壊れでもしたら同職の恥辱知合の面汚し、汝はそれでも生きて居られうかと、到底再度鉄槌も手斧も握る事の出来ぬほど引叱つて、武士で云はば詰腹同様の目に逢はせうと、ぐる／＼／＼大雨を浴びながら塔の周囲を巡つて居たさうな。",
              "citation": {
                "source": "五重塔",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の掌より紅血を滴らすか、滑澤柔軟のもののみを握るか、此の二つは、明らかに人力と運命との關係の好否を語る所の目安である。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、女はニッコリ笑って、それを嫌がりもしないので、いよいよ情を覚えてその手をしっかとにぎると、女は左の手をはずして、右の手で桶をささえると、左の手で氏長の手をわきにはさんだ。",
              "citation": {
                "source": "大力物語",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
