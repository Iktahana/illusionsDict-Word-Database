    "definitions": [
      {
        "index": 1,
        "gloss": "with a complacent smile",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
