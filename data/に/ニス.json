        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "デスカラ身体ヲ大事ニスルヨウニクレグレモ願イマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑いだすと果しがないけれども、いったい、彼にはどのような音楽理論があるのか、ヴァイオリニストとしてどれくらいの腕前があるのか、作曲家としてはどんなものか、そんなことさえ私には一切わかって居らぬのだ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に彼は、人間性の普遍な悲しみを体験して、本質に宗教的なモラルを持ったところの、真のヒューマニストの詩人であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "店へはいると一面に吊した絵のニスの香に酔うてしまう。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十二年の暮には南ドイツからウィーンを見物してヴェニスに泊ったのがちょうどクリスマスであった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスもやった、自転車も稽古した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェニスの美しさも半分は自然の爲によごれ曝されて居るおかげである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋にはこういう事にも熱心な学者が多く、玉突、テニス、砲丸投等の技術を力学的に研究した例は乏しくない。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フェミニストにもいろいろある。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また「英雄が女性の胸に額をつけるとき、遠き星の囁きを聴く」事業上の霊感の交媒者として女性に神秘を感じ、フェミニストたるものもある。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角真のフェミニストは質的のものだ。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性から言えば、弱々しくフェミニストたらざるを得ない男性より昂然としていても、女性に理解力ある男性の方が見込みがある。",
              "citation": {
                "source": "女性崇拝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室の中は、青い天蚕絨を張った腰掛けが、まるでがら明きで、向ふの鼠いろのワニスを塗った壁には、真鍮の大きなぼたんが二つ光ってゐるのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "由来物理学者はデターミニストであった。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰途はギリシアからブリンデイシ、ヴェニスを経て一八七三年五月初旬にロンドンに着いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は散歩の代りにローンテニスもやった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスの上手な来客でもこの羽根の生えたボールでは少し見当が違うらしい。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールは定めて間だるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニス競技の場面の挿入は、物語としては主要なものでないが、映画の中の挿話として見ると不思議な心理的な効果をあげている。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴェニスの街のような者がそれである。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒療治　（山本勝治氏）　ある港町の沖仲仕達を組織化しようとしてゐる一人のコンミユニストが、大事な仕事を前にして自分の固い決意の弛緩をふと意識する。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年前に亡くなつた「敬虔なる奴僕」の弟で、スタニスラウス・フオン・ヰツクと云ふのである。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "祈祷が済むと、現に族長になつてゐるスタニスラウスが、先頭になつて席を起つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ出て、スタニスラウスは妹のリヒテル少佐夫人に臂を貸して、並んで歩き出した。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスと並んで歩く少佐夫人は、体の太つたのと反対に、いつも忙しさうに足を早めたがる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは妹の足の早いのを、慾望的な、現世的な努力を表現してゐるやうに感じて、妹を警醒するやうな口吻で、「兄は可哀さうな男だつたな」と云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは二三度肩を聳かして、そして心配らしい、物を聞き定めるやうな顔をした。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時スタニスラウスは家族が皆見てゐる前で、さつきの肩の運動を繰り返してゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは先づ心配げな顔に、堪忍の表情を蓄へられる丈蓄へて、矢張さつきの肩の運動を繰り返して、溜息を衝いて云つた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "スタニスラウスは妹の少佐夫人とフリイデリイケとの間に据わつてゐる。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
