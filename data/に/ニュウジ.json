[
  {
    "uuid": "f5057f69-88ea-56f1-9cff-542951714d32",
    "entry": "乳児",
    "reading": {
      "primary": "にゅうじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
