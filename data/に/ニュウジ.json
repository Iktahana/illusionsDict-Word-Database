    "definitions": [
      {
        "index": 1,
        "gloss": "infant (below 1 year old)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
