        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その味は市村座の向側の馬肉屋の煮込そっくりであったから、煮込む骨に共通の点があったのかも知れない。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを御飯に混ぜて白ソース即ちバターとメリケン粉と牛乳と塩胡椒のソースで煮込むのです。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮ごと塩で長く煮込むのですから、寒中などはよく持ちます。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三州仕立ての味噌汁は、ほかに江戸前のこいなど入れて煮込むやり方もあるし、白魚、赤貝などの軽いもので拍子を取る場合もある。",
              "citation": {
                "source": "三州仕立て小蕪汁",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日とか半日とかゆっくり煮込む流儀の料理だそうである。",
              "citation": {
                "source": "牧野伸顕伯の思い出",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "必死の父は、すぐさま捜索隊とともに魔法使いの住まいに乗り込み、巨大な窯でせわしなく何かを煮込む老ミシェル・モーヴェ見つけたのです。",
              "citation": {
                "source": "錬金術師",
                "author": "THE ALCHEMIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま、これを膠で煮込むのだ。",
              "citation": {
                "source": "不思議な魚",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だからこんなにこむのだ」と。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つに波はわかれ散り、人魚うかびぬ、身にこむる薫も深し波がくれ。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、自分は本当に好きな人とそうすると、しまいにこむらがえりを起す癖があるのだと説明した。",
              "citation": {
                "source": "七日七夜",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
