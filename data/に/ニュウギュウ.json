        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一つの乳牛に消化不良なのがあって、今井獣医の来たのは井戸ばたに夕日の影の薄いころであった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "小麦が安くなったので、乳牛を飼い始め、一八八五年に十二頭だったのが一九一九年レーリーの死んだ年には八〇〇頭の牝牛と六十人の搾乳夫が居た。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳牛のいる牧場は信子の好きなものだった。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "木戸を開けて道に出ると、収穫小屋の側の日向に群がって眼を細くしながら日の光を浴びていた乳牛が、静かに私たちを目がけて木柵のきわに歩みよってきた。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家畜の宰領をしているラファエレに、現在の頭数を聞いて見たら、乳牛三頭、犢が牝牡各一頭ずつ、馬八頭、（ここ迄は聞かなくても知っている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族には近い知人の二階屋に避難すべきを命じ置き、自分は若い者三人を叱して乳牛の避難にかかった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹部まで水に浸されて引出された乳牛は、どうされると思うのか、右往左往と狂い廻る。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして自分も乳牛に引かるる勢いに駆られて溝へはまった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二頭の乳牛を両腕の下に引据え、奔流を蹴破って目的地に進んだ。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとく二回三回数時間の後全く乳牛の避難を終え、翌日一日分の飼料をも用意し得た。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁水を冒して乳牛を引出し、身もその濁水に没入してはもはや水との争闘である。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "来て見れば乳牛の近くに若者たちもいず、わが乳牛は多くは安臥して食み返しをやっておった。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十頭の乳牛を二回に牽くとすれば、十人の人を要するのである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は勢い込んで乳牛の所在地へ集った。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は駅員の集合してる所に到って、かねて避難している乳牛を引上げるについてここより本所停車場までの線路の通行を許してくれと乞うた。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳牛は露天に立って雨たたきにされている。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが財産の主脳であるところの乳牛が、雨に濡れて露天に立っているのは考えるに堪えない苦しみである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳量が恢復せないで、妊孕の期を失えば、乳牛も乳牛の価格を保てないのである。",
              "citation": {
                "source": "水害雑録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛疫の牛というのは黒毛の牝牛赤｜白斑の乳牛である。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族には近い知人の二階屋に避難すべきを命じ置き、自分は若い者三人を叱して乳牛の避難にかゝつた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹部まで水に浸されて引出された乳牛は、どうされると思ふのか、右往左往と狂ひ廻る。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして自分も乳牛に引かるゝ勢に驅られて溝へはまつた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二頭の乳牛を兩腕の下に引据ゑ、奔流を蹴破つて目的地に進んだ。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯の如く二回三回數時間の後全く乳牛の避難を終へ、翌日一日分の飼料をも用意し得た。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "濁水を冒して乳牛を引出し、身も其濁水に沒入しては最早水との爭鬪である。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "來て見れば乳牛の近くに若者達も居ず、我が乳牛は多くは安臥して食み返しをやつて居つた。",
              "citation": {
                "source": "水害雜録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
