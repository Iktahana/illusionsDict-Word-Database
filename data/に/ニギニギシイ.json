          "literary": [
            {
              "text": "見送りの百姓達で家の表、賑々しい。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "明方の翼に稍ほのあかく染められた彼方の山の頂きを眼ざして、月の白光の波のまにまに打ちつづく私の眼界に現れる大行列は、ガスコンと唐松の崇神者連をごつちやにして、世にも怪奇瑰麗な賑々しい騒ぎであつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも頗る賑々しい事であった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんという賑々しい人だろう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "鈴慕の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
