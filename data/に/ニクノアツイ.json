[
  {
    "uuid": "095d9106-32cc-5bae-8b01-81848679e981",
    "entry": "肉の厚い",
    "reading": {
      "primary": "にくのあつい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
