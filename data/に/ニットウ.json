[
  {
    "uuid": "6cc4ed1f-9e54-56ef-802a-d923516d9d83",
    "entry": "日当",
    "reading": {
      "primary": "にっとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
