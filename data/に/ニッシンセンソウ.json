[
  {
    "uuid": "4d7c76d6-cc6b-537b-bb4e-d521f69faeb4",
    "entry": "日清戦争",
    "reading": {
      "primary": "にっしんせんそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
