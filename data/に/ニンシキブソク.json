[
  {
    "uuid": "62b75971-2ec7-5c62-958f-08dc577171b9",
    "entry": "認識不足",
    "reading": {
      "primary": "にんしきぶそく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
