    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese-language education (for non-native speakers)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
