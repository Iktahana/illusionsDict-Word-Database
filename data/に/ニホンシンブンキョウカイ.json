        "examples": {
          "standard": [
            {
              "text": "日本新聞協会は、新聞の公共的使命と自由な言論活動を推進している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はジャーナリズムを志し、将来は日本新聞協会に貢献したいと考えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本新聞協会が毎年発表する新聞広告賞は、広告業界で注目される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "日本新聞会（統制会）は戦時中すでに解消して日本新聞公社となり、終戦後日本新聞聯盟となり、現に日本新聞協会として存在しているのであるが、この両者の間には次の如き明確な差異があるのである。",
              "citation": {
                "source": "日本出版協会論",
                "author": "嶋中雄作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本放送協会が唯一のものだから権威があるというなら、日本の大新聞はどれも之も本質的には同じ記事しか載せないのだから、つまり日本新聞協会が唯一のものだと考えれば済む訳だ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
