        "examples": {
          "standard": [
            {
              "text": "日本語族に属する言語は、日本語と琉球語である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "言語学の授業で、日本語族の起源について議論した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本語族の言語は、文法構造や語彙に多くの共通点が見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "私の早合点でなければ、日本語族に古代から屡現れて力を逞しくしてゐる、感動語の類に列ねてよいものが、かう言ふ風に屡、語中・語間に姿を表すことがあるのでないか、と考へてゐられたのではないか――、と想像を許して貰つてゐる。",
              "citation": {
                "source": "「さうや　さかいに」",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
