  {
    "uuid": "aefe7055-30c9-5af0-9ee6-869dba694bfe",
    "entry": "ニッサン",
    "reading": {
      "primary": "ニッサン",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Nissan (Japanese car company)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "展示されるのは、フォルクスワーゲン、ニッサン、そしてルノーだ。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "例年のニッサン石鹸の貸切で、石鹸一箱呉れた、それだけの礼でマチネーをやるつまらなさ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹話術のオッサン人形で「アノネニッサン」とやって世辞る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜はニッサンの社員で階下二円席は貸切である。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダットサンを借りたニッサンの新井といふ人を、ホテルのグリルへ招き、夕食をする。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時半に出て、銀座コロムバンへ、ニッサンの新井氏と会ひ、三時半、小松理髪店へ、ふき代へに使ってる平野来り、同じやうに刈り込む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月二十九日（火曜）　十二時にニッサンの常務取締役芦田氏の招待で、丸の内の常盤家へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニッサン本社へ寄り、借りる車のこと相談して、それから三昧堂へ寄り、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニッサンより拝借のダットサンが、高槻と共に到着したが、ロードスターで一人っか乗れない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月二十一日（土曜）　今日は又臨時マチネー、森永についでニッサン石鹸と来た。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハネ後、ニッサンの芦田さんと樋口・中島を赤坂長谷川へ招待する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
