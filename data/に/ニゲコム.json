    "definitions": [
      {
        "index": 1,
        "gloss": "to take refuge in",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山は雨のために白く煙り、雉、山鳥があちこちから、ぱつぱつと飛び立つて矢のやうに早く、雨を避けようとして林の中に逃げ込む。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹嫌がって茶店の奥へ逃げ込む。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急速にＦ・Ｏ）Ｓ＝同じ神社の表　団九郎、逃げ込む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）６２＝（Ｆ・Ｉ）舟宿於加田の表――　浪之助に連れられたお類が逃げ込む。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）62＝（Ｆ・Ｉ）舟宿於加田の表――　浪之助に連れられたお類が逃げ込む。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎……貴様らが上海の本部へ逃げ込む序に門司から此地方へ道草を喰いに入り込んだのを聞くと、直ぐに手配していたんだぞ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中に逃げ込むニンフのようなファニーを追いつめて後ろから抱きすくめた私はバッカスのようだった。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は、もともと無頓着なお方でございましたけれども、このおびただしい汗には困惑しちゃいまして、ついに一軒のビヤホールに逃げ込むことに致しました。",
              "citation": {
                "source": "愛と美について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘たちは泣き顔になって奥へ逃げ込む。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の下から出て来て、縁側へ飛びあがって、再び縁の下へ逃げ込む。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の鳴き声を聞くと同時に槍をほうり出しておいて奥の間に逃げ込むのではあったが。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伸子はその向こう側の光景に驚かされて、電柱のかげへ逃げ込むようにして廻った。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "パウサニアスに月女神浪人都を立てんとする者に教え兎が逃げ込む林中に創立せしめた譚を載す。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　そんな嘘をついて、時には、さもさもほんとうに腹でも痛いかのやうに苦悶の態で脇腹をおさへ、顔を歪めながら自分の部屋に逃げ込むと、恰で盗人のやうにあたりの気合を気遣ひながら慌てゝ仕度を整へ、一目散に森の中の決闘場へ駆け込むのである。",
              "citation": {
                "source": "読書と生活",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてて店へ逃げ込む途端に、大きい稲妻が一つ光った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雷獣と蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "船のなかへ逃げ込むのもあった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "海坊主",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一刹那に、かれの胸に泛んだのは、これから自分の館へむかって走るよりも、兄の師冬の館に逃げ込む方が路順も好い距離も近い。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はもう到底食堂へ顔を出す勇気はなかつたので、四階の自室へ逃げ込むと中から錠をおろして、ベツドへもぐり込んでしまつた。",
              "citation": {
                "source": "女に臆病な男",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは木の蔭へまた逃げ込む。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "となりは仏殿であるので、さあといったらそこへ逃げ込むつもりで、寝床の帳をかかげて窺っていると、棺のなかの鬼も蓋をあげてこちらを窺っているのでござります。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長城を築く、長城を築く」　その声を聞くと、かれらは狼狽して山奥へ逃げ込むという。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は此処こそ暗い横丁だらうと思つて逃げ込むと、其処にはペンキ塗りのバーやカフエーが軒をそろえて客を招んでゐる。",
              "citation": {
                "source": "鱗雲",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "（能因はあわてゝ奧に逃げ込む。",
              "citation": {
                "source": "能因法師",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お尋ね者にとっては安全区域、ここへ逃げ込むと目つからない。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし動いて逃げるとすれば、河へ飛び込むか再び路へ出て向う側の露路へ逃げ込むかのどちらかだった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ばかり前に、往診から戻って来た彼は、人力車を降りるなり、逃げ込むように、玄関の隣りにある診察室へ入ると、その儘室内をあちこち歩いて深い物思いに沈むのであった。",
              "citation": {
                "source": "初往診",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊に追われたとしても、自分の作ったものなら、そこへ逃げ込むのも可笑しいし、第一ドンデン返しにならんように鍵でも懸けて置きそうなものじゃないか。",
              "citation": {
                "source": "人間灰",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸木は森の中ににげこむ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭かきかき　市長のいうにゃ、『でんでんででむしではあるまいし、智慧だせだせと　せめつけられても、無い智慧出されぬ　面目ござらぬ、にげこむねずみの　穴ほしや。",
              "citation": {
                "source": "魔法の笛",
                "author": "ロバアト・ブラウニング",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし、　飛びかかろうとしたら　向こうは　黄ばんだ　歯を　こっちに　ひんむいて　穴に　さっと　にげこむんだから。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
