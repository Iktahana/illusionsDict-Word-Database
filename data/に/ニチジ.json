[
  {
    "uuid": "c12b9588-6aa9-5852-b844-6bcfca93d5d2",
    "entry": "日時",
    "reading": {
      "primary": "にちじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
