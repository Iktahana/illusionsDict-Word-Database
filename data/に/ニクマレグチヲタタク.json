          "literary": [
            {
              "text": "弟子達が大掾について浄瑠璃の稽古をする時は、婆さんはいつもちよこなんと側に坐つて、横合からさんざ憎まれ口を叩く。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あにを、憎まれ口を叩くでい！",
              "citation": {
                "source": "妻恋行",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやほっとしたので、憎まれ口を叩く元気も出たのだろう。",
              "citation": {
                "source": "如何なる星の下に",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お爺さん、御託はそれでおしまいかね」　彼はやっぱり地の底からの様な声で、憎まれ口を叩くのだ。",
              "citation": {
                "source": "妖虫",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
