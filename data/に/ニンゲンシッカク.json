        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「人間失格」という題にするつもりである。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて、いまは不吉な敵国の言葉になったが、パラダイス・ロストをもじって、まあ「人間失格」とでもいうような気持でそんな題をつけたのであって、その日記形式の小説の十一月一日のところに左のような文章がある。",
              "citation": {
                "source": "鉄面皮",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間失格、あたりまえのことである。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――彼はその頃、「展望」に連載する小説「人間失格」にとりかかっていた。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は後に「人間失格」を読んで、あれに覗き出してる暗い影に心打たれた。",
              "citation": {
                "source": "太宰治との一日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "学者などのうちにはほとんど人間失格者のごとき人がある。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに、世俗の人がややもすれば学者をぼんやりした人間失格者のごとくいう。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる風あるものは人間失格者としか思われぬ。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度出るのは、「櫻桃」・「人間失格」、それに「ヴィヨンの妻」――皆故人の名を、その時々に、一段づゝせりあげた作物である。",
              "citation": {
                "source": "水中の友",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヴィヨンの妻」や「人間失格」も、かう言ふ範疇に入れて、私は見てゐた。",
              "citation": {
                "source": "水中の友",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰は、十三の数をひねくったり、人間失格、グッドバイと時間をかけて筋をたて、筋書き通りにやりながら、結局、舞台の上ではなく、フツカヨイ的に死んでしまった。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間失格」「グッドバイ」「十三」なんて、いやらしい、ゲッ。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "太宰が死にそこなって、生きかえったら、いずれはフツカヨイ的に赤面逆上、大混乱、苦悶のアゲク、「人間失格」「グッドバイ」自殺、イヤらしい、ゲッ、そういうものを書いたにきまっている。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかく、人間失格、グッドバイ、それで自殺、まア、それとなく筋は立てゝおいたのだろう。",
              "citation": {
                "source": "不良少年とキリスト",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "千万人の若者が戦地で苦労してるとき、たった一人、戦争もできなかったあなたは、そのことだけでも人間失格よ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間失格、第二の手記まで脱稿。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十四日　「人間失格」いつもの通り五枚御執筆。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく太宰さんの頬に肉づいてきて、やれうれしやと思いつつ帰京いたしましたのに、またまた編集者の訪問責めに逢いまして、このごろは空しく搾り去られてしまいましたけれど、これというほどのこともなく、人間失格の第三の手記にとりかかっておられます。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間失格の第三の手記を執筆なさるためのカンヅメ。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間失格も、熱海で初執筆してから――（二十日間、百五十枚）。",
              "citation": {
                "source": "雨の玉川心中",
                "author": "太宰治との愛と死のノート",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
