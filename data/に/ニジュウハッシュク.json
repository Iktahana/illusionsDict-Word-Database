    "definitions": [
      {
        "index": 1,
        "gloss": "28 mansions of Chinese astronomy (constellations dividing the ecliptic into 28 positions)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
