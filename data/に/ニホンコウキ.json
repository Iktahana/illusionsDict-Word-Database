    "definitions": [
      {
        "index": 1,
        "gloss": "Nihon Kōki (third of the six classical Japanese history texts)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
