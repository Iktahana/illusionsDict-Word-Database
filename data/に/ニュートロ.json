        "examples": {
          "standard": [
            {
              "text": "レトロなアイテムに現代的なエッセンスを加えた、ニュートロファッションが若者の間で人気だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女はニュートロなカフェで、友人と昔のアイドルの話で盛り上がった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「このカメラ、ちょっとニュートロなデザインで可愛いね」と、友人が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そしてこの場合の畢極の個体は、広義に於けるアトム（エレクトロン・ニュートロン・ポジトロン・等々）である。",
              "citation": {
                "source": "科学論",
                "author": "戸坂潤",
