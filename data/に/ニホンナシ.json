      {
        "index": 1,
        "gloss": "Japanese pear (Pyrus pyrifolia)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
