          "literary": [
            {
              "text": "篠は東隣の主人から請うて苦竹に交つたのを後の林から伐つたのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は本陣の裏木戸から、隣家の伏見屋の酒蔵について、暗いほど茂った苦竹と淡竹の藪の横へ出た。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "第十図　次にマダケすなわち苦竹の花を示さん。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "竹といっても中々沢山な種類がありますが、まずその中で淡竹と苦竹とが大関です。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
