    "definitions": [
      {
        "index": 1,
        "gloss": "natural voice (without a microphone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
