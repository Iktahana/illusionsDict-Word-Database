        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ヘルンはその妻と共に、姑の老婦人と一家に同居し、純日本風の仕方でよく孝養の道を尽した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姑の婦人もまた、旧武士の家庭に育った士族の娘で、純日本風の礼儀正しき教育を受け、かつ極めて善良に優しい心根の人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの生活様式は、全く純日本風であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "）住居は度々変ったが、純日本風の家を好んで、少しでも洋風を加味したものを嫌った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昔思ふ草の庵の夜の雨に涙なそへそ山ほととぎす」これは「盧山雨声草庵中」といふ句のある白楽天の漢詩を日本風に訳したものだと言ふ。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは『日本風景論』の著者志賀｜重昂先生で、この一文から、私という人間に目をとめられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも日本風の鬘をかぶって、日本の衣裳を着ています。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手の日本風のお庭に向って一面に硝子障子がはまった廊下へ出て、左側の取っ付きの西洋間の白い扉を開くと妻木君は先に立って這入った。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「奥さんは日本風の顔立ちのおとなしい美人でしょう、妹さんは違いますね。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純粋の日本風でというので結婚式は大神宮の神式で行われた。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "急坂に添つた石垣の上の芝土手（築地と歌には言つたが、日本風のそれではなく、洋風の芝の土手である。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "握手するのかと思って手を出しかけたが、向うは純日本風で挨拶したので、こちらも差し控えた。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋は日本風であるが海に向つて開いた玄関、廊下、翼家の欄間には流石に紅や黄の窓硝子が箝められ、庭の隅々にはまた紅い松葉菊を咲かしてあるといふ風に、如何にも異国趣味の瀟洒な住宅であつた。",
              "citation": {
                "source": "雲母集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根はトタンでふいて、三方は日本風の板羽目になっていたが、そのひどく破損しているのが高谷君の眼についた。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "書道に於ても、空海、道真と、次第に唐風を捨てて日本風となり、道風に至つて、上代風といふわが国独得の書風が完成された。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "世に丸の嘘はないもので、加藤｜咄堂君の『日本風俗志』中巻に、『伊豆日記』を引いていわく、八丈の島人女を恋うても物書かねば文贈らず、小さく作った草履を色々の染糸を添えたる紙にて包み贈る。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつ日本の醜業婦の露人に落籍されるものが益々多く、中には案外なる上流階級の主婦となるものさえあって、これがために日本風の生活が露人間に流行し、日本品でなければ上等でないように思うものが段々｜殖えて来た。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋風、支那風、日本風のあらゆる意味で堕落腐敗し糜爛して行きつつある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何うかして彼れの愁傷を取り消したいと願いながら、当惑した眼を彼れの枕元へと落した時、半ば広げられた鼡色の風呂敷の中に、不図一枚の絵画と一本の日本風な横笛とを発見した。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事も日本風を好みまして、万事日本風に日本風にと近づいて参りました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く日本風の家で、あたりに西洋風の家さえありませんでした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ万事、日本風にと云うのでした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事日本風に造りました。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
