    "definitions": [
      {
        "index": 1,
        "gloss": "observance of the Buddha's teachings",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
