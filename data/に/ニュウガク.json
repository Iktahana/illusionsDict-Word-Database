    "definitions": [
      {
        "index": 1,
        "gloss": "admission (to a school or university)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は今年七ツになる、先達小学校に入学したばかりだつた。",
              "citation": {
                "source": "良子",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今朝もＭのおつ父さんに会つたがね、あれはお前が入学当時の成績のことを思つて、あなたのお子さんはよくお出来でつて挨拶をしたが私は冷汗が出た。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳かな入学宣誓式が行われて、自分も大勢の新入生の中にまき込まれて大講堂へ這入ったが、様子が分らないのでまごまごしていると、中に一人物馴れた日本人が居ていろいろ注意してくれて助かった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入学証書と云ったような幅一尺五寸｜長二尺ほどの紙に大きな活字で皇帝や総長の名を黒々と印刷したものを貰ったが文句はラテン語で何の事か分らない、見ていると気の遠くなるようなものであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからもう一枚哲学部長の署名のあるこれもラテン語の入学免状を貰った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "式の前であったか後であったか忘れたが、大学の玄関をはいって右側の事務室でいろいろの入学手続をすませた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本高等学校に入学した年の冬の休みに長崎から佐世保へかけての見学をした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく彼はチューリヒのポリテキニクムへ入学して数学と物理学を修める目的でスイスへやって来た。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでチューリヒのポリテキニクムの師範科のような部門へ入学して十七歳から二十一歳まで勉強した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それでは大学入学の資格はどうしてきめるかとの問に対して、「偶然に支配されるような火の試練でなく、一体の成績によればいい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一高等学校を経て東京帝国工科大学造船学科へ入学し、明治三十三年卒業した。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴族の子弟であるので、Fellow Commoner として入学した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争でなくても、これだけの心尽くしの布片を着込んで出で立って行けば、勝負事なら勝味が付くだろうし、例えば入学試験でもきっと成績が一割方よくなるであろう。",
              "citation": {
                "source": "千人針",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ついにおしかには無断で、二里ばかり向うの町へ入学試験を受けに行った。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を出ると、再び殆んど無断で、高商へ学校からの推薦で入学してしまった。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長男が中学へ入学したときに父兄として呼び出されて行った。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "県立中学に多分合格しているだろうが、若し駄目だったら、私立中学の入学試験を受けるために、成績が分るまで子供は帰らせずに、引きとめている。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日たって、県立中学に合格したという通知が来たが、入学させなかった。",
              "citation": {
                "source": "電報",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月六日　月今日は入学｜式だった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、私を何所へ遣ったものでしょうと家でもって先生に伺うと、御茶の水の師範学校付属小学校に入るが宜かろうというので、それへ入学させられました。",
              "citation": {
                "source": "少年時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紹介者に連れて行って貰って、些少の束修――金員でも品物でもを献納して、そして叩頭して御願い申せば、直ちに其の日から生徒になれた訳で、例の世話焼をして呉れる先輩が宿所姓名を登門簿へ記入する、それで入学は済んだ訳なのです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昔ある場所の入学試験の問題として、音波と光波の見かけの上の回折の差を証明する事を求めたが、正解らしい要点に触れたものはまれであった。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろは中学や高等学校の入学がだいぶ困難になって来たが、それでも一度入学さえすればとにかく無事にせり上がって行くのが通例である。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が高等学校入学とともに郷里を離れ、そうして夏休みに帰省して見るたびに、目立ってそれが大きくなっているのであった。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいてい死んだであろうと思われていたむすこが無事に帰ったとか、それほどでなくとも、心配していた子供の入学試験がうまく通ったというのでもやはり緊張のゆるむ瞬間に涙が出るのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これでよく、大学なんかへ入学できたものだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると入学試験の前夜のような、ときめきを幽かに感ずるのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはこの内部を入学式のとき、ただいちど見た。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
