        "examples": {
          "standard": [
            {
              "text": "毎晩欠かさずニュース番組を見て、国内外の情勢を把握している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "子供向けのニュース番組は、難しい社会問題を分かりやすく説明してくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねえ、今日のニュース番組、何か面白いこと言ってた？」と妻が尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ＷＨＫ局のニュース番組のコマーシャルに続いて、歌はホンデルズの『リトル・ホンダ』だった。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、この手を使えば短いニュース番組の中にシェイクスピアのソネットを三分間流すことができ、その際、少なくとも私の耳には大した違和感がなくてすむ。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
