    "definitions": [
      {
        "index": 1,
        "gloss": "boiled drinking water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
