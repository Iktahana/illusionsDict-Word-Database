        "examples": {
          "standard": [
            {
              "text": "このシステムは、複数の入力方式に対応しており、ユーザーが選択できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "異なる入力方式のデバイスを組み合わせることで、より多様な操作が可能になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "政府は、高齢者にも使いやすい新しい入力方式の導入を検討している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "大型コンピューターの代表的な入力方式である、パンチカード。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣ―１００に添付されたＭＳ―ＤＯＳも新しい２・０版であり、ＰＣ―９８０１Ｆのものと同様にローマ字と仮名の双方の入力方式に対応した漢字変換機能を組み込んであった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
