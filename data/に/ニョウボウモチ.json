        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六　秋から冬にかけてのことだったが、銀子は女房持ちの若林に、何かしら飽き足りないものを感じ、折にふれてそれを言い出しでもすると、若林は一言のもとに排け、金で面倒を見てやっていれば、それで文句はないはずだというふうだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしに稚気もあって、女房持ちになってから兎角家にこびりつく、つまり野暮だと言われ度くないために仲間の交際いは出来るだけ勤めたい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ぢや、お前さんはもう女房持ちだから。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何故といつて、奥さん、女房持ちの男が怖がるのは、たつた一人の女ですが、独身者は女全体を恐ろしがるんですからね。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は女房持ちであった。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房持ちの男のところへ来たことが、悔いられた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら女房持ちになったって、こんな風な一向変らない私を知って、さぞ君は嬉しがってくれることだろうな？",
              "citation": {
                "source": "卜居",
                "author": "津村信夫に",
                "note": "青空文庫"
              }
            },
            {
              "text": "「和助は好い男だったから、方々へ罪を作ったことと思っていたが、女房持ちとは知らなかった」「そんな事はどうでもようございます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "三千両異変",
                "note": "青空文庫"
              }
            },
            {
              "text": "――尤も女房持ちといふことだが」「深川にお神さんが住んでゐるさうですが、もとは藝人だつたやうで。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の祕薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "山三郎は女房持ちだと言ったな」　平次は問いを挟みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の外の櫻を眺めながら、從兄妹同士ではあるにしても、女房持ちの眞太郎を、自分の部屋に呼ぶ態度は容易ではありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "花嫁の幻想",
                "note": "青空文庫"
              }
            },
            {
              "text": "才八より少し老けて見える、同じ中年者ですが、女房持ちで通ひで、遊び癖のひどい才八に比べると、ひどく地味な男です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "影法師",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の如き独身者は稀れで、女房持ちの方が多かった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも久美子はやはり、女房持ちの男よりも、独身男に共感と関心を持つんじゃないかしら。",
              "citation": {
                "source": "Ｓの背中",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "山三郎は女房持ちだと言つたな」　平次は問ひを挾みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "お六の役目",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんた女房持ちだなんて嘘でしょ、と女が手を動かしながら云った。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房持ちだよ、と参太が答えた。",
              "citation": {
                "source": "おさん",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「木内さんはさっき、女房持ちだって云ったようだな」と房二郎がきいた、「ああ、門前仲町の飲み屋でだ、ほんとかい」「それが問題さ」　寒い風が吹いていて、灯の見えない街を、二人はもつれあうように歩いていた。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房持ちなのもたしかに俺を、疑惑の眼から救ってくれるのに大いに役立った。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日一日で、俺もくすぶった女房持ちの群れに入るのだ。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――女房持ちになる前に」　襖があいた。",
              "citation": {
                "source": "松のや露八",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄弟三人中、女房持ちは長兄の彼一人らしい。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
