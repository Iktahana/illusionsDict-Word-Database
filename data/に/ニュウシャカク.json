        "examples": {
          "standard": [
            {
              "text": "反射の法則によれば、光の入射角と反射角は常に等しくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "水槽の壁に対するレーザーの入射角を大きくしていくと、ある一点で全反射が起きた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "太陽光パネルの効率を最大にするため、季節に合わせて入射角を調整している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "反射角と入射角と等しいという意味の言葉もある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は屍体に喰い込んだ弾丸の入射角を正確に測ろうなどとは毛頭考えたことがなかった。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車の速度をベクトルで書くと、こうなります、弾丸の速度はこうです……」と笹木光吉は、三角｜定規を組合わしたような線を、紙の上に引いてみせて、「これが弾丸の入射角です。",
              "citation": {
                "source": "省線電車の射撃手",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
