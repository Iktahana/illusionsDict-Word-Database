[
  {
    "uuid": "82e9cdab-9e86-536d-89a8-c98a7b9db147",
    "entry": "日本市場",
    "reading": {
      "primary": "にほんしじょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
