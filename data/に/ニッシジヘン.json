    "definitions": [
      {
        "index": 1,
        "gloss": "Second Sino-Japanese War (1937-1945)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
