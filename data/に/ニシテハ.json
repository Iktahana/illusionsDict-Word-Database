    "definitions": [
      {
        "index": 1,
        "gloss": "for (e.g. \"she dances well for an eight-year old\")",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
