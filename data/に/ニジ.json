    "definitions": [
      {
        "index": 1,
        "gloss": "two characters",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どこからともなく〔約二字分空白〕番の声があがりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき汽車のずうっとうしろの方からあの聞きなれた〔約二字分空白〕番の讃美歌のふしが聞えてきました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと思うとまた下の二字を一様に汚して上の二字は綺麗に保存しているのもある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十二字三字四字から二十五字六字というのがあるかと思うと三十四字五字というのもある。",
              "citation": {
                "source": "俳句の型式とその進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概やっと一字、せいぜいで二字くらいしか読めない。",
              "citation": {
                "source": "浅草紙",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "請負の〔二字分空白〕さんも居るだらう。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬軍港を内臟してゐる　北川冬彦のこのやうな詩になつて來ると、軍港といふ二字が既にもう軍港のヴイジョンを伴ふのである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文徳実録に見える席田郡の妖巫の、その霊｜転行して心を心の二字が祇尼法らしいから、随分と索隠行怪の徒には輾転伝受されていたのだろうと思われる。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "那耶、揚州銅器多」から出たので、得董の音は骨董二字の原だ、といっている。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "灼然として雲を駆って白日を見る如し、といふ語の駆雲の二字の如きは、我が邦の歌の中には見がたきものなるべし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「五年生の人は読本の（二字空白）ページの（二字空白）課をひらいて声をたてないで読めるだけ読んでごらんなさい。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一郎さんは読本の（二字空白）ページをしらべてやはり知らない字を書き抜いてください。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今些と平とう言うてみい」「その歌の中の謎が二字ばかり足りません。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらず、いかで自殺なる二字をもってこの二人の怪しき挙動の秘密を解き得べきぞ、貴嬢がいわゆる人とは自ら生きんことを計り自ら死なんことを謀る動物なるべし、この二つの一つを出でざる動物なるべし。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉ちょう二字は二郎が旧歓の夢を呼び起こしけん、夢みるごときまなざし遠く窓外の白雲をながめてありしが静かに眼を閉じて手を組み、膝を重ねたり。",
              "citation": {
                "source": "おとずれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "騎兵ゆき過ぎんとして、後なる馬上の、年若き人、言葉に力を入れ『……に候間至急、「至急」という二字は必ず加えざるべからず』と言うや、前なる騎兵、『無論、無論……』と答えつ、青年の耳たてし時は二騎の姿すでに木立ちにかくれて笑う声のみ高く聞こえたり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "人はあまりにたやすく永久の二字を口にす。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐ろし二字、厳かなる二字、人を生かし人を殺す二字。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど死という一字は人容易に近づきて深く感ずるを得ずといえども、別れの一字は人々の日々親しく感ずるがゆえに、もし人、この一字に永久の二字を加えて静かに思いきわめなばその胸さけん。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語がまだ初歩なのに仏語をちゃんぽんに教わっては不利益だという理由であったが、実際はその教師となるべき青年が近隣で不良の二字をかぶらせた青年であるがためだということが後にわかって来た。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（名まで辛抱は出来まいが、一字や二字は堪えて見せよう。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "横額に二字、たしか（勤儉）とかあつて（彦左衞門）として、圓の中に、朱で（大久保）と云ふ印がある。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」で、局で、局待と言ふと、局員が字數を算へて、局待には二字分の符號がいる。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の降る日（兄のうたへる）萩原朔太郎雨の降る日の縁端にわが弟はめんこ打つめんこの繪具うす青くいつもにじめる指のさき兄も哀しくなりにけり雨の降る日のつれづれに客間の隅でひそひそとわが妹のひとり言なにが悲しく羽根ぶとん力いつぱい抱きしめる兄も泣きたくなりにけり",
              "citation": {
                "source": "雨の降る日",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貧しい生活の中にいて、静かにじっと凝視めている心の影。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『いやにじれつたいな、何うにも、恁うにも、恐かないなら、手を地べたに着いて謝罪んねえ、そこへ坐つて、チエツ、意氣地のない青二才だ』「カツ」と痰を吐いたのが、胸の處へベツタリ絡みつく。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗いランプの光で寒竹の皮をむきながら美しい絵を思い浮べて、淋しい母の横顔を見ていたら急に心細いような気が胸に吹き入って睫毛に涙がにじんだ。",
              "citation": {
                "source": "森の絵",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツ語がよく分らなくては講義を聴くのに困りはしないかと聞くから、なにじきに上手になりますと答えたら Na ! Sehen Sie mal zu. と云ってにやにやした。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの、黒檀で彫刻した鬼の面とでも云ったような感じのする外殻を噛み破ると中には真白な果肉があって、その周囲にはほのかな紫色がにじんでいたように覚えている。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんなにじやんじやん水を注ぎ込まれちや、處置に窮しますよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
