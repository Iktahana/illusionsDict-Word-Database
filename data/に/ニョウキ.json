        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "死ぬにしてもそんなに早く死ぬとは思つてゐなかつたし、案外癒るのだらうとさへ思つてゐた私は、『尿器をとつてくれ』といふ弟の声が、余りにも弱々しい時には腹さへ立てた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光栄の失敗の五年の後、やはり私の一友人おなじ病いで入院していて、そのころのおれは、巧言令色の徳を信じていたので、一時間ほど、かの友人の背中さすって、尿器の世話、将来一点の微光をさえともしてやった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尿器ですか」「イヤ。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝床の周囲には祈り本、聖書、辞書、雑誌、原稿紙、夏みかんの皮、土びん、薬袋、手紙、鉛筆が雑然と席を占め、その真ん中に、尿器が昼寝している。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず一室内八人室に、洗面器、コップ、尿器、各一個よりほか備えてない。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中は一個の尿器に八人分をたくわえるから、これまた大変だ。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台の毛布は外れているし尿は尿器にみちているし、湯たんぽの湯は冷えていた。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "井荻看護婦は例によって少しも私の苦痛には味方をしないで、尿量にこだわってこれを計ることを怠らない、彼女は尿器の目盛りをすかして見ては日誌に書き込み、はばかりでなさらないようにと注意して言った。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い偉大なる尿器の前にそれを行うた時、私は無心であった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時は苦しかったがもう私は治ったという言葉を頭にうかべたが、それは尿器に対う前のほんのちょっとした時間のあいだにうかべた数行であった。",
              "citation": {
                "source": "われはうたえども　やぶれかぶれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度泌尿器科の講義だった。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "八日　晴一時濃煙霧後晴泌尿器科Ｋ教授の往診を受ける。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
