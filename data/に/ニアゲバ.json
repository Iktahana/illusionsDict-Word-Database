          "literary": [
            {
              "text": "これは、五ツ目からこの姿のままで茶舟に搭せられ、大河を遡って枕橋へ着き、下金屋の庭が荷揚げ場になっているから、直ぐ其所へ引き揚げたものである。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "蠑螺堂百観音の成り行き",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉の荷揚げ場へ行きゃ、舟もはしごも掃くほどあるはずだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、構内の掘割には、荷揚げ場もあり、船倉もあった。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
