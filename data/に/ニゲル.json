    "definitions": [
      {
        "index": 1,
        "gloss": "to run away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」そしてあわただしく逃げるやうに歸つて行つた。",
              "citation": {
                "source": "芥川君との交際について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆汁なんかをたくらんだのは大いに惡いが、しかし、このごろの繪本のやうに、逃げるついでに婆さんを引掻いて怪我させたくらゐの事は、狸もその時は必死の努力で、謂はば正當防衞のために無我夢中であがいて、意識せずに婆さんに怪我を與へたのかも知れないし、それはそんなに憎むべき罪でも無いやうに思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "待ってる方は痺れを切らしても、逃げると云う事はないからね。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、一体、馴れた坑夫は、そんなに逃げるように慌てて、駈けはしないものだ。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は柚木が逃げる度に、柚木に尊敬の念を持って来た。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちの方のものが逃げる、ふん。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に人目を嫌って逃げるものや、夜間のみ出あるく獣の天真の態度はなおさら知り難い。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また人間の眼には見えぬ紫外光線でもよく感じ、この光を当てると嫌って逃げると云っている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その半分、裸のかしわが、クックッと逃げる情景　支那の老婆が日向ぼっこして、麦わら細工を縫み乍ら兵隊の行軍を見ている。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚倉はいち早く逃げる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる伝八郎と浪人たちを追う三四郎。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝夜の町　逃げる三次に追う棚倉等。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを拾って、コソコソと逃げる典六。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝他の道――　逃げる大吉と半次、追う役人との立廻り。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "＝道――大吉と半次の立廻り　半次が一人踏み止まり、大吉は逃げる。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる文六と、追う団九郎。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、こちらの山の傾斜面には、民屋もなにもなく、逃げる道は開かれていると思っていたのに、すぐそこに、六七軒の民屋が雪の下にかくれて控えていた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる奴は射撃した。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして人を頼る気持は犬や猫と同じであるような気がするが、しかしどうしても体躯には触らせまいとして手を出すと逃げる。",
              "citation": {
                "source": "高原",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、相談があるから是非寄ってくれというんで、今度は逃げることもできないで、とうとう師匠の家まで一緒に行きました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "人通りの少ないところを選んで浜町河岸まで揺られてくると、石置き場のまえで彼女を乗物からおろして、空の乗物をかついだ男達は逃げるように何処へか立ち去った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の人質となって多年江戸に住んでいることを余儀なくされた諸大名の奥方や子息たちは、われ先にと逃げるように国許へ引きあげた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "つかまえようとすると、鳩が、一尺か二尺かの際どいところで、敏感に、とび立って逃げる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる男が二人の方へ突進してくる。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　賃銀を渡せば工人は逃げる心配があった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と叫びながら、寄宿舎から逃げるように駆け出してしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何に貧窮なものも、誰一人としてこの逮捕から逃げることは出来ない。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎晩お神明さんの、杉のうしろにかくれていて、来るやつを見ていたそうです、そしていよいよ網を入れて鯉が十｜疋もとれたとき、誰だっこらって出るんでしょう、魚も網も置いたまま一目散に逃げるでしょうバキチは笑ってそいつを持って警察の小使室へ帰るんです。",
              "citation": {
                "source": "バキチの仕事",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝六慌てて「待てッ」船頭の舟逃げる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "逃げる舟を追う右門の舟追っ掛け若干あって、１４＝別の橋の附近　伝六やいのやいの。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            }
          ]
        }
