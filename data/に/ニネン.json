        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "将軍家に於いても、ただ二念なく大君の御鴻恩に感泣し、ひたすら忠義の赤誠を披瀝し奉らん純真無垢のお心から、このやうなお歌をお作りになつたので、なんの御他意も無かつたものと私どもには信ぜられるのでございます。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無時性の散亂心とは、一時に二念も三念もあつて散亂するのだ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人といふものは、一時に二念は懷き得られないものであるから、此の一刹那は碁を思ふ、彼の一刹那は電報を思ふ、といふやうに刹那々々に氣が彼方へ行つたり此方へ來たりする、氣は靜かに一處へ注定する譯には行かぬのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "無時性の散乱心とは、一時に二念も三念もあって散乱するのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人というものは一時に二念は懐けないものだから、此の瞬間は碁を思い彼の瞬間は電報を思って、瞬間、瞬間に気が彼方へ行たり此方へ来たりする、気を静かに一所へ集中できないのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花聟君は彼を愛するに二念無く、彼を遇するに全力を挙げたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡夫なればはらもたち、いつくしきものが、おしい、ほしいとおもう一念がおこるとも、二念をつがず、水にえをかくごとく、あらあさましやと、はらりと思い切り、なに心なくむねん、むそうにしておわし候わば、それこそまことの御心にて候え…………親鸞　そのあたりは清い、涼しい法然様のおこころがよくあらわれている。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しお馨さんの渡米には、二念なく賛同した。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二念珠ということをやりだしたのはこの阿波介である。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "外事に※々として、一日の苟安を偸取せんとする幕府は、ここにおいて異国船を二念なく打払うの令を布けり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗と見たら二念無く打殺せといふのだ。",
              "citation": {
                "source": "天狗塚",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨上りで照々と日が射すのに、薄く一面にねんばりした足許、辷って転ばねば可い。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、実に実にねんごろに説き伏せるのですから、荒武者だつて、鬼ではないのだから、坐り直つて、静かに盃をとるより他はなくなるのです。",
              "citation": {
                "source": "捜語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうおおぜい客が来ていて母上は一人一人にねんごろに一別以来の辞儀をせられる。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "坊やにねんねこ歌を歌ってきかせたのよ。",
              "citation": {
                "source": "少年・春",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さんが一緒にねんねして進げますからネ。",
              "citation": {
                "source": "出発",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなことすると、もう一緒にねんねして進げません」「温順しくして、おねんねするんですよ」と婆やも子供の枕頭に坐って言った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は自分に子供を注意した成程、見れば妻の顏のうしろにねんねこの蔭にしつかりと窮屈な位包れて、枝になつた果實のやうにかつちり引きしまつた小さな顏が、默つて笑つて居た。",
              "citation": {
                "source": "自分は見た",
                "author": "千家元麿",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなぼろ靴をつくろふのにも、ねんにねんを入れるのです。",
              "citation": {
                "source": "太一の靴は世界一",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「れぷろぼす」はこの四十雀のふるまひを、訝しげな眼で眺めて居つたが、やがて又初一念を思ひ起いた顔色で、足もとにつどうた杣たちにねんごろな別をつげてから、再び森の熊笹を踏み開いて、元来たやうにのしのしと、山奥へ独り往んでしまうた。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき法然様はどんなにねんごろに法を説き聞かせなすったろう。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "リンデン　（微笑しながら）ノラさん、あなたはいまだにねんねえですのねえ。",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノラ　（頭を立てゝ室内を歩く）おや／＼、そんなにねんねえ扱ひにするもんぢやありませんわ。",
              "citation": {
                "source": "人形の家",
                "author": "ET DUKKEHJEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きぬけられます」　信頼をこめてそう云って、執ったままいる伸子の手の甲を励ますようにねんごろにたたいた。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "400其時彼にねんごろに苦痛鎭むる藥塗り、癒やせし者は巧妙のパイエーオーン――神のわざ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "照ちやんは蒲團でくるんだ赤ン坊を更にねんねこで負つて表の井戸の水も酌むし板間の雜巾がけもした。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "※星よりきれいな花の數　　泣くとお花が萎むぞえ　　　　泣かずにねん／＼おしなされ　この古風な歌を歌ひ終ると、乳母の呆けた頬には、甘い涙の糸が流れました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "子守唄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちばんいいところでも、岩の上にねんどやおもたい砂利があるくらいのもので、とにかく、見るからにひんじゃくだった。",
              "citation": {
                "source": "ニールスのふしぎな旅",
                "author": "NILS HOLGERSSONS UNDERBARA RESA GENOM SVERIGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "也ちやんはその上にねんねこに包まれたまま眠りつづけてゐた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "その娘が、父の屍を負うて、水面に浮び出ましたので、里の人々は父を思う娘の一念に驚きましたが、この心を憐れに思いまして、岸の辺にねんごろに葬りました。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
