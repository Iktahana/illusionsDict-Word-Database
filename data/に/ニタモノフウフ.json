    "definitions": [
      {
        "index": 1,
        "gloss": "married couple with similar tastes or dispositions",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
