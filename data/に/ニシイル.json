        "examples": {
          "standard": [
            {
              "text": "京都の住所で「室町通御池西入ル」と言えば、室町通と御池通の交差点を西へ曲がった場所だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "目的地はその角を西入ルすぐの左側にあるので、地図を見ればすぐにわかります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「そこを西入ルや。歩いてすぐやで」と、通りすがりの人が丁寧に教えてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "それはカトリック教会の教義を人にしいるものであって、各人が直接神から教えを受けるという人間の基本的自由をそこなうものである。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
