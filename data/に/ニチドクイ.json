        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日独伊防共協定が調印されて、国民精神総動員中央連盟が結成された。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十一巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独伊防共協定も、これが終幕である。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一日が日独伊軍事同盟の記念日だからだ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわれらの祖国は翌昭和十二年の十一月には、日独伊防共協定にまで突入したのであった。",
              "citation": {
                "source": "雪今昔物語",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛亥革命を望見して　大正十一年、彼は、はじめて革新倶楽部に入党して犬養毅の傘下に位置を占める政治的立場を確立したが、それも長続きはせず、彼が外遊より得た確信が、日独伊同盟の理想を念願するようになり、次第にヒトラー、ムッソリーニの人間的影響をつよくうけ入れるようになったことだけは事実であろう。",
              "citation": {
                "source": "叛骨・中野正剛",
                "author": "――主観的な覚え書き",
                "note": "青空文庫"
              }
            },
            {
              "text": "日華事変がおこり、日独伊防共協定がむすばれ、国民精神総動員という名でおこなわれた運動は、寝言にも国の政治に口を出してはならぬことを感じさせた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独伊の協定調印成れりと、大いに明るい気持になった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "川口松太郎来り、ルパンで日独伊防協の祝杯から、川口と劇談数刻。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
