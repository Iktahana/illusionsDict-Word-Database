    "definitions": [
      {
        "index": 1,
        "gloss": "to smile cheerfully",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "毎日朝早く妹のアガアテが部屋に這入って参って、にっこり笑うのでございます。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "『星が見えるよ、』と言って娘は肩をすぼめて、男の顔を見てにっこり笑う。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（弥助、約束したるごとくにっこり笑う）九郎助　ありがてえ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠次　（わが意を得たりというように、にっこり笑う）喜蔵　今度は、喜蔵だ（紙片を見せながら）どうだい。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この頃わたしを見覚えて、顔を見ればにっこり笑うようになった。",
              "citation": {
                "source": "小さきもの",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "二度目に女がにっこり笑うもんだから、妙な笑い方をする女だと思っていると、三度目に、あなた忘れたのと云うたというのです。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし相手は源一の方をむいて、にっこり笑うだけであって、源一の店までやって来て買って行く者はなかった。",
              "citation": {
                "source": "一坪館",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "救われた帆村は、べつにおどろいてもいず、はずれた飛行服の釦をかけて、にっこり笑う。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「阿難は幸せだと思うわ」　阿難はにっこり笑う。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "町角でふりかえると、いつも窓でにっこり笑うおかあさんの顔があり、それが励ましになるのでした。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人を見たという学生の写真をじっと見詰めていたが、やがてにっこり笑うとそれをポケットに押し込んだ。",
              "citation": {
                "source": "鳩つかひ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝九郎はふりかえってにっこり笑うと、走りよる敵兵を一刀に斬りふせて、さっと馬首をめぐらす。",
              "citation": {
                "source": "だんまり伝九",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はレッスン９です」……空チャンネル……小さな男の子がヨーグルトを一口食べ、画面に向かってにっこり笑う……空チャンネル……。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　首をかしげて、にっこり笑う。",
              "citation": {
                "source": "風",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、にっこり笑うと、彼の姿は、奥へ消えて見えなくなりました。",
              "citation": {
                "source": "眼鏡",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら、病床のお京がにっこり笑うて、　――これで、やっと、おマンさんに勝ったわ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのとき、あのお母さんは、にっこり笑うと私は思う。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、ぼくを見て、にっこり笑う。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　名探偵は、そういって、モジャモジャの頭を、指でかきまわしながら、にっこり笑うのでした。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　小林くんはじゅわきをおくと、よこにたって聞いていた明智先生とかおを見あわせて、にっこりわらうのでした。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
