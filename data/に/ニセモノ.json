    "definitions": [
      {
        "index": 1,
        "gloss": "impostor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "男はそのかみ、神武御東征のとき、偽者土蜘蛛と呼ばれ、来目の子等によって征服されて帰順した、一党の裔であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "といったら、考えるまでもなく、それは偽者だというだろうが、なにぶんにも今の時節だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとい偽者であるにもせよ、けさまでわが子と思っていたお元を、このまま直ぐに追い出すに忍びないような弱い気にもなった。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかにお此が弱い気になったからといって、すでに偽者の正体があらわれた以上、それをわが子として養って置くことは出来ない。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論それも外聞にかかわることではあるが、偽者と知らずに連れ込んだというよりはましである。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほん者ばかりでなく偽者もまじってくる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、それがほん者か偽者かよくわからないが、いつでも二人づれで異人の生首を抱えてくる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし偽者の多いことは世間でも大抵知って来たので、単に口さきで嚇したばかりでは睨みが利かないと思って、かれらは真の攘夷家であることを証明するためと、あわせて相手を威嚇するために、異国人の生首をたずさえてゆくことを案出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分はそいつ等をなんだと思います」「偽者かな」「えらい」と、熊蔵は手を拍った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうです、あの若けえ野郎です」「あれは偽者じゃあねえ」「ほんとうの武士でしょうか」「足を見ろ」　武士は常に重い大小をさしているので、自然の結果として左の足が比較的に発達している。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "君が何ういふ仕事をしようとする人物なのか僕は知らないが、そんな類ひの偽者でもなく、また法螺吹きの像ではなかつたことは幸せだつた。",
              "citation": {
                "source": "疑惑の城",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたの鑑定通り、どうでその幽霊は偽者に相違ありませんが、わたくしも最初は甚吉の家の奴らだろうと思っていました。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "最初の幽霊が果して偽者であったことは、おきよと甚右衛門の白状によって確かめられたが、後の幽霊が果して真者であるかないかを、確かめ得るものはなかった。",
              "citation": {
                "source": "真鬼偽鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては偽者かと云うことになったのですが、偽物ならば随分ずうずうしい奴、白昼人殺しをして置いて、かたき討ちだなぞといつわって、自分から辻番所へ届けて出るとは、あまりに人を喰った仕方です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "青山の仇討",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声音までが同じであるので、婿の家も供の者も、どちらが真者であるか偽者であるかを鑑別することが出来なくなった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同時に、この偽者の正体も大かたは判った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽者めが」　斯う仰言って、さっと御座をお立ち遊ばした時のあの御姿の神々しさ、私などはほんとうに有難涙にくれたものでございました。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、私はあの時、敗けて偽者めと仰言られた女が、大勢の人々に罵られながら立って行く有様を見て何となく気の毒に思った事でございます。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかして天一坊を偽者だという証拠を得たい、どうかしてあれが御落胤でないという事を確信したい、斯ういうのが御奉行様の御心持であったに相違ございませぬ。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故と申すに、紀州に遣わされました方々が、天一坊が偽者であるという証拠を得られずに却って真ものであるという証拠を伝えて参りました時の御奉行様の御失望、御苦悩を私ははっきりと思い出す事が出来るからでございます。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "では何故ああ迄、天一坊を偽者とお信じになりたかったのでございましょうか。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御奉行様の御取り計らいで、天一坊は全く偽者なる事に定りましたのでございます。",
              "citation": {
                "source": "殺された天一坊",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "画家や俳人の偽者は、実際絵なり句なりを作らせてみれば看破するのも容易だが、小説家の偽者は、眼の前で小説を作るなどと云ふ御座敷芸のない為に看破しにくいのに違ひない。",
              "citation": {
                "source": "偽者二題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の文芸愛好家は、かう云ふ偽者の毒手にかからないやうに注意して貰ひたいと思つてゐる。",
              "citation": {
                "source": "偽者二題",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けンど、所謂情況証拠ちゅう奴が、大分揃うていますさかい、私はえらい大胆な判断やけど、ひょっとしたら、今の和武は偽者やないかしらんちゅう事を砂山さんに報告しました。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "このおせいさんが、和武に会うて、偽者やったらとっちめてやるちゅうて、諾かはりまへン。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、今の叔父が偽者であるならば、真の叔父は何という数奇な可憐な運命を背負った事であろう。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、然し、野村君、果して今の叔父は偽者だろうか。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、もし彼が偽者だったら。",
              "citation": {
                "source": "黄鳥の嘆き",
                "author": "――二川家殺人事件",
                "note": "青空文庫"
              }
            },
            {
              "text": "病技師〔一〕こよひの闇はあたたかし、　　　風のなかにてなかんなど、ステッキひけりにせものの、　　黒のステッキまたひけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
