    "definitions": [
      {
        "index": 1,
        "gloss": "admission ticket",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれはこの動物にとっては全く飼主の曲馬師から褒美の鮮魚一尾を貰うための労役に過ぎないであろうが、娯楽のために入場券を買ってはいった観客の眼には立派な一つの球技として観賞されるであろう。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ彼の座長演説をやる日に、入場券を持たずに会場へ行って門番と押し問答をやった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この専制君主的な儀礼の門を潜って、ロダンさんが事務所で入場券をお求めになると、妾達はこの悪徳による王国の財政の基礎の中に這入って行ったのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時からはじめますから、入場券をあげて置きましょう。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、狐の幻燈会は十一歳までですよ、入場券に書いてあるんだもの。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入場券はお持ちですか。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから画伯デュラーの住居の跡も見ましたが、そこの入場券が富札になっています。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八時からはじめますから、入場券をあげて置きませう。",
              "citation": {
                "source": "雪渡り",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その開場式を兼ねた第一回の野球試合の入場券が村中に配られた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その入場券を買ってはいると、建物はあまり立派でないが、原住民七分、外国人三分という割合で殆んどいっぱいの大入りであった。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時に、開所後は入場券を売って公衆の観覧を許すという話が出て、五銭の入場券が五百枚売れたら切符売りの月給ぐらいはできそうだというような取りざたをした。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "入場券は半月ほどの間に千七百枚とか売れたそうである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球戦の入場券一枚を手に入れるために前夜からつめかけて秋雨の寒い一夜を明かす勇敢な人たちの話は彼を驚かし感心させた。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生この家と交際してゐる二三軒では、丁度葬の日に芝居の入場券が買つてあつたのに、遠慮して行かなかつた位である。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも岡村は何と思うてか、停車場では入場券まで買うて見送ってくれた。",
              "citation": {
                "source": "浜菊",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうでなければ、あの民衆の部屋にはいる入場券が得られないと思っていたんです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、外套の襟を立てながら急ぎ足で、駅内にはいると、入場券を買ってプラットフォームへ急ぎました。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し私には、その入場券は与えられていない。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸開いて見ると、それは夫人の属するある貴婦人の団体で、催される慈善音楽会の入場券とプログラムであった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "たゞ、それの受取のように、夫人から贈られた慈善音楽会の一葉の入場券が、信一郎の紙入に、何の不思議もなく残っている丈である。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、此の何の奇もない入場券と、『是非お出下さいませ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "入場券は象牙と鉛と二通りあって、いずれも賞牌みたような恰好で、表に模様が打ち出してあったり、彫刻が施してあるということも聞いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はその入場券の価まで知っていた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちの袴を着けた男が入場券を受け取った。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
