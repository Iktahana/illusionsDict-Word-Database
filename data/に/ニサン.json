    "definitions": [
      {
        "index": 1,
        "gloss": "two or three",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（一九三七・九・二三）",
              "citation": {
                "source": "逝ける辻野君",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三丁行くと私の名前をひどく嬉しさうに呼ぶ奴がある、見るとそれは三田村なのだ。",
              "citation": {
                "source": "夏の夜の話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから猶二三の御用聞きが現れたが、そのたんびにその調子であつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（一九三五、三、二三）",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから二三日してからのことであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人美しい女が目にとまつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年私ハ、小サイタライノオ風呂ニ二三日ゴトニ入リマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事も米の飯に味噌汁、野菜の漬物や煮魚を食い、夜は二三合の日本酒を晩酌にたしなんだ。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日二三合の米の飯と、少しばかりの副食物と、二三合の日本酒とさえあれば、それで私の生活は充分であると、その訪問客に語っているヘルンは、実際に学者風の簡易生活をしていたのである。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩餐の時、ヘルンはいつも二三本の日本酒を盃で傾けながら、甚だ上機嫌に朗かだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に詩人といふためには、彼の作品は（その二三のものを除いて）あまりに客觀的、合理觀的、非情熱的、常識主義的でありすぎる。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と緒方氏とは、ほんの二三度話合っただけの間柄ではあるが、よい小説家を、懸命に努力した人間を、よほどの不幸の場所に置いたまま、そのまま死なせてしまったという事実に就いて、かなりの苦痛を感じている。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるさい時代が過ぎて、二三日、ほっとしたと思ったら、また、うるさい時代がやって来ました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして各所で成績を挙げるらしいのだが、無理もない、私も二三度ダマされた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三度、漢文や英語の、受験参考書を携へて出たこともあつたが、重荷となつたばかりであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもし、二三の人々が云ふやうに、現代生活自体が詩に反撥する所のものを有してゐるので詩が不振とならば、短歌・俳句こそ詩よりももつと不振でありさうなものだと考へてみられねばなるまい。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は二三日前、給士を呼んで、色んな学校の裏面に就いて訊ねようとしたのであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それは私に変な癖があるのだが、一度私が矢張広島の頃、父が東京に出張するといつて出る時、私はそれまでは何でもなかつたが、父の俥がいよいよ玄関を出る時急に人生の大切な岐路にでも立たせられたやうな気がして来て、泣く泣く父の俥の後を二三町ばかり泣きながら夢中に追つ駆けたことがあつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はもう二三年前の自分だつたら如何でも神経屋である理由を説かうとした筈である。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "鏡台のある間の二三間ばかり向ふは直ぐに病室だつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前初めて辻氏を訪ねたら貴兄に手紙を出してみるがいゝといはれたので、手紙を書かうとしたのですが、手紙つて奴が僕には六ヶ敷いから、過日書いた貴兄についての論文（？",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噂に依ると、二三日前から――さう、だから彼等の噂に一日と続くものはあんまりない筈である――竹山を辞職させようといふ社長の考へだといふ噂があつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処か向ふの方で、子供が二三人、按摩の笛の真似をしてゐるのが聞えた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の乗つた車室には二三人しかゐなかつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オイ、やかましいぞツ」　フイルムをみながらキヤツキヤツ笑つたり喋舌つたりする二三人連の女が二人の傍にゐた、彼は半分Ｓ子の機嫌をとるやうにその女達に怒鳴つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三度顛狂院に送られもした。",
              "citation": {
                "source": "ヂェラルド・ド・ネルヴァル",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その代表的な例として二三の作品をあげてみよう。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時僕は詩を作り、初めて文壇的に出發したので、二三の友人と共に同人雜誌を發行して居た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吹屋の姐さんは吃驚した半身を店から出せば、筆屋の老翁は二三歩往來へ進み出て、共に引き行く人浪の趾を見送る事、少時焉たり。",
              "citation": {
                "source": "二十三夜",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹や弟にさんざん言はれて、濱へ出ると、こんどは助けてやつた龜にまで同じ樣な失敬な批評を加へられる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
