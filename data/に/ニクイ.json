[
  {
    "uuid": "d0db2945-e7b2-5614-b0e5-a955e8336877",
    "entry": "憎い",
    "reading": {
      "primary": "にくい",
      "alternatives": [
        "ニクい"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hateful",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "憎いことはないだろう。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「えへへ、」と狸は急にいやらしく笑ひ、「その口が憎いや。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナニをするんだと抵抗する遊び人の懐から紙入れを取り出した浪人が、　「憎い奴！",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "仇討で御座る」　と言って、Ｔ「憎い敵奴残念乍ら取り逃し申した」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝が、Ｔ「憎いのは　此村大吉とか仰しゃる　御武家様……」　弱い者が強い奴への果敢ない反抗です。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎の天狗は悠々と現れ出て、Ｔ「我名を騙る　憎い人間ども」　山賊達、震え上る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "移住する彼の家　（本庄陸男氏）　讀み憎い作品だ。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀み憎いもう一つの原因は方言であるが、これはかまはないとして、作者はどうしてこのやうに晦澁な地の文を書くのか了解に苦しむ。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の肉体がむしろ憎い――一方の生活慾を満足させようとあせりながら、その方法（貝原に買われること）に離反する。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎い男、妾の伊達男、お前が苦しむほど抱きしめたい、女の全て投げ出して。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が部屋に這入ると絹のハンカチに涙の地図をかいた女が私の姿を見ると罵るように、妾は日本が憎い、妾の恋しい人を連れ出すのはこのインボスタ奴！",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんな憎い、恐ろしい男はありません。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当に憎いやつではありませんか。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菱形の脚の間に見えてゐる風景、女の姿をかくしてしまふ砂埃、心憎いことである。",
              "citation": {
                "source": "詩集『戰爭』",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが憎い女ならおれもなに、邪魔をしやあしねえが、かわいいから、ああしたものさ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎いやつなら何もおれが仕返しをする価値はないのよ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "趙再思は仕方なしに俟っていると、暮方になって漸く季は出て来て、余怒なお色にあるばかりで、「自分に方鼎を売付けた王廷珸という奴めは人を馬鹿にした憎い奴、南科の屈静源は自分が取立てたのですから、今書面を静源に遣わしました。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のひとは、おちぶれた異人を見ると、きっと白系の露西亜人にきめてしまう憎い習性を持っている。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この憎い大暴風雨も、もとはと言えば、私の雨着物の為なのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワンピースを着せて変装の女給に……活動のサキソフォン吹きに……タキシードを着せて芝居のボックスに……どれもこれも憎いほどよく似合った。",
              "citation": {
                "source": "怪青年モセイ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大体、あの鵙という奴は高い処へ止まってキイキイ威張った憎い奴だ。",
              "citation": {
                "source": "鵙征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今ですか、今でも憎いとは思っていません。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然というものは心憎い姿を持っている」　清逸はどんどん流れてゆく河の水を見つめながらこんなことを考えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし（Ｓ夫人自身のこと）がこの聖者に、憎いほど激しい嫉妬を覚えて、その詮索に附き纏い始めたのは、この自分の部屋で聖者の逸話集を読んだときからだ。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、自分の子をいじめる他所の子は憎い、自国に敵対する他国が憎い、自分の位置を凌駕する競争者が憎いなど。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この子が憎いという時にはなげき、この子が賢いと嬉んでもなげかれる、この子が愚しく見えても歎かれる。",
              "citation": {
                "source": "オペラの辻",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、要するに、まあ、こんな話は酒でも呑んだ時でなければひとにははなし憎い話ですなあ。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが世間が、不景気だ、ボヤボヤしてはゐられないと云へば云ふ程、インテリにとつてその世間たるや住みにくい世間となる。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、友達として一言忠告させて貰ふなら、その生活ぶりに、時として余りに野放図なものがあるので、謂はば必要以上に衰弱して居る日があつて、そんな日に出来た詩は、あの感覚と同居しにくい抽象概念を招きすぎて、読者を混乱させる場合がある。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで御当人は益々元気で、『此の世が渡りにくいなぞとはみなこれ感傷の徒のこと』だなぞとも云ふ。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
