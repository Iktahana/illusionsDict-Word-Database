    "definitions": [
      {
        "index": 1,
        "gloss": "test for a position in a company",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
