    "definitions": [
      {
        "index": 1,
        "gloss": "Japan and Italy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いやな許嫁に処女を捧げるよりは……」　と、昨日伊都子は信吉に身を任せた。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十三年十二月二十九日伊豆伊東に於て）　海濱に於ける人間の生活とそこの自然との交渉ほど、予等の興味を引く自然觀相の對象は蓋し鮮い。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『玉葉』四十に寿永三年正月元日伊勢怪異の由を源義仲の注進せる内に、元日の夜大風雨雷鳴｜真虫蛇打ち寄せられ津々に藻に纏われてあるいは二、三石あるいは四、五石（石は百か）皆生きあり、両三日を経て紛失しおえぬ、およそ昔も今も真虫海より打ち上げらるる事は伊勢国に候わず、件の蛇海より来り寄す云々と見ゆ。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日伊達政宗が将軍家のいひつけで、お茶を献じようとお勝手元でその支度にとりかかつてゐた。",
              "citation": {
                "source": "茶話",
                "author": "昭和五（一九三〇）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独協定が行われて略一ヵ年を経た本年下四期に日伊協定が結ばれ、南京陥落の大提灯行列は、大本営治下の各地をねり歩いた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頃日伊沢分家に質して知り得たる所に従へば、蘭軒の長女は天津で、文化二年に夭した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "署して「文政癸未孟春廿二日伊沢信恬識」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日伊沢の乳母が柏を伴つて石川に往つた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳者頃日伊沢辞安の事蹟新聞紙に御連載相成候由伝承、辞安の篤学世に知られざりしに、御考証に依つて儒林に列するに至候段、闡幽の美挙と可申、感佩仕候事に御座候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」一戸の記に拠れば、是日伊庭八郎｜秀頴等は江刺を回復せむと欲して果さなかつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七日伊藤九三様才谷梅太郎御直披",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月十七日　伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月廿七日伊藤様才谷",
              "citation": {
                "source": "手紙",
                "author": "慶応三年五月二十七日　伊藤助太夫あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日伊代達は帯広の街へ行った。",
              "citation": {
                "source": "帯広まで",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者はこの日伊予と阿波との国境を目指して車を駆つた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "文政元年二月六日伊勢国一志郡須川村に生れた。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日伊藤整のところへちよつと寄つたところ、その本箱の中に百鬼園が二冊（一冊は「冥途」といふ小説集であつたが）も入つてゐたので、どんなものを書いてゐるかナと云つて、ちよいと覗いて見たのが不可なかつたのである。",
              "citation": {
                "source": "百鬼園讃",
                "author": "百田宗治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多助は、その頃村の端に小さな水車小屋を持っていましたが、毎日伊作の店に寄っては酒を飲んだり、干魚を食たりして、少しも勘定を払わないので、それが土台になって二人はいつでも喧嘩をしました。",
              "citation": {
                "source": "三人の百姓",
                "author": "秋田雨雀",
                "note": "青空文庫"
              }
            },
            {
              "text": "公若し既成政黨に入るを利あらずとして別に一政黨を組織せば如何既成政黨の孰れにも關係なき中立派は喜むで公を迎ふるのみならず、既成政黨の腐敗に厭き果てたる健全なる同志者は、亦必らず響應して起たむ公乃ち今日伊藤侯の未だ實行せざるものを實行する、亦妙ならずとせむや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "公若し既成政党に入るを利あらずとして別に一政党を組織せば如何既成政党の孰れにも関係なき中立派は喜むで公を迎ふるのみならず、既成政党の腐敗に厭き果てたる健全なる同志者は、亦必らず響応して起たむ公乃ち今日伊藤侯の未だ実行せざるものを実行する、亦妙ならずとせむや。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "安政元年（西暦一八五四）六月十五日伊賀｜上野を中心とした大地震の時には、奈良南大門のあたりに大きな地割れが生じ、それから火焔を噴き出したと言われる（大阪地震記）。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（２）　昭和五年十一月二十六日伊豆地震の発光　昭和五年十一月二十六日午前四時ごろ伊豆半島北部から発した大地震の時、方々で発光現象が観察され、その調査の許可を得るのが容易でなかったことは前に書いた。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日伊協定（これは経済協定の形をとった）や日本ポーランド文化協会もまたここに帰する。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日伊協定の声も亦関係重大だ。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十八日伊豆伊東にて友人　　伊良子清白　夜雨は薄幸の詩人なり、幼ふして身、已に病を懷き、室に筑波の翠微を仰ぎて、而も脚多く戸※の間を出でず、宜なるかな、凄思欝結して詩となるところ、哀音惻々として一に蠶兒の糸を吐いて盡きざる如くなるや。",
              "citation": {
                "source": "花守",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村、明日伊豆へゆくんだって、私がいないと忽ち困るじゃないの。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "――四日伊上、小峰岩波へ出勤　遺言によつて岩波で全集を出版して貰ふについては、芥川が生前新潮社にいれてあつた契約書はまいて貰つた。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日伊藤内閣が変って、大隈がなろうが、山県がなろうが、松方がなろうが、ただ増税を図って憲法は勝手次第に放っておくという政府には、どなたにでも反対しなければならぬ。",
              "citation": {
                "source": "渡良瀬川",
                "author": "大鹿卓",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日伊賀の上野見物、余は後便にて」で充分用が足りる。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "上山より電話、多分明日伊東へ行って貰ふが、又連絡するとのこと。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十六年十二月十四日伊豆古奈の温泉において著者しるす鹿・鹿・角・何本　一昨年の九月、米国ミズリー大学のブリウスタアという未知の人から面白い手紙の問合せを受けた。",
              "citation": {
                "source": "こども風土記",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
