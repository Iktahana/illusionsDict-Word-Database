    "definitions": [
      {
        "index": 1,
        "gloss": "two-storey house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木造二階家の玄関だけを石造にしたようなのが、木造部は平気であるのに、それにただそっともたせかけて建てた石造の部分が滅茶滅茶に毀れ落ちていた。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して新道沿いに新しく出来た当世風の二階家などで大損害を受けているらしいのがいくつも見られた。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廂を長く突出した低いがっしりした二階家では窓から座敷に積まれているらしい繭の山の尖が白く覗かれた。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女は此二階家の前に来ると暫時く佇止って居たが、窓を見上げて「江藤さん」と小声で呼んだ、窓は少し開ていて、薄赤い光が煤に黄んだ障子に映じている。",
              "citation": {
                "source": "二少女",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "開拓使時分に下級官吏の住居として建てられた四戸の棟割長屋ではあるが、亜米利加風の規模と豊富だった木材とがその長屋を巌丈な丈け高い南京｜下見の二階家に仕立てあげた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鴎がちらちらと白く飛んで、浜の二階家のまわり縁を、行きかいする女も見え、簾を上げる団扇も見え、坂道の切通しを、俥が並んで飛ぶのさえ、手に取るように見えたもの。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草、花川戸の、軒に桃の咲く二階家に引越して、都鳥の鼈甲の花笄、当分は島田のままで、祖母さんと妹がそこへ引取られて、私は奉公を止して、中学校の寄宿舎へ入る。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……「今度裏の二階家へ越して來た人は、玉川さんと云ふのだらう。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "叫ぶ聲は、確かに筋向ひの二階家の、軒下のあたりと覺えた。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の夜から、筋向うの其の土藏附の二階家に、一人氣が違つた婦があつたのである。",
              "citation": {
                "source": "霰ふる",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　其を、四五軒行つた向う側に、幅の廣い橋を前にして、木戸に貸屋札として二階家があつた。",
              "citation": {
                "source": "松の葉",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　トちょっと更まった容子をして、うしろ見られる趣で、その二階家の前から路が一畝り、矮い藁屋の、屋根にも葉にも一面の、椿の花の紅の中へ入って、菜畠へ纔に顕れ、苗代田でまた絶えて、遥かに山の裾の翠に添うて、濁った灰汁の色をなして、ゆったりと向うへ通じて、左右から突出た山でとまる。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は膝をずらしながら、帯に手をかけて、揺り上げたが、「お待ちよ、今お銭を上るからね、」　手帳の紙へはしり書して、一枚｜手許へ引切った、そのまま獅子をさし招いて、「おいでおいで、ああ、お前ね、これを持って、その角の二階家へ行って取っておいで。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さく畳んで、幼い方の手にその（ことづけ）を渡すと、ふッくりした頤で、合点々々をすると見えたが、いきなり二階家の方へ行こうとした。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、厚さは雜と塀の上から二階家の大屋根の空と見て、幅の廣さは何のくらゐまで漲つて居るか、殆ど見當が附かない、と言ふうちにも、幾干ともなく、急ぎもせず、後れもせず、遮るものを避けながら、一つ一つがおなじやうに、二三寸づゝ、縱横に間をおいて、悠然として流れて通る。",
              "citation": {
                "source": "番茶話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖障子が縱横に入亂れ、雜式家具の狼藉として、化性の如く、地の震ふたびに立ち跳る、誰も居ない、我が二階家を、狹い町の、正面に熟と見て、塀越のよその立樹を廂に、櫻のわくら葉のぱら／＼と落ちかゝるにさへ、婦は聲を發て、男はひやりと肝を冷して居るのであつた。",
              "citation": {
                "source": "露宿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿のその二階家の前は、一杯の人だかりで……欄干の二階の雨戸も、軒の大戸も、ぴったりと閉まっていました。",
              "citation": {
                "source": "半島一奇抄",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裾の埃、歩の砂に、両側の二階家の欄干に、果しなくひろげかけたる紅の毛氈も白くなりて、仰げば打重なる見物の男女が顔も朧げなる、中空にはむらむらと何にか候らむ、陽炎の如きもの立ち迷ひ候。",
              "citation": {
                "source": "凱旋祭",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓に菫色の日覆を取り付けた簡素な木造の二階家が、丈の高い松の木立ちと一緒に、池の面に姿を映していた。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが立ち退き次第銀子の親たちを入れ、今一｜棟、横の路次から入れる奥にも、静かな庭つきの二階家が一軒あり、それも明けさせて銀子が入り、月々の仕送りもするから、それに決めようと、親爺は昨夜も言っていたのだった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚い露路の奥の、二階家で、堀木は二階のたった一部屋の六畳を使い、下では、堀木の老父母と、それから若い職人と三人、下駄の鼻緒を縫ったり叩いたりして製造しているのでした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "街の小道の上に煉瓦積みのトンネルが幅広く架け渡され、その上は二階家のようにして住んでいるらしい。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁どいまの曲角の二階家あたりに、屋根の七八ツ重ったのが、この村の中心で、それから峡の方へ飛々にまばらになり、海手と二、三｜町が間人家が途絶えて、かえって折曲ったこの小路の両側へ、また飛々に七、八軒続いて、それが一部落になっている。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「角の、あの二階家が、」「ええ？",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その客人が亡くなりまして、二月ばかり過ぎてから、彼処へ、」　と二階家の遥なのを、雲の上から蔽うよう、出家は法衣の袖を上げて、「細君が引越して来ましたので。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いやいや、――どうも話がいろいろになります、――ところが久能谷の、あの二階家が本宅じゃそうで、唯今の主人も、あの屋根の下で生れたげに申します。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雨が二階家の方からかかって来た。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、（乙）の字なりに畝った小路の、大川へ出口の小さな二階家に、独身で住って、門に周易の看板を出している、小母さんが既に魔に近い。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼尻の皺もなにかいやらしかった。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの古池からはなにかいやな沼気が立ちのぼるかと思われた。",
              "citation": {
                "source": "道",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
