        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "怒りて書物を投げすてひとり校庭の草に寢ころび居しがなにものの哀傷ぞはるかに彼の青きを飛び去り天日直射して　熱く帽子の庇に照りぬ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日直上ト兵」　ワーイ「食券持ってイモン袋取りに来い」「オーイ、田中、田中、日直上ト兵ッ」（居ない）○紹介　船尾で寝ていた。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷土望景詩中學の校庭われの中學にありたる日は艶めく情熱になやみたりいかりて書物をなげすてひとり校庭の草に寢ころび居しがなにものの哀傷ぞはるかに青きを飛びさり天日直射して熱く帽子に照りぬ。",
              "citation": {
                "source": "純情小曲集",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、今日直接行動説を贊成したといつても、總ての直接行動、議會を經ざる何事でも贊成したといふことは言へませぬ。",
              "citation": {
                "source": "A LETTER FROM PRISON",
                "author": "‘V NAROD’ SERIES’",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄平、ふと廊下の壁の黒板に、「日曜日、日直当番、小谷初枝訓導」と書いてあるのを見て、おやっと思い、引きかえす。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなれば我は先の日直ちに彼の無禮を責めざりしぞ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし来日直前にＩＢＭが打ちだした新しい動きの余波を利用すれば、日本市場にも食い込みうる可能性は見えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日直ちに土倉氏を銀水楼に訪れけるに、氏はいまだ出阪しおらざりき、妾の失望いかばかりぞや。",
              "citation": {
                "source": "妾の半生涯",
                "author": "福田英子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其価は金一千二百円で、雑誌としては甚だ不廉のようであるが、七十四年間の雑誌を揃えるは頗る至難であって、仮令二千円三千円を出した処で今日直ちは揃え得られるものでは無い。",
              "citation": {
                "source": "灰燼十万巻（丸善炎上の記）",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夢なりけらし、ああ人妻、――實にあえかなる優目見のもの果なさは、日直りの和ぎむと見れば、やがてまた掻きくらしゆく冬の日の空合なりき。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "――夢なりけらし、ああ人妻、――實にあえかなる優目見のもの果なさは、日直りの和ぎむと見れば、やがてまた、掻きくらしゆく冬の日の空合なりき。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "束の間や、――やがて日直り、冬の日はほほ笑みそめつ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等の教室では、たとい鑑定の事項が局所的のものでも、必ず全身を精密に解剖することになって居るので、その日直ちに注意深く解剖を行った。",
              "citation": {
                "source": "闘争",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがある作家たちは、今日直接それを書こうといわず、別な範囲の「大人」の中心問題を大衆に分るように描こうと提唱しているのだが、それならばその「大人」の世界はどんな姿をもっているのであろうか。",
              "citation": {
                "source": "「大人の文学」論の現実性",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "十月五日直柔吉井幸輔様",
              "citation": {
                "source": "手紙",
                "author": "慶応二年十月五日　吉井友実あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月廿四日直柔権平様左右追白此度ハ取急候間、何もくハ敷ハ申不遣候。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年六月二十四日　坂本権平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月八日直柔尊兄左右",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月八日　坂本権平あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月廿六日直柔佐々木先生龍拝左右",
              "citation": {
                "source": "手紙",
                "author": "慶応三年八月二十六日　佐々木高行あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月廿七日直柔本山先生左右",
              "citation": {
                "source": "手紙",
                "author": "慶応三年九月二十七日　本山只一郎あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "廿二日直陰池蔵太様濤次郎",
              "citation": {
                "source": "続　手紙",
                "author": "池内蔵太あて（推定、慶応元年夏、二十二日）",
                "note": "青空文庫"
              }
            },
            {
              "text": "其れに巨万の慰労金を貰つて国立劇場を隠退した俳優は巴里市で興行することの出来ない規定があるのに、剛腹と我儘とを極めた性格の老優が其れを破つてサン・マルタン座へ出たのだから、初日にはコメデイイ・フランセエズの役員が揃つて見物し翌日直ちに裁判｜沙汰が持上つた。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田へ着いた日直に外宮内宮を参拝して、妙見町に止宿したが、その晩奮発して、古市へ登楼した。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日直ちに僕は退院することが出来ます。",
              "citation": {
                "source": "盗まれた手紙の話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、今日直ちに、支那をどうかしたいのである。",
              "citation": {
                "source": "私の従軍報告",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月二十九日直三郎さんの病気を昨夜きいてから、何だかむやみと胸が塞る。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月十四日直三郎さんがとう／＼なくなったといふ。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
