    "definitions": [
      {
        "index": 1,
        "gloss": "game of shogi in which the stronger player plays without a rook and a bishop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "将棋道場で格上の先生にお願いして、飛車と角を抜いた「二枚落ち」のハンデで指導対局をしてもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「二枚落ちといっても、守りの金銀がしっかりしているから、素人だとなかなか攻略できないものだよ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "二枚落ちの定跡を本で勉強し、大駒がない状態での効率的な攻め方をマスターしようと努力している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "汽車が動き出してから気が付くと私の傍に東京の夕刊が二枚落ちている。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてその黒い表紙がだんだんと見えなくなって、もうあと一二枚落ちるとすっかり銀杏の葉で隠れてしまいそうになると、最前から我慢の出来るだけ我慢をしていた姫は、もう堪らなくなって、我れ知らず傍に走り寄って、銀杏の葉を掻き除けて書物を拾い上げて、表紙を一枚夢中でめくって見た。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おとといの晩に下谷の御隠居のあとを追っ掛けて、源森橋の方まで河岸に付いて行きますと、下駄の先にぴかりと光る物がありましたから、提灯の火で透かしてみると、雨のふる中に小判が二枚落ちていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "広重と河獺",
                "note": "青空文庫"
              }
            },
            {
              "text": "大山八段と二枚落ちで指しわけた安永五段が、よし、碁でこい、と七目おかせて、やりだしたのである。",
              "citation": {
                "source": "勝負師",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "よい匂いといっしょに、白い花びらが、ひらひらひらひら、しきりにまいおちて、雪のように地面につもりました。",
              "citation": {
                "source": "山の別荘の少年",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
