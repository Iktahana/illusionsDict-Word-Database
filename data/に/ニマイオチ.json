    "definitions": [
      {
        "index": 1,
        "gloss": "game of shogi in which the stronger player plays without a rook and a bishop",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
