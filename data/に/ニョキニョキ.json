    "definitions": [
      {
        "index": 1,
        "gloss": "(shooting up) one after another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とにかくうすら寒い時候に可愛らしい筍をにょきにょきと簇生させる。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "にょきにょきと屋根が尖った、ブラゴウエシチェンスクの市街は、三時半にもう、デモンストレーションのような電灯の光芒に包まれていた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり切り崩された赤土のなかからにょきにょき女の腿が生えていた。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今彼の前を、勝子の手を曳いて歩いている信子は、家の中で肩縫揚げのしてある衣服を着て、足をにょきにょき出している彼女とまるで違っておとなに見えた。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "胴だけが、にょきにょき長く伸びて、手足がいちじるしく短い。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに金米糖のほうでは、そういう論理などには頓着なく、にょきにょきと角を出して生長するのである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっと崖を登りきったらそこはまばらに栗の木の生えたごくゆるい斜面の平らで雪はまるで寒水石という風にギラギラ光っていたしまわりをずうっと高い雪のみねがにょきにょきつったっていた。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜の山の杉の木は、にょきにょき黙ってつっ立って、尖った針の梢には、冷い半月がかかっていた。",
              "citation": {
                "source": "姥捨",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "にょきにょきのびて、しだいにはっぱをつけました。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "（御覧じゃい、あないにの、どす黒くへりを取った水際から、三｜反も五｜反と、沖の方へさ汐の干た処へ、貝、蟹の穴からや、にょきにょきと蘆が生えましたぞい。",
              "citation": {
                "source": "甲乙",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋から冬にかけてにょきにょきと延び上がった細々したからだには、春の精のような豊麗な脂肪がしめやかにしみわたって行くのが目に見えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きのこにしたっても、そうぞうさなくにょきにょきとはえるわけじゃねんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伝六のささやいた声とともに、ほんのり薄明るい星空下の境内の広庭へ、にょきにょきと黒い姿を現わしたのは、はかま、大小、忍び雪駄の藩士が三人。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "と見えたのは束の間、――ふらりふらりと歩き出すと、影を追う影のごとくに、にょきにょきとまたいずれからか姿を現して尾行し始めました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――出ると同時のように、あちらから二人、こちらから三人、全部では二十名近くの面々が、いずれも異常な緊張を示してにょきにょきと姿を現しながら、互いに目交ぜをしつつ、再び退屈男のあとをつけ始めました。",
              "citation": {
                "source": "旗本退屈男　第七話",
                "author": "仙台に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "真物が姿を見せたら、うわさを聞いて女どももひとりでににょきにょきと姿を見せるにちげえねえから、ひとっ走りいって洗ってきな」「え……？",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る日も私は埠頭で、帆船や小汽船が波頭ににょきにょきと揺れている様を見ながら、じっと立っていた。",
              "citation": {
                "source": "玄海灘密航",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "その際涯もない海の上には、くずれる白い波頭のかげに、海坊主のように、残しておいた家中のものが――それらにこれから会いに行くのだが――にょきにょきと記憶の中に思い描かれた。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "小倉の襞を飽くまで潰した袴の裾から赭黒い足をにょきにょきと運ばして、茶を持って来る。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少しずつ活気づいて来て幼い時からの倣慢不敵さがにょきにょきと表面にあらわれ始めた。",
              "citation": {
                "source": "灰色の記憶",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐにみんなは、崩れた穴の中から、小さな頭をにょきにょきと出したが、そのまん中の、背の高いユースタスの頭は、鳶色の巻毛の中に粉雪がくっついて、白髪のおじいさんのようだった。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう大きい立木が、芝生の中に、きわめて無造作に、にょきにょき立っているのが、即ちこの土地での庭なのである。",
              "citation": {
                "source": "北国の春",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぐんぐん　にょきにょきと！",
              "citation": {
                "source": "えほんのアリス",
                "author": "THE NURSERY \"ALICE\"",
                "note": "青空文庫"
              }
            },
            {
              "text": "春先に草木の芽がにょきにょきと生えてくるように、あるいは九州熊本の水前寺公園で、熔岩のこまかい砂の下から地下水がもくもく湧き上っておるように、復活の喜びと復活による勝利の凱歌は、聖書に満ちておるのです。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この数えきれない竹の木も、地面からにょきにょき生えて来るたけのこも、……雨彦！",
              "citation": {
                "source": "なよたけ",
                "author": "加藤道夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の右手にすわっていた帝大生が、突然手をにょきにょき伸ばして、私の左にいる天願氏の方に盃を差出した。",
              "citation": {
                "source": "風宴",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦後子供の背丈がにょきにょきと向上して、どこで大人と子供の区別をつけるのか、どうも判らなくなって来たようです。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "巻煙草だのパイプだのをくわえたのや、頭巾をかぶったのや、無作法な嘲笑を浮かべた頭が、そこからにょきにょき突き出された。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
