        "examples": {
          "standard": [
            {
              "text": "電車の中で、買ったばかりの本を荷物棚に置いた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "バスに乗ったら、まずは荷物を荷物棚に上げてから席に座る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "飛行機の手荷物は、座席上の荷物棚に収納してください。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "かたわらなるは、十七八歳の令嬢ふうの美婦人、座席の上に横坐りして絹靴下の蹠を広く一般に公開し、荷物棚から真田紐でつるした一個二｜法の貸し枕に河童頭をもたらせ、すやすやと熟睡する相好は、さながら動物図鑑の※画に描ける海狸もかくやと思われるばかり、世にも愛らしき眺めであった。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "謝肉祭の支那服　――地中海避寒地の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "須美子が、ね、というように車室の荷物棚の上におかれた二つの茶色鞄を目でさして、「船では、ごくあたりまえの手荷物のようにして来てくれということですの。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
