[
  {
    "uuid": "f4261744-7d74-5f73-908e-1ff387e953a5",
    "entry": "入棺",
    "reading": {
      "primary": "にゅうかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
