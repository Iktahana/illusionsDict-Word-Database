        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とにかく西洋館で、――とにかく西洋窓のついた日本座敷で、日曜学校で使いそうな長い腰かけと四角なテーブルがおいてあった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "読む本がなくなれば、たけは村の日曜学校などから子供の本をどしどし借りて来て私に読ませた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日オースティン少年の為に歴史の講義をしているほか、最近、日曜学校の先生をもしている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば日曜学校学校の催しなどに行きたがろうものなら、もう気も狂わんばかりで、ですがわたくし、今度ばかりは行く、ぜひ行くって。",
              "citation": {
                "source": "同一事件",
                "author": "A CASE OF IDENTITY",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間後のある夕暮れ、ラ氏を不意に訪れたのは、某教会の日曜学校を監理している三十格好の好青年であった。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴方の御覧になるところでは、秀才だとか仰しゃってですが……」「いや、そう言うわけでも無かったです」「一体、人物はどういう……」「それは却って母さんなどが御存じだと言うことですが」「何アに、須磨の日曜学校で一二度会ったことがある位、妻もよく知らんそうですけえ。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "◇　亜米利加の西部にある或る日曜学校で、教師がしかつべらしく訊いた事があつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから子供を日曜学校へつれて行つたり、遊戯を教へたりすることも、飽かなかつた。",
              "citation": {
                "source": "二人の病人",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本のように修身科というものがない代りに日曜学校で聖書を教えております。",
              "citation": {
                "source": "わたくしの大好きなアメリカの少女",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "河のそばを子供達が、活動芝居をいましめてなんて、日曜学校の変なうたをうたって通った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外側から見ると、まるで日本の田舎に見る日曜学校のやうな造りで、通行人は、たまたまこのみすぼらしい建物を忘れて通つてしまふ。",
              "citation": {
                "source": "瑪瑙盤",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご尤もです」　女ながらも相当教養もあり、日曜学校の教師をしている位だし、夫の為云うまいと決心すれば、生優しい問い方では口を開く女ではないと見極めをつけた石子は、話題を別の目的の方へ転じた。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は白金学院の女学部を出て更に神学科を修めて、二十七と云う若い女ながらも自宅に日曜学校を開いて、教鞭を取っていたので、支倉が神学徒の仲間に知られるようになったのも過半は彼女の為だったのだ。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支倉の妻が日曜学校の教師などをして、同派に属している関係から知合となり、妻の縁で支倉も続いて出入するようになり、小林貞を支倉の家に預けるようにしたのも、彼が口を利いたのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一銭の貯えもない上に子供を抱えて、今は日曜学校の教師を務める事も出来ず、路頭に迷う外はない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶を飲んだら元気よく日曜学校へお行き、みんなでお行き。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「多加ちゃんがあすこへはいると直に、日曜学校の生徒からだって、花を一束貰ったでしょう。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "匪賊討伐の話、楊州の街の様子、米国教会の日曜学校で反日宣伝をした事実など聴く。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十時頃）旭川ではもう日曜学校を終ったらう。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜学校も北海道とはちっとも変らない。",
              "citation": {
                "source": "日記",
                "author": "知里幸恵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから教会でなく学校の方に日曜学校といふのがあり、英語の聖書で旧約のユダヤの歴史を教へられた。",
              "citation": {
                "source": "身についたもの",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は町に住む牧師で、一部の子供から「日曜学校の叔父さん」と懐かしがられている。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜学校へいって、先生からお話を聞いて、それから、とみ子さんや、まさ子さんといっしょに遊ぶ、お約束がしてあったのだ。",
              "citation": {
                "source": "鳥鳴く朝のちい子ちゃん",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいつも部落の中にある小さな教会に引きこもって、日曜には日曜学校を開き、女子供に説教するのがせいいっぱいであった。",
              "citation": {
                "source": "おば金成マツのこと",
                "author": "知里真志保",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして毎日曜には日曜学校を手伝つたり、路傍説教を一人でしたりなどして居た。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十四　翌日の午後、ウイリアムス博士から、西洋人の教会の日曜学校からだと云つて、玩具を二行李、車夫が届けて寄越した。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月七日の日曜からは狭いその五畳敷で日曜学校を始めた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度その時――関西学院神学部の竹田君と、八尾君と、橋田君が親切にも、貧民窟の日曜学校を受持つことを申込まれたので、日曜学校の為めにも家が余り狭いものだから、二軒置いて西隣の――六畳の家を借りることにした。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜学校も、晩の説教も凡て六畳の家ですることになつた。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
