        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "これには胸が煮えたぎる程口惜しかつた。",
              "citation": {
                "source": "『青空』のことなど",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "火の球は、かすかな、ものの煮えたぎるような音を立てながら細かく震動している。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一声かすかに、鴎の泣き声に似た声が、釜の中から聞えた切りで、あとは又、お湯の煮えたぎる音と、老婆の低い呪文の声ばかりでありました。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "休まねばならぬ時に、おれは、煮えたぎる田の水の中で草とりをしたっけ。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭蓋骨は割れ裂け煮えたぎる五體が破れ裂けるまで竈の中を、幾百の惡蛇の如き炎々たる焔の音を覗き込んでゐたのだ！",
              "citation": {
                "source": "無法な火葬",
                "author": "VIOLENT CREMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "――人間、何でも運不運でね、旦那もそりやア大変だが、待つてるお前さんも大変な事だなア……」鉢巻を取つて、その男は、鉢巻の手拭で湯呑みとコップを拭いて煮えたぎる茶をついだ。",
              "citation": {
                "source": "下町",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死人を見てゐると、生命への煮えたぎるやうな感覺が、素肌の肩さきに、腕に、ふくらはぎに、電氣のやうに熱くしびれて感じられる。",
              "citation": {
                "source": "ボルネオ　ダイヤ",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし左近は、はじめて心中に煮えたぎる怒りを感じた。",
              "citation": {
                "source": "左近の怒り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "火が盛に燃えて、釜の中で熱湯が煮えたぎる音と、釜の啼く音とが。",
              "citation": {
                "source": "悪魔",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の生活は湯の煮えたぎる鐵瓶の蓋の上に、あるかなきかに積る塵埃である。",
              "citation": {
                "source": "三太郎の日記　第一",
                "author": "阿部次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを見ていなければならない左膳の苦悩は、煮えたぎる鉛の沼。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのかわり、あなたのことについて、わたしは誰からもひとことも話されていませんよ」　煮えたぎるようだった女のいらだちとぼんやりした屈辱感は、伸子のその話しぶりでいくらかずつ鎮められて行くらしかった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身の意志や良心は、煮えたぎる悲しみに、一つは踏みつけられ、他は窒息してゐた。",
              "citation": {
                "source": "ジエィン・エア",
                "author": "ブロンテイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沸騰している酢のように煮えたぎる音がする」とか「新しい革紐のようにきしる音がする」と彼らは言った。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "油が煮えたぎるような音とともに、湯気が立った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "せずにおかぬ」「…………」「ややもすれば、この業が煮えたぎるように、そなたの体のうちへも、道誉という男を烙きつけねば、一生、妄執は晴れやるまい。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸の中はにえたぎるようだった。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでかがみのような静かななぎのとき、海一面があわだち、にえたぎるような、あらしのとき、朝日、夕日にまっかにいろどられた海、満月の光で銀色にかがやく海、そのひとつひとつが、みんな、たましいもとろけるように、美しいのです。",
              "citation": {
                "source": "海底の魔術師",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
