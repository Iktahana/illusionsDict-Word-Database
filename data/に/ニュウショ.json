    },
    "definitions": [
      {
        "index": 1,
        "gloss": "admission (to an institute, nursery school, facility, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何々紹介所、又は周旋所、口入所なぞ看板をかけたのもある。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうもあろうかということは、ずっと以前、僕の入所当時ですが、恰好の悪いながら、第四図というのを取ったときに、この扁平なのが出たので、鳥渡疑いをもったのです。",
              "citation": {
                "source": "キド効果",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "歸つて行く母の後姿を見て、順吉は入所後はじめて涙をながした。",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "こちらは今日から入所された理学士｜古屋恒人君。",
              "citation": {
                "source": "階段",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋を越して合羽橋へ出て、頼んでおいた口入所へ行く。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、入所時に於ける、教育程度も、高等教育を受けたものはたった一人位で、あとは無筆者が五十三人の多数です。",
              "citation": {
                "source": "新生の門",
                "author": "――栃木の女囚刑務所を訪ねて",
                "note": "青空文庫"
              }
            },
            {
              "text": "みづ江の母親はみづ江が入所してから半年も過ぎぬうち死んだ。",
              "citation": {
                "source": "青春の天刑病者達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "白壁には名灸やら堺の街の呉服屋やら雇人口入所の広告やら何時でも貼られて居るのです。",
              "citation": {
                "source": "月夜",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "北方の諸門は、皇后・中宮その他、後宮の出入所になつて居た。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "白丘ダリアの入所後はやくも五日のちには、赤外線テレヴィジョン装置がもう一と息で出来上るというところまで漕ぎつけた。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は二ヶ月あまりもあちらこちらで働いて入所が遅れ、番号も二三五五〇という、非常に多い数字だった。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕よりも早く入所した人々がまだ多数残っているのに、僕の方が早く帰国出来ることは、少々済まないような気がした。",
              "citation": {
                "source": "比島投降記",
                "author": "ある新聞記者の見た敗戦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……ちゅう話ですたい」　何の遅疑もなく、彼女はこのつぎの部落に「軍馬買入所」が出来たこと等を話す。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人たちは入所したときに重症であって自分たちのことを話すことが出来なかったからであった。",
              "citation": {
                "source": "コレラの伝染様式について",
                "author": "ON THE MODE OF COMMUNICATION OF CHOLERA (1854)",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてＴ君が入所したらすぐ一通りの器械の註文をすまさせて、欧米の関係研究室を見学させるという話になった。",
              "citation": {
                "source": "原子爆弾雑話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのロケーシヨンの頃、入所患者が浮世を感じたと見えて、毎晩催眠剤を請求して困つたのを今も思ひ出す。",
              "citation": {
                "source": "釣十二ヶ月",
                "author": "正木不如丘",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が石山教授は偉い男だったと沁々思うのは、彼に直属する助教授、助手といった弟子たちが、いずれも事件に関与したため戦犯となり、私同様巣鴨獄中の人となったが、入所中私はその誰からも一度として彼を恨む声を聞かなかったことである。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、入所中たまたま皮膚病を患ったことが機会となって、私は思わぬ人生再スタートをきることができた。",
              "citation": {
                "source": "戦争医学の汚辱にふれて",
                "author": "――生体解剖事件始末記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "入所すべき人物は地方で折紙づきの篤農家候補を厳選する（貧農は御免蒙ることにする）。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "入所患者に関する毎日の記事を書くのが、半太夫に任された事務の一つだったのである。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "徒労に賭ける",
                "note": "青空文庫"
              }
            },
            {
              "text": "入所してから五十二日になる。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            },
            {
              "text": "――俗に施薬院ともいわれた「小石川養生所」は、もとより貧しい病人を無料で診察し治療するのが目的であって、病状その他の事情によっては、かよいでなく、入所して治療を受けられることもすでに記したとおりである。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "駈込み訴え",
                "note": "青空文庫"
              }
            },
            {
              "text": "番医の詰める部屋からはじめて、かよい療治の者を診察する表部屋、薬の調合をする部屋、入所患者のための配膳所、医員の食堂などを見たあと、津川は南の口から、庭下駄をはいて外へ出た。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "腰掛は入所患者のために、陽当りのいい場所に七つあるが、その竹藪の前にある腰掛はゆみのために設けたもので、屋根を掛けた亭づくりになっており、夜などは人の近づくこともなかった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "――見習医は二人、これと新出医長だけが定詰で、入所している患者の治療は、殆んどこの三人に任されたようなかたちだったし、かよって来る患者に対しても、他の医員たちは熱意がなく、治療のやりかたも形式的な、投げやりなものが多いようであった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき入所していた患者は三十余人、老人や女が多く、外傷で担ぎこまれたり、行倒れで収容された者などもいた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "津川玄三が去ってからまもないころ、登は森半太夫に呼ばれて、入所患者の手当をしたことが三度ばかりあった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "狂女の話",
                "note": "青空文庫"
              }
            },
            {
              "text": "重ね重ねこれは有難く心得て御入所に及ぶほかはあるまい、笑止千万――ところが、今度の熊は、以前のように手軽くは入らない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ、森半太夫が来て、入所患者の診察をする時刻だと告げた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "おくめ殺し",
                "note": "青空文庫"
              }
            },
            {
              "text": "入所患者の一人一人に、病状と投薬を記した帳面があり、容態によって薬を変える分は、そのたびに調剤の配合を書きつけるのであった。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "おくめ殺し",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
