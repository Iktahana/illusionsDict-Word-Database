    "definitions": [
      {
        "index": 1,
        "gloss": "male homosexual's partner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私あ若気だ、襟巻で顔を隠して、睨むように二人を見たのよ、ね。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その気で居れば可いものを、二十四の前厄なり、若気の一図に苛々して、第一その宗山が気に入らない。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば余計な若気の過失、こっちは畜生の浅猿しさだが、対手は素人の悲しさだ。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが遊び心と思うようなものを振り捨てゝかの女を宿の妻というような絶対な心を起したのは一つはそれ等の恋敵の鼻を明かしてやり度い若気の競争心もあったらしい。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもあとお茶をすすり、爪楊子を使うとは、若気の至りか、厚顔しいのか、ともあれ色気も何もあったものではなく、Ｋはプリプリ怒り出して、それが原因でかなり見るべきところのあったその恋も無残に破れてしまったのである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて春風荘の一室に落ちつくと、父は、俺はあの時お前の若気の至りを咎めて勘当したが、思えば俺の方こそ若気の至りだとあとで後悔した。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、若気の誤は人間の常でござるわい、それにしても早くそれに気が注かれたは、まだ御仏の助けの綱の断れぬ証しでござろう。",
              "citation": {
                "source": "轆轤首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「風俗壊乱」の文士らしく若気の至りの放蕩無頼を気取って、再びデンと腰を下し、頬杖ついて聴けば、十銭芸者の話はいかにも夏の夜更けの酒場で頽廃の唇から聴く話であった。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さしあたり、……のちの祇園のお絹を東京にしたような人だったんです――いや、どうも、若気の過失、やがての後悔、正面、あなたと向い合っては、慙愧のいたりなんですが、私ばかりではありません。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう踏んで「会社がやらないのなら僕が自分でやる」と上司を脅迫したものの、これをはねつけられたトッテン青年は「若気の至り」で会社設立を決意する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "年を重ねるに伴れて、単に若気の亢奮に駆られてゐるらしい空々しい血気が消え失せたならば、これも屡々他人から云はれた通り、阿呆な空殻になつてしまふであらうと、臆病な私は怖れてゐた。",
              "citation": {
                "source": "素書",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母様の御息所はきわめて聡明な人だったのですが、私の若気のあやまちから浮き名を流させることになりました上、私は一生恨めしい者と思われることになったのですが、私は心苦しく思っているのでございます。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには若い正義感や、若気の過失や、いろいろのものがあるだらうと信じてゐる。",
              "citation": {
                "source": "小熊秀雄全集-9",
                "author": "詩集（８）流民詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず、後には若気の過失で後悔しているといった。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "若者はいかに若気ていても、武士じゃほどに勇に勇ましい捨身の言葉を吐くかと思っていたが、右衛門は低い声で、「命が惜しい、命ばかりは助けて下され」といった。",
              "citation": {
                "source": "三浦右衛門の最後",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこの家の次男で、本来ならば相当の土地を分配されて、相当の嫁を貰って、立派に一家の旦那様で世を送られる身の上であるが、若気の誤まり――と、他の雇人は云った。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、そこへ同僚の誰もが行きしぶって恩師がたいへん困っているのに同情したのと、それからもう一つは、若気の無鉄砲とによって、自ら赴任の役を買って出たのであった。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊五郎と松助７・13（夕）　市村座の尾上菊五郎が、若気の思ひ上りから、色々突拍子もない事を言つたり仕たりするので、近頃世間の人気が以前ほど思はしくない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "若気の至りで家出した遊び者の若者は、じきに涙をこぼしながら故郷に立ち戻るものじゃと昔からきまって居る。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、私も妻も、若気の至りとはいえ、随分立ち入った冒険をしたものです。",
              "citation": {
                "source": "暴風雨の夜",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "……若気の至りとはいい乍ら、至極あっさりした考に耽ったものです。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "若気の至りとでも言いますか、悠々たる態度をもって研究することをせず、只管にあせり続けたのが悪かったのです。",
              "citation": {
                "source": "人工心臓",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして僕が分別盛りの三十四の今日まだ、危険人物なぞという物騒な名を歌われているのは、二十二の春から二十四の夏までの、血気に逸った若気のあやまちからのことだ。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそれは決して血気の逸りでもまた若気のあやまちでもない。",
              "citation": {
                "source": "獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "若気の無分別から気まぐれに家を飛びだして、旅から旅へと当もなく放浪したことがある。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、高知県の豪農の息子じゃったそうで御座いますが、若気の過ちで人を殺しまして以来、アチコチと逃げまわった揚句、石見の山奥へ這入りまして、関西でも有名な山窩の親分になっておりました者だそうで……」「フウーム。",
              "citation": {
                "source": "骸骨の黒穂",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君なんぞまだ若気の一途に、学問とか、名誉とかいうことばかりを思うのも無理はないけれど、何もそんな思いをして学問をしなくっても人間の尽す道はわれわれの生活の上にも充分あるではないか。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "かと思うと、おこって然るべき時に、おこらず、だまってにやけこんで居る。",
              "citation": {
                "source": "自画像",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だそのにやけやうは。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（又にやけてやがる。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
