[
  {
    "uuid": "faf50b05-e4ea-52ce-9ffa-e9f907b38526",
    "entry": "二頭立て",
    "reading": {
      "primary": "にとうだて",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
