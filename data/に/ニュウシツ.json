    "definitions": [
      {
        "index": 1,
        "gloss": "entering a room",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私が入室したとき、ぴくりともしなかったが、姿を見るや目が反応したので、気づいてはいるらしい。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が入室すると、うしろから娘も滑り込み、後ろ手に扉の錠をかける。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々が入室し、ファーガソンは一、二歩妻へと歩み寄る。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟った上で、今夜また入室する。",
              "citation": {
                "source": "夢十夜",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "数日過ぎてからもう夕方に近いころ私の隣りに、肥満した可愛らしい娘が入室した。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも入室時に直したらしく、手はまだそこにあった。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "差入室の一室でしばらくみんなで快談した。",
              "citation": {
                "source": "続獄中記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お母さんの入室」「かいせん焼」「碁」「月蝕」「草履つくり」「着物のがら」「一本松」「目」「鼻」「悪口」「闇取引き」「散歩」などじっくりよむと、文章をあふれて深くせまって来る情景や生の思いがある。",
              "citation": {
                "source": "病菌とたたかう人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある者はこの今、すなわち親鸞が「選択の願海に転入」した時をもって、彼が二十九歳で法然を師として吉水に入室した時であるとし、ある者は吉水入室以後にあるとし、ある者はそれ以前にあるとし、ある者は『教行信証』製作の当時にあるとする。",
              "citation": {
                "source": "親鸞",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室厳禁の画室のことですから誰も見ていないので笑われはしませんが、だれか垣間見ていたとしたらずいぶんとへんてこな格好であろうと自分ながらそう思います。",
              "citation": {
                "source": "画室談義",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後森下町へ移ってから友人にすすめられて、禅を始めて、或る禅師の下に入室した事もありました。",
              "citation": {
                "source": "我が宗教観",
                "author": "淡島寒月",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩食の時宜道は宗助に、入室の時間の朝夕二｜回あることゝ、提唱の時間が午前である事などを話した上、「今夜は未だ見解も出來ないかも知れませんから、明朝か明晩御誘ひ申しませう」と親切に云つて呉れた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "此日も其通りであつたが或所へ來ると、突然語調を改めて、「此頃室中に來つて、何うも妄想が起つて不可ない抔と訴へるものがあるが」と急に入室者の不熱心を戒しめ出したので、宗助は覺えずぎくりとした。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "磬を打って入室相見の時、足音を聞いただけで、公案の工夫が出来たか、出来ないか、手に取るようにわかるものじゃと云った和尚がある。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者に診て貰ふと、大したことはない、まあ一ヶ月くらゐ入室でもしてゆつくり休みなさいと親切に云つて、笑ひながら「熱瘤では死にませんよ。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室と云ふのは重病室へ這入ることで、院内では療舎のことを健康舎と呼び作業に従ひ得るやうな者は健康者のうちに加へられるのである。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "重病室はいはばこの癩病村の病院であり、入室はつまり入院であつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室と聞いて成瀬は、それが始めてのことであるだけに余計強く心に響き、病み衰へて死と生の間をさまよつてゐる病人や、半ば腐ち果てた重病者達のうようよとした病室内の光景が思ひ描かれて、はやその方へ一歩を踏み出した自分を意識しなければならなかつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室となると部屋中の者総がかりで、或者は布団をかつぎ、或者は食器を入れた笊を抱へて、病人を載せたリヤカーを囲んでぞろぞろと病室までを異様な行列を続けて行く。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室後四日間彼は高熱に浮かされて意識も定かではなかつたのであるが、昨夜になつて次第に体温が下り、ぐつすりと云へないまでも快い睡りを得たのであつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下から覗くと、二人共頭をこちらにして寝てゐるのであるが、枕許の戸棚が邪魔になつて頭の先も見えない、戸棚にぶら下つてゐる熱型表が正面から見え、それがもう何枚も重なつてゐる所を見ると、昨日今日に入室した者とも思はれなかつた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは彼が入室してからちやうど十五日目にあたつてゐた。",
              "citation": {
                "source": "癩を病む青年達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "右腕の神経痛で七号病室へ入室した。",
              "citation": {
                "source": "重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ隣りの病室六号に彼は入室してゐるのださうだ。",
              "citation": {
                "source": "重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二号病室の廊下まで来ると、ふとＹさんが入室してゐるのに気づき、這入つて見舞ふ。",
              "citation": {
                "source": "重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "五号に入室してゐるＮを見舞つてやらうかと思ひ出したが、やめる。",
              "citation": {
                "source": "重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日九号病室へ入室なさい、と。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "入室は夕方なので女の人に頼んで虫ぼしをやつて貰ふ。",
              "citation": {
                "source": "続重病室日誌",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
