[
  {
    "uuid": "cf7463f0-466a-5df0-ad67-015d2d7a55a3",
    "entry": "煮付け",
    "reading": {
      "primary": "につけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
