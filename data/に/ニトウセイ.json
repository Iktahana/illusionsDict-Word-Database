        "examples": {
          "standard": [
            {
              "text": "夜空には、きらめく一等星と、それに次ぐ明るさの二等星が多数見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの星座の中で一番明るい星は一等星だが、その隣の星は二等星だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "望遠鏡を使えば、肉眼では見えにくい暗い二等星も観察できる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして新星はかなり天頂に近く白鳥座の一番大きな二等星と光を争うほどに輝きまたたいているのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "良夜鮮麗なは良夜の一二等星。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一等星、二等星、生れたての幽かな星。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
