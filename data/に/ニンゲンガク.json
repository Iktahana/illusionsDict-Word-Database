    "definitions": [
      {
        "index": 1,
        "gloss": "philosophical anthropology",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
