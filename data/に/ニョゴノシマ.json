    "definitions": [
      {
        "index": 1,
        "gloss": "mythical island inhabited only by women",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雑魚寝の女護の島で、宿酔の海豹が恍惚と薄目を開けると、友染を着た鴎のような舞子が二三羽ひらひらと舞込んで、眉を撫でる、鼻を掴む、花簪で頭髪を掻く、と、ふわりと胸へ乗って、掻巻の天鵞絨の襟へ、笹色の唇を持って行くのがある。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬまでにいっぺん大奥の女護の島へお参りしてえと思ってたんだからね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "『宛で女護の島だね。",
              "citation": {
                "source": "東光院",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此家へ來ると女護の島へ來たやうな氣がしまんな。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さうだツか、あんたは女護の島ちうとこへ行きなはつたことあるんやな、えらい運のえゝ人や。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "「猪のはん、女護の島へ行きなはつた折の話しとくなはれ、猪のはんみたいな男でも、女子はんが大勢で引ツ張らはりましたやろ。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "女護の島へ十人も荒くれ男を泊めるんで、今朝から二人がテンテコ舞をしてるやおまへんか。",
              "citation": {
                "source": "兵隊の宿",
                "author": "上司小劍",
                "note": "青空文庫"
              }
            },
            {
              "text": "錢形平次が御輿をあげて、髮切り詮索に女護の島へ行つてくれさうも無いとわかると、大して落膽した風もなく、ヒヨイとお辭儀をすると、もう彌造なんか拵へて鼻唄をそゝり乍ら歸つて行く八五郎です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "茶汲み四人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺にも解らねえ、二日でも、女護の島みたいな寮に引止められていたんだから、手前も少しは智恵が付いたろう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鈴を慕う女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺にも解らねえ、二日でも、女護の島見たいな寮に引止められて居たんだから、手前も少しは智惠が付いたらう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鈴を慕ふ女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――その賑やかなことと言ったら、まるで女護の島だ」「亭主の造酒助が居る筈じゃないか」「女六人に男一人と来ると、男なんてものは影が薄くなりますね。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから三日目の朝、「サア大変だ、親分」　などと八五郎が飛込むまで、平次は女護の島へ行った八五郎の「女に対する甘さ」ばかり心配して居たのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "腰抜け彌八",
                "note": "青空文庫"
              }
            },
            {
              "text": "あつしに來てくれといふのは、市ヶ谷で評判のたけえ女護の島」「そんな變なのが江戸の眞ん中にあるのか」「へツ、あるから不思議で。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "ね親分、近頃あつしに汗を掻かせる程の仕事もないから、ちよいと洒落に、女護の島の用心棒に行つて六人の女の子にチヤホヤされながら一と週りも保養して見ようかと思ふんですが」「宜い氣なものだ」　錢形平次もそれを強ひて留めませんでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "女護の島から追ひ出されたのか」　平次は相手欲しさうでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　女護の島と言はれた市ヶ谷の上總屋に、續け樣に起つた、二つの怪事件、――エロチツクで、殘酷で、無恥で横着な事件は用心棒になつて泊つてゐた八五郎を、すつかり間拔けの標準にしてしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "事件落着の後、八五郎は相變らず、この『女護の島異變』の繪解きを平次にせがみました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "女護の島異變",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、千代田の大奥に、ただいまどのくらいの女中がいるか知らないが、それらはみな、女護の島の別世界をなして、幸いを望んでいる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ユルコトヲ得ザルモノ三十六年……　そこで一座は笑いながら、三十六年も大げさだが、これら女護の島の女人たちの多くが、性の悩みに堪えきれないでいることだけは明らかな事実で、その関を突破さえすれば、洪水のように流れ出して来るのだという。",
              "citation": {
                "source": "大菩薩峠",
                "author": "みちりやの巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "成る程、そこの一廓は男子禁制の女護の島であるけれども、外廻りには要所々々に番兵が立ち、晝夜の分ちなく見張りの眼が光っているのである。",
              "citation": {
                "source": "武州公秘話",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに男子禁制の女護の島、風の便りに似たような追憶談に過ぎませんが、まず女役者について申し上げる。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
