    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第一人間を偽善にする。",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "注意せよ、世には甚だ見分け難い偽善がある！",
              "citation": {
                "source": "詩と詩人",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自嘲の習慣を持つてゐたので、自分の作品への偽つた解釈をちよいちよいやつてゐる。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それにも関らず、私は此の詩集に現はれた、彼の驚くべき表現と、そのすばらしい人格的感情のリズムの前には、偽りなき敬虔の心で頭をさげざるを得ないものである。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "先輩らしい忠告なんて、いやらしい偽善だ。",
              "citation": {
                "source": "織田君の死",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「散文が結果的に一つのイデーの下に凝集してゐるに対し、詩は一つのイデーから出発する」といふ河上氏の言を借用するとして、その真偽如何を問はず、詩が欲しくなる時、詩人は「一つのイデーから出発」してゐるもの即ち詩に赴くのであつて、他の物へではない。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京は面白いですか」　彼は窓の外をみて偽へて笑つてゐた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し捕ってりゃ偽物だよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "偽物でも何でも捕えようと思って慌ててるこったろう。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、しゅくしゅく鳴きながら苦しみを訴える鹿の眼の懸命に戸惑う瞳の閃きに一点の偽りもないのを見ると掻き抱いてやり度いようだった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はそのかみ、神武御東征のとき、偽者土蜘蛛と呼ばれ、来目の子等によって征服されて帰順した、一党の裔であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その真偽はとにかく、彼女からこういううぶな態度を見たいためにも、若い女たちはしばしば訊いた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "x＝bb＝a∴ x＝aしてみると、形式論理学で媒概念曖昧の虚偽という奴だな。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから虚偽が起ったのだ。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔ある国での話であるが、天文の学生が怠けて星の観測簿を偽造して先生に差出したら忽ち見破られてひどくお眼玉を頂戴した。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際一晩の観測簿を尤もらしく偽造するための労力は十晩百晩の観測の労力よりも大きいものだろうと想像されるのである。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "真偽の程は保証の限りでない。",
              "citation": {
                "source": "新年雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人殺しをしようが詐偽をしようがそんなことは最初から誰も引受人はないのである。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また『武道伝来記』には、ある武士が人魚を射とめたというのを意地悪の男がそれを偽りだという。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『桜陰比事』で偽山伏を暴露し埋仏詐偽の品玉を明かし、『一代男』中の「命捨ての光物」では火の玉の正体を現わし、『武道伝来記』の一と三では鹿嶋の神託の嘘八百を笑っている。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また例えば『桜陰比事』二の三にある埋仏詐偽の項中に、床下の土を掘っても仏らしいものは見えず「口欠の茶壺又は消炭螺からより外は何もなかりき」とある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには尊い真は失われて残るものは虚偽と醜陋な悪趣味だけである。",
              "citation": {
                "source": "漫画と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で他人の酔つたり狂つたりして、常規を失するやうな言動が皆虚偽のやうに見えたらしい。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが生活の虚偽残酷にあきれてしまった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし『古事記』が、平安朝になってから偽造されたものとすれば、これほど厳重に仮名を遣い分けることが出来るかどうか非常に疑わしいと言わなければなりません。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう点からも偽書説は覆すことが出来ると思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう点から、この書は偽書でなかろうということが出来るのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識とは少しちがう「智恵」については第三十八段に「智恵出でては偽あり」とか「学びてしるは、まことの智にあらず」などと云っているのは現代人にも思い当たるふしがあるであろう。",
              "citation": {
                "source": "徒然草の鑑賞",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画の頂点はヒロインが舞台で衣裳をかなぐり捨てブロンドのかつらを叩きつけて煩わしい虚偽の世界から自由な真実の天地に躍り出す場面であって、その前のすべてのストーリーはこの頂点へ導くための設計であるように見える。",
              "citation": {
                "source": "映画雑感（５）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人夫よ　はやく夏草を刈りつくせ狼火をあげよ　烟を空にたなびかせよ空想の陣幕を野邊にはつてまぼろしの宴樂をほしいままにせよ。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
