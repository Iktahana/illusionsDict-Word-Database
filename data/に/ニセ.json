[
  {
    "uuid": "2e3b87e4-0ded-5e5f-94d2-5c2feda7c7ae",
    "entry": "偽",
    "reading": {
      "primary": "にせ",
      "alternatives": [
        "ニセ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
