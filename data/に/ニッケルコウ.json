        "examples": {
          "standard": [
            {
              "text": "船舶のプロペラには、海水による腐食を防ぐため、ニッケル鋼が用いられることがあります。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この工具は、ニッケル鋼の採用により、高い強度と靭性を実現しています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "ニッケル鋼は、機械部品の製造において、その信頼性の高さから広く利用されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これには前述の二十三プロセントニッケル鋼を羅針盤の近傍必要の箇所に使ったらよいというので、目下ブレメンで新造中の船にはこれを採用するはずになっている。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
