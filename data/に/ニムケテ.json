    "definitions": [
      {
        "index": 1,
        "gloss": "towards (a destination)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
