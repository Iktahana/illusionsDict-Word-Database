[
  {
    "uuid": "fbf97479-47ed-57dc-a5b5-dc448392022f",
    "entry": "入居",
    "reading": {
      "primary": "にゅうきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
