        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本有数という形容は、そのまま世界有数という実相なのだから、自重しなければならぬ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学士ではなかったがしかし非常に篤学な人で、その専門の方ではとにかく日本有数の権威者だという評判であった。",
              "citation": {
                "source": "埋もれた漱石伝記資料",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも聞けば日本有数の大実業家だという。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お家騒動の張本人を、森帯刀様と仮定すると、その連累が大鳥井紋兵衛、それから大槻玄卿なる者は、日本有数の蘭学医、信州の天野か江戸の大槻かと呼ばれ、俺と並称されている。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "余談はさておき、果して阪中君は、日本有数の劇詩人（実は戯曲家）たり得る資格を示したのである。",
              "citation": {
                "source": "中村・阪中二君のこと",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "下野薬師寺は奈良の東大寺、筑紫の観音寺と共に天下の三戒壇、鑑真の開基で、日本有数の名刹だつた。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽黒公爵家は日本有数の大名門。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、押しも押されもしない日本有数の舞台監督です、芸術家です。",
              "citation": {
                "source": "公開状",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "国電、都電にも近く、ドロボー君のアジトとしては日本有数の好点。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕作面積が猫の額ほどしかない山国の飛騨の農家がはるかに立派で、日本有数の米どころたる新潟や秋田の農家が他国の農家の馬小屋の如くに貧困極まるものだというのはウソのような話だ。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "秋田犬訪問記――秋田の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの数字は、運輸方面では、日本有数のエキスパートＳ君の話であるから、十分信用していいと思う。",
              "citation": {
                "source": "北国の春",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下野薬師寺は奈良の東大寺、筑紫の観音寺と共に天下の三戒壇、鑑真の開基で、日本有数の名刹だった。",
              "citation": {
                "source": "道鏡",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗方博士は海水中の微生物研究では日本有数の権威者で今度この近海に発生した夜光虫の研究をするため、三人の助手と令嬢を伴れて移って来たのであった。",
              "citation": {
                "source": "廃灯台の怪鳥",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」のキャプション付きの図（fig55990_688.png、横200×縦280）入る］図‐688　翌日は、日本有数の陶工の一人である永楽を訪問した。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本有数の権威者である）英訳出来なかった平次捕物控　野村　蒐集したレコードを保存するのに鉄筋コンクリートの倉庫でも建てたいと思っているんだが……。",
              "citation": {
                "source": "探偵小説このごろ",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士の答は、学問的には抱琴が上だし、実用語学は露子がうまい、いずれにしても、日本有数のフランス語学者が生れるに違いないと太鼓判を押した。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きていたら間違いもなく日本有数の人材になったと思われる原抱琴と岩動露子（本名は孝久）のためにやはり一度は書いておきたい。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "川村氏は日本有数の彫刻家です。",
              "citation": {
                "source": "黄金仮面",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
