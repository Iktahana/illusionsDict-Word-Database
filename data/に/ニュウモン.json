    "definitions": [
      {
        "index": 1,
        "gloss": "becoming a pupil (of)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最近漸く大學豫科の一年生位に入門して來た。",
              "citation": {
                "source": "初めてドストイェフスキイを讀んだ頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句をはじめるまではさっぱり気づかずにいた自然界の美しさがいったん俳句に入門するとまるで暗やみから一度に飛び出してでも来たかのように眼前に展開される。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡警は、公司の証明書を持たない者には、一切入門を拒絶した。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから「西遊記」、「椿説弓張月」、「南総里見八犬伝」などでやや「人情」がかった読み物への入門をした。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い身空で下寺町の豊沢広昇という文楽の下っ端三味線ひきに入門して、浄瑠璃を習っていた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の著書の中で、比較的初学者に理解し易いと言はれ、したがつて又ニイチェ哲学の入門書と言はれるアフォリズム「人間的な、あまりに人間的な」でさへも、相当に成育した一般の文化常識と、特に敏感な詩人的感覚とを所有しない読者にとつては、決して理解し易い書物ではない。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に標題の示す如く、正に『詩の原理』であるけれども、普通に刊行されてる詩書の如く、単に韻律音譜の註であったり、名詩の解説的批判であったり、初学者の入門的手引であったり、或は独断的詩論の主張であったりするものとは、全然内容が異っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宇万伎は、彼が入門するとたちまち弟子よりもむしろ友人、あるひは客員の待遇をもつて、彼に臨み、死ぬときは、彼を尋常一様の国学者でないとして学問上の後事をさへ彼に托した。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼休みの時間に、僕は教室にひとり残って、小山内薫の「芝居入門」を読んでいたら、本科の鬚もじゃの学生が、のっそり教室へはいって来て、「芹川は居らんか！",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は、小僧でかした、その意気じゃ、と言って入門をゆるすという事になる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小山内薫「芝居入門」。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』に気づくべき筈なのに、帰りて、まず、唯物論的弁証法入門、アンダラインのみを拾いながらでもよし、まず、十頁、読み直せ。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長順　ふむ、何を隠さう――徒らに俗世間の義理人情に囚へられ、新しき教の心もえ覚らぬ俗人｜原、あの老耄の痩首｜丁切り、吉利支丹宗へわが入門の手土産にな致さむ所存。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一の所化　何と、吉利支丹へ入門とな。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下寺町の広沢八助に入門し、校長の相弟子たる光栄に浴していた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて天保三年の春、師家へ入門の手続をして直ぐに秘曲「翁」の相伝を受けた。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に利春十六歳と伝えられているが、これはその時代の事であるから直接上京して入門した訳ではないようである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「武士の子たる者が乱舞を習わぬというのは一生の恥じゃ」　といった論法で、面喰っている筆者の手を引いて中庄の翁の処を訪うて、翁の膝下に引据えて、サッサと入門させてしまった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "筆者は三歳ぐらいから祖父に仕込まれていて、翁の処へ入門した時は数番の謡を丸暗記していたのでイキナリ本番を習ったものであったが、むろんこちらから曲目を撰む事は出来なかった。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大阪から来たばかりの青年で、まだ土居さんに入門しない前だつた。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "下寺町の広沢八助に入門し、校長の驥尾に附して、日本橋筋五丁目の裏長屋に住む浄瑠璃本写本師、毛利金助に稽古本を註文したりなどした。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "沢は、隔てなく身の上さへ話したが、しかし、十有余年崇拝する、都の文学者｜某君の許へ、宿望の入門が叶つて、其のために急いで上京する次第は、何故か、天機を洩らすと云ふやうにも思はれるし、又余り縁遠い、そんな事は分るまいと思つて言はなかつた。",
              "citation": {
                "source": "貴婦人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして神戸大学文学部を中退して、米朝に入門。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間に私は安国寺さんにドイツ文の哲学入門の訳読をして上げる。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで安国寺さんは哲学入門の訳読を、私にして貰う代りに、Ｆ君にして貰おうとした。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は Koeber さんの哲学入門を開いて、初のペエジから字を逐って訳して聞せた。",
              "citation": {
                "source": "二人の友",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃或日金井君は、教場で学生の一人が Jerusalem の哲学入門という小さい本を持っているのを見た。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは吉原入門ともいうべき講義である。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日前に巻き上げた縁先の簾が、ばたんばたんと音をたてて、私はお座敷の隣りの間で、ローザルクセンブルグの「経済学入門」を奇妙な興奮を覚えながら読んでいた。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子珍事由を語ると、その人我は渤海郡の生まれ、李玄石と名づく、やはり辺先生の所へ学びに往く、かく道伴れとなる已上は兄弟分になろうと言い出たので、子珍も同意し、定州に至り飲酒食肉し、死生、貴賤、情皆これを一にせんと誓いおわって辺先生を訪い入門した。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            }
          ]
        }
