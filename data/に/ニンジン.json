    "definitions": [
      {
        "index": 1,
        "gloss": "carrot (Daucus carota)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
