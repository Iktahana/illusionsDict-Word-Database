        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雇人は豹一が何故そんなことをするのか分らなかったが、たゞ何となく憎たらしい子供であると思った。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀代子は口をひらけば必ず傲慢な、憎たらしいことを言う豹一よりも、おずすおずと黙っている豹一の方が好きなのである。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはもってる」　こういうときの高志は、ほんとうに憎たらしい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうだい、あの山高帽子をアミダに被つて頬つぺを突つぷくらせてゐる憎たらしい面つきと云つたら……」「狒々親爺奴が！",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が彼に、鼻曲りといふ形容詞を冠したのは、彼の野蛮な皮肉味を抽象的に指さしたのであつて、実物の彼の鼻は、いつも私に昔噺の中にある業慾者の鼻にぶらさがつたといふソーセージを想像させる態の、赤味の滲んだ肉附き豊かな、何とも憎たらしいごろん棒であつて、決して曲つてゐるといふわけ合ひではない。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "憎たらしい、横柄な口も利かなくなった。",
              "citation": {
                "source": "秋の反射",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんのうぬぼれがいい加減でやまるように、その憎たらしい大頭のちょん切られるところを、ゆっくり拝見するとしましょうよ。",
              "citation": {
                "source": "アッタレーア・プリンケプス",
                "author": "ATTALEA PRINCEPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が、あんな憎たらしい子供に金なんかやるものかと私はチヱリーを買つたことを吻として考へたのだけれども、あの子供は、雨の中を濡れながら、あの髪を剪つた女はいまいましい奴だつたと、一時間や二時間は私を呪つてゐるのだらうと思つた。",
              "citation": {
                "source": "子供たち",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そりゃ、男衆にだったら、そんな時の小式部さんをさ――あの憎たらしいほど艶やかなししむらなら、大抵まあ、一日経っても眼が飽ちくなりやしまいと思う」　とお筆でさえも、上気したかのように、そこまで語り続けたとき、彼女はいきなり言葉を截ち切って、せつなそうな吐息を一つ洩らした。",
              "citation": {
                "source": "絶景万国博覧会",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、内角が外角に変ってしまうのですが、いまあの生物は引ん曲った溝を月の山のようにくねらせて、それは長閑な、憎たらしい高鼾をかいておりますの。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、憎たらしいじゃありませんか。",
              "citation": {
                "source": "ジロリの女",
                "author": "――ゴロー三船とマゴコロの手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど可愛らしさといふものゝない、たゞ憎たらしい傲慢なヒネクレ者であつた。",
              "citation": {
                "source": "石の思ひ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それほど可愛らしさというもののない、ただ憎たらしい傲慢なヒネクレ者であった。",
              "citation": {
                "source": "石の思い",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし女の態度はいかにも憎たらしいし、作為的だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "東京ジャングル探検",
                "note": "青空文庫"
              }
            },
            {
              "text": "年寄りは頑固なものとは言ひながら、自説をひとつ持ち合して、人の言葉に耳をかさない強情さが憎たらしい。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「金魚の子は可愛いね、きみのように大きくなると、憎たらしいところが出てくるけれど。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ憎たらしい、こんな綺麗な体してて、――うちあんた殺してやりたい。",
              "citation": {
                "source": "卍（まんじ）",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……光丸がいないんですか」「まあ、白ばくれて、憎たらしいこと。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もっと太った憎たらしい首よ」　女は命じました。",
              "citation": {
                "source": "桜の森の満開の下",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつだって憎たらしい婆あではあるが、このときほど、俺は婆あを憎いと思ったことはない。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれただの人間が後生大事にかかえているその個性なんか、その「我」なんか、憎たらしいどころか、空の空であり虚無なのだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "にくたらしい犬のまねをして唸つたり吠えたり、猫のなき声をしたり、両腕を羽ばたいて鶏のなき声をしたりした。",
              "citation": {
                "source": "荒野の呼び声",
                "author": "THE CALL OF THE WILD",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
