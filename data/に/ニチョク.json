[
  {
    "uuid": "2f59e1f1-f177-5229-84af-c4e11861b5c6",
    "entry": "二直",
    "reading": {
      "primary": "にちょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
