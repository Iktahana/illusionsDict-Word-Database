        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それぞれ外人たちが各部屋へ戻って来たころ荷降ろしもみな済んだと見え列車はまた動き始めた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく喋る女で、喧嘩安の細君お政をつかまへて稲荷降ろしの『おじゆう』の噂をして居るのである。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのマロニエのあたりは、馬車の荷降ろしを見に来た好奇者でいっぱいだったそうである。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜ルーマニア人が浮気の虫を……におろしに行った間、「――おい、Ｙ、今晩はおれにつきあえよ――」　と、貴女が云ったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、父のおっしゃる言葉をちっとも聞こうとなさらず、腕を伸ばして私の傍の七輪のお鍋を、どさんと下におろして、あちちと言って右手の親指と人さし指を唇に押し当て、「おう熱い、やけどしちゃった。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら、背中の荷物をみちのまんなかにおろしました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舟が又こっちへ戻るまで斉藤平太は大トランクを草におろし自分もどっかり腰かけて汗をふきました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いながら片っぽうのはじをぬいて下におろしましたのでみんなはそれをはね越えて中にはいりました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴーシュの畑からとった半分熟したトマトをさも重そうに持って来てゴーシュの前におろして云いました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ゴーシュはおっかさんのねずみを下におろしてそれから弓をとって何とかラプソディとかいうものをごうごうがあがあ弾きました。",
              "citation": {
                "source": "セロ弾きのゴーシュ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうだ、ありがたかろう」　床の正面に、半分枯れかかった樺色と白との野菊を生けて、駄菓子でこね上げたような花瓶のおいてあったのを、障子の隅におろしてしまって、その代りに自分の懐ろから制帽を取りだして恭しく飾りながら、ガンベが拝むような様子をしてこういったっけ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには先着の勃凸が、ハンティングの庇を眉深かにおろし、トンビの襟を高く立てゝ私達を待ち受けてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理卓の上にはアンショア（ひしこの塩漬）の三枚におろしたのが昨日からオリーブ油に浸けられている。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを和蘭の馬鈴薯を雪の様におろしてオリーブ油、酢、塩、胡椒で味をつけた中へなかば埋める。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言ひながら、背中の荷物をみちのまんなかにおろしました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして荷物をどっかり庭におろして、おかしな声で外から怒鳴りました。",
              "citation": {
                "source": "とっこべとら子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那さん、先ころはどうもありがどうごあんした」　あの山では主のような小十郎は毛皮の荷物を横におろして叮ねいに敷板に手をついて言うのだった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい方は、まるい赤い光るものを大事そうに草におろして、うやうやしく手をついて申しました。",
              "citation": {
                "source": "貝の火",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで耕一は今度は傘をさして行こうと思って足駄を下におろして傘を開きました。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「話してあげるからおまえは鞄を床におろしてその上にお座り。",
              "citation": {
                "source": "黄いろのトマト",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男はブドリを地面におろしながらぶりぶりおこり出しました。",
              "citation": {
                "source": "グスコーブドリの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前が青白く真暗くなりそうになって力なく鼓を膝の上におろした。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はプラトンの説を駁して真理を「天上」から「下界」におろし、「観念」から「実体」に現実させた。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊を下におろして、栄蔵に持つてゐて貰ふことにした。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく三枚におろして、お味噌につけて置くことにしよう。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、伊平は気味の悪い持ち物を縁側におろした。",
              "citation": {
                "source": "西瓜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "畳の上におろしてやると、もうすぐそこにある紙切れなどにじゃれるのであった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤子の首筋をくわえて庭のほうへ行こうとしているかと思うと、途中で地上におろしてまたなめころがしている。",
              "citation": {
                "source": "子猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうか」　万戸もにっと笑って愛卿を下におろした。",
              "citation": {
                "source": "愛卿伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうして私と探偵との手を借りて、その死骸を下におろして、うやうやしく被いものでおおった。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
