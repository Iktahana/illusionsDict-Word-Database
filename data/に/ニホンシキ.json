        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雑喉場の前に日本式の小さい帆前が一艘ついて、汀には四、五人ほど貝でも拾っている様子。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にオリーブ油で日本式の天麩羅にするといい。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「珍しい」「前例のない」ほうの 〔apra_pya, apurva〕 でも、やはり日本式ローマ字で書くと p+r+b(m) の部類にはいる。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばＡ日本語とＢ英語の場合ならば、まず日本語のほうを、かりに「日本式ローマ字」で書く、しかして英語子音の「文字」の中で日本式にないものはかりに後者のどれかで「置換」する。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はその当時とまったく違った俳優たちが純日本式のプロダクションを見せるという、それが観客の人気を呼んだらしいのです。",
              "citation": {
                "source": "米国の松王劇",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらには目もくれず、「ほほほ、日本式ではないんだわねえ、貴下、お気には入りますまい。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は李多というのが本名であるが、堀部君の店では日本式に李太郎と呼びならわしていた。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲賀三郎氏の「従弟の死」を読んで、純日本式の「良心の遊戯のモノスゴサ」がズンズン開拓されつつある事を知ったのも、それから後の事でした。",
              "citation": {
                "source": "江戸川乱歩氏に対する私の感想",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "純日本式の思想もあれば、支那、印度の思想も取り入れられている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、一方ではまた、先生が好きであったと称せらるる某女史の顔は、これらとは全くタイプのちがった純日本式の顔であった。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "注文の大体は、今度は純日本式の童男童女の並んで立っている処をたのむというのであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "引き続き作に苦心したこと",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は在来りの手も力もない日本式の女性とは違うんですからね。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが徳川の天下になると、今度は江戸城下の新開地に日本各国の人民が集まって、ここに日本式最初のプロ文化を作り始めた。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが又大部分が中等以下の安バラック式で、何の事はない、目下の丸の内は、西洋式の大建築と日本式のゴチャゴチャした小店を詰め込んだ、極端な和洋折衷の姿である。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも久し振りで日本式の風呂に入って、日本の畳の上にあぐらをかいて、日本の浴衣の胸をくつろげて、団扇をばさばさと使った心持は、なんともいえないほどにのびのびしたものであった。",
              "citation": {
                "source": "探偵夜話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは最初西洋から渡つた武術でありますけれども、日本人が一種の利用法で日本式な小銃の術をやつたのであります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "お京はおとなしい性質で、日本式の娘型。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは非常に都合の好い話だから、願はくば多数の力でエスペラントの日本式スタイルを作つて、日本語の精神でエスペラントを使つて世界の人を相手にドシドシ著作の出来るやうにしたい。",
              "citation": {
                "source": "エスペラントの話",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから滅多に日本式の宴会には出席しようとしない。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "本野子は自分ひとりでさう／＼食べるのは勿体ないといつて、その頃｜和蘭公使を勤めてゐた珍田拾巳子を、わざ／＼アムステルダムから、呼び寄せて日本式の晩餐会を開いた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近は純日本式の卓抜な方法が成功しつつある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "石炭液化も今日まで困難な路を歩んで来たが、そろそろ純日本式の簡単で優秀な世界無比の能率よい方式が成功しつつある。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱靴だけは日本式であるが、田舎出身の兵隊に、慣れない腰掛を強制し、また窮屈な寝台に押し込んでいる。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "軍事学については、戦術方面は体験的であるため自然に日本式となりつつあるものの、大戦略即ち戦争指導については、いかに見てもモルトケ直訳である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本式に言って、十畳敷ぐらいの室内は、至極あっさりした飾り方であって、金庫と、机と、煖炉と卓子と、三脚の椅子とがあったが、別にはげしい格闘の行われた形跡はなく、黒｜羅紗の洋服を着た死体は煖炉の前に頭を置き、両足を机の方にさし出して、リノリウム敷の床の上に、仰向けにたおれていた。",
              "citation": {
                "source": "謎の咬傷",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "通俗的な日本式庭園の型をまねて更に一層貧弱な結果を示したに過ぎない。",
              "citation": {
                "source": "素朴な庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、牢やの中のあばずれは、ともかく表現したこの女優が、この人間的飛躍のクライマックスでしめした日本式転身の姿に、うたれた。",
              "citation": {
                "source": "復活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、何たる日本式！",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのような日本式談合万端にこそ抵抗しているわれわれではないだろうか。",
              "citation": {
                "source": "「下じき」の問題",
                "author": "――こんにちの文学への疑い――",
                "note": "青空文庫"
              }
            }
          ]
        }
