          "literary": [
            {
              "text": "入選者はその伎倆に應じて、相當の職業に從ふ。",
              "citation": {
                "source": "支那の宦官",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "小谷剛は「確証」によつて入選者の一人と決定したが、私は、ただ祝意を表するだけで讃辞は保留する。",
              "citation": {
                "source": "清潔な文章を買ふ",
                "author": "――芥川賞（第二十一回）選評――",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会も甘くして入選者の御機嫌ばかりとっていないで厳選にして呉れた方が観る方は助かる。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
