          "standard": [
            {
              "text": "京都には、平安時代に定められた二十二社と呼ばれる特別な神社群がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は日本の歴史、特に二十二社に関する深い知識を持っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "二十二社巡りは、日本の古き良き文化に触れる素晴らしい機会だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "西宮廣田神社の祭神が天照大神即ち大日靈尊のに荒魂であると云ふ説（「日本記」）も明かに學人の後作説であつて、寧ろ神功皇后とも八幡同體とも云ふとした俗傳（「二十二社本縁」）の方が眞相に近い。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
