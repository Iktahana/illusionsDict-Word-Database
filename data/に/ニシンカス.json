          "literary": [
            {
              "text": "金肥えの鰊粕を食う。",
              "citation": {
                "source": "名勝地帯",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "釜の中のは鰊粕であろう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰊粕、強突張り、どうするか見ていやがれ、と、こりゃあてめえの怒るのが無理はありますめえ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "岸野が売り残して年を越したために、検査に落ちて、どうにもならなくなった鰊粕を、俺達の農場の方へ送り込んで寄こして、それを検査品と同じ値段で売っていることは、知っている筈だ。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげん煮熟すると螺旋圧搾器にかけて油をしぼり、鰊粕をとる。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
