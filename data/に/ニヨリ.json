    "definitions": [
      {
        "index": 1,
        "gloss": "similarity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何、玉香が、香玉でも、女亡じゃは大抵似寄りだ、心配しなさんな。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この帶の隣には又似寄りたる帶を引きて、その間をば暗紅なる花もて填めたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "その何れにせよ、反省は経験の結果を似寄りの部門に選び分ける。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "又色彩を強く表はす為めに、その隣りにある似寄りの色彩を抄略するだらう。",
              "citation": {
                "source": "描かれた花",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これもそれと似寄りの話で、やはり十七年の秋と思う。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その魚籠のなかには、三匹の蟹が入れてあったので、こっちに準備してある七匹の蟹と引合せて、それに似寄りの大きさのを一匹買おうとしたところが、その小僧は遠いところからわざわざ連れて来られたのだから、三匹をみんな買ってくれというのです。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これも似寄りの話で、陸奥国南津軽郡大鰐という所に長者があり、その家に一人の息子がありました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかりといえどもこれみな東洋の文物のみ、東洋人種のやや似寄りたる国々にありてはその風俗習慣の根柢また相似たるものあり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、西洋人の書いたものに余り似寄りの話を見た為、とうとうそれなりになつてしまつた。",
              "citation": {
                "source": "蒐書",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あっちで又、似寄りの仕事があるのです。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の身として似寄りの死体が出たら、きっと見に行った事であろう。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之と似寄りの話が明時代にもある。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "我が國でも黒船來航の當初、吉原あたりから似寄りの策略を幕府に獻議したといふが、これは北里の忘八輩の猿知慧に過ぎぬ。",
              "citation": {
                "source": "支那人の妥協性と猜疑心",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "張継の詩で有名な寒山寺横の楓橋あたりの運河の眺めは、平凡ななかに特殊な風趣を含んだものであるが、それに似寄りのものでも一つ上海郊外に欲しいと思われるのであった。",
              "citation": {
                "source": "上海の渋面",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに似寄りの染粉も、みんなになつてしまつたのだ。",
              "citation": {
                "source": "虹猫と木精",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は、わしと似寄りの渡世をしているもの――わけあって、何事につけ、共に事をしようと、約束のあるお人だ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに似寄りの定義は、あっても役に立たぬことはない。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "河の堤防などは似寄りのものもなく、彼方の高台は広い谷中の墓地で、田舎に見られない五重塔が聳えています。",
              "citation": {
                "source": "白蛾",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう云う処に居ると、私と似寄りの年頃の話し相手はまるで出来ない。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに似寄りの夫婦よ。",
              "citation": {
                "source": "或る男の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "亡父や兄に似寄りの点を自分の顔貌の中に見出して、どうかすると悲観することはあってもね……。",
              "citation": {
                "source": "不肖の兄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見はこの伝説を聞いたとき、テニスンに似寄りの詩があったことを想起した。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "長兄のお書きの伊沢蘭軒の伝にも、似寄りの話が出ています。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、はいって来たお坊さんの顔を見ると、それは彼とは似寄りの点もない人だった。",
              "citation": {
                "source": "或る女の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "然らば或る事の将来を論ずるに当つては、嘗て既往の歴史中に起つた似寄りの事件の成り行きを調べて、参考し比較する事は甚だ必要である。",
              "citation": {
                "source": "人類の将来",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "従兄弟の年齢も互に似寄り、もの学びしては師匠より教を受けし書をさらえ、事を相談しては父母の命をそむかぬ如く計うは、みな他人にて届く事にあらず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓮の花の開く時の音はポンという言葉で形容されているが、どうもそれとは似寄りのない、クイというふうな鋭い音である。",
              "citation": {
                "source": "巨椋池の蓮",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくばかり我に信なきともがらに、なにのかかはりあるべしやは、空しく坐して祈り、遠き遍路に消え殘る雪を光らしむ、いのちはひとりのもの、ただ我が信願をかくるにより、木ぬれにかかり、有明の月もしらみてふるへ悲しめり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なによりも、怪談がいちばん僕の空想力を刺激するようです」「こんな怪談はどうだ」馬場は下唇をちろと舐めた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓋し、今仮りに文学よりも絵画の方により多くの関心が注がれてゐると云ひたい人があつたとすれば、それはその人自身が文学よりも絵画の方を好きなのであらう。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
