  {
    "uuid": "cedf2315-92bc-57a2-8a91-b1c974536334",
    "entry": "に因り",
    "reading": {
      "primary": "により",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
