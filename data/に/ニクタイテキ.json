[
  {
    "uuid": "00e9332b-a1db-5382-b936-e6dc3063dfc9",
    "entry": "肉体的",
    "reading": {
      "primary": "にくたいてき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞"
