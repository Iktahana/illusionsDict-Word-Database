        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "佐竹の顔は肌理も毛穴も全然ないてかてかに磨きあげられた乳白色の能面の感じであった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その雨の中を漂ひながらいつだか消えてなくなつた、あの乳白の※嚢たち……今や黒い冬の夜をこめどしやぶりの雨が降つてゐて、わが母上の帯締めも雨水に流れ、潰れてしまひ、人の情けのかずかずも竟に蜜柑の色のみだつた？",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "萌えさかつた堤の青草は霧のやうな乳白色を含んで、河原の川柳はそよ風にざわ／＼と騷いではゐたが、雨の脚はまだ何處にも見えなかつた。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕刻近いシャンデリヤの仄白い光は、人いきれで乳白に淀んでいた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐竹の顏は肌理も毛穴も全然ないてかてかに磨きあげられた乳白色の能面の感じであつた。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四肢は気品よく細長く、しっとりと重くて、乳白色の皮膚のところどころ、すなわち耳朶、すなわち頬、すなわち掌の裡、一様に薄い薔薇色に染っていて、小さい顔は、かぐようほどに清浄であった。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の方は氷河の陰翳の如く、上に行くにつれ、暗い藍から曇った乳白に至る迄の微妙な色彩変化のあらゆる段階を見せている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中に、乳白色の光が溢れるように遍照するのを感じた。",
              "citation": {
                "source": "極楽",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "形は一握の中に隠るるばかりなれど、能く遠くを望み得る力はほとほと神助と疑ふべく、筒は乳白色の玉もて造られ、僅に黄金細工の金具を施したるのみ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それにも不拘、夫人の指間に盛上って来るあの乳白色の果肉の上には、現場で発見したものと全く同じ様な左巻の皮が嘲ける様にとぐろを巻いているじゃないか。",
              "citation": {
                "source": "花束の虫",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかうの峰には乳白色の靄がかかつてゐたが、こちらの空は真青に潤んでゐた。",
              "citation": {
                "source": "雲雀病院",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い尼御前が、ふつくりとした乳白の手で悩ましくも合掌してゐる木蓮の花。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい今朝がたまでちやんと合掌してゐたらしい乳白の花弁は、だんだん絡み合ひの力がゆるみ、今ではもう最後の一息を待つばかりになつてゐて、まだなかなか開かうとしなかつた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "花はその間に乳白の花弁をぱつと大きく開いてゐた。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "空は連日乳白色にかきくもり、海の水は雄鰊の排出する白子のために米磨ぎ汁を流しこんだように青白色に濁ってくる。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "罌粟粒よりも微小な鉛色の火薬が、砂時計が時を刻むように乳白の電球の中へさらさらと流れ込んだ。",
              "citation": {
                "source": "鼻に基く殺人",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わが愛らしい原稿紙いつも、お前の　懐しい乳白色の面の上に穏やかに遮られた北の日光を漂わせよ夜は、麗わしい台ランプの穏密な緑色のかげを落してわれとともにうたい、なげき、悦びにおどれ。",
              "citation": {
                "source": "五月の空",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたの病気は死ななきゃ治らないと云われて……」　冷え冷えとした内庭に面した病室の窓から向側の棟をのぞむと、夕ぐれ近い乳白色の空気が硬い建物のまわりにおりて来て、内庭の柱の鈴蘭灯に、ほっと吐息のような灯がついていた。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋代に出來た繪高麗は形もいゝし文樣も濶達で、第一白釉の其の白――乳白といふ字を使つていゝのか、こつくりした白で實にいゝ。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "宋赤繪の高雅なことは人の知るところ、乳白釉の上に赤や緑で牡丹文などを描いてゐるのを見かけるが、滋味津々たるもの、但しキヅものでも買はないと非常に高價なものである。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光には、冷たい清冽な敬虔な気品があって、また、それに暈とした乳白色の濁りがあるところは、奥底知れない神性の啓示でもあろうか。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお床に、チュイルレー式の組字をつけた書室家具が置かれてあるところと云い、また全体の基調色として、乳白大理石と焦褐色の対比を択んだところと云い、そのすべてが、とうてい日本においては片影すら望むことの出来ない、十八世紀維納風の書室造りだったのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋燭の灯が、妙に黄ばんでいて、蔀屋の中が、乳白色の、霧のようなもので、満たされているようであった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "（和子は――）　と、寛之助を見ると、よく眠入っているし、その愛らしい睫毛さえ、はっきりと判ったから、安心して、部屋の異状を、見定めようとすると、その乳白色の空気が、薄暗い屏風の背後へ、流れ込むように動いていた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "モヤモヤと川霧が立ちのぼって河が乳白色にぼかされてゆく。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "梨畑が朦朧と煙つた白色の中に薄れてしまひ、つらなつた葡萄棚の輪廓が徐々に融かされてゆくと、はるか向うの薄暗く木立の群がつたあたりにちらちらと見えがくれする病舎や病棟の燈もぼんやりと光芒がただれて、眼のさき六七間の眼界を残したまま地上はただ乳白の一色に塗り潰されてしまふ。",
              "citation": {
                "source": "青春の天刑病者達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と私は強く呼び、乳白色の中にはや半ば消えかかつた彼女の姿がくるりと飜るのを見ると、歩み寄りながら、お待ち、と重ねた。",
              "citation": {
                "source": "青春の天刑病者達",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
