        "examples": {
          "standard": [
            {
              "text": "パソコンの日本語環境を整えることで、快適な作業が可能になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このシステムは、日本語環境に特化した設計が施されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "OSの日本語環境設定を見直し、文字化けの問題を解決した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "出来上がったブックはさっそく、「建築デザイン」、「在宅ワーキング」、「アプリケーション日本語環境」など、ニフティーで出入りしていたフォーラムに登録しました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ当時、アップルがマック上に用意した日本語環境は劣悪だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あったのは日本語環境ではなく、カタカナ環境だった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "初代のイージーワードはまず草一本も育たないカタカナ環境から日本語表示用のフォントを読み込んで立ち上がり、自力で日本語環境を用意した。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "サードパーティはこうしたバカに支えられ、勝手にソフトウエア側からの努力によってマック上に日本語環境を築き始めた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
