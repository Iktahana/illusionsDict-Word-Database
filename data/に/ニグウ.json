    "definitions": [
      {
        "index": 1,
        "gloss": "the Two Ise Shrines",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
