    "definitions": [
      {
        "index": 1,
        "gloss": "journeying to Song China during the Heian and Kamakura periods",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いわく、大日という僧入宋して仏照徳光に参す。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "今月の『新小説』の和辻哲郎氏が「入宋求法の沙門道元」に就いて書いて居られるが、あの中の「即ち十丈の竿のさきにのぼって手足を放って身心を放下する如き覚悟がなくては」という気持、あの「人を救うための求道ではない、真理の為めに真理を究める求道」であるという心境、それを私は求めたいと思います。",
              "citation": {
                "source": "女流作家として私は何を求むるか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃髪して五郎作｜新発智東陽院寿阿弥陀仏曇とは好劇家たる五郎作が、音の似通った劇場の緞帳と、入宋僧※然の名などとを配合して作った戯号ではなかろうか。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "學問や藝術の爲よりも、宗教の爲に入唐入宋した人數の多いのを見ても、容易にこの事情が理會される。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その書は入宋しながらやわらかい和風を特色とし、大燈と好対照をなしている。",
              "citation": {
                "source": "南浦紹明墨蹟",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいう、――先師全和尚｜入宋を企てた時に、その師｜叡山の明融｜阿闍梨が重病で死に瀕した。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく入宋をのばして自分の老病を扶け、冥福を弔ってほしい。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "入宋は自分の死後でも遅くはあるまい」。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならず、仏法の道理を知って、幾分の名誉を得、今入宋｜求法の志を起こしたのも、皆この師の恩でないものはない。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "再会期し難きを思えば、入宋を留め給う師の命もそむき難い。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今身命を顧みず入宋求法するのは、慈悲によって衆生を救い得んためである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年の入宋はお留まりなさるがよい。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一年や半年入宋が遅れたとて何の妨げがあろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年入宋なされば師の命にもそむかず入宋の本意も遂げられる。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしもし自分が入宋求法の志を遂げて、一分の悟りでも開いたならば、たとい一人の人の迷情に背いても、多くの人の得道の因縁となるであろう。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから今度の入宋の決意は翻すことができぬ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何ゆえに「入宋求法」がそれほどに重大であったか。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば当時の入宋求法は、真実の道の探求を意味していたと言ってよい。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに心を動かされ、大船をつくらせて、入宋しようとしたが、船が進水しなかったので、その望みは空しくなった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
