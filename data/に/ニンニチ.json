        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こういう場合に対する上記のＴ博士のいったような注意は、万人が万人日常よくよく心得ていなければならないはずであるのに、今度という今度までついぞ一度も聞いた記憶も読んだ覚えもない。",
              "citation": {
                "source": "鎖骨",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これと同じようなことをドイツ人日本人がやればまずたいていは失敗するから妙である。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子が、だいぶ経験も積んで、巴里郊外の高等学校の予備校の寄宿舎に、たった一人日本人として寄宿した経験談も出た。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨国の住人日本の刻彫師、尾ヶ｜瀬菊之丞孫の菊松、行年積つて七十一歳。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（自然が人間に対する無関心はツルゲニエフの猟人日記中、森で樵夫が倒れ、大木の下積みになりその大木が樵夫を殺す作を見てから兄が一層痛感しているのであった。",
              "citation": {
                "source": "兄妹",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "子二人、實子は既に歸朝、養子のみ留り在り、其人日本料理を調へ饗せらる。",
              "citation": {
                "source": "秘魯國に漂著せる日本人",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからいやなんだ」「でも、猟人日記、……」「うん、あれだけは、ちょっとうまいね」「あれは、農村生活の感傷、……」「あの野郎は田舎貴族、というところで妥協しようか」「私もいまでは田舎者ですわ。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり自分一人日本の寵児になろうとしたのであって、秀吉のために横面を撲られて恐怖した彼が、家康によって撫でられたので、そこまで懐いて来たのであり、秀吉、家康の硬軟二道の外交術が、南洋諸国を、よく日本に馴染ませた一例ということが出来る。",
              "citation": {
                "source": "秀吉・家康二英雄の対南洋外交",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "車から降りると私一人日歸りの皆と別れて森を通り、ただ一軒よりない宿屋へ行つた。",
              "citation": {
                "source": "榛名",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人日本人が混っていて傍へよって来るとお辞儀をして、「今あちらで受け承りましたが、どうも御苦労でございました。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "車中にて逢ふ人日光の紅葉を問ふ。",
              "citation": {
                "source": "日光の紅葉",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めて、ツルゲーネフが「猟人日記」を当時ロシアの進歩的雑誌であった『現代人』に発表したのは二十九歳の年であったらしい。",
              "citation": {
                "source": "ツルゲーネフの生きかた",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧文のものを禁ぜられたのではなはだ困っているが、露は猟人日記、独はゲーテ文集、この二つを幾度も繰返して読むつもりだ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "猟人日記の持主に、あれを出る頃まで借りられるか尋ねてくれ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、鋪道に溢れるような人出に紛れ込もうとした時、私はふと、山崎の陰鬱に光る大飾窓の向い合った処に、一人日本人でない露店商人がいるのに目をつけた。",
              "citation": {
                "source": "粗末な花束",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光　おや、ここにも一人日本人がいますよ、ははは。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は婦人日で牝馬だけ走るんだが、ダアビイは混合だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシヤではツルゲーネフが「猟人日記」からひきつづき、その時代の若いロシヤの青年男女の姿を「その前夜」「処女地」などに描いた時代である。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の放送事業は財団法人日本放送協会の独占的事業である。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "財団法人日本ペニシリン学術協議会（一九四六年九月設立）。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "尋で蘭軒に「豆日草堂集」の詩があれば、茶山に「人日同諸子賦」の詩がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "人日に蘭軒は自ら医範一部を写した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "文化十五年戊寅人日、伊沢信恬記。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶山の「人日」は錯愕の語を作してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "元旦と人日との詩の間に、「雪日偶成」の作が介まつてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "張従正が儒門事親の跋文、「庚辰人日、記於三養書屋燈下」と書したるものの如きも、その作為する所の一である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の集には人日後春季の詩が五首ある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは「人日雪」と題する五律の三四七八である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "神辺では菅茶山が人日に藩士数人を集へて詩を賦した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「客迎英俊是人日、暦入春韶徒馬齢」の一聯がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
