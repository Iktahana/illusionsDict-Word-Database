    "definitions": [
      {
        "index": 1,
        "gloss": "taking a hot bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "入湯客はいずれも温泉場の正月をすごしに来て良い身分である。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女中部屋でもよいからと、頭を下げた客もあるほどおびただしく正月の入湯客が流れ込んで来たと耳にはいっているのに、こんな筈はないと、囁きあうのも浅ましい顔で、三人の踊子はがたがたふるえていた。",
              "citation": {
                "source": "雪の夜",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸七は、嘗て熱海にも兩三度入湯した事があつて、同地に知己の按摩がある。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやもう、神のごとしとござりまして、所々方々から、彼岸詣のように、ぞろぞろと入湯に参りまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸七は、嘗て熱海にも両三度入湯した事があって、同地に知己の按摩がある。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さう云へば彼處の湯に入つてる客たちだつてそんな奴ばかりでしたよ、長距離電話の利く處に行つていたんぢやア入湯の氣持はせぬ、朝晩は何だ彼だとかゝつて來てうるさくて仕樣がない、なんて。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそうした人里離れた場所であるだけその若者たちの被解放感は他の温泉場に於けるより一層甚だしく、入湯にというより唯だ騒ぎに来たという方が適当なほどよく騒いだ。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、下田から一里ばかりの蓮台寺村にある湯が、瘡毒や疥癬にいいということをきいたので、すぐその日、蓮台寺村に移って入湯した。",
              "citation": {
                "source": "船医の立場",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　入湯の効目か何うか知らなかつたが煎薬ぐらゐを服用するうちに私の病ひは鎮静した。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三回　余程｜風変な恋の初峯入　下　今年の仲の夏、或一｜夜、文三が散歩より帰ッて見れば、叔母のお政は夕暮より所用あッて出たまま未だ帰宅せず、下女のお鍋も入湯にでも参ッたものか、これも留守、唯お勢の子舎に而已光明が射している。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鍋に聞けば、一旦帰ってまた入湯に往ったという。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはわたしたちばかりでもないと見えて、伊香保へ入湯に出掛けた親戚のものなぞは皆それを言ふ。",
              "citation": {
                "source": "桃の雫",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "草津は金持と患者とが入湯するところだらう、万座はしづかに体を養ひ気を吐くところである、プロでもブルでも。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツのカイゼルスウェールト温泉へ母と姉とで逗留したとき、フロレンスは二人の貴婦人たちが入湯や社交に日を消している間をぬけ出して、同地の看護婦養成所に三ヵ月以上も滞在した。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの湯は胃腸病に効験いちじるしいさうなが、それを浴びるよりも飲むのださうな、田舎からの入湯客は一日に五升も六升も飲むさうな、土着の人々も茶の代用としてがぶ／＼飲むらしい、私もよく飲んだが、もしこれが酒だつたら！",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、入湯は趣味だ、身心の保養だ。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "当地には温泉情調といつたやうなものはあまりたゞようてゐない、むろん、私には入湯気分といつたやうなものはないが。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　義男は然う云ひながら入湯に出て行つた。",
              "citation": {
                "source": "木乃伊の口紅",
                "author": "田村俊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に引いた文の前に、猶「春以来御入湯いかゞ」の句もある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此入湯の習慣さへ既に此時よりあつたものと見える。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私方養介も二年煩ひ、去年｜漸起立、豊後へ入湯道中にて落馬、やうやく生て還候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後御病気いかが、入湯いかが、御案じ申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "魚の我水に帰りし心地して湯舟にあれば春雨ぞ降る　魚になつた様な気持がして、とは誰もがいふであらう、入湯と春雨、よく調和したいい気分である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどもまず米の相場を一両に一｜斗と見込み、この割合にすれば、たとい塾中におるも外に旅宿するも、一ヶ月金六両にて、月俸、月金、結髪、入湯、筆紙の料、洗濯の賃までも払うて不自由なかるべし。",
              "citation": {
                "source": "慶応義塾新議",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "入湯戯画　私は入浴を厭う訳ではないが、石鹸を持って何町か歩いて、それから衣服を脱いで、また着て歩いて帰るという、その諸々の仕事が大変うるさいので、一旦着たものは寝るまで脱ぎたくないというのが私の好みである。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし近ごろは浮世の混浴から遠ざかっている事を遺憾に思っているが、といってわざわざ電車に乗って、大阪へ入湯に行くという事は、今もなお億劫である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、そんな不愉快な日ばかりもなかったのは、若葉の道を蛇の目傘をさしかけて、連れ立って入湯にゆくような、気楽さも楽しんでいる。",
              "citation": {
                "source": "遠藤（岩野）清子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「入湯の際だがね、このコスモスてえ花は――」と峰吉は矢鱈に人をつかまえて講釈をするのだ。",
              "citation": {
                "source": "舞馬",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "この、子供がないがために、養子とも居候ともつかない茂助が、お八重のはいるまえから、植峰の家にごろごろしていたのだが、茂助は茂助で、いまは十八から十九になろうとして、お湯屋の番台のおとめちゃんを思って、一日に二度も「入湯」して、そしててかてか光る顔ににきびを一ぱい吹き出さしていた。",
              "citation": {
                "source": "舞馬",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "芋粥の馳走になつた上に、入湯が出来れば、願つてもない仕合せである。",
              "citation": {
                "source": "芋粥",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
