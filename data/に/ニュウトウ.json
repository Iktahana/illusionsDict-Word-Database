  {
    "uuid": "6f738592-e2a5-5a39-92fa-491b1eb2d559",
    "entry": "入島",
    "reading": {
      "primary": "にゅうとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going onto an island",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "名を百合と呼び、大入島の生まれなり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "傾きし月の光にすかし見ればかねて見知りし大入島の百合という小娘にぞありける。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "醍醐の入江の口を出る時｜彦岳嵐身に※み、顧みれば大白の光｜漣に砕け、こなたには大入島の火影｜早きらめきそめぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "（差入島田の要点等）　いまうちには信州の方の知人へ稲ちゃんが世話をたのんで呉れ、よい人が見つかりそうですから御安心下さい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠に私達を再入島させてください。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
