        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雪峡宮沢賢治塵のごと小鳥なきすぎほこ杉の峡の奥よりあやしくも鳴るや　み神楽いみじくも鳴るや　み神楽たゞ深し天の青原雲が燃す白金環と白金の黒の窟を日天子奔せ出でたまふ",
              "citation": {
                "source": "雪峡",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから洞のすきまを通して火のやうにきらきら光る海の水を淺黄いろの天末にかかる火球日天子の座を見た。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿体なくも、我等は光明の日天子をば憚かり奉る。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の空が明るくなりて、日天子さまの黄金の矢が高く射出さるれば、われらは恐れて遁げるのぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし白昼にまなこを正しく開くならば、その日天子の黄金の征欠に伐たれるぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の空が明るくなりて、日天子さまの黄金の矢が高く射出さるれば、われらは恐れて遁げるのじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし白昼にまなこを正しく開くならば、その日天子の黄金の征矢に伐たれるじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日天子、月天子、りりりと虫は鳴きまする。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一杯をつくして日天子を迎え、二杯を啣んで月天子を顧みる。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは前述したやうに支那の國體では君臣の關係は親子の關係で、自分の子に當る赤子が死するのを悲しむといふ念を現はす爲め、その日一日天子は膳を粗食にし、音樂を停止せられることになつて居ります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろ、老生の聞く所によると、袁術は、玉璽を手にいれ、不日天子の称を冒さんとしている由です。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
