    "definitions": [
      {
        "index": 1,
        "gloss": "warfare in which soldiers fling themselves at the enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たちまちまた、波うち際の、前にも増した肉弾戦、咆哮、乱噬。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪戦苦闘のブルどもは不眠不休、飲まず食わずしかも絶倫なる精力はその残虐と流血と肉弾戦の間にも驚くべき性殖力を発揮する。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが、警視庁から派遣されて居た巡査をもって編成した抜刀隊で、この抜刀隊の肉弾戦が、田原坂攻略に大きな役割を果したのであった。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "といって愚図愚図していると更に不利になるので、彼は遂に肉弾戦に訴えることにした。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "上から真逆落しに敵機へぶつかって組みあったまま燃落ちるもの――壮烈な空の肉弾戦だ。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大乱闘、肉弾戦、民政党総務の頼母木桂吉が、政友会の志賀和多利に殴られて、怪我しちょる。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "段山の丘ひとつの争奪戦に、一日のうち、薩軍の死傷百余、籠城方の死傷二百二十五名というような、無茶な肉弾戦も繰返されたが、依然、そこの防禦線は、死守する台兵の手にあった。",
              "citation": {
                "source": "日本名婦伝",
                "author": "谷干城夫人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
