        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "スレッドニードル街を少し下がったあたり、左手に、知っているかもしれないが、壁に引っ込んだところがある。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "７ぼくはひざまずいて祈ったそれが消えてくれるようにと〈ニードルズ・アンド・ピンズ〉サーチャーズ　翌七月二日は、寝不足と恐怖から、慶一は、なにがなんだかわからないままに午前中を終わった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイ・ニード・サムバディ」というジョンの声が入り、モノトーンの画面に、大きな指輪をしたリンゴの右手が映しだされると、あちこちから歓声があがり、たいへんなことになった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "待てよ、あとが〈アイ・ニード・ユー〉で、そのつぎが〈ザ・ナイト・ビフォア〉で、それから〈アナザー・ガール〉か……うん、ジョンのリードは前半ばっかだ」「でしょう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージの〈アイ・ニード・ユー〉は問題外だし」「やっぱり、ジョンがいちばん、えばってんだな」　と、慶一が高志を意味ありげに見る。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オール・ユー・ニード・イズ・ラヴ」とくりかえす単純なもので、二回目には、慶一もいっしょに歌っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "〈オール・ユー・ニード・イズ・ラヴ〉だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでモルトケ大将は、敵の攻撃に対しメッツ要塞を利用し、いわゆるニードの「袋」に敵を誘致して一撃を与え、主力はマース右翼の敵の背後に迫るような作戦を希望したものらしい。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその態度が慎重でどうもニードの「袋」にかかるかどうか。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオニード・グレゴリウィッチ・ジェルテルスキーはやっと商業学校を出たばかりの青年であった。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、レオニード・グレゴリウィッチ！",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「レオニード・グレゴリウィッチ、どうか貴方、可哀そうなマリーナ・イワーノヴナの忠実な騎士になって上げて下さい、ね、お拒みなさりはしませんわね」　ジェルテルスキーは、黒い洋袴を穿いた脚を組みながら、丁寧に碧い眼を見開いて対手を見守った。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それでね、レオニード・グレゴリーウィッチ、お願いと申しますのはね、あなた当分、この不幸な方を保護して上げて下さいませんこと？",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオニード・グレゴリウィッチが電車賃を節約するために勤め先と同じ区内にこの貸間を見つけたのであった。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオニード・グレゴリウィッチはひどく背が高い。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオニード・グレゴリウィッチが彼女の夫であると同じそれは不変の事実だ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女には、レオニード・グレゴリウィッチがこれ以上立身をして、自分達の生活に変りが起ろうとも思えなかった。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あら、これ、家の娘さんですの、悧口そうな眼つきだこと……何ていう名なのお前さん」「我々の言葉を理解しないんですよ、ちっとも」　レオニード・グレゴリウィッチのそれは声だ。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　三時過て、レオニード・グレゴリウィッチは勤め先から帰って来た。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――レオニード・グレゴリウィッチは、愛情をこめ、素早く妻を目がけ接吻を送った。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「レオニード・グレゴリウィッチ、どうぞこのことだけは誰にも云わないで下さい。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、レオニード・グレゴリウィッチ、我々は、キリストを追放しつつレーニンの肖像を祭る。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝る前、マリーナが厠へ降りた間にダーリヤはレオニードを擁き、云った。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「レオニード・グレゴリウィッチにもお気の毒だから、一先ずお帰り、――これこの通り、騙しゃしない、半分だけ兎に角かえして置くから」　エーゴルはジェルテルスキー夫婦の前で卓子の端から端へ十円札を十五枚並べた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオニード・グレゴリウィッチ、久しぶりでどうです」　ジェルテルスキーは、戸棚からギターを出し一つ一つの響きを貪欲にたのしみながら調子を合わせ始めた。",
              "citation": {
                "source": "街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "石油液化を扱った「オイル・シェール」（小山いと子）、ソヴェトのレオニード・レオーノフの「スクタレフスキー教授」などは、科学者の学問的情熱と社会の歴史的環境を扱っていましたが、素人眼にも科学者は成功的でありませんでした。",
              "citation": {
                "source": "質問へのお答え",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レオニード・レオノフは「のんだくれ」を書くのに、一年間工場生活をしなければならなかった。",
              "citation": {
                "source": "現代小説展望",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "……あなたも老けたわねえ、レオニード。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……わずかな金高じゃありませんか……ラネーフスカヤ　じゃいいわ、レオニードにたのみましょう。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            },
            {
              "text": "……出してあげて、レオニード。",
              "citation": {
                "source": "桜の園",
                "author": "――喜劇　四幕――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
