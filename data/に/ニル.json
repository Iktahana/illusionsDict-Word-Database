[
  {
    "uuid": "5f9ad465-4eb3-516a-bf08-3b0b60655486",
    "entry": "似る",
    "reading": {
      "primary": "にる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
