  {
    "uuid": "6e2011db-1bb0-5f4d-a808-1708c33fe3e5",
    "entry": "日ト",
    "reading": {
      "primary": "にっと",
      "alternatives": [
        "にちと"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
