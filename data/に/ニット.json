        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある日トムさんは相変らず一生懸命お嫁さんの自画像をめがけてたがやしてをりますと、どつと強い風が吹いて来て、竹の先のお嫁さんの画を吹き飛ばしてしまひました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "社會主義ノ原理ガ實行時代ニ入レル今日トナリテハ其レニ附帶セル空想的糟粕ハ一切棄却スベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は先日トルストイの性欲に関するエッセイを読みました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "前日トラックの運転手は、空トラックを店のガレージの前に停め、車体の点検を行ったとき、ふしぎなことに、後の荷置き場の隅に赤革トランクが逆さになって置かれてあるのを発見した。",
              "citation": {
                "source": "鞄らしくない鞄",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は毎日トンカツを食ひ、もしくは親子ドンブリを食つた。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日トンパチ屋で会ふと向うから話しかけて文学の話を始めたから、バカヤロー、私は怒鳴つて帰つてきた。",
              "citation": {
                "source": "ぐうたら戦記",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日曽病アリ、依而養生ノ為、宿ヲ外浜町村屋清蔵ニ取、□□医ヲ撰ンデ長府かなや町多原某を求、不日ニ平癒スト、期一七日トス。",
              "citation": {
                "source": "坂本龍馬手帳摘要",
                "author": "坂本龍馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日トラックに八十台のフルーツ・ケーキがつくられ、それが全米に送り出されている。",
              "citation": {
                "source": "桃林堂の砂糖づけ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "年間を通じて、毎日トラック八十台のフルーツ・ケーキをつくっているのにくらべては、あまりにも時代ばなれのした話である。",
              "citation": {
                "source": "桃林堂の砂糖づけ",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは昨日トオキョオへ行ってエレヴェーターというものに乗った。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日トウモロコシ畠を通っていると杭のうえに帽子と上衣がかかっているすぐそばに畠の主人がいるのが眼にはいったが、彼はその前に会ったときより日焼けが少しばかり増しただけであった。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "――この日トビアスはエザウを長い間、むかっ腹でなぐりつけた。",
              "citation": {
                "source": "トビアス・ミンデルニッケル",
                "author": "TOBIAS MINDERNICKEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊此日トロイア、アカイアの衆勢ともに相並びともに地上に斃されて等しく塵の中に伏す。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "神アポローン、先鋒の中に敵軍惱せるパトロクロスを――勇將を斃し、譽をヘクト，ルに　455與ふることの無かりせばその日トロイア落ちつらむ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、来週の今日トリガーセンの妻になるのですから」　ガイ夫人がつぶやいた。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "老年ニナルト誰デモソウカモ知レナイガ、近頃予ハ一日トシテ自分ノ死ノコトヲ考エナイ日ハナイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "イツデモ来ルガイヽ」「有難ウ存ジマス、オ言葉ニ甘エテコレカラチョク／＼伺イマス、毎日ト云ウ訳ニモ参リマセンガ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソレカラ先ハ八日ト同ジ事件ノ経過ヲ辿ル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ今日ハ九日ト工合ガ違ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日ハ唇ダケデナクッテモイヽ、舌ヲ着ケテモイヽ」予ハ七月二十八日ト同ジ姿勢デ、彼女ノ脹脛ノ同ジ位置ヲ唇デ吸ッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "但シ十一日、十三日ト少シ違ウ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦痛昨日ト大差ナシ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不幸ニシテ経過モ昨日ト同様。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お嬢ちゃんが御病気の時ぐらい蓄音器かけたかてええやありませんか、あの西洋人は近所附合い云うこと知らんのですやろかと、お春は憤慨したが、まあまあボッシュさんは変り者やよってに仕方ない、それに朝から蓄音器を鳴らすのは時節柄面白うない、と、貞之助が制したので、悦子はそれからは毎日トランプをして遊んだ。",
              "citation": {
                "source": "細雪",
                "author": "中巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日トロミエスは他の三人の者をわきに呼んで、神託でも授けるような身振りで彼らに言った。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "利根川に沿うた小さな町で、トンカツ屋とソバ屋の外に食堂がなく、僕は毎日トンカツを食い、半年目には遂に全くうんざりしたが、僕は大概一ヶ月に二回ずつ東京へでて、酔っ払って帰る習慣であった。",
              "citation": {
                "source": "日本文化私観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "スペインでも失敗した」「成程」「それから間もなくのこと、或日トボ／＼歩いていると喉が乾いてお寺へ寄ったのさ。",
              "citation": {
                "source": "ガラマサどん",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の部、トチリあり、「毎日トチる者が出るからその罰則考究中なり」と黒板に書く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "端ナクモ、過グル頃ヨリ敵味方トワカレ、矢石ノアイダニ別ルルモ、旧情ハ一日トテ、忘レタコトハナイ。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが生涯の情熱すべてこの一巻に収め得たぞ、と、ほっと溜息もらすまも無し、罰だ、罰だ、神の罰か、市民の罰か、困難不運、愛憎転変、かの黄金の冠を誰知るまいとこっそりかぶって鏡にむかい、にっとひとりで笑っただけの罪、けれども神はゆるさなかった。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
