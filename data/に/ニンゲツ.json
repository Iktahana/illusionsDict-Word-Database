        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "露地も温室のような春の中に、そこに一人月のごとき美人や病む。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした理由で、家来の幾人かが手打にせられたので、終ひには誰一人月代を剃らうと言ひ出す家来はなくなつた。",
              "citation": {
                "source": "茶話",
                "author": "初出未詳",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしこの人月並調を見る事多からざるを以て、その中の一体やや正調に近き者を取てかく評するなり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし大阪の俳人月兎物もあらうに己が新婚の句をわざわざ活版屋の小僧に拾はせて製本屋の職工に綴ぢさせてその得意さを世間に披露したりとすれば甚だ心ばせの卑しき俳人といはざるを得ず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩月人迷野　　月に歩して人は野に迷ひ、照人月度天　　人を照らして月天をわたる。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "古山の分析によれば、開発に要する作業量はベーシックだけで三月から九月にかけて計六五人月。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "古山は時をおかず、互換ベーシック開発には当初予測した六五人月に加えて、もう五〇人月は必要となるという緊急のレポートを浜田に入れた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "メリヤスの猿股は支那人の犢鼻褌に同じきものなれど西洋にては婦人月経中に用ゆるのみにて男子の穿つものならずという。",
              "citation": {
                "source": "偏奇館漫録",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "まち子の良人月田全作である。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれにしてもギリシア人月氏族などの混融している北インドで、五百年ぶりに主権を取り返したインド人が、いかにバラモン文化の復興を企てたところでもう純粋にバラモン的であり得るわけはない。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の中の人月の中の人が、ころがっておちて、北へゆく道で、南へいって、凝えた豌豆汁で、お舌をやいてこォがした。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "某中学では一人月十銭ずつの国防献金もあれば、愛国飛行場建設の志望も二十一カ所におよんだ（二月）。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱は60※のねじり煙草で、各人月曜日まで充分にもつ量だ。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "正直に申しますと、私たちは人間を一人月に送った方が良かったのかもしれません。",
              "citation": {
                "source": "愛と月の犬",
                "author": "R. マッケナ　R. McKenna",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく世間を遠去かって入湯にきているものを、熱海くんだりまで来ていッそうこうでは、さだめし当人に煩わしかろうと思われますが、それが案外で、次郎という小僕も、小間使いも、また問題の佳人月江様という人も、そんなことはどこ吹く風かで、少しも、気にかける様子がありません。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
