          "standard": [
            {
              "text": "日本化学会が発行する専門誌に、彼の研究論文が掲載された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "来月、日本化学会の年次大会が東京で開催される予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学で化学を専攻していた時、日本化学会の講演会によく参加していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "惨劇のあった翌日、秘密裡に、日本化学会の幹部二十三名が、学士会館の一室で会合した。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その道具のことを説明すれば彼氏の奇怪な行動がわかるのであるが、それはプリズムとレンズとからなる反射鏡で、その器体はコック部屋から、換気洞を上の方に匍いあがり、果然、日本化学会の会合のある室に届いているのである。",
              "citation": {
                "source": "国際殺人団の崩壊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
