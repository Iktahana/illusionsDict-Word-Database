[
  {
    "uuid": "36c2c233-055e-5084-89d4-caddc81debd4",
    "entry": "ニコニコ",
    "reading": {
      "primary": "ニコニコ",
      "alternatives": [
        "にこにこ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "副詞-と",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "with a friendly grin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然し何しろ今、Ｂの声は金切声だし、Ａを憎まないまでも、ニコニコは出来ないのだ。",
              "citation": {
                "source": "心理的と個性的",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こつちはイライラするけれど、彼方は親切に何やかと訊ねなさるから、牧代（姉娘）はどうしたか、生れた子供は丈夫かと訊ねなさつて……」とニコニコしながら呼吸をつきながら、仰向き勝なその顔の、アザヤかな色の唇がさういふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのたんびに信者等はニコニコして「あゝ神の御救ひだ」と云ふのであらう。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニコニコ／＼しながら、今もまだ喋舌つてゐる。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから半年の後、フト僕の下宿に現れて「私はこれから一人また広島に帰る」と云つてニコニコしてゐたが、その後母よりの手紙によるとどうも木村といふ人と折合がわるいのらしいといふのである。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういへば、ニコニコの底に、なんだかひどく悲しさうな色があつたのだが、また、何か云ひたげで遂に云はずじまひであつたが、人の悪口を云つてはならぬものとばかりに、相変らずの気持であつたのだらうと、幾分不憫でもあつた。",
              "citation": {
                "source": "引越し",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから眼科の室にも覗けば内科の室にも覗く、一つ一つ丁寧に部屋を覗いてニコニコツと笑つてはまた次の部屋を覗く。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "若しも此の時突然知人の誰かが声を掛けたとしたら、私はニコニコしだすかも知れないし又、愚鈍な瞳で力なく返事するかもしれない。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君――つまり意識を以て生きてる諸君は、若し其の時、私がニコニコすれば私が元気だと思ふだらうし、六ヶしさうな顔をしてゐたら元気がないなと思ふのであらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで私自身では、いくら元気である時にでも、もしその時に佗しげな夢を見てゐたとしたら、尠くとも直ぐにニコニコはしないであらう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」精は無言でニコニコしている。",
              "citation": {
                "source": "鴫つき",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロシアは八かましいと聞いていたから、自ら進んでスートケースの内容を展開しようとしたら税関吏の老人はニコニコしながら手真似で、そうしなくてもいいと制するのであった。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでか、爺っつあんいやにニコニコして居ると思ったよ」　源兵衛爺さん嬉しそうに、　「なアお静、儂清水へ行って来ようと思うんだが……」　「清水へ行くって、兄さんの処、分ってるの」　「なーに、次郎長親分を訪ねて行きァ分るサ」　「でも、兄さんが帰ってから一緒に行けばいいじゃないの？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「八ッ時までに帰らぬその時は」　そうだとなりひらニコニコ顔。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵、ニコニコ笑って行く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「支那を弾圧してニコニコしているのは大金持だけだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "久米の仙人に至って、映画もニコニコものを出すに至った。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分なぞも資産家でさえあればきっとすばらしい贋物や贋筆を買込で大ニコニコであるに疑いない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし季因是はまるで知らなかったのだから、廷珸の言に瞞着されて、大名物を得る悦びに五百金という高慢税を払って、大ニコニコでいた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護婦に、迷惑だろうがどうにか始末をしてもらいたいと頼んだら「いただきます」と答えてニコニコしていたので安心した。",
              "citation": {
                "source": "病室の花",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の話であるが、百貨店の食堂へはいって食卓を見回し、だれかの食い残した皿が見つかると、そこへゆうゆうとすわり込んで、残肴をきれいに食ってしまって、そうして、ニコニコしながら帰って行くという人もあるそうである。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼うだ御方と、今一人の富豪と筆者と、三人歴行して自動車を降り、二月末の曇雲の下を藁葺のお寺じみた門に進むと、益田翁は黒い背広に宗匠頭巾庭穿靴でニコニコと出迎えた。",
              "citation": {
                "source": "お茶の湯満腹談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとから聞くと、一日中機嫌が悪くて、妻子が弱ったそうであるが、自分は極力ニコニコしている積りであった。",
              "citation": {
                "source": "道成寺不見記",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本当に執拗い空瓶だこと」と、今度は妹娘が拾って投げようとすると、その時｜背後の方より、「二人とも何をしている、拾ったのは何んだ」と呼んだ者がある、振り向いて見ると父のモンテス博士で、ニコニコしながら進みよる。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「乃公のたべ物にならない位ならば何だって人間の形をして生まれて来た」　人形はニコニコして答えました。",
              "citation": {
                "source": "人形と狼",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをポツポツ喰べている私の顔を老先生はニコニコして見ておられたが、やがて床の間の横の袋戸から古ぼけた鼓を一梃出して打ち初められた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手に冷たく光る細身の懐剣を持って妙にニコニコしながら私の顔を見下した。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる朝早く起きて見ると、もうすっかりいいお天気になっていましたが、池も田も水が一パイで皆大喜びをしていると、田を見まわりに行っていたお父さんはニコニコして帰ってこられました。",
              "citation": {
                "source": "雨ふり坊主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達はおどろいてそのお爺さんの顔を見ていますと、お爺さんはニコニコ笑いながらも一度、「砂糖になったら何にするのか」　と子供たちに聞きました。",
              "citation": {
                "source": "雨ふり坊主・先生の眼玉に・奇妙な遠眼鏡",
                "author": "香倶土三鳥（夢野久作）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
