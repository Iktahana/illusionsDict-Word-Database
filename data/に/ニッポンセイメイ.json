        "examples": {
          "standard": [
            {
              "text": "「日本生命の担当者が新しい医療保険のプランを持ってきてくれるから、少し話を聞いてみない？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本生命が所有するニッセイ球場は、かつて多くのプロ野球ファンに親しまれた歴史ある場所だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "長年の信頼と実績を持つ日本生命は、顧客一人ひとりのライフステージに合わせた保障を提供し続けている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その次の方が日本生命へ出ていらっしゃる深井さん、高商出身の。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の方が日本生命へ出ていらつしやる深井さん、高商出身の。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "市長の喧嘩７・31（夕）「日本生命保険」の社員から、郷里福岡の市長になつた久世庸夫氏は、市長の椅子が居心地がいいにつけて、自分にこんな結構な地位をあてがつて呉れた福岡の市民を、何だかこのまゝでは打拾つて置かれないやうな気持になつた。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            }
          ]
        }
