        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本は過去十余年間、巨額の資本と高貴なる犠牲（日独戦争）を払いて、山東の資源を開発し、現に邦人の投資額約一億五千万円に達する。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「日独戦争や、シベリア出兵時代とは、時代が違うからね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "気分すぐれず、身心の倦怠いかんともしがたし、行乞もやめて終日独居、ぼんやりして一句もなし。",
              "citation": {
                "source": "行乞記",
                "author": "仙崎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたもたまには洛邑にでも出てお気晴らしをなさっていらっしゃいませ、こんな田舎で長いこと毎日独で考え込んでばかり居らっしゃるのはお体の為によくありませんでしょう」　田氏はまた燭の火に一層近づいて髪の銀｜簪がすこし揺れるくらいの調子でつけ加えた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の手５・17（夕）　少し談話が古いが、日独の国交が断絶して、独逸の日本留学生が一｜纏めに店立を食はされた時の事、皆は和蘭経由で英吉利に落ち延びようとして、日を定めて一緒に伯林のレアタア停車場を発つた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "先日独逸の潜航艇問題が起きた時、ウヰルソン氏は色々心配の余り、幾日か夜徹をして仕事に精を出した。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月五日には独軍は早くもソンムの強行渡河に成功、仏国の抵抗意志は急速に低下して到るところ敗退、六月十四日独軍パリに入城、六月二十五日休戦成立した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独協定が行われて略一ヵ年を経た本年下四期に日伊協定が結ばれ、南京陥落の大提灯行列は、大本営治下の各地をねり歩いた。",
              "citation": {
                "source": "今日の文学の展望",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "終日独坐、無言、反省、自責。",
              "citation": {
                "source": "旅日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は雨を聴き、或は書を読み、終日独坐。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日の今日である、終日独坐無言行。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその翌日独りで再び庸三の書斎に現われた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼過ぎから学校へ通っている甥が出かけて行った後は、笹村は毎日独りで静かな家のなかに臥たり起きたりしていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独協定のことについて、書かれるべき感想は更に多くあるのであろうが、お定の記事が、一等国の大新聞社会欄をあれほどの場面で占め得るということは、その一面に何を暗示しているのであろう。",
              "citation": {
                "source": "暮の街",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "内閣に情報局がおかれ、日独防共協定にイタリーが加えられ、国民精神総動員運動がおこされたころ、新しく生まれた婦人作家に川上喜久子がある。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうかすると彼は逢い過ぎるほど逢わねば成らないような客をその二階に避け、諸方から貰った手紙を一まとめにして持って来て、半日独りで読み暮すこともあった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独にたいする講和促進と中国から手をひくがよいという主張、植民地住民の自立権の確立なども、ウォーレスの政策の一部にふくまれている。",
              "citation": {
                "source": "新しい潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのための強国間の協力、原子爆弾の禁止、人種的差別の撤廃、マーシャル・プランの廃止、植民地住民の自治原則確立、日独に対する講和促進と占領軍の撤退、中国における民主的連立政権の樹立、タフト・ハートレー法の撤廃、非米委員会活動の廃止、基本産業の国有化と時給一ドル最低賃銀制の確立。",
              "citation": {
                "source": "現代史の蝶つがい",
                "author": "――大統領選挙の感想――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月廿二日独坐、読書。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月七日独りを慎しみ独りを楽しんだ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "やうやく三句・ゆんべの雨がたたへてゐる、春・朝から小鳥が木の実たべにきてゐる雨あがり・夜のふかうしてあついあついお茶がある　三月廿五日雨、春雨、終日独坐。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "此書を裁する前年壬午「九日独酌」の詩に自註がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月二十四日辛巳初春、殘寒未去時、氷谷博士遊于志賀高原、見寄殘雪句、（残雪や浮世の風の来ぬあたり、）賦詩乞正當年同是讀書人　　当年同じく是れ読書の人、今日獨空歎老身　　今日独り空しく老身を歎ず。",
              "citation": {
                "source": "閉戸閑詠",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は日独防共協定や保護監察法案で、自分たち転向被告はますます手も足も出なくなつたと、顔を見るなり訴へはじめた。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独防共協定のことなぞが、すべての乗客がだらしなく、口をあけ、むんむんとスチームにむされ脂汗を浮べて眠り込むと、思ひにのぼつて来た。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今日独身で立とうという女子があれば、やむをえない事情からの覚悟であって、決して結婚を嫌っているのではないのです。",
              "citation": {
                "source": "女子の独立自営",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、そうなりましたと云うのは、日独戦争の折炸裂弾をうけて、両足と或る器官を失ってしまったからなので御座います。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日独伊防共協定が調印されて、国民精神総動員中央連盟が結成された。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第十一巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへ達の望んで居る日独同盟の成る日が来るとも、どうして神聖サムラヒ族の顔が崩れよう。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
