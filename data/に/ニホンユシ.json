        "examples": {
          "standard": [
            {
              "text": "日本油脂株式会社は、その高い技術力を背景に、航空宇宙産業向けの特殊潤滑剤などを提供している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "かつての日本油脂の主力製品であった家庭用洗剤は、今もブランドを変えて親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "化学メーカーとしての歴史が長い日本油脂は、現在は日油株式会社として多角的な経営を行っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "十一月十五日（火曜）　北浜のつるやへ、日本油脂会社の重役によばれてゐるので出かける。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本油脂会社重役てのが又、人をよんどいて手前の会社の自慢ばかりしてゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
