    "definitions": [
      {
        "index": 1,
        "gloss": "to run away",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それが慌てて逃げ出す。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分にはまだ経験はないから分かりかねるが、たとえ逃げ出すにしても逃げ出し方があれとはもう少しどうにか違うのではないかという気がするのである。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一秒時間に十八万六千マイルという驚くべき速度で逃げ出すと、もう未来永劫再び我が地球へは帰って来ぬ。",
              "citation": {
                "source": "歳時記新註",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文六驚いて遂に逃げ出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎、例の如く逃げ出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "二つ三つ背中を打たれたからと云つて、逃げ出すなんて。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまでは犬でさえ逃げ出す女達に、私は容易に身を委すことができるようになった。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう斯うなつたら娘をかゝへて一刻も早くこんな化物屋敷を逃げ出すよりほかはあるまいと、お道はもう夫のことも自分のことも振返つてゐる餘裕がなくなつた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那人は、彼の手に握られた柄杓を見ると、物がひっくりかえるようなトンキョウな声を出して逃げ出すのだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが又片隅に居た敬四郎の背中にひッかかって敬四郎飛び上って逃げ出す。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に、生物がはげしい衝撃を受けると肉体と精神との結合が破れて後者が前者の孔から逃げ出すというような考えから、苦痛や快楽の物質的説明を試み、「笑いの元子」などというものはないと言ったりしている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このあひるが自身たちの室の前の道路に上がっているときに、パンやまんじゅうの皮の切れはしを投げてやると、はじめはこわそうに様子をうかがってはその餌をさらって急いで逃げ出す、そうして首を左右に曲げて人間なら横目づかいといったような格好で人間の顔色を見ながら、次のをくれるかどうかと待っているように見える。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大蛇が箱から逃げ出す場面で猿や熊の恐怖した顔のクローズアップを見せる。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アハハハハハハ」「オホホホホホホ」「ウフフフフフフ」　泥棒は夢中になって逃げ出すと、すぐに通りがかりの巡査さんに捕まりました。",
              "citation": {
                "source": "雪子さんの泥棒よけ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮の空ほの暗い時に、柱に靠れて居た僕が突然、眼を張り呼吸を凝して天の一方を睨む様を見た者は母でなくとも逃げ出すでしょう。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "おさよは私の逃げ出すのを見ていつもただ笑っていましたから、私はなおおさよが自分を欺しかけていたのだと信じたものでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうのは大概「金の逃げ出す音」の種類に属するものであった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この教えによっても判るように、苦労は、これを避けて楽なところへ逃げ出すのもいけないが、さればと言って苦労に噛りつき、これに蝕まれるのも正しい人生の行路者ではありません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩人はぽくんと一つ叩頭をして、逃げ出す氣持ちで坂を降りかけたが、何だか物足りないものを殘した氣がしたので、思はず振り向いた。",
              "citation": {
                "source": "狂童女の戀",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゴゴンゴーゴー、　やまのいわやで、　熊が火をたき、　あまりけむくて、　ほらを逃げ出す。",
              "citation": {
                "source": "シグナルとシグナレス",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは「命拾ひのお祝」に、拳骨が一つ宛振舞はれるので『之は堪らぬ』と逃げ出す次第だ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人でこんな場所へ来てこんな恐ろしい面を見たら、キャッと叫んで逃げ出すかも知れぬが、一行は大勢なのでチットも驚かない。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソラ来た」というので、一同ワッと逃げ出す。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はゝゝ、欅の大叉を見せて、船の梶に成る事、檜の大割を見せて、蒲鉾屋のまな板はこれで出來ますなど、御傳授を申しても一向感心をなさらなかつたが、如何です、この旗に對して説明がなかつた日には、海邊橋まで逃げ出すでせう。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "並大抵の者ならば、驚いて慌てて逃げ出すべきであるが、重蔵は頗る大胆であった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝの家へも火の粉が一面にかぶつて来るので、碌々に荷物なぞを持ち出すひまも無しに、寝巻一枚で逃げ出すといふ始末。",
              "citation": {
                "source": "赤い杭",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭二人は或る日林檎の畑の中で明日の夜明けに手をとりあって村から逃げ出す約束までした。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日大火事があってこの家の人が逃げ出す時、衣服と一緒に小さな鞄を大きな鞄の中に入れて逃げ出しました。",
              "citation": {
                "source": "二つの鞄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄ちゃん、どこへにげるの」「船にのって、すこしでも早く、この島からにげだすのだよ。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへハ人から一歩もたして、をとこという男ハ皆にげだすによりて、きづかひもなし。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年一月二十日　姪春猪あて",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
