[
  {
    "uuid": "49629a95-1e86-5a19-a88d-61990ca90a65",
    "entry": "日英",
    "reading": {
      "primary": "にちえい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Japan and the United Kingdom",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今日英語や仏蘭西語の西欧語が、文学的に洗練された言語として輝いているのは、実に過去何世紀の永い間、それが詩文の上に使用されていたからである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "首相は日英同盟は益々鞏固なる上日佛日露の協約成りて日本の地位は鞏固になれる旨を演説せられたり。",
              "citation": {
                "source": "雲間寸觀",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "然り日英同盟は益々鞏固にして日露及び日佛協約は愈々日英同盟を鞏固にならしめたり、日佛協約は滿洲北清の方面に於ける危險を免れしめたり。",
              "citation": {
                "source": "雲間寸觀",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達夫婦が生きている間は日英の外交が破裂する心配はないと思え。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより先、日本は、日清戦争の苦き経験に教へられて、日英同盟を締結し、専心｜露西亜に備へてゐたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく都の豪家の傅日英という者が、子弟を訓えてくれと言って頼みに来た。",
              "citation": {
                "source": "富貴発跡司志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで友仁は日英の家へ移って、月俸として毎月五錠の銭を貰うようになったので、いくらか生活が康らかになってきた。",
              "citation": {
                "source": "富貴発跡司志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで友仁は日英の家に数年いたが、そのうちに張氏が高郵に兵を起したので、元朝では丞相脱脱に命じて討伐さした。",
              "citation": {
                "source": "富貴発跡司志",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊一八〇一年四月二日英艦の攻撃事件。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただしノルウェーの兎は雪を潜って※とて騾のごとき獣とに遺す、二獣、人来るを見れば必ず蹶を負うて走る、これは蹶を愛するでなくて甘草欲しさだ、蹶も二獣の可愛さに甘草を残すでなく足を仮るためじゃとある、まずは日英同盟のような利害一遍の親切だ、『山海経』に〈飛兎背上毛を以て飛び去る〉とあるも跳兎らしい。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "日支事変で日英関係が悪化した事も原因であるが、大体日本人の国民性には、現象に左右されるといふ心理的動揺の幅がありすぎる。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちよつと許り日英間の情勢が変ると、坊主憎ければ袈裟式にすぐ英語を廃さうとするのである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "▼むしろ日英関係が悪化した場合には、大いに英語を学ぶべきで、相手国を理解し尽しそれを圧倒するには、相手国の言葉を知ることが何より先決問題だからである。",
              "citation": {
                "source": "小熊秀雄全集-20",
                "author": "大波小波",
                "note": "青空文庫"
              }
            },
            {
              "text": "大戰中ニ於ケル印度獨立運動ノ失敗ハ凡テ日本ガ日英同盟ノ忠僕タリシガ爲メニシテ、從テ英國ガ一時的全勝將軍タルガ爲ニ瞬時雌伏スルニ過ギズ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日英兩國ハ中立的關係ニ立ツ能ハズシテ、彼ノ從屬的現状ヲ維持スルカ彼ノ分割ヲ結果スル征服者タルカノ二ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本ガ印度ノ獨立ヲ欲スル如ク支那ノ保全ヲ希フナラバ、眼前ニ迫レル支那ト英國トノ衝突ハ日英同盟ヲ存立セシメザル者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "事實ヲ以テ立證セラルルノ日ハ則チ日英兩國ガ海上ニ見ユルノ日ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那保全ニ於ケル日英開戰ハ已ニ論議時代ニ非ザルナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "早ク已ニ揚子江流域ハ英國ノ勢力範圍ナリト云ハルル今日、日本ヲ相手方トシテ英獨協商ヲ日英協商トシテ支那ニ臨ム時、明治大帝ハ何ノ爲メニ日露大戰ヲ戰ヒシカヲ解スベカラザラントス。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎は日英同盟のせいかとも考えた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども日英同盟と大学の陸上運動会とは、どういう関係があるか、とんと見当がつかなかった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あいつは今日英語の時間にほんの一寸笑ったよ。",
              "citation": {
                "source": "背後",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "日英海軍は昔から師弟関係にある。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすることが、日英海軍のあいだに横たわっている誤解をなくすることにもなるのだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "日英関係のけわしい折柄、英国が、これを国交上の大問題としてとりあげたのは、尤もなことであった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブローカーの馬車の群団は日英の銀行間を馳け廻った。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日英語を云ひ出した彼等は、明日はまた何か違つたものを云ひ出すかも知れない。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "日英同盟廃棄数年後になっても日本人は英国が日英同盟の好誼を忘れた事を批難し、つい最近まで第一次欧州大戦に於ける日本の協力を思い出させようとしているのに対し、あるドイツ人が「日本は離婚した女に未練を持っている有様だ」と冷笑した事があった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
