        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただし一九九二年十月に、米ボイジャー社と日本のソフト制作者グループとのジョイントベンチャーによって、日本法人のボイジャージャパン（正式名称、株式会社ボイジャー）が設立されており、一九九三年三月のリリースをめどに日本語化の作業が進められている。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アスキーが同社の製品の販売にあたっていた時期を経て、日本法人としてマイクロソフト株式会社が設立されたのが一九八六年。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして一九八六年三月、アスキーとマイクロソフトが独占代理店契約を打ち切り、新たにマイクロソフトの日本法人が設立される中で、アスキーの開発本部担当取締役を務めていた古川は、新会社の社長へと一大転身をはかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後も一貫して情報処理部門を歩み常務取締役まで上り詰めてから、広範な人脈を持つ御大はアメリカ生まれのベンチャーの日本法人のトップへと転じた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "とすればマックでいいんじゃないかとなって、今やアップルコンピュータの日本法人は笑いが止まらない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "芳賀博士の『攷証今昔物語』に、この譚を『日本法華験記』と『元亨釈書』に漢文で載ったのを本語の後に付けあるが、出処も類話も出していない。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『帝王の誕生』の著者たちは、マイクロソフトの日本法人であるマイクロソフト株式会社にアスキーから移った、古川享のコメントをもとに、このエピソードに関して記述している。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＰＣの日本語化は、世界市場でＰＣ互換のラップトップを成功させた東芝の逆輸入版Ｊ―３１００や、マイクロソフトの日本法人がリーダーシップをとったＡＸと名付けられたプロジェクトによって側面から進められることになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年二月十七日、マイクロソフトは日本法人のマイクロソフト株式会社を設立した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "マイクロソフト日本法人の社長には、古川享が就任することになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本電気にパーソナルコンピューターの種をまいた渡辺和也は、一九九〇（平成二）年六月二十七日付けで同社を退社し、七月二日、ネットワーク用ソフトウエアの雄、ノベルの日本法人の社長に就任した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまざまなメーカーのさまざまなマシンをつなぐネットワーク分野で急成長を遂げたノベルの日本法人の社長にと誘いを受けたとき、渡辺はてのひらからこぼれ落ちたオープンの夢が、小さな炎となって胸によみがえるのを覚えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、日本法廷の裁判官中に三十人ないし四十人の外国人判事を入れ、また十一人の外国人検事を入るる事。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "一木氏の著書『日本法令予算論』（明治二十五年五月の三日初版・三十二年十一月十五日再版）を見ると、夫は純然たる天皇機関説ではないか。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
