    "definitions": [
      {
        "index": 1,
        "gloss": "to scurry home",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "猫は、跛を引いて逃げ帰ると、納屋の隅にうずくまって、殴られた足をかばうようにねぶった。",
              "citation": {
                "source": "「紋」",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "山深く迷い入った猟夫が、暗い岩蔭に嘯いて立つ奇怪の※を視れば、銃を肩にして早々に逃げ帰る。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべまでは鎌倉を通りぬけて、真っ直ぐに江戸へ帰るつもりであったが、さてここまで無事に来て見ると、そんなに慌てて逃げ帰るには及ぶまいという油断が出たのと、めったに再び来ることも出来ないというので、三人は他の人たちと同じように見てあるいた。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌景即ち人数を二手に分け、大久保勢の柵内に逃げ帰るを防いだ。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく、合祀されし社の氏子、遠路を憚り、ことごとく合祀先の社へ参り得ざるをもって、祭日には数名の総代人を遣わすに、多勢に無勢で俘虜降人同然の位置に立つをもって、何のありがたきことなく早々逃げ帰る。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その散策者は胸をわるくして、また不快なパリの町へ逃げ帰るだろう。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵は萱を分けて、ざわざわざわと出で来り、樵夫が驚いて逃げ帰るくらいのものなり。",
              "citation": {
                "source": "遠野の奇聞",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "故郷に逃げ帰る途中関吏に捕われしを、陳宮これを釈し、ともに走って、三日の暮方に成皐に到る。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々見るよりアッといいて立ち騒ぐに驚き、この鼠逃げ帰るを見れば常の黒鼠となって去る。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "出先で、妖怪に逢い這々の体で自分の家に逃げ帰ると、その恐ろしい魔物が、先廻りして、自分の家に這入り込んでいる。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あっしのつえに不思議はねえが、いまだになんとも気味わるいことには、逃げ帰るそのときに、あのお屋敷のへいのところでちらりと変なものを見たんですがね」「何じゃ」「猿公ですよ」「なにッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "桓温は驚き怖れて逃げ帰ると、暫くして尼僧は浴室を出て来たが、その身体は常のごとくであるので、彼は又おどろかされた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "出先で、妖怪に逢ひ這々の体で自分の家に逃げ帰ると、その恐ろしい魔物が、先廻りして、自分の家に這入り込んでゐる。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あたりから遊びに来た者は、それとなくその辺をジロジロと見廻して、彼が夕餉の膳に誘ふと、赧くなつて慌てて逃げ帰る者もあつた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしたわけで貰われた安も、拳の下に崩れた丸髷を整える遑もなく、山内へ逃げ帰る。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は酔うと酒乱になる桂子と喧嘩する度に、それをよい機会と思い、妻子の田舎に逃げ帰るのだが、そこで、妻の表情のかたい、甲羅をかぶった無言の軽蔑に出あうと、死ぬほど桂子が恋しくなり、また彼女のもとに逃げ帰ってしまう。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家の猫はだいたい喧嘩に弱く、よその猫から追っかけられて逃げ帰ることが多いが、その夜はちと気配が違う。",
              "citation": {
                "source": "猫先生の弁",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、勿論新蔵と堅い約束の出来ていたお敏は、その晩にも逃げ帰る心算だったそうですが、向うも用心していたのでしょう。",
              "citation": {
                "source": "妖婆",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の云う通り小枝を放して、丹生川平へ逃げ帰るか、ないしは真剣に切り合うより、他に手段はなさそうだ。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして予想せられた如く完膚なく敗北し、家康は血にそまつて、ともかく城へ逃げ帰ることができたのである。",
              "citation": {
                "source": "家康",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "釣つた魚の二三尾も投げてやつて這々の体で逃げ帰るに限る。",
              "citation": {
                "source": "東京湾怪物譚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "青くなつて逃げ帰るのだ。",
              "citation": {
                "source": "東京湾怪物譚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "長くは海もながめていられなくて、寛斎は逃げ帰るように自分の旅籠屋へ戻った。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャッと叫んで女子供はバラバラと後ろへ逃げ帰る。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右京次郎の兵法　人丸左陣と傾城小銀とは、地丸左陣に翻弄され、這々の態で逃げ帰るや、小銀の山寨妙高山へともかくも一時落ち着いたが、すぐに白山へ使いを出し、兄弟分の天丸左陣へ事の次第を注進した。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてさいごに雪が十分に降って、二百枚の写真がとれ、交通｜杜絶の一歩手前で、逃げ帰ることができた。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大急ぎで真剣になって泳いで逃げ帰るのであるが、岸へ上っても心臓の鼓動はなかなか止らない。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大急ぎで真剣になつて泳いで逃げ帰るのであるが、岸へ上つても心臓の鼓動はなか／＼止らない。",
              "citation": {
                "source": "真夏の日本海",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくのごとき越後産の苧が課役の基礎になっておったのであるからして、その越後の国が乱れると、天王寺商人らも身を全うして逃げ帰るが精一杯で、苧の買入れどころではなく、したがって苧の公事も納まらなくなる。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古木のようなリュウのからだは、半分ほどは雲にかくれて、ところどころにメラメラともえるほのお、トラはそれをむかえて、天地もくずれるばかりにほえたてますが、リュウの威力におじけづいたか、まもなくシッポをまいて、北のやぐら、猫間犬丸の足もとににげかえるのです。",
              "citation": {
                "source": "幻術天魔太郎",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
