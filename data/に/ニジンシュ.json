        "examples": {
          "standard": [
            {
              "text": "彼女は二人種のバックグラウンドを持つアーティストだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "二人種の子供たちは、様々な文化に触れて育つことが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この映画は、二人種の家族が直面する課題を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "看守と囚人とを別々に見れば、共に気の毒なる境遇の人々であるが、さてこの二人種の関係を考えてみれば、滑稽といおうか、馬鹿馬鹿しいといおうか、更にこれを悲惨といおうか、予はこれを評するに言葉を知らぬ。",
              "citation": {
                "source": "獄中生活",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内の目ぼしい家屋の過半は此二人種の所有である。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
