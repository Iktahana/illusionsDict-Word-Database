    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese music (esp. traditional Japanese music)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
