        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兄や父の顔をみるとニヤニヤ笑ふやうになつてゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが兄がそこに近づいてからは、心棒と兄の顔を等分にみながらニヤニヤと笑つた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍で聞いている小店員の中には顔を見合せてニヤニヤ笑っているのもあった。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉ニヤニヤ笑って刀を弄って居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉ニヤニヤ笑い乍ら、Ｔ「日下部典六　可愛いい奴」　半次面喰った。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大吉ニヤニヤ笑い乍ら酒を呑んで居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "典六ニヤニヤ笑い出した。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "長火鉢の前でニヤニヤ笑って居るなりひら小僧。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）夜の街　君江を送る左膳ニヤニヤ笑って居る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "左膳ニヤニヤ笑い乍ら去る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "中根はあわてて無格好な不動の姿勢をとつたが、その顏には、それが癖の間の拔けたニヤニヤ笑ひを浮べてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてニヤニヤと笑っています。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "車掌は踏台から乗り出すようにして、ちょっと首をかしげて右の手でものを捧げるような手つきをしながら「もう一枚頂きましょう」と云ってニヤニヤした。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の車掌は事柄を全くビジネスとして取扱ったからまだよかったが、隣に坐っていた人が妙にニヤニヤしていたという事である。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "行ってみると、中村武羅夫先生はまだ来ていなくて、林先生の橋田新一郎氏が土間のテーブルで、ひとりでコップ酒を飲みニヤニヤしていた。",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、やっぱりニヤニヤ笑いながら、「読まなけれあいいんでしょう？",
              "citation": {
                "source": "眉山",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その線香を拾い上げて遣りながら良助はニヤニヤと笑った。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "チエ子さんはビックリして眼をさましますと、眼の前に気味の悪い顔をした大きな男がニヤニヤ笑って立っております。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "泥棒はやっぱりニヤニヤ笑いながら、「可愛いお嬢さんだね。",
              "citation": {
                "source": "虻のおれい",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "川柳の陰になった一｜間幅ぐらいの小川の辺に三、四人の少年が集まっている、豊吉はニヤニヤ笑って急いでそこに往った。",
              "citation": {
                "source": "河霧",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その豪傑振りをニヤニヤ笑っていたのは当時｜張良をもって自ら任じていたＫであった。",
              "citation": {
                "source": "海水浴",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎朝そいつの顔を見るといやでも目が覚めるくらゐニヤニヤ笑つてゐる。",
              "citation": {
                "source": "散歩生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜違にこれを視めて、前歯の金をニヤニヤと笑ったのは、総髪の大きな頭に、黒の中山高を堅く嵌めた、色の赤い、額に畝々と筋のある、頬骨の高い、大顔の役人風。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ニヤニヤとまた笑ったが、胡瓜の化けたらしい曲った刀が、剥きづらかったか、あわれ血迷って、足で白刃を、土間へ圧当て蹈延ばして、反を直して、瞳に照らして、持直す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か言いそうにした口の、ただまたニヤニヤとなって、大な涎の滴々と垂るる中へ、素直にずきんと刺した。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　子供らはよろこんでニヤニヤ笑って口々に、「おとうさん、ありがとう。",
              "citation": {
                "source": "クねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひましたが、猫大将はニヤニヤ笑って、向ふへ走って行ってしまひました。",
              "citation": {
                "source": "鳥箱先生とフウねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御両方無言にて頷きたまえば、再び矢島に導れ、門を出でて三拝せしが、見送る人眼のあらずなれば、ニヤニヤと笑うて、ペロリと舌。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "六蔵ニヤニヤと独笑して、「お寝間のお伽もまけにしてと――姉さん、真個かい、洒落だぜ洒落だぜ洒落じゃねえ。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……且は臨終の苦患の可哀さに、安心をさせようと、――心配をするな親仁、鐘は俺が撞いてやる、――とはっきり云うと、世にも嬉しそうに、ニヤニヤと笑って、拝みながら死んだ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
