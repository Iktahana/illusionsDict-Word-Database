        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その忍苦の表情を見よ。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども五人は無言の忍苦を続けた。",
              "citation": {
                "source": "ざんげの塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう想像することによって隊員の忍苦の長い時間的経過を味わうことができる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし本来はそれどころか実に深刻な時代世相の端的描写であり、そうして支配階級よりはより多く被支配階級の悲痛な忍苦の表現をもそれらの中に看取することができるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "……………　……………　小布施さん……桂子はハンカチを眼に当てゝよゝと泣いた……小布施さん……　だが、死んだ小布施の名を呼びながら、桂子の涙は、実は桂子自身の異常な運命や悲痛な忍苦、はげしい潜情に向けて送られてゐる。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら、この永い忍苦は、姉さんにとって、決して無駄ではなかったと思う。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "忍苦は、人間の理性を磨いてくれるものだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "アトラスの忍耐、プロメテの忍苦、そのようなかなり永続的な姿であらわされる徳のように思われる。",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はもう幻影に過ぎなかった愛の世界を失って娑婆即ち忍苦の世界の者となったのみだ、其娑婆に在って又ふたたび幻影の世界を求めて、遅かれ速かれふたたび浅ましい物の香に接しようとも思わぬ、と取留めも無く、物を思うでもなく、思わぬでもなく、五月雨のしとしとと降る頃を、何か分らぬ時を過した。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "わがリアリスト、これこそは、君が忍苦三十年の生んだ子、玉の子、光の子である。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有様を見ているうちに、さすがに私も、この弟子たちと一緒に艱難を冒して布教に歩いて来た、その忍苦困窮の日々を思い出し、不覚にも、目がしらが熱くなって来ました。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先手の角道があいて、後手の端の歩が一つ突き進められてゐるだけといふ奇妙な図面を、私はまるで舐めんばかりにして眺め「雌伏十六年、忍苦の涙は九四歩の白金光を放つ。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その苦労はほとんど天下に大名をなしたものの、堅忍苦耐したくらいなもんだよ、その閲歴に対する報酬として、ただ、ひたすら、簡単に神月に見捨てられまいということを願ってまた他意なきを如何よ。",
              "citation": {
                "source": "湯島詣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "遁れても遁れても覆ひかゝる悲しみには、青白い騎士のやうに凝つと忍苦して「その悪い星廻りを通り越させる」賢こさを有ちつゞけませう。",
              "citation": {
                "source": "〔婦人手紙範例文〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼を現実と幻影をしらない記憶と現在との差別を忘れた白痴と思ふのは間違ひだ、彼は赤裸に生長した精虫のやうにあまりに痛々しく人生を知りあまりにも可憐に現実の姿を見る苦労人でこのかくれたる敏感な表現はいたましいほどの弱々しい人間、ただ鈍重は真直な通路を歩みつゞける偉大なる感情の忍苦者である。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ之が自暴自棄から起った業とらしい忍苦だと誰が判断するか？",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この聖母マリアの如きゼ号型船は、かかる犠牲と忍苦と研究の支払いによって生まれ出たんだ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる忍苦ではなかつたか。",
              "citation": {
                "source": "ある僧の奇蹟",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "感謝は誠であり信である、誠であり、信であるが故に力強い、力強いが故に忍苦の精進が出来るのであり、尽きせぬ喜びが生れるのである。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教や儒教が、女らしさにますます忍苦の面を強要している。",
              "citation": {
                "source": "新しい船出",
                "author": "――女らしさの昨日、今日、明日――",
                "note": "青空文庫"
              }
            },
            {
              "text": "在るものは、権力の強制と、その強制を可能ならせている日本の軍国的な封建的な社会の雰囲気と、知識人たる自覚を放棄した一民衆としての忍苦しかなかった。",
              "citation": {
                "source": "誰のために",
                "author": "――インテリゲンツィアと民主主義の課題――",
                "note": "青空文庫"
              }
            },
            {
              "text": "社会運動者の忍苦と意力、周囲に累積する迫害と身内に燃ゆる火、現在の闇黒と未来の曙光、そういうものの持つ一種ヒロイックな魅力、被搾取階級の惨澹たる生活、それに対する同感と愛、それらは確に人を惹きつける或物を持っている。",
              "citation": {
                "source": "性格を求む",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひ出に非ずあらゆる来し方の中より心痛まぬを採る　故人と共に過した四十年の人生は短いものでもなく随分忍苦に満ちた一生ではあつたが、生甲斐のあるやうに思つた年月も少くはない。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち貨幣や職業の奴隷とならずに、自己が自己の主人となり、自己に適した活動に由って、少しでも新しい文化生活を人類の間に創造し寄与することの忍苦と享楽とに生きる人間を作りたいと思います。",
              "citation": {
                "source": "文化学院の設立について",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその長い間彼が一途に死刑より逃れよう、後には一度出獄がしたいと云う果敢ない望みから闇黒な牢獄の中に座して、あらゆる痛苦を征服し、世を呪い人を呪って生きつゞけた、忍苦と生存慾とを思うと、その執念の恐ろしさに戦慄を禁じ得ないと共に、一個の人間としての彼の悩みに転た同情を濺がざるを得ない。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、在獄七年余、朝に夕に呪い続けて、いかなる手段を尽しても死刑を逃れ、一度浮世に出でんと努力し続けた忍苦執拗、支倉の如き人間が又と世にあろうか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、私にとっては辛いとも遣瀬ないとも、悲しいともいら立しいとも、何ともいいようのない忍苦の一年は過ぎた。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
