    "definitions": [
      {
        "index": 1,
        "gloss": "western Japan (usu. Chūbu region and westward)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
