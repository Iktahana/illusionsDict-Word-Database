[
  {
    "uuid": "80224b2f-d51d-5f12-9e40-a349a4261300",
    "entry": "仁寿",
    "reading": {
      "primary": "にんじゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
