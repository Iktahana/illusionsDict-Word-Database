    "definitions": [
      {
        "index": 1,
        "gloss": "Russo-Japanese War (1904-5)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
