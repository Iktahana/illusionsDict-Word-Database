        "examples": {
          "standard": [
            {
              "text": "北海道の冬は日照時間が短いため、気分が落ち込みやすい人もいるという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "太陽光発電所の立地選定では、年間の平均日照時間が最も重要な指標になる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "記録的な猛暑だったが、統計を見れば日照時間も過去最高を更新していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "天竜川中流の、峻嶮極まる峡谷地帯で一日中日照時間が三時間だとか四時間だとか云ふ地帯にも、こんないい日があるかと思はれるやうな、人の心も清々しくなるやうな一日であつた。",
              "citation": {
                "source": "万福追想",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は仲間の宣教師たちによる全世界でのこの病気の分布調査を組織し、充分の日照時間があり、工場の煙で邪魔されていない地域では、この病気は存在しない、という結論に達した（51）。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
