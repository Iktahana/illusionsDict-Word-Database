    "definitions": [
      {
        "index": 1,
        "gloss": "to boil over",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "忘れて咲いたか、と小草にこぼれる。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "匙が壺の縁に當つて鹽の粉が敷居の上にこぼれる。",
              "citation": {
                "source": "すかんぽ",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "引きちがへにこぼれるやうな金色の蜜柑、それはすばらしい蜜柑の眺めがあちらこちらに黄に明つて来た。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて梅雨になれば、その花が一面にこぼれることを想像しながら、やや爪先あがりの細い路をたどって行くと、林のあいだから一人の若い女のすがたが現われた。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "新一はその墓場の中を彼方此方と歩きながら、もしや血が落ちていはしないかと見て廻ったが、足端にこぼれる露があるばかりで色のあるものはなかった。",
              "citation": {
                "source": "狐の手帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "由は裂目が澤山入つて、ボロ／＼にこぼれる泥壁に寄りかゝりながら、ランプのホヤを磨きにかゝつた。",
              "citation": {
                "source": "防雪林",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなにこぼれるばかり客を詰め込んだ車の上も、動き出して行つた時はさすがに風があつた。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "・濡れてすゞしくはだしで歩く・けふも旅のどこやらで虫がなく　ひとり住んで蔦を這はせる　身に触れて萩のこぼるゝよ朝湯はうれしかつた、早く起きて熱い中へ飛び込む、ざあつと溢れる、こん／＼と流れてくる、生きてゐることの楽しさ、旅のありがたさを感じる、私のよろこびは湯といつしよにこぼれるのである。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯をとくと、五十銭玉がばらばらと畳にこぼれる。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほろりと、秋の真昼、緑の四角な瓶から卓の上へ静かにこぼれる。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "哀れなみなし子がその救主を見上げる様なオロオロしたはずかしそうな目つきをして、若々しいまるい顔にこぼれる様なほほ笑みをうかべてウットリと見入って居る舞子の姿を見上げた。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歯ぐきから吹きだした血は、顎から糸のようにこぼれる。",
              "citation": {
                "source": "幽霊",
                "author": "小野佐世男",
                "note": "青空文庫"
              }
            },
            {
              "text": "せまい国土にこぼれるほどの人間がひしめき合い、わずかな物資を暴力で奪い合っている。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原の中の林も色づいて、こずえからは、黄色い葉がひとりでにこぼれるように、ほろほろと落ちていました。",
              "citation": {
                "source": "白い影",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その餌が地面にこぼれるので、雀が多く集って来る。",
              "citation": {
                "source": "澪標",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "批評して「なかなか生意気なことを書きおるわい」と思うと、我ながらまごつくくらい涙がやたらにこぼれる。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その娘はお倫といって、年は十七か八だろう」と彼は上唇を舐めた、「いかにも箱入り娘らしくて、縹緻もいいが、躯つきや身ごなし、ものの云いようにこぼれるような、色気と、おっとりと匂うような品があった」　清一は浅草瓦町の横町に自分の家を持ち、ばあやと二人でくらしていた。",
              "citation": {
                "source": "五瓣の椿",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれを飲む時に幾滴かが馬のたて髪の上にこぼれると、これを舌の先でなめとってやらなければならなかった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその涙は頬にこぼれるようなことはなく、いつしか消えた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "峰の端から映して来る夕陽が、滝つぼの一端にこぼれると、武蔵のもり上がっている肩の肉から、無数の小さい虹が、八方へ昇った。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕闇にこぼれる、湯の音にまぎらして、「オオ、きれいにおなりだこと。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、忙しない騒音が渦をまいている町中とは違い、ここは師走とも見えないのどけさで、カサリ……と真ッ黄色な枯れ葉が灌本の枝をすべる音も、時々、酔った女の耳朶のような山茶花が地にこぼれる音すらも、耳につくくらい静かな昼です。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼女は「……いいえ、なんで私だけが、子に会えるのを、よろこんでいられましょうぞ」と、叫びたげに、顔を振った、その頬にこぼれる露を、義貞は、白桔梗のようなと思った。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
