[
  {
    "uuid": "80828e95-ce00-5bb3-90cb-3478eef6af7d",
    "entry": "任用",
    "reading": {
      "primary": "にんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "appointment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "作右衛門の子｜登は越中守｜宣紀に任用せられ、役料共七百石を給わって、越中守｜宗孝の代に用人を勤めていたが、元文三年に致仕した。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫡子光尚の周囲にいる少壮者どもから見れば、自分の任用している老成人らは、もういなくてよいのである。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の任用したものは、年来それぞれの職分を尽くして来るうちに、人の怨みをも買っていよう。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "忠之はそれを近習に取り立てゝ、次第に任用して、短い月日の間に、秩祿を加へられる度數の多いので、心あるものは主家のため、領國のために憂へ、怯懦のものは其人を畏れ憚り、陋しいもの、邪なものは其人にたよつて私を濟さうとするやうになつた。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を任用する上にも、きのふまで目を懸けて使はれたものが、俄に勘氣を蒙ることがある。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "家來の任用、肥後表へ差し向けた使者の件等は、公儀に於いて越度と認める、追つて詮議を遂げるであらうと云ふ申渡である。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に國郡が手に入つたら、人物を鑑識して任用しなくてはならぬ。",
              "citation": {
                "source": "栗山大膳",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仲平の父は、三十八のとき江戸へ修行に出て、中一年おいて、四十のとき帰国してから、だんだん飫肥藩で任用せられるようになったので、今では田畑の大部分を小作人に作らせることにしている。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "女教員でさえ四十一歳になった女教師は、新しく本任用しない東京都の内規がある。",
              "citation": {
                "source": "離婚について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "片山内閣は、文相として森戸辰男を任用した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが十月で、翌十一月に始て新に講師が任用せられた。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが幕府が蘭法医を任用した権輿で、抽斎の歿した八月二十八日に先つこと、僅に五十四日である。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "学業成就して弘前に帰るなら、我らはこれを任用することを吝まぬであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その子甲子蔵は才学があるので、藩の公用局の史生に任用せられていたのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "後大江は県令｜林厚徳に稟して、師範学校を設けることにして、保を教頭に任用した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それゆゑその任用せられたのは、多紀氏の余沢である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "某局長の目金で任用せられたとか云うので、木村より跡から出て、暫くの間に一給俸まで漕ぎ附けたのである。",
              "citation": {
                "source": "食堂",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず知事にはそれとなしに、この県へ入るとまるで天国へ来たようで、道路という道路は到るところビロードを敷きつめたようだ、それにこういう賢明な粒よりのお歴々を任用している当局はまことに絶大な賞讃に値するなどと仄めかした。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかのみならず多くの場合、外國人をも自國人同樣、何等の差別なく官吏に任用して居る。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に唐時代には、尤も自由に、尤も多數に、外國人を任用した。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "始皇帝五世の祖に當る孝公が、かの商鞅を任用して、富國強兵の大政策を建ててから、天下の大勢は已に秦に歸しかかつて居たが、始皇帝の親政時代、僅々十數年の間に、首尾よく一統の實を擧げ得たに就いては、彼の功績も亦尋常ならずといはねばならぬ。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の太祖が燕京を陷れてから元の太史院（天文臺）に奉仕して居つた囘々の暦官をその儘任用して、暦日のことを掌らしめた。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの『華夷譯語』『元朝祕史』等の翻譯に特別の關係あつた翰林編修馬沙亦黒その人も實は當時太祖に任用された囘教徒である。",
              "citation": {
                "source": "創建清眞寺碑",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その有力者は往々にして位階勲等を有し、衛府の武官として任用せられたるものまた少からず。",
              "citation": {
                "source": "武士を夷ということの考",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその特に勲功のあったものには、或いは位を授けたり、或いは郡司に任用したりなどしまして、大そう調子よく進んでいたのでありました。",
              "citation": {
                "source": "本州における蝦夷の末路",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の官制および官吏任用の実際は、ある種の行政事務に特別の興味を有し、したがって特殊の知識技能を有する役人が一生をその事務にささげつつ適当に出世しうるようにできていない。",
              "citation": {
                "source": "役人学三則",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人を学務部長とする場合にも決してその人が教育事務の主任者として適当であるかどうかを考えるのではない、その人を役人としてある程度に昇進させる必要がある場合に、たまたまその必要なる昇進を与えるに適する地位が学務部長であれば、本人の知識技能いかんを問わずして学務部長に任用するのである。",
              "citation": {
                "source": "役人学三則",
                "author": "末弘厳太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不良になっているにちがいないと、最初から教護院の職員出身者を収容所員として任用しているのがあり、鉄格子を窓にはめたのがあるようだ。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長崎談判」以來の功勞で、在府中だけ帶刀御免をされた榮之助は、つづいて起つた同年末からの「日露修好條約」には、名を多吉郎と改め普譜役に任用され、のち外國通辯方頭取となつたし、このときの小通詞堀達之助も士分に取立てられ、蕃書調所教授となつた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の官吏任用に對しては、資格限定の程度と方法は別問題なりと設辭して、尚ほ獵官の餘地を後日に留め其の收賄行動に對しては、此等弊竇は我黨の深く戒規したる所にして、今更之を一洗するの必要を感ぜず。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
