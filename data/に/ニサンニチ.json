    "definitions": [
      {
        "index": 1,
        "gloss": "two or three days",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから二三日してからのことであつた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年私ハ、小サイタライノオ風呂ニ二三日ゴトニ入リマス。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "うるさい時代が過ぎて、二三日、ほっとしたと思ったら、また、うるさい時代がやって来ました。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は二三日前、給士を呼んで、色んな学校の裏面に就いて訊ねようとしたのであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前初めて辻氏を訪ねたら貴兄に手紙を出してみるがいゝといはれたので、手紙を書かうとしたのですが、手紙つて奴が僕には六ヶ敷いから、過日書いた貴兄についての論文（？",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その噂に依ると、二三日前から――さう、だから彼等の噂に一日と続くものはあんまりない筈である――竹山を辞職させようといふ社長の考へだといふ噂があつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、後で、いろいろ、理論めいて、えらさうな事はいへようが、そんな名目論や、ゴマ化しで無いものが、底の方に流れてゐる、といふ事が、二三日して、ぼんやり私にも分つて来た。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此頃少し身體の工合が惡いので二三日保養のために何處か温泉にでも出掛けようといふ、その目的地に此の因縁つきの伊香保が選ばれることになつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎二三日来風邪をひいて居て女中は欠勤して居りました。",
              "citation": {
                "source": "雪の日",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "落魄れた館へ帰って行った、　二三日経って女はまた湧玉の水のほとりで、男と会った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦労もほどほどの分量にゃ持ち合せているもんだよ」　それから二三日経って、老妓は柚木を外出に誘った。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のような外国人でも二三日続けて行くと「あなたのナプキンを決めましょうか」と聞く。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "話は変わるが二三日前若い人たちと夕食をくったとき「スキ焼き」の語原だと言って某新聞に載っていた記事が話題にのぼった。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前に百花園からつるの手をつけてある目籠に長命菊つくし石竹の苗其他数種の青草を植込にしたやつを買って来て置いたのを持って往ったのであるきょうは暖炉の掃除をやったとの事で先生は八畳の座敷に石油暖炉をたき東向になってねていられた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日たって民さんはなぜ近頃は来ないのか知らんと思った位であったけれど、民子の方では、それからというものは様子がからっと変ってしもうた。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等二人の精神状態は二三日と云われぬほど著しき変化を遂げている。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く二三日以来の二人の感情では、民子が求めるならば僕はどんなことでも拒まれない、また僕が求めるならやはりどんなことでも民子は決して拒みはしない。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　それから二三日して、犀星が私の所へ訪ねてきた。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七五郎、　「暫く居るンだろう」　「今夜帰るつもりだ」　お静、　「まあ、今夜帰るの」　「ウン」　「馬鹿に急ぐんだな、おい、ゆっくりして行けよ、久し振りに来たンじゃねえか」　「せめて二三日遊んで行ったらどう？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京を立つ二三日前から私はさるすべりの花に驚かされてゐた。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺はあの美しさが信じられないので、この二三日不安だつた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前、俺は、ここの渓へ下りて、石の上を伝ひ歩きしてゐた。",
              "citation": {
                "source": "桜の樹の下には",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私、あなたのいい方だってことはよく知ってるのよ」　二三日晴天が続いた。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時のぢつと見合つた二人の眼の中に含まれた或る意味――それから二三日寢ながら考へて行く内に、私はそれがだんだんに分つて行くやうな氣がした。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた二三日經つた、或る夜の十時頃の事だつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕先づ出｜陣に及んで何と四｜勝一｜敗、すつかり得｜意になつてゐると、つい二三日前には口｜惜しさの腹癒やさんずと向うから來｜戰に及んで何と三｜敗一｜勝、物の見事に復讐されてしまつた。",
              "citation": {
                "source": "下手の横好き",
                "author": "―將棋いろいろ―",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱月さんはあとで聞けばその二三日前に死んだのであるが、私は抱月さんその人を見たのは、その二月ほど前に牛込の藝術座の廊下で遠見に姿を見たのが初めてでまた最後で、無論何の面識も持たない人だつたのである。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二三日前に死んだと云ふ事實があつたにしても、私にとつては全く縁もゆかりもなかつた抱月さんが、どうして私のそんな幻覺になつたのか今以て判斷がつかない。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "着物は風呂敷に包んだまゝ二三日老人の部屋に出して置かれたが、やがて、ばあさんは行李にしまいこんだ。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前、将校が軍刀を抜いたのがもとで、両方が、いがみ合っている。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
