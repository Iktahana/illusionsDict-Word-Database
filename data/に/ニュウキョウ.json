  {
    "uuid": "964b7022-0abb-5119-9c2a-2fb1b4e76a04",
    "entry": "入境",
    "reading": {
      "primary": "にゅうきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "crossing a border",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "榎はどこか、深山の崖か、遠い駅路の出入境に有る、繁った大な年｜経る樹らしい。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月五日に備中国の境に入つて、「入境」の作がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚ほ岳珂の傳ふる所に據ると、蒲姓の家宅の後に高大ながこの塔上に登つて、天に叫呼して南風を祈り、外舶の入境の便利を圖つた。",
              "citation": {
                "source": "蒲壽庚の事蹟",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
