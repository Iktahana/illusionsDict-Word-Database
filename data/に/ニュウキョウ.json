[
  {
    "uuid": "54fa86d4-825b-53b2-aca5-215050d5a455",
    "entry": "入京",
    "reading": {
      "primary": "にゅうきょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "entering the capital",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "真耶、偽耶、太祖の失か、失にあらざるか、斉泰の為か、為にあらざる耶、将又斉泰、遺詔に托して諸王の入京会葬を遏めざる能わざるの勢の存せしか、非｜耶。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖の崩ぜるは閏五月なり、諸王の入京を遏められて悦ばずして帰れるの後、六月に至って戸部侍郎卓敬というもの、密疏を上る。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸王の入京会葬を遏めたる時の如き、諸王は皆｜謂えらく、泰皇考の詔を矯めて骨肉を間つと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時は、芸兵入京し、長兵も亦入京していたので、慕府及びその一統が、憤慨して手を出せば、やっつけてやろうと云う肚が排幕派にあったのである。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「九月二十一日、就中土一揆｜乱入京中。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "入京の非常に難儀なこと、私自身の健康のこと、旅費のこと、それからそれと頭の痛くなるほど繰返されてゐるところへ、ひよつこり庭先へ服部純雄さんがやつて來た。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "入京は非常に困難らしいが、幸いなことに、私共は四日の午後に、何がなくとも、福井を出発する準備をしていた。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "役場から、入京に必要だと云う身分証明書を貰った。",
              "citation": {
                "source": "私の覚え書",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この寂しい入京は、おのずと頭の下るような自分の長旅の終りに適わしいとも思った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田も中西も、保と同じく慶応義塾に入らんと欲して、共に入京したのである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治十五年に保が三河国｜国府を去って入京しようとした時、五門は懇親会において保と相識になった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "保は三月三日に静岡から入京して、麹町｜有楽町二丁目二番地｜竹の舎に寄寓した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "入京後三月二十六日から博文館のためにする著作翻訳の稿を起した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "脩はこの年五月二十九日に単身入京して、六月に飯田町補習学会｜及神田猿楽町｜有終学校の英語教師となった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻子は七月に至って入京した。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "脩は七月に鉄道庁に解傭を請うて入京し、芝｜愛宕下町に住んで、京橋｜西紺屋町秀英舎の漢字校正係になった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十九年には脩が入京して小石川久堅町博文館印刷所の校正係になった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時二人の目に奸人の巨魁として映じたのは、三月に徴士となつて熊本から入京し、制度局の判事を経て、参与に進んだ横井平四郎であつた。",
              "citation": {
                "source": "津下四郎左衛門",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "里恵の墓は松陰が其文を撰んだが、但「頼山陽先生入京、娶為継室」と書して、婚嫁の年を言はない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは第三次文政二年の入京である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故にさう云ふかと云ふに、菅茶山は文化十四年に「斎は入京した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "入京の日は四月八日であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都｜総而静謐、僕等本月八日入京仕候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中雨｜少にて、僅一両日微雨に逢候｜而已、只入京之日半日雨降申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "想ふに※斎は入京数度に及びながら、京よりして南下するには及ばなかつたのであらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽は此間の事を、「入京及江戸」の五字中に収めてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "小島春庵の入京は事実の徴すべきものがある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "宝素入京の事実は、初めこれを長井金風さんに聞き、「日本博物学年表」を閲して其年を知り、後に宝素の裔小島｜杲一さんに乞うて小島氏の由緒書を借抄することを得、終に其月日をも詳にするに至つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "京水自筆の巻物に、「里帰の祝の為に入京」と書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
