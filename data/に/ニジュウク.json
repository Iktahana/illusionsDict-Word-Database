        "examples": {
          "standard": [
            {
              "text": "借金と病気の二重苦で、彼は絶望していた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「もう、この二重苦から解放されたい…」と彼はつぶやいた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "慣れない土地での孤独と、仕事のプレッシャーという二重苦に耐えなければならなかった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "狼狽と後悔との二重苦のうちに、私は不図一つの策略を思いついた。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病気は、私の経験からいつても、またひとの場合をみてゐても、常に、二重苦、三重苦によつて、その不幸が倍加されてゐるやうに思ふ。",
              "citation": {
                "source": "述懐",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
