[
  {
    "uuid": "45ffbcb1-c5cf-507a-9383-d41b4a8e5088",
    "entry": "逃げ",
    "reading": {
      "primary": "にげ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
