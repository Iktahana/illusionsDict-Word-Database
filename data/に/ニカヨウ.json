[
  {
    "uuid": "ac039d1a-4dcc-5d7f-89f1-fa1aea49629a",
    "entry": "似通う",
    "reading": {
      "primary": "にかよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ウ行",
