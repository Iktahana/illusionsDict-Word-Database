        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "西荻窪のアンゴ氏は、終戦後初登場のニューフェイスで、私も、いさゝか慌てた。",
              "citation": {
                "source": "西荻随筆",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は三年ほど前に、某撮影所の迎えの人に無理ムタイに撮影所へひきずりこまれて、試写を見せられ、撮影を見せられ、ニューフェイスの教室までのぞかせられたことがある。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "このニューフェイスの教室にはおどろいたね。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "宝塚女子占領軍――阪神の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれてこいよ」　暁葉子はかけだしのニューフェイスだが、細巻がバッテキして、相当な役に二、三度つけてやった。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "細巻もバッテキの甲斐があったといささか鼻を高くしていた矢先であったから、はいってきた葉子とニューフェイス仲間のミノリを睨みつけて、「バカめ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、スターならいざ知らず、海のものとも山のものともつかないニューフェイスに、三百万はおろか、三十万でも社で渋るのが当然なわけだ。",
              "citation": {
                "source": "投手殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "方々でニューフェイス、ニューフェイスで騒いでいるようじゃないかね？",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも荻舟君は、よその社にいたのを、引き抜かれて来たのであるが、私同様のニューフェイスが、三十五円だったのには、腹が立った。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
