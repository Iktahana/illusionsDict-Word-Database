        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しかし田舎にはまた人工的の風呂の代りに美しい自然に囲まれた日光浴場がある。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "１　冬が来て私は日光浴をやりはじめた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光浴をするとき私の傍らに彼らを見るのは私の日課のようになってしまっていた。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蠅と日光浴をしている男」いま諸君の目にはそうした表象が浮かんでいるにちがいない。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光浴を書いたついでに私はもう一つの表象「日光浴をしながら太陽を憎んでいる男」を書いてゆこう。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした感情は日光浴の際身体の受ける生理的な変化――旺んになって来る血行や、それにしたがって鈍麻してゆく頭脳や――そう言ったもののなかに確かにその原因を持っている。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不快感は日光浴の済んだあとなんとも言えない虚無的な疲れで病人を打ち敗かしてしまう。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、食前の日光浴をしにヴエランダへ出た。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光浴用の寢臺に横はつて、薄目あけつつそれだけを觀察してから、看護婦に本を持つて來させた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日光浴をしにヴエランダへ出て、ふと葉藏のすがたを見るなり、また病室へ駈けこんだ。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "い號室の患者も、ろ號室の患者も、日光浴用の寢臺に横はつてゐて、三人の樣子に顏をあかくして笑つてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸で裸で日光浴をやっているオットセイのような群れも号令でいっせいに寝返りを打ってこちらを向く。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の処々に青塗りのベンチが置いてあって、日光浴や散歩に疲れた患者達が黙って腰かけて居る。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は療養の末、病棟を歩き回り、ヴェランダで日光浴が出来るほどまで回復したのだが、そんなときインド領の呪いこと腸チフスにかかり、病床に伏してしまった。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンチとベンチの間にはベッドが置かれて、真白い薬を塗った石膏のやうな病人が日光浴をしてゐる。",
              "citation": {
                "source": "青白き夢",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯槽からあがつてその流の中に横たはりますと、身體半分は温浴、半分は日光浴が出來るといふ有樣です。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "酷く六ヶしい顏をして彼が、海邊の方を眺めてゐると、彌生が口笛を吹きながら廊下をまはつて來て、窓先の縁側に置いてある布椅子に寢ると、「日光浴に出たいんだけれど、人がゐるんで困つてしまつたわ。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「――日光浴は病人がすることぢやないか。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房が吹いたんだらう……ともかく今日は、素晴しい日光浴日和ぢやないの。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ、ずつと向ふの松林の方まで行つて見ない、誰も人の居さうもない――」「日光浴、するのか、ほんとに？",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それとも、いつそ、思ひきつて、そこからバスに乘つて、小八幡か酒匂の方まで行つて見ようか、松濤園の下あたりまで……」「……ドレスや下着も、靴だつて、要心に、その中に入れて來たんだから、日光浴なんて止めにして、散歩に變へても好いけれど、着ることが出來ないわ。",
              "citation": {
                "source": "痴日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　芝生の上では、日光浴をしている白い新鮮な患者たちが坂に成った果実のように累々として横たわっていた。",
              "citation": {
                "source": "花園の思想",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤坊たちは、未来の闘士も婦人技術家もズラリと並んだ白い小さい寝台におさまり、夏なら白樺の木かげで、臍まで日光浴をしながら、三時間おきに、二十分間ずつ乳をのませに職場からやって来るおふくろの胸に熱烈な生活力で吸いつくというわけだ。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランシス・スワン夫人は彼女がホテルの日光浴外廊のアペレテフの上で私と私の妻に告白したとおりに、セルビヤの将軍の娘だった。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は日光浴をしたり魚を釣ったり、夜は燈火をともして聖書やアウグスチヌスや主として、レリジアスなものを研究しています。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであたしはこの子のために、いかに太陽の光線が衛生によいかを知らせるため、この公園へ日光浴をさせに来たんだけれど、生憎今日はあまり照らないのネ」「うむ、なるほど」といったが、見たところ絹坊は日光浴どころか、この灰色の空にさえ慄えあがっていた。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "クリスマスの日、　　〔七、八、九の欄外に〕佃に対する感情の説明　十、日光浴室、三十一日の晩、New year 八日退院、九日の朝の散歩。",
              "citation": {
                "source": "「伸子」創作メモ（一）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそかどのとれた圓滿な男なんだがね‥‥」「驛へ勤めてゐるのは結構ぢやアないか、自分で卑下して、人にからんでくる奴は厭だねえ‥‥」　　　　　　　○　翌朝、埼子は二階の狹いサン・ルームで日光浴をしてゐた。",
              "citation": {
                "source": "就職",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
