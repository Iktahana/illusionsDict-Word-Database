    "definitions": [
      {
        "index": 1,
        "gloss": "Japanese-style house",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
