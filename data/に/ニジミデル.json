    "definitions": [
      {
        "index": 1,
        "gloss": "to exude (e.g. sweat)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いまはもう、胸がどきどきして顔が赤らむどころか、あんまり苦しくて顔が蒼くなり額に油汗のにじみ出るような気持で、花江さんの取り澄まして差出す証紙を貼った汚い十円紙幣を一枚二枚と数えながら、矢庭に全部ひき裂いてしまいたい発作に襲われた事が何度あったか知れません。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてそのあとから水のにじみ出るようなさびしさが襲って来るのであった。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸人の悲しさが、無意識のうちに、にじみ出るのだね。",
              "citation": {
                "source": "メリイクリスマス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "額に汗がにじみ出る。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身に油汗がにじみ出る感じ。",
              "citation": {
                "source": "恥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ四月の始めなのに油汗がにじみ出るというのは余程精力的な男でなければ、どこか内臓に悪いところでもあるのでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うて、彼は思わず涙のにじみ出るのを覚えた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの純一無雑な生命の流露を見守っていると私は涙がにじみ出るほど羨ましい。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい油汗が手のひらににじみ出るばかりで、握ったものは何の力にもならない事を知った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身に冷や汗がにじみ出るのを覚えました。",
              "citation": {
                "source": "玉振時計の秘密",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄は空腹を抱えながら、公園裏の通りをぶらぶら歩いたり、静かな細い路次のようなところにたたずんで、にじみ出る汗を袂で拭きながら、いつまでもぼんやりしていることがたびたびあった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして時々涙のにじみ出る目角を、指頭で拭っていたが、終いにそこを立って暗い段梯子の方へ行った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして袂で顔ににじみ出る汗を拭きながら、黙って裏口の方へ出て行った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして手※で玉のようににじみ出る鼻や額の汗を拭いた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ねえ‥‥」「うん‥‥」　うんと応へてくれた信一の言葉の中にはにじみ出るやうな温かいものがある。",
              "citation": {
                "source": "幸福の彼方",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は一人で全宇宙を背負ふことになつたのであるから、その重さからでも涙はにじみ出るであらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "あぶら汗のにじみ出るようないやな天気の一日であった。",
              "citation": {
                "source": "日記",
                "author": "一九一七年（大正六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、ほんとに、わたしあなたとのことならどんな小さいことでも一つ一つみんな覚えていましてよ」「――僕だって」と彼は呟いて熱い涙が眼ににじみ出るのをこらえていた。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "肉付は豊かだし、顔はほんのり血色がよいし、身体全体が石膏のように白く、ただそこに町方の娘に見出されるゆるやかに流れる鮮かな血潮の色あいと皮膚ににじみ出る青春の光沢がなかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の立派さやにじみ出る人格的の力に対抗するような、平常「虚偽」の底深く遠のいている、犯しがたい「真の自分の力」が自分をすっくと立たせはじめたらしかった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ、にじみ出る涙に無理はないのだ。",
              "citation": {
                "source": "二人の男",
                "author": "島田清次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "不慮の災いからして遂に夭折すべき運命にとらわれてしまった不幸な弟、いたわしいこの小さな魂の所有者が我儘も病苦もさして訴えず、ギーギー鳴る竹の寝台に横たわっているのを見て、母はにじみ出る涙をかくしつつ弟を慰め、一日を十年の様な心持で愛撫しいとおしみつつ最後の日に近づいてゆくのであった。",
              "citation": {
                "source": "梟啼く",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "「心の故郷我等が母校」と歌つて來ると熱い涙がにじみ出る。",
              "citation": {
                "source": "校歌「都の西北」と私",
                "author": "相馬御風",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一人、うす明るい町を歩いて居る私はほんとうにみじめな涙のにじみ出るほど悲しい気持で居た。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その音を、不思議な様な様子をしてきいた男がもはしみじみと涙のにじみ出る気持になって又そのまんまそこに座ってしまった。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち充血した眼の中から涙がじくじくにじみ出る。",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞台脚本の場合もそうであるが、作者があまり演出家の領域にまで足を踏み込み、時とすると、俳優の頭や神経まで使つて書いたものは、脚本としてなかなか特色はあるけれども、一方、しばしば、大切な作品の生命が稀薄になり、底からにじみ出るような美しさに欠けることがある。",
              "citation": {
                "source": "ラジオ・ドラマ私見",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋪道をしばらく歩いてくるうちに、もう体に汗のにじみ出るのをおぼえる。",
              "citation": {
                "source": "脱帽",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ、日は高いのでございますが、重くるしく、ずっしりと、空いっぱいに、たれこめた鼠色の雲の堆積から、さながら、にじみ出るかのように、濃い、乳色の気体が立ちならんだ人家の上を、通りの中を、徐々に、流れはじめたのでございました。",
              "citation": {
                "source": "両面競牡丹",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "・つかれた脚を湯が待つてゐた・雲がいそいでよい月にする　七月十八日晴れて暑い、ぢつとしてゐて汗がにじみでる、湯あがりの暑さは、裸体になることの嫌いな私でも、褌一つにならずにはゐられない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
