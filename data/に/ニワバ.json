    "definitions": [
      {
        "index": 1,
        "gloss": "territory of a stall vendor",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
