    "definitions": [
      {
        "index": 1,
        "gloss": "newton (unit of force)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
