          "standard": [
            {
              "text": "プログラムは、指定された入力ファイルからデータを読み込む。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "コンパイルエラーが発生した原因は、入力ファイルに記述ミスがあったことだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "セキュリティ上の理由から、入力ファイルは定期的にウイルスチェックされる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一九九八年二月末、芥川龍之介の作品を中心に、当時の我々の感覚からすれば、恐ろしいほどの勢いで入力ファイルを送ってくれる人が現れた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "急増し始めた入力ファイルを素速く公開まで進められれば、より意味のある資料になるのにと、悔しさが残った。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            }
