        "examples": {
          "standard": [
            {
              "text": "このロボットは、日本初の実用化された介護支援ロボットとして注目されています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は日本初のノーベル文学賞受賞者として、その名を歴史に刻みました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "日本初の鉄道は、新橋から横浜の間で開通しました。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そんな時期に彼は、完成品としては日本初の、日本電気から発売されたＣＯＭＰＯ―ＢＳ／80に出合った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "なになに、「日本初のテープレコーダー？",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "併しそれも、東洋と雖も、日本初め支那その他も亦、一定の特定条件の下に一応は資本主義化して行きつつあるわけだから、封建期の文化がそのままいつまでも動かずに残って行くということはあり得ない。",
              "citation": {
                "source": "日本文化の特殊性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "その直後には、日本初のマイコン誌『Ｉ／Ｏ』が創刊され、これも急速に部数を伸ばしていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "『行く春』が出て日本初めて詩ありと云はれたのは泣菫氏であつた。",
              "citation": {
                "source": "明治詩壇の回顧",
                "author": "三木露風",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
