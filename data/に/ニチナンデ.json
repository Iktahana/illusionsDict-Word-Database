    "definitions": [
      {
        "index": 1,
        "gloss": "named after",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それに因んでフォワイヨの前身はヨセフ二世ホテルと呼ばれていた。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、糸七の遠い雪國の其の小提灯の幽靈のふ場所が小玉小路、斷然話によそへて拵へたのではない、とすると、蛙に因んで顯著なる奇遇である。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂言の文左衛門は、この頃遊所で香以を今紀文と称え出したに因んで、この名を藉りて香以を写したものである。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "千早、赤坂、吉野の中、赤坂、吉野は落ちたが、千早城のみは、賊の大軍に囲まれながら、金剛山に因んで、金剛｜不壊の姿を示した。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝顏・晝顏・夕顏等、其名の如く其時に開き、西洋でもオシロイ花を、開く時に因んで、四時（フオワ・オークロック）と呼ぶ。",
              "citation": {
                "source": "蓮の花開く音を聽く事",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯、糸七の遠い雪国のその小提灯の幽霊のう場所が小玉小路、断然話によそえて拵えたのではない、とすると、蛙に因んで顕著なる奇遇である。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリップ氏曰く、竜の英仏名ドラゴンは、ギリシアにドラコン、ラテンのドラコより出で、ギリシアのドラコマイ（視る）に因んで、竜眼の鋭きに取るごとしと。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那で馬に因んで驚駭と書き『大毘盧遮那加持経』に馬心は一切処に驚怖思念すとあるなど驚き他獣の比にあらざるに由る。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに一言するは同姓婚と母系統は必ずしも偕に行われず、しかしフレザーが言った通り、母統を重んずるよりやむをえず同姓婚を行う場合もあるに因んで、一緒にその事どもを述べたので、両つながらそれぞれ歴とした訳があり、決して無茶苦茶な乱風でない。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを笑いながら、歴史専門家でなければ記憶せぬ善光寺大地震の頃生まれたカール・マルクスを新説として珍重がるも、阿呆の骨頂と岩猿を絵図と猴話に因んで洒落て置く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴の話と縁が遠いが、『古事記』は世界に多からぬ古典で、その一句一語も明らめずに過すは日本人の面目を汚す理窟故、猿田彦に因んでヒラブ貝の何物たるを弁じ置く。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだしこの山神は専ら森林を司り、その祭日には自分の顔色と名に因んで、赤木に猿たに猿滑りと、一種の木を三様に懸値して国勢調査すと伝えたのだ。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "猪に関する伝説を書くに当り、この篇の発端に因んで野猪と蝮蛇の話を述べよう。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "稲虫の一名｜稲別当、それを斎藤別当に因んで実盛というに及んだ由（『用捨箱』下）。",
              "citation": {
                "source": "十二支考",
                "author": "鼠に関する民俗と信念",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽焼の袋もこれに因んで木兎や達磨の紅摺であったが、喜兵衛は更に袋の新らしい工風をした。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し僕は、ブロークン・ハートに因んで、この題目を選んだ訳では決して無い。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その柳に因んで名づけられた新柳町に、前記の諸寺院の大部分がある訳だが、旧本丸から熱田まで縦走して居る本町筋との交叉点から、市の中心をなす大津町筋との交叉点までがいはゞもつとも繁昌なところであつて、『栄町』の名は至つてふさはしい。",
              "citation": {
                "source": "名古屋スケツチ",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして出来あがつた上は太秦のそれに倣つて牛祭を催す事に定めて、伊原｜青々園の祭文を、梅幸の振付で、その往時の丑之助の名に因んで菊五郎が踊るのだといふ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はこれらの衛星をトスカナ（Toscana）に君臨していた侯爵家の名に因んで『メディチ（Medici）の星』と名づけたのであるが、この衛星の運動の仕方が正しくコペルニクスの所説の重要なる証拠となることを認めた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邊の海岸を東金剛、西金剛といふところから、私はそれに因んで、「金剛洞」と呼んで見た。",
              "citation": {
                "source": "山陰土産",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、池に近い位置に因んで「池の茶屋」とした文字もあらわしてある。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に因んで娯楽的要素と風俗性というものも文学の面白さの要因として挙げられた。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はかつて、最近の日本に於ける自然科学の大衆化・自然科学の啓蒙活動・自然科学ジャーナリズムの発達・に因んで、自然科学の思想化的傾向を指摘したが、この思想化的傾向は、自然科学的認識の逸脱ではなくて、自然科学自身の思想的という意味に於て自然科学的な、進歩と見ねばならぬ。",
              "citation": {
                "source": "哲学の現代的意義",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦争に因んで経済的・政治的・分析を行う一般評論家は併し、勿論非常に多い。",
              "citation": {
                "source": "戦争ジャーナリスト論",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "――乙女は深紅色と青色の服を着て背中から足まで長く伸びた黒髪をしている――これは一四〇〇年前の王女の装束に因んでいる。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦石の製造場があるに因んで、煉瓦餅といふのを賣つてゐる停車場で、その子供が一人減り、そのまた次ぎで一人減り、みんなゐなくなつた頃、義雄の汽車は岩見澤に着した。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで産婦に向かって、モーキイとするか、ソッシイとするか、それとも殉教者ホザザートの名に因んで命名するか、とにかくこの三つのうちどれか好きな名前を選ぶようにと申し出た。",
              "citation": {
                "source": "外套",
                "author": "ニコライ・ゴーゴリ",
                "note": "青空文庫"
              }
            },
            {
              "text": "虹の松原に因んで名を虹汀と改め、八景を選んで筆紙を展べ、自ら版に起して洽ねく江湖に頒たん事を念へり。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さくとも寺であるから主家を御堂と呼び、その上の空に山々の聳えてゐるのを禅宗寺院に因んで五山と呼び、松風を添へて山寺の風致を引き出すわけである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "之も前と同じ時の賛歌で同じく梅に因んでの諧謔である。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
