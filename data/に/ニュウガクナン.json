    "definitions": [
      {
        "index": 1,
        "gloss": "difficulty of getting into a college",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
