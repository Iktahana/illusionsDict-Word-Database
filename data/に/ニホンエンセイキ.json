      {
        "index": 1,
        "gloss": "Narrative of the Expedition of an American Squadron to the China Seas and Japan (1856 report on the 1852-1854 Perry expeditions written by Francis L. Hawks; authorized by Matthew Perry)",
        "register": "standard",
        "nuance": null,
