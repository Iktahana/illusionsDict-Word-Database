    "definitions": [
      {
        "index": 1,
        "gloss": "postscript",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "二伸、――私は、土曜日に、ホオリンゲンの館のすばらしい小徑をさまよひながら、あなたのために、こんなストロフを作りました。",
              "citation": {
                "source": "或女友達への手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには鉛筆の走り書きで――「今夜十時中之島公園、図書館の前で待つ」　　　　　　　　　　　　　　　　　　　　隼　　豹吉へ　二伸　亀吉の二千円は掏らせて貰った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今夜十時中之島公園、図書館の前で待つ」隼　豹吉へ二伸　亀吉の二千円は掏らせて貰った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九二四、四、三〇　夜すえ子なつかしい……私の　玉雄様御許へ二伸誠に恐れ入りますけれど、お写真がありましたら、一枚お恵み下さいませ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ワシリーサ・ツプチェ※スカ愛甥イワン・フョードロ※ッチどの二伸、うちの畠に誠に珍らしい蕪が出来ました。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、彼女――インデアナの未亡人の真の目的はここにあるので、まことに意味深長な二伸だった。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、矢張り、思い付いた儘急いで書き足したらしい二伸がついていて、決して疑うの何のという訳ではないが、「相当以上の資財ある」証拠として、見合いに来る時、三千弗の現金を持って来るように、大金だから、「念のため大事を取って、忘れずに上着の胴中へ縫い込んでいらっしゃいましね。",
              "citation": {
                "source": "斧を持った夫人の像",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども一國な我儘者の圭一郎に傅いて嘸々氣苦勞の多いことであらうとの慰めの言葉を一言千登世宛に書き送つて貰ひたいといふことだけはいつものやうに冗く、二伸としてまで書き加へた。",
              "citation": {
                "source": "業苦",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ Postscriptum（二伸）で、あなたのお胸に訊けば、手紙の主の見当はつく筈です、又あす知事の家で開かれる舞踏会には、当の本人も出席することになっていますとだけ書き添えてあった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "四月十三日　　　　　伊東にて芥川龍之介　　　佐佐木茂索様　二伸。",
              "citation": {
                "source": "伊東から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伸、私の宝石類を書留郵便で返送致します。",
              "citation": {
                "source": "柳原※子（白蓮）",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伸――クラスの諸兄がわたしを慈善の対象とお考えにならないようにねがいます。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "訳者の言葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "はっとして顔をあげると、エミイの顔には苦痛の色があふれ「遺言状には、二伸みたいなものをつけていいでしょうか？",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "電話も今明日中には通ずべきはづ芝○○番に御座候由｜御面倒ながら貴答に接するを得ば幸甚々々彩牋堂主人金阜先生｜碩北二伸　　かの六畳｜土庇のざしき太鼓張襖紙思案につき候まゝ先年さる江戸座の宗匠より売付けられ候文化時代｜吉原遊女の文殻反古張に致候処｜妾宅には案外の思付に見え申候。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伸　林檎の花さくの頃のイギリスの田園の景色は実に忘れ難き美しさに之有候、その頃のケンブリッジ、またオックスフォードの大きな大学街を観ることをお忘れなきよう願上候。",
              "citation": {
                "source": "寺田寅彦の追想",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伸返事一刻も早くくだされ度候。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」　二伸として、彼は手紙を焼いてくれるようにと頼んでいる。",
              "citation": {
                "source": "エリザベスとエセックス",
                "author": "ELIZABETH AND ESSEX",
                "note": "青空文庫"
              }
            },
            {
              "text": "オットー・ディーネル　二伸――日曜には、どうぞ僕の家へ誘いには来ないでください。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして二伸の添え書きがあって、みっともないフェルト帽をよして、麦稈帽を買うようにと、勧めてあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "公判の日時などが二伸に記されていた。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に『矢木幸太郎拝』と署名したあとにも、二伸があり、三拝もつけ加えてある。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "更に二伸としてご本人はあれからも二度ほど見え、私あて、子供あていろいろ手紙がきたりします。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし手紙の終わりに、二伸としてつけ加えた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "はつ秋の空にしんと静もり返っている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのくせ世間が一体に妙にしんとして静かに眠っているようにも思われる。",
              "citation": {
                "source": "夕凪と夕風",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんたうにしんとしてますね。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはあたりの靜かな空氣の中にしんしんと沁み渡つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "職場で、工人達は、水を打ったようにしんとなって、耳を澄まし、仕事をつゞけていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際ある浅薄な理想主義の芸術はまさにしんこ細工の花のようなものである。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　一時がやがやとやかましかった生徒達はみんな教場に這入って、急にしんとするほどあたりが静かになりました。",
              "citation": {
                "source": "一房の葡萄",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
