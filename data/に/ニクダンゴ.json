          "literary": [
            {
              "text": "風葬というのは、犬か鷲に食わせることで、岩山の平らなところへ担ぎあげ、肉は肉、骨は骨にして、石で叩いて手で捏ね、すさまじい肉団子をこしらえ、手も洗わずに恬然たる顔で茶を飲んでいる。",
              "citation": {
                "source": "新西遊記",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の方も、肉団子スープと称するものなどうまい。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝食、唐もろこし湯煮一本分、肉団子とスープ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
