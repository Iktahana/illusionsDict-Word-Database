    "definitions": [
      {
        "index": 1,
        "gloss": "after two outs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "リゼットの疲れた胃袋に葡萄酒がだぶついて意地の悪い吐気が胴を逆にしごいた。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家へ帰って見ると妹は機屋の天井にしごきをかけて縊死していた。",
              "citation": {
                "source": "雀が森の怪異",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう思い思い布の一方を手早く縫い終わって、縫い目を器用にしごきながら目をあげると、そこには貞世がさっきのまま机に両｜肘をついて、たかって来る蚊も追わずにぼんやりと庭の向こうを見続けていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "のどかな顔ばかりしていねえで、たっぷり投げなわにしごきを入れておきなよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "しごきといや、天智天皇の昔から、ひと重のもので、ギュッと伊達にしごいて用いるからこそ、そういう名まえがついているくれえのものなのに、ふた重で袋仕立てになっているたアあんまり聞かねえからね、こいつ、何かいわくがあるだろうと、じつあ首をひねっていたんですが、かなわねえね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "お蘭しごきの秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "リュウリュウと麻幹のごとく見事にしごいて、白髯たなびく古木の面に殺気を漂よわながら、エイッとばかり気合もろ共鳥刺しの面前にくり出すと、「小僧ッ、これでも消えぬかッ」　すべてが全くすさまじい変化でした。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と見えた一刹那、ヒュウと手元にしごいて繰り出したかと見えるや、術の妙、技の奥儀、主水之介程底の知れない男もない。",
              "citation": {
                "source": "旗本退屈男　第八話",
                "author": "日光に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして素早く、そのグニャリと垂れ下った女の手の皮を握ると、手袋を嵌めるあの要領でスポリと逆にしごいた。",
              "citation": {
                "source": "棺桶の花嫁",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの混む省線で、押しあい、へしあいするなかに、かんざし沢山の日本髪、吉彌結びにしごきまで下げた娘さんがまじって、もまれている姿は、場ちがいで気の毒な感じでした。",
              "citation": {
                "source": "今年こそは",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、わたしだって赤んぼを泣かして、みんなをだまして、お前にしごとをさせてやったのじゃないか。",
              "citation": {
                "source": "物のいわれ",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、やがて眼前には、ひらひら悪夢のなかで蠢く水母の手の代りに、今度は胃も食道も、グイと逆さにしごかれるような感覚が起った。",
              "citation": {
                "source": "地虫",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長襦袢にしごきをしめた姿は背丈をなほ高く見せた。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "失望湾は左門洞から約二十キロメートルの距離にある、これは万一のばあい、左門洞の一同と消息を通ずるにしごく容易である。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "他国から来た人と見て、慇懃に、さつきから色々な話を持ちかけて来る六十恰好の夏外套着た紳士は、白い髭を片手間にしごいてゐる。",
              "citation": {
                "source": "雪の島",
                "author": "熊本利平氏に寄す",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあさあ、はいってきて、すぐにしごとをはじめてちょうだい。",
              "citation": {
                "source": "三人の糸くり女",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とかして民さんにしごとを出すものが、見つからないかと捜して歩くのだ、庭というものはぐるぐる廻っていれば、やり直すところ、向きをかえる物、鋏を入れるものなぞが、自然にわかって来る、しかし相当な手間代になるような仕事は、どこにも見つからなかった。",
              "citation": {
                "source": "生涯の垣根",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「一つこのたびだけは、手前どもにもむりをおゆるし願いたいんで」「これだけ事をわけて申し入れてもか」「相すみません」　起き上がりざま、ピンと下緒にしごきをくれた源十郎、「ようし！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分、此通り」　さう言ひ乍らガラツ八は、内懷から拔いた野暮な財布を逆にしごくと、中からゾロリと出たのは、小判が七八枚に、小粒、青錢取交ぜて一と掴みほど。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分、この通り」　そう言いながらガラッ八は、内懐から抜いた野暮な財布を逆にしごくと、中からゾロリと出たのは、小判が七八枚に、小粒、青銭取交ぜて一と掴みほど。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "鉄砲汁",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他の事においては、彼は自分自身にしごく満足していた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、ラ・フーイエットお父つあん（樽のお父つあん）はその綽名にしごく相当していて、月に二、三回は酔っ払っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら急いでも相手のない相撲は取れぬと、父とは反対にしごくのんびりとかまえていたが、ついにどうにもならず今宵に及んだ。",
              "citation": {
                "source": "武道宵節句",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄介は体を斜めにして、人波を逆にしごいて、のろのろと歩いた。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "困ったもんだ」　大久保はおでんを横ぐわえにしごきながら、わざとらしい嘆声を発しました。",
              "citation": {
                "source": "凡人凡語",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "車はさっき乗って来た街衢を、逆にしごいて走る。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "略刀帯を上にしごき上げながら高城に言った。",
              "citation": {
                "source": "日の果て",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついで乱暴にしごきをひきほどき、突いたり殴ったりしながら、わたくしを裸にした。",
              "citation": {
                "source": "やぶからし",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "絞りで模様をおいた鴇色の長襦袢にしごきをしめただけの姿が、あらわに、眼に痛いほど色めいて見えた。",
              "citation": {
                "source": "雪と泥",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
