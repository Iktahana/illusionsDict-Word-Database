          "literary": [
            {
              "text": "はっきりと足の肉球が五つ、爪は長いらしく、全体の大きさは菓子用の匙と大差ない。",
              "citation": {
                "source": "曲れる者",
                "author": "THE CROOKED MAN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりは　ちいさな　肉球で　ぽんぽん　――「あたしたちで　かわいい　マフィンでも　作ろっか。",
              "citation": {
                "source": "ちょびひげサミュエルのはなし",
                "author": "まきまきパンのまき",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あっちの方にゃ、」とここでネコは右の肉球をぐるっとふってね、「ぼうし屋が住んでる。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんであっちの方にゃ、」と今度は左の肉球をふって、「ヤヨイウサギ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫はなおも喉を鳴らし、彼の膝頭に肉球を押し付けたり離したりした。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫は膝頭で喉を鳴らし、肉球を押し付けては離し、長い夜を見守った。",
              "citation": {
                "source": "四風の街",
                "author": "The Street of Four Winds",
                "note": "青空文庫"
              }
            }
          ]
        }
