    "definitions": [
      {
        "index": 1,
        "gloss": "the number of people",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "今では多人数の会へ出ても、不意に人の頭をなぐったり、毒づいたりしようとするところの、衝動的な強迫観念に悩まされることが稀れになった。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山内へ向かう人数につれてぶらぶら歩く。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅々たる行列の進みが百貨店の外の入口まで届くと黒服の店員に管理されて人数の一くぎりずつが内側の入口の床石に誘われる。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほどの人数で合唱してゐるらしいのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの人数が一人一人これから切符を買って這入るのでは、全部が入場するまでに一体どのくらい時間が掛かるかちょっと見当がつかない。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、待っている人数がざっと五百人と見て全部が入場するまでには二百五十分、すなわち、四時間以上かかる。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の輪講会は人数が少なくてそれだけに却って極めてインチームなものであり、至って「尤もらしく」ない「勿体臭く」ないものであった。",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（門人数名を供に連れている）　こらッと、その侍白倉源五左衛門、おしまの腕を掴む。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "大潮の日を選んであるので、流れは人数のわずかな遠泳隊をついつい引き潮の勢いに乗せて海へ曳いて行く。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三人の小人数で、日本兵が街を歩いていると、武器を持ったアメリカ兵は、挑戦的につめよって来た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たまうごとく家という家いくばくありや、人数は二十にも足らざるべく、淋しさはいつも今宵のごとし。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "――チット人数が多すぎるぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月十二日、今日また人数を調べた。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "よほどの人数で合唱しているらしいのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は清国の富豪｜柳氏の家なる、奥まりたる一室に夥多の人数に取囲まれつつ、椅子に懸りて卓に向えり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼光鋭く、意気激しく、いずれも拳に力を籠めつつ、知らず知らず肱を張りて、強いて沈静を装いたる、一室にこの人数を容れて、燈火の光｜冷かに、殺気を籠めて風寒く、満洲の天地初夜過ぎたり。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、小人数とは言へ、他に人がなかつたら、此の友染の袖をのせて、唯二人で真暗の水に漾ふ思がしたらう。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　園の隣なる車は、づゝと長く通つた青い室で、人数は其処も少ない。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神輿の運動の変異量と、その質量や舁夫の人数、各人の筋力、体量等との間に或る量的関係を見いだすことは充分可能でありそうに思われる。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人数の桁数のちがうデパートであったらはたしてどうであろう。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山火事の場合は居合わす人数の少ないだけに、損害は大概｜莫大ではあるが、金だけですむ。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "定員人数の制限を守りさえすれば墜落の恐れはめったにない。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "弘前の新聞記者たち、それから町の演劇研究会みたいなもののメンバー、それから高等学校の先生、生徒など、いろいろな人たちで、かなり多人数の宴会であった。",
              "citation": {
                "source": "チャンス",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "斉藤平太は人数を巧く組み合せて両方の終る日が丁度同じになるやうにやって置きましたから両方丁度同じ日にそれが終りました。",
              "citation": {
                "source": "革トランク",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でも貴方にはトウトウわかったのね……ホホホ……モウ随分前からの事ですからかなりの人数になるでしょう……御存じの家政婦も入れてね……ホホホホホ……」　私は見る見る血の気を喪って行く自分自身を自覚した。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "土竈だって堅炭だって悉な去年の倍と言っても可い位だからね」とお徳は嘆息まじりに「真実にやりきれや仕ない」「それに御宅は御人数も多いんだから入用ことも入用サね。",
              "citation": {
                "source": "竹の木戸",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に群れの人数はだんだんに増す一方である。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすると一つの電車が収容すべき人数は、平均上、すぐ前の電車甲がそこを発車してからの経過時間に比例するものと考えてもいい。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえそれがみんなおとなしい紳士ばかりであっても、乗り込みに要する時間は人数と共に増す。",
              "citation": {
                "source": "電車の混雑について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
