          "literary": [
            {
              "text": "本稿執筆時点の一九九三年一月現在で入手可能なのは、英語版のみ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "農業物理学課題としては各土地の条件に応じて、入手可能の資材をなるべく少く使って、この原理を活かすべきである。",
              "citation": {
                "source": "農業物理学夜話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らが初めて――入手可能な材料と長く知られてきた手法とを用いて――地球生命を創り出したのは海中でのことだった。",
              "citation": {
                "source": "狂気の山脈にて",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
