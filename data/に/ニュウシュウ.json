        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "イフヒムの奴も太腐れて居やがる癖に、胸三寸と来ちゃからっきし乳臭なんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳臭い青二才にも、旦那と云ってお辞儀をする。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かその熱に感じて、桂冠を乳臭兒の頭に加へし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は未熟なる知識を糧とせる乳臭児の襲撃を受けて、知識の事ならば我れいかで汝に譲らんやとて、暫し病苦と悲境とを忘れて嘲弄的逆襲に出たのである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳臭い子供の匂いや、妻のムッとくる膚の臭いを探がした。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "理想などということを言い出すと、まだ世間を知らぬ乳臭児のように一言のもとに言い消される。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "つるつる滑る乳臭い唇だ。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほその次に吾孫｜興邦はなほ乳臭机心失せず。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳴雪翁は短評を以て人を揶揄したり、寸言隻語を加へて他の詩文を飜弄したりすることはむしろ大得意であつたのであるが、今この俳句選の評を見ると如何にも乳臭が多くて、翁の評とは思はれぬほどである。",
              "citation": {
                "source": "病牀六尺",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何だい、まだ乳臭い二歳野郎の癖に……。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ん坊は乳臭くて可愛かつた。",
              "citation": {
                "source": "夜福",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしくなつてしまつて私も小さい声であのねえとくちを耳へ持つて行くと、乳臭い子供の匂ひがして、私は感じたこともない胸さはがしさで、どうきが激しく衝つた。",
              "citation": {
                "source": "柿の実",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳臭い匂ひがふつと鼻さきをかすめると、早苗はいままでの一人居の淋しさが一時に潮のやうに胸に押しよせて來て、切ない氣持ちになるのであつた。",
              "citation": {
                "source": "風媒",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコで私は今度中津に帰ても宗太郎をば乳臭の小児と思い、相替らず宗さん／＼で待遇して居た処が、何ぞ料らん、この宗さんが胸に一物、恐ろしい事をたくらんで居て、そのニコ／＼優しい顔をして私方に出入したのは全く探偵の為めであったと云う。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ乳臭いこの殿の口車に乗せられ居って、抜いた白刃を持て扱うばかりか、おめおめ御意に従いましょうなどとは、どの面下げて申せた義理じゃ。",
              "citation": {
                "source": "邪宗門",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "花香と乳臭と徒らに孰れか多きやの悪※を贏ち得て止まむのみ。",
              "citation": {
                "source": "抒情詩に就て",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "花香を趁ふの童となりて牧童を携ふるに宜しかるべく、乳臭の児となりて琴声を摸ねばむに、絶えて覊せらるゝなきをや。",
              "citation": {
                "source": "抒情詩に就て",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、そのリリシズムには、一抹の生活的乳臭を漂はせ、これがいかんと、僕は危ぶんでゐたのだが、今度といふ今度、小山君は、俄然、その持ち前のリリシズムを「戯曲的」に、主題を、「やや象徴的」に処理しはじめた。",
              "citation": {
                "source": "『十二月』",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳臭い声で「ミミミミ」と甘える声や、可哀くてたまらない様にそれに答える母牛の声が私までが良い気持になる様にひびいて隙間から、草を口うつしに喰べさせて居るのが見える。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕頭の方では、乳臭い子供の香をたずねると見え、幾羽となく集って来ていた。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "柄をひっ掴むとグ――ッと振り上げ、「今度こそ遁がさぬ、乳臭児めが――ッ」　振り返って躍りかかった。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何んだ乳臭い子供ではないか。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やんがて俺等は村に著く、　　　空が半分｜暗エ頃、乳臭エ匂ひがしてゐようわサ　　　日暮の空気のそン中で、臭エ寝藁で一杯の、　　　牛小屋の匂いもするベエよ、ゆつくりゆつくり息を吐エてヨ　　　大ツきな背中ア薄明で白ウくみえてヨ、　　　向ふを見ればヨ牝牛がおつぴらに糞してらアな、　　　歩きながらヨ。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十未滿の女が小説で知つてゐる東京に憬れて、東京の何とか云ふ英語學校へ入つて、學問で身を立てゝ、一生獨身で通すといふやうな乳臭い言ひ草を眞面目に聞いて、兔や角と無用な陳腐な意見を述べる氣にはなれないのだつた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ乳臭い、鼻垂れ小僧のくせして、それで、人と違ったことがしたいなんて……」　だが、ルピック夫人は、彼の額に、一度だけ接吻してやるのである。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "當時私は乳臭で、とても會得が出來たことではなかつたが、それでも幾分哲學上の術語に接し、ターレスやピタゴラスなど、西洋哲學者の名を知つて哲學に對する興味を唆り、同時に先生に對して深い景慕の念を懷くに至つた。",
              "citation": {
                "source": "巽軒先生喜壽の祝辭",
                "author": "中島徳藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十未満の女が小説で知っている東京に憧れて、東京の何とかいう英語学校へ入って、学問で身を立てて、一生独身で通すというような乳臭い言いぐさをまじめに聞いて、とやかくと無用な陳腐な意見を述べる気にはなれないのだった。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の鉱山行などもその時そのままの心持を、日記にでも書いて置いたら、定めし乳臭い、気取った、偽りの多いものが出来上ったろう。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄口少年、乳臭いまだ乾かず、わずかに数巻の西籍を読み、生呑活剥、儼然学者をもっておるものあり、利をむさぼりてあくなきものあり。",
              "citation": {
                "source": "妖怪学講義",
                "author": "再版につきて一言を題す",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
