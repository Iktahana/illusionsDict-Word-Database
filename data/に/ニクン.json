        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "丁度その頃、雜誌「驢馬」の同人を主とし、室生、芥川の二君を賓とするパイプの會が上野にあつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして孤雁木城二君が、横浜山王山の私の宅を尋ねられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭二君はその次男で、兄は重雄、法学博士で現に京都大学教授である。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "恭二君は明治十年十月二十四日東京で生れ、芝桜田小学校から日本中学校に入り故杉浦重剛氏の薫陶を受けた。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "席上「驢馬」の宮木喜久雄「青空」の三好達治の二君あり。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年生の某々二君と、池の水温分布を測った事がある。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "敬治君が戻つてくる、樹明君が酒と下物とを持参した、やつぱり酒はうまい、二君がそれ／″＼帰つた後で、自分で自分の酔態を笑つたことである。",
              "citation": {
                "source": "行乞記",
                "author": "伊佐行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度などは、浅草の何とかいふ珈琲店にラヂオがあるといふので、わざわざ詩人の多田不二君と聴きに行つた。",
              "citation": {
                "source": "ラヂオ漫談",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二、国に二君なく民に両主なし。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひどく醉つた末、明朝訪ねるつもりであつた法月俊郎君方に電話をかけると、彼は驚いて弟浩二君と共に其處へやつて來た。",
              "citation": {
                "source": "樹木とその葉",
                "author": "春の二三日",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、此頃洋酒は苦手で具合が悪いのだが――其処は、シーク・ドランカーの井伏鱒二君や中村正常君達に依つて知らされたところなので、彼等がゐれば好いが――と念じながら走つた。",
              "citation": {
                "source": "川蒸気は昔のまゝ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔無題〕牧野信一　そのとき、たしか、永井龍男君と井伏鱒二君と堀辰雄君と小林秀雄君とに私は誘はれて、恰度うらうらとするこのごろのやうな長閑な日の夕暮時に銀座の方から、須田町の万惣にあつまつた。",
              "citation": {
                "source": "〔無題〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私は、小野松二君にはぢめて会つた。",
              "citation": {
                "source": "〔無題〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本上古の遺物に、牛馬飼養の証左ある由は、八木、中沢二君の『日本考古学』等に出づ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田　僕も今まで知らなかったが、中二君の話ではここから、三四町ほど距れた所にあるそうだ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）中二君は今夜も来るんですか。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田　いや、今度こそは中二君でしょう。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ああ、やっぱり中二君だ。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）中二君……中二君……。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田　こういう事になるのを予期していたわけでも無いでしょうが、中二君はなぜか傷害保険を付けていたそうで、その保険額は三千円だと云うことです。",
              "citation": {
                "source": "青蛙神",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "正宗君、徳田秋声君、この二君は、その成功不成功は兎に角置いて、『自己』から進んで『他』へ入らうとして努力して居る作者であることは、誰も認めることであらうと思ふ。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊島与志雄君の『生あらば』、久米正雄君の『エロスの戯れ』、谷崎精二君の『淡雪』この三つをも読んで見た。",
              "citation": {
                "source": "自他の融合",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇野浩二君のものには、とても完璧と言つたやうなものは望むことは出来ないでせうね。",
              "citation": {
                "source": "黒猫",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、二葉亭の一生はこれらの二君に比べると更に一層意味のある近代的の悶えと艱みの歴史であった。",
              "citation": {
                "source": "二葉亭四迷",
                "author": "――遺稿を整理して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らくそれは舎弟の三木竹二君の斡旋に因るものであろうが、劇界では破天荒の問題として世間の注目を惹いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃、賢二君の話によると、歌舞伎座の作者部屋の給料はあわせて四百五十円で、その中から二百円ぐらいを本所へ送り、百円ぐらいを立作者の寺内が取り、残りの百五十円を一同に分配するのだとかいうことであった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの事情から、とても芝居｜覗きどころの騒ぎではないので、わたしは自分が受持ちの劇評を三木竹二君にたのんで、編集の仕事と従軍の準備とに昼夜をあわただしく送っていた。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに穴をあけてどうするんですか」「おう、敬二君か。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "○○獣が墜っこったって本当ですか」「おお敬二君か。",
              "citation": {
                "source": "○○獣",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "却つて私はかういふ意味での勇者をにくんでゐる。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
