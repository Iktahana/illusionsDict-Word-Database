          "literary": [
            {
              "text": "だがそれにも拘らず、彼はその趣味性の享楽を生活化し、ヂレツタンチズムを肉体化することによつて、不思議な個性的芸術を創造するところの、日本茶道精神の奥義を知つてる。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱き紅茶は春のくれ、雪のふる日はアイスクリーム、秋ふけて立つる日本茶、利休ならねどなほさら寂し。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋ふけて立つる日本茶、利休ならねどなほさら寂し。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤア日本茶店と書てある。",
              "citation": {
                "source": "初夢",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、日本茶を入れてのむのに、車掌のところへ行ってさゆいりのコップを借りたら年上の、党員ではない方の車掌がもしあまったら日本茶を呉れと行った。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あなた日本茶、知っているの？",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "其面ニ刻スル文ニ云フ、長楽未央漢宮瓦、高帝五年治、七年成、本秦之興楽宮、此瓦殆蕭何所書、稀世之宝」其背ニハ、傚日本茶道宗師嘱製之法、道光三年刻之　素川ト刻セリ。",
              "citation": {
                "source": "土用干ノ記",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本茶道の伝統を誇る茶人にして、だんだんと降っていくこの有様は、遺憾というより他にない。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他支那茶を円型に乾し固めたのを持って歩いていたし、日本茶を土産に持って行くと、たいへん喜んで、おかえしに乾肉をくれたりした。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "予ハ起キ上ッテ洗面ヲ済マセ、部屋ニ日本茶ヲ取リ寄セテ鱧ノ鮨ヲパクツク。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は座員一同鎌倉の海で慰労会といふ日、駅からすぐ海岸へ、日本茶館の出張店で休む。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉園で一休み、六時に又、日本茶館へ集り、去年も行った鎌倉山の高島氏の別荘へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
