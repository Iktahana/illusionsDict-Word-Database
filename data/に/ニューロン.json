        "examples": {
          "standard": [
            {
              "text": "人間の脳には数百億個ものニューロンが存在し、複雑なネットワークを形成している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ニューロン同士はシナプスを介して情報を伝達し、思考や感情を生み出す。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この人工知能は、ニューロンの構造を模倣したニューラルネットワークを採用している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかしながら、チャールズ・ウォードはニューロンドンにおいて、とあるフェナーの文通相手からほんやりした側光を見いだした。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで六月までには、ニューロンドンとニューヨークに旅行し同地に存在することが示された古い手紙を調べるための準備ができていた。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリストテレスは神経と腱を区別することが出来ずギリシア語のニューロンは区別しないで両方に使われていたがヘロピロスは脳が神経系の中心的な臓器であり末梢神経は感覚を伝える臓器であることを知っていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
