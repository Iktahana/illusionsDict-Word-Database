        "examples": {
          "standard": [
            {
              "text": "日本図書館協会は、図書館の自由に関する宣言を採択し、知る権利の保障に努めている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "学校図書館司書として、日本図書館協会が推奨する新刊リストを参考に選書を行う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "日本図書館協会の全国大会に参加し、各地のユニークな図書館活動について共有した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "二十世紀の後半の、巌頭に立って、わが日本図書館協会は、まったくそれにふさわしく出発したことについて、諸兄とともに、その喜びをわかち合いたいのである。",
              "citation": {
                "source": "大会を終りて",
                "author": "中井正一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「法案の流線型化」という妙な言葉を考えついたのも六月の大阪における日本図書館協会大会においてであった。",
              "citation": {
                "source": "図書館法楽屋話",
                "author": "中井正一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
