  {
    "uuid": "e53d0a1f-99f9-5083-81d6-cc3c0c2f2f0e",
    "entry": "兄",
    "reading": {
      "primary": "にい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞-接尾辞"
      ],
