[
  {
    "uuid": "41ef6a18-e46d-5f1f-a361-1f8b98b50f51",
    "entry": "任地",
    "reading": {
      "primary": "にんち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
