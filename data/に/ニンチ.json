      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "one's place of appointment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）、終列車にて父の任地なる旅順に赴いたのださうである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の医師に診てもらうために出て来て私のうちで数日滞在してから、任地近くの海岸へしばらく療養に行っていたが、どうもはかばかしくないので、学校を休職して郷里の浜べに二年余り暮らした。",
              "citation": {
                "source": "亮の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこれからはあなたの買物に行くときにはいつでも一しょに行ってあげますよ」　その秋に松崎は浦子を妻に貰って東北の任地へ立って行った。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "復一よりも単純な研究で定期間に済んだ同期生たちは半年前の秋に論文が通過して、試験所研究生終了の証書を貰ってそれぞれ約定済の任地へ就職して行った。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　その秋に松崎は浦子を妻に貰つて東北の任地へ立つて行つた。",
              "citation": {
                "source": "汗",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "興世王もこれには憤然とせざるを得なかつたが、根が負け嫌ひの、恐ろしいところの有る人とて、それなら汝も勝手にしろ、乃公も勝手にするといつた調子なのだらう、官も任地も有つたものでは無い、ぶらりと武蔵を出て下総へ遊びに来て、将門の許に「居てやるんだぞぐらゐな居候」になつた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長は可いけれど、私は何だか一所に居るのが嫌だから、金沢に残ることにして、旦那ばかり、任地へ行くようにという相談をしたが不可なくって、とうとう新潟くんだりまで、引張り出されたがね。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "任地に立つ前、子路は孔子の所に行き、「邑に壮士多くして治め難し」といわれる蒲の事情を述べて教を乞うた。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後孔生は進士に挙げられて、延安府の刑獄をつかさどる司理の官になったので、一家をあげて任地に往くことになったが、母は道が遠いので往かなかった。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "松娘は任地で一人の男の子を生んだので、小宦と名をつけた。",
              "citation": {
                "source": "嬌娜",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閭が長安で主簿の任命を受けて、これから任地へ旅立たうとした時、生憎こらへられぬ程の頭痛が起つた。",
              "citation": {
                "source": "寒山拾得",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "無事、任地に着きました。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "任地に第一歩を印した時から、すでに死ぬる覚悟をしておられたらしい。",
              "citation": {
                "source": "散華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供心に機会をねらっていたが、そのうちに紀伊守が任地へ立ったりして、残っているのは女の家族だけになったころのある日、夕方の物の見分けの紛れやすい時間に、自身の車に源氏を同乗させて家へ来た。",
              "citation": {
                "source": "源氏物語",
                "author": "空蝉",
                "note": "青空文庫"
              }
            },
            {
              "text": "任地の話などをしだすので、湯の郡の温泉話も聞きたい気はあったが、何ゆえとなしにこの人を見るときまりが悪くなって、源氏の心に浮かんでくることは数々の罪の思い出であった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは地方官の息子などの好色男が、頭中将を恐れて、身の上を隠したままで父の任地へでも伴って行ってしまったのではないかとついにはこんな想像をするようになった。",
              "citation": {
                "source": "源氏物語",
                "author": "夕顔",
                "note": "青空文庫"
              }
            },
            {
              "text": "常陸介になった親の任地へも行かずに彼はこちらへ来ているのである。",
              "citation": {
                "source": "源氏物語",
                "author": "須磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘たちをそれぞれ結婚させておいて、夫婦で任地へ立とうとする時にもまだ叔母は女王を伴って行きたがって、「遠方へ行くことになりますと、あなたが心細い暮らしをしておいでになるのを捨てておくことが気になってなりません。",
              "citation": {
                "source": "源氏物語",
                "author": "蓬生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少弐一家は姫君をかしずき立てることだけを幸福に思って任地で暮らしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "玉鬘",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉が死に、樗牛が死に、鴎外は小倉の任地に行つて文壇とは没交渉になつて了ふ。",
              "citation": {
                "source": "明治文学の概観",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾州から父に伴われて父の任地島根に行き、殆んど幼時の大部分を島根に暮した。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて淮上の乱も鎮定したので、独身で任地にむかい、官舎に生活しているうちに、そこに出入りする美婦人と親しくなって、女は毎夜忍んで来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "恵州の太守が一家を連れて、福州から任地へ赴く途中、やはりこの潮州を通りかかると、元来このあたりには野生の象が多くて、数百頭が群れをなしている。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに任期が満ちて、彼は山東の別駕に移されたので、家族を連れて新任地へ赴く途中、荏平という所の旅館に行き着いた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "子不語",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは僕の赴任地なのだ。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は茨城縣第○中學の助教諭、兩親と小妹とをば、昨年の暮任地に呼び寄せて、餘裕もない代り、別に窮迫もせぬ家庭を作つた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は茨城県第○中学の助教諭、両親と小妹とをば、昨年の暮任地に呼び寄せて、余裕もない代り、別に窮迫もせぬ家庭を作つた。",
              "citation": {
                "source": "葬列",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年の月日を姉と呼び妹と呼んで一棟の寄宿舎に起臥を共にした間柄、校門を辞して散々に任地に就いてからの一年半の間に、身に心に変化のあつた人も多からうが、さて相共に顔を合せては、自から気が楽しかつた寄宿舎時代に帰つた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ根所の神を仰いでゐる族人が根人（ねいんちゆ＝にんちゆ＝につちゆ）である。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
