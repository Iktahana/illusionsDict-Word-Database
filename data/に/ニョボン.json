[
  {
    "uuid": "88201b43-08b9-5993-a768-07dec7d1157a",
    "entry": "女犯",
    "reading": {
      "primary": "にょぼん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
