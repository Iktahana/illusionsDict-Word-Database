        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ケネディのニューフロンティアとフォークソングのブームがぴったりかさなっているのは、歴史のなかの偶然でもなく、この場かぎりのこじつけでもない。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケネディは、アメリカの若い革命を前進させるニューフロンティアの、伝説的な美しい悲劇の英雄とされている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューフロンティアという架空の国（現実には、アメリカがドルで支配することを考えている海外の諸国）では平和部隊のような費用のかからないことしかできず、国内には軍事費の半分以下の予算しかふりむけることができなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューフロンティアは、たとえば『リパブリック讃歌』のなかのアメリカでしかなかった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューフロンティアは、うたい終られると同時に消えていく、ひとつの歌だった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケネディやニューフロンティアが持っていた限界についてはすでに書いた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
