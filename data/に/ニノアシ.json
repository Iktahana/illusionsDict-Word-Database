    "definitions": [
      {
        "index": 1,
        "gloss": "second step",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "亭主もし二の足ふまば我が職掌をいうべきなれど、蔵匿うことを承知したればそれにも及ばず都合｜可し。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "金時｜真先に二の足踏み、「得右衛門もう帰ろうぜ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前様、今の住居は、隣の嚊々が小児い産んで、ぎゃあぎゃあ煩え、どこか貸す処があるめえか、言わるるで、そん当時黒門さどうだちゅったら、あれは、と二の足を蹈ましっけな。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらか覚悟はして参りましたが、目のあたりお話を伺いましては、ちと二の足でございますが。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も其時分は果敢ない者で、然云ふ天氣に船に乘るのは、實は二の足の方であつたが。",
              "citation": {
                "source": "旅僧",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺ときいて二の足を踏むと、浅草寺だって寺ではないかと、言う。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒ん坊のことが杣仲間の口から世間にひろまると、婿の方では二の足を蹈むようになった。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なかなか探せぬと思っていたところ、いくらでも売物があり、盛業中のものもじゃんじゃん売りに出ているくらいで、これではカフェ商売の内幕もなかなか楽ではなさそうだと二の足を踏んだが、しかし蝶子の自信の方が勝った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "一日の報酬何百円だと、そんな金ずくめの話なら、二の足も踏まなかったが、ともかく法廷にも立ち女優もやめねばならないほどの罪を犯した女ではないか。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦令舞台へ出る役割を振られてもいよいよとなったら二の足を踏むだろうし、踊って見ても板へは附くまい。",
              "citation": {
                "source": "二葉亭追録",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも、青年は美奈子が同行することを、厭がってはいないまでも、決して欣んではいないだろうと思うと、彼女はいつも二の足を踏んだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、下の谷間の岩に当って砕けている死体を見たり、またその噂をきくと、模倣好きな人間も二の足を踏む。",
              "citation": {
                "source": "身投げ救助業",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、金助のそのつらだましいをしげしげと見て、右門はちょいと、二の足を踏んだかたちでありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "身代わり花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "頼んだおかたは手ぶらのままお越しになって、いきなり古島雛をこしらえろとおっしゃいましたゆえ、いくらまがいものでも、手本の真物がなくてはと、はじめは二の足を踏みましたんですが、名の高いもの、天下に知られたご名品は、何によらず暇のあるかぎり見ておくものでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "因縁の女夫雛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえには目の毒、おれには虫の毒、こういう色っぽい詮議をすると、二、三日おまんまがまずいから二の足を踏んだが、すがられてみりゃいやともいえまい。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも彼と縁組をするということになると、さすがに二の足を踏むものが多いので、彼はこの年になるまで独身であった。",
              "citation": {
                "source": "青蛙堂鬼談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "重右衛門も流石に二の足を踏んだに相違ないが、余りに人から執念く勧めらるゝので、それでは何うか好いやうにして下され、私等は、ハア、どうせ不具者でごすでと言つて承知して、それより一月ならざるに、重右衛門の寂しい家宅にはをり／＼女の笑ふ声が聞える様になつた。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、抱きとめられたＮ君も、淵に立つて水の勢ひを見るとさすがに二の足をふんだものか、當惑した顏を見合した。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むむ、だが、向うが大勢だと剣呑だぜ」　銀蔵はまた二の足を踏んだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "柳原堤の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一は入場料がその時代として滅法界に高いことで、桟敷一間が十三円八十銭、平土間は二人詰めで一間四円五十銭というのであるから、団十郎が見たい見たいと言いながらも、その観覧の値があまりに高いのに脅かされて、二の足をふむ人々の多かったためである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少くとも、青年は美奈子が同行することを、厭がつてはゐないまでも、決して欣んではゐないだらうと思ふと、彼女はいつも二の足を踏んだ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ひは言つたが、松太郎、余り諄く訊かれるので何がなしに二の足を踏みたくなつた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と言ひは言つたが、松太郎は餘り冗く訊かれるので何がなしに二の足を踏みたくなつた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い駿介が二の足を踏んでゐるのは無理がなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分のなかのむなしいものや、甘えるものや、また自分の発心や動機などに根在する不純な趣味的要素（妙な言葉ですけれど）に眼がつくほど、新しい生活に対して二の足を踏みます。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "辞安開板せよとすゝめ候へども二の足をふみゐ申候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "刊行せしめむとして「二の足をふみゐ申候」と云ふ詩集は、黄葉夕陽村舎詩後編である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "対価が高ければ、サードパーティーはバンドルに二の足を踏み、ＰＣ―９８０１をＯＳマシンとして再生させるシナリオは機能しなくなると予想できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうさ、姐さんおかわりだ、ヘイ宜しゅうってんで、なんしたんだが、あんまり大きすぎたのはいけないね、眼にたつんで、客の方が二の足でね、なにせ、だいぶお立派な方々でございまして、ヘッて、平伏っちまやがるんだから。",
              "citation": {
                "source": "朝散太夫の末裔",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
