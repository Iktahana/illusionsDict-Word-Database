[
  {
    "uuid": "96b3093b-8edf-51d4-bfda-b4e59a15c3c7",
    "entry": "柔弱",
    "reading": {
      "primary": "にゅうじゃく",
      "alternatives": [
        "じゅうじゃく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "weak",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それらが陳子文の柔弱な死への哀悼歌となって米良を悲しませた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その私の繰り返し繰り返し言った忠告が効を奏したのか、あるいは、かのシェパアドとの一戦にぶざまな惨敗を喫したせいか、ポチは、卑屈なほど柔弱な態度をとりはじめた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても／＼、あの狂氣のやうに立騷いで居る多人數の間を分けて、此柔弱き夫人と少年とを安全に端艇に送込む事が出來やう？",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "日陰の唐茄子の萎びているごとく、十分に大気に当り、十分に太陽の光線を浴びぬ奴は心身共に柔弱になる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の所謂ハイカラなどという奴は、柔弱、無気力、軽薄を文明の真髄と心得ている馬鹿者共である。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽薄なるハイカラの模倣、柔弱なる気風の彌蔓、如何にして生活すべきやの嘆声、小成功熱の流行、議員高官の収賄、詐偽会社の出没。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは外国文学の話など、いろいろ僕に話して聞かせるので、僕も、木村のニイチェに興奮した時みたいに、大いに感激して僕の友人は佐伯ひとりだと思い、すすんでこちらからも彼の家に遊びに行ってやったものだが、どうも彼は柔弱でいけない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "文芸なんて、柔弱男女のもて遊びもので、国家の存廃には何の関係も無いように見えながら、しかし、これが的確に国の力をあらわしているのですからね。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此を以て太祖の詩を賦せしむるごとに、其詩｜婉美柔弱、豪壮｜瑰偉の処無く、太祖多く喜ばず。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "政宗の幼い時は人に対して物羞をするような児で、野面や大風な児では無かったために、これは柔弱で、好い大将になる人ではあるまいと思った者もあったというが、小児の時に内端で人に臆したような風な者は柔弱臆病とは限らない、却って早くから名誉心が潜み発達して居る為に然様いう風になるものが多いのである。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて当時の難波の潟に湧きたる潮の迹を問へば、寧ろ武勇の精神を遺却して、他に柔弱なる一種の精気の漸く成熟し来れるを見るべし。",
              "citation": {
                "source": "徳川氏時代の平民的理想",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "匂い袋なんぞを持っているけに、たわいもない柔弱者かと思うと、油断のない体の構え、足の配り……ことに彼の胆玉と弁舌が、年頃と釣合わぬところが奇妙じゃ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより柔弱なる兄等二人の及ぶ処に非ず。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度の事は泰平の御代に武道を忘れ、縁辺の手柄を頼に出世を望み給ひし御身の柔弱より出でし事ぞかし。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "京外れで買うた尺八の歌口を嘗め嘗め破れ扇を差出しながら、宿場宿場の揚雲雀を道連れに、江戸へ出るには出たものの、男振りよりほかに取柄のない柔弱武士とて、切取り強盗はもちろん叶わず。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "義元死後も朝比奈兵衛大夫の外立派な家老も四五人は居るのであるが、氏真、少しも崇敬せずして、三浦右衛門義元と云う柔弱の士のみを用いて、踊酒宴に明け暮れした。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "上方勢は、柔弱だと云う肚が、どっかにあったのであろう。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地を離れ、都会に定住し、柔弱な側用人や腰元などに取りまかれてゐたのでは、知行取りで、今の高級サラリーマンと同じで、もう武士ではないのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子路は至って勇ありしと聞くが周王太子などいずれ柔弱な人なるべきに叱られて服した虎はよほど弱腰の生れだったと見える。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "その失望はどこから起ったかというと、前にお話しした柔弱なる考えから起ったのでございます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし武者絵に於いては、その作風の軟弱さ、その柔弱さが目につくほどの、近来個性的作風となつてきてゐる。",
              "citation": {
                "source": "小熊秀雄全集−19−",
                "author": "美術論・画論",
                "note": "青空文庫"
              }
            },
            {
              "text": "例せば、面首を以て愛重された男子はことごとく柔弱萎縮しおわると説く者甚だ多きも、ハンニバル、シーザル等かつて若契を経た偉人泰西に多く、「蘭丸をいっち惜しがる本能寺」、「佐吉めは出征をしたと和尚いい」、わが邦にも美童の末大名を馳せた者少なからず。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "アラブ馬｜猛しといえども、軍士と等しく児女や柔弱な市人をも安心して乗らしむ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、方頷粗髯の山本権兵衛然たる魁偉の状貌は文人を青瓢箪の生白けた柔弱男のシノニムのように思う人たちをして意外の感あらしめた。",
              "citation": {
                "source": "二葉亭余談",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、今迄柔弱とばかり見えたのが、俄然一変したのですから、その冴えまさった美しさというものはない。",
              "citation": {
                "source": "旗本退屈男　第一話",
                "author": "旗本退屈男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
