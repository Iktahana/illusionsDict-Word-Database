          "literary": [
            {
              "text": "「ゴトブ」の幹部連は、ブルジョア舞台芸術の個人主義、個人偏重からなかなかぬけられないでいることを。",
              "citation": {
                "source": "ソヴェトの芝居",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙吉は又、やれ白木屋で反物を五反取ったの、にんべんで鰹節を盗んだの、日本銀行でお札をごまかしたのと、出鱈目ながら生意気な事を云った。",
              "citation": {
                "source": "少年",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
