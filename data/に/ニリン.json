    "definitions": [
      {
        "index": 1,
        "gloss": "two wheels",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "手水鉢の向かいの梅の枝に二輪ばかり満開したのがある。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一種の三輪自転車であるが、普通の三輪車と反対に二輪が前方にあってその上に椅子形の座席が乗っかっている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間にも残ったが、と見ると、莟の堅いのと、幽に開いた二輪のみ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の花瓶には彼の椿が生けてあって、手入の好い所為でもあろう、紅い花は已に二輪ほど大きく綻びていた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度二輪咲いてるから、お前さんと妾とで一個ずつ分けようじゃアないか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　二輪の花を折って縁側に列べると、重太郎は其の一個を取った。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "与へる人のいろ／＼さま／″＼が考へられる、三輪空寂は理想だ、せめて二輪空寂になりたい。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてボンド街で二輪馬車を拾うと、夜更けの街を一散に疾駆させた。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　堅く妄想を捏して自覚｜妙諦　腕を隠せし花一輪削り二輪削り、自己が意匠の飾を捨て人の天真の美を露わさんと勤めたる甲斐ありて、なまじ着せたる花衣｜脱するだけ面白し。",
              "citation": {
                "source": "風流仏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一坪の庭も無い家へ急に移つた時に一切の菊を失つて終つてから、今はもう自分は一株の甘菊をも有たぬが、秋更けて酒うまき時、今はたゞ料理菊でもない抛つたらかし咲かせの白き小菊の一二輪を咬んで一盞を呷ると、苦い、苦い、それでも清香歯牙に浸み腸胃に透つて、味外の味に淡い悦びを覚える。",
              "citation": {
                "source": "菊　食物としての",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィナスが白鳥に曳かせた二輪車に乗り、森や果樹園のなかを駈けめぐって遊んでいると、怪しからぬ望を持った数十人の神々たちは、二輪車の濛々たる車塵を浴びながら汗を拭き拭き、そのあとを追いまわした。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人に聞かれたのでは極りが悪いね……」　西明寺を志して来る途中、一処、道端の低い畝に、一叢の緋牡丹が、薄曇る日に燃ゆるがごとく、二輪咲いて、枝の莟の、撓なのを見た。",
              "citation": {
                "source": "燈明之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "磐面には花を摘んだ、大輪の菫と鼓草とが、陽炎の輝く中に、鼓草は濃く、菫は薄く、美しく色を分つて、十二輪、十二輪、二十四輪の駒なるよ……向ふ合はせに区劃を隔てゝ、二輪、一輪、一輪、二輪、空に蒔絵した星の如く、浮彫したやう並べられた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたりはとっぷりと暮れて、川づらの景気はまわりから墨の闇で圧し縮めただけにきら／＼華やかに浮上り、空に爆ける花傘も間を近くして、とき／″＼は二輪三輪の重ね咲きも見せます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一輪咲いたが一輪草、二輪咲くのが二輪草、まことの花を知る人もなし。",
              "citation": {
                "source": "観相の秋",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの幅の広い林道を材木をつけた二輪馬車がカラカラカラと通るのです。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "花といへば、風鈴草、高山の虫取菫、蒜の花、一輪咲いたが一輪草、二輪咲くのが二輪草、まことの花を知る人もなし。",
              "citation": {
                "source": "第二真珠抄",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "後の見すぼらしい二輪の牛車には、寂しげな孔子の顔が端然と正面を向いている。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "コスモスが二輪、柵に沿つてちゞれながら咲殘つてゐる。",
              "citation": {
                "source": "かめれおん日記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（中）　諸君は博多｜二輪加の名を御存じであろう。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "御覧にならない方々のためにチョッと知ったか振りを御披露申上げておくが、博多二輪加の本領というものは、東京の茶番狂言や、大阪二輪加なぞと根本的に仕組みの違ったもので、一切の舞台装置や、台本なぞいう面倒なものの御厄介にならない。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "湊屋の大将こと、篠崎仁三郎は、その日常の生活が悉くノベツ幕なしの二輪加の連鎖であった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし急にりんどうが好きになった。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きな瞳は青い蓮のはなびらのやうにりんとみんなを見ました。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとうにりんどうの花は何がかなしいんだろうね」王子はトパァスを包もうとして、一ぺんひろげたはんけちで顔の汗をふきながら言いました。",
              "citation": {
                "source": "虹の絵具皿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴はひもがうごくたんびにりん／＼となりました。",
              "citation": {
                "source": "ぽつぽのお手帳",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間に、清々しい白百合と、根じめにりんどうの花が生けてあった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何時果てるとも判らぬ議論の間にりん子の甘つたれた声が仲裁に入つた――みなさん、遅いのよ、寝まない彼女の声で二人の論敵たちは夢から醒めたやうにたがひに顔を見合せてにやりと笑つた――みなさん、遅いのよ、寝まない二人はもう一度口の中で彼女の言葉を繰り返してみた。",
              "citation": {
                "source": "託児所をつくれ",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は私のうちにりんりんたるものを感じる、それを正しくうたふことが私の当面の仕事である。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地の間にりんりんたるものがある。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
