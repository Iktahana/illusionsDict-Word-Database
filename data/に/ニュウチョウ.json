  {
    "uuid": "1786f301-2756-5c7a-8bbb-036943ccc86d",
    "entry": "入庁",
    "reading": {
      "primary": "にゅうちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "becoming employed by a government office, agency, board, etc.",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんなことがあろうかとかねてより予期していた婦人のほうでは両手を繋ぎ合せて、監視者のほうに突進し、入庁者を安全に市庁舎の中に入れる工夫をした。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこの内国歳入庁へ立ち寄り、自分の名刺を差し出した。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十三章　フィールド警部補はワンダワースの内国歳入庁におもむき、ついに本筋にたどりついた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "紳士が五ポンド手形を渡し、内国歳入庁へ行って、羊皮紙に二ポンド一〇セントの蝋印を押してもらうように頼みました。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
