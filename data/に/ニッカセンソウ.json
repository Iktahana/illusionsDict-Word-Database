        "examples": {
          "standard": [
            {
              "text": "日華戦争は、日本の近代史において非常に大きな意味を持つ戦争だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史博物館では、日華戦争に関する貴重な資料が展示されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は日華戦争の研究に生涯を捧げ、多くの論文を発表した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "「蒙古と広東で日華戦争が起ってるんだが、大げさに書いてあるにしても、こんなに新聞のトップ一面ということは今までになかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　久慈はまた別のを見ると、その新聞にも日華戦争と題してトップを大きく占めていた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
