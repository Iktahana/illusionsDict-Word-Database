        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ジンの中へダイナマイト……つまりニトログリセリンが割ってあるんだ。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして家業としては、工業藥品、特に爆藥ニトログリセリンの製造に從事していた。",
              "citation": {
                "source": "ノーベル小傳とノーベル賞",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち工業爆藥ニトログリセリンの製造、並びに利用等に、その研究を集注したのである。",
              "citation": {
                "source": "ノーベル小傳とノーベル賞",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニトログリセリンを砂に浸み込ませたものは、ダイナマイトと新たに命名され、爆藥として大飛躍を遂げたのは、彼が二十九歳の時からである。",
              "citation": {
                "source": "ノーベル小傳とノーベル賞",
                "author": "長岡半太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その金庫はニトログリセリンで爆発させるばかりになって居る。",
              "citation": {
                "source": "青い眼鏡",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニトログリセリンである。",
              "citation": {
                "source": "水中の怪人",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのニトログリセリンが爆発さえしなければ、私は成功者になっていただろう。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "又発作のおこった時は、これも患者持参のニトログリセリン錠を舐めるように指示する。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニトログリセリン錠と当直医師の鎮静剤、冠拡張剤の注射で間もなくおさまる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニトログリセリン錠、冠拡張剤、鎮静剤の注射で間もなくおさまる。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし狭心症は全く治癒した訳ではなく、その後も時々軽い発作があり、今になっても折々ニトログリセリンの厄介になっている。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
