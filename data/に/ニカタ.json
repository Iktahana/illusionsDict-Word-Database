    "definitions": [
      {
        "index": 1,
        "gloss": "way of cooking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「ふ、ふ、ふ、いもをどんな煮方をして食ってやがるだろう。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍋は風早の方へ、煮方は宜くお頼み申しますよ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんは物の煮方の事なぞあれこれ言つといて行つて下さつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お節ちゃん、葱を入れないで下さい」「僕には蒟蒻ばかり」　こんな註文が遠慮なく煮方の方へやって来た。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮方の料理番が、私がヨシツネさんにみかんを貰っているのを見て冷かしている。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ市村座の向側に小さい馬肉の煮込を食わせるところがあり、その煮方には一種の骨があって余所では味えない味を出していた。",
              "citation": {
                "source": "三筋町界隈",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは下宿で芋責豆腐責になつてる上、蕎麦屋行き、団子屋行きを禁じられてる際だから、そいつは結構だと、すぐ婆さんから鍋と砂糖をかり込んで、煮方に取りかゝつた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれは下宿で芋責豆腐責になってる上、蕎麦屋行き、団子屋行きを禁じられてる際だから、そいつは結構だと、すぐ婆さんから鍋と砂糖をかり込んで、煮方に取りかかった。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "処によると鮑を蕎麦粉へくるんでおいて柔に煮る人もありますがこれもやっぱり大根の方がいいようです」妻君「それで里芋の方は普通の煮方でようございますか。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっと驚きますよ」大原「僕もお相伴を」お登和「ですが美味いシチュウは今日の間に合いません」妻君「そんなに長く煮るのですか」お登和「イイエ長く煮過ぎても肉が硬くなって味が抜けますし、煮方が足りないでも柔になりません。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからの煮方は略式の通りだが出来上ったら火から鍋を卸して地の上へ置いて一旦冷却してイザ食べようという時に再び煮て出すのだ。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五十一　水道の水　梅干の煮方はお登和嬢によりて説明せらる「小山の奥さん、梅干を煮ますのは最初三度ほどもよく湯煮漏してそれから味淋とお砂糖と鰹節を沢山入れて三時間位よく煮詰めるのです。",
              "citation": {
                "source": "食道楽",
                "author": "春の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮方は鰯を丸のまま頭と臓腑とを取去り、別に赤味噌を裏漉になし味淋と水とを加えてドロドロにゆるめ唐辛少し入れ前の鰯を入れて煮るなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お裁縫だの、洗ひ張りだの、糠味噌の塩加減、野菜の煮方、その他｜細ま細ましたことが彼女の空想を刺戟した。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煮つまらなくて、醤油がだぶだぶしているような煮方は不味い。",
              "citation": {
                "source": "海苔の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまで煮つめるのが美味しい煮方である。",
              "citation": {
                "source": "塩昆布の茶漬け",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他、本場ものの穴子の煮方が旨いとか、赤貝なら検見川の中形赤貝を使うとかで、よしあしはわけもなくわかるが、とにかくまず材料がよくなくては上等寿司には仕上がらない。",
              "citation": {
                "source": "握り寿司の名人",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "里芋でいっても、ゴリゴリした芋だったら、どんな煮方をしたって、料理人の手に負い切れないのです。",
              "citation": {
                "source": "日本料理の基礎観念",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊煮方は水に酒を加えた汁仕立がよい。",
              "citation": {
                "source": "料理メモ",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼はまたおかずの煮方がよくないといわれる。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "また煮方と洗い方とがトンガリッこなしてるんだろう。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "おせうを先に煮方子之吉、洗い方藤八が出てくる。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "野菜椀のうちによく合せてある蕗などにしても、ああイヤ甘い薄味なのよりは、惣菜味の“ショッパイ”煮方のほうがいい。",
              "citation": {
                "source": "舌のすさび",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "『どうもいまの女はいけませんよ、ヒジキの煮方一つ知りゃあしない。",
              "citation": {
                "source": "舌のすさび",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬至の南瓜は、東京ではかなり衰退してしまつてゐることを、私は今日偶然にも知つたのであるが、さういへば、南瓜の煮方も、変化してゐることを思はせられる。",
              "citation": {
                "source": "冬至の南瓜",
                "author": "窪田空穂",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私の郷里の家の煮方に倣つてのものであるが、それにつき思ひ出すのは、私の十代の初め、松本藩士であつた老人が、父との雑談の中に、あの煮方は手前の家で始めたものだと云ふのを耳にした記憶がある。",
              "citation": {
                "source": "冬至の南瓜",
                "author": "窪田空穂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだこんな小ッこい」と煮方の松どんが、煮を待ちながら背丈の寸法を示して、「そいつなら、ゆうべも今朝も、さんざん刑事部屋でなぐられていたッて、庄吉が話してましたぜ」「じゃ、たしかに、捕まって来たのだね」「なあに、今朝はもう、西戸部の少年｜懲治監の方へ廻されましたよ。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時はじめて氣がついたのであるが、乙姫の背後には、めだかよりも、もつと小さい金色の魚が無數にかたまつてぴらぴら泳いで、乙姫が歩けばそのとほりに從つて移動し、そのさまは金色の雨がたえず乙姫の身邊に降り注いでゐるやうにも見えて、さすがにこの世のものならぬ貴い氣配が感ぜられた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何萬年も經つてゐるので、こんな岩みたいにかたまつてゐますが、でも、羊羹よりも柔いくらゐのものです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯々面白いのは、此の何萬囘の足音が一度にかたまつて發しないで、實にうまく一樣に時間的に配分されて、勿論多少の自然的偏倚は示しながらも統計的に一樣な毎秒平均足音數を示してゐることである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
