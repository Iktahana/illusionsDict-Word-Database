    "definitions": [
      {
        "index": 1,
        "gloss": "to be unequal to the burden (job)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は史論家としては偉大であるが、通志の出來榮は荷が勝つたと見えて十分でなく、その史論には及ばぬ。",
              "citation": {
                "source": "支那史學史概要",
                "author": "――史記より清初まで――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し荷が勝つかも知れぬが、遊隊第一人のお前だ。",
              "citation": {
                "source": "斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……焼酎はにがかつた（いかに酒のうまいことよ）、豆腐はからかつた（こゝで味噌醤油の必要なことがわかる）、でも、おかげで、腹がふくれて、ほろ酔気分になつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はさう考へて、その厭らしさに、ほろにがかつた。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "別れのみ、にがかつた。",
              "citation": {
                "source": "ふるさとに寄する讃歌",
                "author": "――夢の総量は空気であつた――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し気持はにがかつたのだ。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "曙は胸｜抉り、月はおどろしく陽はにがかつた。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間に遅れてはいけないといふ母の注意で箸を取り上げた私の舌に、その時のおかず――つましい鱈の煮つけが、刺すやうににがかつた。",
              "citation": {
                "source": "母たち",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の若い力も無益であつた、彼等の笑ひは寒さでがち／＼鳴つてゐる齒の上でにがかつた。",
              "citation": {
                "source": "氷島の漁夫",
                "author": "PECHEURS D'ISLANDE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
