        "examples": {
          "standard": [
            {
              "text": "三味線の二の糸が切れてしまい、修理に出すことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は二の糸を弾きながら、美しい旋律を奏でた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この三味線は、特に二の糸の響きが良い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わたしは二の糸の上った様子から語っているのは何かと耳を傾けるとも知らず内ではおもむろにおもひきらしやれもう泣かしやんな――――――と主人が中音。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "其処で又第二の糸を膠着させて、直ちにまた円周まで行きついて、第一の糸から少し隔つた処に第二の糸の端をくつつける。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の糸、第三、第四とすぐに捕虜の死ものぐるいの骨折りに打ち勝つてしまひます。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二の糸が長くなつて敷かれる。",
              "citation": {
                "source": "科学の不思議",
                "author": "STORY-BOOK OF SCIENCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
