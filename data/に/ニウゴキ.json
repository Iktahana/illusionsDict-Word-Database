        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "木はみな波のやうにゆすれ、坊さんの梟も、その中に漂ふ舟のやうにうごきました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木はみな波のようにゆすれ、坊さんの梟も、その中に漂う舟のようにうごきました。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "じつと外を見てゐる若者の唇は笑ふやうに又泣くやうにかすかにうごきました。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがみんなといっしょに踊るのではなくて、わざとみんなの邪魔をするようにうごきまわるのです。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして下の根もとから枝のずっとさきまで、ふしぶしが自由にうごきました。",
              "citation": {
                "source": "人魚のひいさま",
                "author": "DEN LILLE HAVFRUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、飛行島の鉄桁が横にうごきだした。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし貧しくして富める家の隣にをるものは、朝夕すぼき姿を耻ぢてへつらひつゝ出で入る妻子、僮僕のうらやめるさまを見るにも、富める家のひとのないがしろなるけしきを聞くにも、心念々にうごきて時としてやすからず。",
              "citation": {
                "source": "方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オルガ姫、上陸地点を探して、艇をそこへつけたまえ」「はい」　艇のエンジンが、再び活溌にうごきだした。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで大きなひさしが天空を横にうごき、星の光りをかくしていくようであった。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁科を相手にうごきさうもない。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の中をぬいつつ、兵曹長の目は、あちらこちらにうごきました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから艇長の手が、器用にうごきはじめる。",
              "citation": {
                "source": "大宇宙遠征隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "計器の針が、一どにうごきだした。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにひきかえ、二人ののった豆潜水艇は、ゆっくりおちついて、割れた動く島の間からゆらりゆらりと海中にうごきだし、そして安全に航海をつづけて、また元の日本へかえってまいりました。",
              "citation": {
                "source": "豆潜水艇の行方",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁科を相手にうごきそうもない。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、目をつぶろうとしたとたん、ベッドがひとりでにうごきだして、お城じゅうをぐるぐるまわりはじめました。",
              "citation": {
                "source": "こわいことを知りたくて旅にでかけた男の話",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにもここにも華奢な青い生命が樹から樹にうごき廻っていたが、誰ひとり二人の路をさまたげるものはなかった。",
              "citation": {
                "source": "精",
                "author": "CATHAL OF THE WOOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベホックは音もさせず進み出てその槍を拾いあげ、影のようにうごき出した。",
              "citation": {
                "source": "剣のうた",
                "author": "フィオナ・マクラウド　Fiona Macleod",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の日本の女性作家の日記にうごきがのろかつたやうに、「追放者」の中にも動きがすくない。",
              "citation": {
                "source": "過去となつたアイルランド文学",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "親の遺産をついで活溌にうごきだした少壮実業家、金融界の逸材だ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、貧しげな顎の下、夕映や、扁桃腺の色をして、ぐるりぐるりと、ハチきれさうにうごきます。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　白い埃の渦がしだいに遠のき、だいぶおくれて、指揮官らしい三四人の……が、しずかに馬の上で揺れながら、笑い声をひびかして通りすぎると、いままで軒先や、道傍に避けていた荷馬車や、百姓達がホッとしたようにうごき出した。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "下ばたらきのものが私たちのために戸をあけてくれたとき、馬や羊が、わらの中にうごきました。",
              "citation": {
                "source": "村の学校（実話）",
                "author": "アルフオンズ・ドーデー　Alphonse Daudet",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし人間は火を発見したので広い部屋でその空気を囲い、自らの体温をうばうかわりにそれをあたため、それを自分の寝床にしてそのなかでは嵩ばった着物を着ずにうごきまわることができ、真冬のさなかに一種の夏をたもち、窓によって明かりさえ通し、ランプによって一日を継ぎ足す。",
              "citation": {
                "source": "森の生活――ウォールデン――",
                "author": "WALDEN, OR LIFE IN THE WOODS",
                "note": "青空文庫"
              }
            },
            {
              "text": "今時、変にうごきまわるのはろくでなしというのは分るが、だってねえ、うごかないということと、ゴをうつということとはすぐ結びついてそれで終りではないわけでしょうし。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "湖水にうつる雲の影はしずかにうごき、雑魚の群は吹きかわった新鮮の気を吸うように滑な水面に泡をたてる。",
              "citation": {
                "source": "島守",
                "author": "中勘助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これを今日飛行機で陣地の上から配ったんだよ、――もう駄目だね、こうなったら」　彼のはなしによると日暮れがたであったが「近衛師団長」の機智で山王台の上から帰営ラッパを吹き鳴らすと急に隊を組んでいた兵卒のむれが一角からくずれるようにうごきだしたというのである。",
              "citation": {
                "source": "菎蒻",
                "author": "尾崎士郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遽かに汗のにおいが大地にうごき、馬蠅までわんわん立つ。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その白い花の一つ一つが、夕風にうごき出した。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤いポストが、まわるだけでなくて、横にうごきだしたのです。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
