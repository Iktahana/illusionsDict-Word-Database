    "definitions": [
      {
        "index": 1,
        "gloss": "glaring at each other",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして二人はまるで二匹の獅子のように、じっとにらみ合いました。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老いたのと若いのとが、互角ににらみ合いの格好になった。",
              "citation": {
                "source": "死生に関するいくつかの断想",
                "author": "BITS OF LIFE AND DEATH",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、おれと養父とは、きょうがきょうまで、互いににらみ合いながら、何事もなくすぎて来た。",
              "citation": {
                "source": "偸盗",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも二人はにらみ合いもしないで会えばじょうだんも云い、下らない事で笑ったりして居た。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は若し自分が片思いにしても思って居る男が外の女と好きそうな様子をして、たった一度位にらみ合いをしたったって、必してそんな事に安心させられるほどのんきな気持をもって居るものじゃあありゃしない。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄の水母とスミス警部とのにらみ合いだ。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤマ族とトロ族のにらみ合いも、そのとたんに解消の外なくなった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "源三郎に陰膳すえて、道場方とにらみ合い――ふしぎな生活がつづいている。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "宏大な屋敷のほんの一部に、お蓮様、峰丹波など、以前からの不知火道場の連中が追いつめられて、これは、小さく暮らしているに反し、奥のいちばんよい住居のほうは、伊賀侍の一団が占領して日夜無言のにらみ合い。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの分では、妻恋坂の道場では、まだ当分にらみ合いがつづくことでございましょう」　などと、いいかげんな報告をして、殿の御前をとりつくろってしまった。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしんも、そのお美代へすぐ眼を返して、また二人の女のにらみ合いになった。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔と顔、文次と侍、しばしにらみ合いの体だ。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "平家は西国に、義仲は京都に、頼朝は東国にと、それぞれ勢力を張り、互ににらみ合いをつづけていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく双方で空想空想とばかりいい張りてにらみ合いしていても、猫の喧嘩のようで際限もないことなれば、その一段は拙著『破唯物論』その他の著書に譲ることにいたしましょう。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階にいる健一と、階下の将昭のにらみ合いは続いた。",
              "citation": {
                "source": "くじらようかん",
                "author": "澤西祐典",
                "note": "青空文庫"
              }
            },
            {
              "text": "血書提出、県当局の警戒、校内の動揺、朝倉先生訪問、私服刑事、馬田とのにらみ合い、大巻訪問、とそのいずれをとってみても、彼には鉛のように重たい感じのすることばかりであった。",
              "citation": {
                "source": "次郎物語",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在とても、最後的破局が明日来るか、一週間以後に来るか、あるいは現在のにらみ合いの状態がまだえんえんと続くか、皆目見当もつかない有様です。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは野呂に相談するまでもなく、その都度僕がことわっているのですが、この男が二人のにらみ合いの状態の続行を望んでいるのです。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い長いにらみ合い。",
              "citation": {
                "source": "影男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "にらみ合いに勝った、という感じは全然なかった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきのにらみ合いは、二十秒ぐらいであった。",
              "citation": {
                "source": "幻化",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのにらみ合いが、まる一時間もつづいたような気がした。",
              "citation": {
                "source": "断崖",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、きょうの半日を、この岬のはなの風にあたッて、根気よく海とにらみ合いをしていたのは、まったく、それとは意味のちがうものであって、「まだ見えない」「はてな、きょうは波も穏やかだし、日どりの狂うはずはねえが」　と、何か心待ちにするのか、ついそこで、日の暮れるのをうッかりしていたものであります。",
              "citation": {
                "source": "江戸三国志",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "久しぶり両派の人々がこうした因縁で一堂に会したのだから、自然そこに一脈の和気も生じたわけだが、しかし一面にはやはり、どうしても、対抗の気分、にらみあいの気味があった。",
              "citation": {
                "source": "赤旗事件の回顧",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまま、しばらくにらみあいのままでいましたが、さて、線路が一筋なので、お互に通りぬけることができません。",
              "citation": {
                "source": "ばかな汽車",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は荒れ、波の狂う太平洋の一角で、今や二つの怪物が、気味のわるいにらみあいだ。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "息のつまるようなにらみあいである。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとしまつ　事実、クイーン・メリー号を中にはさみ、ラスキン大尉指揮の英空軍と海底超人の群れとのにらみあいは、もう終幕になったわけではなかったのである。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "無気味なにらみあいの時間が流れていった。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして、ぶきみな、にらみあいがはじまった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
