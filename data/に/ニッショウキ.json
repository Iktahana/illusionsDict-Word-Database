        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あげよ我等の日章旗人みな愁眉をひらくの時わが戰勝を決定してよろしく萬歳を祝ふべし。",
              "citation": {
                "source": "南京陷落の日に",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし旭日章旗のような光線の放射でなく、大きな火の玉というよりも、全身｜爛焼の火山その物のように、赤々と浮び上った。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫の首まきへ私がいつか教えてやった日の丸を真似てこしらえた小さな日章旗と独逸の旗を二本しかけて返して上げた。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はユーストンの地下鉄の乗換場附近にある玄関に、日章旗を交錯した日本料理店胡月の卓子で、外交官の松岡、画家の山中、トンテム・ハム・コートの伊太利料理店の主人と暗い東洋風の部屋で、日本食の晩餐後お互に深い沈黙に陥っていた。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁が崩れ落ちたと思うところに、日章旗を交叉した間に勘亭流で「祝開店、佐渡屋さん」と書いたびらをつるして隠してあるような六畳の部屋だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は斷言する、鷲の如く猛く、獅子の如く勇ましき列國の艦隊が百千舳艫を並べて來るとも、日章旗の向ふ處、恐らくば風靡せざる處はあるまいと。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "元より紛議も葛藤も恐るゝ所でない、正理は我にあるのだが、然し※里の波濤を距てたる絶島に於て、既に唯一の確證たる可き日章旗を徹去されたる後は、我に十二｜分の道理があつても、一個の證據なく、天下の承認を得る事は餘程困難であらうと思ふ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "荒浪の國の旗は、其竿頭から三方に引かれた綱に結ばれて、翩々と風に靡く、其頂上には我が譽ある日章旗は、恰も列國を眼下に瞰おろすが如く、勢よく飜つて居る。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "○十一月、歌舞伎座にて日清戦争劇「海陸連勝日章旗」を上演。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "國をあげての日章旗、神輿、群衆。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　島の最高部、柱が天を摩して一本、日章旗だ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それも勇少年と自分との区別がなかつたから、更にウラジオ行の日章旗を翳して、出発の新しい希望が湧いて又奮起するのであつた。",
              "citation": {
                "source": "喜びと悲しみの熱涙",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "半分がた散り尽くした桜の葉は真紅に紅葉して、軒並みに掲げられた日章旗が、風のない空気の中にあざやかにならんでいた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀元節の日には校門には日章旗が立てられ、講堂からはオルガンが聞こえた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "号外の来るたびに、田舎町の軒には日章旗が立てられ、停車場には万歳が唱えられ、畠の中の藁屋の付近からも、手製の小さい国旗を振って子供の戦争ごっこしているのが見えた。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "輝く日章旗　中の島にある敵のトーチカに、お父さまがおしこめられているときいて、高一少年は大決心をしました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなでばんざいをとなえよう」　トーチカの上に日章旗をたてると、大尉のおんどで、陸戦隊や、高一やお父さままで力いっぱい、ばんざいをさけびました。",
              "citation": {
                "source": "電気鳩",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "白ちやけたスクリーンの上には、今や小学生の打振る日章旗に送られる出征軍を満載した列車が、濛々たる黒煙を挙げて東海道の風景の中を南下してゐた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十畳間を二つ貫き欄間から欄間には子供のつくつた小さな日章旗と聯隊旗が縦横に張り回され、床の間には、御聖像軸の下に、乃木、黒木、奥、東郷の諸大将の肖像画が掲げられ、※の上に組み立てられた鎧の上には連縄が張つてあつた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に鎖を引くと消えるアメリカ製のきらびやかなオイル・シヤンデリアが、ワアツ――といふ観客の熱狂と共に幻のやうに消えて、技手役の照吉が写し出す日章旗のへんぽんたる光景が華麗な色彩を浮べた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "江南の空澄み渡り日章旗城頭高く夕陽に映え皇軍の威容紫金山を圧せり。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとその軍艦が急に日章旗をおろして砲撃を始めた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "看て千本松に到りける時、日章旗をかゝげたる白帆來たる。",
              "citation": {
                "source": "十和田湖",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで補筆価値百二十パーセントの堂々たる日章旗を翻した司令塔、信号マスト、水雷発射管、速射砲の設備整然たる五百｜噸級、乃至二百噸級の水雷駆逐艇が五艘、九十線の銅版キメ細やかに浮き出しているとは夢にも知らずに、山羊髯が「分捕潜水艇」の標題を附けた版下の寸法書を印刷部へまわしたものだろう。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の構内の告知板には、日章旗と祝出征という字を赤インクで描いた紙に、川上大二郎君八月十四日、某々君同日と列記して張り出しがされた。",
              "citation": {
                "source": "鏡の中の月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄上の、御発明の、あの日の丸の総船印が、日本の総船印として、定められたそうで、ござりませぬか」「うむ」「日章旗と、名づけて」「ふむ」　久光は、世継が、今日、殿中で決まったのに、いつもより、憂鬱な顔をしている斉彬の態度に、不安な影がさしてきた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすぐ月世界に、第一回の日章旗をたてて見せる。",
              "citation": {
                "source": "地図にない島",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その草原が尽きるあたりに、石の垣をめぐらせた、小さい赤塗りの家が一軒、岩だらけの山を後にしながら、翩々と日章旗を翻している。",
              "citation": {
                "source": "長江游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "大勢の客はその画の中に、たまたま日章旗が現れなぞすると、必ず盛な喝采を送った。",
              "citation": {
                "source": "奇怪な再会",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "日章旗の尖の飾玉などが、多くは金銀紙を貼り、又は金箔などを附けて目籠の目を塞ぎ、或は木細工の刳り物などを用ゐて居るのは、元来此物がをぎしろであつて、魔を嚇すが本意ではなかつたことを暗示し、即武蔵野の目かいの由来談に裏切りするものである。",
              "citation": {
                "source": "髯籠の話",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
