        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本鋼管のエライ人から貰つたもので、鉄の蓋が工夫よくつくられてあつて頭からスッポリかぶせると、直撃を受けない限り大丈夫、理想的なものだつた。",
              "citation": {
                "source": "わが戦争に対処せる工夫の数々",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "製鉄会社日本鋼管の岸壁に着いたのは五時頃で、一つ目の口からは約三時間。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本鋼管の向う岸の建物が昭和鋼管。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "前には独立している会社であったが、いまは日本鋼管と合併しているとのことである。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本鋼管の岸壁では、いま四台のクレンを運転しているところだが、一日三百トン位の鉄屑をダルマから引き揚げているわけだ。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本鋼管には、三千四、五百人の職工が働いているという。",
              "citation": {
                "source": "ダルマ船日記",
                "author": "山之口貘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
