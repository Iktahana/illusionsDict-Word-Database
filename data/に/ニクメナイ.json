    "definitions": [
      {
        "index": 1,
        "gloss": "hard to dislike",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それにも拘らず、孝行な他の賢い子より、そのやくざで嘘つきな息子の方が可愛ゆくて憎もうとしても憎めない。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわばその「憎めない」は盲愛の変形でありますから、愛についての検討の部に属するものですが、しかし、普通の憎みの感情に対して変態的なもの、つまり憎み能わない憎みとでも強いていえばいえましょう。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも僕は、お父さんをちっとも憎めない。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう判ると、兼松らもこの若い僧を憎めないような気にもなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "夜叉神堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "』散文詩　鴉は憎めない　私は朝の鴉を愛する。",
              "citation": {
                "source": "小熊秀雄全集-2",
                "author": "詩集（１）初期詩篇",
                "note": "青空文庫"
              }
            },
            {
              "text": "くやしかありませんか」　憎めないやつで、かわいいことをとうとう白状してしまいましたものでしたから、右門は目を細めながら、この愛すべくむじゃきな部下をしみじみと愛撫するようにながめていましたが、いつにもなく右門に似合わない述懐をもらしました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "『僕は、たとへ少し位お光さんが惡くても憎めないやうな氣がする！",
              "citation": {
                "source": "道",
                "author": "――ある妻の手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその人のよさが憎めない魅力をもつてゐた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "須山はどっちかと云えば調子の軽い、仲々｜愛嬌のある、憎めないたちの男だったので、私はその度に苦笑した。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな間にも、いつか木山が仲間が山へ行くのだと、ちやらつぽこを言つて、朝日靴などもつて出かけて行つたが、それを待合に忘れて来たものらしく、靴をおいて来た宿へ葉書を出す出すと言ひながら其れきりになつてしまつたが、考へてみると憎めないところもあつた。",
              "citation": {
                "source": "のらもの",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しいが憎めない奈良の若者の稚気ある口真似と比較にならない、憎々しさ、粗暴さが、見物人対手の寺僧にある。",
              "citation": {
                "source": "宝に食われる",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その画家は岸本の方をも見て、「岸本君は巴里へ来ていながら、ほんとにまだ異人の肌も知らないんですか――話せないねえ」　何を言っても憎めないようなその快活な調子は一同を笑わせた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "同宿六人、みんなおへんろさんだ、その中の一人、先月まで事件師だつたといふ人はおもしろいおへんろさんだつた、ホラをふいてエラがる人だけれど憎めない人間だつた。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "山口で、ゆくりなく、川棚温泉で昨夏相識の坊さんに邂逅した、彼は俗坊主だけれど、憎めない人間だ。",
              "citation": {
                "source": "行乞記",
                "author": "室積行乞",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「文芸春秋」昭和五年四月）　　　電球　強盗、ゆすり等はあまりに直接な行動だから芸術的余情を伴わないけれども、いろいろと工夫を凝らして玄関から欺しに来る奴の心は憎めない愛情があり、よくあんな智恵を絞ったものだと感心されることもしばしばある。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "藍子は、女のそういう下心が憎めないような、単純さに微笑まれるような気がした。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして（仮令、そうであるにしても――妾には、月丸様が、憎めない。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもちょっと滑稽な、憎めない存在だった。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の日本を立つ時に敦賀まで来て下すつた茅野さんも、光さんは憎まうとしても憎めない性質を持つて居るから叔母さんも可愛がりなさるでせうと云つて私を安心させて下すつたのでしたが、つまりああした中性のやうになつた方は男から見ても女から見ても想像の出来ない心理の変態があるのだらうと思ひます。",
              "citation": {
                "source": "遺書",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "常連の一人に相馬といふ友禅の板場職人がゐて、山本宣治の葬式の先頭に赤旗を担いだ男で、勇み肌の正義感から時々逆上的な喧嘩をしたが、凡そ憎めない男がゐた。",
              "citation": {
                "source": "古都",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この占師は中学生のころ修三を訪ねて行つて（修三は占師の家にゐた）時々見かけたことがあつたが、占師といふ特殊な世渡りが我々に感じさせる悪どいものはなくて、文学青年的な神経をもつた根気のつゞかない憎めない人といふやうな印象を受けた。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、それが、憎めないんです……恨むことなんかできません……どうしても、さうしてあげなけれやならない……さうするのがほんたうだと思つたんです……あの人のために、さうするのがうれしかつたんです……。",
              "citation": {
                "source": "歳月",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "タブチ、腹が立つが憎めないというような若僧だ。",
              "citation": {
                "source": "日記",
                "author": "一九三一年（昭和六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ心の育ちかけの漸々赤坊と云う名からついさっきはなれたと云う様な時に「お久美さんは可愛い」と思い込んだのが一種の感情の習慣になって、お久美さんと云えば憎めないもの、可愛いものとなって来て居るのが気味の悪い位種々な時にフイフイと現われて来た。",
              "citation": {
                "source": "お久美さんと其の周囲",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「碁をやらうか」　今度は太平の方からいふと、庄吉の目にやはらかな光がさして、「落合さん、俺は君が憎めないのだ。",
              "citation": {
                "source": "外套と青空",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子は後でそれを知つた時には思はず眉をしかめたが「多少は悪いと思つてるんでせうよ」と云ひながらも憎めない気がした。",
              "citation": {
                "source": "鳥羽家の子供",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "本当にこうだとは申しませんが、こうならなんとなく愛すべき情趣に富んだ一幅の画であるなアと、つまりですね、私は殺されたあなたの兄さんよりも、このノロマの如くで素ばしこい御二方が憎めないのですよ」　新十郎は暗い顔をそむけた。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この占師は中学生のころ修三を訪ねて行って（修三は占師の家にいた）時々見かけたことがあったが、占師という特殊な世渡りが我々に感じさせる悪どいものはなくて、文学青年的な神経をもった根気のつづかない憎めない人というような印象を受けた。",
              "citation": {
                "source": "二十一",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者の先生が前山氏に一服もり、剣術の先生が夜中に前山氏を一刀両断にしても、オレは憎めないよ。",
              "citation": {
                "source": "影のない犯人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまや人間は、にくまないものをもにくめないものをも、あえて殺すような戦争をやるまでに堕落してきた。",
              "citation": {
                "source": "親鸞聖人について",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
