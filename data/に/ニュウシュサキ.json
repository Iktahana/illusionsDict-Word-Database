        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "奴らが持ってきてくれるけど、入手先は知らない。",
              "citation": {
                "source": "ドレントン・デン特派員の冒険",
                "author": "BEING AN ADVENTURE OF DRENTON DENN, SPECIAL COMMISSIONER",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人とは交際場裡の双璧とうたわれて、事ごとに烈しく妻の競争心理を煽っていたが、かねて安からぬ思いを懐いていたその夫人の、極秘にしている犬の入手先が、今日初めて友達のマシアス・モリナーレ夫人に耳打ちされて、南米あたりから手に入れたどころか！",
              "citation": {
                "source": "陰獣トリステサ",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみの叔父さんに、縞ナデシコの入手先を聞けば米国だと答えるだろう」「そうだと思います」「ああ、その通りだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、よろしければ、その花の入手先を知りたいですな」　レスブリッジは半ば上の空だった。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十章　同種出現　レスブリッジがとっさに考えたのは、女に呼びかけて、花の入手先と入手方法を聞くことだ。",
              "citation": {
                "source": "黄金薔薇",
                "author": "The Golden Rose",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度会ったときに入手先を教える。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりか少しも疑わなかったのは、石の入手先をこの女は知っているな。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしアイダが外務省の暗号書を持っていたとしたら、グレイ以外に入手先はあり得ない。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
