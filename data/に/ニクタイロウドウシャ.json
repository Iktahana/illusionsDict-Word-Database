        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "人力車夫と同じ肉体労働者です。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "さんざ濡れて働らく、かういふ人々の間を通り抜けて行乞する、私も肉体労働者であることに間違いない。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "大連其他の苦力（肉体労働者）は一日の食費が日本貨の五銭乃至十銭で足ると云ふ事である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、肉体労働者と精神労働者は声が非常に違う。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしはただの大工だ――肉体労働者だ。",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
