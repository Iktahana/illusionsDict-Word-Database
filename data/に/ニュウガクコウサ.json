        "examples": {
          "standard": [
            {
              "text": "幼稚園の入学考査に向けて、親子で面接の練習を繰り返した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「今日の入学考査、パズルが難しかったけど一生懸命頑張ったよ！」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "小学校の入学考査では、知能テストだけでなく行動観察も重視される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "文部省が入学考査に難問題を提出するのを禁止したのが、せめても合理的な対策だと思うが、之とても準備の量を制限するだけで却って質を重加する結果を招くに過ぎないかも知れない。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが問題は単に師範学校に這入れるか這入れないかの問題ではないのであって、一般に今日男女を問わず中等学校（小学校も特別なものの場合には同様だが）以上の学校の入学考査全体に亘る問題なのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "官公立の中等学校だってこの教育の実際上の方針に就いては変りはないのだが、大体中等学校では家庭を中心にして入学考査すると見ていいだろう。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省が最近重ねて、入学考査に難問題を提出するのを禁止したのが、せめても合理的な対策だと思うが、之とても準備の量を制限するだけで却って質を重加する結果を招くに過ぎないかも知れない。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
