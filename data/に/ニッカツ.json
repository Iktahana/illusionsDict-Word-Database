    "definitions": [
      {
        "index": 1,
        "gloss": "Nikkatsu (former film company)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
