        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "十分後にはにぎり寿司を頬張っていた。",
              "citation": {
                "source": "大阪の憂鬱",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、男はにぎり寿司の皿を指した。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちょっと……」　男は食堂の女を呼んで、「――この娘に、にぎり寿司食わせてやってくれ、それからビールもう一本……」　にぎり寿司が来ると、娘はむさぼるように口へ放り込んで、またたく間に食べてしまい、皿についている飯粒を、舌の先でペロペロと拾った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月二十五日◯英と私の合同誕生日祝にて、にぎり寿司をつくる。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にぎりずしの盛合せ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トラ十へ、これをさしいれたいから頼みますと、にぎりずしが一｜折と、鼻紙一｜帖とをもってきたのです。",
              "citation": {
                "source": "爆薬の花籠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にぎりずしやら、饅頭、煙草、酒などの豪勢な差入れがあった。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
