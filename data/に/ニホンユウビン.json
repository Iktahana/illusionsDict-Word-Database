          "standard": [
            {
              "text": "日本郵便の配達員さんが、雨の日も風の日もバイクで大切な手紙を届けてくれる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "年賀はがきの販売が始まると、日本郵便の各窓口には多くの人が列を作る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「荷物を送りたいんだけど、一番近い日本郵便の窓口は何時まで開いてるかな？」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "五月二十日ごろ佐々の一家をのせて神戸を出帆した日本郵便株式会社のカトリ丸は七月一日の午前九時ごろにマルセーユへ入港する予定だった。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
