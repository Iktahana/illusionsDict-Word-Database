    "definitions": [
      {
        "index": 1,
        "gloss": "Japan",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "扨、魂はにがい深淵だぞといふやうなことを我々日本人が云ふと、一寸そぐはない感じがしよう。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本文学にしろ外国文学にしろ、その作品の「流れ」の諦視、「持続ぶり」「終始ぶり」の諦視、さてはフォルムに就いての理念、その涵養が今日我々の緊急事である。",
              "citation": {
                "source": "撫でられた象",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕と節野とは、教室で可なり口をきき合つたのであり、一緒に酒場なぞにも行つた男であるが、それでも彼の昼間通つてゐる日本大学の同級生が其の場に来合せたりすると、その方が主になるのである。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れ易く、破れ易く、着くづれし易く、こんな服装を讃へなければならない我々日本男児は、なんとなく不幸であるやうに思へる。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、俺のこの宿酔の頭では、一杯ひつかけてから行かなければ、とても相談にはのられやしないぞ」といふやうなわけで私はまたも其処に入り、どうせこんな所の日本酒はまづいからと思つたのでビールを註文。",
              "citation": {
                "source": "その一週間",
                "author": "――不真面目なわが心……",
                "note": "青空文庫"
              }
            },
            {
              "text": "男　新聞に拠ると、いよいよ改築を修了せんとする、日本の、ドレスデン街さ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのリズムは、過去に現はれた日本語の抒情詩の、どれにも発見することのできない珍しい鋭どさをもつて居る。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの詩集は、北原兄の『思ひ出』以後における日本唯一の美しい抒情小曲集である。",
              "citation": {
                "source": "抒情小曲集",
                "author": "序",
                "note": "青空文庫"
              }
            },
            {
              "text": "およそ日本の詩壇に自由詩形が紹介されて以来、真に日本言葉のなつかしいリズムを捉へて、之を我我の情緒の中に生かしたものは、室生以前には一人も無かつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに私共の求めてゐたものは、もつと鮮新で、もつと自由で、そしてもつとしんみりとした情熱をもつた、純日本言葉の美しい音楽であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした私共の要求を満足させて、最初に日本現代語の「音楽らしい音楽」を聴かせてくれたものは、実に私の友人室生犀星その人であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうした彼の艶艶しい表現は、長く日本の枯燥した詩に不満を抱いてゐた私にとつては実に絶大の驚異であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "「此の書物こそは」私は言ふ「日本人が日本語で書いた告白の最初の真実であり、そして日本に於ける、最初の感情生活の記録である」と。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしこの悲しい宿命者も、さすがに日本に渡ってからは、多少の平和と幸福を経験した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が日本に帰化したことも、普通の常識が思惟するように、日本を真に愛したからではなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の彼は、日本をもはや『夢の国』としては見ていなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして『西洋の国々と同じく、ここにもやはり醜い生存競争があり、常々不義や奸計が行われている』と、地上の現実社会である日本を見ている。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし彼に妻子がなかったら、日本に幻滅した最初の日に、再度また『まだ知らぬ新しい国』を探すために、あてのない漂泊の旅に出発したにちがいなかった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして国籍を持たない家族が、財産上にも生命上にも、日本の政府から保護を受け得ないことを考えた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもその妻のごとき、純日本的な可憐な女を、彼のいわゆる『野蛮人』である西洋人の社会に、孤独で生活させることの痛ましさは、想像だけでも耐えがたい残忍事だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが彼が帰化を決心し、日本の土となることを覚悟した時、言い知れぬ寂しさとやるせなさが、心の底にうずつき迫るのを感じたであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが日本人の抒情的な言葉で、あきらめと呼ばれるものであることさえ、おそらくヘルンは知ったであろう。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "上陸当初の日に一瞥して嘔吐を催し、現代日本の醜悪面を代表する都会と罵り、世界のどんな汚い俗悪の都市より、もっと殺風景で非芸術的な都市と評した東京は、彼が死んでも住みたくない所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンはその妻と共に、姑の老婦人と一家に同居し、純日本風の仕方でよく孝養の道を尽した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この姑の婦人もまた、旧武士の家庭に育った士族の娘で、純日本風の礼儀正しき教育を受け、かつ極めて善良に優しい心根の人であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの文学に出る日本婦人のモデルは、多くその妻に非ずば姑の老婦人だといわれてるが、すくなくともヘルンは、この点での好運にめぐまれていた。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "げにほんとであることよ！",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴船神社の森影の広場にほんの五六人の影が踊っていた。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "青春などは素通りしてしまって、心はこどものまま固って、その上皮にほんの一重大人の分別がついてしまった。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはそのひとにほんたうに気の毒でそしてすまないやうな気がする。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
