    "definitions": [
      {
        "index": 1,
        "gloss": "square (of a number)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "両辺を二乗すれば、わけがないのだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私は幽霊の二乗を背負って、折角の真夏の旅の一日を引っ籠っているのだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二乗の車が衛の都を行く。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのように、人生の与えられた事実に対しても、一通り方程式の両辺にb/2aの二乗を足して解りやすく意味のあるものとする技術を習得すべきだね。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「謎語」の二乗になっているという事は、「世界歴史が鼻の表現の歴史である。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "光線の圧力は半径の二乗に比例するが、引力のほうは半径の三乗に比例するんだから、物が小さくなればなるほど引力のほうが負けて、光線の圧力が強くなる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａの二乗、マイナス、Ｂの二乗を因数分解すると、さあどうなる？",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝦原　えーとＡの二乗、マイナス、Ｂの二乗はえーとえーとえーえー。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ａの二乗、マイナス、Ｂの二乗はえーーと、えーと、ＡマイナスＢの二乗……じゃないや、ＡマイナスＢとそれからキャラメル、いやちがった。",
              "citation": {
                "source": "新学期行進曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついにこれが基礎となって、万有引力は距離の二乗に逆比例するという法則が発見されたのである。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "農学校に樹明君を訪ねて話してゐるとき、思ひがけなく周二君来訪、三人いつしよに帰庵して会飲、そして珍客芝川君を迎へた、意外であつたゞけ会合のよろこびは二乗された、千福の酔心地、広島牡蠣のうまさ、そのうまさも二重だつた。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち牽引の度は距離の二乗に反比例するものと考えられる。",
              "citation": {
                "source": "エマヌエル・カント『自然哲学原理』解説",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "光線の圧力は半径の二乗に比例するが、引力の方は半径の三乗に比例するんだから、物が小さくなればなる程引力の方が負けて、光線の圧力が強くなる。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくこのようにしてニュートンは月の運動を研究して、それを地球上で物の落ちるのと比較し、月が遠方にあるから、それに対する地球の引力は距離の遠いだけ減っているのを見出だし、その大きさが丁度距離の二乗に逆比例するということを計算で出したのでした。",
              "citation": {
                "source": "ニュートン",
                "author": "石原純",
                "note": "青空文庫"
              }
            },
            {
              "text": "漱石先生の『断片』の明治四十一年初夏以降即ち『三四郎』の辺の所に、寺田先生からこの話を聞かれて直ぐ書き止めておかれたノートがあって、光圧は半径の二乗に比例し、重力は三乗に比例するということが英文で認めてある。",
              "citation": {
                "source": "「光線の圧力」の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "直角三角形の各辺を「を」「え」「と」と決めて、一辺の二乗を他の辺の二乗の和に等しいと置く。",
              "citation": {
                "source": "八月三日の夢",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ｃが三百億という膨大な数字でその二乗がかかっているために、ウラニウムの分裂の際に、極く少量の物質が消えても、途方もない量の勢力が現出するのである。",
              "citation": {
                "source": "八月三日の夢",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか議会での米価の説明をするのに、最小二乗法を使ってあって、その専門の技師が欠席していたので何とかしたという事件があった。",
              "citation": {
                "source": "琵琶湖の水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最小二乗法を忘れたというならば、数学の教育が悪いともいえる。",
              "citation": {
                "source": "琵琶湖の水",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "春子　あら、まあ、私がおきれいなら敦さんはおきれいの二乗！",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道を廻ったのでは間に合わないと思ったから、道を外れて藪ヶ丘を遮二無二乗り越え、檜の植林地を横断して吉井村と椙原村をつなぐ街道へ出た、――それを更に南へ十丁あまり、馬を煽り煽り行くと、向うから、「あ――ッ　助けてッ」　凄じい悲鳴が聞えて来る。",
              "citation": {
                "source": "殺生谷の鬼火",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでに菩薩の御指量をお許しになるとすれば、二乗凡夫のともがらもまたその宝の所在を窺い知ることを許されねばならぬ約束ではございませんか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "弁信の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "二の二乗は、わたしの意志なんかなくたって、やっぱり四になるんだからな。",
              "citation": {
                "source": "地下生活者の手記",
                "author": "ЗАПИСКИ　ИЗ　ПОДПОЛЬЯ",
                "note": "青空文庫"
              }
            },
            {
              "text": "つくりものの鳥が、いつものようにじょうずに歌をうたい、皇帝が寝床の中にはいって、それを聞いていますと、きゅうに、鳥のからだの中で、「プスッ」という音がしました。",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、そこにいるおなべたちは、みんながみんな、心の中で、自分にできる力や、自分がどんなにじょうひんかということを、考えているのでした。",
              "citation": {
                "source": "空とぶトランク",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、ほんとうにじょうひんな宴会に行ってきたのです。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくには、こんなにじょうぶで、強い手足があるんですもの。",
              "citation": {
                "source": "旅の仲間",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤ちゃんは、王子のようにじょうひんで、天使のようにきれいでした。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれも相手がいないのに、じっさいにいるようにじょうずにしゃべっていた、あの白い少女のことを。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてご自分自身は、粗末なぬのの着物をめし、いやしい船頭のようにじょうずにお姿をお変えになって、かじを握って、その船の中に待ち受けておいでになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
