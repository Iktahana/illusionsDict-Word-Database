        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "南の鉄格子の窓に映っている弱い日かげが冬至に近いことを思わせた。",
              "citation": {
                "source": "砂糖泥棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "牢屋や留置場の窓の鉄格子、工場の窓の十字格子。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵には、鉄格子の組まれた窓があった。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を精神病患者にして、この檻に入れたのは、たしかにこの鉄格子の外に立っている診察着の私であった。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に面した方の、鉄格子のはまつた小さい窓があいてゐたからである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵には、鉄格子の組まれた窓があつた。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄格子と、金網と、それから、重い扉、開閉のたびごとに、がちん、がちん、と鍵の音。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪の数々、目おおえども、耳ふさげども、壁のすきま、鉄格子の窓、四方八方よりひそひそ忍びいる様、春の風の如く、むしろ快し。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "洞窟に中世紀風の鉄格子を嵌めましょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄格子ひしとすがりて黄金髪わかきをおもふ。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍍金鉄格子に囲まれた中で、我々は、わが政治犯達及び刑務所長ウルムブラント氏と共にカヴァを飲んだ。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久子の寝室の鉄格子の嵌まっている磨ガラスの窓に、猛火に責め立てられて※き苦しんでいるらしく、両手を広げて窓に飛びかかっている正勝の姿が影絵のように映って、踊り狂っていた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "工場にはもうだれもいませんから」　頑丈な鉄格子の門の奥には、黒い大きな建物が鯨のように横たわっているだけだった。",
              "citation": {
                "source": "猟奇の街",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風は鉄格子の窓からぴゅうぴゅう吹き込みました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、夕方になって、鉄格子のちかくにはくちょうの羽ばたきがきこえました。",
              "citation": {
                "source": "野のはくちょう",
                "author": "DE VILDE SVANER",
                "note": "青空文庫"
              }
            },
            {
              "text": "長い廊下の行手に、沢山の鉄格子の窓を持った赤い煉瓦の建物がつッ立っていた。",
              "citation": {
                "source": "独房",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "――自分に気づいて見ると滝本は未だちやんと剣術道具に身を固めて、面を被つてゐたから、その鉄格子を透して眺めるせいか、稍ともすると一つの物のかたちが二つにも三つにもなつてチラチラした。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "給仕が私達の註文を取りに来ると、華奢な鉄格子の填った窓を見ていた喬介は、その少女を捕えて、何階の窓にも一様に鉄格子が填っている、と言う事実を確かめていた。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後の陽ざしが、ただ一つ西側にあいた窓から入ってきて、破れたリノリウムの上に、鉄格子の影をおとしている。",
              "citation": {
                "source": "第五氷河期",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大向うの立見席の前には鉄格子が嵌っているので、そのころの通言に“熊”といっていたのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると指先にザラザラした粗い鉄格子が触れた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄格子ならば、これは後から嵌めたものに違いない。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとゴトリという音がして、その重い鉄格子が少しもち上った。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "下に落ちては大変だと気を配りながら、満身の力を奮って、鉄格子を押しあげた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、それはさっき彼が押し上げたのと同じような円い鉄格子が嵌って居り、そして下から光がさしているのだった。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがどうやら、あの輝く鉄格子の下に部屋があるらしい。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれが吾が手に入ったらなァ」　だが鉄格子はどこで打ちつけてあるのか、ビクリとも動かない。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙はクルクルと廻りながら、とうとう鉄格子の近くまで上って来た。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鏡の底には、丁度真上にあたる帆村の隠れている空気孔の鉄格子がハッキリうつっていた。",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
