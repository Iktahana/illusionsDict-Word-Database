        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "東京｜帝国大学の招聘に応じて、松江や熊本の地を去ったことも、同じくヘルンの身にとっては、愛する妻への献身的な犠牲だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京帝国大学の卒業証書も検閲のために差出したが、この日本文は事務の役人にとって自分の場合のラテン語以上に六かしそうであった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのためにその頃郷里でただ一人の東京帝国大学卒業医学士であったところの楠先生の御厄介になることになった。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正十二年関東大震災以前から既に地震学に興味をもっていたが、大震災の惨害を体験した動機から、地震に対する特殊の研究機関の必要を痛感し、時の総長｜古在由直氏に進言し、その後援の下に懸命の努力をもって奔走した結果、遂に東京帝国大学附属地震研究所の設立を見るに到った。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年四月『帝国大学新聞』）",
              "citation": {
                "source": "科学に志す人へ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年一月『帝国大学新聞』）",
              "citation": {
                "source": "鉛をかじる虫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近に東京帝国大学地震学科学生某氏は市内二か所の街上における自動車の往復数に関する統計についても、やはりかなりの程度まで同様な物理的方則が適用される事を示した。",
              "citation": {
                "source": "物質群として見た動物群",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年十一月、帝国大学新聞）",
              "citation": {
                "source": "人魂の一つの場合",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年三月、帝国大学新聞）",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和十年四月、帝国大学新聞）　　　　　十　ナナ　ゾラの「ナナ」から「暗示を受けて」作った映画だと断わってあるから、そのつもりで見るべきであろう。",
              "citation": {
                "source": "映画雑感（４）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和九年十月、帝国大学新聞）",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　　　　　七唱　わが日わが夢　　　　　　　　　　――東京帝国大学内部、秘中の秘。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時、私は極めて懶惰な帝国大学生でありました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "八年間、その間には、往年の呑気な帝国大学生の身の上にも、困苦窮乏の月日ばかりが続きました。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「東京帝国大学校地質学教室行、」と書いた大きな札がつけられました。",
              "citation": {
                "source": "気のいい火山弾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和五年十一―十二月、東京帝国大学新聞）　　　　　　　二「モロッコ」という発声映画を見た。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和六年十一月、東京帝国大学新聞）　　　　　　　五「三文オペラ」を見た。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年三月、東京帝国大学新聞）　　　　　　　六　評判のフランス映画「パリの屋根の下」というのを見物した。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆがみて蓋のあわぬ半櫃　　　凡兆草庵にしばらくいては打ちやぶり　　　芭蕉（昭和七年五月、東京帝国大学新聞）",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "総領は忠一と云って、帝国大学の文科に学んでいる。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに文楽が文薬となっており、東京の帝国大学を出た人にこんな人がざらにいるとすれば、ほんとうにおかしな、由々しいことだと、私は眼玉をくるくる動かして腹を立てていた。",
              "citation": {
                "source": "天衣無縫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、来年十九才で学校を出ると直ぐに今東京帝国大学の法学部に通っている従兄と結婚することになって居り、十六の少年など十も年下に見える姉さん振りが虚栄の一つであった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正四年、葛原氏編纂の勾当日記には、東京帝国大学史料編纂官、和田英松というお人の序文も附加せられて在るが、それには、「葛原勾当は予が郷里｜備後の人にして音楽の技を以て其名三備に高かりき。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのこの世の中に、たとい帝国大学校を出たって、……」「いいえ、サラリイマンになるんでは無いんです」「それじゃ、何です」「画家です」　思い切って、それを言いました。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京帝国大学の経済科を卒業してから、フランスへ行き、五、六年あそんで、日本へ帰るとすぐに遠い親戚筋の家（この家は、のち間もなく没落した）その家のひとり娘、静子さんと結婚した。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老い疲れたる帝国大学生、袖口ぼろぼろ、蚊の脛ほどに細長きズボン、鼠いろのスプリングを羽織って、不思議や、若き日のボオドレエルの肖像と瓜二つ。",
              "citation": {
                "source": "狂言の神",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "本郷帝国大学の裏門を出て根津｜権現の境内まで、いくつも曲りながら傾斜になって降りる邸町の段階の途中にある或る邸宅の離れ屋である。",
              "citation": {
                "source": "高原の太陽",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は来年十八歳で学校を出ると、いま東京帝国大学の法学部にいる従兄と結婚することになっており、十六の少年など十も年下に見える姉さん面が虚栄の一つだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の関心は試験に良い点を取ることであり、東京帝国大学の法科を良い成績で出ることであり、昭和何年組の秀才として有力者の女婿になることであった。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
