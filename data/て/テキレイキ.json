        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "娘が適齢期を迎えたので、親として心配が増える。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "適齢期になっても、なかなか結婚に踏み切れない人も多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は、女性は適齢期になるとすぐに結婚するのが当たり前だった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "様式だけは完全な流眄をして「どのくらい目方があるか量ってみてよ」　柚木は二三度膝を上げ下げしたが「結婚適齢期にしちゃあ、情操のカンカンが足りないね」「そんなことはなくってよ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれのまわりでも、まだまだ結婚適齢期の娘をもった母親は、時にふれ、折にふれて眼の色を変えている。",
              "citation": {
                "source": "女性の歴史",
                "author": "――文学にそって――",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五歳ぐらいの不良少年がチャリンコ適齢期であり、親分子分、兄貴とのつきあいを知っていることは、こんにちの日本の世相では周知の事実である。",
              "citation": {
                "source": "犯人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学生として、中年の紳士として、結婚適齢期のお嬢さんとして、なんでもいい。",
              "citation": {
                "source": "俳優倫理",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚適齢期は段々後れて来つつあるのである。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私でも、仮に自分を結婚適齢期の娘と仮定すれば、色々私独特の求婚工策がないでもない。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い女性というとき、これまでその若さは何となし結婚適齢期のぐるりで考えられていた。",
              "citation": {
                "source": "若い人たちの意志",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘達が結婚適齢期になると、彼女達は夫を自分の好みで選べると考えた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "おしろいつけてきれいきれいに、お化粧しましょ」　お袖は、子どもを抱きに来た。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
