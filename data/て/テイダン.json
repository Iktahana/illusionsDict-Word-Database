        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミドリちゃんのにいさんの敏夫くんは、しょうねんたんていだんいんなので、ミドリちゃんもそういうたんていみたいなことがすきなのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　しょうねんたんていだんいんの敏夫くんが、ざんねんそうにいいました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミドリちゃんのにいさんの木村敏夫くんは、さっそく、このことをしょうねんたんていだんちょうの小林くんに知らせましたので、小林だんちょうが、木村くんのうちへやってきました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わしは、いつか、きみたちしょうねんたんていだんと、ちえくらべをしたまほうはかせだよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからしばらくすると、小林くんがでんわでよびよせた、十人のしょうねんたんていだんいんが、明智たんていじむしょへあつまってきましたが、その中にひとりだけ、女の子がまじっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "５　しょうねんたんていだんのたったひとりのしょうじょだんいん、宮田ユウ子ちゃんは、ルビーでできた赤いカブトムシをもって、じぶんのうちのせっこうざいくのこうばにはいって、なにかやっていました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "このちえくらべは、しょうねんたんていだんのかちよ。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "７　こんどは、少年たんていだんが、ルビーのカブトムシをさがす番でした。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "９　少年たんていだんの小林だんちょうと、だんいんの木村くんと、ユウ子ちゃんと、井上くんと、ノロちゃんの五人が、まほうはかせのあんごうをといて、世田谷区のはずれのさびしい原っぱにあるほらあなへはいっていくと、コンクリートのまるいへやにとじこめられ、上からおもい鉄のふたが、じりじりとさがってきました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと前に、少年たんていだんがたたかった、あのおそろしい、せいどうのまじんと、そっくりなのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうねんたんていだんのなわばしごは、一本のきぬひもです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "みなさん、しょうねんたんていだんのみかたというのは、このヘリコプターだったのです。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "12　しょうねんたんていだんのおうえんにやって来たヘリコプターは、強い風をまき起しながら、原っぱのまん中へちゃくりくしました。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうねんたんていだん、おめでとう。",
              "citation": {
                "source": "赤いカブトムシ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "２　しょうねんたんていだんの井上くんと、ノロちゃんと、井上くんの妹で、小学校三年のルミちゃんの三人が入れられたへやが、まっさかさまになったのです。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、井上くんもにっこりわらって、ポケットからしょうねんたんていだんのきしょうのＢ・Ｄバッジを一つとり出しました。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうねんたんていだんちょうの小林だなっ」　せいようあくまが、ぎょっとしたようにさけびました。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おうごんのとら』のじけんで、ぼくたちしょうねんたんていだんに負けた、あのまほうはかせだ。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十人近くのしょうねんたんていだんいんたちが、まほうやしきのへいの外をぐるっととりまいていたからです。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、わしが負けたしるしに、あの三まいの子どもライオンの毛皮は、きみたちのおもちゃにあげることにしようね」　こうしてしょうねんたんていだんは、またしても、おとなのまほうはかせをうち負かしてしまったのでした。",
              "citation": {
                "source": "まほうやしき",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "この小さいぼうえんきょうは、しょうねんたんていだんの七つどうぐの一つで、いつでももちあるいているのです。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうねんたんていだんのぽけっと小ぞうは、じどうしゃのうしろのとらんくの中にかくれました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっき、きみのぽけっとから、しょうねんたんていだんのばっじをだして、みちにまいておいたから、いまに、こばやしくんが、きみをたすけにやってくるからな」４「おまえは、ここにはいっていろ」　二十めんそうは、ぽけっとこぞうを二かいのへやにおしこめてしまいました。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
