    "definitions": [
      {
        "index": 1,
        "gloss": "removing extra buds (to promote the growth of those remaining)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は、私の家庭を決してきらいでは無いのですが、それでも淋しくてなりません。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の恋人や、夫についての感想をひとに求める女ほど、私にとってきらいなものはまたと無いのである。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦いなんてきらいだし、おしばいだって面白くありません。",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは兄を、決してきらいではないのですけど、でも、兄に何でも打ち明けて語ろうという親しい気持は起りません。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何はしかれ、御手紙をうれしく拝見したことをもう一度申し上げて万事は御察し願うと共に貴下をして、小生を目してきらいではない程のことでは済まされぬ、本当に好きだといって貰うように心掛けることにいたします。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、映画の中でのことよ、好きと云ったってきらいと云ったって。",
              "citation": {
                "source": "女の歴史",
                "author": "――そこにある判断と責任の姿――",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在のアメリカ人にとってきらいなことは、きらいなことだときめるだけですむかのように、それから先の追究をすてているところに、アメリカの明るさと同時に異様な主体性の没却を示している。",
              "citation": {
                "source": "心に疼く欲求がある",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてきらいかというとうるさいからだ。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そンなこと云う貴方ってきらいッ！",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お蒲団をたたんでいらっしたおかあさんが、「戦争ってきらいね」　と、おっしゃいました。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕のおかあさんは、いつも戦争ってきらいだ。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女生徒達の方では、「困るわねえ、男の生徒ってきらいだわ……」　とぐちぐちこぼし始めたが、やがて、饗庭芳子は何を思ったのか、つかつかと教壇に上って、　――男のセイトキライ――　と書いた。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「とうとう……でもいいでしょう、自分の望んで居た事なんだしいろんな事が都合よく行って居るんなら……私だってきらいな事じゃなし……」　私は、こんな事を云った。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "決してきらいではない！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんはあんなところは危なくてきらいなんです。",
              "citation": {
                "source": "童話",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうめんて長くて、変に曇っていてきらいだわ。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は君で生き、僕をいやらしくてきらいだといい、僕はその僕を生きているだけの話だ。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昼間が決してきらいでない。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "大してきらいでなかったら、やはりあがった方がいいのではないでしょうか。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから市中においても野外においても、乗馬以外の乗物はすべてきらいである。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
