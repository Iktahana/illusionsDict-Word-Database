        "examples": {
          "standard": [
            {
              "text": "彼女は貞操蹂躙の被害に遭い、深い心の傷を負った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "貞操蹂躙は、決して許されることのない重大な犯罪である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "法律は、貞操蹂躙からの被害者を守るために存在する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんなことを、貞操蹂躙とか色魔とか云って大騒ぎする奴の気が知れない。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴力行為で、貞操蹂躙されかかったのは、こっちの方じゃ」　そのことだけを、釈明した。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体なら、貞操蹂躙で訴えるところじゃけんど、あれを芸者としてお座敷に出しといたのが、こっちの油断じゃ。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
