          "literary": [
            {
              "text": "過ぐる日中戦争で、七機の敵飛行機を撃墜している。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "空からなりと、海面からなりと、一機の敵飛行機であれ、一隻の怪ジャンクであれ、向こうから近づけば、どんなことがあっても生かしては帰さぬ決心であった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらはつづいて東鳥島の敵飛行根拠地を攻め、二百機の大空軍を全滅せしめたり。",
              "citation": {
                "source": "昭和遊撃隊",
                "author": "平田晋策",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
