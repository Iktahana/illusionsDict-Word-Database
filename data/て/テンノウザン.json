        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天王山は諸所方々に移転した。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だってまた天王山を持ち出したのだろう。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天王山を間違えたのかどうだか、天目山などと言う将軍も出て来た。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば、二枚落を指す場合、六五歩と下手が角道を通すか通さないかは、山崎合戦で、天王山を占領するか否か位の大事な手である。",
              "citation": {
                "source": "将棋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "和成るや飛ぶが如くに馳せ上って、光秀の虚を山崎｜宝寺天王山に衝き、光秀をして三日天下のあわれを喫せしめた。",
              "citation": {
                "source": "賤ヶ岳合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎で戦うとすれば、大切な要地は天王山である。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、出立の時刻よりも、天王山に到る道程の関係や、登り道の関係も考えねばならぬ。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、秀吉軍の方が、先きへ天王山の頂上を占領して、後から来る松田政近の軍勢を、追い落した。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "山崎合戦の勝敗の岐路は、天王山への登山競争にあったわけである。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "光秀もその戦略眼に於ては、一歩も秀吉に譲らなかったのであるが、天王山の地理などには、光秀の方が、その所領の関係上暗かったかも知れないのである。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "光秀は、之より先天王山が、気になったので、並河｜掃部、溝尾勝兵衛の二人を応授にやったが、既に松田の軍破れ松田は討死して、天王山は全く秀吉の手中に落ちてしまっていた。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉、生駒｜親正、木村｜隼人を天王山方面に増援して、横槍についてかからせた。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "光秀が、天王山に関心しながら、淀川の方を気にしなかった事も亦、一つの敗因でなかったかと云われている。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、天王山が秀吉軍に帰し、そのほうから横撃されては、万事すでに去ったと云うべく、それと同時に洞ヶ峠にいた筒井順慶の大軍が裏切りして淀川を渡り、光秀の背後に襲いかかって来た。",
              "citation": {
                "source": "山崎合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂小五郎も、この事件に就ては、簡単ながら手記を書き、「天王山に兵を出す、此に基けり」　と結んでゐる。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂に長軍の上洛となり、天王山に本拠を進め、蛤御門の戦闘となるのである。",
              "citation": {
                "source": "大衆維新史読本",
                "author": "池田屋襲撃",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天王山だ、天目山だ、これこそ本土決戦の関ケ原だ」といわれた沖縄が失陥したのだ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "果して天王山だったのか、関ケ原だったのか。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは尚相当の時日を貸さなければ判定できないが、この天王山だの関ケ原などという用語が、あまり感心出来ないものであることは確かだ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当局はそれに困ってか、沖縄は天王山でも関ケ原でもなかった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんならなぜ初めに天王山だ、関ケ原だといったのだと、いいたくなるわけだ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「沖縄は天王山であり、関ケ原である。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は最後の二十一日まで踏みとどまろうとしたが、その時は山崎に退いた長州兵も散乱し、久坂、寺島、入江らの有力な同僚も皆戦死したあとで、天王山に走って、そこで自刃した。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "その暮れになって見ると、天王山における真木和泉の自刃も、京都における佐久間象山の横死も、皆その年の出来事だ。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は市川三左衛門をはじめ諸生党の領袖が水戸の国政を左右する際で、それらの反対党は幕府の後援により中山藩と連合して天狗残党を討とうとしていたので、それを知った彼は場合によっては天王山に立てこもるつもりで、武器をしらべると銃が七｜挺あるに過ぎない。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "天王山の麓から高麗山の麓へかけて、紅く黄ろく色づいた木々の美しさに目を惹かれて、家に爲殘してゐる用事をも忘れて時を過してゐたが、菊など植ゑてある或る小さな別莊の庭先に、二人の子供を從へて立つてゐる、可成り老けた顏した婦人がふと目についた。",
              "citation": {
                "source": "見て過ぎた女",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "淀の川尻で舟に乗った生絹は、右に生駒の山、男山を見、左に天王山をのぞんだ。",
              "citation": {
                "source": "荻吹く歌",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「千鳥塚というのはどこですか」　女の人がたずね返すと、「千鳥塚は天王山にありますがねえ、この道をこう行って、こう戻らっしゃると……」　千鳥塚の案内をかなり細かく親切にしてくれる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて二人は相前後して、路を裏に取り、教えられた通り、天王山の千鳥塚をさして行くべく、田疇の間の並木の中に身を隠してしまいました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "年魚市の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
