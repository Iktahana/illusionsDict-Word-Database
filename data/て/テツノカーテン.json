        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "冷戦時代、ヨーロッパは「鉄のカーテン」によって東西に分断されていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉄のカーテンの崩壊は、世界の歴史において大きな転換点となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼が書いた本は、鉄のカーテンの向こう側の生活を描いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "こんにち反動は、おそろしげに鉄のカーテンとよんでソヴェト同盟の現実をかくそうとしている。",
              "citation": {
                "source": "事実にたって",
                "author": "――一月六日アカハタ「火ばな」の投書について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パール・バックは平和の確保のためにあのように熱心だし、「怒りの葡萄」「真珠」などの作品で世界的なアメリカの作家スタインベックは最近ソヴェトを訪問して「鉄のカーテン」の彼方に温い血をもって勤労し建設し笑い悲しんでいる同じ人間の生活していることを発表した。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「自然主義的鉄のカーテン」である。",
              "citation": {
                "source": "恐怖の季節",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "終戦のあくる年には、ウインストン・チャーチルのフルトン演説によって、「鉄のカーテン」という言葉が、有名になっていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
