          "literary": [
            {
              "text": "手紙文という特異な文体。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手紙文といふ特異な文體。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは私の創作「虚構の春」のおしまいの部分に載っている手紙文であるが、もちろん虚構の手紙である。",
              "citation": {
                "source": "帰去来",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "卷紙に毛筆で書くのは不慣れだつたし、文體も彼が日頃書き慣れてゐる手紙文とは違はねばならなかつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "単なる別れの手紙ではあったが、この手紙文の数行に若い夫婦の幸せがかかっていた。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場では、説明できないけど、キミが教えてくれた最後の手紙文の様子から、明確に言えることは、俺が言ったと同様な線で、絶筆文として組み立ててある。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
