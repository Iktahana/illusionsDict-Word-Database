        "examples": {
          "standard": [
            {
              "text": "手すき紙の賞状を受け取ると、その質感から努力が報われた実感が湧いてくる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "大切な友人への手紙は、風合いの良い手すき紙の便箋に書きたい。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "美術館のショップで、地元の職人が作った美しい手すき紙の工芸品を購入した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "電報用紙、使ひかけの書簡箋、手すき紙の角封筒がすこし、鏡の割れたのと香水の空壜、それに、去年の夏裏の崖つぷちで拾つた土栗といふ星形の黒く乾いた茸、これは幾島に名前を訊ねようと思つて持つて帰つたのである。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "横とじの、吉野の手すき紙で装幀して横帙に入れた本よ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "書類は粗い手すき紙に、羽根ペンで書いてあります。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            }
          ]
        }
