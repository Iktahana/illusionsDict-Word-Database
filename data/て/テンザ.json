    "definitions": [
      {
        "index": 1,
        "gloss": "one of the six administrators of a Zen temple (in charge of food and other matters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから三人前後して濡れた石を踏みながら典座寮と書いた懸札の眼につく庫裡から案内を乞うて座敷へ上った。",
              "citation": {
                "source": "初秋の一日",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は俊和尚の典座だ、飯頭であり、燗頭であつた、ふらん草のおひたし、山蕗の甘煮、蕨の味噌汁、みんなおいしかつた、おいしく食べてぐつすり寝た。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の住持は私も一度御目にかかつたが近頃珍しい老清僧で、知客、典座の役まで一人で引受けられる位気軽な、良寛ほども俗気のない方だつた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが典座教訓　とにかく、隠れた所を穢くしておかぬように厳重に言い付けておくのです。",
              "citation": {
                "source": "料理一夕話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
