      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "seal-engraving style (of writing Chinese characters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでその定窯の鼎の台座には、友人だった李西涯が篆書で銘を書いて、鐫りつけた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで其の定窯の鼎の台座には、友人だつた李西涯が篆書で銘を書いて、鐫りつけた。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一冊は学科に関係のない事件の備忘録で、表題には生利にも紺珠という二字がペンで篆書に書いてある。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "日露戦役後、度々部下の戦死者のため墓碑の篆額を書かせられたので篆書は堂に入った。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "本人も得意であって「篆書だけは稽古したから大分上手になった、」と自任していた。",
              "citation": {
                "source": "鴎外博士の追憶",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も一枚こっきりのいわゆる常上着の晴着なしであったろうが、左に右くリュウとした服装で、看板法被に篆書崩しの齊の字の付いたお抱え然たる俥を乗廻し、何処へ行っても必ず俥を待たして置いた。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "篆書でも隷書でも草書でも、学ばずして見事に書くので、見る人みな驚嘆せざるはなかった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "※完白風の篆書を書く。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に是れに書いてある篆書などを一々入れると云ふことは手數であるから、一部分だけ寫眞石版で體裁を見せて置くと云つて、三四枚載せてあります。",
              "citation": {
                "source": "弘法大師の文藝",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は餘計な話でありますけれども、此の出版者も仰つしやる通りに、此本に篆書がありますが隨分下手な篆書でありまして、弘法大師が書かれたならば、こんな下手な字は書かれませぬが、弘法大師の原本から幾度も傳寫をして、斯う云ふやうになつたので、隨分下手な字が書いてある。",
              "citation": {
                "source": "弘法大師の文藝",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し愈々是れが面倒だと云ふならば、此の篆書は有つても無くつても大したことはありませぬ。",
              "citation": {
                "source": "弘法大師の文藝",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば最初どんな字体を習えばよいかと聞きますと、楷書、行書、草書と順をおい、隷書とか篆書とかは、あらゆる書を習得した後にやるべきものだということでした。",
              "citation": {
                "source": "能書を語る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、隷書とか篆書を習うと、次第に反感を持ちまして、私はそれから秘かに隷書の稽古をいたしました。",
              "citation": {
                "source": "能書を語る",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塗の上へ篆書の金文字で神籤と書いたその箱の中には、象牙を平たく削った精巧の番号札が数通り百本納められていた。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど仔細に見ると、同じ鼎形なり額形の「二天」とある篆書体の印も、決して一様でないのである。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "篆書の字劃も彫りも、何様、素人彫の手すさびらしい稚拙が見遁せない。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう篆書体の字劃も、寛永や元和頃なら、もう日本へ篆書の本が渡っているので、あってふしぎはないな。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "げんきてんしょうの昔よりずいぶんながい世間をわたってまいりましたので、もう後生をねがうよりほかのことはござりませぬが、たゞこのはなしをいっぺんどなたかにきいていたゞきたかったのでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
