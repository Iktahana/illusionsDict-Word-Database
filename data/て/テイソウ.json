    },
    "definitions": [
      {
        "index": 1,
        "gloss": "forwarding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
