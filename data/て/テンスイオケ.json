        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "門をくぐってゆくと、あの大きい天水桶はなくなっていた。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして天水桶のあったあたりには、木之助の嫌いな、オート三輪がとめてあった。",
              "citation": {
                "source": "最後の胡弓弾き",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ここに、信也氏のために、きつけの水を汲むべく、屋根の雪の天水桶を志して、環海ビルジングを上りつつある、つぶし餡のお妻が、さてもその後、黄粉か、胡麻か、いろが出来て、日光へ駆落ちした。",
              "citation": {
                "source": "開扉一妖帖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側に御手洗、金燈籠、石燈籠、狛犬が左右に建ち並んで、それから拝殿の庇の下に喰つくようになって天水桶があった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天水桶は鋳鉄であった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その右側の天水桶の縁に烏のような水だらけになった一羽の鳥がとまって、それがばさばさと羽ばたきをやっていた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚い天水桶の上には鳥の柔毛が浮んでいた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "広巳は鵜に興味がなくなったので、天水桶の傍をぐるりと廻って、社の横手へ往ってそこの階段へ腰をかけた。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はいつもの通りに冷たい水で顔を洗って家を飛び出すと、朝日のあたらない横町は鉄のように凍って、近所の子供が悪戯にほうり出した隣りの家の天水桶の氷が二寸ほども厚く見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしも寒中に金魚をながめていた人もあったんですよ」「天水桶にでも飼って置いたんですか」と、わたしは訊いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、天水桶の金魚は珍らしくもありません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい天水桶ならば底の方に沈んで、寒いあいだでも凌いでいられますからね。",
              "citation": {
                "source": "半七捕物帳",
                "author": "冬の金魚",
                "note": "青空文庫"
              }
            },
            {
              "text": "見る見る歯医者の家の前を通り過ぎて、始終僕たちをからかう小僧のいる酒屋の天水桶に飛び乗って、そこでまたきりきり舞いをして桶のむこうに落ちたと思うと、今度は斜むこうの三｜軒長屋の格子窓の中ほどの所を、風に吹きつけられたようにかすめて通って、それからまた往来の上を人通りがないのでいい気になって走ります。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩の九つ過ぎでもありましたらうか、この助十とわつしとが遲い仕事から歸つて來まして、馬喰町の横町へ差しかゝると、頬かむりをした一人の野郎が天水桶で何か洗つてゐるやうでしたから、何をしてゐるのかと提灯の火で透かしてみると、そいつは着物の袖を洗つてゐるらしいのです。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今もいふ通り、天水桶で袖を洗つてゐるだけならば、別に不思議と云ふほどのことでもねえが、そいつが光るものを持つてゐる。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "六郎　天水桶で袖を洗ひ、何か光るものを洗つてゐたのだな。",
              "citation": {
                "source": "權三と助十",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お玉さんの家の格子のまえには古風の天水桶があった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちがもしその天水桶のまわりに集まって、夏はぼうふらを探し、冬は氷をいじったりすると、阿母さんはたちまちに格子をあけて、「誰だい、いたずらするのは……」と、かみ付くように呶鳴りつけた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外無駄骨折りになるかも知れないとは思いながらも、この職業に伴う一種の好奇心も手伝って、かれはそっとあと戻りしてそこらの塀の外にある天水桶のかげに身をひそめていると、今夜も暗い宵で、膝のあたりには土から沁み出してくる霜の寒さが痛いように強く迫って来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "松茸",
                "note": "青空文庫"
              }
            },
            {
              "text": "上のかたには土蔵の白壁がみえて、鉄の大きい天水桶もある。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし達がもしその天水桶のまわりに集まって、夏はぼうふらを探し、冬は氷をいじったりすると、阿母さんは忽ちに格子をあけて、「誰だいいたずらをするのは……」と、かみ付くように呶鳴り付けた。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は町内にはいって二、三軒も通り過ぎたかと思うと、質屋の天水桶のかげから何かまっ黒な影があらわれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "箪笥や鏡、嫁入り道具一式を売る向いの古い反物屋の前に据えた天水桶に、熱そうな日が赫々と照して、埃深い陳列所の硝子のなかに、色の褪めたような帯地や友染が、いつ見ても同じように飾られてあった。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨は喧ましく板屋根を敲きながら、さざめく小川のように傍らの天水桶へ流れ落ちている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう家の前を離れると、すぐ傍が黒い蔵であったり、木口のよい板塀であったりして、天水桶や、金網をかけた常夜燈が灯っていたように覚えている。",
              "citation": {
                "source": "流れた唾き",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、暖簾も紺、長暖簾もおなじく、屋号と、印を白く染めぬいた紺のれんで、鉄や厚い木の天水桶が店のはずれに備えつけてあって、中にはなかなか立派な、金魚や緋鯉が住んでいた。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "天水桶があって――桶といっても上に乗っている手桶だけ木で、下の天水桶は鋳鉄が多かった。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから麦酒樽の天水桶の上に乾し忘れたままの爪革だった。",
              "citation": {
                "source": "保吉の手帳から",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
