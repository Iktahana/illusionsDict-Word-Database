    "definitions": [
      {
        "index": 1,
        "gloss": "celestial world",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そういう時に彼は音楽の醸し出す天上界の雰囲気に包まれて、それで始めて心の集中を得たのではあるまいか。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しいと申して、竜宮や天上界へ参らねば見られないのではござらんで、」「じゃ現在いるんですね。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "列仙の集まる蟠桃会を擾がし、その罰として閉じ込められた八卦炉をも打破って飛出すや、天上界も狭しとばかり荒れ狂うた。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "……一体が、天上界の遊山船に擬らへて、丹精籠めました細工にござるで、御斉眉の中から天人のやうな上※御一方、と望んだげな。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢやが、お前様は山が先生、水が師匠と言ふわけ合で、私等が気にや天上界のやうな東京から、遥々と……飛騨の山家までござつたかね。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟浄がかつて天上界で霊霄殿の捲簾大将を勤めておったとは、この河底で誰言わぬ者もない。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天上界で五百年前に捲簾大将をしておった者が今の俺になったのだとして、さて、その昔の捲簾大将と今のこの俺とが同じものだといっていいのだろうか？",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、俺は昔の天上界のことを何一つ記憶してはおらぬ。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで洗濯石鹸を揉むようで……その水を汲み換え汲み換え泡の影が無うなるまで揉みました奴の三杯酢を肴にして一杯飲もうモノナラその美味さというものは天上界だすなあ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "助かりや助かりや、有難や有難や、勿体なや、サンタ・マリア……一丁テレスコ天上界。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は更に進んで「抒情歌」によってとうとう現世をすて霊の天上界へまで逃げのびてしまった。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "と怪みつぶやきて立ちとまれば、匂はそと少女の耳に口を寄せ、「上に見ゆるは天上界、下に見ゆるは月球なり。",
              "citation": {
                "source": "花枕",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "下界を去られて、天上界へ……」「私は信仰を失いそうだ」「私は教団を出ようかしら」「苦行するのが厭になった。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの星のまたたくのを見てゐると天上界では人々翠帳にこもつて甘語しきりなるを思はせるのに、その同じ時下界の私は一人で悶々としてゐるといふ様な意味に解せられるが、「星の今を」など随分無理な言ひ廻しであり、終りの「よ」なども困りものである。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すべての現象を、直に天上界の無心の自然と観ずる時は」と言ふのである。",
              "citation": {
                "source": "橘曙覧評伝",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒼白く面高に削り成せる彼の顔と、無辺際に浮き出す薄き雲の※然と消えて入る大いなる天上界の間には、一塵の眼を遮ぎるものもない。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、天つ祝詞は、神聖な天上界と同じ詔詞を発する聖座の義だ。",
              "citation": {
                "source": "日本文学の発生",
                "author": "――その基礎論――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俗曲の『恋慕』とは違いまして、『鈴慕』と申しますのは、御承知でもございましょうが、普化禅師の遷化なさる時の鈴の音に合せた秘曲なんでございます、人間界から、天上界に上って行く時の音が、あれなんだそうでございます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時の心持と、今晩の心持とが同じことでございます、人間界を離れて、天上界にうつる心持というのはこれかも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかのお星さまのように、遠く、高く、地から離れて、天上界に住むことができないのであります。",
              "citation": {
                "source": "めくら星",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あめの」は、日本神話に於て、最も多く用いらるる形容詞或は附加言にして、要するに、地上界に対する天上界、人間界に対する諸神界、その中に坐ます諸神、その附属物、その他の万事万物を、尊厳にし、神聖にせんが為めの、一個の形容言、一個の修辞的附加言たるに過ぎず。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何なる民族も、そのはじめに於て、天上界の存在を信ぜざるはなし。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "既にその存在を信ず、従て天上界と地上界の連絡、交通、接触等に関して、物語るに至る。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天女は清浄なる天上界の存在なり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して此等の鳥が、凡ての場合に於て、超自然的性質を有し、天上界の存在の如きの観あるは如何。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに、未開人民が、天上界に超自然的存在を想像し、時としては、或目的の為めに、若しくは或条件の下に、此者と人間との結合の可能なるを、信じたりとの説は、一般に許容す可きものとす、吠※のウルヴシも、琉球の天女も、伊香の天女も、赫夜姫と等しく、凡て或る事情によりて、一時人間界に降り来たるものなり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の如くして、彼等は天上界に超自然的存在を想像し、時としては、或目的の為めに、若しくは或条件の下に、人間との間に、接触結合の起り得可きを信じたり。",
              "citation": {
                "source": "比較神話学",
                "author": "高木敏雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに天よりの迎えが到着して、天上界と地上界とが全然重なり合った場面の描写はきわ立って巧みである。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上のものではなく、まさに、天上界に属すべき美であった。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、この世界を唯心の世界とし、精神中に包有する原因に従ってわれわれの境遇の起こることを知らば、われわれの死するときは、わが一生中の言行と、前世の業因とが相合して、その精神中に熏伝し、他日、精神再起の暁にその結果を開き、あるいは人間界、あるいは天上界等に、さらに一生を現ずることが分かりましょう。",
              "citation": {
                "source": "通俗講義　霊魂不滅論",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
