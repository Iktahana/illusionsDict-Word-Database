        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "手配師として振る舞えるほどのコネクションはなかったが、一つだけ手がかりを思いついた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "運よく、そこで馴染みの俳優手配師ジャーマンを見つけた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し経つと、制作兼俳優ハーコートと、凄腕の俳優手配師ジャーマンの二人きりになった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、我々劇場手配師は些細なことも知ってる。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「当誌の信頼できるマーク・ジャーマン手配師によれば、ウィルビイ・ハーコートの最新ヒット劇『世の終わり』に新たな秘話が加わった。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですので　ババールも　そなえて　スキーいたを　てにいれ　そりを　てはいします。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府はそれを新聞やラジオで発表しないように、てはいした。",
              "citation": {
                "source": "宇宙怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
