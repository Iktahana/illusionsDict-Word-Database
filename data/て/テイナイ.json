    },
    "definitions": [
      {
        "index": 1,
        "gloss": "grounds",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "邸後の森からは、小川が一度邸内の泉水を潜って、前の田へと灑がれていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防組の赤い半纒を着た人たちや、青年会の連中が邸内のあちこちに眠そうな手で蚊を叩いていた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "本田家の邸内を護衛していた、小作人組合に入っていない、青年団の青年たちや、消防組員までも、一応は取調べを受けた。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴァイオリン弾きの老爺はしきりに主人の邸内から辞してまたさすらいの旅に出ようとしました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処までも、自分の邸内にとどめて可哀想な乞食音楽師を安楽に暮らさせ様と心掛けました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、主人はヴァイオリン弾きの老爺が、突然無断で邸内から抜け出し、何処とも知らず、逃げ失せたのを知りました。",
              "citation": {
                "source": "慈悲",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は家族を挙げてターリングの邸内に移り、死ぬまでここでレーリーの片腕となって働いた。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○＝主膳の邸内　なりひら小僧が座敷の中を引ッ掻き廻して連判状を探して居る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）７３＝（Ｆ・Ｉ）結城左久馬邸内　左久馬が十人ばかりの若侍を呼んで、Ｔ「昨夜の事、お上に知れては身共の首が危ない」　と言って、Ｔ「右門を殺して呉れ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）73＝（Ｆ・Ｉ）結城左久馬邸内　左久馬が十人ばかりの若侍を呼んで、Ｔ「昨夜の事、お上に知れては身共の首が危ない」　と言って、Ｔ「右門を殺して呉れ。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん自分の中学時代、それもよほど後のほうかと思うころに、父が東京の友人に頼んで「大杯」という種類の楓の苗木をたくさんに取り寄せ、それを邸内のあちこちに植えつけた。",
              "citation": {
                "source": "庭の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも、自分の邸内にとどめて可哀相な乞食音楽師を安楽に暮させようと心掛けました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある夜、主人はヴァイオリン弾きの老爺が、突然無断で邸内から抜け出し、どことも知らず、逃げ失せたのを知りました。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの幾つもの車が、表門の土台まで除けて邸内に曳き入れられた。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ト此の團右衞門方に飼猫の牡が一｜疋、これははじめから居たのであるが、元二が邸内へ奉公をしてから以來、何處から來たか、むく／＼と肥つた黒毛で艶の好い天鵝絨のやうな牝が一つ、何時の間にか、住居へ入つて縁側、座敷、臺所、と氣まゝに二つが狂ひ遊ぶ。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さては珍事じゃ大変じゃと、邸内一統｜煤掃という見得で騒出し、家令はまず何はともあれ、警察へ届けて出る。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "繪を研究する爲には、邸内に、立派な獨立の畫室も建てゝ貰ツた。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "周三は、何と云ふ譯もなく此の音と響とを聞き分けて見やうと思ツて、熟と耳を澄ましてゐると、其の遠い音と響とを消圧して、近く、邸内の馬車廻の砂利に軋む馬車の轍の音がする。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "久能はあとでこの鼓をさし上げたことを心から苦にして、或る時鶴原卿の邸内へ忍び入ってこの鼓を取り返そうとすると、生憎その頃召し抱えられた左近という若侍に見付けられて肩先を斬られた。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここは三四代前からの牧瀬の邸で、隣接する歳子の兄の家の敷地も昔はこの邸内になつてゐた。",
              "citation": {
                "source": "夏の夜の夢",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には又、あの流を邸内へ引いて、用水ぐるみ庭の池にして、筑波の影を矜りとする、豪農、大百姓などがあるのです。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧は旗野と謂へりし千石取の館にして、邸内に三件の不思議あり、血天井、不開室、庭の竹藪｜是なり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし手証を見ぬことだから、膝下へ呼び出して、長煙草で打擲いて、吐させる数ではなし、もともと念晴しだけのこと、縄着は邸内から出すまいという奥様の思召し、また爺さんの方でも、神業で、当人が分ってからが、表沙汰にはしてもらいたくないと、約束をしてかかった祈なんだそうだから僥倖さ。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際Ｏ家は此の町の一端何町四方を邸内に採っている。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その邸内の何町四方は一ぱいの樹海だ。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方加奈子とは知り合わない昔の小学校時代の隣の息子か、京子がＭ伯と結婚時代の邸内にいたという殊勝だった書生の名ででもあったろうか。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、自分の作品をあまり認めていないし、また、よその人の作品もそんなに認めていない。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術だとは思っていない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに私は、近眼のくせに眼鏡をかけていないので、よほど前の席に坐らないと、何も読めない。",
              "citation": {
                "source": "弱者の糧",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、人の虚栄を非難しようとは思っていない。",
              "citation": {
                "source": "答案落第",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
