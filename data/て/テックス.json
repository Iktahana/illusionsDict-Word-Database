    "definitions": [
      {
        "index": 1,
        "gloss": "(soft) fiberboard",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "またラヴィシウス・テックストル10の『痴愚集』の中にも、それと同じ崇高な最期を遂げた人物の長いリストが載っている。",
              "citation": {
                "source": "しめしあわせ",
                "author": "THE ASSIGNATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "Im Abendrot のテックストを送って下さってありがとうございました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたたびパワー・ポリテックスへの幕が開いたのである。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから40年以上の月日が経ち、サン＝テックスの著作権が日本国内で失効することになりました。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "サン＝テックスの著作権が切れる前から、どの出版社がやるのか、どんな翻訳者がこの作品に挑むのか、たいへんな話題になりました。",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は簡単に陥落して、とうとう一晩も泊らなかったが、菅谷君は、通計一週間ばかり泊りこんで、小屋の内部を、天井も四方の壁も、全部テックスで張りつめて、やっと住めるようにした。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "入り側にむいた吉野障子は、磨硝子とニッケルを組み合わせた、モダーン・タイプの硝子扉になり、なにやらの工匠が彫った有名な欄間と、銀の引手のついた花鳥の絵襖が取り払われ、襖のあったところにテックスの間仕切りができ、ぞっとするような富士山の油絵がかかっていた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "上段ノ間と二つの書院は、テックスの壁で仕切られて、三つの独立した部屋に成り上り、おのおのの部屋には、ベッドと電気冷蔵庫がついて、独身者アパートのような趣きになっているのである。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "話のつづきは、勢い立ち話になり、われわれはテックスの間仕切りに凭れて聞いていた。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヴィンテックス洗剤でいたしましょうか。",
              "citation": {
                "source": "我が家の楽園",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒地にペインテックスで桂馬と飛車の将棋の駒が描いてあるのであった。",
              "citation": {
                "source": "細雪",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "テックス・リターやロイ・エイカフは、ニクソン大統領の就任式に、大統領から個人的に招待された。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テックス・リターが商用でマイアミに向かったとき、乗っていたジェット機がハイジャックにあい、リターは、ハヴァナまでつれていかれた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テックス・リターですらそうだし、キティ・ウエルズは、最近でもワン・ナイターに出ていないのは、一年のうち一〇〇日くらいのものなのだ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テックス・リターにはホワイトフラッシュという馬がいた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
