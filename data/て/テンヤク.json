  {
    "uuid": "8222229b-b326-59b7-bd2f-e49a2ad59f2f",
    "entry": "点訳",
    "reading": {
      "primary": "てんやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "translating into Braille",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "堀之内さんのページからたどって、ＢＢＡのサイトを開くと、「弱視者を含めた視覚障碍者全般の読書を支援するために点訳・音訳・拡大訳の３分野の活動を全て統合的に推進しています。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから、点訳、音訳、拡大訳の三つの道筋を付けていく。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ目の点訳とは、文章を点字に置き換える作業を指す。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、パソコンの普及に連れて点訳用のソフトが開発され、利用されるようになった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "続いて点訳用のソフトを使って、五十音を表す、点字データを入力する。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした一般的なパソコン点訳の流れに対して、ＢＢＡの作業フローは、漢字仮名交じりの原文データをコンピュータに変換させ、少ない手間で直接点字データを得ようとする形で描かれていた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "全盲に対する読書支援は、点訳や音訳によって、充分からはほど遠いものの行われてきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな文字による拡大写本作りは、もっぱら手書きに頼ってきたのが実状で、ボランティアの数も、点訳や音訳に比べれば、はるかに少なかった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにそっておけば、青空文庫のテキストを、ＢＢＡが想定している、点訳、音訳、拡大訳の三つの流れにのせて、視覚障碍者の読書支援に活用してもらえるのではないかという期待もあった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴眼者がパソコンなどの画面で読むテキスト・データを、そのまま点訳、音訳、拡大訳に利用していくというＢＢＡの構想のかなりは、今や常識的なものとなっている。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お点ちゃん」と名付けられた、無料で利用できる点訳ソフトは、漢字仮名交じりテキストから、点字プリンター用のデータを直接生成する。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "理解力の高い人間に比べれば、点訳ソフトの分かち書きでは、誤りや解釈のずれが生じやすい。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "将来にわたっても、漢字仮名交じり文から、完璧な点訳データを一気に生成するといったことは困難だろう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、複数の変換候補からそのつど選んでいく方式で、パソコンにおける日本語入力が広く普及したように、修正しながら作業することを前提に、新しいタイプの点訳ソフトの活用も広がって行くだろう。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "この延長線上に、点訳ソフトを使って点字データを入力し、点字プリンターに打ち出して、「書ける」ようになった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……無限の霊を持っている私たち有限の人間どもはひたすら悩んだり喜んだりするために生まれていますが、ほとんどこういえるでしょう――最も秀れた人々は苦悩をつき抜けて歓喜を獲得するのだと……」〔傍点訳者〕〕",
              "citation": {
                "source": "ベートーヴェンの生涯",
                "author": "VIE DE BEETHOVEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
