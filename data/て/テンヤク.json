[
  {
    "uuid": "ec429e21-7bef-5c68-982a-a008d37b166c",
    "entry": "典薬",
    "reading": {
      "primary": "てんやく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "court physician",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "光起の亡き父も、義庵と称して聞えた典薬頭、今も残っている門内｜左手の方の柳の下なる、この辺に珍しい掘井戸の水は自然の神薬、大概の病はこれを汲めばと謂い伝えて、折々は竹筒、瓶、徳利を持参で集るほどで。",
              "citation": {
                "source": "三枚続",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この病いは和丹両家の典薬どもにも匙を加えようがない。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "関白殿のお指図で典薬頭が方剤を尽くして、いろいろにいたわって下されたが、人の命数は是非ないものでのう」と、玉藻も今更のように眼をうるませた。",
              "citation": {
                "source": "玉藻の前",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃幕府の典薬に始終讃岐守の世話になつてゐる男があつて、お礼の印に何がな贈り度いと思つてゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "典薬は早速江戸中を探して、素晴しく立派な鶉を買ひ込むだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "典薬は占めたと腹のなかで小躍りした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　典薬は鶉のやうに背を円めてお辞儀をした。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "典薬め、物知らずにも程があつたものぢや。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると誰言ふとなくその鶉は典薬が大金を出して、買込んだものだといふ事が伝はつて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しほの母は素京都｜諏訪神社の禰宜飯田氏の女で、典薬頭某の家に仕えているうちに、その嗣子と私してしほを生んだ。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを正親町天皇が出して典薬頭半井通仙院瑞策に賜わった。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是より先正親町天皇の時、典薬頭｜半井瑞策が秘府より受けて家に蔵することとなり、其｜裔孫広明に至つて出して徳川氏に呈したのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "華陽は典薬頭半井景雲の門人で、蕨駅に住んでゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此女が長じて京都の典薬頭某の婢となつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしはこれを典薬頭と解した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "典薬頭某は先妻が歿して、継室を納れてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "其生父は京都の典薬頭某の嫡子であつた筈である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その二百三　蘭軒の嫡子榛軒の妻志保の母は、京都の典薬頭の家に仕へてゐて、其嗣子の子を生んだと云ふことであつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の典薬頭の家は唯一の錦小路家あるのみである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "老女笹尾を筆頭としてお供の女中残らずが、黒姫の裾野の怪旋風に両眼殆ど潰れたも同然、表方の侍とても皆その通りで、典薬が手当も効を見ず、涙が出て留度が無かった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽州米沢の典薬｜勝成裕が、御隠居｜上杉鷹山侯（治憲）の内意を受けて、一行十五人、深山幽谷に薬草を採りに分け入るという、その時代としては珍らしい計画が立てられた。",
              "citation": {
                "source": "壁の眼の怪",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "就てはこの頃或｜典薬之助が、あなた様にお会はせ申せと、責め立てて居るのでございますが、……」　姫君はその話を聞きながら、六年｜以前の事を思ひ出した。",
              "citation": {
                "source": "六の宮の姫君",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに典薬が、何人か閨房に派出されたが、彼等は、ただ、小首をかたむけるばかりだ。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、その医者も、城内典薬たちの診断と違わなかった。",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の侍、いかなる身元かと言うと、当時時めく名医、典薬左井黙庵の次子、不二之進、代々の医業を嫌って、菱川派の流れを汲んだ浮世絵ぶりに大名を馳せ、雅号を露月と名乗って、程近い徒士町辺に閑居を構え、数寄風流の道に遊んでいるものでありました。",
              "citation": {
                "source": "艶容万年若衆",
                "author": "三上於兎吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑戸とは種々の技芸・工業・雑役等に従事するもので、例えば珠玉を造る玉造部とか、弓を造る弓削部とか、鎧を造る鎧作とか、雅楽寮の楽戸、主船司の船戸、造酒司の酒戸、典薬寮の薬戸、造兵司の雑工戸、主鷹司の鷹戸などとかいう様な、一定世襲の職業を持ったものを申すのであります。",
              "citation": {
                "source": "特殊部落の成立沿革を略叙してその解放に及ぶ",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし『延喜式』を見ると、典薬寮の諸国進年料雑薬の条に、甲斐国十二種黄菊花十両と載せてある。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先年宮が病気のとき召された医者｜典薬頭定成がいるはずである、あの者なら首を確認できようというので、使いが走ったが、ただいま病の床に伏しているのでお役には立てない、と申したきり出てこない。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第四巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
