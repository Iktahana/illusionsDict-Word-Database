    },
    "definitions": [
      {
        "index": 1,
        "gloss": "grandniece",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼女には可愛い姪孫が二人いて、よく遊びに来る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の姪孫は、先日大学を卒業したばかりだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家族が集まるお祝いの席で、姪孫たちが歌を披露してくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "此人よくよみ候故、私｜女姪二十六七になり候寡婦御坐候にめあはせ、菅三と申｜姪孫生長迄の中継にいたし候積、姑思案仕候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくし女姪二十六七になりし寡婦御坐候にめあはせ、菅三と申姪孫生長迄の中継にいたし候積」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "行状を参照すれば、「二弟曰汝亦夭、有子曰万年、（中略）亦夭、有子曰惟繩、称三郎、於先生為姪孫、今嗣菅氏、（中略）又延志摩人北条譲、為廉塾都講、以妹女井上氏妻焉」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」末に「半月前喪姪孫女」と註してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂「姪孫女」とは誰であらうか。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此系図と尺牘とに就いて、姪孫女の誰なるかを究めて見ようとおもふ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "原来姪孫女の称呼には誤解し易い処がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし茶山の斥して言ふ所は「姪孫之女」ではなく、「姪之孫女」であるらしい。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは半月前に姪孫女を失つたからである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「十五夜」の詩の註には「半月前喪姪孫女」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "姪孫女とは茶山の同胞の子の娘か、将茶山の同胞の孫の女か。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　茶山の後は姪孫菅三｜惟繩が継いだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "関藤々陰の「菅自牧斎先生墓碣銘」に「茶山先生以儒顕、本藩賜爵禄優待之、比歿、樗平君子孫独先生（自牧斎惟繩）在焉、以姪孫承其後、主郷校、藩給廩米五口、事在文政丁亥」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
