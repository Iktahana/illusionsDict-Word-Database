          "standard": [
            {
              "text": "毎朝、定置網にかかった新鮮な魚が地元の市場に運ばれてきて競りにかけられる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "漁師たちは日の出とともに沖へ向かい、一晩仕掛けておいた定置網を引き上げた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "定置網漁は、魚を追いかけるのではなく待ち受けるスタイルの持続可能な伝統漁法だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "太い孟宗竹を何十本と束ねて縛ったものを浮標にして、重い錘をつけておくと、それが海の中でいわゆる定置網の拠点になるのである。",
              "citation": {
                "source": "大謀網",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
