        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "テニスもやった、自転車も稽古した。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋にはこういう事にも熱心な学者が多く、玉突、テニス、砲丸投等の技術を力学的に研究した例は乏しくない。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏は散歩の代りにローンテニスもやった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスの上手な来客でもこの羽根の生えたボールでは少し見当が違うらしい。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫が見たら人間のテニスやベースボールは定めて間だるっこくて滑稽なものだろうという気がするのである。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニス競技の場面の挿入は、物語としては主要なものでないが、映画の中の挿話として見ると不思議な心理的な効果をあげている。",
              "citation": {
                "source": "映画雑感６",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "海原、離宮、車輛、工場のテニスコート、僕が彼女の乳房のあたりを見つめているうちに、八時四十分、大阪着。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "留学の序を憤り、　　　　　　　中庭にテニス拍つ人。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "肖像朝のテニスを慨ひて、　　　額は貢し　雪の風。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった二人でぬれた運動場の朝のテニスもさびしいだらう。",
              "citation": {
                "source": "山地の稜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "午后はみんなでテニスコートを直したりした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ほどの処の地続きは平にならされてテニスコートになっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下がテニスコートの平地になっている。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスンの詩「プリンセス」に「戦士の亡骸が運び込まれたのを見ても彼女は気絶もせず泣きもしなかったので、侍女たちは、これでは公主の命が危ういと言った、その時九十歳の老乳母が戦士の子を連れて来てそっと彼女のひざに抱きのせた、すると、夏の夕立のように涙が降って来た」というくだりがある。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "運動場もテニスコートのくらいでしたが、すぐうしろは栗の木のあるきれいな草の山でしたし、運動場のすみにはごぼごぼつめたい水を噴く岩穴もあったのです。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代のスポーツ流行はそうした進化の一階段に過ぎないので、喜多実氏がテニスのスタイルを能の中に体現し、松野奏風氏が素早くこれをスケッチしたのも、決して偶然の事ではない。",
              "citation": {
                "source": "「生活」＋「戦争」＋「競技」÷０＝能",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "モトモトテニスらしいものが出来るのは、正直のところ一滴も酒の飲めない筆者の一組だけで、ほかは皆、支那の兵隊と一般、テニスなんてロクに見た事もない連中が吾も吾もと咽喉を鳴らして参加するのだから、鬼神壮烈に泣くと言おうか何と言おうか。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕方なしにそいつを選手外のマネージャー格に仮装して同行を許すような始末……それから原稿紙にテニス・コートの図を描いて一同に勝敗の理屈を説明し始めたが、真剣に聞く奴は一人もいない。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人が一塊になつて砂ほじりでもしてゐるかと思ふと、テニス・コートをてん／″＼ばら／＼に駈け※つて、腹を抱へて笑ひ合ふ姿も見える。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてテニスだのランニングも必要だと云って盛んにやっている。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君はテニスだの野球の競争だなんてことはやらない。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校といっても入口とあとはガラス窓の三つついた教室がひとつあるきりでほかには溜りも教員室もなく運動場はテニスコートのくらいでした。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村博士は瘠せて眼のキョロキョロした人だけれども僕はまあ好きだねえ、それに非常にテニスがうまいんだよ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "式場は、教会の広庭に、大きな曲馬用の天幕を張って、テニスコートなどもそのまま中に取り込んでいたようでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭球もある、「クリツケツト」もある、射的塲もある、相撲の土俵もある、いづれも櫻木大佐が日本を出づる前から、かゝる孤島の生活中、一同の無聊を慰めんが爲めに凖備して來た事とて「テニス、コード」も射的塲も仲々整頓したものである、然し、此島で一番流行るのは端艇競漕と野球競技とであつた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "テニスだよ、テニスと言えば可い。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "虎の門の裏でお友達とテニスをしたのよ……」と甘えるような声で少女は答えた。",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
