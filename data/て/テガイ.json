[
  {
    "uuid": "b3b2154b-66b2-53f4-98be-bee571b15ed1",
    "entry": "手飼い",
    "reading": {
      "primary": "てがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
