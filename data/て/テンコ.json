                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、また、すってんころりんと、ころんでしまった。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんにつるり、すってんころりであった。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身もまた年少にして文筆の生活に入り、時流に耐える底力なく自棄の生活を送っているうちにすッてんころりんと落伍してしまい、ひどいひどい貧乏暮らしのありッたけをしてから、やっとこの頃多少でも自分の好きなものだけを書いて世間に問うことができてきたのである。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぼも　みんな　火元の上の　たなから　おっこちて、　缶の　入れ物も　せいりだなから　すってんころりん。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええっ――すってんころり。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "がァがァ、がちょうがァ、がァ、がちょう、うろついてどこいこ、階上を、下を、おくさまのへやで、じじいにであった、そのじじいどうした、不信心ないやなやつ、そこで、そいつの左の足をすくって、すってんころりとあがり段からころがした。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで　まくしたてたのが、　ながい　はなを　もつ　おおきな　いきもののことに、　そいつに　すごい　いきおいで　はないきを　かけられ　すってんころりん　おいはらわれたこと。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなこってもええ、おめえの思ってんことーすっかり俺れに打ちあけてくんねえか！",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩主に対しても、宇内の大勢を論じて一挙中原の覇を樹てんことを建言した。",
              "citation": {
                "source": "青年の天下",
                "author": "大隈重信",
                "note": "青空文庫"
              }
            },
            {
              "text": "テンコウは砂糖のうちでやすい、赤っぽいてんこ砂糖です。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あぎゃん、こぎゃん、てんこちない、たんぼらめ！",
              "citation": {
                "source": "大菩薩峠",
                "author": "恐山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は彼が必ずひっくりかえるだろうと思い、すっかり睡気をさまして一マイル以上も見つめていたら、果して彼はすってんころりと、路傍の湿った溝へころげ落ちた。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そう　さけんだ　一休さんは、かめと　いっしょに　すってんころりと　ちゃだんすの　うえから　ころげおちました。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『昔はこぎゃんした晩には蒟蒻の化物が出おったばってんこの節は世の中が開けたけん』と言いながら、この向う通りを歩いていますと、『にゃごとこくきゃあ！",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
