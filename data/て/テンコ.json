      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "authentic precedent",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "漢書に典故がある、前代の故実を掌る官職である。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」第六の張為が主客図の典故は唐詩紀事に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に此文の最も不都合なる點は第七行の「紀氏竹内越中守正四位云々」と書下した所に存ずるのであるが、史實に關するものであるから後※にして、今は唯此文は典故を知らない人の作つたものであることを言つて置く。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上文體の考察を約言すれば、此文は文法も知らず典故も知らずして書いたもので、且つ全體の調子より察して比較的近頃の人の作と思はせられる。",
              "citation": {
                "source": "天津教古文書の批判",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "煩雑な典故を尚んだ、殿中では、天下の侯伯も、お坊主の指導に従わなければならない。",
              "citation": {
                "source": "煙管",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "日記には、単なる女房の後宮記録・執務覚え書きとしての外に、先例書・典故録と言つた側の職分から、知識宝典・詞藻類典の様な姿を採る物さへあつた。",
              "citation": {
                "source": "短歌本質成立の時代",
                "author": "万葉集以後の歌風の見わたし",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本に於ても、古代はこれと典故を同じうしたれば、歴代の天皇、皆直接に人民を呼ぶに『百姓』の語を以てし給ふ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "其詞なども典故ある古語を主とせずして、俗語を以て自由に表現するやうに變つた。",
              "citation": {
                "source": "概括的唐宋時代觀",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてサザンカを山茶花と書くべしという確かりした根拠典故は元来何んにもなく、これは実によい加減に充たものである。",
              "citation": {
                "source": "植物記",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その故は何かというに『鶉衣』の思想文章ほど複雑にして蘊蓄深く典故によるもの多きはない。",
              "citation": {
                "source": "雨瀟瀟",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて御馳走だが、その晩は、鱒のフライ、若生蕈と称ふる、焼麩に似たのを、てんこ盛の椀。",
              "citation": {
                "source": "十和田湖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｉが飯をつがうとすると、「うんと盛つてくれ、てんこ盛りによ、な」　仏家の出なるＩが器用に円く飯を盛り上げた茶碗を渡すと、勃凸はと見かう見しながら喜び勇んだ。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見ろ、てんこ盛り。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき良寛さんの長頭が、こてんこてんと左右にかたぶくので、うしろから見てゐる下男は可笑しくなつて、つい、ぷつ、と噴き出してしまつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりに数多い、あれもこれもの猟犬を、それは正に世界中のありとあらゆる種属の猟犬だったのかも知れない、その猟犬を引き連れて、意気揚々と狩猟に出たはよいが、わが家を数歩出るや、たちまち、その数百の猟犬は、てんでんばらばら、猟服美々しく着飾った若い主人は、みるみる困惑、と見るうちに、すってんころりん。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狂女心底より狂ならず、醒め来りて一夜｜悲悼に堪へず、児の血を濺ぎしところに行きて己れを殺さんとす、己れを殺す為に、その悲しき塲所に独り行くことを得ず、却つて路傍の人を連れ立てんことを請ふ、狂にして狂ならず、狂ならずして猶ほ狂なり、あわれや子を思ふ親の情の、狂乱の中に隠在すればなるらむ。",
              "citation": {
                "source": "鬼心非鬼心",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字を処理し、数字を処理するための道具であれば、できのいいマシンが秋葉原にはてんこ盛りになっている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "加藤のそれ、かれの心事、懐に剣をかくすを知らぬにあらねど、争はんはさすがにうしろめたく、さらばとてかれもまたかかる人とは思ひ捨てんこそ世にかしこかるべし。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "てめえたち、そんなことを言ふ口の下から、毎晩ててんこうばかししやがつて、この野郎。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "積った雪は堅く凍りついてともすればすってんころりんところばねばならぬ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "刑事は、すってんころりと転んだが、気丈夫な奴と見えて匐いながら、千切れた脚をつかんで頭の上にさしあげたと思うと、ぱったり倒れて動かなくなった。",
              "citation": {
                "source": "奇賊悲願",
                "author": "烏啼天駆シリーズ・３",
                "note": "青空文庫"
              }
            },
            {
              "text": "「幸なる哉、法華経のために身を捨てんことよ。",
              "citation": {
                "source": "学生と先哲",
                "author": "――予言僧日蓮――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おちついて下さい」　僕は、あやうく身体の平衡を失ってすってんころりんとするところを、タクマ少年が敏捷に腕をつかんで引揚げてくれたので、醜態をさらさないですんだ。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年に湖北按察使梁鼎芬が、聖人の郷たる曲阜に曲阜學堂を立てんことを請ふ疏にも、「日本講孔子之學。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきはどうして滑ったのかわからないが、こんどは滑らないようにと用心をして、ゆかの上を一足ふみだした――とたんにかれは、またすってんころりんと滑ってしまって、そのいきおいで、ゆかの上を氷のかたまりのように滑って走って、戸口から外へ……どすん！",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、また、すってんころりんと、ころんでしまった。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "とたんにつるり、すってんころりであった。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私自身もまた年少にして文筆の生活に入り、時流に耐える底力なく自棄の生活を送っているうちにすッてんころりんと落伍してしまい、ひどいひどい貧乏暮らしのありッたけをしてから、やっとこの頃多少でも自分の好きなものだけを書いて世間に問うことができてきたのである。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぼも　みんな　火元の上の　たなから　おっこちて、　缶の　入れ物も　せいりだなから　すってんころりん。",
              "citation": {
                "source": "きつねめさんのはなし",
                "author": "THE TALE OF MR. TOD",
                "note": "青空文庫"
              }
            },
            {
              "text": "ええっ――すってんころり。",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
