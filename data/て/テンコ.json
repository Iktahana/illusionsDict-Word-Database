[
  {
    "uuid": "19ebc107-2736-592e-81a8-e06fa5b8ce9f",
    "entry": "典故",
    "reading": {
      "primary": "てんこ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
