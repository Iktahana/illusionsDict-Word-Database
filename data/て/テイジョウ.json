    "definitions": [
      {
        "index": 1,
        "gloss": "giving",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は心から此貧しい贈物を我愛する田舍娘に呈上する！",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "成功すれば謝礼としてその半額を呈上します」　名探偵は快よくうなずいた。",
              "citation": {
                "source": "夫人探索",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙には矢張粟田爺さんの手らしく、『失禮ながら呈上仕候』　とある。",
              "citation": {
                "source": "樹木とその葉",
                "author": "青年僧と叡山の老爺",
                "note": "青空文庫"
              }
            },
            {
              "text": "場長や指導員、塾生、事務員、全部のひとに片端から辛辣な綽名を呈上するのも、すなわち、この助手さんたちのようである。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こないだの手紙に、ここの助手さんたちは、油断のならぬところがあって、男のひとたちに片端から辛辣の綽名を呈上していると言ったが、しかし、また塾生のほうだって負けずに、助手さんたち全部を綽名で呼んでいるのだから、まあ、アイコみたいなものだ。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙には矢張粟田爺さんの手らしく、「失礼ながら呈上仕候」　とある。",
              "citation": {
                "source": "青年僧と叡山の老爺",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "（口の中に黙読する、最後に至りて声を上げる）こんどの狂言われも心に懸り候ままかくは急飛脚をもって一筆呈上仕り候。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "公正なる発表を致しまして当選者には陳列の品物を一個｜宛呈上致します。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この文は印刷せられ次長以下各部長等に呈上せられた筈である。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、明治二十何年という時代、三宅花圃、田沢稲舟などという婦人が、短篇小説を当時の文芸倶楽部にのせた時、出版書店は御礼として半衿一かけずつを呈上したということである。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかというてまた広く類似の資料を収集し展並して諸君によき指示を呈上するというようなことも田舎にいてはできぬ芸当である。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何ぞ御贐に差上度候へ共有合不申、此鄙著二冊致呈上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "此度明後日出立に而河村大造立帰りに帰省致候由幸便を得候に付、不取敢此二冊呈上仕候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その事を、あとで、猫を作った某氏にその人が話して、君が逢えばきっと猫をつくらせられてしまうよといったらば、いや決して僕は魅惑されないといっていたのが、いつか銀の猫をつくって、呈上してしまって、そういったものへは内密にしていた。",
              "citation": {
                "source": "九条武子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途中の廊下に待っていて、僕たちは、おとなの諸君には、ビスケットの袋を、少年少女の諸君には、塩せんべいと餡パンとを、呈上した。",
              "citation": {
                "source": "水の三日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして他人の雅號を用ゐる事を云云しながら、余は今此書を匿名でもつて君に呈上するが、之は暫時許して呉れ玉へ、其中には屹度判る時が來るから、君も此書を手にしたからには何人が寄越したかと屹度疑念を抱くことだらう、何人であるか當てて見るのも一｜面面白いことだらうと思ふ。",
              "citation": {
                "source": "貝殼追放",
                "author": "愚者の鼻息",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、困りゃしませんか」「あの人形が動いているのを見た人があったら、わしは水牛の背に積めるだけの銀貨を呈上する」「本当ですな、それは……」「くどい男じゃ、早く調べてみたがよかろう」　帆村は頷いて、後をふりかえると、水牛仏に、じっと目を注いだ。",
              "citation": {
                "source": "鬼仏洞事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「懸賞」と赤インキで二重丸をうった見出しで、「ラジウムを発見したる者には、金五百円也を呈上するものなり」と、墨痕あざやかに認めてあった。",
              "citation": {
                "source": "柿色の紙風船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき彼は、みやげにカレーの粉を石油缶に五杯も持って帰り、同僚にも分け、もちろん大江山課長にも呈上した。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人を当てられた方へ、作者より敗北料を呈上致します。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　ザヴィエルは贈り物を山口の殿様に呈上することに極めましたが、前に将軍にあって懲りたことがありますから、今度は身なりに気をつけました。",
              "citation": {
                "source": "ヨーロッパ的性格　ニッポン的性格",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "此えり麁物ながら呈上（○蘭の絵ハ御苑ニアル分ヲ写させ申候）。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、あえて誇大な讃辞は呈上しないが、ここに問題としただけで、いずれも優れた書であるということを御承知ありたい。",
              "citation": {
                "source": "現代能書批評",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "大坪彦次郎てえのが相棒で、モウケたと云ってもそれほどの成金ではないが、こういうカセギをするにも、それ、山本定信の手を通し、進物を呈上しなくちゃア事が成らないてえワケだ。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十三　幻の塔",
                "note": "青空文庫"
              }
            },
            {
              "text": "承れば近頃御妻帯の由、何よりの吉報に接し候心地千秋万歳の寿をなさんがため一句呈上いたし候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて先般来当熊本人常松｜迂巷なる人当市『九州日々新聞』と申すに紫溟吟社の俳句を連日掲載するよう尽力致しなお東京諸先俳の俳句も時々掲載致度趣にて大兄へ向け一書呈上候処その後何らの御返事もなきよしにて小生より今一応願いくれるよう申来候。",
              "citation": {
                "source": "漱石氏と私",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "事變以來は支那駐在の皇軍慰問の爲めにも贈つた事もあり、本年は陸海軍の白衣の勇士達の若干の病院にも呈上した。",
              "citation": {
                "source": "隨筆　藪柑子",
                "author": "土井八枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の南画の第二の高弟黒須巳之吉博士に呈上する時などは、其処へ耳鼻手術用の道具を描く。",
              "citation": {
                "source": "南画三題",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "複本をつくって」「たぶんそうなさるだろうと思ったから、そのためにも、僕のつくったやつは潔く呈上しました。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朱泥は呈上｜可仕候唐墨の方は進呈｜致兼候間存分御試用の後御返送を願上候」というのである。",
              "citation": {
                "source": "南画を描く話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
