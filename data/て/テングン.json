    "definitions": [
      {
        "index": 1,
        "gloss": "heavenly hosts",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
