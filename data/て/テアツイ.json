[
  {
    "uuid": "5d3e1c76-56bf-5374-981c-d49e207cb7db",
    "entry": "手厚い",
    "reading": {
      "primary": "てあつい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
