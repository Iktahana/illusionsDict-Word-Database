[
  {
    "uuid": "8f160d2d-5a62-5026-a16a-2ea65bb67c41",
    "entry": "丁重",
    "reading": {
      "primary": "ていちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
