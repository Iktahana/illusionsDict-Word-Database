        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな中では私は、無鉄砲少女が好きなんです。",
              "citation": {
                "source": "生と歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで庄屋になった人が「カアチ／＼鉄砲打て」と命ずると、「カアチ（加八）」になった子が「何を打ちましょう」と聞く。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鴫突き」は鉄砲で打つのと比べれば実に原始的な方法のようであるが、また考え方によると一つのスポーツとしてはかなり興味の深いものではないかという気もする。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "駒込の富士から神田明神、深川八幡の境内、鉄砲洲の稲荷、目黒｜行人坂などが、その主なる場所であった、がそれも、今ではお伽噺になってしまった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから廻り縁になって、別の一室にも、槍、薙刀、鉄砲などが「なげし」にかけられて、山東京伝的｜草艸紙興味を味わせるのに十分であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲を持たせてる限り、軍人が人を殺して悪いと云ふ法はない。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄砲の音に驚いて立った海猫が、いつの間にかまた寄って来るのと本質的の区別はないのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやどんなに速い鉄砲玉でも追付かれぬくらいな速度で空間を飛んでいる。",
              "citation": {
                "source": "宇宙の二大星流",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俄に天井に白い泡がたつて、青びかりのまるでぎらぎらする鉄砲｜弾のやうなものが、いきなり飛込んで来ました。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鳥捕りは二十疋ばかり、袋に入れてしまふと、急に両手をあげて、兵隊が鉄砲弾にあたって、死ぬときのやうな形をしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると空中にざあっと雨のやうな音がして何かまっくらなものがいくかたまりもいくかたまりも鉄砲丸のやうに川の向ふの方へ飛んで行くのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジョバンニが斯う云ひながらふりかへって見ましたらそのいままでカムパネルラの座ってゐた席にもうカムパネルラの形は見えず〔〕ジョバンニはまるで鉄砲丸のやうに立ちあがりました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旗手が新らしい白い手袋をはめてそのあとから剣をつけた鉄砲を持って三人の級長がはいって来た。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは校旗を剣つきの鉄砲で護るわけがちゃんとわかったやうでもありまた宣言通り式場へ行ってからいきなり校旗を抛げ出して何か叫び出すつもりのやうでもありどうも見当がつかなかった。",
              "citation": {
                "source": "大礼服の例外的効果",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、一人の変に鼻の尖った、洋服を着てわらじをはいた人が、鉄砲でもない槍でもない、おかしな光る長いものを、せなかにしょって、手にはステッキみたいな鉄槌をもって、ぼくらの魚を、ぐちゃぐちゃ掻きまわしているのだ。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この効果の最も著しく感ぜられる場合は、たとえば茂みの中を鉄砲を持って前進する猟者を側面から映写しながら追跡する場合である。",
              "citation": {
                "source": "耳と目",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また射的をしている人の鉄砲の筒口の正面へ突然顔を出して危うく助かった事もあった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "図に乗った人間は網や鉄砲やあらゆる機械を工夫しては鳥獣魚虫の種を絶やそうとしている。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地ノ果テヲ行ク、参照スベシ×月十五日「儂の拳骨は鉄砲の弾丸だ　武士の情けだ」　モンモンの兵、鉢巻をするあり。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）「おい親友、鉄カブトかぶれよ、危ねえぞ」「何言ってやんでえ　可笑しくッて鉄カブトが冠れますかッてンだ」「鉄砲の弾丸は頭ばかり当たるッて訳のもんでもあるめえ、手に当る事もありゃ足にも当らア鉄のテッ甲脚絆でもはめてきアがれ」○帽子の中へ写真を入れて置く兵隊。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「非人に迄、身を落し　さだめて辛いであろう」　とハラハラと落涙して、Ｔ「其の方の至孝　天に通ぜぬ　道理が無い」　と乞食の手を掴んで、Ｔ「仇討本懐の日を　祈り申すぞ」　と老臣に金子を包ませて、　それを乞食に与え、Ｔ「些少乍ら　余の志じゃ」　乞食はまるで、鳩が豆鉄砲を喰った形。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "パルチザンと鉄砲で撃ち合いをやり、村を焼き、彼等を捕えて、白衛軍に引渡す、そういうことにあきてしまった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなに、さわったらころびそうな連中を引っぱり出して鉄砲をかつがせるって法があるかい！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は殺気立ち、無鉄砲になり、無い力まで出して、自分達に勝味が出来ると、相手をやっつけてしまわねばおかない。",
              "citation": {
                "source": "戦争について",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その時には、丘にも谷間にも豚群が呻き騒いで、剛い鼻さきで土を掘りかえしたり、無鉄砲に馳せまわったりしていた。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々列車からおりて、鉄砲で打ち合いをやった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば「鉄砲の遠音に曇る卯月かな」というのがある。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ鉄砲でもアメリカトーキーのピストルの音とは少しわけがちがう。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊が二、三人鉄砲を持ってはいって来た。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ植えるのはすずめのかたびらじゃない、すずめのてっぽうだよ。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
