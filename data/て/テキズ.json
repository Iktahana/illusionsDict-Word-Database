    "definitions": [
      {
        "index": 1,
        "gloss": "wound (suffered in a fight)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
