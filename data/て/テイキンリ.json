        "examples": {
          "standard": [
            {
              "text": "低金利が続き、住宅ローンの借り換えを検討する人が増えている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "銀行は低金利で企業の設備投資を促している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この低金利時代に、どのように資産を運用すべきか悩んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "そして貧農民は他ならぬこの農村低金利資金のおかげで、×××××られたり××××になったりしているのである。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村高利貸しのために低金利の融通を円滑にしてやるのもいいだろう。",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "予算は、軍事費が七、内政費が三の比率で、ヴェトナム戦争での出費がさらに大きく食いこみ、ケネディが提案した減税とか低金利は、たちまちのうちに、高い金利と一〇パーセントの増税となってしまった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
