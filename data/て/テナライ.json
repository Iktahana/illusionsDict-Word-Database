    "definitions": [
      {
        "index": 1,
        "gloss": "practice writing with a brush",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
