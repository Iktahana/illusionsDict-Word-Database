  {
    "uuid": "cd2e4ab8-4ddd-578d-9981-7e872b565dbf",
    "entry": "転校",
    "reading": {
      "primary": "てんこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "changing schools",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "京都立命館中学に転校す。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　さうした、所詮世上のニヒリストには最も馬鹿気たと見えるだらう生活を――私自身もこだはつた生活だと今では思つてゐる――してゐた私は、今態々落第して、それをキツカケに京都の某中学に転校してゐて、「その頃の生活」の環境といふものと離れてゐる。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "落第や其の他の事情で土地の学校を出て他所に転校を余儀なくされた彼は、わざわざ、もう暑中休暇も終るといへば、また立つて行くのだ。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "その五年の二学期に私が内地から龍山の小学校へ転校して行ったのだ。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍山の小学校へ転校してから二三日｜経ったある日、その日も読方の時間に、「児島高徳」のところで、桜の木に書きつけた詩の文句を私が読み始めると、皆がどっと笑い出してしまった。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら彼は、常々、恋人さへ出来れば何んな犠牲も厭はない、それに自分の家の者は、新時代の教養に目醒めてゐて、このボンクラ学校の変態教育法などに就いては不満を抱いてゐるし、寧ろ転校の意志を持つてゐる位である……。",
              "citation": {
                "source": "塚越の話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "舎監は、「彼のご両親は転校させるとおっしゃっている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「被害者であるじぶんの子どもが転校して、加害者がそのままなのは、納得できない、そうおっしゃっている」　ヤバい。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえが親父に泣きついて、転校させてもらうのはかまわない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっき東屋で、いなくなるって……」「うん、令子は転校するっていってる」　ほかに解釈のしようがなくて、たぶん、そういうことなのだろうと推測していたが、それでも、改めて確認されるてみると、逆に信じられなくなった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしとしては、転校しますといわれて、はい、そうですか、では、ごきげんようというわけにはいかない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしが心配したのは、このまま中学に入っても、母の都合で転校させられるんじゃないかって……まえにも、おなじことがあったんです。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかしいですよね」「でも、なんでそんな……」「それは、わたしが転校することにしたって話したからだと思います。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "転校試験の結果二年級を飛び越えて、彼は三年生に進んだ。",
              "citation": {
                "source": "淡雪",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "校長が師範学校から出た当座、まだ今の細君ができない時分、川越でひどい酌婦にかかって、それがばれそうになって転校した話や、ついこの間までいた師範出の教員が小川屋の娘に気があって、毎晩張りに行った話などをして聞かせたのもやはり、この老訓導であった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "侃はその春、そこの中学校に転校すると、奇妙に友達と云ふものを持ち損ねた。",
              "citation": {
                "source": "背後",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "欧州大戦前のドイツで中学校に入学するものは右翼または有産者即ち支配階級の子供であり、小学校卒業者は中学校に転校の制度はなかったのである。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "松枝は横浜のどんな学校にいるのか知らぬが、東京の相応の学校に転校したらよかろう。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "松枝は三月まで今の学校にいて、四月には東京の何処かに転校して、そしていろいろ足下の手伝いをさせたい。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "治国平天下の青雲の志があって、四高へ入っていたが、老父がどうにもならないと言うので、泣いて長崎の医専に転校した。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "味方のチームでは浅賀という関東の私立中学から転校して来た生徒がピッチャーで派手なユニフォームを著けていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長節を控へ舎を挙げて祝賀会の余興の支度を急いでゐる時分、私と小学校時代同級であつた村の駐在巡査の息子が、現在は父親が署長を勤めてゐる要塞地の町の中学から転校して寄宿舎に入つて来た。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうした私の悪意を極めた陰口と見え透いたお世辞とによつて彼は転校者として肩身の狭い思ひから巧に舎内の獰猛組に親交を求め、速に己が位置を築くことに汲々としてゐた。",
              "citation": {
                "source": "途上",
                "author": "嘉村礒多",
                "note": "青空文庫"
              }
            },
            {
              "text": "高校に入ってからも、長崎北高校から小倉西高校への編入を体験した藤井だったが、目まぐるしい転校体験はむしろ、彼の心に腰の据わったしなりを育んでくれた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は私を、もっと費用のかからぬ学校に転校させたかった。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "啓吉の学年は三級もあって、転校者の多い級だけ男女混合であった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな弟や妹はとにかく、菊子さんが、あちらの女学校の五年に転校できるかどうか、それが問題になりました。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の女学校では、五年生の転校は殆んど受付けないのです。",
              "citation": {
                "source": "白い朝",
                "author": "――「正夫の童話」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "用器画の先生に会ふのが辛くて、転校したかつたが、僕を入れてくれる中学はもう東京にはないので、あきらめて新学期に出てみたら、先生の方が学校をやめてゐた。",
              "citation": {
                "source": "剣術の極意を語る",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして清は、近くの雪見中学校へ転校入学したのだった。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
