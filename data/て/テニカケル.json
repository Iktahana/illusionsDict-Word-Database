    "definitions": [
      {
        "index": 1,
        "gloss": "to take care of",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「どうせ犬殺しの手にかけるなら自分でやっちまった方がいいと思って……」　太十は口をしがめた。",
              "citation": {
                "source": "太十と其犬",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、母が身に付けたものを、他人の手にかけるのは、厭だった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなこっぱ事件、おれが手にかけるがほどのものはねえと思っていたんだが、質屋のおやじのせりふが気に食わねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "青眉の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし仮にも武士たるものが、歌舞伎役者の上手下手をあらそって、町人の相手をふたりまでも手にかけるとは、まことに類の少い出来事で、いくら仇討の芝居を見たからと云って、とんだ仇討をしてしまったものです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、母が身に付けたものを、他人の手にかけるのは、厭だつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お月見にといってあなたを誘い出して、こんな山奥へ連れて来たのは、今年はあなたがもう七十になって、いつ島流しにされるか分からないので、せめて無慈悲な役人の手にかけるよりはと思ったからです。",
              "citation": {
                "source": "姨捨山",
                "author": "楠山正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドンナ難事件でも一旦彼奴の手にかけるとなると、キットどこからか犯人をヒネリ出して来る。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが四尺近くもあろうかと思われる長い髪を色々な日本髪に結うのじゃそうなが、髪結いの手にかけると髪毛が余って手古摺るのでヤハリ自分で結うらしい」「してみると入浴の一時間は長くないですな。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせなら汚ならしい婆さんの手にかけるよりも、別嬪さんの方がいゝからねえ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家政婦の小林と芝山は、その頃は小林の部屋でしっぽりよろしくやっていたので、主人を手にかけるどころじゃなかった。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それにこの女のいうとおり、人形――雛などというような品物は、男手にかけるより女手にかけて、優しくあつかった方がいいらしい）「梶子殿、これはもっとも」　と、とうとう姉小路卿はそう云った。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "団子屋を飛び出してから間もなく、道庵先生が、「あ、敦盛を手にかけるのを忘れた」　これはこの土地に、梅本という蕎麦の名物があったのを、つい忘れて立寄らなかった洒落でしょう。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは長い紐の一端に、はげしく引張れば解けて来る結び方の輪を一つ作っておき、この輪をボルトの把手にかける。",
              "citation": {
                "source": "Ｊ・Ｄ・カーの密室犯罪の研究",
                "author": "井上良夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄上は心のよからぬ者は男も女も三位一体だとしきりに三の数にこだわっていらッしゃるようですが、私が妙にハッキリと覚えていることは、ロッテナム美人館の扉ボーイの黒ん坊が扉の把手にかける左手の指が、三本指しかなかったことです。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十四　ロッテナム美人術",
                "note": "青空文庫"
              }
            },
            {
              "text": "イプセンなどと相前後して、韻律をふまない、勝手にかけるドラマを書いたのであった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして自分の兄を手にかけるなんて、聞いても恐ろしい――」　民五郎はあまりの事に転倒して、縛られたまま身を揉みますが、縄尻を押えたお神楽の清吉は、グイグイと引いて大地に押付けております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰にも満足の行くようなもののさばき方は、普通には出来ないこととされているが、それすら、苦労人の手にかけると、案外すらすらとさばかれて行くものである。",
              "citation": {
                "source": "青年の思索のために",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――僕は然し、洞穴の入口で黄色い粉を拾った時、それが夜光剤だと知って大体の見当がついたんだ」「でもよく母さん殺されなかったわね」「如何に悪人でも、義理の姉を手にかける事は出来ないさ、あの洞穴の中で飢死させてから、底無し沼へ沈める積だったのだろう。",
              "citation": {
                "source": "殺生谷の鬼火",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、お君は、絵姿だと思って、「ほんとに、お生写し……どうしてこんなに上手にかけるものでございましょう」と我を忘れて驚嘆したのであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "如法闇夜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし奥向を働くようになって、ムクと離れる機会が多くなると、ムクの世話を人手にかけるのが気にかかる。",
              "citation": {
                "source": "大菩薩峠",
                "author": "伯耆の安綱の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "具足の小貫、装剣の飾り、馬具の小金物、何くれとなく飾金の職人の手にかける金銀の細工物はここでやっている。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "標札、即ちある家の住人の名前は、木片に書き、入口の横手にかける（図338）。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして自分の兄を手にかけるなんて、聞いても恐ろしい――」　民五郎はあまりの事に轉倒して、縛られたまゝ身を揉みますが、繩尻を押へたお神樂の清吉は、グイグイと引いて大地に押付けて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "血潮と糠",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の手にかける手錠を自分で磨くのだからこれ以上の皮肉はない。",
              "citation": {
                "source": "私の履歴書",
                "author": "浅沼稲次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むろん自分で手にかけるつもりはなかった。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "真実の父でないとはいえ、育ての父を手にかけるという極悪非道の罪を犯したのです。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう研師の手にかけるのは心もとない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "――木剣でいたしても、真剣でいたしても、拙者の試合は同じことですから」「それを止めるのではないぞえ」「お分りならばよいが、剣は絶対だ……手にかける以上、五分までの、七分までの、そんな仮借があるものではない。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
