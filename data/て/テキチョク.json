    "definitions": [
      {
        "index": 1,
        "gloss": "hesitation",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "後年郷里に住むやうになつてから、その模型は庭の躑躅の蔭の平たい石の上に置かれてゐた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで私も庭の方を向いて眺めるともなしに躑躅の根本の所を眺めた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がまだ六つの頃、広島にゐた時、下女に連れられて買ひ物に出ようとすると庭の出口の躑躅の下から蛇が出て来た事を思ひ出した。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭石の根締めになっていたやしおの躑躅が石を運び去られたあとの穴の側に半面、黝く枯れて火のあおりのあとを残しながら、半面に白い花をつけている。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年はこの翡翠の色をした薔薇の虫と同種と思われるものが躑躅にまでも蔓延した。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山躑躅こはやまつつじ丘丘の、　　栗また楢にまじはりて、　　熱き日ざしに咲きほこる。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "路の右左、躑躅の花の紅なるが、見渡す方、見返る方、いまを盛なりき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見返ればハヤたらたらさがりに、その肩躑躅の花にかくれて、髪結いたる天窓のみ、やがて山蔭に見えずなりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "山土のいろもあかく見えたる、あまりうつくしさに恐しくなりて、家路に帰らむと思う時、わが居たる一株の躑躅のなかより、羽音たかく、虫のつと立ちて頬を掠めしが、かなたに飛びて、およそ五六尺隔てたる処に礫のありたるそのわきにとどまりぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しく走りつきて石をあわせ、ひたと打ひしぎて蹴飛ばしたる、石は躑躅のなかをくぐりて小砂利をさそい、ばらばらと谷深くおちゆく音しき。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "見渡せば、見まわせば、赤土の道幅せまく、うねりうねり果しなきに、両側つづきの躑躅の花、遠き方は前後を塞ぎて、日かげあかく咲込めたる空のいろの真蒼き下に、彳むはわれのみなり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "立あがりてゆくてを見れば、左右より小枝を組みてあわいも透かで躑躅咲きたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一文字にかけのぼりて、と見ればおなじ躑躅のだらだらおりなり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣きながらひたばしりに走りたれど、なお家ある処に至らず、坂も躑躅も少しもさきに異らずして、日の傾くぞ心細き。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆう日あざやかにぱっと茜さして、眼もあやに躑躅の花、ただ紅の雪の降積めるかと疑わる。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後には躑躅の花飛び飛びに咲きて、青き草まばらに、やがて堂のうらに達せし時は一株も花のあかきはなくて、たそがれの色、境内の手洗水のあたりを籠めたり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "躑躅花　つゝじは品多し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "花紅にして単弁なるもの、珍しからねど真の躑躅花のおもむきありと思はる。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "光琳の躑躅などは、セザンヌ、モネー、ゴーギャン、誰の画よりも、すぐれていると思われました。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「躑躅でござります。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……玄關口で、躑躅の鉢植に吃驚するやうでは――此の柄だから通しはしまいが――上壇の室で、金屏風で、牡丹と成ると、目をまはすに相違ない。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "躑躅――驚くな――山吹などを輕くあしらつた、此の角座敷。",
              "citation": {
                "source": "飯坂ゆき",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月五日｜躑躅の花盛んなりし。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩を転じてかしこなる躑躅の丘に上らんとて、池に添いつつ歩めるとき、かなたより来たりたる、一群れの観客あり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「むむ」　かくて丘に上りて躑躅を見たり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "躑躅は美なりしなり。",
              "citation": {
                "source": "外科室",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絶壁の躑躅と見たは、崩れた壁に、ずたずたの襁褓のみ、猿曵が猿に着せるのであろう。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "五月になると、大久保名物の躑躅の色がここら一円を俄に明るくした。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "躑躅園は一軒も残っていないが、今もその名所のなごりを留めて、少しでも庭のあるところに躑躅の花を見ないことはない。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            }
          ]
        }
