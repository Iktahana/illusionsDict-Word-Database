[
  {
    "uuid": "1ac908be-f671-5c9d-969f-d9944773a3f2",
    "entry": "天花",
    "reading": {
      "primary": "てんげ",
      "alternatives": [
        "てんけ"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flowers that bloom in the heavens",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "シャンパンのキルクがボーイの鉤鼻から落下すると私のパートナアが横目をつかってボーイに現金で酒代とチップを渡すように催促して別に靴先につける天花粉の代金十｜仙を請求する。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち諸神に示し、今此矢を返し下さんに、若し天花日子命を違えず惡神を射し矢の來つるならば此矢彼れに中らじ。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "）ところどころに蝋質の白い天花粉などくつつけて、まるで赤ん坊みたいぢやないか。",
              "citation": {
                "source": "独楽園",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがてタオルで拭かれた子供の赭い体には、まだらに天花粉がまぶされた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「天花――天勝の娘じゃそうな」　すみ子が教えた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はい」　と天花は笑いながら私の方を見て、ひよいと頭を下げて、「お客さまのおのぞみは六時二十三分でございます。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は天花に心をとられて、すみ子のことを忘れていた。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に帰ってからも天花のことが胸に残った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "がその後三十年の今日まで、私はいく度もそのかみの天花を思い出したが、とうとう一度も彼女を見た事はない……。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "心臓の血が一時に頭に向かって逆流した時、私は片隅にあった天花粉の箱を覆してしまった。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "天花粉の山積みせるところに私が蒼ざめて立っていたのだ。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "食用又は藥用にするのは其果實で、根の澱粉は所謂天花粉である（郷土一卷四號）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "食用または薬用にするのはその果実で、根の澱粉はいわゆる天花粉である（郷土一巻四号）。",
              "citation": {
                "source": "食料名彙",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それどころじゃねえ」　久助が出て行ったので、彼女は夕化粧をし、お燕の額にも、天花粉をたたいてやっていた。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
