    "definitions": [
      {
        "index": 1,
        "gloss": "transferring from one college (or one department) to another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分よりはずっと前にドイツへ来ていて他の大学からベルリンへ転学して来たそうで言葉なども自由らしかった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは、ちょうど私がマールブルクへ行った学期に、ハイデッゲル教授はフライブルクからマールブルクへ招聘されたので、私は主として氏に就いて学ぶためにハイデルベルクから転学したのであった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "独逸の大学で学生に転学の自由が与へられてゐるのはそのひとつです。",
              "citation": {
                "source": "消息一通",
                "author": "一九二四年一月一日　マールブルク",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は志を抱いて維也納からミユンヘンに転学した当時は、部屋を得るに困難なこと如是であつた。",
              "citation": {
                "source": "南京虫日記",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少年の頃、東京へ転学した。",
              "citation": {
                "source": "わが童心",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "転学後間もなく我らは講堂に召集されて吉村校長からデグニチーという事を繰り返して説法された。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂本四方太、大谷繞石の二君はやはり京都よりの転学組に属する。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "松島から帰った日、今の工科大学教授加茂正雄君、昨年露国｜駐剳大使館一等書記官として亡くなった小田徳五郎君らの周旋の下に京都転学組一同は余ら二人の送別茶話会を開いてくれた。",
              "citation": {
                "source": "子規居士と余",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上宗助はある事情のために、一年の時京都へ転学したから、朝夕いっしょに生活していたのは、小六の十二三の時までである。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "文部省や大学当局がそういう勝手なことをする以上、当然学生も転学の自由位い与えられるべきだと思うのだが。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "正三君は家へ帰って転学の手つづきをすませた。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同時に御失明の虞有之候間｜片時も早う眼科へ転学｜可然』とありました。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
