        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "視聴率が低迷しているバラエティ番組に、新レギュラーを投入してテコ入れを図る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経営難の地方鉄道を存続させるため、国による財政的なテコ入れが行われた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "売り上げが伸び悩む既存商品に、パッケージデザインを一新するテコ入れを施した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "雨は漏るし風は入るし、柱はかたむき廂は破れ、形容｜枯槁して喪家の狗の如く、ここらで金をかけて根本的にテコ入れしなきゃ、大変なことになりそうなのですが、そこはそれ誰の持ち家か判然しないものですから、誰も手出しをせず、ついそのままになっているのです。",
              "citation": {
                "source": "ボロ家の春秋",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "manipulation (of the market, esp. to prevent a sudden fall)",
        "register": "standard",
