[
  {
    "uuid": "87a735e5-5924-5e06-b7ae-d54a1ea40c84",
    "entry": "蹄叉",
    "reading": {
      "primary": "ていさ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
