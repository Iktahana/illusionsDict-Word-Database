[
  {
    "uuid": "78be4daf-fbcf-5b45-a47d-bde64ae9300e",
    "entry": "展望",
    "reading": {
      "primary": "てんぼう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "view",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高原地方のアトモスフィアを、これほど鮮明に、印象強く、しかもパノラマ的展望で書いた俳句は外にない。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人工的方面や、温泉場としての気分の好いことは勿論だが、自然の展望から言つても、箱根の感じは別である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山を中心にして、周囲の展望は変化する、大空へ掛けた額面として、横から見たり、裏返しに見られる山だ。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "母体の山脈は、あとに退き、うすれ日に透け、またはむれ雲の間から薔薇色に山襞を刻んで展望図の背景を護っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこはのびのびとしていて展望も利いた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり突如として入った別天地に私は草臥れるのも忘れて、ただ、せっせと主人について歩いて行くうちどのくらいたったか、ここが峠だという展望のある平地へ出て、家が二三軒ある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見晴らす広漠とした河原に石と砂との無限の展望。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後裔の一人であったマルクスには、「経済」という唯一の見地よりしか人間の世界を展望することが出来なかった。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄骨ペンキ塗りの展望塔がすっかり板に付いて見える。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな樹木のないお蔭で展望の自由が妨げられないのがこの道路の一つの特徴であろう。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "理学者以外の世人にとっては、地震現象の心像はすべて自己の感覚を中心として見た展望図に過ぎない。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方では連句的レビューの可能性が示唆され、他方ではまたアメリカン・レビュー的連句の開拓も展望される。",
              "citation": {
                "source": "マーカス・ショーとレビュー式教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを過ぎると道は切り立った崖を曲がって、突如ひろびろとした展望のなかへ出る。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "道は小暗い谿襞を廻って、どこまで行っても展望がひらけなかった。",
              "citation": {
                "source": "冬の蠅",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "展望の北隅を支えている樫の並樹は、ある日は、その鋼鉄のような弾性で撓ない踊りながら、風を揺りおろして来た。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あああ大きな落日が見たい」　彼は家を出て遠い展望のきく場所を捜した。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道は展望を持っていたがそんな道の性質として気が散り易かった。",
              "citation": {
                "source": "筧の話",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はそのせせこましい展望を逃れて郊外へ移った。",
              "citation": {
                "source": "過古",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんの拘りもしらないようなその老人に対する好意が頬に刻まれたまま、峻はまた先ほどの静かな展望のなかへ吸い込まれていった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つの窓は樹木とそして崖とに近く、一つの窓は奥狸穴などの低地をへだてて飯倉の電車道に臨む展望です。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その展望のなかには旧徳川邸の椎の老樹があります。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに屋上さらに三四百尺の鉄塔を建てて頂上に展望台を作るといいと思う。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上七十余尺の頂上まで上ってしばらく四方を展望していると思うと、突然石でも落とすようにダイヴするが途中から急に横にそれて、直角双曲線を空中に描きながらどこかの庭木へ飛んで行く。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただこういう仮設的な比較によって、連句におけるいろいろな個性の対立ということがいかに重要なものであるかを理解するための一つの展望的見地を得ようとするに過ぎないのである。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前の展望は段々狹まつて、行手の右側には街道と並行に山の裾が逼り出した。",
              "citation": {
                "source": "幻想",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで折角楽しみにした噴火口の展望も探り見ることが出来なくなった。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その時の大火傷、享年六十有七歳にして、生まれもつかぬ不具もの――渾名を、てんぼう蟹の宰八と云う、秋谷在の名物｜親仁。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺どのは、どっこいしょ、と横木に肩を入れ直いて、てんぼうの片手押しは、胸が力でござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『読売新聞』に、この一月座談会記事が連載されていた間の或る日「てんぼうだい」に一読者よりとしての投書でのせられていた。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんぼうが一人だけ残っている。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
