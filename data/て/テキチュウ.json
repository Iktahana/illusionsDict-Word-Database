[
  {
    "uuid": "c2f52875-c0af-5a06-bc10-a0ef3dd29497",
    "entry": "的中",
    "reading": {
      "primary": "てきちゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
