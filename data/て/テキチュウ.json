      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hitting the target",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その後子規の所で出会ってその直感の的中していたことを知ったのである。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんのこの判定は、だいたいに於いて的中してゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばまた過飽和の状態にある溶液より結晶が析出する場合のごとき、これがいつ結晶を始め、また結晶の心核が如何に分布さるべきかを精密に予報せんとする時、単に温度従って過飽和度を知るのみにては的中の見込は極めて小なるべし。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在の気象観測制度をもってすれば各気象区域における大体の天気の推移を予知する事は十分可能にして、観測の範囲の拡張につれて的中の公算を増すべしと考えらる。",
              "citation": {
                "source": "自然現象の予報",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで重力の秘密は自明的に解釈されると同時に古い力学の暗礁であった水星運動の不思議は無理なしに説明され、光と重力の関係に対する驚くべき予言は的中した。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、銃を掌の上にのせるとすぐ発射することになれていた――それで十分的中していた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウィーゼ氏の話によると数年来かの国の気象学者たちは、気圧その他の気象学的要素の配置から夏期における北氷洋上の氷の分布状況を予報することを研究し、それがだいぶうまく的中するようになった。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不思議の的中は、みんなのうちで、私をいちばん興奮させた。",
              "citation": {
                "source": "逆行",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その番号から運転手の名前を探り出して、鼻薬を使いながら未亡人の行先を尋ねてみると、私の着眼が一々的中している事が裏書きされて来た。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "イヤ其樣な無※な事もあるまいが、子ープルスの埠頭で、亞尼が泣いて語つた事は、不思議にも的中した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　的中星を指されて、自分は忸怩しながら、默ツて垂頭いてゐた。",
              "citation": {
                "source": "水郷",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "その予感を後から配達して来る夕刊の相場面と照し合わせて見ると一々的中しているので、面白くてしようがなかった。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "的中していないのはＦ市の新聞社の誤植である事を翌る日の正午に来る大阪の新聞で発見した事も珍らしくない。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこの疑惑は無残にも的中していた。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこの疑惑は無殘にも的中してゐた。",
              "citation": {
                "source": "列車",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "惣助の懸念はそろそろと的中しはじめた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "的中の気配を、かすかにその身に感覚する時のよろこびを歌っているのだそうだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の疑惑が、まんまと的中していたのだ。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうしてそれが必ず美事に的中してゐるのでございますから、どうしてもあのお方は、私たちとはまるで根元から違ふお生れつきだつたのだと信じないわけには参りませぬ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治四十年比、独り判断の出来るハート形の軽い板へ、三つ足の後の二本へ陶製の円い物を附け、前足は鉛筆で、いろいろな問を筆答する仕組の物が現われたが、この比もまたその流行を見るのは、的中率の高いのと、意識的な易断トランプに優るところがあるためであろう。",
              "citation": {
                "source": "狐狗狸の話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "的中らずば許し給へかし。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この点でもやはり龍代の見込みが百パーセントに的中していたのかも知れませんが、元来、風来坊の川流れであった私が、それから後というものは、龍代にも負けないくらい性格の一変ぶりを見せましたもので、どこで得た知識かわかりませんが、自分でも驚くほどの才能を発揮し初めたものです。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがそこまではＡの着眼が百二十パーセントに的中していたのですから、先ず先ず大成功と云ってもよかったのですが、それから先がどうもイケませんでした。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲しい事には、宗矩の言一々的中したのであった。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「後頭部の中央に正確に的中り、脳を貫通しているよ。",
              "citation": {
                "source": "空家の冒険",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "今思ふと怪しくも此の予言は的中した。",
              "citation": {
                "source": "悪魔の舌",
                "author": "村山槐多",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのあいだ一般の精神機能、ことに記憶が、絶対的中絶の状態にあった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
