    "definitions": [
      {
        "index": 1,
        "gloss": "(Roman) Catholicism",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
