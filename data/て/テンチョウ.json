  {
    "uuid": "2f2f72c3-b5bd-5998-863a-95a197ad9219",
    "entry": "天長",
    "reading": {
      "primary": "てんちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Tenchō era (824.1.5-834.1.3)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "また私の郷里では昔天長節の日に市の公園で「お化け」と称する仮装行列が行われた。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "また今年も天長節には大雪だろうね。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　八月の三十一日は二度目の天長節だが、初めての時は諒闇でお祝ひをしなかつたからと云つて、鶴吉は一日店を休んだ。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長節の佳日に際し　　子爵　　伊東海軍大將　　　　　　肝付海軍少將　　伯爵　　吉井海軍少佐　　子爵　　小笠原海軍少佐　　　　　　上村海軍少佐各位の清福を賀※、つたなき本書のために、題字及び序文を賜はりし高意にむかつて、誠實なる感謝の意を表す。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あすは天長節である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きょうは天長節である。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの説に依ると、昔から、天長節は必ずこんなに天気がいい事にきまっているのだそうである。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生、石井君は、昨日式場へ来ておりました」「嘘です、死んだなんて嘘です」「そんな事はありません、確かに歿くなりました」「否え、嘘です、昨日、天長節に来ておりました」　そこでＳ君も不思議に思って詳しく訊いてみた。",
              "citation": {
                "source": "天長節の式場",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでＳ君は、石井の死亡した事情を談したので、生徒たちは初めて石井の死を知り、天長節に見たのはその陰影であったと云う事を知った。",
              "citation": {
                "source": "天長節の式場",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その京都の地震で天長四年七月に起った地震は、余震が翌年まで続いた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天平神護二年六月には、大隅国神造新島、弘仁九年七月には、相模、武蔵、下総、常陸、上野、下野の諸国、天長七年一月には、出羽に地震があった。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月天長節日曜と続いたを幸いに矢野は、中島木島らと、日光の紅葉狩りに行った。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長節の式場で佐治君は演説した。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長元年旱災の際、弘法大師天竺無熱池の善如竜王をこの池に勧請して、三日間あまねく天下に雨ふる。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれたちには天長節も何もあったもんじゃない」　そういわれてみると葉子はきょうが天長節なのを思い出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天長節であるだけにきょうはことさらそれがにぎやかなのかもしれない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに急いで越すのか」と三四郎が聞くと、「急ぐって先月中に越すはずのところをあさっての天長節まで待たしたんだから、どうしたってあしたじゅうに捜さなければならない。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は約束だから、天長節にもかかわらず、例刻に起きて、学校へ行くつもりで西片町十番地へはいって、への三号を調べてみると、妙に細い通りの中ほどにある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち高等学校で天長節の式の始まるベルが鳴りだした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ広田先生がフロックコートで天長節の式から帰ってきた、三人は挨拶をする時に画帖を伏せてしまった。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "移転以来、花を生けて眺めるという気分にもなれず、花を生けるような物も具えていないので、さきごろの天長祝日に町内の青年団から避難者に対して戸毎に菊の花を分配してくれた時にも、その厚意を感謝しながらも、花束のままで庭の土に挿し込んで置くに過ぎなかった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十三　天長節には学校で式があった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "荻生さんが天長節の午後から来て、半日かかってせっせとはって行ったという。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "移転以来、花を生けて眺めるという気分にもなれず、花を生けるような物も具えていないので、先ごろの天長祝日に町内の青年団から避難者に対して戸ごとに菊の花を分配してくれた時にも、その厚意を感謝しながらも、花束のままで庭の土に挿し込んでおくに過ぎなかった。",
              "citation": {
                "source": "十番雑記",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンチェンコ氏は田舎の停車場で子供に調戯れたのだが、此の頃のノーウォエ、ウレーミヤを見ると、去年の天長節に東京の真中で、しかも大学生に異人馬鹿といはれた露西亜人がある。",
              "citation": {
                "source": "露都雑記",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天長節あたりはどうだらう？",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "畏れ多いが、先づ我天皇陛下から申し上げると、陛下の御誕生が一八七九年で、御即位が一九一二年、御治世が五箇年で、今年の天長節で第三十八回の御誕辰を迎へさせられた。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和十五年天長の佳辰に発せられた総軍司令部の「派遣軍将兵に告ぐ」には、事変の解決のため満州建国の精神を想起せしめ、道義東亜連盟の結成に在る事を強調せられた。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本晴、天長節、万歳万々歳。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
