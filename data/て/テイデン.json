    },
    "definitions": [
      {
        "index": 1,
        "gloss": "power outage",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてもっと甚だしい、もっと永続きのする断水や停電の可能性がいつでも目前にある事は考えない。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その風車は直径三十五フィートでこれを五十フィートの櫓の上に据え付け、十六燭の電灯二百個を点ずる外に、なお五馬力のモートル三個を運転しているが、未だかつて停電などを起さぬという事である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この感情を思い浮かべるためには、われわれが都会で経験する停電を思い出してみればいい。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停電して部屋が真暗になってしまうと、われわれは最初なんともいえない不快な気持になる。",
              "citation": {
                "source": "闇の絵巻",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつてもいゝ……」　停電した。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し停電をきつかけに私達の話題は角度をかへてゐた。",
              "citation": {
                "source": "骨",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その晩は急に大雨となり、風もひどく、飲んでる最中二度ばかりも停電した。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな女中と、小さい女中が、「暫らく停電いたすそうですから……」　といいながら、大｜蝋燭の燭台と、ゆうげの膳を運んで来た。",
              "citation": {
                "source": "呼ばれし乙女",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のテーブルの上の電気スタンドの場合にしますと、もしスタンドに、停電かなんかで、因の電気が来ていなければ、私がいくら骨折って縁にスイッチを捻りましても灯が点るという結果が出て来ません。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいにくとまた停電で、蝋燭のあかりを借りつゝ、燈と共に手がふるふ。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何、黒山の中の赤帽で、そこに腕組をしつつ、うしろ向きに凭掛っていたが、宗吉が顔を出したのを、茶色のちょんぼり髯を生した小白い横顔で、じろりと撓めると、「上りは停電……下りは故障です。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "よしんば雨のための停電にせよ、まるでわざとのような停電のような気がした。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと家並みは続いていたが、停電のせいだろう、門燈は消えて、洩れて来る一筋の灯りもなく、真っ暗闇だった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "深夜、停電している家へ、そんな娘を連れて行って、泊めてくれとは、さすがに云えなかった。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺は停電ではなかったらしい。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（スタンド消える）妹　　あら、停電よ。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "（スイツチをひねつて見る）妹　　停電だわ。",
              "citation": {
                "source": "ラムプの夜",
                "author": "――学芸会のための一幕劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもそれは、あらしの夜、ふたりの姉妹が勉強をしていると、ふいに停電してしまうので、古いランプを持ち出してきてともすのだそうである。",
              "citation": {
                "source": "嘘",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　スズメが部屋から出て行ったとたんに、停電。",
              "citation": {
                "source": "犯人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四つも五つも電話が鳴りはためいている中でも平気で辷っていたペンが、蠅の羽音を聞いても停電するようになりました。",
              "citation": {
                "source": "スランプ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　第一相互館の屋上で夜の銀座をながめていたら、突然停電で屋上はまっ闇になり、同時に銀座の両側の街燈も消えたが、街壁を飾るネオンサインはみんな平気でともっていた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停電｜暫時で行燈を点けるという、いや、酷い混雑。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電車が二度ほども長い停電をしたりして、沼田町に着いたのは七時半であつた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その電車が二度ほども長い停電をしたりして、沼田町に着いたのは七時半であった。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京に来てから二週間ばかりの間に、停電と架線修繕のための停車を各二度と見たが、僅かの間に数町の間電車の行列が出来た。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁日に出ている停電用の燭台や電球蔽い、書翰箋やインキ壺まで文化と名づけてある。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　その翌晩、長い時間にわたって、停電があった。",
              "citation": {
                "source": "ラ氏の笛",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "停電に備えるガソリン・エンジンがすぐ側に据えつけられている。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「周波数はちゃんと合っているのに……変だなあ、電波が消えたらしい」「どうしたんだ、停電かね」　ドレゴが訊いた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "かいなはで筈たっかなけきが口ていでん死は井熊に既きとたっ帰が谷柴らな故何。",
              "citation": {
                "source": "密林荘事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
