    },
    "definitions": [
      {
        "index": 1,
        "gloss": "being suited to a role",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "隆景進み出て云う様、この大役は立花左近将監宗茂こそ適役である。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに今度のカルメンなどは、彼女に最も適した漂泊女の女であり、鼻っぱりの大層強い性格で、適役でなければならないのに、どうもいきが弱かったと言った。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹十郎の吾太夫は寿美蔵の師匠張より見好きも、貫目に乏しく、翫太郎の道庵は適役にて好し。",
              "citation": {
                "source": "明治座評",
                "author": "三木竹二",
                "note": "青空文庫"
              }
            },
            {
              "text": "素質の美しさ、若殿型の桜丸として適役であつた。",
              "citation": {
                "source": "手習鑑雑談",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さういふ彼にとつて、動物の番人はこの上ない適役であり、一つの部屋が与へられるといふことが、彼にとつて大変好都合だつたのである。",
              "citation": {
                "source": "間木老人",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "伯母さんといっても、まだ四十歳の未亡人で、金があって孤独で閑で、ぼんやり日を暮してた人だから、丁度適役だった。",
              "citation": {
                "source": "南さんの恋人",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳優も、それぞれ先づ適役と云ふべきであらう。",
              "citation": {
                "source": "“にんじん”を観て",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「楽天公子」はロツパの適役であらうが、さういふ見方をしだすと余計な注文をつけたくなる。",
              "citation": {
                "source": "ロツパの「楽天公子」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、広く適役を物色した。",
              "citation": {
                "source": "「温室の前」の人物について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "五尺四寸五分とかの良く延びた豊艶な肉体美で、絵を書くよりもモデルの方が適役だと絵描き仲間に噂のあつた人である。",
              "citation": {
                "source": "女体",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の役は、成るほど、適役だと云へないのが残念である。",
              "citation": {
                "source": "春秋座の「父帰る」",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「適役」とか、「無理な役」とかいふ見方が、才能技芸と関係なく許される。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の目にも実直な夜番にはこの上もない適役と見立てたくなる風態だ。",
              "citation": {
                "source": "吝嗇神の宿",
                "author": "人生オペラ　第二回",
                "note": "青空文庫"
              }
            },
            {
              "text": "一しょに檻の中で酒をのみ、はじめはお光り様の悪口を云っていたが、酔いが廻るとほめはじめて、どうしても私と入れ代りに檻の中に残った方が適役のような言辞を喋りまくって戻っていった。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたしかに適役ではないのですよ。",
              "citation": {
                "source": "ルイスヒェン",
                "author": "LUISCHEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "木を叩ッ切るだけなら、他に適役があらア。",
              "citation": {
                "source": "夜長姫と耳男",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "適役だ」「南太平洋に消えたひとりのサーファーと、無人の環礁の物語」　窓の外の赤い黄金色の陽ざしを僕は見つめた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "不特定多数に配布するカレンダーに、ひょっとしたら適役かもしれない。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカの理想に対して疑問を投げかける役として、黒人以上の適役がいないことはすでに書いた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "――こういう、因縁つきの主従なので、吉宗に附するに、彼の隠し目付は、たしかに適役にちがいなかった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そのお供には、あっしが適役。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと曹操に愛せられた男ですが、これを用いれば適役でしょう」「呼べ。",
              "citation": {
                "source": "三国志",
                "author": "望蜀の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
