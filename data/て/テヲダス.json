[
  {
    "uuid": "794affd9-df13-506a-870a-48a5a37dca1f",
    "entry": "手を出す",
    "reading": {
      "primary": "てをだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
