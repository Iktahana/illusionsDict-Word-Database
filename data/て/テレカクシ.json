[
  {
    "uuid": "a02c013b-b1c6-5f22-949e-5240df0ff863",
    "entry": "照れ隠し",
    "reading": {
      "primary": "てれかくし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
