  {
    "uuid": "79a9053c-2a94-56cc-9ab2-075a0835e681",
    "entry": "ＴＥＬ",
    "reading": {
      "primary": "テル",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "telephone",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ＨＯＴＥＬ・ＲＩＴＺ――マドリッド第一のホテル――の数年まえの止宿人名簿を探すと、メリイ・カルヴィンの自署を発見するに相違ない。",
              "citation": {
                "source": "踊る地平線",
                "author": "血と砂の接吻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは読出専用メモリ（ＲＯＭ）を主メモリとした、４ビット並列処理のワン・チップＣＰＵ（ＭＣＳ―４、アメリカのＩＮＴＥＬ社製、わが国ではパネトロン社扱い）である。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "例へば高倉テル氏や矢田※雲氏など。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この橋のあるあたりの小高い崖の上に、湯元ホテルとかいふ木造のホテル兼レストランがある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に何の奇もない平凡な木造建築であつて、ホテルと言つてもごく簡便な物であるが、それがどことなく西洋の野菜料理店といつた感じがする。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝夕の散歩のかへり道に、このホテルの静かな食堂へ入つて、大層冥想的な紅茶を飲むのは、温泉場の物侘しい生活にふさはしいことである。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを左へ曲るとウンテルデンリンデンですぐ右側の角がツォイクハウス、次が番兵屯所、その次が大学である。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのポルチエーが自分を小蔭へ引っぱって行って何かしら談判を始める。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日の夕方、ホテルの食堂で食事のあとに出した菓物鉢の数々の果物の中にただ一つ柿の実がのっかっていた。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "またいふ、東郷大將とふたり外遊の折、乃木、かならずその國一のホテルに宿り、手袋、煙草、すべて一流のものをのみ用ゐた。",
              "citation": {
                "source": "人物に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "瘤取りムカシ　ムカシノオ話ヨミギノ　ホホニ　ジヤマツケナコブヲ　モツテル　オヂイサン　このお爺さんは、四國の阿波、劍山のふもとに住んでゐたのである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、例へば私の額に、どういふレツテルを貼ればいいか分らないやうな時には、「あれは妙な奴だ、どうも妙な奴だ！",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪の宵　　　　　　青いソフトに降る雪は　　　　　　過ぎしその手か囁きか　　白秋ホテルの屋根に降る雪は過ぎしその手か、囁きか　　　　ふかふか煙突｜煙吐いて、　　赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しづかにしづかに酒のんでいとしおもひにそそらるる……　　ホテルの屋根に降る雪は　　過ぎしその手か、囁きかふかふか煙突煙吐いて赤い火の粉も刎ね上る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく富士山麓の宿屋としては、北の精進ホテル以外において、もっとも景勝の地を占めたものであろう。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "生憎時計を見ると、かれこれ午後二時に近い、空気も稀薄になり始めて、絶頂まで、遅々たる足取りでは、今夜中にホテルまで、戻り得られるか否かも、覚束ないので、ここから下山することにした。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し池畔からホテルへのドライヴウェーは、亭々たる喬木の林を切開いて近頃出来上つたばかりださうであるが、樹々も路面もしつとり雨を含んで見るからに冷涼の気が肌に迫る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "瑞西あたりの山のホテルを想はせるやうな帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルといふ宿屋に泊つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあつたが自分達の盆の餅をすゝめて、さうして此人達から新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道を引返して帝国ホテルで昼飯を食つてから、今度は田代池といふのを見に行つた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし池畔からホテルへのドライヴウェーは、亭々たる喬木の林を切開いて近頃出来上がったばかりだそうであるが、樹々も路面もしっとり雨を含んで見るからに冷涼の気が肌に迫る。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "スイスあたりの山のホテルを想わせるような帝国ホテルは外側から観賞しただけで梓川の小橋を渡り対岸の温泉ホテルという宿屋に泊った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "失礼ではあったが自分たちの盆の餅をすすめて、そうしてこの人たちから新築のホテルに関する噂を聞いた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道を引返して帝国ホテルで昼飯を食ってから、今度は田代池というのを見に行った。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏の考案は光がエーテルの波動だという事を基礎としたもので、理論上実に巧妙なものである。",
              "citation": {
                "source": "天然色写真新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてそんなことで、主人も私も東海道のことはすっかり忘れ果て、二人ともめいめいの用向きに没頭して、名古屋での仕事もほぼ片付いた晩に私たちはホテルの部屋で番茶を取り寄せながら雑談していた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝、ホテルを出発しようとすると、主人に訪問客があった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
