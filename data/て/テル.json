    "definitions": [
      {
        "index": 1,
        "gloss": "to shine",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "寒菊や日の照る村の片ほとり　冬の薄ら日のさしてる村の片ほとり、土塀などのある道端に、侘しい寒菊が咲いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の照る砂地に落ちてゐた硝子を、歩み来た旅人は周章てて見付けた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲がきれて陽が照るしもう雨は大丈夫だ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕みんなさっきはあしをぬらすまいとしたんだが日が照るし水はきれいだし自分でも気がつかず川にはいったんだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が強く照るときは岩は乾いてまっ白に見え、たて横に走ったひび割れもあり、大きな帽子を冠ってその上をうつむいて歩くなら、影法師は黒く落ちましたし、全くもうイギリスあたりの白堊の海岸を歩いているような気がするのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "陰氣だつた梅雨の日も忘れたやうに過ぎて、緑の深くなつた桐の葉に照る日光が急にギラギラと夏めいて來た、病室の中は暑苦しくなつた。",
              "citation": {
                "source": "病院の窓",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇にも歡びあり、光にも悲あり麥藁帽の廂を傾けて、彼方の丘、此方の林を望めば、まじ／＼と照る日に輝いて眩ゆきばかりの景色。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇にも歓びあり、光にも悲あり、麦藁帽の廂を傾けて、彼方の丘、此方の林を望めば、まじまじと照る日に輝いて眩ゆきばかりの景色。",
              "citation": {
                "source": "画の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道理で、坂は照る照る鈴鹿は曇る＝といい、袷遣りたや足袋添えて＝と唱える場合には、いずれも疲を休めるのである、無益なものおもいを消すのである、寧ろ苦労を紛らそうとするのである、憂を散じよう、恋を忘れよう、泣音を忍ぼうとするのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時は、その下蔭は矢張こんなに暗かったか、蒼空に日の照る時も、と然う思って、根際に居た黒い半被を被た、可愛い顔の、小さな蟻のようなものが、偉大なる材木を仰いだ時は、手足を縮めてぞっとしたが、（父親は何うしてるだろう、）と考えついた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕　みんなさっきはあしをぬらすまいとしたんだが日が照るし水はきれいだし自分でも気がつかず川にはひったんだ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が強く照るときは岩は乾いてまっ白に見え、たて横に走ったひゞ割れもあり、大きな帽子を冠ってその上をうつむいて歩くなら、影法師は黒く落ちましたし、全くもうイギリスあたりの白堊の海岸を歩いてゐるやうな気がするのでした。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに樽の中が泡ばかりになりかけて来ると、重役連中が一人逃げ二人逃げ、しまいには相手の選手までいなくなって、カンカン日の照る草原に天幕と空樽と、コップの林と、入れ代り立ち代り小便をする味方の選手ばかりになってしまった。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたかも野辺にさすらいて秋の月のさやかに照るをしみじみと眺め入る心持と或は似通えるか。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "日は青々とした空に低く漂ッて、射す影も蒼ざめて冷やかになり、照るとはなくただジミな水色のぼかしを見るように四方に充ちわたった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬ようやく船に乗りて船、河の中流に出ずれば、灘山の端を離れてさえさえと照る月の光、鮮やかに映りて馬白く人黒く舟危うし。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿江はまた思わず自分の顔が火照るのを痛々しく感じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊廓なんぞにも平気でいらっしゃるという人もあるんだから……」　おぬいは遊廓という言葉を母の口から聞くと、身がすくみそうに恥じらわしくなって、顔の火照るのを覚えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそう決心すると同時に、園は心臓がきゅうに激しく打ちだして、顔が火照るまでに慌ただしい心持になっていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "七楽しからずや天の原　　そら照る星のさやけさに月の光の貴さに　　心をさらすその時のアー　是れ　是れ　是れ　　是れこそ楽しき極みなれ。",
              "citation": {
                "source": "遠友夜学校校歌",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ道理で、坂は照る／＼鈴鹿は曇る＝といひ、袷遣りたや足袋添へて＝と唱へる場合には、いづれも疲を休めるのである、無益なものおもひを消すのである、寧ろ苦勞を紛らさうとするのである、憂を散じよう、戀を忘れよう、泣音を忍ばうとするのである。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時は、其下蔭は矢張こんなに暗かつたが、蒼空に日の照る時も、と然う思つて、根際に居た黒い半被を被た、可愛い顏の、小さな蟻のやうなものが、偉大なる材木を仰いだ時は、手足を縮めてぞつとしたが、（父親は何うしてるだらう、）と考へついた。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "日がかんかんどこか一とこに照る時か、また僕たちが上と下と反対にかける時ぶっつかってしまうことがあるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに照る月、輝く日は、兀げた金銀の雲に乗った、土御門家一流易道、と真赤に目立った看板の路地から糶出した、そればかり。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……と思うと、もう麦稈帽を頭に乗っけて、夕日のカンカン照る往来に出て行った。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが心慰めかねつ更科や姨捨山に照る月を見て月見れば千々に物こそ悲しけれ我身ひとつの秋にはあらねど中庭地白ウシテ樹ニ鴉棲ム。",
              "citation": {
                "source": "月の詩情",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初冬に入って間もないあたたかい日で、照るともなく照る底明るい光線のためかも知れない、この一劃だけ都会の麻痺が除かれていて、しかもその冴え方は生々しくはなかった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして明日の今頃は　　長の年月見馴れてる　　故郷の土をば見てゐるのですさよなら、さよなら！",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "５向ふに、水車が、見えてゐます、　　苔むした、小屋の傍、ではもう、此処からお帰りなさい、お帰りなさい　　僕は一人で、行けます、行けます、僕は、何を云つてるのでせう　　いいえ、僕とて文明人らしくもつと、他の話も、すれば出来た　　いいえ、やつぱり、出来ません出来ません。",
              "citation": {
                "source": "別離",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自転車に紐か何か付いてるでせう、と僕は云つた。",
              "citation": {
                "source": "（七銭でバットを買つて）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
