        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "目ばかり黒い、けばけばしく真赤な禅入を、木兎引の木兎、で三寸ばかりの天目台、すくすくとある上へ、大は小児の握拳、小さいのは団栗ぐらいな処まで、ずらりと乗せたのを、その俯目に、ト狙いながら、件の吹矢筒で、フッ。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "天王山を間違えたのかどうだか、天目山などと言う将軍も出て来た。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "天目山なら話にならない。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長坂は、勝頼と天目山に最期を共にして居るのである。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡部もとにかく天目山迄は同行しているのである。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝頼が天目山で死んだのは天正十年だが、武田はこの一戦で敗亡の形を現したのである。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその瞬間、金二千両の天目茶碗を失った代りに、自分の心の落着きをしかと取り返すことが出来たように思って、昂然と胸を反らした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言いざま、天目茶碗に白湯をくみ、瓢から香煎をふり出して、この珍客にたてまつった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一回は歌舞伎座で開かれて、わたしが第一の史劇「天目山」二幕を書いた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年勝頼が四方に敗れ小山田信茂には裏切られ、天目山で自尽した時、諸将ほとんど離散した中に、惣蔵一人｜己が子を殺し、二心なきを現わした上、最後のお供｜仕ったほどで、この義烈には敵ながらも徳川家康が感心し、苦心して遺族を尋ね出し常陸土浦九万石に封じた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その推移をみると明かに初めは天目茶を目的として造られたものかどうか――これとて何かの器物だつたのが、用途において轉用されたのかもしれない。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "釉の變化、窯中の神秘、天目釉、飴、黄、織部、志野、その他いろ／＼の釉の發生の動機や釉と時代との變化を考へてゆくと興味津々たるもので、同じ黄瀬戸といつても時代が變る毎に黄色がちがつてくる。",
              "citation": {
                "source": "やきもの讀本",
                "author": "小野賢一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の歌にはまた　渓間なる人｜山女魚汲み行く方に天目山の靡く道かな　などいふのもある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "と」　その時一人のお小姓が、恭しく天目を捧げながら、襖をあけて入って来た。",
              "citation": {
                "source": "生死卍巴",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　さすがの勝頼も気味悪くなり、侍臣をして天目山へ埋めさせた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "で止むを得ず僅の部下と共に天目山へ立籠った。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其上に女が天目へ茶を載せて出す。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上に女が天目へ茶を載せて出す。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少しで頭だけ入りそうになった時、すうと向うに見える障子が明いて、天目を持った若い女が縁側にあらわれた。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天王山だ、天目山だ、これこそ本土決戦の関ケ原だ」といわれた沖縄が失陥したのだ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "武田勝頼が天目山に自刃のとき、秀吉は中国征伐の陣中でこの報告をきいたが、思はず長大息、あたら良将を殺したものよ、甲斐信濃二ヶ国を与へて北方探題、長く犬馬の労をつくさせるものを、と嘆いた。",
              "citation": {
                "source": "二流の人",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "標高千四百五十｜米突の大菩薩嶺を左にしては、小金沢、天目山、笹子峠がつづきます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "お銀様の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いかにもご主人の仰せの通り、広い日本の諸方には、眼を驚かすような武芸者が、幾人か覇を競うておりまする」「たとえば北条の身内にて、鮎川天九郎｜一羽斎、武田信玄の家臣では、天目八兵衛馬之丞、松永｜弾正の郎党には、十文字｜刑部鋭鎌介、これら一方の旗頭に皆々お逢いでござろうな？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔に見覚えのある、司馬の門弟の少年が一人、褥、天目台にのせた茶などを、順々に運び出てすすめたのち、つつましやかにさがってゆく。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "田丸主水正は、主君対馬守のお代理という格式で、突き袖をせんばかり、そっくりかえってその部屋へはいっていくと、竹田は、前に出ていた天目台をちょっと横へそらして、両肘を角立てて、畳をなめた。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分古い伝説のある天目一箇命をまつった荒田神社ではないかと思う。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "時として無地｜天目のものも見かける。",
              "citation": {
                "source": "雲石紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天目と白磁との両方である。",
              "citation": {
                "source": "全羅紀行",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほしなし、すけ、てんもく、たけしま、きひめ、という珍らしい名なるがあり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
