        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "不用意な発言でメディアを敵に回すと、今後のキャリアに大きな支障をきたすだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「俺一人を敵に回すならまだしも、この街全員を怒らせたのがお前の間違いだ」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "強引な手法で業界全体を敵に回した結果、彼の会社は孤立してしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "――彼女は、クリストフがどうもそう決心しているらしく思われるとおりに実際においても、ドイツ芸術とドイツ精神との偏見にたいして一徹な攻撃的の道を固執するならば、彼はすべての人を敵に回し、保護者をも敵に回すようになるだろうということを、明らかに見て取っていた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ世界中の人間を敵に回すようなことになろうとも、己の正しいと信じる道を邁進する強靭な勇気が君には必要だ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと、突っ立ちながら、これは敵に回すより味方にした方がいい。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "致命的なもめ事やへまをしたら、敵に回す。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
