    "definitions": [
      {
        "index": 1,
        "gloss": "shadow cast by a person's hand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "手暗がりで教科書の文字が読みづらいから、電気をつけてよ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "台所で手暗がりにならないよう、手元を照らすスポットライトを設置した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "手暗がりのせいで、裁縫の針に糸を通すのに苦労した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "灯の真下で文を書こうとすれば紙面は手暗がりになります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手暗がりにしない為その手を除けば文は書けません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一同は、はずみのついたボールのように、もんどりうってくらがりの闇の中へ叩きつけられたが、幸いにもそこは身体にやわらかくあたった。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてくらがりの中で、博士の身体をしらべていた。",
              "citation": {
                "source": "少年探偵長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は丸木のあとを追ってくらがりの中を歩いているうちに、とうとう相手のすがたを見失ってしまった。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
