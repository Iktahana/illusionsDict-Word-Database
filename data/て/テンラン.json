    "definitions": [
      {
        "index": 1,
        "gloss": "imperial inspection",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "○四月二十六日より四日間、麻布鳥居坂の井上外務大臣邸において演劇天覧あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一日は聖上陛下の天覧、第二日は皇后陛下の台覧、第三日は外国公使その他の招待、第四日は皇太后陛下の台覧あり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかくご天覧いただいているところで失敗しては堪りませんよ。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ天覧という大きなことがかぶさって来ては！",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに脊骨が絞られるような悩みが……」「ト云うと天覧を仰ぐということが無理なことになるが、今更｜野暮を云っても何の役にも立たぬ。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　自分は今天覧の場合の失敗を恐れて骨を削り腸を絞る思をしているのである。",
              "citation": {
                "source": "鵞鳥",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "陛下の天覧が機会となって伊井公侯の提撕に生じたのだから、社会的には今日の新劇運動よりも一層大仕掛けであって、有力なる縉紳貴女を初め道学先生や教育家までが尽く参加した。",
              "citation": {
                "source": "四十年前",
                "author": "――新文学の曙光――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついては本会の光栄として、特に天覧に供するものがなくてはならないのですが、それについて、いろいろ協議の結果、濤川惣助氏の無線七宝の花瓶と、あなたの作の矮鶏とを出品中の主なるものとして陳列することに決議しましたから、どうかお作を出すことにして下さい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏の作が計らず展覧会に出品されたいきさつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは会場へ陳列するとはいうものの天覧に供し奉るのでありますから、公衆の前に発表するでなくただ上御一人の御覧に供するだけで御還御の後は直ちにお引き取りになって下さい。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "矮鶏の作が計らず展覧会に出品されたいきさつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "演劇改良と改作　あくる二十年の四月にわが劇界に取って前代未聞――尤もその昔、かの猿若勘三郎父子が京都の内裏で天覧を賜わったという伝説はあるが――とも言うべき出来事が起こった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは麻布鳥居坂の井上伯爵邸へ両陛下が行幸啓にならせられて、劇場関係者一同が歌舞伎天覧の光栄を荷ったというのである。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "改作問題というのは「勧進帳」を天覧に供するについて、ある人が――末松謙澄子だとか伝えられている――その字句の修正を行なった。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十年の井上外務大臣邸における演劇天覧と、三十六年における団菊両優の死と、この二つの事件は明治の演劇史に特筆せらるべき重要の記録である。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、麻布鳥居坂の井上邸で、天覧芝居という、破天荒の悦びをもつことになったのだ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勧進帳」その他が、明治天皇陛下、皇后宮、皇太后の宮と、天覧につづき台覧になったことは、劇界ばかりではない、諸芸の刺戟になったのだ。",
              "citation": {
                "source": "朱絃舎浜子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、同じく二十七日から三日に渉り、麻布鳥居坂の井上外相邸で、初日は天皇、二日目は皇后、三日目は皇太后、三陛下の臨幸を仰いで演劇天覧。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治二十年四月、井上外務大臣私邸における天覧演劇以来、俄かに東京の歌舞妓役者の間に、貴族趣味が猖獗に流行し出した。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天覧演劇が生み出した、歌舞妓の光りであつたと。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "其でもまだ彼は、「姫百合」よりも前の天覧芝居を、大阪で聞いてゐた印象を忘れなかつたのである。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天覧芝居三年後に興行した有洲成人の姿が、彼の一生に、そのまゝ張りついてしまつたものと言へる。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌年四月の天覧芝居も、天外の孤客のやうな侘しい感動を、彼に与へて過ぎた。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "得意想ふべし、暇さへあれば稽古に余念がなく、天覧に供し、大名に見せ、妻妾侍女に見せ、果は京都の町家の女子衆も一人あまさず悩殺してやらうといふので一般に公開して見物させ、頻りの興行、ほめる者には即座に着てゐる着物まで脱いでくれてやる。",
              "citation": {
                "source": "我鬼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "楠公の像の木型が出来て、それを二重橋の内に持って行って飾りつけ、先ず明治天皇が天覧になった。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兜の前についている剣に楔を入れることを忘れて、陛下が突然地面にお降りになって、ぐるぐる像の周囲を御廻りになりながら天覧になったが、その時にその剣がぶらぶら揺れるので、それが落ちたら切腹ものだったと言っていたのを記憶している。",
              "citation": {
                "source": "回想録",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水さんは昭和五年の天覧試合だかに杖術の型を披露するため、神伝夢想流の先生にともなわれその高弟として上京したのだそうだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "天覧山という飯能の名所の地にあるのである。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "駅の広告に、「天覧山麓、温泉旅館、東雲亭」　とあったから、「ヒル飯はあそこだ！",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "高麗神社の祭の笛――武蔵野の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時は天覧演劇であるとか、あるひは貴顕の邸へ陛下の御臨幸ある場合などは、ガスの大気嚢であるとか発電機を特にそこへ持運んで、照明の用に供へたといふ。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "この映画は試写には露伴先生にまみえ、後には天覧も賜わった。",
              "citation": {
                "source": "露伴先生と科学",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "到頭あきらめて、雪の結晶の天覧がすんで間もなく、何もかにも放り出す気で、さっさと家をたたんで、伊豆の伊東へ引き揚げてしまった。",
              "citation": {
                "source": "ジストマ退治の話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
