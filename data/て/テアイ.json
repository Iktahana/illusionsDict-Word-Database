        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その辺の農家の石垣は、氷河の推し流した堆石を使ったりしているのが、私たち富士山で、万年雪を物色したり、日本アルプスで、「カアル」の痕を、氷河時代の遺蹟か否かと、論じ合ったりしている手合いに、いかに珍しかったろうか。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは余裕のある手合いがいうことだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾を持ってる手合いは世間ざらにある。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "野郎が有難い事を云ったってかんかん虫手合いは鼾をかくばかりで全然補足になら無えってんで、工場長開けた事を思いつきやがった、女ならよかろうてんだとよ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かんかん虫手合いで恐がられが己れでよ、太腐れが彼奴だ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を考えたってお前、己ら手合いは人間様の様に智慧がありあまんじゃ無えから、けちな事にも頭を痛めるんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間って奴は何んの事は無え、贅沢三昧をして生れて来やがって、不足の云い様は無い筈なのに、物好きにも事を欠いて、虫手合いの内懐まで手を入れやがる。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "寂然して溢れる計り坐ったり立ったりして居るのが皆んなかんかん虫の手合いである。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "九分九厘まで行って、ギリギリの一点を残して、あとは大いに享楽して、それでプラトニックだと称している手合いが多いんだ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰があんな自我の無い手合いと一しょになるものか、自分にはあんな中途半端な交際振りは出来ない。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母がこういう手合いの中に入っての仕こなしは、また鮮かなものであります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやじというのは、お袋とは違って、人のよさそうな、その代り甲斐性のなさそうな、いつもふところ手をして遊んでいればいいというような手合いらしい。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分に全躯保妻子の臣といわれても、こういう手合いは、腹も立てないのだろう。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな手合いは恨みを向けるだけの値打ちさえもない。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七〇年前後、熱に浮かされたように大声で喋っていた手合いには、お預けの餌を取り上げられたポチのように茫然としている連中が、このころ多かった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄夫婦は稲の出来ばえにほくほくして、若い手合いのいさくさなどに目は及ばない。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより相手になる手合いではないが、少ししかりつけてやろうと考えたのである。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それでも足利のおあねえ様や分家の手合いが寄り集まって、何とか埒をあけることに苦労しているんだが、どうも右から左に纏まりそうもねえ。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "後詰めとなってくれる親類の一人もないのはもちろんの事、ややともすれば親切ごかしに無いものまでせびり取ろうとする手合いが多いのだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちなみに××っていうのは、そういう手合いのためにいろいろと作ってくれるところだ。",
              "citation": {
                "source": "罪と覚悟",
                "author": "A RETRIEVED REFORMATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手合いに対しては残念ながら我々は全く策の施しようがないのである。",
              "citation": {
                "source": "雑文的雑文",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "数多の下女下男があるなかに、稲子沢の寝手間取りとて、年中ごろごろ寝てばかりいて食っている手合いも多かった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれも下等なマテリアリストで、所謂駱駝が針のメドを通るより、もっとむずかしい手合いである。",
              "citation": {
                "source": "錯覚した小宇宙",
                "author": "――Our faith comes in moments;",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あの手合いのようなお喋りを読む時、露骨に嫌悪を感じます。",
              "citation": {
                "source": "マクシム・ゴーリキイの発展の特質",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから地獄の釜の蓋のあく日に、お閻魔様への御機嫌伺い、これとて強ち冥土の沙汰も金次第だからとて、死なぬ先から後生をお願い申すわけでも何でもなく、そんな卑怯な気の弱い手合いは口幅ったいことを言うのじゃないが、恐らく正真正銘の江戸ッ児には一人もないはず。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "走りを好む手合いをお客様にしての商売は、こうした生きものをも造化の下請負せねば間に合わず、一年三百六十五日、己が住居の床下にそれはそれはごたいそうな虫の巣を拵えこんで、無慈悲の冬を囲いもしてやれば、かれらの子孫の蕃殖をもお手伝いする。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "河鹿は縁日もの、振り売りの手合いからは決して買わぬもの、これも三歳以下なはまだ籠なれずして鳴きも歌わず、どうかすると姿ばかりがよく似た蛙めを掴まされることさえある。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "別段そのビラには大したことは書かれていなかった――＊３コツェブーの芝居がかかっていて、ロールの役をポプリョーヴィンが、コーラの役をジャブロワ嬢がやるというだけで、その他の役者は一向名もない手合いばかりであった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一方の手合いといえば、よく肥った連中か、さもなければチチコフと同じような、つまりあまり肥ってもいなければ、そうかと言って決して痩せてもいない連中で。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この手合いは反対に、婦人連を横目で見やりながら後ずさりをして、知事の従僕が何処かへ緑いろの骨牌台を出さないかと、あたりを見まわしながら、そればかり狙っている。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
