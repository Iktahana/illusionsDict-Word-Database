    "definitions": [
      {
        "index": 1,
        "gloss": "to place both hands on the ground (to express respect, apology or to present a request)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "娘がおとなしく手をつかえるのを待ちかねたように、師直は声をかけた。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "十六になる小女が、はいと云って敷居際に手をつかえる。",
              "citation": {
                "source": "文鳥",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「昨夜は御忙しいところを……」と女は入口に近く手をつかえる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "一にやろうがやるまいが余計な御世話じゃないか」「今どっかへ出掛けたでしょう」「どこへ行ったんだろう」「きっと宗近へ行ったんですよ」　対話がここまで進んだ時、小野さんがいらっしゃいましたと下女が両手をつかえる。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも結局は、母の為に自分をまげて、「すみません……」と、手をつかえるほか無かったのだが、どっと涙があふれ出てとまらなかった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かいおうとしたが手をつかえると、それなりしばらく黙ってしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「じゃあ、お先に」「さあ、さあ、なにも心配しないがいいぞよ」「……すみません」　と、手をつかえる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――しばらくでした」　座を辷って、武蔵が、両手をつかえると、沢庵はその手を握って、「ここは遊びの里だ、あいさつはざっとにしよう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそれいりました」　坐って、両手をつかえると、しばらくは胸を正せなかった。",
              "citation": {
                "source": "剣の四君子",
                "author": "柳生石舟斎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「文八にございます」　手をつかえると、そうかといったのみで、机のうえで、何か書きつづけていた。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口にまわしてある屏風をかわして、両手をつかえると、光圀はふり向いて、「そのへんに藤井紋太夫がおるであろう。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お帰りあそばしませ」　寧子はいつもと変りなく、すぐ彼の棒立ちになった足もとへ手をつかえる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "手をつかえると、妻は、おろおろと泣きわなないた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口まで立って出迎えた礼を、もういちど繰り返して、わが子に手をつかえるのであった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "揃って手をつかえる顔、顔、顔――の出迎えを秀吉はまばゆいような眼と微笑にうけて通った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "清子の横へ、手をつかえると。",
              "citation": {
                "source": "私本太平記",
                "author": "あしかが帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
