[
  {
    "uuid": "08506631-34c6-561d-90f3-7f1656e219cd",
    "entry": "低額",
    "reading": {
      "primary": "ていがく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
