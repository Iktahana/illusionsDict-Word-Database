    "definitions": [
      {
        "index": 1,
        "gloss": "to shine brilliantly",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この人たちは、わたしの照り輝く光の中で、墓の中からよみがえった都市を見ようと思ったのです。",
              "citation": {
                "source": "絵のない絵本",
                "author": "BILLEDBOG UDEN BILLEDER",
                "note": "青空文庫"
              }
            },
            {
              "text": "明煌々と照り輝く座敷の中に立ち、あたりを見廻すと、逸子も久振りに気も晴々となった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――飛びだして、山を越えて、あたたかい南の国へ、お日さまがさんさんと、さんさんと照り輝く場所へ飛んでいくことができる。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "その瞬間に彼女は真黄に照り輝く光の中に投げ出された。",
              "citation": {
                "source": "クララの出家",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう思つて有明月に立ち向つてゐる和泉式部の靜かな姿は、美しさを過ぎた清らかさに照り輝くばかりであつた。",
              "citation": {
                "source": "誠心院の一夜",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏具のない寝殿造りの神社に似た霊屋は、照り輝く砂の白さに調和した破風の反りを波うたせ麗しかった。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜は、概して平安一路な航海、月や星の美しい甲板で、浴衣がけや、スポオツドレスのあなたが、近くに仄白く浮いてみえるのを、意識しながら、照り輝く大海原を、眺めているのは、また幸福なものでした。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには空想的なものもありますが、夢の中では意識が一方に集つて照り輝くためでせう、微妙な心理や複雜な生活状態から目が覺めて居る時よりも一層よく寫實的に觀察することの出來るばかりで無く、其れにおのづから明暗の度が適度に附いて、ちやんと一つの藝術品として立體的に浮き上つて構圖されて居る場合があります。",
              "citation": {
                "source": "夢の影響",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太陽の照り輝く日中でも音もなく吹く秋風は膚身にこたえて寒かった。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠くの向うに、明かな日光の暖かに照り輝く海を控えて、黄な上衣を着た美しい男と、紫の袖を長く牽いた美しい女が、青草の上に、判然あらわれて来た。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱き持つた等身の白玉と一つに、水の上に照り輝く現し身。",
              "citation": {
                "source": "死者の書",
                "author": "釋迢空",
                "note": "青空文庫"
              }
            },
            {
              "text": "抱き持った等身の白玉と一つに、水の上に照り輝く現し身。",
              "citation": {
                "source": "死者の書",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都の永観堂とか通天とかに行くと、野外の冷たい空気に触れて照り輝く紅葉などを賞しつつ、湯豆腐をやる風流があるが、こうした寒きに過ぎた場合には熱い醤油もふさわしいが、部屋の中では強いてそうしなくていいことと思う。",
              "citation": {
                "source": "湯豆腐のやり方",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "うららかな太陽の照り輝く朝だった。",
              "citation": {
                "source": "リップ・ヴァン・ウィンクル",
                "author": "ディードリッヒ・ニッカボッカーの遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの可愛らしい燕と思ふさま照り輝く夏の日光と入海の彼方に延長する優しい丘陵とに対して、何といふ事もなくダンヌンチオ作品中の風景に接する思をなした。",
              "citation": {
                "source": "海洋の旅",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖をうしろにした此の窪地は風も吹き通はず小鳥の聲も聞えず、小春の日光の照り輝くばかり。",
              "citation": {
                "source": "畦道",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さつきから空の大半は真青に晴れて来て、絶えず風の吹き通ふにも拘らず、ぢり／＼人の肌に焼附くやうな湿気のある秋の日は、目の前なる大川の水一面に眩しく照り輝くので、往来の片側に長くつゞいた土塀からこんもりと枝を伸した繁りの蔭がいかにも凉しさうに思はれた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから空の大半は真青に晴れて来て、絶えず風の吹き通うにもかかわらず、じりじり人の肌に焼附くような湿気のある秋の日は、目の前なる大川の水一面に眩しく照り輝くので、往来の片側に長くつづいた土塀からこんもりと枝を伸した繁りの蔭がいかにも涼しそうに思われた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖をうしろにした此の窪地は風も吹き通はず小鳥の声も聞えず、小春の日光の照り輝くばかり。",
              "citation": {
                "source": "畦道",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて、真夏の澄み渡った空気だの照り輝く太陽だのがいくら骨を折って発散しようとしてもとても覚束ないような陽気な空気が戸外に棚引いていた。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮雲の引幕から屈折して落ちて来る薄明い光線は黄昏の如く軟いので、眩く照り輝く日の光では見る事｜味う事の出来ない物の陰影と物の色彩までが、かえって鮮明に見透されるように思われます。",
              "citation": {
                "source": "監獄署の裏",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は英字で『スタンプショップ』と書き、日本字で『印章速応』と書いた厚紙の看板を柵にぶらさげ、川べりで釣りをたれて魚のくひつくのを待つこゝろで、静かに照り輝く小春日和の下に時をすごしたが、第一日は全く何の手ごたへもなかつた。",
              "citation": {
                "source": "老残",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            },
            {
              "text": "活溌なうちにも上品さを失わず、間近にあると、美質はいっそう発揮され、俺の眼にはほとんど照り輝くばかりに見える。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを日中の照り輝く路を、渡御なされるやうにしたのは中古からの変化で、その為に特に道中を花やかにするやうな、動く舞台といふものが考へ出されたのだつた。",
              "citation": {
                "source": "祭のさまざま",
                "author": "柳田國男",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのどうしても太陽が照り輝く真昼に、物を見ようとして灯火を捜す者があろうか。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
