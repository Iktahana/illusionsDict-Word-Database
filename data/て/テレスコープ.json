        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "従って自然なしでは柱なき家でありテレスコープなき潜航艇でもある。",
              "citation": {
                "source": "油絵新技法",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "中に、小さい望遠鏡をつけた大きなテレスコープがあり、握りに玉のついた棒の幾本かで、調節する。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度艇を上昇させて、煙幕の端の方から、テレスコープを出してみろ」　私は、命じた。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレスコープが、そろそろとくりあげられる。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレスコープが、波の上に頭を出した。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｍ君は生真面目な顔をして、バットの煙を濛々と揚げながらテレスコープにしがみ付いている。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるでお伽噺の小人国の燐寸のやうなその眼玉が、直立してテレスコープの役目を果してゐる。",
              "citation": {
                "source": "測量船拾遺",
                "author": "三好達治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
