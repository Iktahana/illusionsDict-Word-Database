  {
    "uuid": "6e55366b-15c8-5861-bdc4-e0cb279b7721",
    "entry": "店屋物",
    "reading": {
      "primary": "てんやもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
