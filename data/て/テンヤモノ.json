      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "food delivered from a restaurant",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いくら新宿をそばに控えているからといって、今どきの場末の稽古師匠が毎日｜店屋物を取ったり、刺身を食ったり、そんなに贅沢ができる筈がねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくら新宿を傍に控えているからと云って、今時の場末の稽古師匠が毎日店屋物を取ったり、刺身を食ったり、そんな贅沢が出来る筈がねえ。",
              "citation": {
                "source": "半七雑感",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯を三日分づつ炊く方が惡いぢやないか」「まア、そん事で、尤も、日に三度｜店屋物を取つちや、あつしの身上が保たねえ」「それからお化けはどうしたんだ」「あ、忘れちやいけねえ――細田屋の奧座敷、叔母は花嫁道具の番のやうに、次の間の六疊に寢た。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "飛ぶ若衆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに小夜菊は、あつしに店屋物一つ取らせないやうに、それは／＼氣をくばりますよ」　八五郎はまことに良い心持さうです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "用心棒",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が房州へ歸つてゐると言ふから、昨夜あたりは店屋物を取つてゐるに違げえねえ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "下女が房州へ帰っているというから、昨夜あたりは店屋物を取っているに違えねえ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆる店屋物の主たるものは餅と団子、一方にはまた粗末ながら酒の肴であった。",
              "citation": {
                "source": "木綿以前の事",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "お八ツ時分になると、甘党の松島は卓上電話で紅谷から生菓子を取り寄せ、玉露を煎れて呑んでいたが、晩餐には姐さんのためにてんやものの料理が決まって二三品食卓に並び、楽しい食事が始まるのだったが、彼自身は口がきわめて質素で、ひじきや煮豆で済ますのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもお酒は大好きで、たべものはてんやものばかりとっていた。",
              "citation": {
                "source": "大門通り界隈一束",
                "author": "続旧聞日本橋・その一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
