        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日本の琴の音によく似てゐるが、しかしあれほど強くはなく、もつと柔かで、はかなく、さうしてへんに嫋々たる餘韻がある。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬまへつてへんなものねえ……修羅街輓歌　　　関口隆克に序歌忌はしい憶ひ出よ、去れ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "酔っ払ってへど吐きゃ、臭いに極ってら。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほんとかい」「ほんとだとも」　水夫たちは、ボースンと共に、カンカン・ハマーを放り出したまま、おもてへ駆け込んだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「時間中に、おもてへ入ることは能きないって、おもてへ行って、ボースンにそう云って来い」「ハイ」　彼が下りかけると、浴せかけるように、一運はつけ加えた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長、一運の二人が、おもてへ来て、「酔っ払って、管を巻いてる」患者を見た。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは俄かに顔いろがよくなって威勢よくおじぎをすると台の下に置いた鞄をもっておもてへ飛びだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次が棚倉を見上げてへへへへへと笑った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "松住町から湯島臺へ上つて行く左手のバラツク屋根のなかゝら、茫然とした空に向つてへんにどぼーん／＼と立つてゐる四五本の銀杏樹――それにははつきり誘惑された。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "私もそれに續いたが、高かつた踵の、横に曲つてへつてしまつた女の黒い編上靴がおづおづと動いて行くのを眼の前にすると、私の胸には變な不快さが込み上げて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩釜から小さな汽船に乗って美しい女学生の一行と乗合せたが、土用波にひどく揺られてへとへとに酔ってしまって、仙台で買って来たチョコレートをすっかり吐いてしまった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇三郎は家内のものに口止めをして、夜ふけを幸いに藤吉の死骸をおもてへ運んで、そっと江戸川へ捨てさせました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると忽ちいざりの脚が立って、蹴とばした者の脚が立たなくなってへたばりこんでしまったという。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "くるくる廻ってへたばらないやう御用心。",
              "citation": {
                "source": "電車",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "死者を納れる石棺のおもてへ、淫らな戯れをしている人の姿や、牝羊と交合している牧羊神を彫りつけたりした希臘人の風習を。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには機材とほぼ同様な形をした試片をいろいろに押し曲げてへし折ってみて、その折れ口の様子を見てはそれを現品のそれと比べたりした。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子は、母の真似をして、小さい白いガーゼのマスクをして、そうして白昼、酔ってへんなおばさんと歩いている父のほうへ走って来そうな気配を示し、父は息の根のとまる思いをしたが、母は何気無さそうに、女の子の顔を母のねんねこの袖で覆いかくした。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニはにわかに顔いろがよくなって威勢よくおじぎをすると、台の下に置いた鞄をもっておもてへ飛びだしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たうとう削られてへらされて、しまひには上の方がすっかり無くなって、前のかたまった熔岩の棒だけが、やっと残るといふあんばいだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助と三郎がもう一匹を押えようとそばへ寄りますと、馬はまるでおどろいたようにどてへ沿って一目散に南のほうへ走ってしまいました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジヨバンニは俄かに顏いろがよくなつて威勢よくおじぎをすると、臺の下に置いた鞄をもつておもてへ飛びだしました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう削られてへらされて、しまいには上の方がすっかり無くなって、前のかたまった熔岩の棒だけが、やっと残るというあんばいだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女を連れて、どこかの果てへ遠く旅立ってしまおうか……。",
              "citation": {
                "source": "窓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おもてへ出て見ると日光は実に暖かくぽかぽか飴色に照ってゐた。",
              "citation": {
                "source": "税務署長の冒険",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍浴場内に大の字に成ってへた張ったところ、三人して頭からガジャガジャ冷水の洗礼を見舞うとこ、たちまち家屋を震動せしむるウエーウエーの大声を連発する数回。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩に躓ずき、葛に引っからまり、山中をかけずり回り、身体綿のごとくなってへたばる。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠は得々としてへいげんの英語を通弁す。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寢苦い思ひの息つぎに朝戸を出ると、あの通り暴れまはつたトタン板も屋根板も、大地に、ひしとなつてへたばつて、魍魎を跳らした、ブリキ罐、瀬戸のかけらも影を散らした。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
