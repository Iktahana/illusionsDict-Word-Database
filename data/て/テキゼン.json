    },
    "definitions": [
      {
        "index": 1,
        "gloss": "in the face of the enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "……なんてこった、敵前でぼんやり腹を見せて縦隊行進をするなんて！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵前でなにをしているのだ！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御主人は、ジャンパーなど召して、何やらいさましい恰好で玄関に出て来られたが、いままで縁の下に蓆を敷いて居られたのだそうで、「どうも、縁の下を這いまわるのは敵前上陸に劣らぬ苦しみです。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秀吉が本営名護屋に着いた四月の末頃には、既に行長清正相次いで釜山に敵前上陸し、進んで数城を占領して居る。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵前間近く冑の忍の緒を締め、鎗をしごいて立った兵等の勇気は百倍した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あワレな自由しゆ義者の神経スイジャクをおたスけ下さい』　　芸妓聯隊の敵前渡河　燈ともし頃、大森の料亭『資本』に、三人組の定連がやつて来た。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『おい、芸妓ども、列べッ、敵前渡河ぢや』　芸妓達はならび、三味線を掻き鳴らし、黄色い声で歌ひ出した。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『浅い河なら―膝までめくる』　選ばれた踊り子雛太は、しぶしぶ立つて舞つた、兵士が敵前の河を渡るしぐさをするのであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『勇敢にせんか、敵前ぢやぞ』　水は膝頭よりだんだん深くなつていつた、途端に雛太は白い脛を飜しぺたりと坐り、わつと泣き出した。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『馬鹿ッ、上官に反抗するか、上官は敵前渡河は馬に乗つてやるもんぢや―』　　村会の議題『旦那の湯加減並に蝋燭製造の件』　電燈も、飯米も、肥料も、種子もない。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵前に敢えて闘うは勇なり。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "「敵前においての無礼講、人物試験は気に入った催し。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時敵前上陸をするために私たちは舟艇に乘つて輸送船を離れた。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何百個中隊、何十個大隊が横隊に並んで、それが敵前で動くことは非常な熟練を要することであります。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルジニアを屈したナポレオンは再び墺国に向い前進、ポー川左岸に退却せる敵に対しポー川南岸を東進して五月八日ピアツェンツァ附近に於てポー川を渡り、敵をしてロンバルデーを放棄の止むなきに至らしめ、敵を追撃して十日有名なるロジの敵前渡河を強行、十五日ミラノに入城した。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "特攻隊をつくり出すまで非人道になり、絶望した若い人々を、そのせっぱつまった心理から、猛然として敵前上陸でも何でもしてしまうようにもって行った。",
              "citation": {
                "source": "小説と現実",
                "author": "――小沢清の「軍服」について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「その武器を積んだ船が六ぱいあれば、ロンドンの敵前上陸が出来ますよ。",
              "citation": {
                "source": "微笑",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "各地に転戦して、敵前上陸をすること十三回に及んだ。",
              "citation": {
                "source": "ジャングル頭",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずいずれも武装したまま、幾条かの交通路に腹這いながら、じりじり敵前へ向う事になった。",
              "citation": {
                "source": "将軍",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで私もいよいよ死を決したが、百姓の竹槍に突かれて嬲り殺しにされるのもつらいから、どうかして敵前に進み出て彼の銃丸に中りたいと思った。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかが南米の蛮人ども、切って捨てるに訳はござらぬ」　日本武士の真骨頂、大敵前後に現われたと見るや、紋太夫は勇気いよいよ加わり、大刀の束に手を掛けながら前後を屹と見廻したものである。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ、敵前二十米で、あの大きなトラツクを廻れ右させるんだからな。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "斎藤隊長は新たな情況によつて、進路を右に求め、敵前のクリークを泳いでゞも渡る決心であるといふことを小川部隊長に報告した。",
              "citation": {
                "source": "従軍五十日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "『青軍の危急を救うべく、敵前に於て危険きわまる低空の急旋転を行いたるところ、折柄洋上には密雲のために陽光暗く、加うるに霧やや濃く、僚機との連絡至難となり、遂に空中衝突を惹起せるものなり』てなことを云ったので、不可抗力の椿事として、両中尉は戦死と同格の栄誉を担ったわけだった。",
              "citation": {
                "source": "恐しき通夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「第一師団は、マニラの北方二百キロのリンガイエン湾に敵前上陸し、三日目にはマニラを去る六十キロのバコロ附近まで進出したのじゃったが、そこで勝手の悪い雨中戦をやり、おまけに山一つ向うのオロンガボオ軍港からの四十｜糎の列車砲の集中砲火を喰って、その半数以上が一夜のうちにやられたということじゃ。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "其のとき柵山南条という二等兵がどうした事か敵前というのに、目に余るほど遺憾な振舞をしたために、皇軍の一角が崩れようとするので已むを得ず、泪をふるって其の柵山二等兵を斬殺したのです。",
              "citation": {
                "source": "爬虫館事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、たまたま、其方面作戦中、わたくしは、敵前数百米の第一線にあつて、眼近に、散解前進する某部隊の動静を逐一眺めてゐたのであります。",
              "citation": {
                "source": "かへらじと",
                "author": "日本移動演劇連盟のために",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時わが先鋒隊は敵の右翼を乱射しつつすでに敵前を過ぎ終わらんとし、わが本隊の第一に進める松島は全速力をもって敵に近づきつつあり。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり敵前上陸をやるつもりでなければ、この事は失敗に終ると言っている。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
