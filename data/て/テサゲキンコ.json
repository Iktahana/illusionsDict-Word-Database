        "examples": {
          "standard": [
            {
              "text": "バザーの売上金を管理するために、鍵付きの手提げ金庫を用意した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "家計の大事な通帳や印鑑は、まとめて手提げ金庫の中に保管してある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "災害時に備え、現金を入れた手提げ金庫をすぐに持ち出せる場所に置いている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "その情婦のところへ、浅井はお柳のいたころの自分にしたように、株券や貴重な書類の入った手提げ金庫などを運んでいることが知れてから、二人の情交のだんだん深みへ入っていることが、お増に解って来た。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう人にかぎって、手提げ金庫とまちがえて煙草盆をだいてかけ出したり、書類入れのつもりで猫をさかさにつかんでとびだしたりなどという話は、よくあります。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな手提げ金庫に入れる。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
