    "definitions": [
      {
        "index": 1,
        "gloss": "peace throughout the world",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "天下泰平の趣がある。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人には老人相応のオモチャを当がって、落ついて隅の方で高慢の顔をさせて置く方が、天下泰平の御祈祷になる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "植物でも少しいじめないと花実をつけないものが多いし、ぞうり虫パラメキウムなどでもあまり天下泰平だと分裂生殖が終息して死滅するが、汽車にでものせて少しゆさぶってやると復活する。",
              "citation": {
                "source": "災難雑考",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下泰平町内安全、産ある者は仁者となり、産無き者は志士となりて、賢哲天下に満ちたれば、六六館の慈善会は今にはじめぬ大当。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人には老人相応のオモチャを当がつて、落ついて隅の方で高慢の顔をさせて置く方が、天下泰平の御祈祷になる。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "休題、南町の桐楊塾は、監督が祖母さんで、同窓が嬢たちで、更に憚る処が無いから、天下泰平、家内安全、鳳凰は舞い次第、英吉は遊び放題。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川中興の名将軍吉宗公の後を受けた天下泰平の真盛り。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり異性に対して恍惚としていられる方の気持はともかくもダレていて、天下泰平ノンビリフンナリしているところがあります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎から出てきた叔父さんが天下泰平の長逗留をする。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖武天皇は仏教に依つて、国家を治めようと思召し、天下泰平、国土｜安穏を祈らせ給うて、国毎に国分寺を建てられ、総国分寺として奈良の東大寺を建立された。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この君戴いて天下泰平、諸民安堵！",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の平民的性格の中にこうしたブル気分が流れ込んだ原因の中には、天下泰平から来た武士の無力と、彼等の富の膨張も勿論加わっているのであるが、とにかくこうして彼等の気象の中には次第に亡国的気分があらわれて来たのである。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "円満円満、天下泰平。",
              "citation": {
                "source": "不在地主",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで済めば天下泰平、いや、些とぐらいの騒動が起っても大丈夫であったのですが、こゝに一つの事件が出来した。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下泰平とおいでなすったね」　取りとめもない独白のあとは、鼻にかかる何やら音頭の歌い放し。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "此位天下泰平な事はないでせう。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "この位天下泰平な事はないでせう。",
              "citation": {
                "source": "雲は天才である",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは天下泰平の夢を見続けて、今に至るまで一つの組合さえ持たなかったのである。",
              "citation": {
                "source": "映画界手近の問題",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下泰平、徃生安楽国、ムニヤムニヤアーメン。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "是を亡國で無い、日本は天下泰平だと思つて居るのであるか。",
              "citation": {
                "source": "亡國に至るを知らざれば之れ即ち亡國の儀に付質問",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "扨いよ／＼天下泰平になって、私が彼の買屋敷の内に住い込んで居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに文字の義を細かに論ぜずして民間普通の語を用うれば、天下泰平・家内安全、すなわちこれなり。",
              "citation": {
                "source": "教育の目的",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人あるいはいわく、天下泰平・家内安全をもって人生教育の極度とするときは、野蛮｜無為、羲昊以上の民をもって人類のとどまるところとなすべし。",
              "citation": {
                "source": "教育の目的",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに天下泰平・家内安全の快楽も、これを身に享くる人の心身発達して、その働を高尚の域にすすむるときは、古代の平安は今世の苦痛不快たることあるべし。",
              "citation": {
                "source": "教育の目的",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、贋首が判ったって、天下泰平。",
              "citation": {
                "source": "三人の相馬大作",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下泰平のそのためには、甘んじて賊臣の汚名を受け、しかも俯仰天地に恥じず、どうどうと所信を貫いた。",
              "citation": {
                "source": "大捕物仙人壺",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下泰平国土安穏、今日の御祈祷なり。",
              "citation": {
                "source": "よくぞ能の家に",
                "author": "二十四世　観世左近",
                "note": "青空文庫"
              }
            },
            {
              "text": "総ての大夫は「翁」を心から神聖視して「天下泰平、国土安穏」の祈祷として勤めたから、その見識もまた大層なものであつた。",
              "citation": {
                "source": "よくぞ能の家に",
                "author": "二十四世　観世左近",
                "note": "青空文庫"
              }
            },
            {
              "text": "お話申した如く、封建時代に於ては、武士が刀を以て百姓を抑へて居つたのですが、天下泰平となつては刀では利かないで、利くのは黄金の力のみとなつた。",
              "citation": {
                "source": "日本の眞の姿",
                "author": "竹越與三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "琴にて、てんかたいへい。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
