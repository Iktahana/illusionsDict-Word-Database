    "definitions": [
      {
        "index": 1,
        "gloss": "one's subordinate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ひと一人、くらい境遇に落ち込んだ場合、その肉親のうちの気の弱い者か、または、その友人のうちの口下手の者が、その責任を押しつけられ、犯しもせぬ罪を世人に謝し、なんとなく肩身のせまい思いをしているものである。",
              "citation": {
                "source": "緒方氏を殺した者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "若や重太郎か、但しは追手の者かと、お葉は眼を据えて透し視る間に、人か猿か判らぬような者が雪を蹴ってちょこちょこと飛び込んで来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行上手の者に到っては、事情がまるで正反対である。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "其中に西村左馬允という者があって、大の男の大力の上に相撲は特更上手の者であった。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の敵城あることをば某も存ぜず候間に、先手の者ども、はや攻落して候、と空嘯いて片付けて置いて、扨それからが反対に政宗の言葉に棒を刺して拗って居る。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "名妓と言われるほどのものは、その旦那と共に手の者の芸人を集め、花柳街に一つのグループとして勢力を張る。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから手の者の芸人に猛者を得ることに、彼女等は腐心したのであって、つゞまるところわたしはお品のプロパガンダの道具に使われたに過ぎないが、しかし、わたしをそうしたに就て、下町の名妓の好みもあった。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でもそんな者はおりません」「争いは無益じゃ、家探しして捕えめされ」　討手の者は頭の声と共に、ばらばらと寺の中へ駈けあがった。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "討手の者は皆其処へ集まって来た。",
              "citation": {
                "source": "八人みさきの話",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桑名藩より、徳川殿｜今度勅命により召寄せらるるにより、先手の者上京する由を告げたが、薩兵聴かず、問答を重ぬる裡、薩州より俄に大砲を打ち出したが、最初の一発に桑名の兵、十数人打ち重って倒された。",
              "citation": {
                "source": "鳥羽伏見の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのころ、畿内を分領していた筒井、松永、荒木、和田、別所など大名小名の手の者で、『鎗中村』を知らぬ者は、おそらく一人もなかっただろう。",
              "citation": {
                "source": "形",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いちいち説明をすれば際限もありませんが、彼は何故ともなくその面前では相手の者を信用させる徳か技に似たものを持つてゐますが抽象的には断じて信用の出来兼ねぬ銀ながしだ左うであります。",
              "citation": {
                "source": "月あかり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "津村正恭の『譚海』二に、丹後の由良の湊に逆沓という故事あり、つれ王丸という冠者、三荘太夫が許を逃れて京へ登る時に、雪中に沓を跡になし穿きて逃れたる故、雪に附ける足跡奥の方へ行けるように見えしかば、追手の者奥の方を尋ね求めし故、遁れて京へ入る事を得たりという。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃井か、山名か、塩冶を追っ手の者と見申した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今しがた通り過ぎた人数が果たして塩冶を追っ手の者どもであるなら、落人はかしこの村で追い付かれたのであろう。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "先手の者が馳せ帰って、「青木新兵衛大坂城の一番乗り仕って候」と注進に及ぶと、忠直卿は相好を崩されながら、「新兵衛の武功第一じゃ――五千石の加増じゃと早々伝えよ」と、勇み立とうとする乗馬を、乗り静めながら狂気のごとくに叫んだ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "村では犬神持ちと云われている家があって、その家にいる犬神は其処の家人の心のままになって、対手の者に憑いた。",
              "citation": {
                "source": "村の怪談",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おーい、お勝手の者――ほんとうの酒を持つて来て呉れ。",
              "citation": {
                "source": "南風譜",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来カンの悪い婆さんで稍ともすれば飛んだ独り合点をして相手の者をまごつかせたが、ひとり私の母は巧みな手真似をもつて円滑にはなし合へる程の仲だつた。",
              "citation": {
                "source": "剥製",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「山の手の者が川向うまで頭を刈りに来る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "歩兵の髪切り",
                "note": "青空文庫"
              }
            },
            {
              "text": "成経が、それに堪えかねて、二｜言三｜言言葉を返すと、俊寛はすぐかっとなって、成経に掴みかかろうとして、基康の手の者に、取りひしがれた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに惹かれて相手の者も、無造作に眼を挙げ、「粉になッちまふヅラァ！",
              "citation": {
                "source": "環魚洞風景",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、相手の者から迷惑さうに問ひ返されて、酔払ひの彼は、思はずハツとして言葉を濁らせることが屡々あつた。",
              "citation": {
                "source": "鏡地獄",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は風帆船が早かった時代もありしかど、蒸気船を知りて居る眼より見れば風帆船は遅しと申すが至当の理に有之、貫之は貫之時代の歌の上手とするも前後の歌よみを比較して貫之より上手の者ほかに沢山有之と思わば、貫之を下手と評することまた至当に候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は風帆船が早かつた時代もありしかど、蒸気船を知りてをる眼より見れば、風帆船は遅しと申すが至当の理に有之、貫之は貫之時代の歌の上手とするも、前後の歌よみを比較して貫之より上手の者外に沢山有之と思はば、貫之を下手と評することまた至当に候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔は風帆船が早かつた時代もありしかど蒸氣船を知りて居る眼より見れば風帆船は遲しと申すが至當の理に有之貫之は貫之時代の歌の上手とするも前後の歌よみを比較して貫之より上手の者外に澤山有之と思はゞ貫之を下手と評すること亦至當に候。",
              "citation": {
                "source": "歌よみに與ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなら拙者は手の者と玉造組とを連れて出ることにいたしませう。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "跡部は坂本が手の者と、今到着した与力四人とを併せて、玉造組の加勢与力七人、同心三十人を得たので、坂本を先に立てて出馬した。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして始て敵に逢つて混乱してゐる跡部の手の者を押し分けながら、天神橋筋を少し南へ抜けて、豊後町を西へ思案橋に出た。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の淡路町を大塩の同勢が一歩先に西へ退くと、それと併行した南の瓦町通を坂本の手の者が一歩遅れて西へ進む。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
