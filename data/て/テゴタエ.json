[
  {
    "uuid": "2cc48c64-f167-56e8-8aa7-7b3b41bf1dbc",
    "entry": "手応え",
    "reading": {
      "primary": "てごたえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
