          "literary": [
            {
              "text": "（昭和八年五月『鉄塔』）",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年十一月『鉄塔』）",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年十二月、鉄塔）二　錨と怒り、いずれも「イカリ」である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年四月、鉄塔）三　春（ハル）のラテン語が ver であるが、ポルトガル語の 〔vera:o〕 は夏である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年七月、鉄塔）四「ウミ」（海）のヘブライ語が 〔ya_m〕 である。",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年八月、鉄塔）",
              "citation": {
                "source": "言葉の不思議",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年九月『鉄塔』）",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年十月、鉄塔）",
              "citation": {
                "source": "科学者とあたま",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年一月、鉄塔）",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついでに屋上さらに三四百尺の鉄塔を建てて頂上に展望台を作るといいと思う。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の体が鉄塔ごと左右に大きくゆれてゐるやうな錯覚も感じた。",
              "citation": {
                "source": "登つていつた少年",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "エッフェル鉄塔が夜と昼とでは、約七尺弱、高さに異変を生ずるなど、この類である。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "北斎にいたつては、その頂角、ほとんど三十度くらゐ、エッフェル鉄塔のやうな富士をさへ描いてゐる。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭は高峯のごとく眼は電光のごとく双角は両座の鉄塔に似たり。",
              "citation": {
                "source": "悟浄歎異",
                "author": "―沙門悟浄の手記―",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつと抜けると水之尾道の高圧線の鉄塔の下に出る。",
              "citation": {
                "source": "蜜柑山散策",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "湧きのぼる沖べの煙むらさきに消えもやらずて、神のごと美しきもの鉄塔のうへに坐ししを。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "鋼鉄風景神は在る、鉄塔の碍子に在る。",
              "citation": {
                "source": "海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "真夏真夏なり、鉄塔のよき間隔、ちちと、ちちと、飛び撓む鳥。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "月に寄せて言問はむ、鉄塔の上に坐す円かなる月読の神、二三すぢ細み引く茜の雲。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "凛烈たる霜、霜は湖畔の鉄塔を噛む。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "下手の空際には高圧線の鉄塔が見える。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭和九年四月砧村の雲と鉄塔の下にて白秋識天王寺墓畔吟大正十五年の、谷中天王寺墓畔に於ける生活に由る。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の砧村大蔵の野に於ける鉄塔と雲との風景は快適、日月ともに明らかにして、季節の推移亦おのづからなる玄理にかなふ。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年二月、鉄塔）",
              "citation": {
                "source": "藤の実",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄塔神の霊異　蔚州の城内に寺があって、その寺内に鉄塔神というのが祭られているが、その神霊｜赫灼たるものとして土地の人びとにも甚だ尊崇されていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを他の僧らに話したが、誰も信じる者がないので、講師も一時はやや躊躇したが、鉄塔神の霊あることはかねて知っているので、とうとう思い切って自分だけの荷物を取りまとめて、寺のうしろの山へ逃げ登った。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "夷堅志",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛行甲板の下は、太い数十本の組立鉄塔で支えられている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その鉄塔は水面下に没していて下はよく見えないが、話によると一本一本のその鉄塔は下に大きな鉄筋コンクリートのうきを下駄のように履いているという。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
