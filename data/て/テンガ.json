[
  {
    "uuid": "2d00a1b8-6b7f-56f6-96df-7d6eb663bfd5",
    "entry": "典雅",
    "reading": {
      "primary": "てんが",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
