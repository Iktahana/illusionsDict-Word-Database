    "definitions": [
      {
        "index": 1,
        "gloss": "resistance level (e.g. in share prices)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
