        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rolling about",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文徳実録に見える席田郡の妖巫の、その霊｜転行して心を心の二字が祇尼法らしいから、随分と索隠行怪の徒には輾転伝受されていたのだろうと思われる。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "など低く口に出して言ってみたりして、床の中で輾転しているのである。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "世外の老人の死だから、五年やそこらは何れが真実でも差支は無いが、想うに書写｜輾転の間に生じた何れかの誤りなるのみであろう。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎夜、毎夜、万朶の花のごとく、ひらひら私の眉間のあたりで舞い狂う、あの無量無数の言葉の洪水が、今宵は、また、なんとしたことか、雪のまったく降りやんでしまった空のように、ただ、からっとしていて、私ひとりのこされ、いっそ石になりたいくらいの羞恥の念でいたずらに輾転している。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時、想世界の敗将気｜沮み心疲れて、何物をか得て満足を求めんとす、労力義務等は実世界の遊軍にして常に想世界を覗ふ者、其他百般の事物彼に迫つて剣鎗相｜接爾す、彼を援くる者、彼を満足せしむる者、果して何物とかなす、曰く恋愛なり、美人を天の一方に思求し、輾転反側する者、実に此際に起るなり。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに発露刀一たび彼の心機を断截するや、彼は自ら依怙するところを喪ひたり、仏智はこの一瞬間に彼の中に入り、彼をして照明の心鏡に対せしめ、慚愧苦憂、輾転煩悶せしめ、然る後に自己を寄するところを知らしめたり。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁から忍び笑いの声が聞えて来て、深夜、床の中で輾転しているのです。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝付が悪いというお久が今夜は熟睡って、寝坊だと笑われている自分が今夜は何うして睡られそうもないので、お菊は幾たびか輾転した。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端に、隣に寝ていたお久が不意に此方へ向いて輾転を打った。",
              "citation": {
                "source": "黄八丈の小袖",
                "author": "岡本椅堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "横になりはしたがいつまでも寝つかれないで二時近くまで言葉どおりに輾転反側しつつ、繰り返し繰り返し倉地の夫婦関係を種々に妄想したり、自分にまくしかかって来る将来の運命をひたすらに黒く塗ってみたりしていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして苛いらしながら七日の間、いろいろのことを考えながら輾転反側しているうちに、かえって私の肉体は日増しに丈夫になっていって、寝室の鏡にうつしてみても平常と変わりがなく、ふたたびもとの人間らしくなった。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "幻の人力車",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は不眠のために夜の明けるまで床の中に輾転していたことを思い出す。",
              "citation": {
                "source": "動物園の一夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "無意識に輾転反側した。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "疼痛、疼痛、かれはさらに輾転反側した。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "病気か」　「ああ苦しい、苦しい……」　とはげしく叫んで輾転した。",
              "citation": {
                "source": "一兵卒",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その歌集を貰った時分、私は青山に住んでいて、生活のうちに落付けず、輾転反側していた時代であった。",
              "citation": {
                "source": "作品の血脈",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "決して一人の機敏な精力的な女がアナーキイに感情の二つの極から極へとのびうつる輾転反側では解決しない。",
              "citation": {
                "source": "中国に於ける二人のアメリカ婦人",
                "author": "――アグネス・スメドレーとパァル・バック――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　内心の熱い輾転反側は彼女が十七歳の秋、ジュリアンのアトリエに通いはじめて、やっと一つの方向を見出したように見える。",
              "citation": {
                "source": "マリア・バシュキルツェフの日記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の文学は、世相の激動につれて非常に動揺し、ある意味では文学としての基準を失い、男の作家たちの多数が、卑俗に政治化したり、非文学的な著述業に堕したり、自身の文学的境地打開のための輾転反側に陥った。",
              "citation": {
                "source": "婦人の文化的な創造力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行は輾転反側のように見えた。",
              "citation": {
                "source": "カール・マルクスとその夫人",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の若い娘が、もしああもこうも考える力をもっていると云うならば、その考える力を輾転反側の動力として空転りさせないで、考える力をあつめて、生涯を貫く一つの何かの力として身につけなければ意味ないと思う。",
              "citation": {
                "source": "若い娘の倫理",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらによりよい人間の生活の可能を発見しようとしてのもがきであり、試みであり、輾転反側であることは疑いないことを確信していると思う。",
              "citation": {
                "source": "働く婦人の新しい年",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "寝台に輾転反側して、眠りが来るようにしきりに祈りながら、一生懸命に眼をつぶっていると、そのうち、何処か高いところからでも墜落するように、急に眠り出したものとみえる。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでもどうにか長靴をぬがせると、主人は曲りなりにも着物を脱いで、寝台をガタビシとやけに軋ませながら、暫らくのあいだ輾転反側していたが、やがてのことに、すっかりヘルソン県の地主になったような気持で、ぐっすり寝こんでしまった。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "この美女は夜つぴて上掛の下で輾転反側して、一睡もすることが出来なかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "済まねえけど少し貸してくんねえ」　「俺もすってんてんにいかれてしまって、これっきりよ」　と銭二三枚袂から出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が顏の吹出物へ、三角形や六角形や花の形に切つた絆創膏をてんてんと貼り散らしても誰も可笑しがらなかつた程なのである。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "母屋へ通る豆畑のあひだの狹い道を、てんてんと一列につらなつて歩いて行く皆のうしろへついて、私は陽氣にはしやぎながら豆の丸い葉を幾枚も幾枚もむしりとつた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ども夫婦ばかりでなく、あの人に見込まれて、すってんてんになってこの寒空に泣いている人間が他にもまだまだある様子だ。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が顔の吹出物へ、三角形や六角形や花の形に切つた絆創膏をてんてんと貼り散らしても誰も可笑しがらなかつた程なのである。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
