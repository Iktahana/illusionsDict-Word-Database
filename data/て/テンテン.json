  {
    "uuid": "5b5255cb-e10a-56d3-b637-07d14731ac14",
    "entry": "輾転",
    "reading": {
      "primary": "てんてん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
