        "examples": {
          "standard": [
            {
              "text": "刺身の醤油を入れるのに、ちょうど良い大きさの手塩皿を選んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "食器棚には、様々な形や色の手塩皿がコレクションのように並んでいる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "一人分のお浸しを盛り付けるのに、涼しげなガラス製の手塩皿を使った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "醤油注ぎ、手塩皿、ちりれんげ、なぞの載っている盆を持出した。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手塩皿の溜醤油に片れの一角を浸し熱さを吹いては喰べた。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲丹だの海鼠腸だの、お文の好きなものを少しづゝ手塩皿に取り分けたのや、其の他いろ／＼の気取つた鉢肴を運んで置いて、女中は暫く座を外した。",
              "citation": {
                "source": "鱧の皮",
                "author": "上司小剣",
                "note": "青空文庫"
              }
            },
            {
              "text": "手塩皿もってきて大吉、型をとるから。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
