[
  {
    "uuid": "0fa99e93-506d-56df-8a53-d522eaa8afaa",
    "entry": "点鼻",
    "reading": {
      "primary": "てんび",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "taking medicine nasally",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "頭や咽喉の病気に特に適すると思われる点鼻薬は頭をはっきりさせるときや強くすときに使った。",
              "citation": {
                "source": "医学の歴史",
                "author": "History of Medicine",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなうなぎをつかんだといって、両方の手の指で、てんびんぼうほどの太さをして見せるので、ほんとうかと思っていってみると、筆ぐらいのめそきんが、井戸ばたの黒いかめの底にしずんでいるというふうである。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "三角のすげ笠をかぶつた安南の百姓女が、てんびんをかついでトラックに道をゆづるのもゐた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チビ公は肩のてんびん棒にぶらさげた両方のおけをくるりとまわした。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こらッ」　生蕃の手がてんびん棒にかかった、とこのとき電柱の陰から声が聞こえた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "生まれてはじめててんびん棒をかついだので母はがっかりつかれて、肩を冷水で冷やしていた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やあやあ勇敢勇敢」と森君は喝采した、千三は球が石のどぶ端を伝って泥の中へ落ちこもうとするやつをやっとおさえようとした、てんびん棒が土塀にがたんとつきあたったと思うとかれははねかえされて豆腐おけもろとも尻餅をついた。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいれ」と先生はてんびんをおろしてからいった。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ石垣の急な段々を一段一段用心ぶかく下りながら、鉢巻をした爺さんが、発動汽船の油の罐をてんびん棒でになって、小舟へつみこんでいる。",
              "citation": {
                "source": "日記",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "海の方から、若い女が、かごの中にたくさんのたいを入れて、てんびん棒でかついで村の中へはいってきました。",
              "citation": {
                "source": "女の魚売り",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、岩の近くにきて、肩からてんびん棒をはずして、かごを湿った砂の上に下ろしました。",
              "citation": {
                "source": "女の魚売り",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の黒い蓬々とした、脊のあまり高くない、色の白い男で、石油のかんを、てんびん棒の両端に一つずつ付けて、それをかついでやってくるのでした。",
              "citation": {
                "source": "火を点ず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどそのとき、隣家の軒下では、男は肩からてんびん棒を下ろして、四十｜前後の女房が汚れた小さな石油を入れるブリキのかんを手に下げて出てきました。",
              "citation": {
                "source": "火を点ず",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "にない棒を二本、左右の手に一本ずつ、四本の指に真中を載せ、てんびんに持ちて立つなり。",
              "citation": {
                "source": "妖怪学",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんびん棒かなんかで、殴り殺しにでもしなきや、腹の虫がいえねえんですからね――。",
              "citation": {
                "source": "金魚は死んでいた",
                "author": "大下宇陀児",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
