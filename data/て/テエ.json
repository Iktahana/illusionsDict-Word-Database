        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あ、いてえ、いてえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いや、おれはいつそ死にてえ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「へべれけに酔っ払いてえなあ。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして何もかも打ち壊して見てえなあ」と怒鳴った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て鬼だ」「船長ってえ鬼だったよ」「大笑いさすなよ。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前さんたちがどんなに田舎者見てえな恰好をしてたって、番頭に化けたって、腰弁に化けて居たって、第一、おめえさんなんぞ、上はアルパカだが、ズボンがいけねえよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "たった一日俺もグッスリ眠りてえや」　彼等は足駄を履いて、木片に腰を下して、水の流れる手拭を頭に載せて、その上に帽子を被って、そして、団扇太鼓と同じ調子をとりながら、第三金時丸の厚い、腐った、面の皮を引ん剥いた。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "安田が死んでるんだぜ」「死んだ程、俺も酔っ払って見てえや、放っとけ！",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "アインシュタインの仕事の偉大なものであり、彼の頭脳が飛び離れてえらいという事は早くから一部の学者の間には認められていた。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の何日頃であったか、表の呉縁に朝日が暖くさしてる所で、自分が一人遊んで居ると、姉が雑巾がけに来て「坊やはねえやが居なくても姉さんが可愛がってあげるからね」と云ったら「ねえやなんか居なくたってえいや」と云ってたけれど、目には涙を溜めてたそうである。",
              "citation": {
                "source": "守の家",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は自分を見るや泣き声を絞って、何だってもう浮いていたんですものどうしてえいやらわからないけれど、隣の人が藁火であたためなければっていうもんですから、これで生き返るでしょうか……。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ」　「七五郎って人が、折入って親分に話してえ事があるそうで、此処に来て居りますが」　「七五郎？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだ」　「清水港の長五郎って人が来て、親分にお目に掛りてえと言って下に居りますが……」　「清水の長五郎？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝庭　「清水の御貸元、裏口がこっちにあります」　「そうか、有難てえ」　石松、次郎長を庭の彼方の裏口へ案内する。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "石松、　「父っつあん、清水の御貸元が夜の明ける迄何処かで休みてえと仰言るから俺が家へお連れ申したんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半五郎、フト思い出して、　「じゃ源兵衛さん、うちの親分の身内になりてえと云う石松ってなァ」　「そうよ、俺の伜だ」　「ほう、じゃ、あの当時、いつも姐さんに抱かれてたあの子供が、そうかい？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なーんだ、父っつあん、自分がやくざのくせに今迄俺がやくざになりてえと云うと目の色かえて叱るのは可笑しいや」石松は嬉しいから、多少はしゃいで言う。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「併し折角帰って来たんだから俺ァお半の処へ一寸寄って行きてえなァ」　「この野郎暢気な事云ってやがらァ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「嫌いじゃないけど……大きくなって貴ン方みた様な男になると、困るから……」　「俺みてえな男って？",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これは爺っつあんか、俺ァ都田村の吉兵衛って者だ」　「はい……」　「石松つあんとは以前からの友達だ」　「久し振りに二人で一杯やりてえと思って来たんだが……まだ帰って来ねえのか」　「石松が帰って来るので御座いますか」　「なんだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　七五郎、　「――手や爪を綺麗にして毎晩酒の一本も呑める身分になってみてえ……」　お民、　「お酒だったの。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「日に二度も来ることがあるわ、あの人達、兄さんに何の用事かしら」　「なーに彼奴等、石松と兄弟分になりてえンだろう、きっとそうだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　「実は俺を次郎長親分の身内に加えて貰えねえだろうか」　「お前が……親分の身内になりてえって……」　「俺も、おッ母ァが居なくなって、誰にも遠慮も要らねえし、何時迄もこんな田舎でくすぶってるのは厭だから……やくざになって一生を楽しく暮そうと決心したンだ」　「七五郎、其奴ァよくねえ考えだ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「誰もいねえ、いねえてえのに」　児分達、梯子を掛けて駈けあがる。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次観念してシャアシャアと、Ｔ「今日も亦旦那の糞詰り見てえな面にぶつかりやしたね」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯が食いてえな」　よろしゅう御座ると左衛門。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　なりひらが、Ｔ「くでえなあ」　と言って、Ｔ「なりひら小僧は江戸ッ児だよ」Ｔ「江戸ッ児って奴ァ昔から」　と尚、Ｔ「近頃のチャンコロ見てえな」　と言って、Ｔ「二枚の舌使わねえから安心しな」　と大笑いだ。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、Ｔ「面倒だ　両人共斬り捨てえ」　ハハッと家臣、今度は、二人に斬り付ける。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この方が温くうてえい！",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
