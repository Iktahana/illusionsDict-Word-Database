    },
    "definitions": [
      {
        "index": 1,
        "gloss": "not having enough workers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それにはその本場の作品を、読むことよりほかには手がないと思はれる。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ登るには、ロッククライミング以外に手がない。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "豪胆で殺伐なことが好きで、よく銃剣を振るって、露西亜人を斬りつけ、相手がない時には、野にさまよっている牛や豚を突き殺して、面白がっていた、鼻の下に、ちょんびり髭を置いている屋島という男があった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしばらくだれか遊ぶ相手がないかさがしているようでした。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たれか引き取り手がないものかナ。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ親子ふたりの男世帯で、女の手がないのですから、こんな時にはお給仕にも困ります。",
              "citation": {
                "source": "怪談一夜草紙",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "失望と煩悶とがごツちやになツて耐へず胸頭に押掛ける………其の苦惱、其の怨、誰に訴へやうと思ツても訴へる對手がない。",
              "citation": {
                "source": "平民の娘",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "この間山を少しばかり売ろうと思ってちょっと分家に当たってみたところ、買わないというから、誰か買い手がないか聞いてみてくれないかと頼んでみたけれど、おいそれとすぐ買手がつくものでないから、止した方がいいだろうと言うんだ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "碁、将棋の類は好きであるが、友人との交際がない私は、めったに手合せする相手がないので、結局それもしないじまいでいる次第だ。",
              "citation": {
                "source": "秋と漫歩",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お洒落しゃれても惚れ手がないよ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな噂がひろがって、その後は誰も借り手がない。",
              "citation": {
                "source": "月の夜がたり",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お安が雇い人であれば、その主人に掛合うというすべもあるが、本人が主人では苦情を持ち込む相手がない。",
              "citation": {
                "source": "恨みの蠑螺",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ふくれツ面をして、「別に話し相ひ手がないから。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "その空屋の借手がないために、屍体がいつまでもいつまでも発見されないでいる。",
              "citation": {
                "source": "書けない探偵小説",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして利用するだけ利用して最早使い手がないとなると弊履の如く棄ててかえりみないところに、彼の腕前のスゴサが常に発揮されて行くのである。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりほかに、今のこの情けない心の状態を救う手がないと思った。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、大きな躓物の石は、私に元手がないということにありました。",
              "citation": {
                "source": "患者兼同居人",
                "author": "THE RESIDENT PATIENT",
                "note": "青空文庫"
              }
            },
            {
              "text": "駕籠は……四本竹に板を渡したほどなのがあるにはある、けれども、田植時で舁き手がない。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "東じゃ、品川から川崎続き、横浜、程ヶ谷までも知っていて対手にし手がないもんですから、飛んで、逗子、鎌倉、大磯ね。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かのはずみでにらめっこイベントの担当者にでもさせられて、どうあってもこの成功を期する立場に追い込まれたとすれば、清盛さんにでもおでまし願って浮川・溝口連合軍とのスペシャル・マッチでも用意するしか手がないね、実際のところ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのマッキントッシュを真似ようとするＷｉｎｄｏｗｓを紹介するとすれば、六、七年前からアップルのユーザーが耳にタコができるほど聞いてきた話をもっともらしく今になって繰り返すしか手がないという苦しい事情には同情する。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はひどく仲を好くして、一しょに遊んでいるようだが、それは外に相手がないから、小さい同志で遊ぶのであろう。",
              "citation": {
                "source": "ヰタ・セクスアリス",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしくしとれば、人の憐みもかかるが、強いことをいうと、こういう際にだれも相手になり手がないからな」「自分によくいって聞かせとくがいいや、おれらのことならお世話にゃならないや。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教をぬすんでこいつだけは只でくれても我々の世界では貰ひ手がない。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "男手がないと何となく心細くってよ。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "だれも話をする相手がないからだらうかと思つて見る。",
              "citation": {
                "source": "赤い鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして、そういう、くだらないアイディアしか思いつかないんだ」「ほかに手がないんだから、しかたないだろ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも直ぐの兄に当る二十七、八になる一人息子が、家｜土蔵をなくするほどの道楽をした揚句、東京で一旗上げると言って飛び出した切り、行方を晦ましているそうで、年｜老った両親は誰も構い手がないままに、喰うや喰わずの状態でウロウロしているそうです。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし別にどこというきまったあてがない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教では、この大きな天地も、私たち小さな人間のいのちも、その根もとで一つに親密に繋がり融け合って、分け距てがないことを教えております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
