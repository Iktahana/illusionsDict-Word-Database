        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一字一字文字を選び、指定の字詰めに合わせて仕上げた印画紙を台紙に張り込み、訂正の求めに応じて手作業で文字の張り替えを進めます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "編集プロダクションという、いろいろやっかいな作業が吹き寄せられてくる下請けで働いていた私は、はさみとのりを使ったプリプレスの手作業に、一般の編集者よりはよほどなじんでいました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと点字化は、先に針の付いた点筆や点字タイプライターを使って、手作業で進められてきた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕切り直し後は、ウェッブページの約束事を定めているＷ３Ｃ（World Wide Web Consortium）の勧告ＸＨＴＭＬ1.1にそった形式を選び、しつらえも揃え、新たにＸＨＴＭＬ版作成用のプログラムを開発して、テキスト版から手作業なしで、自動生成する形に切り替えた。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて第三水準第四水準に向けた選定用資料をまとめた際は、もっぱら手作業に頼るしかなかった。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずパネル上に並んでいるスイッチを上げ下げし、ごく短い機械語のプログラムを手作業で入れていく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "手作業の、ハンドアセンブルを進めていく。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジャカードも自動ピアノも、カードにあけた穴の位置によって機械の動作を制御している点に着目したホレリスは、個人のデータを一人一枚同様の穿孔カードに記入することで、集計から手作業を追放できると考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレルは引き続いてアップル※に注文をかけてくれたが、その一方でベーシックインタープリターをいちいち手作業で入力しているようではこのマシンに大きなチャンスはないと考え、カセットテープレコーダーとのインターフェイスを開発するよう強く求めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空文庫の蔵書数が飛躍的に増えはじめたために、作品の管理を手作業で行なうことに無理が生じてきたのだ。",
              "citation": {
                "source": "青空文庫ものがたり",
                "author": "インターネット図書館の開設から今日まで",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓、老婦、手作業者、床屋および床屋―外科医――これらの人たちはしばしば知る価値のある知識を持っていた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はまた手作業職人の労働時間の法的制限を要求した。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
