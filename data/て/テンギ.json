  {
    "uuid": "0f74535c-03b0-5d3a-82c1-2a65045abe66",
    "entry": "天喜",
    "reading": {
      "primary": "てんぎ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
