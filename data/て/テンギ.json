    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Tengi era (1053.1.11-1058.8.29)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうしてヤットの思いで気に入った名前を発見した時のその作家の喜びようといったら、それこそ歓天喜天、手の舞い足の踏むところを知らなかったという。",
              "citation": {
                "source": "創作人物の名前について",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼近世の小説は歓天喜地愉快を写さずして、総て悲哀を以て終らざる可からざる乎と。",
              "citation": {
                "source": "舞姫",
                "author": "石橋忍月",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は治承の春、世は平家の盛、そも天喜、康平以來九十年の春秋、都も鄙も打ち靡きし源氏の白旗も、保元、平治の二度の戰を都の名殘に、脆くも武門の哀れを東海の隅に留めしより、六十餘州に到らぬ隈なき平家の權勢、驕るもの久しからずとは驕れるもの如何で知るべき。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんじの場合も、尚円を神号「金丸按司添」、尚清を神号「天続之｜按司添」、尚元を「月始按司添」、尚寧を「目賀末按司添」、尚豊を「天喜也末按司添」とつけてゐる。",
              "citation": {
                "source": "日琉語族論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、眞に觀天喜地のうれしさでありました。",
              "citation": {
                "source": "浪",
                "author": "石川三四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆桶を抜くがごとく痛快なる悟りを得て歓天喜地の至境に達したのさ」　あまり迷亭の言葉が仰山なので、さすが御上手者の鈴木君も、こりゃ手に合わないと云う顔付をする。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かんだ」や「こまがた」や「はんてんぎ」では妙に近代的理性的で、つまり乙ゥ啖呵が切れないからでさぁと生前、事あるごとに教えてくれた。",
              "citation": {
                "source": "寄席行燈",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
