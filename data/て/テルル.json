          "standard": [
            {
              "text": "「テルル」は、周期表の酸素族に属する半金属元素だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼の研究室では、「テルル」を使った新しい太陽電池の開発が進められている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「テルル」の原子番号は52で、元素記号はTeと表記される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "エラリー教授はその不思議な合金の中に白金、鉄、テルルを見いだしたが、他にも少なくとも三種類の元素が含まれることが明らかで、それらは大きな原子量を持ち化学的には全く同定できない物質だった。",
              "citation": {
                "source": "魔女の家で見た夢",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            }
          ]
        }
