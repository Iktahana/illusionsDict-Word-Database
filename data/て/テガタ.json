          "standard": [],
          "literary": [
            {
              "text": "高知市附近で「鴫突き」というのは、蜻※を捕えるのと同じ恰好の叉手形の網で、しかもそれよりきわめて大形のを遠くから勢いよく投げかけて、冬田に下りている鴫を飛び立つ瞬間に捕獲する方法である。",
              "citation": {
                "source": "鴫突き",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "バビプによって手術された近代女のヴァルバ、マルセル・ウェーブによって美の典型を指示した化粧術、最もきわどいエルンスト・フルウ氏の子宮除去法、知人の政府委員はメイ・フレデリックの美顔術によってマルクス学の国家理論さえ見下す約束手形を振り出した。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とごま白の乱髪に骨太の指を熊手形にさしこんで手荒くかいた。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えて見れば黄金や宝石だって人生に取って真価値があるのではない、やはり一種の手形じゃまでなのであろう。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "為替や手形にデュープリケートの写しを添えるよりもいっそう手堅いやり方なのである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この方は手形さえあれば、曲りなりにも関所が通られると思うと、五｜度に一度、それさえ半年の間なんだ、……小遣を貯めるんだからね。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も誰も一見して直ちに館の飼犬だということを知って、これを従えた者は、知事の君と別懇の者であるということを示す、活きた手形のようなジャムの奴が、連れて出た己を棄てて、滝太郎の後から尾を振りながら、ちょろちょろと入ったのであった。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "淵沢小十郎はすがめの赭黒いごりごりしたおやじで胴は小さな臼ぐらいはあったし掌は北島の毘沙門さんの病気をなおすための手形ぐらい大きく厚かった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云ふのは代金の証書としては会社の手形で松村と、も一人奥田と云ふ松村の同僚の裏書が条件となつて居た。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸畑に対する責任は手形の振出人たる信托会社と裏書人たる松村個人とがある。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに此訴訟関係を解決する方法として当会社が約束手形の振出人となることは理義に合はない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "此外に約束手形の期限のことなども書添へてあつた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "之が俺の本心である、どこまでもやると覚悟をしてしまへば、手形の形式はどうでもいい。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともとこの手形は外へ廻さず、取立には交換にもかけないと云ふ約束なんだから、会社の名誉が外から損はれる訳はない。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜になつて、僕を電話で呼んで、手形の形式はいいかつて云ふんでせう。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "水は川から灌いで、橋を抜ける、と土手形の畦に沿って、蘆の根へ染み込むように、何処となく隠れて、田の畦へと落ちて行く。",
              "citation": {
                "source": "海の使者",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その閂の上までも一面に、蜘蛛手形に蔦の枝が匍っている。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "考へて見れば黄金や宝石だつて人生に取つて真価値が有るのでは無い、矢張り一種の手形ぢやまでなのであらう。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランス人のブローカーが彼の居間に自由に出入して殖民地の一獲千金的紙上利益をタイプライターが創造しているだけの計画書を示し、彼に荘重な約束手形の署名をさせるようになった。",
              "citation": {
                "source": "バットクラス",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "贋手形で関所は抜けられるかも知れんが吾々の眼の下は潜れんば……のう……」「そうじゃそうじゃ……のうヨカ稚児どん。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "返す返すの御親切……関所の手形は仇討の免状と共々に確と所持致しておりまする。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "讐仇の生国、苗字は申上げかねまするが、御免状とお手形だけならば只今にもお眼に……」「ああイヤイヤ。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "但、御用繁多の折柄に付、広周一存を以て諸国手形相添え差許者也。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっともあの女も最初は、まだ評判の広がらぬ中に、御免状とお手形を使うて、関所を越えようという一心から、敵討に扮装ったもので御座いましょう。",
              "citation": {
                "source": "斬られたさに",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "云わば約束手形が沢山出されていたのである。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "転がった者は町役人に請手形を入れさして、俵を解いて赦してやった。",
              "citation": {
                "source": "切支丹転び",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "右のかくしには信用手形を入れ、左のかくしには、旅券を入れていました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "あちらはいつも夏景色で、その上、この信用手形でお金が取れるのだろうが。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "税關の調べ二度、手形の改め三度あるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "領分境に至りて、手形改めあるべしとて、人々車を下りぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            }
          ]
        }
