    "definitions": [
      {
        "index": 1,
        "gloss": "four-of-a-kind (in a dealt hand)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（天罰は立ち処じゃ、足四本、手四つ、顔二つのさらしものにしてやるべ。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いでわれ親ら往いて求めんとて、朝まだきに力強き漕手四人を倩ひ、湊を舟出して、こゝかしこの洞窟より巖のはざまゝで、名殘なく尋ね給ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮羊君の奥さんから十銭借りて街へ出かける、切手四銭、ハガキ二銭、そしてなでしこ四銭。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の買物一金八十三銭　　切手四十枚と一枚一金十二銭　　　ハガキ八枚一金十八銭　　　酒二合一金五銭　　　　醤油二合一金七銭　　　　バツト一ツ一金二十三銭　　米一升　　〆金壱円四十八銭本日敬坊から送金壱円五十銭差引残金二銭！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に免許にはいまだ致されぬが、しかし、一足二身三手四口五眼を逆に行って、彼の眼は天下無敵だ。",
              "citation": {
                "source": "怪異暗闇祭",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "創は「首構七寸程、左肩六七寸ばかり、右肩五寸ばかり、左右手四五ヶ所、鼻上耳脇また頭に疵二三ヶ所、背中右の脇腹まで筋違に一尺五寸ばかり」である。",
              "citation": {
                "source": "忠義",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "手四箇では盆の四日間にあんがまあが来る。",
              "citation": {
                "source": "琉球の宗教",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手四分の一がほどを占めて正面の石段により登りぬべき鐘楼｜聳え立ち、その角を過れる路はなお奥に上る。",
              "citation": {
                "source": "道成寺（一幕劇）",
                "author": "郡虎彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍の中身は、さすがによく手入れが届いて明晃々たる長剣五寸横手四寸の業物です。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうら、こちらの方でも御用とおっしゃる」　今度は一っ掴み、数でこなしてバラ蒔いて、「あちらの方でも御用とおっしゃる」　指の股へ四枚はさんで、四枚を同時に振り出すと、それが眼あるもののように飛び出して、相手四人の顔面へ好みによって喰いつこうというのだから、眼も当てられない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "睦会の方には、いまの柳橋、柳好、小文治、文楽君が若手四天王で売り出していた。",
              "citation": {
                "source": "わが寄席青春録",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、わずかに一軒、京都の花街、縄手四条上ルところに、昔ながらの方法を遵奉して、よい豆腐をつくっている家があった。",
              "citation": {
                "source": "美味い豆腐の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤城の記事は三回飛んだ最後に、アプローチを八十米にしたら、Ａ選手三十何米、Ｂ選手四十何米というのであった。",
              "citation": {
                "source": "山を思う",
                "author": "石川欣一",
                "note": "青空文庫"
              }
            },
            {
              "text": "敦賀からウラジオストックに向かって航海中、深夜一つの火の玉が、正面から右手四十五度乃至五十度の方向に現れた。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "其夜はいつもの頃ふせり候処、蚊屋釣手四所壱度に落しが、起て釣り候へばまた落し。",
              "citation": {
                "source": "三次実録物語",
                "author": "稲生武太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日は今日より大きな舟に、漕手四人を乗り込ませ、湾内数マイルの所まで出て行くことにした。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "潘璋が去ると、また、「朱然を呼んでくれ給え」　と、近侍へたのみ、その朱然が見えると、「新手四千騎を加えて、敵城の南、東、西の三方へいよいよ圧力を加え給え、そして足下はべつに千騎をひきい、北方の小道や山野など隈なく遊軍として見廻っているように」と、いった。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてしなき、そが心母にも、……もとより友にも明さざりき。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は弱いので、　悲しみに出遇ふごとに自分が支へきれずに、　生活を言葉に換へてしまひます。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が自殺した時、それも作家が自殺した時、その原因を簡単に云つてしまふなぞはよくないことである。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、人が、思はず云ひ過ぎをしてしまふやうに、自殺も、思はずしてしまふやうなものに相違ない。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもなんとなくみんなが遠慮して、結局そこで小さい声で話すことになつてしまつた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに猶、諸君も嫌ひではない冗舌は、此処に十分に按配されてをり、直き直きに抽象語を以てしなければ、かの「意味がない」と云つて嘯く、平盤な心情の人達のためには、十分哲学的学術的な言葉も此処には見出されるのである。",
              "citation": {
                "source": "宮沢賢治全集",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、二、三、四行に於ても、第五、六、七、八行に於ても、海は猶深さよりも広さを感じさせたが、茲に於て海は深く、ふてぶてしくも狂暴である。",
              "citation": {
                "source": "海の詩",
                "author": "――人と海――",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒場であらうと屋台であらうと、その場に眠つてしまふ。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "楊林宮沢賢治エレキに魚をとるのみか鳥さへ犯すしれをのこ捕らでやまんと駐在の戸田巡査こそいかめしきまこと楊に磁の乗りて小鳥は鉄のたぐひかやひとむれさつと落ち入りてしらむ梢ぞあやしけれ",
              "citation": {
                "source": "楊林",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "開墾地宮沢賢治焦ぎ木のむらはなほあれば山の畑の雪消えて〔以下なし〕　――――――――青年団が総出にてしだれ桜を截りしなり",
              "citation": {
                "source": "開墾地",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗谷〔一〕宮沢賢治まくろなる流れの岸に根株燃すゆふべのけむりこらつどひかたみに舞ひてたんぽゝの白き毛をふく丘の上のスリッパ小屋に媼ゐてむすめらに云ふかくてしも畑みな成りてあらたなる艱苦ひらくと",
              "citation": {
                "source": "宗谷〔一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それといふのが修辞的熟達とか心理的洗練といふことは、即ち二枚目的なことであつて、えてして俗への道である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、書かうとなれば、詩作と同様のことになり、誰に出す手紙かも分らなくなつてしまふのです。",
              "citation": {
                "source": "感情喪失時代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
