        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "警察の特高と※母たちとの応酬も短いうちにティピカルなものを示している。",
              "citation": {
                "source": "解説（『風知草』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体小夜子という女は、所謂カフェーの女としてティピカルな女です。",
              "citation": {
                "source": "死者の権利",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにティピカルに平均的な人間というものさえそう沢山はいないのが事実だ。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "磨き抜かれた、いわゆるティピカルな『第九』として、永く残され語り伝えらるべきものである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それこそ申し分なく外面的な形の整ったもので、野村光一氏はこの人の指揮をドイツ風の指揮と対照的だと言っておられるが、全くフランス風の形の美しさに重点を置いて、ティピカルなものである。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人は実にフランス人のティピカルな紳士であったらしい。",
              "citation": {
                "source": "名曲決定盤",
                "author": "野村長一",
                "note": "青空文庫"
              }
            },
            {
              "text": "総評としては今度のは、御馳走のティピカルなもので、前の簡素なのゝ方がよかったやうに思ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
