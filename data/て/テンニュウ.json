    "definitions": [
      {
        "index": 1,
        "gloss": "moving into (a city, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
