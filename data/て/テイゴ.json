[
  {
    "uuid": "8d378d45-f1bc-576b-9fd2-e10267ea67e1",
    "entry": "亭午",
    "reading": {
      "primary": "ていご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "noon",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "日は正に、亭午であらう。",
              "citation": {
                "source": "酒虫",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "粗き目は不充分なるさとりの力一〇三―一〇五【いよ／＼】正午の太陽は光殊に強く※轉殊におそしとみゆ【見る處の】正午即ち太陽の過ぐる子午線の位置は經度の異なるに從つて異なる意か【亭午の圈】子午線一〇九―一一一【仄闇き蔭】林の一一二―一一四【エウフラーテスとティーグリ】エウフラテス、チグリス。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "この愛の障礙となるものは罪なり、救世主世に降りて罪を贖ひ、愛あらたに燃ゆ〔この花〕天上の薔薇一〇―一二〔亭午の〕正午の太陽に因みて光の強きをいふ。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭午昇眞の贖罪の話に移り、廿七部の經（舊約聖書）を留め三一淨風。",
              "citation": {
                "source": "弘法大師と景教との關係",
                "author": "イー、エー、ゴルドン",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘十字　日は亭午。",
              "citation": {
                "source": "希臘十字",
                "author": "高祖保",
                "note": "青空文庫"
              }
            },
            {
              "text": "お舟がきれいに明りをつけていごいていますね。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もラグリーは怒つたあとではたいていごく太つ腹になるんですがね。",
              "citation": {
                "source": "手早い奴",
                "author": "THE QUICK ONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
