    },
    "definitions": [
      {
        "index": 1,
        "gloss": "low speed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "極めて平凡なものの観察でさえも映画によって始めて可能な利益があるとすれば、映画技術によってのみ得られる観察、例えば高速度撮影や反対の低速度撮影のごときものの効能は今更云うまでもないことである。",
              "citation": {
                "source": "教育映画について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "砲弾が低速で走れば、たちまち落ちるばかりではないか。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、なぜ、あのように低速で飛ぶのですか。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その話は、知っているだろう」「ええ、その話なら、知っています」「そのアメリカ人の着想に基いて、わしが低速砲弾に応用したんだ。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "低速砲弾においては、ほんのわずか重力をうち消してあるばかりだ。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二百発の低速砲弾を、敵の四｜隻の巡洋戦艦に集中する。",
              "citation": {
                "source": "のろのろ砲弾の驚異",
                "author": "――金博士シリーズ・１――",
                "note": "青空文庫"
              }
            },
            {
              "text": "低速のおかげで往復に寧日なく、呼べば「ヘーイ」と調子の外れた大声で返事はするが目じろぎもせず必死の構へは崩れをみせず、真剣敢闘、汗は流れ、呼吸は荒れ、たまに勝負の手があくと汗をふきふき誰彼と腹蔵なく談論風発、隠し芸まであつて「浜辺の歌」だの「小さな喫茶店」などゝいふセンチな甘い歌が大好きで声もよい。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、道路をとび越えますよ」　庭の飛石を飛び越えるように、僕たちは高速道路から低速道路へと渡っていった。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろカモシカ号の最低速度は、このへんでも時速五十キロメートルで、かなり早い。",
              "citation": {
                "source": "宇宙の迷子",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな低空低速、悠々と見物してまわっている。",
              "citation": {
                "source": "長崎の鐘",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "超低速でぼくたちの前まできたヤマハＲＤ２５０は、とまった。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カワサキにとっては超低速に近いスピードで、ぼくはさらにミニ・パトカーをひきつけた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "知らん顔で、ぼくは、超低速の蛇行をつづけた。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉は風に負けまいとして一生懸命に走っているが、カワサキにとっては超低速だ。",
              "citation": {
                "source": "彼のオートバイ、彼女の島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
