        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "蹄鉄のひゞきと、滑桁の軋音の間から英語のアクセントかゝったロシア語が栗本の耳にきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　馬が苦しげに氷上蹄鉄を打ちつけられた脚をふんばって丘を登ってきた。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、きしきしという軋りが聞えて、氷上蹄鉄を打ちつけられた馬が、氷を蹴る音がした。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄鉄の釘がゆるんでいるとか、馬が風邪を引いているとか。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は、滑らないように下面に釘が突出している氷上蹄鉄で、凍った雪を蹴って進んだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄鉄に蹴られた礫が白樺の幹にぶつかる。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごくとしよりの馬などは、わざわざ蹄鉄をはずされて、ぼろぼろなみだをこぼしながら、その大きな判をぱたっと証書に押したのだ。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてその人が競馬の何かだといふことがわかったかと云ひますと、実はその人の胸に蹄鉄の形の徽章のついてゐたのを、さっき私は椅子にかける前ちゃんと見たのです。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見るとこの家の主人は五十ばかりのお爺さんですが、独身者と見えてお神さんも子供も居ず、たった一人で一生懸命鉄槌で鉄敷をたたいて、テンカンテンカンと蹄鉄を作っています。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人はトラックによぢ下りて線路に軌条蹄鉄を嵌め、それに繋がる小箱の外側に取り付けた十二の電球が一せいに燃えることによつて線路の電汁はまた多汁であることを検査してゐた。",
              "citation": {
                "source": "英国メーデーの記",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄鉄、長柄の鎌、フオク、斧、鉈の類がその土間には放り出されてあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蹄鉄が浪岡の膝に入った。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "正勝は鞭を振り振り、蹄鉄の跡のその硬い凸凹を蹴崩した。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへぽかぽかと蹄鉄を鳴らして、三頭の馬が殺到してきた。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後から敬二郎と松吉と平吾の三匹の馬が、蹄鉄をぽかぽか鳴らしながらついていった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人と被害者はここまで四輪馬車で来、引く馬の蹄鉄の三つは古く、右前肢だけ新しい。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この鞄にストレーカの履いていた靴を片方と、フィツロイ・シンプソンのをひとつと、それからシルヴァブレイズの蹄鉄を一個持って来ました。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからこの蹄鉄は幸運のまじないに、懐に入れるとしましょう。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人の目前の軟らかい土に馬のひづめの跡がいくつもはっきりついており、そこで懐から取り出された蹄鉄があてがわれると、ぴったりと符合した。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが急な火の光に驚いた馬は、同時に動物の不思議な本能で何か危害が加えられようとしていると察知し、脚を蹴り上げたその拍子に蹄鉄でストレーカの額に一撃。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生瓜を作っても、馬の蹄鉄を造っても、また一生｜杉箸を削って暮しても差支えない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三五年五月小熊秀雄I蹄鉄屋の歌泣くな、驚ろくな、わが馬よ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてわたしは働き歌をうたひながら、――辛抱しておくれ、　　すぐその鉄は冷えて　　お前の足のものになるだらう、　　お前の爪の鎧になるだらう、　　お前はもうどんな茨の上でも　　石ころ路でも　　どんどんと駈け廻れるだらうと――、私はお前を慰めながらトッテンカンと蹄鉄うち。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "焼けた蹄鉄をお前の生きた爪に当てがつた瞬間の煙のやうにも、私の歌は灰色に立ちあがる歌だ。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "強くなつてくれよ、私の友よ、青年よ、私の赤い焔を君の四つ足は受取れ、そして君は、けはしい岩山をその強い足をもつて砕いてのぼれ、トッテンカンの蹄鉄うち、うたれるもの、うつもの、お前と私とは兄弟だ、共に同じ現実の苦しみにある。",
              "citation": {
                "source": "小熊秀雄全集-4",
                "author": "詩集（３）小熊秀雄詩集１",
                "note": "青空文庫"
              }
            },
            {
              "text": "タヴェルニエー言う、ノガイ人は、馬を飼いて餓渇に堪えしめ、その蹄堅くして蹄鉄を要せず、土や氷の上に足跡を印する事あたかも蹄鉄を附けたるがごとし、ただしかく育て上ぐるは難事ゆえ、五十匹の中わずかに八疋十疋のみ成功す、征行に良馬のほかに凡馬二、三を伴れ騎り、大事あるにあらずんば決して良馬に乗らずと。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "六軒目には蹄鉄屋があった。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂は蹄鉄屋の前の火の光に照りかえされて濛々と渦巻く姿を見せた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "蹄鉄屋の先きは急に闇が濃かくなって大抵の家はもう戸じまりをしていた。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "くろへ腰掛けてこぼこぼはっていく温い水へ足を入れていてついとろっとしたらなんだかぼくが稲になったような気がした。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
