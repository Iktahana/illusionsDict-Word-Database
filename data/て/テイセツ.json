[
  {
    "uuid": "fce001d0-03ad-5d5d-8f4c-d9add5f53904",
    "entry": "貞節",
    "reading": {
      "primary": "ていせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
