    },
    "definitions": [
      {
        "index": 1,
        "gloss": "chastity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女は生れながらの貞節な細心な労苦を厭わない意志の強い主婦であった。",
              "citation": {
                "source": "不幸",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "太く短い環、古代の貞節な女に似て垂れ下った醜い肩、まるで病み疲れてサタンに生育を阻止された女が奇妙な嬌態をして、流行の衣裳と近代の手管をもって私の前に現れたのだ。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "昆虫も貞節でなければものの役には立たぬと見えて、後妻を娶ったり再嫁したやつは、薬になる資格さえ無いというわけである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "心の貞節や人知れぬ涙を決して人に見せまいとする悩みから湧くこの世の淋しさが、まざまざと鼻に現われて来るからであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい、罪人となった癖に、貞節も糞もあるかい」　これを見ると王は戸を突き開けて入って往って、刀を抜くなり驚いて逃げようとする番人を突き殺した。",
              "citation": {
                "source": "蘇生",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「永年遠國に罷在候夫の爲、貞節を盡候趣聞召され、厚き思召を以て褒美として銀十枚下し置かる」と云ふ口上であつた。",
              "citation": {
                "source": "ぢいさんばあさん",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "慈悲深キ賢母ヲ勞働ノ苦役ニ驅リ貞節ナル良妻ヲ賣淫ノ汚濁ニ投ズルハ、夫タリ子女タル國民ノ忍ブ能ハザル所。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども美しい貞節な妻と可憐な娘を三人まで持っている倉地の心がいつまで葉子にひかされているか、それをだれが語り得よう、葉子の心は幌の中に吹きこむ風の寒さと共に冷えて行った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "倉地って人は妻子まで離縁した……しかも非常に貞節らしい奥さんまで離縁したと新聞に出ていました」「そうね新聞には出ていましたわね。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし何でもなかったとしたら、この俺は、善良な友人と、貞節な妻とに対して、あんな恐ろしい疑いを抱いた、この俺は何という人間だ――だがそんなことは断じてない。",
              "citation": {
                "source": "二人の盲人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "この世の中に、旧式の丸髷、泥鴨のような歩き振、温順と貞節とより他に何物をも有せぬ細君に甘んじていることは時雄には何よりも情けなかった。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "エムマのモデルは數年前に死んで、其墓に行つて見ると、其墓石に、『貞節温良なる細君として、慈愛ある母として、かの女は其一生を送つた。",
              "citation": {
                "source": "『マダム・ボワリーの故郷』",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳母　　はて、お若い方、母御樣は此お邸の内室さまぢゃがな、よいお仁で、御發明な、御貞節な。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロミオ　姫よ、あの實を結ぶ樹々の梢の尖々をば白銀色に彩ってゐるあの月を誓語に懸け……ヂュリ　おゝ、※る夜毎に位置の變る不貞節な月なんぞを誓言にお懸けなさるな。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そこにお死にゃったるロミオこそはヂュリエットが正しい夫、またそこにお死にゃったるヂュリエットこそはそのロミオが貞節なる宿の妻、二人を嫁したは手前。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾等純金にて姫の像を建て申し、此※ローナが同じ呼名で知らるゝ限り、貞節なヂュリエットどのゝ黄金の像をば上無き記念と崇めさせん。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "お八重に貞節を守っているわけではなかったが、新一郎もまだ結婚しないでいた。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は、夫の横死の原因が自分であることを知っていたために、亡夫のために貞節を立て通した。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "貞節悲壮な母子に対する賞賛は、江戸の隅々にまで伝わった。",
              "citation": {
                "source": "仇討三態",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃殊にさう云ふことに關して感傷的になつてゐる彼には、良人に貞節な女の行爲が、よしそれが些細なことであつても彼を大へん喜ばした。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本當に貞節な女はゐないのか。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本當に貞節な女がゐたなら、俺は何時でも生命を投げ出してやるだらう。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、本當に貞節な男もゐないぢやないか。",
              "citation": {
                "source": "悲しみの代價",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "これを別方面の言葉で云うと、子はみんな孝行のもの、妻は必ず貞節あるものと認めていたらしいのであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから芝居でも小説でも非常な孝行ものや貞節ものが、あたかも隣り近所に何人でもいるかのごとき様子であらわれて参るのみならず、見物や読者もまた実際にいくたりでも存在しているうちの代表者だと云わぬばかりの顔つきで、これに対していたのであります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「女は三界に家なし」無限の悲哀を誘うこの現実と、生殺与奪の権利をもった男たち、その父、その良人、その息子からさえ監視されて、貞節に過さなければならなかった女の生涯を眺め合わせたとき、私たちは心から慄然とする。",
              "citation": {
                "source": "貞操について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はモンナ・バンナが夫に貞節を証するために、「私の眸を見て下さい」というのを実に純潔な表現と思いました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はこんなに貞節のある良人だ！",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "惡事を罪として避けるものは心靈的になる、然らざるものは肉的である――信仰、眞理、貞節、眞率等は前者に屬し、殺人、姦淫、偸盜、僞證、色慾等は後者のものである。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
