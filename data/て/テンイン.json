    "definitions": [
      {
        "index": 1,
        "gloss": "employee (of a store)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "遅々たる行列の進みが百貨店の外の入口まで届くと黒服の店員に管理されて人数の一くぎりずつが内側の入口の床石に誘われる。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああして月給取も店員も運転手も職工も小僧も女事務員も町娘も女給も仲居もガソリンガールも一緒になって踊っているのは何と美しく善いことだろう。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "このキャディのような環境におかれた少年は例えば昔の本郷青木堂の小店員のごとく大概妙に悪ずれがしてくるものであるが、ここの子供達はそんな風が目に立たない。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それらの店の店員や主人は「石油ランプはドーモ……」と、特に「は」の字にアクセントをおいて云って、当惑そうな、あるいは気の毒そうな表情をした。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍で聞いている小店員の中には顔を見合せてニヤニヤ笑っているのもあった。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者は素直な筆つきで、そこに傭はれてゐる女店員の心に映じた爭議を――彼女達がその爭議によつて體驗して來たことを描いてゐる。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五の女店員を、「彼女等はまだ髮を引つ詰めにして、身體の痩せた、着物の裾と足袋の間に脛の見えてゐる娘たちであつた。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "女店員を書き女店員の些末な心遣ひを書くのに、作者の筆は正しく女流の筆である。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは小店員の話であるが、同じやうに中番頭のものが六月號の文章倶樂部に出てゐたが、その方がずつとよかつた。",
              "citation": {
                "source": "『戰旗』『文藝戰線』七月號創作評",
                "author": "-------------------------------------------------------",
                "note": "青空文庫"
              }
            },
            {
              "text": "店員の怪しむような眼を睨みかえして油絵を見た。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業は、南京路角、百貨店｜泰興公司の女店員、支配人デー・ダブリュ・クロフォードに愛さる。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は百貨店レーン・クロフォードの女店員になった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カフェーを沸かしながら彼女は卓上電話をとると、麹町にある彼女の経営している店に電流を通じて、その日のスケジュールをつくるために店員たちと約束客の時間の繰合わせについて打合せを始めた。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "水島君は私の中學時代の同窓で、外國語學校露語科の出身者で、Ｋ商事會社の支店員だつたが、互に仕事の餘暇を誘ひ合せて、大正――年の秋、反過激派の勢力が衰へて過激派の勢力が次第にシベリアを南下してくると共に不安騷然たる空氣に包まれてゐるハルピンの町を、日となく夜となく彷徨ひ歩いたのであつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新京極に折れると、たてた戸の間から金盥を持って風呂へ出かけてゆく女の下駄が鳴り、ローラースケートを持ち出す小店員、うどんの出前を運ぶ男、往来の真中で棒押しをしている若者などが、異様な盛り場の夜更けを見せている。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここでも三四人の店員が雪投げをしていた。",
              "citation": {
                "source": "泥濘",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「××どんあれはいつ頃だったけ」「へい」　しばらく見ない間にすっかり大人びた小店員が帳簿を繰った。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまたある時自分にしては比較的高価な本を買った時に応接した店員の顔がどこかにちらとひらめいたと思われた冷笑の影が自分に不思議な興奮を与えた事も思い出される。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで自分は時々買い物をするが、そのたびにいつでも店員の中のあるものが一種の疑いの目をもって自分を注目しているような気がしたり、あるいは自分の美術に対する嗜好に同情をもっていないらしいある人たちのだれかが、不意に自分の肩をたたいて「相変わらずやってるね」とあびせかけられはしないかという気がする。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつかクルイクシャンクの評伝を買った時に、そばに立っていた年少の店員が「クルイクシャンク／＼」と言ってクスクス笑った。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じょさいのない中老店員の一人は、顧客の老軍人の秘蔵子らしいお坊っちゃんの自分の前に、当時としてはめったに見られない舶来の珍しいおもちゃを並べて見せた。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "年の若い店員の間には文学熱が盛んで当時ほとんど唯一であったかと思われる青年文学雑誌「文庫」の作品の批評をしたりしたことであった。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "以前に「鳥類の嗅覚」に関する詳しい記事のありそうな本を捜していた時に、某書店の店員が親切にカタログをあさってともかくも役に立ちそうな五六種の書名を見つけてくれて、「海外注文」を出してもらったが、一年以上たってもただ一冊手に入っただけで、残りのものは梨のつぶてである。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでさっそくそのＳ商会の陳列所へ行くと、係りの店員は先日の「花壇展覧会」は見なかったから知らないという。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どう見ても金持ちらしい五十格好のあぶらぎった顔をした一人の顧客が、若い店員を相手にして何か話している。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い店員は心持ち顔を長くしたようであったが、「はあ、……比較的に」と答えた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしできれば次に出版するはずの随筆集の表紙にこの木綿を使いたいと思って店員に相談してみたが、古い物をありだけ諸方から拾い集めたのだから、同じ品を何反もそろえる事は到底不可能だというので遺憾ながら断念した、新たに織らせるとなるとだいぶ高価になるそうである。",
              "citation": {
                "source": "糸車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "買う時には店員まで付き添って雨の降る中を届けて来たのに、それでは少しおかしいとは思ったがどうにもならなかった。",
              "citation": {
                "source": "蓄音機",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音楽家からも楽器屋の店員からも、また音楽好きの学生からも一つとしてよい印象を受けなかった。",
              "citation": {
                "source": "二十四年前",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
