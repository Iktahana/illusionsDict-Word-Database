        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "猫が前手で顔を洗う仕草はとても可愛い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "犬は、おやつが欲しい時によく前手でおねだりする。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "熊が前手を上げて威嚇する姿は迫力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
      },
      {
        "index": 3,
        "gloss": "handle",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
