[
  {
    "uuid": "1232c61e-cac8-5065-9140-20093f983a86",
    "entry": "転住",
    "reading": {
      "primary": "てんじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
