    "definitions": [
      {
        "index": 1,
        "gloss": "the laws of nature and humanity",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
