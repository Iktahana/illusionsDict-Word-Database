        "examples": {
          "standard": [
            {
              "text": "この研修プログラムに参加するには、特定の業務経験が3年以上であることが適格である条件だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女のこれまでの実績を考慮すると、その役職に適格であると判断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "試験に合格すれば、あなたは次の段階に進む適格であると認められる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも甚だ不適格であるというので二年間だけでクビになったが、そのために寺田正一郎は歌子を知り、その父の朝之助にも接するようになったのである。",
              "citation": {
                "source": "女剣士",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
