[
  {
    "uuid": "a2257dff-7761-51ac-a983-3852b08ccf97",
    "entry": "天帝",
    "reading": {
      "primary": "てんてい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Shangdi (supreme deity in ancient Chinese religion)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "然りとはいえども、天帝の身には近づかで、修羅かれがために破らる。",
              "citation": {
                "source": "天守物語",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでは親に済むまいとか、お上に済むまいとか、神様に済むまいとか、仏に済むまいとか、天帝に済むまいとか云おうとしても、どれもこの女に掴まえさせる力草にはならない。",
              "citation": {
                "source": "蛇",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "この年の夏彼等は人心の動揺に乗じて、「慶長の頃天草｜上津浦の一｜伴天連が、国禁によって国外へ追放された時の遺言に、今より後二十六年、天帝天をして東西の雲を焦さしめ、地をして不時の花を咲かしめるであろう。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "国郡騒動して人民困窮するけれども、天帝は二八の天章をこの地に下し、宗門の威を以って救うであろうとあるが、今年は正にその時に当る」と流言を放った。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで松右衛門は好次と謀って、四郎をもって天帝｜降す処の天章と為し、大矢野島宮津に道場を開き法を説いた。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "城兵は、四郎を天帝の化身のように考え、矢石当らず剣戟も傷くる能わずと思っていたのに、四郎が傷いたので、彼等の幻影が破れ、意気｜頓に沮喪したと云われる。",
              "citation": {
                "source": "島原の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天帝釈化して猴となり身に疥癬を病めり、来り進んで猴衆に石を負わせ、海を杜がしめ衆｜済るを得とあり。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジェームス・ローの『回教伝説』に、帝釈の天宮に住む天人、名はノルテオクが天帝の園に花を採る若い天女に非望を懐いた罰として、天帝を拝みに来る諸天神の足を浄める役にされたが、追々諸神の気に入ってついに誰でも指さして殺す力を得た。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからちゅうものは、少しく癪に触る者あればすなわち指さして殺すので、天帝すこぶる逆鱗あり、ヴィシュニュの前身フラ・ナライ（那羅延）に勅して彼を誅せしむと来た。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、帝釈、天帝に謁せんとカイラス天山に趣く、留守の天女ども、鬼王が化けたと知らず、帝釈帰ったと思うて至誠奉仕し、鬼王歓を尽くして地に還る。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて帝釈は、天女どもを鬼王に犯されたと思うと焼けてならず、天帝に訴える。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "五万年の昔、阿修羅は天帝と闘うて、すでに勝利を得べきであったが、帝釈の矢軍に射すくめられて、阿修羅の眷属はことごとく亡び尽した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "天帝はあなたが早く孤児になって、しかも恭謹の徳を守っているのをあわれんで、仮りにわたしに命じて、家を守り、煮焚きのわざを勤めさせていたのです。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神後記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚書洪範に帝が禹に洪範九疇を錫へたとある帝の字は古來天帝と解してゐる。",
              "citation": {
                "source": "易疑",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "呂刑の中に見ゆる帝或は黄帝の字は帝若しくは帝堯、帝舜と解せられてゐるが、今文家は之を天帝と解して居る。",
              "citation": {
                "source": "易疑",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿を出でゝ再たび三月堂に上れば、梵天帝釋の温雅整肅にまします、裏手なる執金剛神の怒氣すさまじき、共に寧樂美術の粹とこそ聞け、乾漆の四天王、本尊は不空羂索の觀世音、共に天平のものなりとぞ、建築も當時のまゝなるは、東大寺境内にて正倉院を舍きては、この堂に留めたり。",
              "citation": {
                "source": "寧樂",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ええやはり天草殿には、天帝をお信じなされた結果、原の城へお籠りなされたので？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「は」というと四十二、三、胸毛の多いさむらいが、「天帝｜如来を信仰し、現世においては安心を得、死して天国へうまれよう……」「ははあ、それで帰依したというのか？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "というのは天帝如来、そいつを拝むようなまねをして、毛唐の連中のご機嫌をとり、うまく通商貿易をし、ボロい儲けをしようとしたのさ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ天帝に祈りをあげろ」「あッ、ちょっと待て！",
              "citation": {
                "source": "流線間諜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけでとうとう妖婆は午前六時に唱うべき天帝に約束の三度の呪文をあげないでしまう。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "天帝の愛子、運命の寵臣、人の中の人、男の中の男と世の人の尊重の的、健羨の府となる昔｜所謂お役人様、今の所謂官員さま、後の世になれば社会の公僕とか何とか名告るべき方々も出た。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私は五条｜西洞院辺にゐる仏ぢやが、つね／″＼評判のお前様の読経を聴きたい／＼と思つてゐたが、平素は梵天帝釈などのお入来があるので遠慮してゐた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "天帝に媚びれば、仕事が殖えるとでも思っているなら愚の骨頂だ。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――斯う宇宙一体が溌溂としないのは、俺が思うに、天帝の故だ。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴れる時は、天地の軸が歪みそうで、天帝の眉さえ顰む程だが、必ずあとに、休止と云うものが従っている。",
              "citation": {
                "source": "対話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやら、天帝の定めた一日が、どこかへ尻尾を置き忘れて来たものとみえる。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで天帝は諸神の会議を召集し、特に鴉片煙劫を創めることにした。",
              "citation": {
                "source": "鴉片",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "神楽坂署で夫の恐ろしい罪の自白を聞いて、既に覚悟はしていたけれども、こうして改めて予審廷に呼び出されると、彼女は新な涙に誘われて、天帝の無慙な試練に歯を喰いしばってこらえているのだった。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
