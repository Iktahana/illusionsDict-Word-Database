    "definitions": [
      {
        "index": 1,
        "gloss": "washing one's hands",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手洗い口すゝぎなどするうち空ほの／″＼と明けはなれたるが昨夜の雨の名残まだ晴れやらず、蚊帳をまくる風しめっぽきも心悪からず。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも忠実に付従して来るはいいとしても、まさかに手洗い所までものそのそついて来られては迷惑を感じるに相違ない。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダムお気に入りの銀子が、手洗いの湯やタオルを盆に載せて持って行くと、ちょうど診察が済んだあとで、一両日中に入院でもするような話であった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とおやじに聞えよがしに呟いて、自分で手洗いの水を両手で掬って来て、シャッシャと鉢にかける。",
              "citation": {
                "source": "禁酒の心",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「螺旋まわしと二三の螺旋を手洗い台の上で見つけました。",
              "citation": {
                "source": "入院患者",
                "author": "コナンドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中にお手洗いに起きて、お玄関の衝立の傍まで行くと、お風呂場のほうが明るい。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの火事があってから、お母さまは、夜中に時たま呻かれる事があるし、また、風の強い夜などは、お手洗いにおいでになる振りをして、深夜いくどもお床から脱けて家中をお見廻りになるのである。",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそっと立って、お隣りの部屋へ行き、病身らしく蒼白く痩せたおかみさんに、お手洗いをたずね、また帰りにその部屋をとおると、さっきの一ばんきれいで若いチエちゃんとかいうお嬢さんが、私を待っていたような恰好で立っていて、「おなかが、おすきになりません？",
              "citation": {
                "source": "斜陽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "随って手洗い所が一番群集するので、喜兵衛は思附いて浅草の観音を初め深川の不動や神田の明神や柳島の妙見や、その頃｜流行った諸方の神仏の手洗い所へ矢車の家紋と馬喰町軽焼淡島屋の名を染め抜いた手拭を納めた。",
              "citation": {
                "source": "淡島椿岳",
                "author": "――過渡期の文化が産出した画界のハイブリッド――",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、京子がお手洗いへ立つかどうかして、倭文子と二人きりになる機会が、必ずあるに相違ないと楽しみにしていた。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "神明様の手洗い水で顔でも洗っておいでよ。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "お庄は手洗い水を持って行って、襖の蔭で聞いていた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "外には春風が白い埃をあげて、土の乾いた庭の手洗い鉢の側に、斑入りの椿の花が咲いていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "しきりに手洗いに立つひとが出来た。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしたら婦人席のわきにいた守衛の一人が、手洗いに立つならば今のうちに、という意味をいったそうで、数人が立ち、隣席の三人づれも立った。",
              "citation": {
                "source": "待呆け議会風景",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖父の墓は、小さい木の門がついた一区画のなかにあって、大きな槇の木の下には丸い手洗いが置かれ、高い、いかめしい墓石のぐるりにも木が植っていて、いくらか庭のようだった。",
              "citation": {
                "source": "道灌山",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうしてそれがわかりました」「私が手洗いにまいりました時、さだ子の部屋の前を通りましたの。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の二号室の附添看護婦が、あの廊下の突当りの手洗い場に行きかけると、あの室の扉が開いて、眩しい電燈の光りが廊下にさしている。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから私は気が付いて、あの向うの二等病室づきの手洗い場に行ってみましたが、手洗い場の龍口栓は十分に締まっていない上に、床のタイルの上に水滴が夥しく零れておりました。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時間程経って、朝子が手洗いのついでに、例の濠を見渡す、ここばかりはややセザンヌの絵のような風景を眺めて立っていると、伊田が来た。",
              "citation": {
                "source": "一本の花",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かわり番こにワイシャツにチョッキ姿の社員が手洗いに出たり入ったりした。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "便所と手洗いの間にはさまれているこの二畳はおかしな部屋で、どだい壁も天井板もないところであった。",
              "citation": {
                "source": "三月の第四日曜",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、今晩は少のうございますね」手洗いの湯をすすめに来た母はほとんど手柄顔にこう云った。",
              "citation": {
                "source": "子供の病気",
                "author": "――一游亭に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ主人鶴彌氏は、当夜この部屋ばかりにいたわけじゃないんで、土居嬢を送るために玄関へも行ったでしょうし、手洗いへも行ったでしょう。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "観音様の手洗い水よ。",
              "citation": {
                "source": "柳営秘録かつえ蔵",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代乃はつと立ち上って、手洗いに行き、それから、裏口、表口、二階と、すっかり戸締りをしてしまった。",
              "citation": {
                "source": "女心の強ければ",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、娘らしい心づかいが田舎じみた衣しようのはし／″＼にもみえてあらい手織りじまのモンペがよく似合うのも、ほゝえましかつた。",
              "citation": {
                "source": "火の扉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
