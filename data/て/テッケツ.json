[
  {
    "uuid": "42c72c3c-14f4-5d69-b617-1c51d67e3dd0",
    "entry": "剔抉",
    "reading": {
      "primary": "てっけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
