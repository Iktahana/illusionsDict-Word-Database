    "definitions": [
      {
        "index": 1,
        "gloss": "stop (bus, tram, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
