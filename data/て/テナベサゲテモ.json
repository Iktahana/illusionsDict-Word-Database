        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "どんな苦労があろうとも、あなたと一緒なら手鍋提げても構わない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「手鍋提げても」の覚悟で、彼は事業を始める決意をした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は愛する人のためなら、手鍋提げてもどこへでもついて行くと言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "俚謡に「竹の柱に茅の檐」と唱うのも、「手鍋提げても」と唱うのも、貧即不幸福の妄見を照破してしまっている手近い例だ。",
              "citation": {
                "source": "貧富幸不幸",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は「手鍋提げても」という俗謡にあるような生活を眼のあたり見た。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "『手鍋提げても』てなことを實行してゐやあがる。",
              "citation": {
                "source": "俳諧師",
                "author": "高濱虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
