[
  {
    "uuid": "5d66e001-0e32-5078-8414-63d1dda3a470",
    "entry": "照葉",
    "reading": {
      "primary": "てりは",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
