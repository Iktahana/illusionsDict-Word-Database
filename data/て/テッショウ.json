        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お手紙を見て驚喜仕候、両君の室は隣室の客を驚かす恐れあり、小生の室は御覧の如く独立の離島に候間、徹宵快談するもさまたげず、是非｜此方へ御出向き下され度く待ち上候　すると二人がやって来た。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝三郎の家に集り毎晩徹宵で協議をこらした。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "連中に出す酒肴の世話で、伝三郎の妻は徹宵し、時々居眠りをして負けた伝三郎に叱られた。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」徹宵、議論の揚句の果は、ごろんと寝ころがって、そう言って二人うそぶく。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "大いに親しい人ならば、そうしておいでになる日が予めわかっているならば、ちゃんと用意をして、徹宵、くつろいで呑み合うのであるが、そんな親しい人は、私に、ほんの数えるほどしかない。",
              "citation": {
                "source": "酒ぎらい",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人の内に宿る射道の神が主人公の睡つてゐる間に體内を脱け出し、妖魔を拂ふべく徹宵守護に當つてゐるのだといふ。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "名人の内に宿る射道の神が主人公の睡っている間に体内を脱け出し、妖魔を払うべく徹宵守護に当っているのだという。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁和二年五月二十四日の夜には、安房国の沖に黒雲が起って、雷鳴震動が徹宵止まなかったが、朝になってみると小石や泥土が野や山に二三寸の厚さに積んでいた。",
              "citation": {
                "source": "日本天変地異記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがために、しかしわが家ながら、他家のごとく窮屈に思われ、夏の夜をうちわ使う音さえ遠慮がちに、近ごろにない寂しい徹宵の後に、やッと、待ち設けた眠りを貪った。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "武装した護衛兵と、他に幾人かの夜警が、徹宵家の周囲に就いている。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら巡視と称して刀を従者に預けたまま、小姓四五人を連れて大声をあげて家康の陣に行き、徹宵して酒を飲んで快談した。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "余徹宵枕辺に侍し四方山の話をなす。",
              "citation": {
                "source": "五月のはじめ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "直に城中こぞつて、徹宵額をあつめて議を廻らすのであつたが、幾夜々々続けても、天狗の羽ばたきにのみ想ひを馳せてゐた夢想家達には、決して具体の案が浮ばなかつた。",
              "citation": {
                "source": "東中野にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄昏時に起床し、見張船に徹宵し、魚群到来を合図するトラムペツトを吹き鳴すであらう。",
              "citation": {
                "source": "来年は何をするか",
                "author": "――一九三〇年に対する私の希望・抱負・計画――",
                "note": "青空文庫"
              }
            },
            {
              "text": "南はその夜門の外で女と児の啼く声を徹宵聞いたが、黎明比からぱったり聞えなくなった。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "與吉の枕元に三｜人は徹宵眠らなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "土が徹宵さういふ作用を營んだばかりに、日は拂曉の空から横にさうして斜に其の霜を解かして、西風は直にそれを乾かして残酷に表土の埃を空中に吹き捲くる。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "手足を伸せば括りつけた萱や篠の葉に觸れてかさ／＼と鳴る程狹い室内を、寒さは束ねた松葉の先でつゝくやうに徹宵其隙間を狙つて止まなかつた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　しかし大胆な男でしたから、どうかしてこの不思議な嚏の主をみつけてやらうと考へましたので四日目の晩から屋根の上に布団をしいて、徹宵張り番をしながら寝ることにきめました。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに依ると『廃帝の一族は各自椅子に縛せられ徹宵拷問されたる後、銃剣を以て惨殺されたり。",
              "citation": {
                "source": "たちあな姫",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はその晩徹宵蚊帳の外で、蚊遣を焚ながら読みたくもない本を読んでゐた。",
              "citation": {
                "source": "老苦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨宵は徹宵話して、二時まで大気焔を挙げて来た。",
              "citation": {
                "source": "硯友社の勃興と道程",
                "author": "――尾崎紅葉――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで、医師の合田氏は、これはいけないと非常な丹精をしてくれまして、夜も帰宅らず、徹宵附き添い、薬も自身｜煎じて看護してくれられました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "大病をした時のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに干場の面型をかぞへて見ると辛うじて十二三の数で、あれがきのふまでの三日がかりの仕事では今夜あたりは徹宵でもしなければ追ひつくまいと心配した。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに干場の面型をかぞえて見ると辛うじて十二、三の数で、あれがきのうまでの三日がかりの仕事では今夜あたりは徹宵でもしなければ追いつくまいと心配した。",
              "citation": {
                "source": "鬼涙村",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "祭りの武者用には古来から此処に伝はる鎧でなければならなかつたので、結局私のそれが登用されることになつたのであるが、昨夜から徹宵の村議の結果、誰人でも真ツ先にそれを私の所有から奪ひとつた者が、この先何年間といふもの春秋併せて太鼓叩きの栄誉を荷ふべし――といふ事に可決された。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本街では婦人や子供を避難所へ送った後で町会組織の警備隊が勇ましく街を守って徹宵を続け始めた。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に帰つてから、東京の某君に柬せんと欲して徹宵筆を措かず表書を書了る頃、更既に明けたり、　十七日午前七時九分大阪発、村山社長素川君等見送られる、三ノ宮で下車すると僕と形影相追随するが如き長田君ステーションで僕を迎へて呉れた。",
              "citation": {
                "source": "旅日記",
                "author": "東海道線",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
