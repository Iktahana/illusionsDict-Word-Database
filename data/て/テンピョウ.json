    "definitions": [
      {
        "index": 1,
        "gloss": "Tenpyō era (729.8.5-749.4.14)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
