        "examples": {
          "standard": [
            {
              "text": "自分の作品が選ばれて、ついに展覧会に出すことになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この絵を展覧会に出すためには、もっと完成度を高める必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「ねぇ、今年の公募展、君も力作を展覧会に出すんでしょ？楽しみにしてるよ。」",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "先生は、私のこんな姿を画いて、こんど展覧会に出すのだそうだ。",
              "citation": {
                "source": "女生徒",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本画家は多くの場合すでに注文主のある絵を仕上げて展覧会に出す。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会に出すのに、私の所蔵と名前をつけたい、箔がつくからと云うんでね。",
              "citation": {
                "source": "私は隠居ではない",
                "author": "吉田茂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
