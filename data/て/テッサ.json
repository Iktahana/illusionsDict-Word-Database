    "definitions": [
      {
        "index": 1,
        "gloss": "iron chain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鉄鎖のように黄葉したその葉が月の光でよく見えた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、一夜、転輾、わが胸の奥底ふかく秘め置きし、かの、それでもやっと一つ残し得たかなしい自矜、若きいのち破るとも孤城、まもり抜きますとバイロン卿に誓った掟、苦しき手錠、重い鉄鎖、いま豁然一笑、投げ捨てた。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か能く真に是非曲直の鉄鎖を断離し得たるものぞ。",
              "citation": {
                "source": "心機妙変を論ず",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々はみんな鉄鎖に繋がれた死刑囚だ。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村は、夙にこの事あるを予期して、河底に鉄鎖を沈め置き、多数が河の半ばまで渡るを待って、これを一斉に捲き上げたので、先陣の三百余騎、見る見る鎖に捲き倒されて、河中に倒れた。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前岸の巨木からさがった鉄鎖のような藤葛が流れの上に垂れて、その端が水の勢で下流に靡き、また放ね返って下流に靡いているのが見えた。",
              "citation": {
                "source": "仙術修業",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "石狩川の水を引ける掘割の傍に宿屋ありけるが、小熊を鉄鎖にて木に繋げり。",
              "citation": {
                "source": "層雲峡より大雪山へ",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "海ぞいに立て連ねた石杭をつなぐ頑丈な鉄鎖には、西洋人の子供たちが犢ほどな洋犬やあまに付き添われて事もなげに遊び戯れていた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯う思ううちにも「例のか」と言い「鉄鎖を緊く」など云った医学士の言葉が耳に残って居る。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "広い墓地内をうろうろしてようよう探し当てたイブセンの墓は、白樺の疎林を背に生垣と鉄鎖の柵をめぐらした広さ六坪ほどの芝生の敷地に、左右の立木に挟まれて高さ三｜間あまりの上の尖った黒い石が立っていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯鉄鎖のように生命が彼等を引きずるのである。",
              "citation": {
                "source": "土城廊",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は床を踏み鳴らし、口小言をいったり、歯を喰いしばったりして力一杯鍵束を引抜いた拍子に、糸がぷっつりと切れて、錆び鉄鎖のような音響とともに、鍵も銀器も一しょくたになって床に散乱した。",
              "citation": {
                "source": "空家",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "粘土から人間を創造し、それに生命と幸福を賦与せんがため天より火を盗んだかどでコーカサスの山の岩壁に鉄鎖で縛められ、荒鷲に内蔵を啄まれながら苦悩に堪えた英雄。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は色の黒い苦み走った、骨組の岩畳な二十七八の若者で、花色裏の盲縞の着物に、同じ盲縞の羽織の襟を洩れて、印譜散らしの渋い緞子の裏、一本筋の幅の詰まった紺博多の帯に鉄鎖を絡ませて、胡座を掻いた虚脛の溢み出るのを気にしては、着物の裾でくるみくるみ喋っている。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六尺余りに肥大せる腹を抱えて、全身は枯痩し、宛然草紙にある餓鬼の姿よりなき幹枝を見れば、ありし日の俤何処ぞやと嘆ずるのほかなく、転変の鉄鎖の冷たさは、夢幻まさに泡影の如しというべし。",
              "citation": {
                "source": "失楽園殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「与三其殺二不辜一、寧失二不経一」に同じ）Little thieves have iron chains, great thieves gold ones.（オランダ）　　小盗は鉄鎖、大盗は金鎖。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "（「与其殺不辜、寧失不経」に同じ）Little thieves have iron chains, great thieves gold ones.（オランダ）　　小盗は鉄鎖、大盗は金鎖。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそろしい顔だ、太い鉄鎖でつながれている囚人だ。",
              "citation": {
                "source": "時計屋敷の秘密",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "決定的な鉄鎖でつながれているんだ。",
              "citation": {
                "source": "囚われ人",
                "author": "――寓話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、低い石柱に二本の鉄鎖を渡した柵が、道路と神社の境内とを区切っている。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その柵の鉄鎖に、一人の男が腰をかけて、丁度ぶらんこにでも乗った恰好で、ふらりふらり身を揺っていた。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ももうその時は、柵の鉄鎖に腰を下していた。",
              "citation": {
                "source": "椿の花の赤",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そらあ急嶮い山だ、鉄鎖が十本もさがってるのを、つたって上るのだからね。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダン艇長も、鉄鎖でつながれている太刀川を見て、「おお、……」　と、いって、かけだそうとした。",
              "citation": {
                "source": "太平洋魔城",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "而してその他の人々に至つては徒らに『鉄鎖を求め埒内に止まらんこと』のみを希ふてゐる。",
              "citation": {
                "source": "恋愛と道徳",
                "author": "エレン・ケイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは全く女子の本性を拘束する道徳上及び社会上の偏見の鉄鎖が煩はしく耐へがたきものになつてきたからである。",
              "citation": {
                "source": "婦人解放の悲劇",
                "author": "エンマ・ゴルドマン",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは私も、思いきって自分の鎖を振り棄て、自由で高潔な精神をもってあたりを見まわしたが、鉄鎖が肉に食いこんでいるのを見て、ふたたび戦慄し失望してみじめな自分に還るのであった。",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
