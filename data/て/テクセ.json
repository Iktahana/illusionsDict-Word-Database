    "definitions": [
      {
        "index": 1,
        "gloss": "having sticky fingers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三男は子供のときから手癖が悪いので、おまきの方から追い出してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "女に似あわない大酒は、こういう商売の者として大目にも見られたのであるが、そのほかに誰にもゆるされないのは、かれの手癖の悪いことであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "手癖が悪い――泥棒だというのである。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしは、手癖がわるいのよ。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この持ち主について確かなのは、体格の立派な男で左利き、歯は丈夫だが手癖が悪く、あとあえて節約生活を送る必要はないということだ。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "花鳥はどうも手癖が悪くって、客の枕探しをする。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘のお節は容貌も好し、見たところは如何にもしとやかな女ですが、どういうものか手癖が悪くって、肩揚げの取れない頃から万引きなどを働いていたんですが、見掛けがおとなしいから誰も気がつかない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大阪屋花鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "一生のうち、たったいちど、思わず右手が一尺うごいたからって、それが手癖の悪い証拠になるのでしょうか。",
              "citation": {
                "source": "燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "猴は前にもしばしば述べたごとくすこぶる手癖の悪いもので盗才が多い。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに一方では猴がややもすれば手が長いところから、今も紀州などの田舎では庚申の夜交われば猴に似て手癖悪き子を生むと信ずると同時に、庚申を信ずれば盗難を免るとし、失踪人や紛失物を戻し、盗賊を捕うるにこの神に祈り、縄を以てその像を縛るは、その本意神様を盗人と見立てたので、この神、本は猴だったと知れる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "手癖の悪い娘が出来たり、虚栄のために身を持ち崩すお嬢さんが出来たりしている。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "展かれたのは、モウ手癖のついてゐる例の馬太伝第二十七章である。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "展かれたのは、モウ手癖のついてゐる例の馬太傳第二十七章である。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の妻君は、さう言つちや悪いけれど、少し手癖が悪いんぢやないかい。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして女中頭はああ手癖が悪いのか？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにせ、うちの奴らはみんな手癖が悪いだから？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから台所をちょっと覗いて、召使たちが満足な物を食っているかどうかと調べるような顔をして、玉菜汁と粥を鱈腹つめこみ、一同を誰彼なしに、手癖が悪いの、身持がよくないのと罵りちらしておいてから、自分の部屋へと戻った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でも百姓たちのあけすけに供述したところによれば、この駐在巡査はまるで狒々のように好色で手癖が悪かったので、彼等はもう一再ならず彼に警告を与えており、一度などは、夜這いに入っているところを丸裸のまま追い出したことさえあるというのであるが、しかし確かなところは分らない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勘当をされても手癖がなおらぬ上に大恩ある家のお嬢様を盗むは何事だ」と責めた。",
              "citation": {
                "source": "黒白ストーリー",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何れも同説で、夫れから陸に上て茶屋見たような処に行て、散々酒を飲でサア船に帰ると云う時に、誠に手癖の悪い話で、その茶屋の廊下の棚の上に嗽茶椀が一つあった、是れは船の中で役に立ちそうな物だと思て、一寸と私が夫を盗で来た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「が、今はわしの部下じゃ」「…………」「悪い手癖もやめている」「…………」「ついでにみんな明かしてしまえ。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに手癖がわるかつた。",
              "citation": {
                "source": "老嫗面",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "なあに、そんなことがあるものか、自分というやつの手癖足癖が悪いから、こうなったに相違ないが、嬶が良かったらこうならずに済んだかと思われるのも、まんざら愚痴じゃあるめえ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "２．彼は手癖が惡い。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "餓鬼の時から手癖が悪く――」「抜け参りからぐれ出して。",
              "citation": {
                "source": "或る日の小せん",
                "author": "吉井勇",
                "note": "青空文庫"
              }
            },
            {
              "text": "診察を終るのを待ちかねた主人は、突然大きな声を出して、「先生、せんだって催眠術のかいてある本を読んだら、催眠術を応用して手癖のわるいんだの、いろいろな病気だのを直す事が出来ると書いてあったですが、本当でしょうか」と聞く。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまあみろ、そういう手癖のわるいやつは殺されるのがあたりまえだと、はるかＭ橋の欄干からＸ街の屍体をむちうったが、こうなると、万年ペンから足がついておれが「その夜の男」にならぬともかぎらぬ。",
              "citation": {
                "source": "放浪作家の冒険",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "生れると直ぐ他家の籍に入ったのですから――、その弟が公高のように才はじけた頭のいい美しい少年でしたが、年頃になると不良仲間に入り隼の正という名までつけられ、その上、手癖が悪るく箸にも棒にもかからなかったが、喧嘩で大怪我をしたのが原因で死にました。",
              "citation": {
                "source": "魂の喘ぎ",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の野郎は手癖が悪い」「一杯機嫌で行ったんだ。",
              "citation": {
                "source": "ある温泉の由来",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何でもありやしません、不斷から手癖の惡い娘で、家中で持て餘されて居りますが、この物置に寢泊りして居るんですから、昨夜だつて、泥棒の入つたのを知らない筈はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "人肌地藏",
                "note": "青空文庫"
              }
            }
          ]
        }
