    "definitions": [
      {
        "index": 1,
        "gloss": "casting away one's vices or worldly desires and achieving enlightenment",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "我邦でも弘法大師は今に存在して、遍路の行者とまでも云えない世の常の大師まいりをする位の者の間にも時によりて現われて、抜苦与楽転迷開悟の教を垂れて下さるという俗間信仰がある。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっきょう宗教なるものも道徳と同じくその終局の目的とするところは各個人がおのれの欲するところを他に施すような浄土楽園を地上に造るにあるので、克己復礼を主眼とする孔子の教えも転迷開悟を唱道する仏の教えも、神者愛也と説くキリストの教えもみなこの目的に達するための種々の方便に過ぎぬ。",
              "citation": {
                "source": "理想的団体生活",
                "author": "丘浅次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏教に転迷開悟というはすなわちこれにして、迷とは有限性を示し、悟とは無限性を指すものなり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかして、その転迷開悟の方法に種々あるがゆえに、したがって多数の宗派を分かつに至る。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
