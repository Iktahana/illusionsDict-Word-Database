        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "小田巻草千日草｜天竺牡丹と各々手にとり別けて出かける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ばたの家に天竺牡丹がある、立ち留って見る。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよの心にはただ省作が見えるばかりだ、天竺牡丹も霧島も西洋草花も何もかもありゃしない。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダーリヤ　白井博士教示に天保十三年初めて輸入され、初めは蘭名ラノンケルで通用したが、葉花共にやや牡丹に近いゆゑ天竺牡丹と俗称したと、舶上花譜に出づと。",
              "citation": {
                "source": "きのふけふの草花",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "花壇にはいろいろ西洋種もまいて、天竺牡丹や遊蝶草などが咲いている。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "八車、孔雀草、天竺牡丹、昼照草、丁子草、薄荷などあり。",
              "citation": {
                "source": "わが幼時の美感",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダリヤは天竺牡丹といわれ稀に見るものとして珍重された。",
              "citation": {
                "source": "葛飾土産",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度其れと同じやう、現代の年少詩人が日本にも随分古くからある天竺牡丹の花に殊更ダリヤといふ洋語を応用し、其の花の形容から失へる恋、得たる恋の哀楽を叙して、忽ち人生哲学の奥義に説き及ぶが如き、亦よく吾々の時代思潮を語るものでは無からうか。",
              "citation": {
                "source": "虫干",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし彼方此方見廻っている中に『ダリヤ』（和名天竺牡丹）という札が目につきました。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『御前、ダリヤは天竺牡丹でございますか？",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天竺牡丹なら昔から日本にありますから、いくら無学な私でも能く存じて居ります。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽織袴で天竺牡丹の化物を拝観したと思ったら馬鹿馬鹿しくなりました。",
              "citation": {
                "source": "親鳥子鳥",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
