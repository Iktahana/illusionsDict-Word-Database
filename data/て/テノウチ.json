    "definitions": [
      {
        "index": 1,
        "gloss": "palm (of one's hand)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
