        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "じょん、べるとん英国ロンドン府、アワリー、テレグラフ社｜編輯行明治二十九（一八九六）年一月",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "じよん、べるとん英国ロンドン府、アワリー、テレグラフ社｜編輯行",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "デイリィ・テレグラフ――犯罪史上、稀にみる奇怪な惨劇である。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「テレグラフ紙とクロニクル紙の記事は一読を。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "……でも、そうじゃないわ――あなたは諷刺詩が書けないから、バルビエ風の短長格の長詩でも作って、その力作を『テレグラフ』誌に発表なさるわ。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「テレグラフ紙とクロニクル紙との記事は読んだ」「この事件も探究の方法としては、新らしい証拠を求めるよりも、既に知れている些末な事実を分析し淘汰して行く方が、賢い方法かも知れぬ。",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れはテレグラフだ。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「タイムス」「デリー・テレグラフ」をはじめ各国の特派員。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼のこの企ては、イギリスのデリー・テレグラフ新聞社とアメリカのニューヨーク・ヘラルド新聞社から、充分の後援を得ました。",
              "citation": {
                "source": "アフリカのスタンレー",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨネ野口の師事したウオーキン・ミラーという詩人で名高いバークレーの街を、ずんずん山手に登った所にテレグラフという大通りがある。",
              "citation": {
                "source": "バークレーより",
                "author": "沖野岩三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今は「テレグラフ」を取っておらん、「スタンダード」だ。",
              "citation": {
                "source": "倫敦消息",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレグラフ新聞の過激な見出しは一脈の詩的な英雄礼讃を思わせ、ホメロス的な勇気に満ちていた。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふとその頃に、倫敦タイムス紙やマンチェスター・ガーデアン紙、デリー・テレグラフ紙、クロニクル紙各紙の社会面を賑わしていたアンゴラ、ロアンダ特電の出来事が眼に触れたのであった。",
              "citation": {
                "source": "令嬢エミーラの日記",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくデイリイ・テレグラフ新聞を読んで楽しんでいると、個室と書かれた内扉がやっと開いて、白髪交じりの長身の男が、身障者を腕で支えて出てきた。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレグラフ新聞の最新版のここです。",
              "citation": {
                "source": "四日闇夜",
                "author": "THE FOUR DAYS' NIGHT",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
