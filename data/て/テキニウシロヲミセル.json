    "definitions": [
      {
        "index": 1,
        "gloss": "to flee from one's enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "昨夜おれが吉原行きを断わって戻って来たのを、放蕩者に似合わない、敵に後ろを見せるは名折れだとひやかしたが、本心はやっぱり、おれが吉原を断わって、待たせてある人のために帰って来てくれた、それがこんなに嬉しいのだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "椰子林の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "武士とあろうものが敵に後ろを見せるのか。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に後ろを見せるわけには行かないよ」　平次は隙間もる陽の光をながめながら、一寸も退く様子はありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に後ろを見せるといふ法は御座いません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "敵に後ろを見せるという法はございません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "大村兵庫の眼玉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それとも、敵に後ろを見せるのが癪だ、という反抗気分かも知れません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "勿来の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
