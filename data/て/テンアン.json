      {
        "index": 1,
        "gloss": "Ten'an era (857.2.21-859.4.15)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
