[
  {
    "uuid": "e252565c-ec21-5e14-8516-496c5e39d08f",
    "entry": "手乗り",
    "reading": {
      "primary": "てのり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
