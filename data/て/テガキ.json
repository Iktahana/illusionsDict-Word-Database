[
  {
    "uuid": "dcfca2ac-84a3-5a70-8fbd-e2401c12668f",
    "entry": "手書き",
    "reading": {
      "primary": "てがき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
