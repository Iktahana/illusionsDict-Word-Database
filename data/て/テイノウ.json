    "definitions": [
      {
        "index": 1,
        "gloss": "low intelligence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこにはむやみと生硬の漢語や、俗悪で不自然な言葉のアクセントや、中学生じみた幼稚な興奮や、およそさうした類の低能な感傷的表情を、むやみと鼓張した態度で一本調子に並べたてられて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "お爺さんも、この低能の踊りには呆れた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚感覺が倫理を覆つてゐる状態、これを低能あるひは惡魔といふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "低能でなければ惡魔である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、惡魔といふものは元來、低能なのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "審査委員が如何に私情ないしは私利のためにもせよ、学位授与の価値の全然ないような低能な著者の、全然無価値かあるいは間違った論文に及第点をつけることが出来ると想像する人があれば、それは学術的論文というものの本質に関する知識の全く欠如している人に相違ないであろう。",
              "citation": {
                "source": "学位について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "数学嫌いの生徒は日本に限らないと見えて、モスコフスキーの云うところに拠ると、かなりはしっこい頭でありながら、数学にかけてはまるで低能で、学校生活中に襲われた数学の悪夢に生涯取り付かれてうなされる人が多いらしい。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このいわゆる数学的低能者についてアインシュタインは次のような事を云っている。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "平生からお人好しで、愚圖で、低能な彼は、もともとだらしのない男だつたが、今は全く正體を失つてゐた。",
              "citation": {
                "source": "一兵卒と銃",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその中で日本人というものがはなはだしく低能な幼稚なものとして取り扱われているのに不快を感じると同時にその説がそれほどの名論とも思われないのを奇妙に思ったりした。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんにも書けない低能の文学少女、炬燵にはいって雑誌を読んでいたら眠くなって来たので、炬燵は人間の眠り箱だと思った、という小説を一つ書いてお見せしたら、叔父さんは中途で投げ出してしまいました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "弟の純次は低能に近いといっていいから尋常小学だけで学校生活をやめたのはまずいいとしても、妹のおせいに小樽で女中奉公をさせておかねばならぬというのは、清逸の胸には烈しくこたえていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今年は何台卵を孵えすんだね」「知らねえ」　母がさすがに気をかねて、「知らねえはずはあるめえさ」　と口添えすると、純次は低能者に特有な殺気立った眼を母の額の辺に向けて、「知らねえよ」　と言いながら持ち合わせた箸で食卓を二度たたいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその声のする方を見ると、少し低能じみた、そんな見分けのつきそうにもない小柄な少年の戸沢だった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純次はどうせ辻褄の合わないことをいう低能者ではあった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今の言葉に清逸は、低能でない何人からも求められない純粋な親切を感ぜずにはいられなかった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合あたりまえの娘ならば、真紅な顔になってはにかんでしまうか、おたけさん級の娘なら、低能じみた高笑いをして、男に隙を見せるか、悧巧を鼻にかけた娘なら、己惚れはよしてくださいといわんばかりにつんとするに極っているのだった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もし哲学者なり芸術家なりが、過去に属する低能者なら、労働者の生活をしていない学者思想家もまた同様だ。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人とも揃って低能らしいので、誰も相手にしなくなっていたのだそうです」　と、その巡査の話。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術家というものは弱い、てんでなっちゃいない大きな低能児ね。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "皮膚感覚が倫理を覆つてゐる状態、これを低能あるいは悪魔といふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "低能でなければ悪魔である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、悪魔といふものは元来、低能なのかも知れない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に「ツァラトストラ」の如きは、片手に註解本をもつて読まない限り、僕等の如き無識低能の読書人には、到底その深遠な含蓄を理解し得ない。",
              "citation": {
                "source": "ニイチェに就いての雑感",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見れば僕のような人間、初老の年を既に過ぎて、馬鹿げた妄想や情熱から、未練に執着を脱しきれないような男は、日本人としては少しケタ外れで、修業の足りない低能児であるかも知れない。",
              "citation": {
                "source": "老年と人生",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし一方から考えると、そこにはまた特別の事情があって、あながち僕の低能のせいでもない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分が低能のような気がして来た。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はおろか、ていのうです。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は少年時代には、ていのう児と云われ満州から内地に引揚げてからの生活の貧しさに弱い躰と頭のはっきりしない事でとても苦しい目に会って来ました。",
              "citation": {
                "source": "遺愛集",
                "author": "島秋人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「き、きさま、どうするか見ろっ……」　四十めんそうは、りょう手をひろげて、あけちたんていのうしろからおそいかかろうとしました。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
