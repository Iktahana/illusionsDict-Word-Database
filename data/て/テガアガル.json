      {
        "index": 1,
        "gloss": "to improve one's skill (esp. at calligraphy or drinking larger amounts of alcohol)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "書道を習い始めてから、彼の字の腕が上がったね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "最近、彼の麻雀の腕が上がったと評判だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "練習の甲斐あって、ゴルフの腕がめきめきと上がってきた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "だがプログラミング研究会と称するコンピューターの同好会に所属した小澤は、全国の大学でいっせいに紛争の火の手が上がる中で、大学にあったＩＢＭの大型機用にコボルやフォートランでプログラムを書くことを面白がっていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "グルグルグルと渦が巻く、ヒラヒラヒラと手が上がる、そのつどそいつが飛んで来る。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "公定価格のすべてがあがる。",
              "citation": {
                "source": "便乗の図絵",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
