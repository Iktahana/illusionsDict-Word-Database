          "literary": [
            {
              "text": "その四五日前、私は「ダイス」のマダムから四ツ橋の天文館のプラネタリュウム見物を誘われた。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿は九州の縣知事が集まるといふので、一日で追はれて、天文館通りに近い、小さい旅館に變つた。",
              "citation": {
                "source": "屋久島紀行",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕暮れの通りを、賑やかな天文館通りへ出て、富岡は、映画館の一つ一つを眺めてまはつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
