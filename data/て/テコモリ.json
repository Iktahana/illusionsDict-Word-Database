    },
    "definitions": [
      {
        "index": 1,
        "gloss": "piling up high (food in a bowl)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まあまあ、どうぞお一つ、それやアお一つ、てこ盛りで、勧め方があくどいからね。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "この容態で氏は、家庭に於て家人の些末な感情などから超然として、自分の室にたてこもり勝ちであります。",
              "citation": {
                "source": "岡本一平論",
                "author": "――親の前で祈祷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ当年北畠親房が一時たてこもりたる処也。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれ二人は、博士の遺志をついでこの花陵島にたてこもり、あくまで火星の生物に対抗しようとかたく誓ったことであった。",
              "citation": {
                "source": "地球を狙う者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八九〇年代のフランス文学の潮流は、一方に象徴派が隠遁超脱の城に立てこもり、一方には自然主義者たちが、象徴派の人々の神経病を嗤っているという時代であった。",
              "citation": {
                "source": "ジイドとそのソヴェト旅行記",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、一九二四年代に、プロレタリア作家たちが、「工場的抽象的ロマンチシズム」に立てこもり、現実から離れた不自然な楽観主義で、所謂「木造の赤い聖画」（空虚な宣伝文学）制作に満足しているべきでないこと、過去の文学の伝統に対する清算主義を批判したこと等においてウォロンスキーは誤っていなかった。",
              "citation": {
                "source": "ソヴェト文壇の現状",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は南の町の寝殿へ、夫人の所から離れてこもりながら、どうして習得したのか承和の帝の秘法といわれる二つの合わせ方で熱心に薫香を作っていた。",
              "citation": {
                "source": "源氏物語",
                "author": "梅が枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "連合赤軍による事件が浅間山荘への立てこもりから内部でのリンチによる殺人へと大きくその相を変えた時期、タケシは合格の報せを受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "われ箱根山上にたてこもりて著述に苦心しけるに、思ひがけずも、春浪に邂逅す。",
              "citation": {
                "source": "酒に死せる押川春浪",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、タクマールといふ勇敢な娘が、僅か十八歳の身で、その年下の弟や妹たちを助けて、この塔に立てこもり、最後まで敵と戦つて、とう／＼切り死にしました。",
              "citation": {
                "source": "ラマ塔の秘密",
                "author": "宮原晃一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "襖をしめてたてこもり、私を一層苦しくさせる、気勢・足音、せき払の音ばかりで刺戟するのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二三年（大正十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "洗面も食事も済むと、神尾は書斎へ立てこもりました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "南北朝は元中九年（北朝の明徳三年）南朝の後亀山天皇が北朝の後小松天皇に神器を伝えて、南朝の不和は和解したことになっているが、実はさにあらず、後南朝というべきものがあって、その後も吉野にたてこもり、六十五年がほど抗争していた。",
              "citation": {
                "source": "安吾の新日本地理",
                "author": "飛鳥の幻――吉野・大和の巻――",
                "note": "青空文庫"
              }
            },
            {
              "text": "市川三左衛門をはじめ諸生党の領袖が国政を左右する時を迎えて見ると、天狗連の一派は筑波山の方に立てこもり、田丸稲右衛門を主将に推し、亡き御隠居の御霊代を奉じて、尊攘の志を致そうとしていた。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き男の詭計を用いたのも、糞尿の計を用いたのも、わずか百五十人の寡兵をもって金剛山に立てこもり、北条二十万の大軍を堂々として破ったのも、この書がお手にあったればこそだ。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十人近くのお客さんが、店に一杯立てこもり、盛んに話しながら飲み食いしている。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "高大之進の尚兵館組と、結城左京等の道場立てこもりの一統とは、底も知れない穴へ左膳がおちこんだのをこれ幸いと、泣きさけぶチョビ安をそのままに、そうそう引きあげてしまったのだ。",
              "citation": {
                "source": "丹下左膳",
                "author": "日光の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに立てこもりながら、長々と室一杯の日なたにねそべつて、鏡花本の風流線であるとか同じく三枚続、通夜物語等々、新装された諸本を、飽かず楽しんだ「夢」は、忘れ難いものがある。",
              "citation": {
                "source": "鏑木さん雑感",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんらかの陣営に立てこもりたいことはかつてなかったか、」と彼は尋ねてみた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――サン・メーリー修道院だけでも六百の人数がいて、会堂の中に立てこもり銃眼をあけている。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "館林には留守兵をはじめ、上野のくに八ヶ城の兵およそ六千余騎がたてこもり、力をあわせて防戦したが、もとより寄り集りの兵のことで決戦の意気もなく、わずか三日のたたかいにあえなくやぶれ、おなじ三十日にはついに降参のうえ開城してしまった。",
              "citation": {
                "source": "日本婦道記",
                "author": "笄堀",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし失敗しても、皆でこの邸宅へ戻り、奴らに知られないうちに立てこもりましょう。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "わけて夫人が、良人の死後、一族もみな討たれて少ない中に、よく三、四千の小勢をもって、河内の小盆地にたてこもり、正行、正時の成人を待っていた十二年間の苦節を語るだんになると、涙に顔もよごしていった。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "右大臣家（織田）にたいし奉り、疎意抱くにあらねど、当家も三木城にたてこもり、羽柴どのの手を離れて、善戦独歩の覚悟相定め申し候。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには城兵が千余人もたてこもり、中国の豪将日幡｜景親がおり、また軍監としては、毛利家の一族｜上原元祐がこれを扶けていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ妙覚寺へ行ったが、ここの一隊もすでに二条へたてこもり、城内は濛煙につつまれている様子。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここにあるべきはずの北畠信雄は、蒲生賢秀とともに江州の土山にたてこもり、いまなお伊勢伊賀の叛乱軍と抗戦中なることも来て見てわかった。",
              "citation": {
                "source": "新書太閤記",
                "author": "第八分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "主柱たる劉県の城にたてこもり、依然として抗戦しつづけていた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "まずは関東を相手に、一戦の上ならでは、寄りつくまい」　正成のことばどおり、やがて赤坂の一塁は急速に出来上ったが、そこへたてこもり得る兵力は、一族五百少々、近郡の武士百人足らずにすぎなかった。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "事実、半年ちかくも山上にたてこもりながら、すこしも楠木勢におとろえがみえないのは、その水ノ手の確保にあると、寄手方では観察している。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
