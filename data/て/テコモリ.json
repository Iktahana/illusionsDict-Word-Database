[
  {
    "uuid": "cd7ae328-f7bb-56ea-83cd-ad95e065bf4c",
    "entry": "てこ盛り",
    "reading": {
      "primary": "てこもり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
