        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "支那語の達者な友人は早速笑ひ聲を交へながら女と何やら話しはじめたが、僕は至極手持ち無沙汰である。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の社会生活が進歩した結果として、何もしないで楽に遊んでいられる人間が多数に存在するようになると、今まで使っていた手が暇になって、全く言葉どおりに手持ちぶさたを感じる。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白日のもとに見るとあれはいかにも手持ちぶさたな間の抜けたものである。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる宣伝を手持ちぶさたにする「太陽」のようなものがもし何かあるとしたら、それはどういうものであろう。",
              "citation": {
                "source": "神田を散歩して",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機がぱたりとやむと、踊り子たちの手持ちぶさたを紛らすためにだれかが歌いだす。",
              "citation": {
                "source": "沓掛より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛騨は、手持ちぶさたげに床をスリツパでぱたぱたと叩いたりして、しばらく葉藏の枕元に立つてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん毎朝見ているものを見ないという一種の手持ちぶさたな感じはあったに相違ないが、それと同時になんだか急に世の中がのんびりしたような気持ちがないでもなかったように思う。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は貴女のいるのに気づくと手持ち無沙汰そうに立ちすくんだ。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで手持ち無沙汰で帰って来て、文殊にその報告をしたという寓話が「五燈会元」という本に載っております。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はしばらく手持ち無沙汰の様子。",
              "citation": {
                "source": "ある日の蓮月尼",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行は元来（人間の生活というものも、同じことだと思われるが）手持ち無沙汰なものである。",
              "citation": {
                "source": "『井伏鱒二選集』後記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "好奇心で一ぱいのかの女には却って何やかや観察の時間が与えられ都合がよかったが、常識的の社交の儀礼に気を使うらしい夫人は、ひどく手持ち無沙汰らしく、その上茶を勧めたり菓子を出したりして、沈黙の時間を埋めることを心懸けているように見えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に刹那々々の刺戟のほかには……」と負け惜しみのやうなことを云ひながら、手持ち不沙汰にそれを巻き納めて部屋を出て行くのだつた。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女たちは、手持ちぶさたの様子であった。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "女たちは、手持ちぶさたの様子であつた。",
              "citation": {
                "source": "火の鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへ一瞬時でも、おれは手持ちぶさたな思ひをしたくなかつたのである。",
              "citation": {
                "source": "陰火",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十手持ちたるが引添いて眼を配り、顱巻したるが肩をあげて睨め着くる。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "李太郎も手持ち不沙汰のような形でうつむいていた。",
              "citation": {
                "source": "雪女",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はその後ろに小さくなって手持ちぶさたでいると、おりよくここの俊ちゃんが出て来て、待ちかねていたというふうで自分を引っ張ってお池の鯉を見に行った。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼は、その豪壮な新邸宅ですることもなく手持ち無沙汰に暮らしていた。",
              "citation": {
                "source": "或る部落の五つの話",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市内電車の中で手持ち無沙汰に乗車券を弄ぶ女達の指。",
              "citation": {
                "source": "指と指環",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手持ちの賭け帳を調べてみると、自分であの名馬の負けに五〇〇〇ポンドも賭けたと控えてあった。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "手持ちの材料では、とても空白を埋めきれないと、あからさまになってきたのです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑うひとは、たとえば井伏鱒二の短編小説を手持ちのＤＴＰソフトで何通りかに詰め組みしてみよ。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、手持ちぶさたを紛らすためにＮの喉をギユツと絞めたりした。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻から手持ちぶさたそうにただ立って成り行きを見ていた五十川女史は思いきって近寄って来て、若者を葉子から引き離そうとしたが、若者はむずかる子供のように地だんだを踏んでますます葉子に寄り添うばかりだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども鞄膝掛けその他いっさいの手荷物はすでに宿屋の番頭が始末をして、ちゃんと列車内に運び込んであったので、彼はただ手持ち無沙汰にプラットフォームの上に立っていた。",
              "citation": {
                "source": "手紙",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "手持ちぶさたの慶一が、気配を感じて、ついたてのほうに目をやった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それやこれやを思いますとな、どう考えてもちと親が無慈悲であった様で……。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂本｜繁二郎氏のセガンチニを草体で行ったような牛の絵でも今見てもちっとも見劣りがしない。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
