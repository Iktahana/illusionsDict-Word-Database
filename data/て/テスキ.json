    },
    "definitions": [
      {
        "index": 1,
        "gloss": "not busy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "典型的なもくもくと盛り上がったまるい頭を並べてすきまもなく並び立っていた。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分なども時々だいじな会議の日を忘れて遊びに出たり、受け持ちの講義の時間を忘れてすきな仕事に没頭していたり、だいじな知人の婚礼の宴会を忘れていて電話で呼び出されたりして、大いに恥じ入ることがあるが、しかたがないからなるべく平気なような顔をしている。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいて手にもったその一つぶのばらの実を見ましたら、それは雨の雫のやうにきれいに光ってすきとほってゐるのでした。",
              "citation": {
                "source": "よく利く薬とえらい薬",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家普請を春のてすきにとり付いて」（野）の静かな低音の次に「上のたよりにあがる米の値」（芭）は、どうしても高く強い。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり僕も気の毒になったから屋根の上からじっとボールの往来をにらめてすきを見て置いてねえ、丁度博士がサーヴをつかったときふうっと飛び出して行って球を横の方へ外らしてしまったんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの花の盃の中からぎらぎら光ってすきとおる蒸気が丁度水へ砂糖を溶したときのようにユラユラユラユラ空へ昇って行くでしょう。",
              "citation": {
                "source": "チュウリップの幻術",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなんとなくさびしく空虚な頭の底によどんでいた長い長い旅の疲労が、今にも流れ出ようとしてすきまを求めていた。",
              "citation": {
                "source": "旅日記から（明治四十二年）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おやゆび姫はかれたはっぱにくるまりましたが、真ん中にひびが入っていてすきまからぬくもりが逃げていきます。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "了意の『東海道名所記』に「大きなる赤犬かけ出てすきまなく吠えかかる云々、楽阿弥も魂を失うて俄に虎という字を書いて見すれども田舎育ちの犬なりければ読めざりけん、逃ぐる足許へ飛び付く」とある。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "光みち／＼てすきとほすばかりなり。",
              "citation": {
                "source": "月",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "父も工合わるいスエ子と自分フジへ行ってすきやきサンミッシェルの角まで歩いて車　　　コンコードの美しさ　　　十時ごろはもう消える夜十一時頃　ホテルモンソーへかえる　十月六日　　カーテンから朝日この数日ない。",
              "citation": {
                "source": "「道標」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "王　　さてさてすきこのみの多い人じゃ。",
              "citation": {
                "source": "胚胎（二幕四場）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が自分の空想の小さいはけ口としてその音楽堂の素描を私にまで見せたりした、その望みは十何年か前から既に心に潜んでいたものであったのかと、特に当時は父が大してすきでもなかった文部省の小役人であったとしてみれば、一層この実現したかしないか分らないデッサンにしたしみを覚えます。",
              "citation": {
                "source": "父の手帳",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪ぐらい自分の頭に生えているものなのにどうしてすきに結っていけないのだろう。",
              "citation": {
                "source": "青春",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが商売となればどんな厭やなこともがまんしなきやならず荒くあたられてもやはらかに受けなきやならない、丁度看護婦か何ぞのやうにね、無論だれだつてすきこのんでする事ぢやない。",
              "citation": {
                "source": "ウォーレン夫人とその娘",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして好きな金魚が寒鯉のように動かずじっとしていると心配になるとみえて、竹のきれをもって来てすき間から金魚をついてみて金魚が動くとさも安心した顔をするのである。",
              "citation": {
                "source": "棲霞軒雑記",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "青みを帯びた白い顔は美しくてすきとおるような皮膚つきである。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰でもすきな花聟を見つけるがいいよ、そしてすきな男をからかふがいいさ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "教科は殆んどのけものにされてすきな文学物の書ばかりが机の上に乗るやうになつた。",
              "citation": {
                "source": "惑ひ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月六日（火曜）晴　暖〔摘要〕大瀧氏へ御年始かたがた午後から遊びに行く〔発信〕成井先生　岡田信一郎　福島祖母君〔受信〕曾我ふみ子　すきだらけな気持で行ってすきだらけでかえって来た。",
              "citation": {
                "source": "日記",
                "author": "一九一四年（大正三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうしたらね、己だってすきな女を囲ってさ。",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「又一日ねころんで居なくっちゃあなるまい、子供なんて……、どうしたってすきになれるものか……」と天井をにらんで云った。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいかげんに稽古をしまって母親はしのび足に二階にのぼってすきまから目だけでのぞくと筋がぬけたようなかたちをして手すりに頭をおっつけて午後のキラキラした川面をとんで居る都鳥の姿をなつかしそうに見て居た。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "インクの色もその人の年によってすきな都合が違うと云うことをこの頃になって知った。",
              "citation": {
                "source": "芽生",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢中になってすきがって居る人の詩集を抱えたまんま眠った様なさめた様な気持で目を細くあいたりつぶったりして居た。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌にしよう、よい歌を作り上げようといふ意圖のなかつた僧家の歌に、ほんの稀々ながら、とびぬけてすきになれる物がある。",
              "citation": {
                "source": "好惡の論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が、元のように其那下らないものの何が面白いのだ、と云う調子で云ったら、Ａは、さも侮蔑されたように、「百合ちゃんのように家に居てすきなことをして居る人には必要でもなく興味もないかもしれないが、外に出て居る男には」必要と切実な興味があることを主張するだろう。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "中井氏を私はどうも大してすきになれず。",
              "citation": {
                "source": "日記",
                "author": "一九二五年（大正十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう武士でないわしだから、何をしようと構わぬとあって、結句、よろこぶだろうよ」「旦那様といい、龍造寺さまといい、どうして結構な御身分をすててすき好んで町人になぞおなりなさるのでございましょうねえ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇子を半開きにしてすき透るやうな美声で順々に取組を披露する。",
              "citation": {
                "source": "両国今昔",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
