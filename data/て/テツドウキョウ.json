        "examples": {
          "standard": [
            {
              "text": "荒川に架かる巨大な鉄道橋を、真っ赤な車体の急行列車が轟音を立てて通過していった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "古い鉄道橋の橋脚にひび割れが見つかり、補修工事のために一部区間が運休となった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "夕暮れ時、オレンジ色に染まる空を背景に鉄道橋のシルエットが美しく浮かび上がっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "がらがらと音がして、汽車が紫川の鉄道橋を渡ると、間もなく小倉の停車場に着く。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "川が崖に沿うて走るようになり、白い巌壁からなる峡の鉄道橋を渡ったとき、ドナウが依然としてそう細くなってはいなかった。",
              "citation": {
                "source": "ドナウ源流行",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
