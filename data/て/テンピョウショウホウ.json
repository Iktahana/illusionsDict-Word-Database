    "definitions": [
      {
        "index": 1,
        "gloss": "Tenpyō-shōhō era (749.7.2-757.8.18)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
