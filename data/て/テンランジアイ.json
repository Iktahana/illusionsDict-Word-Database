        "examples": {
          "standard": [
            {
              "text": "大相撲の天覧試合は、特別な緊張感と盛り上がりを見せる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔は、剣道の天覧試合が武士たちの間で最高の栄誉とされていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天覧試合に選ばれることは、選手にとって生涯忘れられない経験となるだろう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "清水さんは昭和五年の天覧試合だかに杖術の型を披露するため、神伝夢想流の先生にともなわれその高弟として上京したのだそうだ。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
