[
  {
    "uuid": "cb913ba9-88f3-530b-bdc2-5cc5df92aa7c",
    "entry": "テラ",
    "reading": {
      "primary": "テラ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
