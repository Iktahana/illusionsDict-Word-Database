    },
    "definitions": [
      {
        "index": 1,
        "gloss": "tera-",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "こんな暑い日にはいっそドテラでも着てみたら、どうかしら。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう十一月も終り頃だつたが、私が女の新しき家の玄関に例のワレ物の包みを置いた時、新しき男は茶色のドテラを着て、極端に俯いて次の間で新聞を読んでゐた。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩に面白いタランテラの踊りへ案内するから十時に玄関まで出て来いというらしかった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "埴輪のやうな、テラコツタの肌をしてゐるのであります。",
              "citation": {
                "source": "國技館",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべすべしてゐる床の上、金のカンテラ点いてゐる。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のこたあない、ストーヴの中のカステラ見たいな、熱さには、ヨウリスだって持たないんだ。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "とある宿屋の前の崖にコンクリートで道路と同平面のテラスを造り其の下の空間を物置にして居るのがあるのは思ひ付きである。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベンチの上にはしわくちゃの半紙が広げられて、その上にカステラの大きな切れがのっている。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩道へ半分ほどもテーブルを並べ出して、角隅を硝子屏風で囲ってあるテラスのまん中に置いた円い暖炉が背中にだけ熱い。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い秋を見限ってテラスの真ん中の丸暖炉と、角隅を囲う硝子屏風はもう季節の冬に対しての武装だ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "キャフェのテラスに並んでうそ寒く肩をしぼめながら誂えたコーヒの色は一きわきめこまかに濃く色が沈んで、唇に当るグラスの親しみも余計しみじみと感ぜられる。",
              "citation": {
                "source": "巴里の秋",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "父はあまり遠くない蘆の中で、カンテラを燃して数珠子釣りをやっている。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の武士の中の変人達が酷暑の時候にドテラを着込んで火鉢を囲んで寒い寒いと云ったという話があるが、暑中に烈火の前に立って油の煮えるのを見るのは実は案外に爽快なものである。",
              "citation": {
                "source": "さまよえるユダヤ人の手記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "坑夫等はもちろん裸体で汗にぬれた膚にカンテラの光を無気味に反映していた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アナタコノヘンノオテラ、ボンゾサン　シッテヰルゴザイマスカ。",
              "citation": {
                "source": "一九三一年度極東ビヂテリアン大会見聞録",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラの光に、兵士たちが蠢めいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乳のあたり、腰から太股のあたりが、カンテラの魔のような仄かな光に揺れて闇の中に浮び上っている。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "背後には、井村が、薄暗いカンテラの光の中に鑿岩機をはずし、ハッパ袋をあけていた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、うしろからは、導火線に点火し終った井村がカンテラをさげ、早足に、しかもゆったりとやって来た。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そのカンテラがチラ／＼見えた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、差し出したカンテラが、彼女にぶつかりそうになって、始めてそれに気がついた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラの火がハタ／＼ゆれた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラを突き出た岩に引っかけると、いきなり無言で、彼女をたくましい腕×××××。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　カンテラに薄く照し出された女の顔をま近に見ながら彼は考えた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白服の、課長の眼鏡が、カンテラにキラ／＼反射していた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、カンテラと、金の金具のついた縁なしの眼鏡を岩の断面にすりつけた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　彼は、眼鏡とカンテラをなおすりつけて、鉱脈の走り具合をしらべた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンテラが、無愛想に渋り切った井村の顔に暗い陰影を投げた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」脚の悪い老人は、心配げにカンテラをさし上げて広々とした洞窟の天井を見上げた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　老人はなお、ざら／＼に掘り上げられた天井の隅々をさぐるように、カンテラを動かした。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
