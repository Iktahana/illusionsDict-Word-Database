  {
    "uuid": "908426f0-5dcd-54dc-b2fc-d3dba3022826",
    "entry": "寺",
    "reading": {
      "primary": "てら",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "temple (Buddhist)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "車が芝南寺の少し手前まで来ると、助手台に乗つてゐた谷丹三の親友が、急に停車を命じた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "牧野さんは当時南寺の借家にゐた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなた一所に行きます』と言って、ヘルンが妻を連れ出す所はたいてい多くは寂しい静閑の所であり、寺院の墓地や、邸の空庭や、小高い見晴らしの丘などであった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたヘルンの小泉八雲が、常に最も好んだ散歩区域は、寺院の閑静な境内だった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "特に東京の富久町に居た時には、近所の瘤寺へ毎日のように出かけて行った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その寺は庭が広く、背後に老杉の茂った林があったので、彼の瞑想的な散歩に最も好ましい所であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の老僧とも懇意になり、ついにある時、自分がその住持になりたいと言い出し、夫人と次のような問答をした。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ママさん私この寺に坐る。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺の住持になって世を隠遁し、読経と墓掃除に余生を送りたいといった彼の言葉は、決して一時の戯れではなく、彼の心の無限の悲哀を告白した言葉であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして田舎の、寂しい寺に埋めて下さい。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れかけて来たころ、私はやっと立ちあがって、死んだように、ぼんやりなってお寺へ帰ってまいりました。",
              "citation": {
                "source": "葉桜と魔笛",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "清水寺のすぐちかくに赤い毛氈を敷いた縁台を二つならべて置いてある小さな甘酒屋で知り合った。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "碧雲寺を背景にして支那服を着て立っている写真。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺町の呉服屋の、豊田様であります。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられてゐて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えてみると、僕たちだって、小さい時からお婆さんに連れられてお寺参りをしたり、またお葬式や法要の度毎に坊さんのお経を聞き、また国宝の仏像を見て歩いたりしているが、さて、仏教とはどんな宗教かと外国の人に改って聞かれたら、百人の中の九十九人は、へどもどするに違いないのだ。",
              "citation": {
                "source": "世界的",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が中学の二年生の頃、寺町の小さい花屋に洋画が五、六枚かざられていて、私は子供心にも、その画に少し感心しました。",
              "citation": {
                "source": "青森",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "住んでゐたのは野田寺町の照月寺（字は違つてゐるかも知れない）の真前、犀川に臨む庭に、大きい松の樹のある家であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが野田寺町の先刻云つた家であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方弟と二人で近所の子供が集つて遊んでゐる寺の庭に行つた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺ばかりといつてもいゝやうな町に住んでゐたので、葬式は実に沢山見た。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬式のあるたんびに子供達は葬式をやつてゐる寺に名刺を持つて行つて菓子を貰ふのであつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが面白かつたので、すぐ次の外題が掛かると祖母にせがんで連れてつて貰つたが、その時は本願寺の高僧の葬儀の実写か何かで、後から後からゾロゾロゾロゾロ坊主ばかりの行列であつた。",
              "citation": {
                "source": "金沢の思ひ出",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺小屋育ちの祖母には、中学の学問と言ふものが、非常な大した物と思はれるのであつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "古寺やほうろく捨てる芹の中　荒廃した寺の裏庭に、芥捨場のような空地がある。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "閑居鳥寺見ゆ麦林寺とやいふ　夏の日の田舎道、遠く麦畑の続いた向うに、寺の塔が小さく見える。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……対象の知れぬ寂しみ神様はつまらぬものゝみをつくつた盥の底の残り水古いゴムマリ十能が棄てられました雀の声は何といふ生唾液だ！",
              "citation": {
                "source": "（ツツケンドンに）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "芭蕉は、一物と他物との合体の瞬間に於ける妙といふことを、非常に大切にしたのであるが、そして恐らく此の事こそ俳句の最高眼目たるものでもあらうが、その眼目が射当てられるためには、蓋し情理的であるよりもおのづと感覚的である方が適切であるに相違ない。",
              "citation": {
                "source": "新短歌に就いて",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "親戚はネグロ達から家を逐ひ立てられてゐるといふ始末であつた。",
              "citation": {
