    "definitions": [
      {
        "index": 1,
        "gloss": "Teigin Bank robbery (in which 12 people died of cyanide poisoning; 1948)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この帝銀事件が、わたしたちに教えていることは極めて意味がふかい。",
              "citation": {
                "source": "目をあいて見る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それから、ずっと前の、椎名町の帝銀事件だ。",
              "citation": {
                "source": "或る作家の厄日",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件で十二人死んだ。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件余談　帝銀事件犯人の似顔絵の発表は無理だろう。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件の犯人が早くつかまるということよりも、人権を尊重するということの方が、どれだけ大切なことか分らない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件の犯人のタイホがおくれてもよいから、人権を尊重するという国風は断じてこれを守り、確立しなければならない。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件の犯人のタイホがおくれてもかまわぬ。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件の犯人などはゴマシオ頭のくせに、たった十六万ぬすむのに十二人も殺している。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は帝銀事件の犯人が怖い。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は帝銀事件の犯人などにも、同様な家族的｜掩護があるのじゃないかと考える。",
              "citation": {
                "source": "ヤミ論語",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が帝銀事件に感じるものは、決して悪魔の姿ではない。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は帝銀事件の犯人に、なお戦争という麻薬の悪夢の中に住む無感動な平凡人を考える。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "片山前首相が、帝銀事件の犯人について、未曾有の兇悪犯であり、すべてに代えて逮捕せよ、などと警官を激励するのはオコの沙汰と申すべきで、これが警視総監の言ならば当然であるが、首相たるもの、その政策のいたらざるをまずもって三思すべきではないか。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は帝銀事件に戦野を思う。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件などは、どうでもいい。",
              "citation": {
                "source": "帝銀事件を論ず",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件などはそのデカダンスによる悲劇の一ツとも云えよう。",
              "citation": {
                "source": "親が捨てられる世相",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "労働組合の運動そのもののなかに多分の「封建性」がみられるように、例の帝銀事件も、犯罪の特質をよく考えてみると、日本人の特殊な残虐性というようなものではなく、むしろ、「長いものにまかれる」一種の事大的傾向があの悲劇をもたらしたものといえましよう。",
              "citation": {
                "source": "Ｓ夫人への手紙",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウチじゃア、帝銀事件ぐらいじゃ、驚く人はあんまりいないわね。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "毒をのまされた娘は、帝銀事件の何とかさんの何倍もシャンだそうですぜ」「バカ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件は来年起るんだ」　ようやく記者の包囲を脱して門内へ逃げこむ。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件の犯人がほかに居ればよいという考えは、平沢氏に対する同情からのことではなくて、手際よき忍術使いへの憧憬だ。",
              "citation": {
                "source": "安吾巷談",
                "author": "湯の町エレジー",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが帝銀事件であった。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "私がなんとか組のなんとか氏と腕相撲していた時刻に、帝銀事件が起っていたのである。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、私は帝銀事件に限ってアリバイがある。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "何月何日にどこで何をしていたというようなことは、自分の大切なことでも忘れがちなものだが、帝銀事件に限って、身のアリバイを生涯立証することができるという妙な思い出を持つに至ったのであった。",
              "citation": {
                "source": "安吾巷談",
                "author": "熱海復興",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来小心の花田が、犯人の如く、心細く窓口に待つところへ、ホンモノの二十万円が事もなげにつみ重ねられ、イヤ、驚いたネ、そうですとも、二十万円と申せば、帝銀事件の先生よりも三万円も余計じゃないか。",
              "citation": {
                "source": "カストリ社事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそのことで憤死したとは突飛な飛躍で、帝銀事件の容疑を裏づけるに、こんな飛躍をしたならば、たちまち検事は失格するが、中野好夫教授は教授も批評家も失格しないから、文壇は楽天地である。",
              "citation": {
                "source": "志賀直哉に文学の問題はない",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝銀事件の場合の如き、首実検など、一番当にならないものだ。",
              "citation": {
                "source": "切捨御免",
                "author": "――貞操なきジャーナリズム――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の探偵作家（外国の作家も）たちはやたらと作中に刑事をボンクラに仕立てゝ名探偵を登場させるが、帝銀事件の如く、実際の犯罪は、偶然に行われるから、却々犯人がつかまらないのは当然で、これは刑事の頭が悪いのでもなく、近代捜査法を知らないのでもなく、偶然だから、つかまらないのだ。",
              "citation": {
                "source": "「刺青殺人事件」を評す",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
