[
  {
    "uuid": "220c21cc-feba-51fb-9db7-fe98fd2da3dd",
    "entry": "手配",
    "reading": {
      "primary": "てはい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "arrangement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自分が来たときしばらく待たせておいたのもその手配をするためだったのか。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ァ手配するから、手前達、もう少し見張ってろ」Ｓ＝次郎長の居間　次郎長と石松、大瀬の半五郎など居る。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "主膳尚も近侍に、Ｔ「早速御手配なされとな」　近侍心得て去ろうとする。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず行者一家の者どもを引き挙げて、それをぶっ叩いて白状させるよりほかあるまいと、かれは内々でその手配りにかかっていると、あしたが池上のお会式という日の朝、多吉があわただしく駈け込んで来た。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵士は南軍接近の知らせに、警備手配に忙殺されていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「野郎……貴様らが上海の本部へ逃げ込む序に門司から此地方へ道草を喰いに入り込んだのを聞くと、直ぐに手配していたんだぞ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから間もなく倉庫主任宛のお電話が警察にかかって参りましたのでスッカリ安心して手配してしまったのです。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "手配がすんだ証拠に、お山全体の電灯にスイッチを入れると申し上げて置きましたが、おわかりになりましたか」「ええ。",
              "citation": {
                "source": "女坑主",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田五十五万石の浮き沈みに拘わる一か八かの勝負に落ちるかも知れぬと思うたけに、特別に念を入れた極く内々の手配りで取りかかりたい私の考えじゃ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうすっかり手配がついています。",
              "citation": {
                "source": "ポラーノの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ手配が行われ、雪子は著物の柄が目印になって、つかまったのである。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "関白が政宗に佩刀を預けて山へ上って小田原攻の手配りを見せた談などは今｜姑く措く。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが氏郷の手配は行届いて居て、彼の三隊の後備は三段に備を立てて、静かなること林の如く、厳然として待設けて居た。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "末には維幾も勘忍し兼ねて、官符を発して召捕るよりほか無いとなつて其の手配をした。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "京師では驚愕と憂慮と、応変の処置の手配とに沸立つた。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理に瀧の上へ出て生命を粗末にしようとする狂人共を制する爲の手配であるが、見るさへにが／＼しい。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっぱりおれの思った通りや」　貴子は今日の昼間、夜の九時頃に立つといっていたが、その時間に出る東京行きの急行はこの二十一時大阪発の一本しかないと、章三は田村から大阪へ帰った足で、すぐ切符の手配をして、その汽車に乗り込んだのだった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに対して、穴穂王のほうでもぬからず戦の手配りをなさいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも後日の悪口の種を播かないように、兄夫婦は前からかなり神経を痛めていろいろの手配をして置いただけに、万事がとどこおりなく進行して、お客様いずれも満足であるらしかった。",
              "citation": {
                "source": "こま犬",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夜のこと、死刑にする筈の四人の囚人が、破獄したという通知が来たので、奈良原典獄は直ぐに駈付けて手配をさせた。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、此頃には信長の方でも準備おさおさ怠りなく手配して居るのであって、かの大高城の如きも充分に監視して、兵糧の入ることを厳重に警戒した。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "酒井与四郎｜正親、同小五郎忠次、石川与七郎数正等が「信長ならば必ずや城への手配を計画して居る筈である。",
              "citation": {
                "source": "桶狭間合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "この陣中、奥州の政宗が初て御機嫌伺いに来たとき、大軍の手配を見せてやるとて、政宗に自分の佩刀を持たせて、後に従えさせてただ二人で小高き所に上り、いろいろ説明をきかせたのは、有名な話しである。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　シャーロック・ホームズと私は、宿屋クラウン・インで、居間つきの寝室を難なく手配できた。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は神聖四長老会からフェリア父娘の逃亡を助けたかどで手配されてるんだぞ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「知ったことか、あんなやつらも、手配も。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "帆前船がサヴァナに到着するまでに郵便船はこの手紙を持っていくはず、さらに海底電信を通じてサヴァナ警察に、三人の紳士が殺人容疑でこちらで指名手配されていることが伝わるだろう。",
              "citation": {
                "source": "橙の種五粒",
                "author": "THE FIVE ORANGE PIPS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合もそいつの保釈や弁護用の金は手配される。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "片言の英語で赤帽相手に齷齪していたイタリア人の高位司祭がいたので、数分ばかり手間取ったが、手荷物輸送をパリ行きで手配してあると伝える手助けをした。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「臨時列車を手配する。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
