    "definitions": [
      {
        "index": 1,
        "gloss": "being exceedingly wiser than the common man",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ぜんたい、これは晩をすごすてきとうな方法でありましょうか。",
              "citation": {
                "source": "ひこうかばん",
                "author": "DEN FLYVENDE KOFFERT",
                "note": "青空文庫"
              }
            },
            {
              "text": "本船は、ただちにこの地点をひきあげ、てきとうなところで時間をおくり、あすの夜八時になったら、ふたたびこの地点まで来る。",
              "citation": {
                "source": "恐竜島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それまでに、われわれは、至急、てきとうな方法を考えて、海底超人族に対抗しなければ、手おくれになります。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは腕というよりも、触手というほうがてきとうかもしれない。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎに、劇の面白さは、日常生活の中でみられるものの面白さとは、おのずから違っているので、舞台の幕が開いている間は、たえずてきとうな速度で何かが進行している。",
              "citation": {
                "source": "劇の好きな子供たちへ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして、一人一人の動き、一人一人のセリフを、みんなが相談をして、一ばんてきとうで、一ばん面白いのにきめていくのである。",
              "citation": {
                "source": "劇の好きな子供たちへ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "とつぜんでへんですが、ぼくは女房をさがしてるんですが（といってもまだ誰にもいったことはないんですが）てきとうな人はありませんでしょうか。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあいだに佐平治は、てきとうにことばをかまえて、不審顔している若さまのお供を、かえしてしまいました。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "われわれは、いったん陸にかえって、てきとうな技師をたのんで、おおぜいの人をつれて、もう一度、出なおしてくるほかはないでしょうね。",
              "citation": {
                "source": "怪奇四十面相",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
