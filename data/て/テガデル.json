    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to resort to violence",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "細めにあいた戸のすきから女の手が出る。",
              "citation": {
                "source": "映画雑感（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも、いはない方がよいことは解つてゐるのだが、のどから手が出るやうに、いひたくなるのだから、何ともしやうがない。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き上戸のおくの手が出るかな。",
              "citation": {
                "source": "花のき村と盗人たち",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "のどから手が出るほど、お菓子はたべたかったのでした。",
              "citation": {
                "source": "牛をつないだ椿の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "口から手が出るような思いがするのも、決して無理からぬことであった。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、字義どおりに「のどから手が出る」ほどであった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し子規のことでも話そうかと思っていると、「どうも好きなものにはしぜんと手が出るものでね。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "拷問、火責め、お次はどんな手が出るかしらねえが、急がねえところがまた右門流の十八番でな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろに間を置いて引き随っていた豊後守の乗物の中から、慌ててさッと手が出ると、打ちうろたえながら影を制しました。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "交換手がひっこんで、相手が出る、その短かい間、龍介は「いてくれれば」という気持と「かえっていないでくれれば極りがつく」という気持を同時に感じた。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、渠はまたもや喉から手が出る程｜喫みたくなつて、『君は何日でも煙草を持つてるな。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、渠はまたもや喉から手が出る程喫みたくなつて、『君は何日でも煙草を持つてるな。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "我らもかねてから生食はのどから手が出るほど欲しかつたのだ。",
              "citation": {
                "source": "余裕のことなど",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "今一つの競争は圏外に新手が出る事であります。",
              "citation": {
                "source": "文壇の趨勢",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに「｜手作り」だから高値い、そして高値が故にのみ手が出るのである。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "胡瓜と黒パンがあらあな」　若者は咽喉から手が出るほど、飛びつきたかったが、もじもじせずにはいられなかった。",
              "citation": {
                "source": "放浪の宿",
                "author": "里村欣三",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもＰＣ―９８０１に対応していないこの製品は、喉から手が出るほど欲しいＭＳ―ＤＯＳ対応のアプリケーションだった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に、お師匠さんの『山茶図』はカタログに出ていただけで、わたし共はもう喉から手が出るくらいなんですからね。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっ、そうそう、君に話すことを忘れていたがね、こいつは屹度、君も咽喉から手が出るにきまってるんだが、一万ルーブリだすと言ったって手放さないから、前もって断わっておくよ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの料理店の側でも通ると、そこでは外国人のコック、それはきっとフランス人なんですがね、そいつが明けっぱなしな顔附をして、オランダ製のシャツに雪と見まがうような真白なエプロンをかけて、松露を添えたカツレツかなんかを拵らえています――まったく贅沢な御馳走で、ほんとに咽喉から手が出るくらいなんです。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉦の音で引き退き法螺の音で新手が出る。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう少し子規の事でも話さうかと思つてゐると、「どうも好なものには自然と手が出るものでね。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早く乗れ」　トラックの上から、手が出ると、やっという懸けごえと共に、彼は車上に引き揚げられた。",
              "citation": {
                "source": "英本土上陸戦の前夜",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうら見ろ、あれ買って来ると、きっといい話があるから……はア、あんたの思いがかかっているんだもの、なんで誰にも手が出るもんか。",
              "citation": {
                "source": "錦紗",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに苦しくとも辛くとも咽喉から手が出るほどお金が欲しくとも、場末の寄席やあまり安いお座敷なんぞでは稼がないことだ。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　咽喉から手が出る程欲しい金を――断らなくてはならなかった、彼等は頬を不自然に剛らせ、お金からそっと目を外らせた。",
              "citation": {
                "source": "鋳物工場",
                "author": "戸田豊子",
                "note": "青空文庫"
              }
            },
            {
              "text": "受話器をとってから、交換手が出るまでに、ひどい時には五分もかかる。",
              "citation": {
                "source": "硝子を破る者",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かまわずに進んで行くと、往還の両側の薄闇の中から、いくつも手が出る。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋食は、一般にいってあまり好かないが、このサラダだけは例外で、食卓に出ていると、つい先に手が出る。",
              "citation": {
                "source": "サラダの謎",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
