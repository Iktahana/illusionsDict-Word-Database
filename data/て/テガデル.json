[
  {
    "uuid": "9bdc21ca-408e-5d42-96b8-02e2896201e3",
    "entry": "手が出る",
    "reading": {
      "primary": "てがでる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-一段"
      ],
      "ctype": null,
