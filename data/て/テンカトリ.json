    "definitions": [
      {
        "index": 1,
        "gloss": "rule over the whole country",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
