[
  {
    "uuid": "32b1ba65-d019-5039-aa19-5d0b388052bd",
    "entry": "定量",
    "reading": {
      "primary": "ていりょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
