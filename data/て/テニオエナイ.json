[
  {
    "uuid": "f06fcc17-c5fa-57b8-8888-6e8e96ccca05",
    "entry": "手に負えない",
    "reading": {
      "primary": "てにおえない",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
