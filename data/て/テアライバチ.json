          "literary": [
            {
              "text": "外には春風が白い埃をあげて、土の乾いた庭の手洗い鉢の側に、斑入りの椿の花が咲いていた。",
              "citation": {
                "source": "爛",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "盗難を防ぐマジナイに、手洗い鉢を家の中に伏せて置けばよいというのがある。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "山芋の蔓や、夕顔の蔓が、垣から手洗い鉢の脚にまでからみついている。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
