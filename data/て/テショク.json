[
  {
    "uuid": "6919f238-14a4-5010-a6c6-bd8e8224f341",
    "entry": "手職",
    "reading": {
      "primary": "てしょく",
      "alternatives": [
        "てじょく"
      ],
      "is_heteronym": false
    },
    "grammar": {
