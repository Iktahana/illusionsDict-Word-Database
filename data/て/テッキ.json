      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "summarization",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其中人名のあるものを摘記することとする。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは此に先づ正右の世に於ける竹亭の履歴を摘記する。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して是れは誰れも知る所で、今、改めて言ふの要もないから嘗て居士の生前に余の物した一二の文を摘記して、いさゝか今昔の感を叙する代りとした。",
              "citation": {
                "source": "鳴雪句集",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ホトヽギス三十二年七月号碧子の俳句評釈の文中摘記）僕は子規子に対して、年齢と経歴とに於ては郷里の長者先輩である。",
              "citation": {
                "source": "鳴雪句集",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ホトヽギス三十五年六月号獺祭書屋俳句帖抄に就きての文中摘記）下の子規居士の画と句とは居士の病革まる少し以前に乞ひ得たもので永き紀念として附載した。",
              "citation": {
                "source": "鳴雪句集",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところで、この柳丹永のことだが、それを詳しく書くとすれば長い一篇の物語ともなろうから、茲には、この物語に関係ある部分だけを摘記するに止めよう。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、さらに言上した内容を摘記すると、こうである。",
              "citation": {
                "source": "私の陶器製作について",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "こはたまたま僕の記憶に存せる語句を摘記したるに過ぎず。",
              "citation": {
                "source": "桑中喜語",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かのしをりにならうし、勘定してはわかりにくいことだから、左に関係部分だけの年号の干支を摘記しておくこととしよう。",
              "citation": {
                "source": "岸田劉生の日本画",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一つのいゝ例として、その年の五月の、この作が「太陽」に出た直後のある日の日記にしるされてゐることを摘記しよう。",
              "citation": {
                "source": "「樋口一葉全集第二卷」後記",
                "author": "久保田万太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その要点を摘記すると、「ナヰ」は地震現象そのものを表すのではなく、「地」又は「地面」と言う意味で、「ナヰフル」で始めて「地面が揺れる」の意味になる。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生はどの雜誌にも一往眼を通し、必要なものにはアンダラインしたり、内容を摘記したりしてゐたやうである。",
              "citation": {
                "source": "知られざる漱石",
                "author": "小宮豐隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに要する費用を摘記すると、距離その他の関係で多少の相違はあるが、先ず一台一回について、人夫賃、運転手、ガソリン代、其他雑費諸掛りを計算して、最小限度、一円五十銭の実費を要する。",
              "citation": {
                "source": "糞尿譚",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が西洋探偵小説から採集した異様な兇器の例は六十余りあるが、小説としては面白くても、その方法だけを摘記したのでは、さしたることもないようなものが多い。",
              "citation": {
                "source": "探偵小説の「謎」",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「てっきり彼奴」　と独り言、Ｔ「朝ッぱらから一稼ぎしてやがるかも知れ無えぞ」　其辺で鉄五郎クルッと踵を反して走り去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フト彼方を見れば、てっきり鉄五郎がのこのこやって来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近　尾行して来たてっきり鉄五郎、立ち止って素早く物蔭にかくれる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝通り――　てっきり鉄がのこのこ歩いて来る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｔ「翌る朝」Ｓ＝ファーストシーンの町角　てっきり鉄と三次が今日も亦ばったり出会った。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝附近の通り　屋根の上からひらりと跳び下りた三次、その儘立ち去ろうとしてバッタリ急ぎ足にやって来たてっきり鉄と出合わした。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄が、Ｔ「俺は又てっきりお前と思ってやって来たが」　三次が「飛んでも無い。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と肩を叩かれて振り返ると、　何時の間に来たか、てっきり鉄五郎。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「わかったよお絹ちゃん」　てっきり鉄が辺りを見廻し乍ら戻って来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "てっきり僕は北方の田舎者だと思われてしまったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその女は自分が咳をしてから庭の方を向いたのを勘違いして、てっきりこれは「心臓へ来た」と思ってしまったのだと吉田は悟ることができた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことに小平さんが、松吉の耳をつまんで、二どばかり、耳の毛をそったときには、松吉は、てっきり、小平さんが、むかしのいたずらをはじめたと、思いました。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にアムモニアの議論のことまで出てゐましたから、私はもうてっきりあの紳士のことだと考へました。",
              "citation": {
                "source": "毒蛾",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "てっきり蔵元屋騒動のかかり合いと察しました私ども一家の驚きと悲歎のほど御察し下さいませ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "イフヒムといがみ合った様な噂もちょくちょく聞くから、貢ぐのは野郎じゃ無くって、これはてっきり外に出来たなとそう思ったんだ。",
              "citation": {
                "source": "かんかん虫",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "目がお見えなさらないというだけは不吉じゃあござりましたが、東京の方だというし、お年の比なり御様子なり、てっきり貴方に違いないと、直ぐこちらへ飛んで参り、向うのあの荒物屋で聞いてお尋ね申しました。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
