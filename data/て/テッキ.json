[
  {
    "uuid": "54c77e61-0d87-5561-92d7-7aeebbc7e39f",
    "entry": "摘記",
    "reading": {
      "primary": "てっき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
