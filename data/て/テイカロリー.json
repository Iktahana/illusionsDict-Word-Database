        "examples": {
          "standard": [
            {
              "text": "健康のために、低カロリー食品を選ぶようにしている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "この飲料は低カロリーで、ダイエット中の人にもおすすめだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "レストランでは、低カロリーメニューを豊富に取り揃えています。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "これは日本の文化水準を辛うじて維持するための最低カロリーであって、役に立つだの、立たないだのという方が、野暮である。",
              "citation": {
                "source": "科学は役に立つか",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "要約すると、食事は低カロリーに、野菜を多く、米飯は少量、果物は好ましい。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
