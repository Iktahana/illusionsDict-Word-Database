        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "深い森の奥から、「てっぺんかけたか」というホトトギスの澄んだ鳴き声が響く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "早朝の静寂の中、かすかに「てっぺんかけたか」と聞こえてきて心地よく目が覚めた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "昔の人は、ホトトギスの鋭く印象的な鳴き声を「てっぺんかけたか」と聞きなした。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ほととぎすの声をてっぺんかけたかと聞くように。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
        "index": 2,
        "gloss": "lesser cuckoo (Cuculus poliocephalus)",
        "register": "standard",
        "nuance": null,
