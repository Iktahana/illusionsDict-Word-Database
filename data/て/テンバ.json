    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flying horse",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちょっと外側から見ると恐ろしく窮屈そうに見えるような天地に居て、そうして実は、最も自由に天馬のごとく飛翔しているような人も稀にはあるようであり、一方ではまた、最も自由な大海に住みながら、求めて一塊の岩礁に膠着して常に不自由を喞つ人も稀にはあることはあるように思われる。",
              "citation": {
                "source": "学問の自由",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば僕の「英雄」は、君の自ら羞恥して克服した所の、昔の天馬空を行く自然性にあつたのだから。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い才能は、思い切り縦横に、天馬の如く走り廻るべきだと思っています。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度其｜赫灼たる霊光の人の胸中に宿るや嬋妍たる柳眉玉頬の佳人をして、猶｜且つ這般天馬空を行くの壮事あらしむる也。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "暴風雨模様の高浪を追越し追越し、白泡を噛み、飛沫を蹴上げて天馬｜空を駛るが如く、五島列島の北の端、城ヶ島を目がけて一直線。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れ天馬は大逆不慮の際、急を遠国に報ずる為め聊か用うるに足る丈である。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十八歳の老齢で、九四歩などといふ天馬の如き溌剌とした若々しい奇手を生み出す坂田の青春に、私はぴしやりと鞭打たれたやうな気がし、坂田のこの態度を自分の未来に擬したく思ひながら、その新聞を見ることが、日日｜愉みとなつたのである。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十八歳の老齢で、九四歩などといふ天馬の如き溌剌とした若々しい奇手を生み出す坂田の青春に、私はぴしやりと鞭打たれたやうな気がし、坂田のこの態度を自分の未来に擬したく思ひながら、その新聞を見ることが、日日愉みとなつたのである。",
              "citation": {
                "source": "聴雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "木綿ちゃんの行動は天馬空を行くがごとくで、四畳であろうが、百畳であろうが、木綿ちゃんにそんな差別はない。",
              "citation": {
                "source": "水籠",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "折にふれては、天馬はたまたま彼等を乗せて疾駆する。",
              "citation": {
                "source": "浪曼的月評",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "旌旗の翻る処、彼の行動は天馬空を征くの趣があつた。",
              "citation": {
                "source": "悲しき項羽",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "『山海経』に、〈天馬｜状白犬のごとくにして黒頭、肉翅能く飛ぶ〉とあり、堀田正俊の『※言録』に、朝鮮の天馬形犬のごとく毳白兎のごとしといえるは、馬の属らしくないが翼生えた馬の古図も支那にある。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『史記』などを見ると天馬は外国最駿馬の美称だ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "『根本説一切有部毘奈耶』に、天馬｜婆羅訶海より出て岸辺の香稲を食う。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのごとく声聞や縁覚よりは菩薩｜迥かに功徳殊勝なりとし、観音救世の績殊に著しいから、前述五百商人を救うた天馬などをその化身とし、追々馬は皆観音の眷属としたのじゃ。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る夜夢のなかで天馬の呼び声がしたので目が覚めると、枕辺には彼の幻影が遠のいて行くのだ。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故、僕は天馬と逢ふと早速云った、「君の大恋愛も大変なことになったね、君の霊魂は昨夜夜なかに巣鴨を抜け出して、横浜の女学校の方へ赴いた形跡があるよ。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "」この話は早速天馬から月狂へ、月狂から吉士へ伝はって、吉士は僕の荒唐無稽さを鬼の首を獲った如く欣び勇んだ。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉士、月狂、天馬と僕との四人が集まって句会でもやる時にはきまって誰か一人が遅れるか欠席した。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "天馬はいろいろ説を為したがった。",
              "citation": {
                "source": "四五ニズム述懐",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋物では「名馬天馬」などという写真が松山館に現われた。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この板沢家には氏神に大天馬という祠がある。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "後世、明日は大天馬祭りだから今夜は板沢の老婆がくるというような言伝えになったのであるが近年はどうだかわからぬ。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "車体の胴中に天馬のような羽根が生えているやつなら、五円ぐらい投げだしてもいいぞ」　ところが意地悪く出来あがっているもので、いつもの朝とはこと違い、いくら待っても円タクの姿が一台も現われて来ない。",
              "citation": {
                "source": "深夜の市長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時僕等のクラスには、久米正雄の如き或は菊池寛の如き、天縦の材少なからず、是等の豪傑は恒藤と違い、酒を飲んだりストオムをやったり、天馬の空を行くが如き、或は乗合自動車の町を走るが如き、放縦なる生活を喜びしものなり。",
              "citation": {
                "source": "恒藤恭氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "これ天馬うち見るところ鈍の馬埴馬の如きをかしさなれど　これ作者の自負であらう。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "見た所鈍な馬であり埴馬の様なをかしい馬だが、これでも一度時至れば空をゆく天馬になれるのだ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に新聞紙の論説の如きは奇想湧くが如く、運筆飛ぶが如く、一気に揮洒し去って多く改竄しなかったに拘らず、字句軒昂して天馬行空の勢いがあった。",
              "citation": {
                "source": "文士としての兆民先生",
                "author": "幸徳秋水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「あのおてんばのことは、どうも、俺には分らないよ。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "じくじくと考えている彼の眼がきゅうに輝きだして、湯気を立てんばかりな平べったい脂手が、空を切って眼もとまらぬ手真似の早業を演ずる。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
