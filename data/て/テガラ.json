        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども私は、彼もさすがにてれくさそうにして眼を激しくしばたたかせながら、そうして、おしまいにはほとんど不機嫌になってしまって語って聞かせたこんなふうの手柄話を、あんまり信じる気になれないのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "謝源と郭光はそれから一しきり、いくさの手柄話に花を咲かせて居た。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子細は、其主人、自然の役に立ぬべしために、其身相応の知行をあたへ置れしに、此恩は外にないし、自分の事に、身を捨るは、天理にそむく大悪人、いか程の手柄すればとて、是を高名とはいひ難し」とはっきりした言葉で本末の取りちがえを非難している。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他所の女にちやほやされるのを見て手柄を感ずる。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然、その間に手柄の競爭が起る。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "踊り家台の見物よりも、強飯の御馳走よりも、わたしに取ってはそれが何よりも嬉しいので、すぐにその尾について又いつもの話をしてくれと甘えるように強請むと、また手柄話ですかと老人はにやにや笑っていたが、とうとう私に口説き落されて、やがてこんなことを云い出した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おふくろを嚇かして来たんじゃあ、あんまり手柄にもならねえが……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "大抵のことはもう判りました」「そりゃあお手柄だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "田中君が戰地から歸つて、私の家に來た時も、戰爭の手柄話は、一言も語りませんでした。",
              "citation": {
                "source": "田中君に就いて",
                "author": "――田中英光著『オリムポスの果實』序",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで、すっかり手柄を立てることが出来た……何んて、気しょくのいいこっだろう！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の力で貴様が手柄を立てたんだ！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あんたは、自分の立てた手柄まで、上の人に取られてしまうんだね。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「自分でこんな大きな鉱石を掘りあてときながら、まるで他人の手柄にせられて、くそ馬鹿々々しい。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「今度の捕物にもし失ぱい致すとなれば」Ｔ「一生家内に頭が上りません」Ｔ「何卒武士の情を持ちまして」Ｔ「この手柄は拙者におゆずり下さい」　と頼み込んでいる。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（はい、ならば手柄でござんす、さあ、貴僧参りましょうか。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪口をいえば骨董は死人の手垢の附いた物ということで、余り心持の好いわけの物でもなく、大博物館だって盗賊の手柄くらべを見るようなものだが、そんな阿房げた論をして見たところで、野暮な談で世間に通用しない。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "信長の時になると、もう信長は臣下の手柄勲功を高慢税額に引直して、いわゆる骨董を有難く頂戴させている。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "羽柴筑前守なぞも戦をして手柄を立てる、その勲功の報酬の一部として茶器を頂戴している。",
              "citation": {
                "source": "骨董",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、将来大マラソン家になろうという野心も無く、どうせ田舎の駈けっくらで、タイムも何も問題にならん事は、よく知っているでしょうし、家へ帰っても、その家族の者たちに手柄話などする気もなく、かえってお父さんに叱られはせぬかと心配して、けれども、それでも走りたいのです。",
              "citation": {
                "source": "トカトントン",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年こそ白いのをうんととって来て手柄を立ててやろうと思ったのです。",
              "citation": {
                "source": "谷",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から腕前のない、手柄望みの役人は、すぐに弱い正直者を罪に落そうとするものじゃてや」「とは言うものの、蔵元屋の方も、家内の模様さえまだわかっておらぬけに、松倉どんもバッタリ行詰まって御座るが、さればとてほかには何の手も足もない。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "又おだてる……実は私が直接にアンタの話を聞いて、それを私の聞込みにして、お目付に申上げても済む事じゃが、それではイツモの通りお前の手柄を横取りするような恰好になるけに気持が悪い……のみならず今度の一件は、模様によると日田のお金奉行を相手に取るような事になろうやら知れぬ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "お先まっくらの奴……ヒトの手柄を横取りし腐って……」「……エ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはお手柄じゃった。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしておもに手柄話か失敗話であった。",
              "citation": {
                "source": "鹿狩り",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛乳屋の物食う口は牛七匹と人五人のみのように言いしは誤謬にて、なお驢馬一頭あり、こは主人がその生国千葉よりともないしという、この家には理由ある一｜物なるが、主人青年に語りしところによれば千葉なる某という豪農のもとに主人使われし時、何かの手柄にて特に与えられしものの由なり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓑吉は一人使いの手柄を早く姉に誇ろうと気負い込み、一心に顔を緊張させ、眼は寮の方ばかり見詰めるだろう。",
              "citation": {
                "source": "娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にね、――潰島田に水色の手柄を掛けた――年数が経って、簪も抜けたり、その鬢の毛も凄いような、白い顔に解れたが――一重桜の枝を持って、袖で抱くようにした京人形、私たち妹も、物心覚えてから、姉に肖ている、姉さんだ姉さんだと云い云いしたのが、寂しくその蜜柑箱に立っていた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてがらん／＼と、けたゝましく鐸を振つた。",
              "citation": {
                "source": "駆落",
                "author": "DIE FLUCHT",
                "note": "青空文庫"
              }
            },
            {
              "text": "起きてから私が一言も口をきかないので、照れかくしに私の胸にボクシングで穴をあける真似をして片足を私の鼻につきだしてがらがらとした声でおしゃべりを始めようとするので、私が扇風機に電流を通じる。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
