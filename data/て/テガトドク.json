    "definitions": [
      {
        "index": 1,
        "gloss": "to be able to reach",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "高さ五｜間以上もある壁のような石垣ですから、私は驚いて止めようと思っているうちに、早くも中ほどまで来て、手近の葛に手が届くと、すらすらとこれをたぐってたちまち私のそばに突っ立ちました。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "アンタ程の人がそこまで睨んでおんなさるなら、今一足で下手人の肩に手が届くと思うがなあ」「それが、まだ届いとらん」「ハアテ……なあ……」「イヤ。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯気や煙で煤けたまわりを雇人の手が届く背丈けだけ雑巾をかけると見え、板壁の下から半分ほど銅のように赭く光っている。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "丈高く伸びたのは、車の上から、花にも葉にも手が届く。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も六十に手が届くやうになり、田舎の閑居で退屈まぎれに、同棲三十年近くで、はじめて妻といふ女を見直して見るのであつた。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度はすまないが、この机の上に、手が届くよう手紙と紙を頼む。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが己はあの窓を外から見た時、外の戸をぴつたり壁まで開くと、針金を支へた枠から二尺の距離に外の窓枠があつて、手が届くと云ふことに気が付いた。",
              "citation": {
                "source": "病院横町の殺人犯",
                "author": "THE MURDERS IN THE RUE MORGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "四畳半で、腰を曲げて乗出すと、縁越に手が届くんですね。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　がばと開けて、「それ、救の手が届くと、はや、白い天人が仰向いたようじゃ。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "がたのきた自分にも、これなら手が届くのではないかと、もう一度本作りに心が向いた。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "近く見えたのも道理で、二三歩にして手が届くのである。",
              "citation": {
                "source": "しらくちの花",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふくらんだ蕾を持った、紅味のある枝へは、手が届く。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "代助はみんなから一足後れて、鴨居の上に両手が届く様な伸を一つした。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "押入れを開けて見ても、台所へ出て見ても、痒いところへ手が届くように、整理が行き届いている。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の愛と心遣いの行き届くことを俗に「痒い所に手が届く」という。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして何かに魘えているかのようにオドオドと禿頭を下げたが、揉み手をしいしい首を擡げて、正木博士と私の顔を霞んだ眼で等分にキョロキョロと見比べると、又一つ、床に手が届くくらい馬鹿叮嚀なお辞儀をした。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私がまだ五つか六つ位の時にもう七十に手が届くと云はれたその母親に養はれてゐたのですが、力だけは驚く程持つてゐますので、よく米搗や山から薪を運ぶ仕事などに使はれてゐました。",
              "citation": {
                "source": "白痴の母",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ハハハハ見えない所でも、旨く手が届くね。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "……六尺までは手が届く、八尺となると届かない。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな事を云ったって、こんな大きな村に巡査が一人しかいないのだから、とてもそんな事まで手が届くものではないよ。",
              "citation": {
                "source": "田舎医師の子",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "媼は私の世話になつたころは、既に六十に手が届くぐらゐの齢に達してゐた。",
              "citation": {
                "source": "日本媼",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐさういふところへ手が届くでせうか？",
              "citation": {
                "source": "優にやさしき心",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょいと手を伸ばせば、日本の本土に手が届く。",
              "citation": {
                "source": "空襲葬送曲",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一息で、政の身体に手が届くというところで、わしはツルリと、左足を滑らせた。",
              "citation": {
                "source": "夜泣き鉄骨",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二階に手が届くようになったから、一度懐中電灯をつけて見る。",
              "citation": {
                "source": "疑問の金塊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "痒いところへ手が届くとは漱石の知と理のことで、人間関係のあらゆる外部の枝葉末節に実にまんべんなく思惟が行きとゞいてゐるのだが、肉体といふものだけがないのである。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもう一歩で、入口の扉に手が届くというところまで近づいたそのときでありました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
