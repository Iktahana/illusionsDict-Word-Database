[
  {
    "uuid": "7d883c91-c5ff-58ab-8836-ac48ec246cc1",
    "entry": "低級",
    "reading": {
      "primary": "ていきゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
