[
  {
    "uuid": "ca8dedd0-4311-574a-bc9d-8ce81024df81",
    "entry": "徹する",
    "reading": {
      "primary": "てっする",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-サ変-特殊",
        "動詞-自動詞"
      ],
