    "definitions": [
      {
        "index": 1,
        "gloss": "Tenryaku era (947.4.22-957.10.27)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
