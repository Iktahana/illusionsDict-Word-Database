        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんな大きな頭の人間だったら、じぶんのあたまには、とても陸軍制式の鉄帽が、すっぽりはいるわけがない。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "背嚢、弾薬帯、短剣、小銃、黄色い鉄帽、その他鷲尾が知らぬようなものを背嚢わきにくくりつけていて、近頃の歩兵は歩くだけでも大変だと思われるほどだった。",
              "citation": {
                "source": "冬枯れ",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツヤ子すばやい動作でラジオ台の下から鉄帽を引き出してかむり、床の上に腰をおろし戸外の空をのぞいて見ながら、鉄帽の中に入れてあったゲートルを脚に巻きはじめる）（投弾と高射砲発射の爆音のきこえはじめる直前の、ぶきみな静けさ。",
              "citation": {
                "source": "猿の図",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左手に鉄帽をかかえている。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（鉄帽をベンチの上に置く）大豆だ。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "治子　……（鉄帽の中から大豆をつまんで噛む）人見　……（自分も手を伸ばして大豆をつまみながら）治子。",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "制服にゲートルに鉄帽）監守　（いきなり）おいエスさま！",
              "citation": {
                "source": "その人を知らず",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "輜重には、木牛流馬と称する、特殊な運輸車が考案され、兵の鉄帽（鉄かぶと）から鎧にいたるまで改良された。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、かた手でてつぼうにつかまり、かた手をひらひらうごかして、下のけんぶつ人をばかにしています。",
              "citation": {
                "source": "かいじん二十めんそう",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "てつぼうのはまったろうやのようなものでした。",
              "citation": {
                "source": "ふしぎな人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
