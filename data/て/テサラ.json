    "definitions": [
      {
        "index": 1,
        "gloss": "holding food over one's hand",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
