    "definitions": [
      {
        "index": 1,
        "gloss": "water for washing or moistening one's hands",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　さう言つた父は急に立ち上がつて河鹿に手水をやつた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も縁側へ出て新しく水を入れた手水鉢で手洗い口すすいで霊前にぬかずき、わが名を申上げて拍手を打つと花瓶の檜扇の花びらが落ちて葡萄の上にとまった。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢を座敷のまん中で取り落として洪水を起こしたり、火燵のお下がりを入れて寝て蒲団から畳まで径一尺ほどの焼け穴をこしらえた事もあった。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢の向かいの梅の枝に二輪ばかり満開したのがある。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「家は腰高の塗骨障子を境にして居間と台所との二間のみなれど竹の濡縁の外には聊かなる小庭ありと覚しく、手水鉢のほとりより竹の板目には蔦をからませ、高く釣りたる棚の上には植木鉢を置きたるに、猶表側の見付を見れば入口の庇、戸袋、板目なぞも狭き処を皆それぞれに意匠して網代、船板、洒竹などを用ゐ云々」。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "狭き庭の中垣ともいわず手水鉢ともいわず朝顔を這いつかせたり。",
              "citation": {
                "source": "草花日記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸ばたの流し場に手水をすました自分も、鶏に興がる子どもたちの声に引かされて、覚えず彼らの後ろに立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス障子の外には、狭い形ばかりの庭ではあるが、ちょっとした植込みに石燈籠や手水鉢などが置いてあった。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして手水鉢にはいつでも清水がいっぱいに溢れていた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蚊帳をぬけ出して来て、半七は縁先の手水鉢で手を洗って、もとの四畳半へ戻った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒔絵の手水盥を持って来て顔を洗わせてくれた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて小用を達した様子、雨戸をばたりと開けるのが聞えた、手水鉢へ柄杓の響。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ明日が手術という夜は、皆寐静まってから、しくしく蚊のように泣いているのを、手水に起きた娘が見つけてあまり不便さに抱いて寝てやった。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "はいって来る信徒らは皆入り口の壁や柱にある手水鉢に指の先をちょっと入れて、額へ持って行って胸へおろしてそれから左の乳から右の乳へ十字をかく。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺に、瑠璃に、紅絞り、白に、水紅色、水浅葱、莟の数は分らねども、朝顔形の手水鉢を、朦朧と映したのである。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手水鉢と垣の間の、月の隈暗き中に、ほのぼのと白く蠢くものあり。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう筋も抜け、骨崩れて、裳はこぼれて手水鉢、砂地に足を蹈み乱して、夫人は橋に廊下へ倒れる。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と手水鉢から見越して言った。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "髪の根は髷ながら、笄ながら、がッくりと肩に崩れて、早や五足ばかり、釣られ工合に、手水鉢を、裏の垣根へ誘われ行く。",
              "citation": {
                "source": "悪獣篇",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "梅ヶ枝の手水鉢三十五「座敷へ入ると間も無くさ、びりびり硝子戸なんざ叩破りそうな勢、がらん、どん、どたどたと豪い騒ぎで、芸者交りに四五人の同勢が、鼻唄やら、高笑。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――楠の正成がーと梅ヶ｜枝の手水鉢で唄い出す。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ここに、朝顔形の瀬戸の手水鉢が有るんです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お鹿の内には、まだ開業当時というので手水鉢も柄杓も無かった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく待合の手水鉢に柄杓の無いのは、厠に戸の無いより始末が悪い。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ですよ、奥庭に有った手水鉢を見ましたがね、青銅のこんな形、とお鹿の女房は仕方をして、そして竜の口を捻ると、ザアです。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "清葉の手水鉢、でいささか酔覚の気味。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二階は梅ヶ枝の手水鉢。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……私はそこへ手水鉢なんぞじゃない、摺鉢と采配を両手に持って、肌脱ぎになって駆込んで驚かしてやったものを。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そなたに見せなば親恋しと思う心かならず起こらん、そのときわれを父と思え、そなたの父はわれなり」　かくて源叔父は昔見し芝居の筋を語りいで、巡礼謡をかすかなる声にてうたい聞かせつ、あわれと思わずやといいてみずから泣きぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかと言ってみずからこれらの多くの問題のどれもに手を着けることは到底不可能である。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
