[
  {
    "uuid": "d1f73bba-0eff-56f6-a7f0-bf096b548cad",
    "entry": "天福",
    "reading": {
      "primary": "てんぷく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heavenly blessing",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伝説に依ると、水内郡荻原に、伊藤｜豊前守忠縄というものがあって、後堀河天皇の天福元年（四条天皇の元年で、北条｜泰時執権の時）にこの山へ上って穀食を絶ち、何の神か不明だがその神意を受けて祈願を凝らしたとある。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "『明月記』に天福元年十一月御法事の夜僧房の童が女の姿で堂上に昇り、大番武士に搦めらるとあり。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴等は可憐しいヂュリエットの手の白玉を掴むことも出來る、また姫の脣から……其上下の脣が、淨い温淑な處女氣で、互ひに密接と合ふのをさへ惡いことゝ思うてか、いつも眞赤になってゐる……其姫の脣から永劫死なぬ天福を窃と盜むことも出來る、ロミオにはそれが能はぬ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十二　法然が亡くなってから、順徳院の建保年間、後堀川院の貞応嘉禄年間、四条院の天福延応年間などたびたび一向専修の宗旨を停止の勅命を下されたけれども、厳制すたれ易く興行止まりがたく、念仏の声は愈々四海に溢れた。",
              "citation": {
                "source": "法然行伝",
                "author": "中里介山",
                "note": "青空文庫"
              }
            },
            {
              "text": "後白河天皇の天福元年、伊藤豊前守忠綱という人があって、この山にこもり、穀食を断って祈願をこらし、大自在力を得て、二百年余を生き、応永七年足利義持の時に死んだという。",
              "citation": {
                "source": "露伴先生と神仙道",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鮫は朝鮮の一の切れ、目貫は金で断の一字、銘を天福輪と切った稀代の剛刀――ぐいと、背後ざまに落とし差した下谷の小鬼、伴大次郎、黒七子の裾を端折ると一拍子、ひょいと切戸を潜って戸外へ出た。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "鎌倉幕府の記録である吾妻鏡天福元年五月二十七日の条には、聴くも憐れな補陀洛渡海の事件が載せてある。",
              "citation": {
                "source": "本朝変態葬礼史",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天福寺の本堂が影絵のように見え、風はないが海が近いので、空気に汐の香がかなりつよく匂っていた。",
              "citation": {
                "source": "あすなろう",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一年を隔て、天福二年六月三日に一千四百九十八首の自筆の本を奉って仮奏覧を行ったが、その後引きつづき改訂を行いつつあった。",
              "citation": {
                "source": "中世の文学伝統",
                "author": "風巻景次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「年ちゃん、汽車がてんぷくしたよ、たいへんだからきておくれよ。",
              "citation": {
                "source": "ゆずの話",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方には、小さな、赤と青にぬられた、竜骨のないボオトをこいでは、笑いながらてんぷくしている連中もあった。",
              "citation": {
                "source": "ヴェニスに死す",
                "author": "DER TOD IN VENEDIG",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あらッ」　村のとっつきの小さな波止場では、波止場のすぐ入り口で漁船がてんぷくして、鯨の背のような船底を見せているし、波止場にはいれなかったのか、道路の上にも幾隻かの船があげられていた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "世界をてんぷくさせることができる。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、世界をてんぷくし、世界をぬすむかもしれない。",
              "citation": {
                "source": "超人ニコラ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "法勝寺の僧俊寛の山荘で、法皇の近臣たちが、平家てんぷくを策した世にいう“鹿ヶ谷会議”なるものが行われ、密告者のため、死罪、遠流、追放などの犠牲者をちまたに見たのもこの年でした。",
              "citation": {
                "source": "随筆　新平家",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
