        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふられても恰好がつくなんてのは、てんからひとに甘ったれている証拠らしいが、――ま、落ちつく」　馬場がそう言ったのを私は忘れない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここではお芝居およしなさいね」　てんから疑って呉れなかった。",
              "citation": {
                "source": "あさましきもの",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風が一そうはげしくなってひのきもまるで青黒馬のしっぽのよう、ひなげしどもはみな熱病にかかったよう、てんでに何かうわごとを、南の風に云ったのですが風はてんから相手にせずどしどし向うへかけぬけます。",
              "citation": {
                "source": "ひのきとひなげし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふられても恰好がつくなんてのは、てんからひとに甘つたれている證據らしいが、――ま、落ちつく。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうかといって、てんからいけないとはかわいそうで言えないから、口出しができないでいる。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ふたりは賓主普通の礼儀などはそっちのけで、もうてんから打ちとけて対座した。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして「おつう支度して見ろ、俺連れてんから」勘次は性急におつぎを促し立てた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "□　いくら悪評でも、てんから相手にされないよりは好いに違ひない。",
              "citation": {
                "source": "批評",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、てんから相手にされないといふこともまた決してわるくはない。",
              "citation": {
                "source": "批評",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう、私の考えていることが、いや、こうよりほかに考えざるを得ないことが、大体お判りになったでしょう……つまり、峯吉は、あの発火の時に、てんから坑内には入っていなかったのですよ」「待ち給え」係長が遮切った。",
              "citation": {
                "source": "坑鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども、せがれはご覧のような鈍根のうつけ者、群青色焼き分けは夢おろか、てんからふできな、先に望みもないやつなのでござります。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いゝえ、私はかういふ人間でてんから役に立たないもんですから、まあせめて毎日の物費りでも少くなるやうにと思つて、自分の事のやうにつましくやつて来たつもりですが、どうもそれが却つて青木さんのお気に入らないやうな場合がありましてね。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "セックス革命六〇年代風かなんか知らないけど、おれは、そういうのは、てんから信用しないんだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくはてんから娘さんなど見はしない。",
              "citation": {
                "source": "灯台鬼",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "勇吉の様子をジロジロと見て、てんから相手にしないようなところも何軒かあった。",
              "citation": {
                "source": "トコヨゴヨミ",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "親には見放される、兄弟には唾を吐き懸けられる、村の人にはてんから相手にされぬといふ始末で、夜逃の様にして村を出て行つたが、其時の悲しかつた事は今でも忘れない。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "論理の地盤を竪に切り下げた坑道などへは、てんから足も踏み込めない。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "垂れたかあてんから光る海風が流れこんで、リスボンは今日も輝かしいお天気だ。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術的良心を痲痺させてしまって出版業者に動員されて、てんから恥ない所がありはすまいか、出版当事者美術家ともに大いに良心を覚醒させる要があろう。",
              "citation": {
                "source": "業者と美術家の覚醒を促す",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆はてんから呆気にとられたが、彼がへへへと照れ臭そうに笑いつつ出て行った時、「気違いじゃろか」と先の一人は首をひねったのである。",
              "citation": {
                "source": "天馬",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんからお互いが感情というものを持合わせていないかのように。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶奴め最初はまつたく見憶えがなかつただが、よくよく見ればくだんの男なので、てんから思ひもよらぬといつた顔つきをしやあがつて、と、空とぼけて見せをつたものさ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰹賣が盤臺の肩をかへながら、時鳥が鳴いた空をちよいと見上げるところがあるが、東京の空を、ほととぎすが啼いてすぎる夜があるといふと、てんから嘘だとあきれ顏をする人に、默阿彌さんは明治まで生きてゐた人で、本所にお住居ゆゑ、おききになつて景色にそへたのに違ひない、といふことをいつて、おしまひにする。",
              "citation": {
                "source": "初かつを",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "サラリとした氣風といふなかには、生れだちの氣風もあるし、修業によつて超然たる悟りもあるし、ガラツパチの粗雜なものとは、てんから質においてちがつてゐることは、女丈夫をもその中に入れるやうだが、女丈夫は讀んで字のごとくますらをの魂がある女なのだ。",
              "citation": {
                "source": "凡愚姐御考",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "だけど、詩もてんから売れやしない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ええ、一度出してもらったンですけど、てんからないンですよ。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "隆吉にかたづく二十五の年まで浮いた事もなく、年をとっても、てんから子供のようななりふりでいた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「谷中村かね、はあ、あるにはあるけれど、沼の中だでね、道も何にもねえし――いる人も、いくらもねいだよ――」　あんな沼の中にとても行けるものかというように、てんから道など教えそうにもない。",
              "citation": {
                "source": "転機",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、わたしたちが都會の子供で、狐については、本ものを知らず、彼の狡智な顏つきに接せず、しかも、そんな、汚なく化される人間そのものを、てんから馬鹿ものとして耳にしてゐたからなのかも知れない。",
              "citation": {
                "source": "春宵戲語",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ちあけて何も話さず、てんから藍子が尾世川の何かでありでもするように、「ねえ、あなた。",
              "citation": {
                "source": "帆",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
