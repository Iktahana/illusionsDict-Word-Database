        "examples": {
          "standard": [
            {
              "text": "事故の経緯を説明するため、顛末書を提出する必要がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "顛末書には、事実関係と今後の対策を明確に記載する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は始末書ではなく、より詳細な顛末書を作成することになった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかれば子孫のため事の顛末書き残しおきたく、京都なる弟又次郎宅において筆を取り候。",
              "citation": {
                "source": "興津弥五右衛門の遺書",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ大日本帝国の首都たる東京市の名誉職が、白昼公然他を脅嚇して盗賊を行へる顛末書なり。",
              "citation": {
                "source": "自由の使徒・島田三郎",
                "author": "木下尚江",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
