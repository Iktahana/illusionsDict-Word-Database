        "examples": {
          "standard": [
            {
              "text": "そのテレビドラマのテーマ音楽は、今でも多くの人に愛されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "オーケストラが壮大なテーマ音楽を演奏し、観客を魅了した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画のテーマ音楽を聴くと、すぐに感動的なシーンが頭に浮かぶ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "音楽第６回　金吾　お豊　喜助　壮六音楽信州のテーマ音楽（冬の）火じろにたき木のはぜる音。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有効な画面構成要素のひとつとして自然を利用した完全主義者の作品が、テーマ音楽の助けとともに、観客にあたえるロマンティックな衝撃力を、そしてそれだけを『シェーン』は持っていた。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
