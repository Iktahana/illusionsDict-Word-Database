[
  {
    "uuid": "cd7bc335-bea4-59cb-9f62-50330ec7cc67",
    "entry": "展開",
    "reading": {
      "primary": "てんかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
