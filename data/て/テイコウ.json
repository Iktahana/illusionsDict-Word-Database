[
  {
    "uuid": "507b5d46-56e4-5b3f-b89f-1ed531ef7236",
    "entry": "抵抗",
    "reading": {
      "primary": "ていこう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
