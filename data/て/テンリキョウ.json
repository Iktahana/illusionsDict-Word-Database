    "definitions": [
      {
        "index": 1,
        "gloss": "Tenrikyo (Shinto sect)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "義母などの信心から、天理教様に拝んでもらえと言われると、素直に拝んでもらっている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この帽子と羊羹色になりたる紋付羽織とのために、同船の一商人をして我を天理教の伝道師と見誤らしめき。",
              "citation": {
                "source": "閑天地",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ないのはキリスト教と天理教だけである。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "天理教の蒟蒻躍り、静坐法の癲癇舞踊、皆それぞれ相当の境界があろう。",
              "citation": {
                "source": "謡曲黒白談",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "神道に比べて由緒はるかに劣れる天理教、金光教すら存立を許しおれり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その民、神を拝むこと成らぬよりヤケになり、天理教に化する者多く、大字内の神林をことごとく伐らんと願い出でたり。",
              "citation": {
                "source": "神社合祀に関する意見",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "当夜の火元は柳屋ではなく、かえってその不祥の兆に神経を悩まして、もの狂わしく、井戸端で火難消滅の水垢離を取って、裸体のまま表通まで駆け出すこともあった、天理教信心の婆々の内の麁匆火であった事と。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クエーカー」宗ノ價値ハ天理教ヨリ遙カニ以下ニシテ「リンガム」禮拜ヨリ聊カ以上ナル程度ノ者ナリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "仁右衛門を案内した男は笠井という小作人で、天理教の世話人もしているのだといって聞かせたりした。",
              "citation": {
                "source": "カインの末裔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだ細君から結核を伝えられたＵ氏があの理智的な性情を有ちながら、天理教を信じて、その御｜祈祷で病気を癒そうとしたその心持を考えると、私はたまらなくなる。",
              "citation": {
                "source": "小さき者へ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなりに十八の歳になつて、村の役場に見習の格で雇書記に入つたが、恰度その頃、暴風の様な勢で以て、天理教が付近一帯の村々に入込んで来た。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或晩、気弱者のお安が平生になく真剣になつて、天理教の有難い事を父作松に説いたことを、松太郎は今でも記憶してゐる。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "神道天理教会○○支部といふのがそれで。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後も矢張その会堂に起臥して、天理教の教理、祭式作法、伝道の心得などを学んだが、根が臆病者で、これといふ役にも立たない代り、悪い事はカラ能ない性なのだから、家を潰させ、父を殺し、母を死なしめた、その支部長が、平常可愛がつて使つたものだ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に帰つて、早速亭主を呼んで訊いて見ると、案の如く天理教はまだ入込んでゐないと言ふ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、重兵衛の遠縁の親戚が二軒、遙と隔つた処にゐて、既から天理教に帰依してるといふ事は、予て手紙で知つてもゐ、一昨年の暮弟の家に不幸のあつた時、その親戚からも人が来て重兵衛も改宗を勧められた事があつた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はお由にも天理教に入ることを勧めた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋の門と此の家の門に、『神道天理教会』と書いた、丈五寸許りの、硝子を嵌めた表札が掲げられた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『抑々天理教といふものはな――』と、自分の教へられた支部長の声色を使つて、眼前の石塊を睨んだ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "此家の門と鍛冶屋の門の外には、『神道天理教会』の表札が掲げられなかつた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなりに十八の歳になつて、村の役場に見習の格で雇書記に入つたが、丁度その頃、暴風の樣な勢で以て、天理教が附近一帶の村々に入り込んで來た。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "或晩、氣弱者のお安が平生になく眞劒になつて、天理教の有難い事を父作松に説いたことを、松太郎は今でも記憶してゐる。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "神道天理教會××支部といふのがそれで。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其後も矢張その會堂に起臥して、天理教の教理、祭式作法、傳道の心得などを學んだが、根が臆病者で、これといふ役にも立たない代り、惡い事はカラ出來ない性なのだから、家を潰させ、父を殺し、母を死なしめた、その支部長が、平常可愛がつて使つたものだ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿に歸つて、早速亭主を呼んで訊いて見ると、案の如く天理教はまだ入り込んでゐないと言ふ。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、重兵衞の遠縁の親戚が二軒、遙と隔つた處にゐて、既から天理教に歸依してるといふ事は、豫て手紙で知つてもゐ、一昨年の暮弟の家に不幸のあつた時、その親戚からも人が來て重兵衞も改宗を勸められた事があつた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人はお由にも天理教に入ることを勸めた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋の門と此の家の門に、『神道天理教會』と書いた、丈五寸許りの、硝子を嵌めた表札が掲げられた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
