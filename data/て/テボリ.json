          "literary": [
            {
              "text": "この扉がロッビアだろうが左甚五郎の手彫りだろうが、僕は是が非でも叩き破るんだ」　そうして斧が取り寄せられて、まず最初の一撃が、把手の上のあたり――羽目を目がけて加えられた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "煖炉棚には、なまなましい木目込人形、アイヌの手彫りの木箱、さびくちた古い鉄の五重塔、其他。",
              "citation": {
                "source": "坂田の場合",
                "author": "――「小悪魔の記録」――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃のきたない絵もやはり自分のきたなさは感じないがその癢さを感じてぼりぼりブラシで引掻いたような痕が見える。",
              "citation": {
                "source": "二科展院展急行瞥見記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "障子の外では庭で傭人が陸稲を扱きはじめたと見えてぼり／＼と懶相な音が聞える。",
              "citation": {
                "source": "隣室の客",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜に入ってかき餅などを焼いてもらってぼりぼり噛んだ。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
