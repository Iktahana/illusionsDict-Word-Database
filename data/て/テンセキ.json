  {
    "uuid": "c8c18ab2-b710-5efb-8e87-523ba23e4e5e",
    "entry": "転籍",
    "reading": {
      "primary": "てんせき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
