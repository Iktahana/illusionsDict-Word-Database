    "definitions": [
      {
        "index": 1,
        "gloss": "books",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "富士登山家として、富士に関する図画典籍の大蒐集家として、君は疑いもなく第一人者であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "一夜幼君燈火の下に典籍を繙きて、寂寞としておはしたる、御耳を驚かして、「君、密に申上ぐべきことの候」と御前に伺候せしは、君の腹心の何某なり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暇あれば内外の典籍を披閲して以て才識に資す。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自身、家は焼かれ貴重な典籍の多くを失って居るのである。",
              "citation": {
                "source": "応仁の乱",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今ここに画を描くことを非常に好む者が有って、その者が親兄弟の勧めに従って自ら励んで自分の好まない僧侶になろうと志して、厭々ながら『三藏』（仏教の典籍）に眼を曝すとすると、どうしてもその気が全幅を挙げて宗教の事には対かわないで、自然と絵画の方へ赴きたがる傾向が有るものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は敬首和上の「典籍概見」を以て、我邦に於ける殆ど唯一の目録學書として推薦せざるを得ず。",
              "citation": {
                "source": "敬首和尚の典籍概見",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "和上は淨土宗にて戒律の復興に功ある碩學なるが、此書は全く儒道二教の典籍のみを批判して内典に及ばず。",
              "citation": {
                "source": "敬首和尚の典籍概見",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "（大正十五年十月「典籍の研究」第五號）",
              "citation": {
                "source": "敬首和尚の典籍概見",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "国文学者にとって必要な古文書、典籍などは、主として皇室の図書館や貴族の秘蔵にかかっており、常人にはそれを目で見ることさえ容易でない有様である。",
              "citation": {
                "source": "文学上の復古的提唱に対して",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "カーライルの歿後は有志家の発起で彼の生前使用したる器物調度図書典籍を蒐めてこれを各室に按排し好事のものにはいつでも縦覧せしむる便宜さえ謀られた。",
              "citation": {
                "source": "カーライル博物館",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "温を師として詩を学ぶことになってからは、一面には典籍の渉猟に努力し、一面には字句の錘錬に苦心して、ほとんど寝食を忘れる程であった。",
              "citation": {
                "source": "魚玄機",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "啻に国文を誦するのみではなく、支那の典籍にも通じてゐた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明の一｜訓詁学者は宋代典籍の一にあげてある茶筅の形状を思い起こすに苦しんでいる。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "始皇の典籍を銷燬した記事は、詳に『史記』に載せてあるが、之を熟讀すると、左の事實を否定することが出來ぬ。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後ち楚の項羽が關中に入つて、咸陽の宮殿を一炬に焚き盡した時、官府所藏の典籍多く灰燼に歸したので、古書佚亡の責は、始皇よりも咸陽を焚いた項羽、若くば項羽に先だつて關に入りながら、官府の藏書の保護を怠つた、劉邦や蕭何らが負ふべき筈である。",
              "citation": {
                "source": "秦始皇帝",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "卿が江戸表へやって来たのは、京都の公卿衆が古来の習慣の、典籍や和歌の研究ばかりに、安逸の日を送るのを廃し、ひそかに兵学や武術等を学ぼうと、鷹司関白家をはじめとし、多くの公卿衆がよりより集まり、その実行にとりかかったのを、京都所司代が耳に入れ、これを幕府へ通達した。",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の僧侶どもが、古代異教國の典籍によつて、カトリックの諸聖僧の愚傳をつくつたことは、人のよく知るところである。",
              "citation": {
                "source": "共産黨宣言",
                "author": "カール・マルクス",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十年近くも前のことであるが、私が金沢の高等学校に在学時代、初めて知り合いになった頃は、支那の仏教典籍に凝っていて、鳥巣禅の図などを描いて呉れたことがあった。",
              "citation": {
                "source": "墨色",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば応仁の乱の際には無数の典籍が焼かれたが、幸いに耄及愚翁本は助かったとする。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ日本は、支那の文化を受入れることによって、はじめて自己の文化の発達が促進せられ、また後までも知識社会の知識は支那の典籍によって与えられたものに支配せられることが多かったけれども、その実生活は全く支那人のとは違っていた。",
              "citation": {
                "source": "東洋文化、東洋思想、東洋史",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "上代の学者が支那の典籍から学び得た知識をそのまま書きあらわしている場合が古典には多く、政治的権威を有する公文においても同様である。",
              "citation": {
                "source": "日本精神について",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは典籍も不十分であり、賢人もいないからだ。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「君子は博く典籍を学んで知見をゆたかにすると共に、実践の軌範を礼に求めてその知見にしめくくりをつけて行かなければならない。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "典籍の研究、生活体験、誠意の涵養、社会的信義がそれである。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「典籍の研究は、私も人なみに出来ると思う。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生は順序を立てて、一歩一歩とわれわれを導き、われわれの知識をひろめるには各種の典籍、文物制度を以てせられ、われわれの行動を規制するには礼を以てせられる。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ひろく典籍を学んで知見をゆたかにすると共に、実践の軌範を礼に求めてその知見にしめくくりをつけるがいい。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "千古の典籍の翻訳企図に敬虔の態度を欠かざりしか。",
              "citation": {
                "source": "読書子に寄す",
                "author": "――岩波文庫発刊に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "文庫の編入すべき典籍の厳選はもちろん、編集、校訂、翻訳等、その道の権威者を煩わして最善をつくすことに人知れぬ苦心をしたのである。",
              "citation": {
                "source": "岩波文庫論",
                "author": "岩波茂雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
