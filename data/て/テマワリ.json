        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たとえば電車や公共建築物設備の不完全あるいは破損のために将来当然に起こるべきけがや病害を、とかく不手回りがちな当局者に先だって発見し注意したい。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがたいていけりがついたから、おれは少しばかり手回りの荷物だけ持って一足先にここに越して来たのだ。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "台所などをさせずに、小間使いとして手回りの用事でもさせたら顔かたちといい、性質といい、取り回しといいこれほど理想的な少女はないと思うほどだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "愛子は煤けた障子の陰で手回りの荷物を取り出して案配した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "住持の好意によって、手回りの品物が給せられた。",
              "citation": {
                "source": "乱世",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事手回りかねる際とて、椅子も粗末なものを並べて間に合わせてある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "処でこの云わば制度と制度習得感としての習俗が、一見片々たる細々した手回り品や言葉身振りにまで細分されて捉えられた場合が、恐らく風俗というものだろう。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が公式は単に訓練上だけではなくいつも論証上の又広く制作上の目的に実地に技術的に役立てられるべきもので、古典のように過去のどこかに位置する事物ではなく、現在日常的に手回り近くに用意されてある処の観念的な生産用具に他ならないのである。",
              "citation": {
                "source": "日本イデオロギー論",
                "author": "――現代日本に於ける日本主義・ファシズム・自由主義・思想の批判",
                "note": "青空文庫"
              }
            },
            {
              "text": "本は手回りの道具であり材料なのである。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "書物の借主側において、書物のこの手回り品としての意義を尊重するようになれば、貸借関係の主な困難は消えるだろう。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "異存はあるまいな」　屹と言い放つと、自分の部屋へ入って、何やら手回りのものを一と纏め、四面を睥睨しながら、富山七之助は出て行くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "万両分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "胸から噴き流れて凝った血が、岩となって二枚目の肋骨としてまわりに張っていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "脱穀器は小屋やそこら中の雪、それからすきとおったつめたい空気をふるわせてまわりつづけました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「宇一は、だいぶ方々へ放さんように云うてまわりよるらしい。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬は、テーブルのあしや、ベッドのあしを、ぽんぽんけってまわりました。",
              "citation": {
                "source": "あし",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでルラ蛙はまたもとのところへ走ってきてまわりをぐるぐるぐるぐるまわって泣きました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "と思うと小十郎はがあんと頭が鳴ってまわりがいちめんまっ青になった。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "とのさまがえるは早速例の鉄の棒を持ち出してあまがえるの頭をコツンコツンと叩いてまわりました。",
              "citation": {
                "source": "カイロ団長",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　と、御手洗は高く、稚児は小さいので、下を伝うてまわりを廻るのが、さながら、石に刻んだ形が、噴溢れる水の影に誘われて、すらすらと動くような。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、今までにデンマークを、すみからすみまで旅してまわりました。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "養子夫婦の親孝行のことを今更のように村中に吹聴してまわり始めた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　小さなサーカスは、村むらをねっしんにうってまわりましたが、みいりはほんの、みんなが、かつかつたべていけるだけの、わずかなものでした。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば矢が弦を離れてからぐるぐると風を切てまわりながら直線に進む所が近い例サ。",
              "citation": {
                "source": "ねじくり博士",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと同じ力で張り合って、気分をしてまわりを廻らしめている何物かゞある筈だ。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "チラシが出来上がると、お前はそれを持ってまわり、村のあちこちに貼りつけた。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "去るあたりから尊い智識をお迎えになりまして御住職となされ、満月どののために仰山な施餓鬼をなされまして、御自身も頭を丸めて法体となり、法名を友月と名乗り、朝から晩まで鉦をたたいて京洛の町中を念仏してまわり、満月どのの菩提を弔うておいでになりまする。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一度俺しの言うことをよく聞いてみるがいい」　そう言って、父は自分の質問の趣意を、はたから聞いているときわめてまわりくどく説明するのだったが、よく聞いていると、なるほどとうなずかれるほど急所にあたったことを言っていたりした。",
              "citation": {
                "source": "親子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　伝六のおどろいたことはもちろんでしたが、それよりも妻女の青ざめたことはいっそうのもので、へたへたとそこにうずくまってしまったのをみると、右門はさらに勢い鋭く天井を突き刺してまわりながら、ふたたび大音声で叫びました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞い姫たちは、兄妹を席場の真中の一番高い処の台の上に立たせて、パノラマのような四方の景色を見渡させながら、雪の台のまわりを歌をうたって踊ってまわりました。",
              "citation": {
                "source": "雪の塔",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大概朝のうち註文を取ってまわり、夕方自転車で魚を配達するのであったが、どうかすると何かの都合で、日に二三度顔を現わすこともあった。",
              "citation": {
                "source": "翳",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
