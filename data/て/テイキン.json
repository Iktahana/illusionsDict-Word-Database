[
  {
    "uuid": "a85efd7e-266c-5236-b43f-9d61dd926f52",
    "entry": "提琴",
    "reading": {
      "primary": "ていきん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
