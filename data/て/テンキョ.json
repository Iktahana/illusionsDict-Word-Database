[
  {
    "uuid": "56ecc73b-5e07-5c7e-b61b-9e2ae57312f7",
    "entry": "典拠",
    "reading": {
      "primary": "てんきょ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
