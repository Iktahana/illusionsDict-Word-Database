[
  {
    "uuid": "e46540e1-0f9b-54c7-bc94-af02b22509b7",
    "entry": "的確",
    "reading": {
      "primary": "てきかく",
      "alternatives": [
        "てっかく"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
