    "definitions": [
      {
        "index": 1,
        "gloss": "means of deceiving another",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
