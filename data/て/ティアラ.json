        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜会服の女は頭にダイヤモンドのティアラをつけている。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "階段を降りてくるひときわ目立つ女性が、頭にダイヤモンド・ティアラをつけている。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、サロンにざわめきが起こり、主催者のメリヘイブン令夫人が部屋にはいってきて、少し遅れて、頭にダイヤモンド・ティアラをつけた高貴な女性が入場してきた。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "家具の後ろから見えた背の高い、威厳のある姿、明かりが見事な髪に映え、ダイヤモンド・ティアラがキラキラ輝いている。",
              "citation": {
                "source": "王冠の重み",
                "author": "The Weight of the Crown",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラスタ山にそびえる様子は黒髪女王の頭に輝くティアラのよう。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            },
            {
              "text": "向こうのあれは同じ女性か、仰々しく結い上げた髪にティアラを輝かせたあの女性は、おとなしくて内気な同じ人物か、あのアルカディ森のサクラソウの中で求婚して勝ち取った女性か。",
              "citation": {
                "source": "道化玉座",
                "author": "A MUMMER'S THRONE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
