    "definitions": [
      {
        "index": 1,
        "gloss": "if (an action, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
