        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "インポテンスじゃないかと思うんだけれど。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プルウストの文章はプルウストの話し方が少し難かしい上に、今云つたインテイメイトな話し方で、大層譯すのに困難な長いセンテンスを持つてゐるやうだ。",
              "citation": {
                "source": "「親近」と「拒絶」",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざつとそれを譯して見ると、――※一九〇三年四月二十五日、伊太利ヴィアレジオ（ピサ近郊）、オテル・フロオテンスにて。",
              "citation": {
                "source": "リルケ書翰（ロダン宛）",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋人流の科学的な態度から見た客観的写生的描写だと思って見れば、これは実につまらない短い記載的なセンテンスである。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "マルテンスの『ストリングマスタリー』より拙訳）　スペシアリストのほんとうの意義、その心得を説き尽くしたものと思う。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "六七歳のころ、始めて従兄から英語の手ほどきを教えられた時に、最初に出会ったセンテンスは、たしか「猿が手を持つ」というのであった。",
              "citation": {
                "source": "比較言語学における統計的研究法の可能性について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩きながら口ずさんでいるセンテンス、ふと気づいて指折り数えてみると、きっと、五七五調である。",
              "citation": {
                "source": "古典竜頭蛇尾",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを無茶先生はヤットコで引き出して、大きな鉄敷の上に乗せて、片手に大きな鉄槌をふり上げて、「スッテンスッテンスッテン」　とたたきましたので、豚吉の身体はだんだん長く延びて来て、当り前の長さになりました。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "インポテンスぢやないかと思ふんだけれど。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての遊戯にインポテンスになった私には、全く生気を欠いた自叙伝をぼそぼそ書いて行くよりほかに、路がないであろう。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラヴ・インポテンス。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の二つの場合（前に陳べたるものを斥す）も今｜憶ひ出だし候てだに心｜跳りせらるゝ一種の光明、慰籍に候へども、先日御話いたしし実験は、最も神秘的にして亦最も明瞭に、インテンスのものに候ひき。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の二つの場合（前に陳べたるものを斥す）も今｜憶ひ出だし候てだに心｜跳りせらるゝ一種の光明、慰藉に候へども、先日御話いたしし実験は、最も神秘的にして亦最も明瞭に、インテンスのものに候ひき。",
              "citation": {
                "source": "予が見神の実験",
                "author": "綱島梁川",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかばかしいセンテンスのおかげで、これはなにかと引合いにだされる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うむ、ジム・ホーテンスの説に傾聴するんだな」　さっきから水戸は、巖陰からオルタの町の方を見下ろしていたが、振り向いてドレゴの顔を見ながら、そういった。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ジム・ホーテンスって、アメリカのＣＰの記者のことか。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はホーテンスと話をしたんだな」「うん。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はどういうわけか、ホーテンスから話かけられてね、かなり深く本事件について意見を交換したんだが……」「で、結論はどうだというんだ」　ドレゴは、せきこんで聞いた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……ホーテンスは、さすがに烱眼で、いい狙いをつけているよ。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてホーテンスは、ゼムリヤ号について目的を達したかね」「残念ながら、今朝までのところはね」　と水戸は応えた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おい水戸、これからホーテンスに会おうじゃないか。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ホーテンスは、今この山にいない」「えっ、ここにいない。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "まもなく焦るドレゴを連れて、水戸はホーテンスの跡を追った。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてかれは、ホーテンスとドレゴとを、自分の部屋に招待して、晩餐会を催すことにした。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドレゴが喜んだことは勿論のこと、ホーテンスもいつになくよく喋った。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーテンスはこの土地の名産であるところの一種の鱒の燻製をたいへんに褒めて食べた。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "水戸は、ドレゴがホーテンスが調査したことの詳細を知りたがっていると述べると、ホーテンスは、「よろしい、ではこの好ましき仲間のためにもう一度それを述べよう、今日握った新しい事実も加えて……」　といって気軽に語り出した。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "新鋭砕氷船「水戸君には話しておいたことだが、あの怪汽船ゼムリヤ号はソ連船なんだ」　と、ホーテンスは語り出してドレゴの顔を見た。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
