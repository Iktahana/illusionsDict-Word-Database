        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眉毛は太く短くまっ黒で、おどおどした両の小さい眼を被いかくすほどもじゃもじゃ繁茂していやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眉毛を描いて眼鼻をくっつけ、そうして知らんふりをしていやがる。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "平凡と言つた所で、決していやな感じがする平凡ではない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "福慈岳には夏に入るので白雪でも頂いていやしないか知らん。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」帽子をとっていやに堅苦しくその男が云った。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「民さんはさっき何を考えてあんなに脇見もしないで歩いていたの」「わたし何も考えていやしません」「民さんはそりゃ嘘だよ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "シベリアへ兵隊を出すことさえ始めなければ、自分達だって、三年兵にもなって、こんなところに引き止められていやしないのだ。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お、おどれがうま／＼と腹をおこしていやがる。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかの同年兵達が、よそ／＼しい疑うような眼をして、兵舎へ這入って来た時、彼は始めて自分があの鮮人から贋造紙幣を受取っていやしなかったか、そのことを試されているのに、気づいた。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人の邪魔をしながら、いい気になっていやがるんだ、と西山は思った。",
              "citation": {
                "source": "鍬と鎌の五月",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等をシベリアへよこした者は、彼等が、×××餌食になろうが、狼に食い×××ようが、屁とも思っていやしないのだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人の絵にはかつていやな絵というものを見ない。",
              "citation": {
                "source": "昭和二年の二科会と美術院",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "家主だって自身番だって、なんとも思っていやあしませんよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪く片付けていやあがると引っぱたくぞ」「今と違って、むかしの番屋の調べはみんなこんな調子でしたよ」と、半七老人は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何をしていやあがるのか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうポケットにはどれだけが程も残っていやしない！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おや、こんな、ロシヤの弾丸がまじっていやがら――こいつのさきは、両方とも尖っているんだぞ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴様ッ、まだ、ふてぶてしくかまえていやがるんか！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰の仕業だか、あきていやになるまで探しても分らなかった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺れがどんなにのた打ちまわっとったって、領事館の奴はへへら笑っていやがるんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど小学校の読本の村のことを書いたところのようにじつにうそらしくてわざとらしくていやなところがあるのだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蠍は尾をギーギーと石ころの上に引きずっていやな息をはあはあ吐いてよろりよろりとあるくのです。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこれは豚の方では、それが生れつきなのだし、充分によくなれていたから、けしていやだとも思わなかった。",
              "citation": {
                "source": "フランドン農学校の豚",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かがどこかで見ていやしなかったかと、自分は眼の下の人家の方を見た。",
              "citation": {
                "source": "路上",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺身ッていやあ一寸試だ、鱠にすりゃぶつぶつ切か、あの又目口のついた天窓へ骨が繋って肉が絡いついて残る図なんてものは、と厭な顔をするからね。",
              "citation": {
                "source": "三尺角",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ばかめ、こんな爺さんを掴めえて、剣突もすさまじいや、なんだと思っていやがんでえ、こう指一本でも指してみろ、今じゃおいらが後見だ」　憤慨と、軽侮と、怨恨とを満たしたる、視線の赴くところ、麹町一番町英国公使館の土塀のあたりを、柳の木立ちに隠見して、角燈あり、南をさして行く。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨年始めてイタリアのお寺でこの懺悔をしているところを見ていやな感じがしてから、この仕掛けを見るごとに僧侶を憎み信徒をかわいく思います。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、これで百歳まで生きる覚悟があったら、自分はやっぱり奮発していやな品に慣れる努力をするであろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を言っていやがる。",
              "citation": {
                "source": "葉",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの先生、口髭をはやしていやがるけど、あの口髭の趣味は難解だ。",
              "citation": {
                "source": "渡り鳥",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
