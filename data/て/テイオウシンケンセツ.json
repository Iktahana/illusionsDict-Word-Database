        "examples": {
          "standard": [
            {
              "text": "王権は神から授かったものであり、国民はそれに背くことはできないという帝王神権説。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "歴史の授業で、絶対王政を支えた理論的根拠として帝王神権説を習った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "市民革命の勃発により、古びた帝王神権説は民衆の手によって否定された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "当のニコラスはそのくせ危険なほど自己の優越を誇り、皇帝は支配し、臣民は服従すべく神によって定められているという帝王神権説を信奉してい、レセプション付の晩餐会などでわけのわからぬ演説をして廷臣や官僚を面白がらせた。",
              "citation": {
                "source": "淪落の皇女の覚書",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
