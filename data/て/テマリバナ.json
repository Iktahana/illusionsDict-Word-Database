        "examples": {
          "standard": [
            {
              "text": "春の庭には、白い手毬花が美しく咲き誇っていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女は手毬花の花束を手に、幸せそうに微笑んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "小さな路地の奥に、ひっそりと手毬花が咲いていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "しかし近代の中国人は日本から中国へ渡ったアジサイを瑪理花（毬花の意）とも、天麻理花（手毬花の意）とも、また洋繍球とも、あるいは洋綉球ともいっているが、この洋は海外から渡来したものを表わす意味の字である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
