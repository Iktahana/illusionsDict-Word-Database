[
  {
    "uuid": "ac04c347-831e-5fec-a57e-039771e894c3",
    "entry": "手間取る",
    "reading": {
      "primary": "てまどる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
