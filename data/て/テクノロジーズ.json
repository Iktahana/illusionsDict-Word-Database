        "examples": {
          "standard": [
            {
              "text": "その会社は、エヌ・ティ・ティ・データ・テクノロジーズという名称だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "様々なテクノロジーズを融合させて、全く新しいサービスを開発する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "求人サイトで、社名に「テクノロジーズ」と付くIT系企業を探した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "ＡＭＤのＸ８６互換への挑戦は、その後チップス＆テクノロジーズ、サイリックス、テキサス・インスツルメンツといった追随者を生み、競争相手の出現によってインテルは製品の大幅な値下げを迫られた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "互換ＢＩＯＳを販売するフェニックステクノロジーズ社の誕生は、独自開発に必要な規模の大きな投資を不要にし、互換機メーカーの誕生に拍車をかけた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
