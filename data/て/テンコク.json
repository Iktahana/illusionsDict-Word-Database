        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこから自ずから彼は表具もやれば刀を採って、木彫｜篆刻の業もした。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは表札が家不相応にしゃれた篆刻で雅号らしい名を彫り付けてあるからである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "朶石からは画の他に漢詩作法と篆刻と築城講話と、そして国手から半弓と碁と笛と釣りと箱庭作法とを習つた。",
              "citation": {
                "source": "気狂ひ師匠",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その途端｜篆刻家の桑名鉄城氏ががつしりした肩を揺がしながら入つて来た。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体殿様だの、物特だのが何か大それた事でも仕出来さうとする時には、次の室からよく人が留め立に出て来るもので、それが二千石の家老であらうが、篆刻家であらうが少しの差支もない。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　篆刻家は座につくなりかう言つて、侯爵の顔を見た。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "侯爵はじろりと篆刻家を見かへした。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　篆刻家は一字幾らと相場の極つた掌面で額を撫であげながら感心した。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "山田泰雲君は元｜篆刻師の弟子であったが、芦野楠山先生の世話で師の許を得て私の門下となった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "その後の弟子の事",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は詩をつくることと篆刻が少年時代の趣味だったそうで、楠の小引出しにいろいろと彫った臘石があったのを私も憶えている。",
              "citation": {
                "source": "本棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煎茶を嗜み、篆刻を善くした。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "又斎の子が亦斎で、家業を嫌ひ、篆刻を学び、後には所謂戯作者の群に投じ、雑書を著して自ら紫軒道人と署した。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "書、篆刻、謡、舞、長唄、常盤津、歌沢、狂言、テニス、氷辷り等通ぜざるものなしと言ふに至つては、誰か唖然として驚かざらんや。",
              "citation": {
                "source": "田端人",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "書画、篆刻、等を愛するに至りしも小穴一游亭に負ふ所多かるべし。",
              "citation": {
                "source": "わが家の古玩",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから或｜篆刻家は、――しかし彼等の犯した罪は不思議にも彼の苦しみには何の変化も与えなかった。",
              "citation": {
                "source": "玄鶴山房",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "篆刻の美は、死の海に泛んだ生の美の象徴ではなかったか。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ていると篆刻のようで、家の盛衰も餅の円形に顕れている。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "篆刻のごとき美しさだ。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の家の遺伝を云えば、父も兄も文人で、殊に兄は書も善くし、画も出来、篆刻も出来る程の多芸な人に、その弟はこの通りな無芸無能、書画は扨置き骨董も美術品も一切無頓着、住居の家も大工任せ、庭園の木石も植木屋次第、衣服の流行など何が何やら少しも知らず又知ろうとも思わず、唯人の着せて呉れるものを着て居る。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "欣々女史の書画――篆刻の技は、素人のいきをぬけて、斯道の人にも認められていたのだ。",
              "citation": {
                "source": "江木欣々女史",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、その時扉の裏側に、はしなくも異様な細字の篆刻を発見したのである。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、しばらくその篆刻文を瞶めていたが、やがて、「ああ、そうでしたね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを露柴はずっと前から、家業はほとんど人任せにしたなり、自分は山谷の露路の奥に、句と書と篆刻とを楽しんでいた。",
              "citation": {
                "source": "魚河岸",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「桐陰論畫」で私はその簡單な記事を讀んだだけであるが、詩文書畫のいづれにもすぐれ、ことに篆刻が好く、簡古超逸とある。",
              "citation": {
                "source": "我思古人",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、これは篆刻家ではないらしく、黄丕烈（蕘圃）といふ清代の學者の手刻した「蕘圃手校」といふ印がある。",
              "citation": {
                "source": "我思古人",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "篆刻が旨いという事も話した。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩は閑人の囈語に非ず、詩は彫虫篆刻の末技に非ず。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、詩を以て遊戲と爲し閑文字と爲し彫虫篆刻の末技と爲すは古來の漸なり、是弊敗れずんば眞詩決して起らじ。",
              "citation": {
                "source": "天地有情",
                "author": "土井晩翠",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に篆刻の研究及び心得があるという理由で、大きな顔して批判するのではないが、私の観るところ、この中日本製印が一番芸術的に優れていると思う。",
              "citation": {
                "source": "陶磁印六顆を紹介する",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
