          "literary": [
            {
              "text": "天保より前に、天明の飢饉と云ふのがあつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれが明暦の大火事や天明の飢饉のような凶年ばっかり続いた日にゃ、いくら贅沢がいたしたくてもまさかに盆栽や歌｜俳諧で日を送るわけにも行きますまい。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "天明の飢饉の折にお粥の炊き出しをしたという大釜の罅の入ったのが残っている。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
