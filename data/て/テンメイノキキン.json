        "examples": {
          "standard": [
            {
              "text": "天明の飢饉では多くの人々が食料不足に苦しんだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史の授業で天明の飢饉について深く学んだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "天明の飢饉は江戸時代の社会に大きな影響を与えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "天保より前に、天明の飢饉と云ふのがあつた。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしこれが明暦の大火事や天明の飢饉のような凶年ばっかり続いた日にゃ、いくら贅沢がいたしたくてもまさかに盆栽や歌｜俳諧で日を送るわけにも行きますまい。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "天明の飢饉の折にお粥の炊き出しをしたという大釜の罅の入ったのが残っている。",
              "citation": {
                "source": "ぐうたら道中記",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
