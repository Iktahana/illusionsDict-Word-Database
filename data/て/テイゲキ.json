    "definitions": [
      {
        "index": 1,
        "gloss": "Imperial Theatre (Tokyo)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
