        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうかといって太平のシャンゼリゼーの大通りやボアの小道を散歩するのに、まさか弓矢や人殺し用の棍棒や台所用のパン棒を携えるわけにも行かないから、その代わりに何かしら手ごろな棒きれを持つことになったのではないかとも想像される。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　チュンセ童子が沓をぬいで小流れの中に入り、ポウセ童子は岸から手ごろの石を集めはじめました。",
              "citation": {
                "source": "双子の星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは結局われわれの身近に起こるいろいろな現象の観測をする場合に最も「手ごろな」単位として選ばれたものであることは疑いもない事実である。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなるものを「手ごろ」と感ずるかは畢竟人間本位の判断であって、人間が判断しやすい程度の時間間隔だというだけのことである。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろでは「夜光虫ノクチルカ」その他の発光動物に関するものを捜しているが、まとまった手ごろな本はまだ見つからない。",
              "citation": {
                "source": "錯覚数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまで美しというにあらねど童には手ごろの生き物ゆえ長の児が寵愛なおざりならず、ただかの青年にのみはその背を借すことあり。",
              "citation": {
                "source": "わかれ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "道ばたにはところどころに赤く立ち枯れになった黍の畑が、暗い森を背景にして、さまざまの手ごろな小品を見せていた。",
              "citation": {
                "source": "写生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしまた一面においては常設館の常顧客であるところの大衆の期待に応ずるような手ごろの材料をかなりに盛りだくさんにあんばいすることに骨を折ったようである。",
              "citation": {
                "source": "音楽的映画としての「ラヴ・ミ・トゥナイト」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが手ごろの風呂敷包を二枚の板の間に挾んで、棒を通して挾み箱のように肩にかついでいた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "純次は何か手ごろの得物をさぐっているのらしくごそごそと臥床のまわりを動きはじめていた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷は筵包にして天秤に釣したる、其片端には、手ごろの石を藁縄もて結びかけしが、重きもの荷ひたる、力なき身体のよろめく毎に、石は、ふらゝこの如くはずみて揺れつ。",
              "citation": {
                "source": "紫陽花",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで許宣は白娘子と二人で碼頭の傍へ手ごろの家を借りて薬舗をはじめた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁の下には枯れ枝や竹切れがほうり込んであるので、父は手ごろの枝を持ち出して静かにあるき始めた。",
              "citation": {
                "source": "穴",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "怪量は手ごろの松の木を引っこ抜いて、縦横無尽に振りまわした。",
              "citation": {
                "source": "轆轤首",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボールがゴムまり、バットには手ごろの竹片がそこらの畑の垣根から容易に略奪された。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで許宣は白娘子と二人で、碼頭の傍へ手ごろの家を借りて薬舗をはじめた。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と構えたのは蟇で――手ごろの沢庵圧ぐらいあろうという曲者。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は兎に角、可憐なさうして手ごろの小さい抒情小曲集を、私のなつかしい人々の手に献げたいと思つて、なるべく自分に親しみの深い、穉い時代の「思ひ出」を茲に集めた。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "枯々とした裏庭に出て、父さん達は『シヨクノ』の遊びにする細い木を探したり、それを手ごろの長さに切つたり、地べたへよく打ちこめるやうに先の方を尖らせたり、時にはもう幾度か勝負をした揚句に土のついて齒のこぼれたやつを削り直したりして遊びました。",
              "citation": {
                "source": "ふるさと",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "四十三　夏の半ば過ぎに、お銀たちの近くのある静かな町で、手ごろな家が一軒見つかったころには、二人の心はまた新しい世帯の方へ嚮いていた。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、それにかかわらず、お絹も道太が時々気をぬきに来るように、もし手ごろな家を一軒かりてでもおくなら、留守番をしていてもいいような話もあったので、それも頭脳に描いていた。",
              "citation": {
                "source": "挿話",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兵隊や兵隊を送った家族の女の感情にもひきずられてその女の感情で」中国へも南方へも行ったのであったが、一九四五年八月十五日がくるまで日本の人民を虚偽の大本営発表であざむきつづけた軍部としては、彼女たちの「泣いて語る話が手ごろに必要だったのである」と。",
              "citation": {
                "source": "婦人作家",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし強い僧は手ごろの若木を引きぬいて武器とし、それを打ちふって首をなぐりつけ、恐ろしい力でなぎたててよせつけなかった。",
              "citation": {
                "source": "ろくろ首",
                "author": "ROKURO-KUBI",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くの町で彼は眼の悪い義雄兄のために手ごろな杖を見立てて買って来て置いた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖母はその二、三種を、手ごろな有りぎれのまま、ザクリと手にさげて帰る――あたしたちの目はかがやいたものである。",
              "citation": {
                "source": "大丸呉服店",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばに、手ごろな朱塗の棒まで添えてあるから、これで叩くのかなと思っていると、まだ、それを手にしない中に、玄関の障子のかげにいた人が、「どうぞこちらへ」と声をかけた。",
              "citation": {
                "source": "野呂松人形",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この日に限って強いて、アンリエットを押しつけるようにしたがる久慈だったが、それも自分をからかうには手ごろな面白さなのだろうと矢代は思った。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "悉くやめてごろり轉がるとがつかりして身體が解けるやうな氣がした。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして日あたりのいい南向きのかれ芝の上に、いきなり獲物を投げだして、ばさばさの赤い髪毛を指でかきまわしながら、肩を円くしてごろりと寝ころびました。",
              "citation": {
                "source": "山男の四月",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大学士はマッチをすって火をたき、それからビスケットを出しもそもそ喰べたり手帳に何か書きつけたりしばらくの間してゐたがおしまひに火をどんどん燃してごろりと藁にねころんだ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
