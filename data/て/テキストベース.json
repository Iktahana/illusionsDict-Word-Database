        "examples": {
          "standard": [
            {
              "text": "複雑なグラフィックを排したテキストベースのゲームが、一部の層で根強い人気を誇っている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "このツールはテキストベースで動作するため、低スペックのPCでも軽快に動く。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "仕様書をテキストベースで管理し、Gitなどのバージョン管理システムで変更履歴を追う。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "テキストベースのマシンならともかく、ビットマップの処理を高速で繰り返す必要の生じるアルト型のマシンでは、ＤＭＡコントローラーへの負担はとりわけ大きくなることが予想できた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ浮川は、当初社内でプロトタイプの開発を進めていた光の延長上にくる、テキストベースのワードプロセッサーを開発したいと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自社ブランドへの切り替えと、テキストベースの新しい製品の開発という二つの目標を据えていた浮川は、ＪＳ―ＷＯＲＤの移植を打診された日本ＩＢＭのＪＸを、突破口を開くための機会として利用しようと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、ＪＸ用に開発する新しいテキストベースの製品では、文章単位でカタカナも含めて一気に変換してしまう連文節変換まで機能を拡張し、これをＡＴＯＫ３と改名することとした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにクォーターデック社がＤｅｓＱと名付けた操作環境を発表し、ＩＢＭもまたテキストベースながらウインドウを提供するＴｏｐＶｉｅｗの開発を自ら進める中で、マイクロソフトはこの年の十一月、Ｗｉｎｄｏｗｓの正式な発表に踏み切り、翌年の五月には出荷を開始することを約束した。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
