    "definitions": [
      {
        "index": 1,
        "gloss": "(being) empty-handed",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "乗合わせた農夫農婦などは銘々の大きな荷物に腰かけているからいいが、手ぶらの教授方以下いずれも立ったままでゆられながら、しきりに大気の物理を論じ合っていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等は手ぶらでいやがった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れらは、まったく手ぶらで、ただ、衣服を着けただけで上がってくる。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十分ほどたつと、彼は手ぶらで、悄然と反対の方から丘を登り、それから、兵営へ丘を下って帰って来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「俺ら、若しもの場合に、銃を持って行くから、お前、手ぶらで来て呉れんか。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅行でも、出来れば手ぶらで汽車に乗れるように、実にさまざまに工夫するのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぶらで帰れば、雪子は今日も宿を出られず、昨夜と同じように一つの部屋で明かさねばならない。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "病み疲れてヘトヘトになりかけている彼にとっては、その把手に縋って押して歩く方が、手ぶらで蹌踉めき歩くよりも遥かに楽な気持ちがした。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "真佐子の方から手ぶらで珍らしく復一の家の外を散歩しに来ていた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵太郎君は、手ぶらで、へんにうかぬ顔をしていた。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぶらで、その手つきは、大石投魚を取返しそうな構えでない。",
              "citation": {
                "source": "貝の穴に河童の居る事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、其の色にも活計にも、寐起にも夜晝の區別のない、迷晦朦朧として黄昏男と言はれても、江戸兒だ、大氣なもので、手ぶらで柳橋の館――いや館は上方――何とか家へ推參する。",
              "citation": {
                "source": "遺稿",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このまま、手ぶらでも、けえられめえ。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "言問の曲角で、天道是か非か、又一組、之は又念入な、旦那樣は洋服の高帽子で、而して若樣をお抱き遊ばし、奧樣は深張の蝙蝠傘澄して押並ぶ後から、はれやれお乳の人がついて手ぶらなり。",
              "citation": {
                "source": "彌次行",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "手と膝頭を擦り剥いただけでしたが、私は手ぶらで帰っても浜子に折檻されない口実ができたと思ったのでしょう、通りかかった人が抱き起しても、死んだようになっていました。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀やんは毎朝北田辺から手ぶらで出てきて河堀口の米屋に預けてある空の荷車を受けとると、それを引っぱって近くの青物市場へ行き、仕入れた青物つまり野菜類をその車に載せて、石ヶ辻や生国魂方面へかけて行商します。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局お前は手ぶらですごすご帰って行った。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こんなスカタンな、滅茶苦茶な戦争されて、一時間のちの命もわからんようなことにされながら、いくら兵隊さんにでも、へいと言って出せるもんですか」　そう言われると、二人は、「自分たちもそう思います」　と、うっかり（というより寧ろ本心から）そう答えてしまい、これでは手ぶらで帰るより仕方がなかった。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、このまま手ぶらで帰れば、咽から手の出るほどスキ焼きを待ちこがれている隊長の手が、狂暴に動き出して、半殺しの目に会わされるだろうことは地球が、まるい事実よりも明らかである。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は小さい風呂敷包み一つを持っているだけで、ほとんど手ぶら同様だ。",
              "citation": {
                "source": "水鬼",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠が手ぶらでさきに立つてはしご段をのぼる時、ちよツと下の夫婦の樣子に目を放つたが、「どうだ、下のあツたかさうなことは」と、義雄は上へあがつてからお鳥に初めて私やかに聲をかけた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だめよ、汝、手ぶらで往っちゃ、これ持ってくのよ、お婆さんに持って往かして」　それは抱きかかえている渋紙包を持って往けと云うのであった。",
              "citation": {
                "source": "春心",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、その色にも活計にも、寐起にも夜昼の区別のない、迷晦朦朧として黄昏男と言われても、江戸児だ、大気なもので、手ぶらで柳橋の館――いや館は上方――何とか家へ推参する。",
              "citation": {
                "source": "遺稿",
                "author": "遺稿",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぶらでも帰られまい。",
              "citation": {
                "source": "註文帳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その残金はわたくし共の方に確かにあずかってございますが、自分のふところにはどのくらい持っていましたか、それはどうも判り兼ねます」「外から帰ってくる時には、いつも手ぶらで帰ったかえ」「いいえ、いつも何か風呂敷包みを重そうに提げていました。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分、後生だからいい智恵を授けておくんなせえ」「いい智恵と云ってもねえが、見込みをつけて江戸から乗り込んで来た以上、ただ手ぶらでも引き揚げられねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "異人の首",
                "note": "青空文庫"
              }
            },
            {
              "text": "やっぱり手ぶらで帰って来て、『今夜もまたやり損じた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹の縁に引かれながらも、手ぶらでいつまでも彼女の厄介になっていたくもなかった。",
              "citation": {
                "source": "両国の秋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、もう縛り上げる罪人の種が尽きたとみえ、いちばん最後に手ぶらでミルク屋を出ようとした土工体の男は、入口に立ち塞がっているこの青年が邪魔になったとみえ、「退け！",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく、同僚が皆それぞれ獲物を連れて帰るのに、自分一人、手ぶらで帰るのは、この刑事にとってはちょっと不快なことであったのに相違ありません。",
              "citation": {
                "source": "若杉裁判長",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
