    "definitions": [
      {
        "index": 1,
        "gloss": "moving out (to)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "斯くて婦人が無体にも予が寝し衾をかゝげつゝ、衝と身を入るゝに絶叫して、護謨球の如く飛上り、室の外に転出でて畢生の力を籠め、艶魔を封ずるかの如く、襖を圧へて立ちけるまでは、自分なせし業とは思はず、祈念を凝せる神仏がしかなさしめしを信ずるなり。",
              "citation": {
                "source": "妖怪年代記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎のほうに転出しようかとも考えているのですが、永い汽車旅行のあいだに悪化してしまうといけませんし、とにかくこの子の眼がよくならなければ私たちはどこへも行けない状態で、ほんとに困ってしまって。",
              "citation": {
                "source": "薄明",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは書画骨董の鑑定を学んで、それ等の仲介のコンミッションを取ったり、自分でも売買する方面へ職業を転出して行った。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大摩里支菩薩経』に、〈※酥枳竜口より二舌｜出づ、身弦線のごとし〉とあるのは、トラクオトなどより転出した物か、アリゾナのモキス人、カシュミルの竜種人など、竜蛇の子孫という民族所々にある、これらも昔は鱗あるといったのだろう。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度『ラーマーヤナ』を通読すると支那の『西遊記』の孫悟空はどうもハヌマン伝から転出したよう思われる。",
              "citation": {
                "source": "十二支考",
                "author": "猴に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く上に引いた『賢愚因縁経』の瓢箪から駒でなくて麦を出した話から転出されたので、瓢から出た穀物を国中に施したなども両譚相似いる。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "上に孫引きした『博物類纂』の支那方あたりから転出したと見える。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより転出したようなは、ブリタニーの天主教寺の縁日に壁に掛けて僧が杖もて絵解する画幅で、罪業深き人の心臓の真中にある大鬼を七動物が囲繞の体だ。",
              "citation": {
                "source": "十二支考",
                "author": "猪に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の軍司令官は村岡中将で、河本大佐はその直前転出し、板垣征四郎大佐が着任したばかりであった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦災を被った都会からの転出者との生活上の摩擦、昨今の供出の難かしい問題など、それは農村の封建的な土地との関係、家族の関係などを引くるめて、決して農村婦人の生活を、これまでよりも負担の軽い、楽しい明るいものとはしていないのである。",
              "citation": {
                "source": "私たちの建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "転入は転出証明だけでは駄目なので、一寸暇どるやうです。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後、この村から私が転出する際も、私はまたその老人の手を煩はした。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人は滅多に役場に姿を現さず主に畑を耕してゐるのだつたが、その日、村道の中ほどを悠然と歩いてゐる老人の姿を見つけると、私はやにはに追ひ縋つて、転出のことを頼んだ。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "村役場の机で、老人は転出証明を書いてくれた。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東京への転出はどうもむつかしいといふことだがな……」と老人は首を捻りながら、とにかくそれを書いてくれたのである。",
              "citation": {
                "source": "小さな村",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちに彼は済南方面へ転出するという噂もありましたし、また、省政府筋と常に反目しがちで、急激な武断政略を計画してるとの噂もありました。",
              "citation": {
                "source": "白塔の歌",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "）転出調査表を送って書きこめと云って来た。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だいたいパンパンというものは移動がはげしいし、転出証明もない者が多く、たいがい選挙権を持たない連中だ。",
              "citation": {
                "source": "選挙殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれがまだ農家に転出していた時のことだ。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見はやっとの思いで、転出先の農家に帰り著いた。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるに昨年の秋になって、転出先から疲れ切った翼を休めにもとの古巣に戻って来て、さて今年の夏になって見ると、裏庭を畑におこしたそのあとの土に、この久しく忘れていたとんぼ草が一面にはびこり出したのを発見した。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風笛は高天井に木魂して、人々がこれを怪しみ誦経の声を呑んだ時には、転出する円凹様々な風声のみが大小高低の妙を描きだすばかりであつた。",
              "citation": {
                "source": "閑山",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十四日（木）　陸軍軍務局長に眞田（穰一郎）少將就任し、例の佐藤賢了は他に転出した。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "と間もなく横山町辺の提灯をつけた辻駕籠一梃、飛ぶがように駈来って門口に止るや否や、中から転出る商人風の男、「先生は御在宅でいらっしゃいますか。",
              "citation": {
                "source": "散柳窓夕栄",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後になってもやまないので監視しているうちに、トラックの兵隊が、東京近県の各部隊が東京へ転出する輸送準備の一部だというようなことをいっているのを聞きこんだ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "猶、進駐地域ニ居住スル必要ナキ婦女子ハ出来得ル限リ速カニ地域外ニ転出スベシ。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに手落ちです」「お伺いいたしますが、転出すべしというのは、注意なのでしょうか、命令なのでしょうか」「注意でも命令でもない、一種の自白のようなものです。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "忽然と消滅したり……というのは殺されることですが、唐突に転出したり……そういう不断の変化と取ッ組んで、たえず個人カードを修正していかなくてはならないんだが、スイスの公使館は、利益代表の立場を守って、俘虜関係には手をださない。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "先々で、またお願いするとして」「わかりました」　転出要請の電文のほかに、転出の理由と目的を説明した簡単な報告書をタイプで打つと、すぐ地階の監倉へ入れられた。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
