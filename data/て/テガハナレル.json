        "examples": {
          "standard": [
            {
              "text": "子どもが成長して、ようやく親の手が離れる時期が来た。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "大学進学を機に、実家を離れて親の手が離れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "プロジェクトの準備が整い、ようやく担当者の手が離れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "一生懸命に靴下を摘んで、ながいことかかって或る程度まで脚を空に上げる事業に成功するんだが、そのうちにぽつんと切るように手が離れると、身体ぜんたいがころっと反り返って驚いて両腕をひろげる。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
