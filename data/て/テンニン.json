        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「昔宮古島｜川満の邑に、天仁屋大司といふ天の神女、邑の東隅なる宮森に来り寓し、遂に目利真按司に嫁して三女一男を生む。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "年十四歳の時、祖母天仁屋及び母真嘉那志に相随ひて、倶に白雲に乗りて天に升る。",
              "citation": {
                "source": "山の人生",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
