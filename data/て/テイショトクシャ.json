        "examples": {
          "standard": [
            {
              "text": "自治体は、生活に困窮している低所得者に対して、食料品や日用品の無料配布を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "「低所得者への増税は、生存権を脅かすものだ」と野党議員が国会で激しく訴えた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "国民健康保険料の軽減措置を受けるため、低所得者向けの減免申請を市役所で行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "黒人、農村、老人、低所得者たちが、豊かな中産階級の影に、とりのこされていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "都市と機械が勝ちを示していく日々の影で、農村、黒人、そして都市の低所得者たちが、とりのこされていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
