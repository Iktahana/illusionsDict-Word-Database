    "definitions": [
      {
        "index": 1,
        "gloss": "to repeat someone's mistake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
