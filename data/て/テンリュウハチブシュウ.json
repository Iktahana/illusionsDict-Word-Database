        "examples": {
          "standard": [
            {
              "text": "天竜八部衆は、仏教の世界観を構成する重要な要素である。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "仏像の周囲には、天竜八部衆の姿が彫刻されていることが多い。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの寺院の壁画には、天竜八部衆がそれぞれの役割を果たす場面が描かれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "十大弟子、天竜八部衆、二組の四天王、帝釈・梵天、維摩、などを除いて、目ぼしいものはみな観音である。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三月堂の諸作や聖林寺観音などを一群として、これを興福寺の十大弟子や天竜八部衆に比べて見る。",
              "citation": {
                "source": "古寺巡礼",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            }
          ]
        }
