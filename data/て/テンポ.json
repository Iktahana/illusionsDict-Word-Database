[
  {
    "uuid": "e437a366-80d9-59b4-90df-274b9c58fdc1",
    "entry": "テンポ",
    "reading": {
      "primary": "テンポ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
