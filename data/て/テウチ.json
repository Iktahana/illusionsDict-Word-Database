[
  {
    "uuid": "b8db8833-1518-58d6-a182-1451ddfe0272",
    "entry": "手打ち",
    "reading": {
      "primary": "てうち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
