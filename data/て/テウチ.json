    "definitions": [
      {
        "index": 1,
        "gloss": "striking a deal",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "暗い道の辻を曲った時、うどんそば手打と書いた赤い行燈を見て、ふと「手打ちだ！",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "座にあるものは思はず片唾を飮んで、平手打ちでも喰はされたやうに後ろに靡きたぢろいだ。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……」「蕎麥は手打ちで、まつたく感心に食はせるからな。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも加奈江が二、三歩階段に近づいたとき、その社員は加奈江の前に駆けて来て、いきなり彼女の左の頬に平手打ちを食わした。",
              "citation": {
                "source": "越年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "お言葉のとおり、この国は大空の神さまのお子さまにおあげなさいまし」と言いながら、自分の乗って帰った船を踏み傾けて、おまじないの手打ちをしますと、その船はたちまち、青いいけがきに変わってしまいました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」かう急に聲が變つて、腦天から出たやうな叫びをあげながら、廊下を渡つて行つて、まだ水も切れない手で妻の横ツつらを平手打ちにした。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、直ぐにでも得意の平手打ちを喰らはせようと待ちかまへてゐた張り合ひがなくなつた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "母上善くぞ歌ひしと讚め給へば、農夫どもゝジヤコモが旨さよ、と手打ち鳴してさゞめきぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "お身が今、お目通りに出たら必定お手打ちじゃ。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ただこのままに、お手打ちを」と嘆願する与四郎は、なんのお咎めもなく下げられたばかりでなく、与四郎の妻も、即刻お暇を賜った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と前吉はおふくろの頬ぺたに平手打ちを加へる。",
              "citation": {
                "source": "おふくろ",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "サーベルで×××つける音が、平手打ちの音に交つて聞えた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも片手だ、片手打ちだ！",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなったら仕方がない、一日も早くお北のありかを探し出して、手打ちにして……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "白蝶怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の可愛らしさを心の中で平手打ちにしている女性はいない。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ近衛青年内閣あたりで手打ちをしておこう、という虚脱した気持ちさえある。",
              "citation": {
                "source": "近衛内閣の常識性",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで殿様は煩悶して家来を手打ちにしたりして乱暴するものですから幽閉されて、子供に殿様の位を譲って隠居させられてしまう。",
              "citation": {
                "source": "幸福の建設",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕎麦は手打ち、うでて「しゃっきり」と角があって、おつゆをかけて出されてもきらりと光っていたものであります。",
              "citation": {
                "source": "蕎麦の味と食い方問題",
                "author": "村井政善",
                "note": "青空文庫"
              }
            },
            {
              "text": "殿様が恋慕していた腰元が不義をして、対手の若侍と並んで刑に処せられようとする三角恋愛に、悪びれずにお手打ちになろうとする女と、助かりたさと恐怖に、目の眩んでいる若侍と、一種独特な人世観を持った殿様とが登場する狂言で、殿様が喜多村｜緑郎、若侍が花柳章太郎、貞奴が腰元であった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「職工の方が折れさせられて手打ちになったが、太いもんにゃかなわないよ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "平手打ちを食つて、頬が焼けつくやうであつたが、なか子は泣かなかつた。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「○○が仲へ入って三割かた職工の方が折れさせられて手打ちになったが、太いもんにゃかなわないよ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "島田屋はその門前にある農家の兼ねた蕎麦屋で手打ち蕎麦を食べさせたさうである、先生達はよくそこへ行かれた。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、現代画家でもっとも高く、もっとも多くの自作をもっとも手広く売り拡めんがためには、金持ちの応接間はことごとく上がり込むだけの勇気と、手打ちうどんの如き太き神経を必要とするだろう。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "グルリとかこんだ者の中から誰か、しっかりその手の平に平手打ちをくわして、素早く引こむ。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この様を見たる喜左衛門は一時の怒に我を忘れ、この野郎、何をしやがったと罵りけるが、たちまち御前なりしに心づき、冷汗背を沾すと共に、蹲踞してお手打ちを待ち居りしに、上様には大きに笑わせられ、予の誤じゃ、ゆるせと御意あり。",
              "citation": {
                "source": "三右衛門の罪",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを、巻き風が平手打ちのようにたたきつけるのだ。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その前の数年間、中芝居に毎年顔見世の手打ち芝居から続けてゐた右団治（斎入）、それに、荒五郎・正朝・琥珀郎・玉七などの一座を見て居たのである。",
              "citation": {
                "source": "戞々たり　車上の優人",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来この隣国の大将は、獅子王をも手打ちにすると聞えた、万夫不当の剛の者でおぢやれば、「あんちおきや」の帝とても、なほざりの合戦はなるまじい。",
              "citation": {
                "source": "きりしとほろ上人伝",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "またその※のうつくしさふと物音におどろきて午睡の夢をさまされし牡牛のごとも、あどけなくかろやかにまたしとやかにもたげられ、さてうち俯しぬ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
