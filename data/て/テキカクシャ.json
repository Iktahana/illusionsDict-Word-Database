        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "委員会は、プロジェクトのリーダーとして最も適格者を選出した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "応募書類を厳正に審査し、面接に進む適格者を決定する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この難解な研究テーマに取り組むには、高度な専門知識を持つ適格者が不可欠だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "さらにつづいて一般復員軍人の教職への新規採用に関する日本教育非適格者追放指令が発せられた。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家橘の死後、此方面には、適格者としては我童があつたばかりで、長く類型を見ることが出来なくなるのである。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のところ日本では全くの不適格者ばかりで、なんとも情ない状況にあります。",
              "citation": {
                "source": "陶芸家を志す者のために",
                "author": "―芸術における人と作品の関係について―",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまのアメリカ社会には意外に穴が多いから、自ら不適格者となる方法をみつけ、その穴からドロップ・アウトしろ、と呼びかけている。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "(*5) 軍務不適格者。",
              "citation": {
                "source": "最愛の君",
                "author": "Ｈ・ビーム・パイパー　H. Beam Piper",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
