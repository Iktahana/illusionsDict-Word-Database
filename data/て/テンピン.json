[
  {
    "uuid": "05a2b174-e6ee-538a-b6b0-04c21142f1f9",
    "entry": "天稟",
    "reading": {
      "primary": "てんぴん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
