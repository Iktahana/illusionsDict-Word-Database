    },
    "definitions": [
      {
        "index": 1,
        "gloss": "natural talents",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
