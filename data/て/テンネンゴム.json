        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "でも化学反応は絶えず起こり、ゼラチンが自然蒸発して切れるので、再充填しなければならず、その為には天然ゴム管で直接肺に送り込み、肺の表面から絶えず体内に送ることだ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "四輪馬車で、風変わりなことに天然ゴムのタイヤだ。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、指の間にハンカチを一枚持っており、ガードンには手首が柔らかくしなやかで、まるで天然ゴムのように見えた。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天然ゴムが裏当てされているでしょう。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっくり返すとポケットの天然ゴムがそっくり出てきた。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草入れの大きな袋になるし、丈夫な天然ゴムだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "真っ暗やみの中、天然ゴムの焼ける悪臭が漂った。",
              "citation": {
                "source": "見えざる力",
                "author": "THE INVISIBLE FORCE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
