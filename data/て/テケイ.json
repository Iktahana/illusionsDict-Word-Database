        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「早く天神様を描いてけいんか。",
              "citation": {
                "source": "再度生老人",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "規律とか規則とかと云うものに、私はつばきを引っかけてけいべつをしてやりたくなった。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その連中が、われわれに対してけいこくをこころみたのかな。",
              "citation": {
                "source": "三十年後の世界",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "百姓弥之助は書道の妙味はこころえて居るつもりだが筆をとってけいこした事は殆んどないから予想外出来のいいのもあるが、どうにも始末に困るのもある、然しけいこをしないだけに流儀にはまらない誰にもまねの出来ないまずさがある処が身上と云うものだ。",
              "citation": {
                "source": "百姓弥之助の話",
                "author": "第一冊　植民地の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやく、日月ボールを買ってけいこをなさい。",
              "citation": {
                "source": "日月ボール",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっちり二十四時間もかかってけいれんがやっと下火になりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和七年七月）水浴させた文晁の画絵具の使い方を知らぬ画家　日本画の彩色法も、今はだいぶ手法も違って来たが、古来本格的に濃彩を施すのは相当修練を要したもので、土佐派でも狩野派でも胡粉のとき方からしてけいこさせる。",
              "citation": {
                "source": "明治世相百話",
                "author": "山本笑月",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを日劇へ引返して午前一時から「さらば青春」の舞台けい古、一景を二度宛くり返してけい古する。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月二十三日（水曜）　医者へ寄ってけい古場へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋谷正代、東宝へ入ってからあんまり安く使はれたのでくさってけい古に出て来ない。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「丸の内オペラ」――浅井に作曲をたのんであるのに、おくれてけい古が出来ない、用なしになってしまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
