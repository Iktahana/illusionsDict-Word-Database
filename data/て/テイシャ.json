    "definitions": [
      {
        "index": 1,
        "gloss": "stopping (of a train, car, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "車が芝南寺の少し手前まで来ると、助手台に乗つてゐた谷丹三の親友が、急に停車を命じた。",
              "citation": {
                "source": "思ひ出す牧野信一",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼は沈默し、無言の中に傘をさしかけて、夜の雨中を田端の停車場まで送つてくれた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場のガードをくぐつて坂を登ると、暗い煤ぼけた古道具や、安物の足袋など店に竝べた、昔の宿場そつくりの町がある。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も、その男が私の親しい友であつたことゝ、私がその夕行かなければならなかつた停車場までの途中に、女の行く新しき男の家があつたことゝは、何かのために附けたして言つて置かう。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場はそれから近くだつたのだが、とても直ぐ電車になぞ乗る気にはなれなかつたので、ともかく私は次の駅まで、開墾されたばかりの、野の中の道を歩くことにした。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "曰く、停車場の驛札等に於て見る國府津の「かふづ」は、よろしく「こうづ」または「こーづ」とすべきである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の伊香保の第一印象は、電車の停車場附近であるが、あの辺の気分も悪くない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一、ああした山の中に、電車の停車場といふやうな者があると、その辺の空気を奇体に明るくする。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海洋博物館の前を西へ高架線に沿うて行くと停車場の前をぬけてスプレーの河岸へ出る。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の上には人が沢山停車場から凌雲閣の方を眺めている。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで朝飯かき込み岡崎氏と停車場に馳けつくれば用捨気もなき汽車進行を始めて吐き出す煙の音乗り遅れし吾等を嘲るがごとし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "多門通りより元の道に出てまた前の氷屋に一杯の玉壺を呼んで荷物を受取り停車場に行く。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "丸文へと思いしが知らぬ家も興あるべしと停車場前の丸万と云うに入る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "勘定をすませ丸く肥え太りたる脊低き女に革鞄｜提げさして停車場へ行く様、痩馬と牝豚の道行とも見るべしと可笑し。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで今朝汽車が出てしまって改札口へ引返すと同時に、なんだか気抜けがしたように、プラットフォームの踏心も軽く停車場を出ると空はよく晴れて快い日影を隠す雲もない。",
              "citation": {
                "source": "障子の落書",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日曜の午後に谷中へ行ってみると寛永寺坂に地下鉄の停車場が出来たりしてだいぶ昔と様子がちがっている。",
              "citation": {
                "source": "子規自筆の根岸地図",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の賣店には、國民新聞が、一部殘つてゐた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の待合室のベンチに腰をおろして、その新聞をひらいて見た。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼠色の印象（暴風雨前の富士山及び白峰山脈）　汽車の中は、蒸されるように混んだ、肘と肘と触れ、背と背と合された人々が、駅ごとに二、三人ずつ減る、はてはバラバラになって、最後の停車場から、大きな、粗い圏を地平線に描いて散った、そうして思い思いの方向へと往った。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上、同じ登山口でも、御殿場は停車場町であって、宿場ではない。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は昨年｜塩山の停車場で、白ペンキ塗の広告板に、一の宮郷銘酒「白嶺」と読んで、これは「雪の白酒」ではあるまいか、さぞ芳烈な味がすることであろうと思った、また他で製糸所の看板に、白嶺社とあるのを見て、この社の糸の光には、天雪の輝きがあろう、衣に織ったらばさぞ、と考えたことがある。",
              "citation": {
                "source": "雪の白峰",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場前の百貨店の食堂の窓から駿河湾の眺望と涼風を享楽しながら食事をしている市民達の顔にも非常時らしい緊張は見られなかった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場近くの神社で花崗石の石の鳥居が両方の柱とも見事に折れて、その折れ口が同じ傾斜角度を示して、同じ向きに折れていて、おまけに二つの折れ目の断面がほぼ同平面に近かった。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎も角も榛名湖畔迄上ぼつて見ようといふので、ケーブルカーの停車場のある谷底へ下りて行つた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の谷底の停車場風景は一寸面白い。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場の燻ぶつた車庫や、ペンキのはげかゝつたタンクや轉轍臺のやうなもの迄も、小春の日光と空氣の魔術にかゝつて名状の出來ない美しい色の配合を見せて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車場迄來ると汽車はいま出た計りで、次の田端停り迄は一時間も待たなければならなかつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浦和の停車場からすぐに町外れへ出て甘藷や里芋やいろいろの畑の中をぶら／＼歩いた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "崖を下りて停車場の方へ行く道傍には清らかな小流が音を立てゝ流れて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "成増で下りて停車場の近くをあてもなく歩いた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
