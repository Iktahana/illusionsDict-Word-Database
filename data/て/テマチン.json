    "definitions": [
      {
        "index": 1,
        "gloss": "payment (for labour)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
