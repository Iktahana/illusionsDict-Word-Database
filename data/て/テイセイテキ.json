          "literary": [
            {
              "text": "マルサスの人口論は、今日定性的には誰も疑うものがない。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通勘がよいとか、悪いとかいうが、それ等は全然定性的のことで、しかも主観が大いに働いている。",
              "citation": {
                "source": "勘",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い生理学では常に問題は定性的に考えられ物差しや数を使って研究されることはなく時間の単位を考慮することはなかった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラヴォアジエは酸化の実態を認識し、化学を純粋に定性的な科学から定量的な科学に上昇させた。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
