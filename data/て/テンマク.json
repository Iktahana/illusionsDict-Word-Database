    "definitions": [
      {
        "index": 1,
        "gloss": "decorative curtain hung from the ceiling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
