    "definitions": [
      {
        "index": 1,
        "gloss": "to sit on the edge of one's seat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
