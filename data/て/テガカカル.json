    "definitions": [
      {
        "index": 1,
        "gloss": "to take a lot of dealing with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "金棕櫚織の襟飾に手がかかる。",
              "citation": {
                "source": "街頭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで虎猫は急いであくびを切り上げて、机の上から手をのばして、それを取らうとしましたが、やつと手がかかるかかからないか位なので、べんたうばこは、あつちへ行つたりこつちへ寄つたり、なかなかうまくつかまりませんでした。",
              "citation": {
                "source": "猫の事務所",
                "author": "……ある小さな官衙に関する幻想……",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまで気が付けば今一足で下手人に手がかかる。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつや　自分の家じゃあ直ぐに追手がかかるのは知れている。",
              "citation": {
                "source": "影",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、ではわれ等の新手がかかるゆえ、後につづかれいッ。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿丘が呉子さんを迎えてからは、この不作法極まる訪問様式を、厳格に改めたいと思ったのではあるが、どうも習慣というのは恐ろしいもので、格子にちょいと手がかかると、僕はいつの間にやらガラガラとやってしまって、気のついたときには、茶の間の座蒲団の上にチョコナンと胡坐をかいているという有様だった。",
              "citation": {
                "source": "振動魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾久の嫂は、いつもの優しい丁寧な口調で、子供や職人達に手がかかるので、せっかく寿女を引きとっても、よく面倒みられないから残念だと言った。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "困っちゃったンだもン」「昨夜、富佐子が来て、太郎たち引取ってもらいてえと云って来たよ」「あら、そうですか……もう二ヶ月以上にもなりますからねえ……男の子は手がかかるしねえ」　与平は筍を仕入れて来たと云って、これから野菜と一緒にリヤカアで、東京の闇市へ売りに行くのだと支度をしていた。",
              "citation": {
                "source": "河沙魚",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "放すが早いか飛退って腰へ手がかかる刹那、左手に槍をすてて片手なぐりに二度目の祐定が打下す。",
              "citation": {
                "source": "鍵屋の辻",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "手がかかるといったって、家の中のことですからね、仕事は多いほど張り合いがあっていいんです。",
              "citation": {
                "source": "新妻の手記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "移動するにはいつも十人ぐらいの手がかかるんですからね。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピストルをもった怪塔王の右手に手がかかると、一本背負いなげで怪塔王の体を水車のようになげとばしました。",
              "citation": {
                "source": "怪塔王",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、期せずしてまずその長持に手がかかるや否や、傍らの水田の中へがむしゃらに抛り込んでしまい、駄賃馬に向っては、持合せの間竿で、その尻っぺたをイヤというほどひっぱたきました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体、釣の弟子には人の想像以上に、手がかかるものがある。",
              "citation": {
                "source": "弟子自慢",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただの住宅としてはもはや彼の家も広過ぎて、いたずらに修繕にのみ手がかかるところから、旧い屋敷の一部は妻籠本陣同様取り崩して桑畠にしたが、その際にも亡き父｜吉左衛門の隠居所だけはそっくり残して置いてある。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部下",
                "note": "青空文庫"
              }
            },
            {
              "text": "相馬　　学校に住んでるだけ手がかかるな。",
              "citation": {
                "source": "速水女塾",
                "author": "四幕と声のみの一場よりなる喜劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし手がかかるが、物量を節約するには、こんなこともせにゃならん。",
              "citation": {
                "source": "水鳥亭",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "金十郎はせきこんで烏丸中納言のおむすめはどうされたと、しどろもどろにたずねかけると、月の光のかからぬむこうの小暗い萱の中から声があって、「烏丸さまのおむすめは、奥州街道を行けば追手がかかる。",
              "citation": {
                "source": "奥の海",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎十郎は閉口して、「どうも、手がかかるの。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "紙凧",
                "note": "青空文庫"
              }
            },
            {
              "text": "の隙を狙ってはいりこんで来たお藤、坤竜に手がかかるが早いか、サッと袂に抱きしめてもとの裏口へ！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ざまあ見やがれ」　と、それでも早くも刀の柄に手がかかるのを、栄三郎はしずかに押しとどめて、「待たれい、丹下！",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "みっし、みっしとうしろに板敷きがきしんで、今手がかかる！",
              "citation": {
                "source": "つづれ烏羽玉",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "――と二、三歩、歩を返して障子に手がかかる。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "客が十人も来れば台所の方では相当に手がかかる。",
              "citation": {
                "source": "漱石の人物",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "追手がかかるくらいだから国境の哨所には、もう電話がいってることでしょうし、行けば、捕まるにきまってるでしょう。",
              "citation": {
                "source": "墓地展望亭",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "この実験はらくでしたが、つぎの実験は手がかかる。",
              "citation": {
                "source": "オスカー・ブロズキー事件",
                "author": "THE CASE OF OSCAR BRODSKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "判ったでしょうネ、左様なら」　先刻深山茂がやったように、窓ワクに手がかかると、身体を浮かしてスーッと下へ。",
              "citation": {
                "source": "判官三郎の正体",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手がかかるのはここまでで、あとはみんなこの機械がひとりでにやってくれます。",
              "citation": {
                "source": "処刑の話",
                "author": "IN DER STRAFKOLONIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は倒れて居るボーシュレーの傍へ走って、その傷口から出る血を、自分の手や顔に塗り付け、ジルベールに手がかかるや否やいきなり物をも云わず投げ倒した。",
              "citation": {
                "source": "水晶の栓",
                "author": "モウリス・ルブラン",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
