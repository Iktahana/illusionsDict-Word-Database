    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to withdraw from (a deal)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "喧嘩を慰みと思っている軍人党と、一生懸命の弱虫との挌闘にはたいてい利口な軍人の方が手を引く。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに妾は女でございますから、お話しがむつかしくなりますと手を引くより外に道がございません。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "具体案ができ上がったら、私は全然この農場から手を引くことにします。",
              "citation": {
                "source": "小作人への告別",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれ有志の一人と、仮装なかまで四五人も誘ったが、ちょっと手を引張っても、いやその手を引くのが不気味なほど、正のものの身投げ按摩で、びくとも動かないでいる。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（と胸に手を当て、おそうとして、火に触れたるがごとく、ツト手を引く）死ぬ気になって、と聞いたばかりで、動悸はどうだ、震えている。",
              "citation": {
                "source": "湯島の境内",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "吃驚して按摩が手を引く、その嘴や鮹に似たり。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "○八月、松竹会社が歌舞伎座を買収せんとし、同座一部の役員間に紛糾を生じたるが、結局松竹が手を引くことになりて和解す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と立ったまま手を引くように致しましたが、いつの間にやら私の体は、あの壁を抜けて戸外へ出まして、見覚のある裏山の方へ、冷たい草原の上を、貴方、跣足ですたすた参るんでございます。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、もう、こうなった以上は、僕も手を引くのをいさぎよしとしない。",
              "citation": {
                "source": "耽溺",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おどろいて手を引くと、ずっと前にも前にも赤い花が一ぱいにつらなって咲いている。",
              "citation": {
                "source": "咲いてゆく花",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉に近い健策が大急ぎで把手を引くと扉の外の暗いリノリウムの床に、白い服を着た品夫が横たわっていた。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくともアメリカがベトナムから手を引く奇跡よりは、東大解体は現実味を帯びて見えた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分も好んでこんな事に係り合いたくは無いのであるから、お前の主人がいつまでも渋っているようならば、自分はもう手を引くのほかは無いと、彼は云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ無にして、変な小細工をするなら、おれはもう手を引くからそう思ってくれ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "正雪の絵馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは嫌な心持が致しましたが、あんな立派な先生のなさる事ではございまするし、娘子供か何かのやうに、慌てて手を引くのもいかがと存じますので、どう致さうかと存じてゐましたのでございます。",
              "citation": {
                "source": "魔睡",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲裁の人達が手を引くころになると、いつも二人は何方からか寄つて来て、そしてまた一緒になつた。",
              "citation": {
                "source": "迅雷",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "木村はそのくらいな事で葉子から手を引くようなはきはきした気象の男ではない。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を引くばかりでなく反感を持つようになる。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガスコアン大尉は、この日も最初はいい加減なところで体よく手を引くところであったが、問題が自分たちに本質的に関係しているので、ついつい深入りをしてしまったのである。",
              "citation": {
                "source": "ゼラール中尉",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "――騒ぎもまたぴたりと静まって、押えつけていた近侍の面々が手を引くと同時に、はじめて直訴人の姿が雪の中から現われました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには自分の前の十七｜憧を、皆がとりやすいように斜めにしてすこし前へ出してやるとみせかけ、例えば右手の中に、不用の持牌二個を隠し持ち、前へ押すときにそれを十七憧の右端へ加え、前へ押して手を引くとき、左手の中に左端の二枚を隠し取って手牌の中に入れてしまう。",
              "citation": {
                "source": "麻雀インチキ物語",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うわっ」青二は、いそいで手を引くと、その場にとびあがった。",
              "citation": {
                "source": "透明猫",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "よもやとは思うものの、仲裁人らもなんだか薄気味悪くなって、そのままに手を引くことも出来なくなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と、手を引く許りにする。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を引く許りにする。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "このような部分、あるいは場合に関しては監督は一応手を引くべきであろう。",
              "citation": {
                "source": "カメラに関する覚え書",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここらで映画の前途に見きわめをつけて、そろそろ手を引く事業家が出てくるかもしれぬが、もしそんなことがあつても、このような多難な時期に映画を見捨てる人に対して、五十万円だの百万円だのという退職手当は出さないでもらいたい。",
              "citation": {
                "source": "思い",
                "author": "――情報局の映画新体制案について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学に縁遠い人間に、三角形に対する恐怖を抱かせることの出来た私は、もうそれで所信の点を充分確かめ得たわけですから、此所で手を引くのが当り前でした。",
              "citation": {
                "source": "三角形の恐怖",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "急いで手を引く拍子だったので、案外強い力だったのだろう。",
              "citation": {
                "source": "双面獣",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "自殺に相違ない、とあって警察も型通り前後の模様を聴取しただけで、手を引く。",
              "citation": {
                "source": "ロウモン街の自殺ホテル",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
