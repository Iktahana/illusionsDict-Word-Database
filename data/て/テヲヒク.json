[
  {
    "uuid": "8eaa8253-f509-592a-b333-bd8eb28c2a1b",
    "entry": "手を引く",
    "reading": {
      "primary": "てをひく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
      ],
