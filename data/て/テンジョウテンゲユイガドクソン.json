    "definitions": [
      {
        "index": 1,
        "gloss": "throughout heaven and earth, I alone am the honored one",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
