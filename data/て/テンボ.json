    "definitions": [
      {
        "index": 1,
        "gloss": "visiting a grave",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　その母親の展墓である。",
              "citation": {
                "source": "縷紅新草",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は久振で展墓の為帰省した。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "山陽は展墓のために竹原に往つて、帰途に廉塾を過つたのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "九月平八郎名古屋の宗家を訪ひ、展墓す。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "展墓の詩中わたくしは枕山の伝をつくる資料となるべき句のみを挙げる。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "『枕山詩鈔』に「先妣一七日忌辰展墓途上。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "」〔先妣一七日忌辰展墓ノ途上〕と題して、「野逕蕭条蛩語哀。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "先祖の墓所が山口にあつて、父は明治の人として、外地への赴任の途次かならずや展墓を忘れなかつただらうからである。",
              "citation": {
                "source": "少年",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾来、それで郷里に帰省したのは、小学校の頃、夏休みに一回、実父の葬式に一回、徴兵検査に一回、ずっと後に展墓に一回、合計四回しかない。",
              "citation": {
                "source": "丹波篠山",
                "author": "平野零児",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度の帰国は展墓が目的だが、亡友の意志を継いで水上氏の孫娘の諸権利を確立したいためでもあると結んであった。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "その展墓を最後として、駒井は老婆と共に墓地の中を出ることにしました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白骨の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖先の展墓のためだった。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "祖先の展墓を兼ねて、自分の出世を報告するために、――故郷は岩手県のどこかで、汽車をおりてからバスで半日ほどゆき、それから歩いて何里とかの山を越す、といったような寒村であった。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年まえ藩侯の側近へあげられて、江戸、国許ともお側去らずだったが、そのとき展墓のため（理由はほかにあった）帰国したといい、兄の和兵衛を訪ねて来たついでに、出三郎の住居をのぞいたのである。",
              "citation": {
                "source": "艶書",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ月の六日は亡父の忌日に当るので、藩にいる亡父の門下の青年十七人が来て展墓をし、別棟になっている塾で半日ほど、旧師の追憶など語りあうのが例になっている。",
              "citation": {
                "source": "菊屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あとで思い当ったことだが、帰国するとすぐ菩提所の大竜寺へ展墓をし、それから間をおいてしばしば寺を訪ねた。",
              "citation": {
                "source": "桑の木物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　寛文十年十月、伊予国宇和島の領地へ、藩主として初めて国入をした伊達大膳太夫宗利は、亡父秀宗の展墓を済ませるとすぐその翌日、鶴島城で家臣たちの引見を行った。",
              "citation": {
                "source": "松風の門",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大弐は展墓のため、甲斐の国｜巨摩郡篠原村の故郷へ帰るのだった。",
              "citation": {
                "source": "夜明けの辻",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "有望なら展墓に行く」　ということになった。",
              "citation": {
                "source": "村の成功者",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所領地の不破へ帰り着くと、半兵衛重治は、その一日を祖先の展墓にすごし、また一｜刻を、菩提山に佇んで、「あの山も、この河も」　と、なつかしげに故郷の天地と語っていた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "展墓者名簿を一眄すると、ただに剣道家ばかりでなく、遠くは布哇、朝鮮、満州などの居住者が見えるし、中でも私が目を止めたのは、岡山県英田郡讃甘村宮本　平尾泰助　とある一名の参詣者だった。",
              "citation": {
                "source": "随筆　宮本武蔵",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、その時の大火傷、享年六十有七歳にして、生まれもつかぬ不具もの――渾名を、てんぼう蟹の宰八と云う、秋谷在の名物｜親仁。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "爺どのは、どっこいしょ、と横木に肩を入れ直いて、てんぼうの片手押しは、胸が力でござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『読売新聞』に、この一月座談会記事が連載されていた間の或る日「てんぼうだい」に一読者よりとしての投書でのせられていた。",
              "citation": {
                "source": "文学における今日の日本的なるもの",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、この名誉のてんぼのお蔭で、弁護士がしきりにそれを力説しましてね、お蔭で二カ年間の執行猶予になりましたよ。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんぼうが一人だけ残っている。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "と云うのはそうやって働いている、大勢の人間の一人一人が、片耳であったり片足であったり、てんぼうであったり盲目であったり、唖者であったり聾者であったり、満足な人間はないからであった。",
              "citation": {
                "source": "神秘昆虫館",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "都合によってはじぶんでじぶんの片手片脚を斬り捨て、てんぼうに化けたり、いざりに化けたりするようなことさえするんです。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "捨公方",
                "note": "青空文庫"
              }
            },
            {
              "text": "親のほうはいざりでてんぼう。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "野伏大名",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つ変っているのは、この主人がてんぼうであったことだけであります。",
              "citation": {
                "source": "大菩薩峠",
                "author": "市中騒動の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
