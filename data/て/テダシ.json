    "definitions": [
      {
        "index": 1,
        "gloss": "meddling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "プロレタリアの国に喰い下ろうとするブルジョアどもも何も手出しができやしなかったのだ！",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お孝に手出しが出来なかったら、せめて私を殺す、私を狙う計画を立ててくれ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰某は屁玉を喰って凹んだと大きに笑われたそうで、もう懲々して、誰も手出しは致しません、何と、短銃では、岩見重太郎宮本の武蔵でも叶いますまい。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家来は大勢居ましたけれど、誰も手出しが出来ないんですって。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、父も考えて、「今も云うような訳で、此方では誰も手出しを為ないから、対手の方でも別に悪い事は為ないらしい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、正面から手出しは出来ないのであるが、さりとて此の儘おめおめと別れてしまうのも何だか残念である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "不断臆病であつた私がそんな大胆な手出しをしたのはよく／＼の事であつた。",
              "citation": {
                "source": "小学生のとき与へられた教訓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "又たとへ将門の方から手出しをしたにせよ、恋の叶はぬ忌※しさから、其女の家をはじめ、其姉妹の夫たちの家まで、撫斬りにしようといふのも何となく奇異に過ぎ酷毒に過ぎる。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "これだけの大事になつたのであるから、四方隣国も皆手出しこそせざれ、目を側だてゝ注意したに相違ない。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻以外の女に手出しが出来ることを知ってからも久しくなる。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "帯も〆めで、懐中より片手出して火鉢に翳し、烈々たる炭火｜堆きに酒の燗して、片手に鼓の皮乾かしなどしたる、今も目に見ゆる。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで神八井耳命は刀を持ってお出かけになりましたが、いざとなるとぶるぶるふるえ出して、どうしても手出しをなさることができませんでした。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手出しをしてみろ！",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "事はここまで上々なのだから、そのまま逮捕に向かう限りは僕の手出しなしでもうまく運んでゆくのだが、さすがに有罪に持ち込む段には僕の存在が必須だ。",
              "citation": {
                "source": "最後の事件",
                "author": "THE FINAL PROBLEM",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は沢山集まっているけれども、かんじんの家のものが皆殺されてしまったので、どうするにも手出しが出来ない。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾分のろまなような亭主は、馬をつれて四五里もある村へ出かけて、馬を交換してみたり、一寸した土地の売買に手出しをしたりして居たが、今度も家の方は嫁さんと老人にまかしたきり、天塩の海岸の方に何の目的もなく出かけて行って、まだ手紙の一本もよこさない。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "わっしはあの虫に手出ししたかあごぜえません、――ご自分で取りにいらっせえ」そこでルグランは真面目な重々しい様子で立ち上がり、甲虫の入れてあるガラス箱からそれを持ってきてくれた。",
              "citation": {
                "source": "黄金虫",
                "author": "THE GOLD-BUG",
                "note": "青空文庫"
              }
            },
            {
              "text": "やとい女もさしずがなければ手出しのしようもない。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして又暫く間を措いて「畜生つちはれんの口惜しけりや、口惜しいちつて見た方がえゝ、原因はつちへば己奴が手出しすんのが惡りいんだから」と低く然も鋭く彼は呟いて、芒で裂いたやうに口をぎつと閉ぢて畢つた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "口が利けたら相應に騷がれたんだらうな」「氣味が惡いから手出しはしませんね。",
              "citation": {
                "source": "おふさ",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "討手でないのに、阿部が屋敷に入り込んで手出しをすることは厳禁であるが、落人は勝手に討ち取れというのが二つであった。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "御沙汰には火の用心をせい、手出しをするなと言ってあるが、武士たるものがこの場合に懐手をして見ていられたものではない。",
              "citation": {
                "source": "阿部一族",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを怺へてお前を人に奪れるのを手出しも為ずに見てゐる僕の心地は、どんなだと思ふ、どんなだと思ふよ！",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "股肱と恃み、我子とも思へる貫一の遭難を、主人はなかなかその身に受けし闇打のやうに覚えて、無念の止み難く、かばかりの事に屈する鰐淵ならぬ令見の為に、彼が入院中を目覚くも厚く賄ひて、再び手出しもならざらんやう、陰ながら卑怯者の息の根を遏めんと、気も狂く力を竭せり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほ露國が滿洲を占領せしを見ても、清國、韓國などが何等の手出しをも爲す能はざりしが如し。",
              "citation": {
                "source": "猫征伐",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応はそれとなく次郎左衛門に訊いて見て、とても出来そうもないことならば、その儘に聞き流してしまうもよし、又どうにか手出しのできそうな話であったら、改めて自分の考えも言い、旦那の料簡も訊いて見ようと、彼は亭主と相談して別れた。",
              "citation": {
                "source": "籠釣瓶",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家の見る前では、何者もさすがに手出しはあるまいぞ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまたま葉子の姉妹の内実を知って気の毒だと思っても、葉子ではというように手出しを控えるものばかりだった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "擲るんならいくらでも勝手にお擲り、俺は決して手出しはしないから落着いてやつたらいゝだらう……だが、可愛想にお前もまるで狂ひだね。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "染之助の方でも、私が彼の言伝をきっぱりと断ってから、私の心が測りかねたものと見えて、もう少しも手出しをすることはありませんでした。",
              "citation": {
                "source": "ある恋の話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
