        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔郡属伊原忠右エ門〕宮沢賢治郡属伊原忠右エ門科頭にゴムの靴はきて冬の芝生をうちよぎり南ちゞれし綿雲に雨量計をぞさゝげたる天狗巣病にはあらねどもあまりにしげきこずゑかな",
              "citation": {
                "source": "〔郡属伊原忠右エ門〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとへば西洋の惡魔が、日本では鬼や天狗の類となるし、昔の童話に出る武者修業の豪傑が、今日の新しい童話では、飛行機に乘つて機關銃を撃つたりするところの、科學的武裝をした日の丸太郎の類に變るのである。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北山の法経堂に現れる怪火の話とか、荒倉山の狸が三つ目入道に化けたのを武士が退治した話とか、「しばてん」（木の葉天狗）と相撲を取る話。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "神社の庭には天狗がおもちゃにするというまさかり、かま、太刀などが、散乱している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍馬山で牛若丸が天狗と劒術をやつて居るのがあつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな天狗のやうでもある。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "亭主が、Ｔ「天狗様が　お出ましに　なります」　団九郎が驚いた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎尚も亭主に、Ｔ「烏天狗　二十や三十」　鼻へし折って、と手振り身振りで威張り出す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と口々に、Ｔ「天狗様の　お怒りが　怖しいぞ！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹が涙で眼を光らして、Ｔ「隣り村へお嫁に　行くぐらいなら」　と言って、Ｔ「いっそ天狗様に　喰われて　死んだ方が倖せです」　と言う。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいえとお絹が、Ｔ「天狗様の御祟りが　怖しうて……」　困ったなァと六助。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "と杉木立の真黒な処から、　ニューと天狗が現れた。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "葛籠の傍へ寄って人影なしと見て天狗の面を取って辻堂の縁に置く。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻堂の中から手が出て、縁に置かれた天狗の面をそッと掴んだ。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「こーら」　タハッと驚く山賊が振り返ると、　真黒な辻堂の中に天狗の顔が物凄く光って居る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "辻堂の天狗が（団九郎）、Ｔ「吾こそは　此の仙境に　棲む天狗なり」　そら出たと山賊達、腰を抜かす。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "団九郎の天狗は悠々と現れ出て、Ｔ「我名を騙る　憎い人間ども」　山賊達、震え上る。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が団九郎、調子に乗って首を振って居た時、　天狗の面が落ちる。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗退治の大勇士とあって団九郎は得意満面で盃を重ねている。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵はさて一同の者に、　天狗退治の有様を話す。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し大時代に天狗退治をやって下さい）　遂に天狗を叩き斬ると、　苦しみもがく天狗。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中に舞い上り、　杉の梢に飛び付いた天狗。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "天狗、空中より、Ｔ「やれッ　宮本武蔵　よく聞け！",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中の天狗、Ｔ「汝が非凡の働きにより　我は鞍馬山に退散せん」　と叫んで、Ｔ「そも、そも、我は　巳年生れの天狗なり」　と言って、Ｔ「されば、その娘を　巳年の男に与うべし」　何と？",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "空中の天狗が、Ｔ「巳年の男に　与うべし」　ドロンドロンドロンで空中遙かに飛び去ったり。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "武蔵が、Ｔ「天狗の祟りが　怖ろしう御座るぞ」　ハテ困った、と庄屋。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくつもの峠を越えて海藻の〔数文字空白〕を着せた馬に運ばれて来たてんぐさも四角に切られて朧ろにひかった。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "安珍清姫恨みの恋路、坂田の金時｜女夫の相撲、牛若丸はてんぐのあしらい、踊れといえば、そら、あのとおり、――牛若丸はてんぐの踊りとござい」　いいながらむちでたたくまねをすると、いかさま二匹のくまはのっそりのっそりと立ち上がって、いとも器用に鞍馬山の牛若丸を思わすような剣術の型を使いました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "耳のない浪人",
                "note": "青空文庫"
              }
            },
            {
              "text": "こっちへおいでなせえよ」　しかし、名人は何か思うところがあるとみえて、相手にもせず河岸っぷちのそのお湯屋の、てんぐぶろと染めぬいたのれんをさっとくぐりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "てんぐぶろとはいかさま鼻を高くするだけあって、じつになんとも焼けただれそうな熱湯でした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
