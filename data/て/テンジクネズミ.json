          "literary": [
            {
              "text": "ある人が天竺鼠について試験したところによれば、たとえ健全なのと病にかかっているのとを接近させぬようにしておいても蚤が移ると感染する。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "『彼女はこのモンテ・カアロのばくちにかけてはじつに天竺鼠のように上手に立ち廻るのです。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎や天竺鼠をみてごらん。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれのどこがえらいんだい」「天竺鼠とお前とは別だよ」　兄貴のフェリックスがいう。",
              "citation": {
                "source": "にんじん",
                "author": "POIL DE CAROTTE",
                "note": "青空文庫"
              }
            },
            {
              "text": "また養兎場に天竺鼠を置いてそのにおいで野鼠の来るのを防がした。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
