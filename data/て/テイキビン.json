        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "サウス・ステーションからバッテリー街行きの定期便が出ているから、そこから歩けばすぐだ。",
              "citation": {
                "source": "ピックマンのモデル",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "定期便をさけたわけでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手はやはり既知の、定期便の、完全な一人の他人としての女だった。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天候とは逆に重たるくすっきりとしない日が、また同じような日につづいて、私は下宿での自分、女という定期便の先週の欠航にいろいろと気をまわしたり、心を向けたりする余裕もなかった。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女がホノルルから乗ってくるアロハ・エアラインの定期便は、午後の一時二十八分に、この島の空港に到着する予定だ。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "降りてくるその定期便を、やや斜めにそれた正面から、ぼくは双眼鏡の視界のなかに見ることが出来た。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくが乗った定期便は、定刻にヒロ空港を離陸した。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "アロハ・エアラインの定期便が、時間どおり滑走路に降りた。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "客車も購入し、旅客列車の定期便もあった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
