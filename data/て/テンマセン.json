    "definitions": [
      {
        "index": 1,
        "gloss": "large sculling boat",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私はその小女から、帆柱を横たえた和船型の大きな船を五大力ということだの、木履のように膨れて黒いのは達磨ぶねということだの、伝馬船と荷足り船の区別をも教えて貰った。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し離れて団平船と、伝馬船三｜艘とが井桁に歩び板を渡して、水上に高低の雪渓を慥えて蹲っている。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "左隣の船は運送会社のマークの付いた高提灯を立て、紅白の幕で飾った会社の社員や関係者の家族の乗込んだ伝馬船で、シャツの上衣の良人が舷からガーゼの簡単着を着たこどもにおしっこをさせていますと、その妻は「酔ってるから、あなた、坊や落っことしちゃいけませんよ」と後から危がっています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝馬船なら漸く二艘だけすり違えられる枝川であります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "八丁堀の伝六親方を知らねえかッ」　まことに伝六の名声広大とも広大――といいたいが、実は八丁堀といった啖呵がものをいったとみえまして、通りすがりの伝馬船が倉皇としながら舳先を岸へ向けましたので、ふたりはひらりと便乗――まだ混乱のままでいる現場へこがしていってみると、しかるにこれがすこぶる奇態です。",
              "citation": {
                "source": "右門捕物帖",
                "author": "へび使い小町",
                "note": "青空文庫"
              }
            },
            {
              "text": "なによりも縁起をかつぐ荷足り舟や伝馬船が、縁起でもない死体をのせたり運んだりするはずはないのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「元気のいい船頭をふたりほど雇うてな、舟足の軽い伝馬船を一艘用意してくれませんかな。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そっちにすわっているおこり虫は左がいけるほうじゃから、それも二、三本忘れずに用意しておいてくださいましよ」　舟遊山ならば屋台船にしそうなものであるが、どうしたことか伝馬船を雇って用意万端の整うのを待ちうけながら、さっさと乗りうつりました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "足のある幽霊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、波止場の伝馬船が叩き起されて、片ッ端から虱潰しに調べられた。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "齎らされた幾つかの報告を組合して、小森安吉を殺した釧路丸の船長は、海員合宿所から一人の砲手を雇うと、早くも自船の伝馬船に乗って、沖合に待たしてあった釧路丸へ引挙げたことが判って来た。",
              "citation": {
                "source": "動かぬ鯨群",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "褐色の破れた帆をあげた伝馬船が、港の方から、次ぎ次ぎに登って来た。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "密輸入の伝馬船が真黒な帆を上げながら、並んだ倉庫の間から脱け出て来ると、魔のようにあたりいっぱいを暗くしてじりじり静に上っていった。",
              "citation": {
                "source": "上海",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "上げ潮につれて灰色の帆を半ば張った伝馬船が一｜艘、二艘とまれに川を上って来るが、どの船もひっそりと静まって、舵を執る人の有無さえもわからない。",
              "citation": {
                "source": "大川の水",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "沖漁に行く船は皆陸へ引き揚げてあるが、小伝馬船は皆舳を揃へて繋いであつた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "港には古風な伝馬船が密集している。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今日はひとつ、伝馬船で投網に案内すべえと思ってるが、旦那……。",
              "citation": {
                "source": "初秋海浜記",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処が宜かろう、罷り違ていよ／＼ドン／″＼遣るようにならば、此処へ逃げて来よう、けれども表から行かれない、行かれないから海岸から行くより外ないと云うので、いよ／＼セッパ詰たその時に、私は伝馬船を五、六日の間｜雇て、新銭座の浜辺に繋いで置たことがある。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅田川の濁流、ポンポン蒸汽、伝馬船、モオタアボオト等に囲まれ、せせこましい練習をしていた、ぼく達にとって、文字どおり、ドリイミング・コオスといった感じです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝靄を、微風が吹いて、さざら波のたった海面、くすんだ緑色の島々、玩具のような白帆、伝馬船、久し振りにみる故国日本の姿は綺麗だった。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "ボートは長さ四メートルばかりの伝馬船で、帆柱は根元から折れ、右舷はひどく破れていた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪漢どもはあわてふためいて、伝馬船をおろした。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "ケートとイバンスはそのすきに、伝馬船へ乗り移った。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「清い水は飲みほうだい、ぴちぴちした魚はたくさんとれる、ぼくらはここに住まいを定めることにした、伝馬船は浜辺づたいにひいてきて、川口につないだ。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにかれらの伝馬船がなかったらわれわれはどうして島をのがれるつもりか」　イバンスの最後の一語をきいた少年たちは、疑惑を感じた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたしたちが伝馬船を手に入れてこの島を出るとしても、どの方向にすすみますか」　とゴルドンは問うた。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかれらが帰国の便宜をうるためには、まず海蛇らの持っている、伝馬船をうばわねばならぬ、それには一戦はまぬがれないのである。",
              "citation": {
                "source": "少年連盟",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
