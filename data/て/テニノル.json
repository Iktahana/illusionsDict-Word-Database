        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「いくら俺をだまそうとしたって、もうその手に乗るものかい、この妖怪」　許宣の後からやって来た王主人は、許宣が門前でやかましく云っていて人に聞かれても面白くないと思ったので、その傍へ往った。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いくら俺をだまそうとしたって、もうその手に乗るものかい、この妖怪」　許宣の後から出てきた王主人は、許宣に門前でやかましく言われては、隣家へつけてもていさいがわるいので、その傍へ往って言った。",
              "citation": {
                "source": "雷峯塔物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今更こんな手に乗るものかと思った。",
              "citation": {
                "source": "青木の出京",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりでのこっても、つまらないわ」　おまえはその手に乗るのか、という顔で、高志が慶一をにらみつける。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手に乗るもんか」　女は女体を振っておおげさに笑った。",
              "citation": {
                "source": "雪の夜",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘンべら棒、その手に乗るか、コウこの辺の地廻りはな、雑種とは違う江戸ッ子だ。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その手に乗るか、ばかな面め。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生の気持はよく解るけれど、ジャアナリストの手に乗るということがありますかよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "（独語）誰がその手に乗るもんか。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本全国に会員三万人、後藤大臣並びに夫人（象次郎伯）の尊敬｜一方でないという先生も、女史を知ることが出来ず、そんな甘い手に乗ると思ったのは彼れが一代の失策であったであろう。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この根岸がそんな甘手に乗ると思うか。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな手に乗るものか」「いや本当だ、そんな者ではない。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふふん、そうよなあ、こっちかも知れねえ」「へん、その手に乗るものか。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん畜生、だれが其手に乗るものか」　翌日おれは学校へ出て校長室へ入つて談判を始めた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "こん畜生、だれがその手に乗るものか」　翌日おれは学校へ出て校長室へ入って談判を始めた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "うっかりその手に乗るやつが大莫迦さ」　と、一笑に附した。",
              "citation": {
                "source": "時限爆弾奇譚",
                "author": "――金博士シリーズ・８――",
                "note": "青空文庫"
              }
            },
            {
              "text": "君はなかなか芝居がうまいようだが、その手に乗るようなわれわれでないぞ」　と、大江山は一喝をくらわせた。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手が小心であり、卑屈であれば文句なくこの手に乗る。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘　　きいたつて、そんな手に乗るバカはないのよ。",
              "citation": {
                "source": "女人渇仰",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "フフン、その手に乗るものか）　こう思ったからである。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな古手に乗るものか！",
              "citation": {
                "source": "銀三十枚",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手に乗るか、途方もねえ、こう見えても裏切りはしねえ、五両ばかりのハシタ金で、山塞を明かしてたまるものか」「プックリ懐中が膨らんでいらあ、三十や五十は持ってるらしい。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手に乗るか、馬鹿な奴め！",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「先生にかわって御成敗いたすところだが、まずまず堪忍……丹波とはちがい、さような手に乗る源三郎ではござらぬ」　お蓮様は、壁にはりついて、あっけにとられた顔で、源三郎をみつめている。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その動きのすきをねらって、一団となっておどりこもうという寸法なんですが、ドッコイ、そんな月並みな手に乗る源三郎じゃアありません。",
              "citation": {
                "source": "丹下左膳",
                "author": "こけ猿の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウフフ、誰がその手に乗るものか。",
              "citation": {
                "source": "魔像",
                "author": "新版大岡政談",
                "note": "青空文庫"
              }
            },
            {
              "text": "うふっ、尼にでもなるというつもりだろうが、その手に乗るおれじゃあねえんだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の手に乗るのは何よりも業腹でした。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋの来ないうちは、他の手に乗るのが厭だという我慢が私を抑え付けて、一歩も動けないようにしていました。",
              "citation": {
                "source": "こころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな煽てにのるやうな連中ぢやないよ」　富田の仲買は表向きの商売ではなかつた。",
              "citation": {
                "source": "医師高間房一氏",
                "author": "田畑修一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
