    "definitions": [
      {
        "index": 1,
        "gloss": "wear from frequent handling",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
