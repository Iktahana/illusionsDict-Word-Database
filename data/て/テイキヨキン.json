        "examples": {
          "standard": [
            {
              "text": "将来のために、毎月少しずつ定期預金に貯金している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "定期預金は、普通預金よりも金利が高いのが一般的だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「まとまったお金ができたので、定期預金に回そう」と妻が言った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "その日暮しの生活知識の奥に、永遠に利息が産み出せる定期預金のような知識を積みたい。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の定期預金を擔保にして、非常に高利の金を借りるようなものである。",
              "citation": {
                "source": "革命を待つ心",
                "author": "――今の實業家、昔の實業家――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
