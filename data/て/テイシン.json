    "reading": {
      "primary": "ていしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "going ahead of the others",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "午後になって抜刀隊の巡査五十名を間道から進ませ、歩兵また、装剣して待機し、喇叭を合図に、全軍一斉に挺進して数十人を斬り、砲塁全部を恢復し得た。",
              "citation": {
                "source": "田原坂合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいか、さあ喋るぞ”　とモグラ下士は、大きな咳ばらいをして、“挺進Ｚ百十八歩兵中隊報告！",
              "citation": {
                "source": "二、〇〇〇年戦争",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、この子はあの三月十日の東京大空襲のさい、女學校から女子挺進隊にとられてゐて私のそばにも居られませんで、つひに戰災のもとに死なせてしまひました。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病者の二人ではとうていしんぼうしきれないのでしょう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
