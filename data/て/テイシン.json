[
  {
    "uuid": "7bd0be31-a98c-5877-8198-6b10d3a029cb",
    "entry": "廷臣",
    "reading": {
      "primary": "ていしん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "courtier",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "其著者を誰とかする、即ち當時廷臣とし、軍人とし、政治家として夙に盛名あるも、未だ文筆の人としては左までに顯はれざりしラロシフコー公爵其人なりとす。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」いかにも、「廷臣とし、軍人とし、政治家として夙に盛名ある」ラロシフコー公爵その人の息吹が感ぜられる尊嚴盛大の文章である。",
              "citation": {
                "source": "ラロシフコー",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "プノンペンの街、タマリンドの街路樹、メコン河の流れ、シソワット王の城内、彼方には椰子の林があり、赫熱とした熱帯の強烈な太陽の直射と、熱風を避けた王城内でノラの母はシソワット王と廷臣の居並ぶ玉座のまえで、オーケストラと数十人の唄い手の歌声のなかで華麗な彼女はカンボジヤの踊りを舞うのだった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "燕軍の再敗せること京師に聞えければ、廷臣の中に、燕今は且に北に還るべし、京師空虚なり、良将無かるべからず、と曰う者ありて、朝議｜徐輝祖を召還したもう。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "太祖崩じ、皇太孫立つに至って、廷臣｜交々孝孺を薦む。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はまた廷臣としての、また大胆な陰謀家としての彼をも知っていた。",
              "citation": {
                "source": "盗まれた手紙",
                "author": "THE PURLOINED LETTER",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷臣たちが我も我もと随行を望んだ。",
              "citation": {
                "source": "源氏物語",
                "author": "澪標",
                "note": "青空文庫"
              }
            },
            {
              "text": "源氏は一廷臣として太政大臣に続いてまた女院のすでに危篤状態になっておいでになることは歎かわしいとしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "薄雲",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる廷臣が今日はここへ来ることかと思われる列席者の派手に並んだ所へ、人の介添えを受けながらはいって来た若君は、大学生の仲間とは見ることもできないような品のよい美しい顔をしていた。",
              "citation": {
                "source": "源氏物語",
                "author": "乙女",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷臣の膝を走れば平身低頭の夢となり、代言人の指を走れば忽ち謝金の夢となり、美人の唇を走れば忽ち接吻の夢となる。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひはまた廷臣の鼻の上を走る、と叙任を嗅出す夢を見る、或ひは獻納豚の尻尾の毛で牧師の鼻を擽ると、僧め、寺領が殖えたと見る。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷臣たちも同じくほほ笑んだ。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "喃、これ、」と女帝は、他の廷臣たちより少し離れて立つてゐた、＊でつぷりして、すこし蒼白めた顔の人物に眼を注ぎながら、言葉をつづけられた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人物は、身にまとつた真珠の釦のついた質素なカフターンから推して、明らかに廷臣ではなかつた。",
              "citation": {
                "source": "ディカーニカ近郷夜話　後篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷臣カオの家に、タン、カン、と云ふ二人の兄弟があつた。",
              "citation": {
                "source": "浮雲",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "君長賢明ならざるにあらず、廷臣方正ならざるにあらず。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねえ田郷さん、確かこれだけは、風精が演じたうちで、一番下手な廷臣喜劇でしたね」　法水が語り終えると、検事は冷たくなった手の甲を擦りながら、歩み寄って云った。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日のこと、プロスペエル・メリメが出題者になつて、有名な「アカデミイの書取」をやることになり、競技者を募つたところ、出題者が出題者だけに、多くの廷臣たちは、いろいろ口実を設けて、尻ごみをするばかりだつた。",
              "citation": {
                "source": "アカデミイの書取",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "◎「私がばかなばかりに廷臣らしい廷臣にも恋するだけの魂があるものとばかり信じていたのだ」職業はそうです、立場はそうです p. 65、しかし人間として云々という人へのよい教訓。",
              "citation": {
                "source": "日記",
                "author": "一九四七年（昭和二十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに武士や、僧正や、廷臣や、政治家たちが「闇の床」に臥して朽ちつつあるのだ。",
              "citation": {
                "source": "ウェストミンスター寺院",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう芝居どころでなく、王も妃も廷臣もいっしょになって上手へ駆けだし、幕のうしろへ入ってみますと、小松は四十尺も下の玄関のそばにうつ伏せになり、頭のまわりの敷石に真赤な血潮が磯ぎんちゃくでもうちつけたようにどろりとねばりついていました。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日から廷臣またはローゼンクランツとして近侍の生活がはじまりました。",
              "citation": {
                "source": "ハムレット",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "露台が一杯に見える一段高くなった所には、半円形にずらりと列んだ、悪い顧問官達や、おべっか使いの廷臣達にかこまれて、えらいポリデクティーズ王が着座していました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "王様や顧問官や廷臣や人民は、みんな熱心にパーシウスの方を見つめていました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "廷臣達は一斉に、パーシウスが彼等の王様であり主君である陛下に対して不敬を敢てしたと呟きました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "海岸では、皇帝も廷臣も、みんなが、私の戻って来るのを、今か／＼と待っていました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "三日目の朝、十一時頃、国王は自ら貴族、廷臣、役人どもを従えられ、それ／″＼楽器の調子をとゝのえると、それから三時間、休みなしに演奏されました。",
              "citation": {
                "source": "ガリバー旅行記",
                "author": "GULLIVER'S TRAVELS",
                "note": "青空文庫"
              }
            },
            {
              "text": "武鑑で大名は壱岐守、伊賀守、周防守であったものが、ここではすべて正二位から従五位にいたる廷臣としての序列でならんでいる。",
              "citation": {
                "source": "武鑑譜",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "世故に長けた才物で、腹をたち割ればなかなかの陰謀家でもある彼は、色ごのみにかけても決して他の廷臣たちに引けをとらないのだが、さすがにこればかりは、どうにもならなかつた。",
              "citation": {
                "source": "鸚鵡",
                "author": "『白鳳』第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "臆病者の二人ではとうていしんぼうしきれないのでしょう。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
