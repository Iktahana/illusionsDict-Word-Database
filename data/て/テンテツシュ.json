          "literary": [
            {
              "text": "見たことのあるような気のする転轍手の顔。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "転轍手と遊んでいた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い髯で山羊なめし外套の転轍手は笑いながら、金棒をうしろにかくした。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "転轍手は男の子に金棒を渡した。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "転轍手は子供の方と、かなたの電車線路の上とをかわるがわる眺めた。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "転轍手はいそいで子供のところへ走って行った。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
