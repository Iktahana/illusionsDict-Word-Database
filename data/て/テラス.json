  {
    "uuid": "e3f355ee-9127-5730-9c14-3f964549cdb2",
    "entry": "照らす",
    "reading": {
      "primary": "てらす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to shine on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その間に朝日夕日は一万三千五百五回ずつ平和な浜辺の平均水準線に近い波打際を照らすのである。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "円筒の外線には小さいアーク灯があって強い一条の光線を送り、写真の膜を通じて筒中のセレニウムを照らす。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこでもし円筒を徐々に廻せば、光線は膜の諸点の濃淡に応じてあるいは強くあるいは弱くセレニウムの感光器を照らすようになる。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかるにセレニウムの奇妙な性質として、その電気抵抗はこれを照らす光の強弱に応じてあるいは減じあるいは増すので、目的地に通ずる電流もまたこれに応じて増減するのである。",
              "citation": {
                "source": "写真電送の新法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃はまた瓦斯を下向きに噴き出して、普通電灯のように下方を照らすヤコブ灯というのが出来た。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体物の色というのはそれを照らす光の色に依るので、例えば染物類を昼日光で見たのと夜石油ランプで見たのと全くちがう場合が多い。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちルプスという皮膚病は弧灯の強い光で長く照らすとだんだんに治癒するそうである。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから電車のポールの尖端から出る気味の悪い火花も、日本アルプスを照らす崇厳な稲妻の曾孫くらいのものに過ぎない。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "客観的な戦争は、探照燈の行った部分だけ青く着色されて映るが、探照燈はすべてを一時に照らすことは出来ない。",
              "citation": {
                "source": "明治の戦争文学",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが一階の右の方の窓を照らすかと思っていると急に七階の左の方へ飛んで行く。",
              "citation": {
                "source": "異質触媒作用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野も山も、此の果しなき雨夜の中へ、ふと窓を開けて、此の銀の鍋を翳したら、きらりと半輪の月と成つて二三｜尺照らすであらう。",
              "citation": {
                "source": "銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈も夢を照らすやうな、朦朧とした、車室の床に、其の赤く立ち、颯と青く伏つて、湯気をふいて、ひら／＼と燃えるのを凝然と視て居ると、何うも、停車場で銭で買つた饂飩を温め抱くのだとは思はれない。",
              "citation": {
                "source": "続銀鼎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "暗中では色の見えぬ事、照らす光によって色のちがって見える事が引証されている。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂のまん中へ立って高い色ガラスの窓から照らす日光を仰いで見るのはやはりよい心持ちがします。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓原の草の葉末を照らす燐火のように、深い噴火口の底にひらめく硫火の舌のように、ゆらゆらと燃え上がる。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雙眼涙を含める蒼ざめた顔を月はまともに照らす。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅葉火のごとく燃えて一叢の竹林を照らす。",
              "citation": {
                "source": "小春",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日きれいに照らす日の目も、毎晩美しくかがやく月の光も、青いわか葉も紅い紅葉も、水の色も空のいろどりも、みんな見えなくなってしまうのです。",
              "citation": {
                "source": "燕と王子",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「光明、十方世界を照らす」「光明、河砂のごとく遍し」「光明、日月を勝過す」等の言葉があります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "はらりと音して、寝ながら投げた扇が逸れたか、欄干を颯と掠めて、蒔絵の波がしら立つごとく、浅翠の葉に掛って、月かと思う影が揺ぐと、清葉の雪のような頬を照らす。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "紺地に金泥のごとく、尊い処へ、も一つの室には名も知れない器械が、浄玻璃の鏡のように、まるで何です、人間の骨髄を透して、臓腑を射照らすかと思う、晃々たる光を放つ。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、美しさは、夜の雲に暗く梢を蔽はれながら、もみぢの枝の裏透くばかり、友染の紅ちら／＼と、櫛卷の黒髮の濡色の露も滴る、天井高き山の端に、電燈の影白うして、搖めく如き暖爐の焔は、世に隱れたる山姫の錦を照らす松明かと冴ゆ。",
              "citation": {
                "source": "印度更紗",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曉の霜を裂き、夕暮の霧を分けて、山姫が撞木を當てて、もみぢの紅を里に響かす、樹々の錦の知らせ、と見れば、龍膽に似て俯向けに咲いた、半鐘の銅は、月に紫の影を照らす。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（空ざまに取って照らすや、森々たる森の梢一処に、赤き光｜朦朧と浮き出づるとともに、テントツツン、テントツツン、下方かすめて遥にきこゆ）……見えたか。",
              "citation": {
                "source": "多神教",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "断雲の絶間より、幽霊火のごとき星の照らす甲板上には、今しも一団の黒影入り乱れて闘いおるなり、人数およそ二十人ばかり、我が帆船の水夫のみにはあらず、オオ、これ何事ぞ！",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "月いと清うさしいでて、葉裏を透して照らすにぞ、偶然思い付く頬の三日月、また露れはせざるかと、懐中鏡を取出せば、きらりと輝く照魔鏡に怪しき人影映りけるにぞ、はっと鏡を取落せり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛤が六つ七つ、むらむらと渚を泳いで、左右を照らす、真珠の光。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と六月の日の照らす中に、寢不足の蒼白い顏を、蒸返しにうだらして、筋もとろけさうに、ふら／＼と邸に近づく。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬間に人間の運命を照らす、仙人の黒き符のごとき電信の文字を司ろうと思うのです。",
              "citation": {
                "source": "革鞄の怪",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寒の月てらす玉垣、霜はただふりそそぐなり。",
              "citation": {
                "source": "第二海豹と雲",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
