        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いま列車は横浜駅のホームを離れ、次の停車駅大船までぐんぐんスピードをあげてゆきつつある。",
              "citation": {
                "source": "暗号数字",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車駅で老婆や娘の売っている鶏は油がわるくてむっとする。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "つぎの停車駅までは、約一時間もかかる。",
              "citation": {
                "source": "くまと車掌",
                "author": "木内高音",
                "note": "青空文庫"
              }
            },
            {
              "text": "たぶん最初の停車駅フォート・アンソンだ。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "連れていってください」　三津子が降りると言った停車駅でふたりは新幹線を降りた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "急行の停車駅でもある駅を出て、夜道を彼は部屋のある建物まで歩いた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "停車駅がほどよいアクセントとして機能した。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
