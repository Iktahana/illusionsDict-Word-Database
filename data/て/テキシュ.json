[
  {
    "uuid": "89c20907-c667-5ba6-b5dc-d0191cd6ce48",
    "entry": "摘取",
    "reading": {
      "primary": "てきしゅ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変"
      ],
      "ctype": null,
