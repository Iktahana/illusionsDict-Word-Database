    },
    "definitions": [
      {
        "index": 1,
        "gloss": "picking",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その花や莟をチョイチョイ摘取って、ふところの紙の上に盛溢れるほど持って来た。",
              "citation": {
                "source": "野道",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして真先に立つた一人が、其辺の道傍に芽ぐんでゐる草の葉を摘むで、それに味噌をつけて食べると、後に続いた者は順繰にその葉を摘取つて食はなければならぬ。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "此にその作者の出入起居を窺ふべきものを摘取することとする。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "すこし取って行って進げようと思って」「そう……好く生ったことね」と言ってお雪も摘取りながら、「福ちゃん、此頃姉さんと約束したもの……あれを書いておくれナ。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "妹は自分で摘取った莢を姉の前垂の中へあけて、やがて畠を出て行った。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "蕗の薹はお雪が裏の方へ行って、桑畑の間を流れる水の辺から頭を持上げたやつを摘取って来た。",
              "citation": {
                "source": "家（上巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "軟かき雪のなだれの繻子の背や、仰向きて横はる月は吐息も長々と、青空に真白く昇る幻影の花の如きを眺めやりて、懶き疲れの折々は下界の面に、消え易き涙の玉を落す時、眠りの仇敵、沈思の詩人は、そが掌に猫眼石の破片ときらめく蒼白き月の涙を摘取りて、「太陽」の眼を忍びて胸にかくしつ。",
              "citation": {
                "source": "珊瑚集",
                "author": "仏蘭西近代抒情詩選",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅い木の実を摘取ると、すぐそれが汚れて了ひ、ちよいと草木の根を穿つても、この手が付くと凋んでゆく。",
              "citation": {
                "source": "癩病やみの話",
                "author": "RECIT DU LEPREUX",
                "note": "青空文庫"
              }
            },
            {
              "text": "自ら手こそ下さなかったが、行末、長く咲くべかりし清純の花を、おのれ一個の体裁をつくろうために、無残にも摘取って地獄の口へ追いやってしまった。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
