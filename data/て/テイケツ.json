[
  {
    "uuid": "e171ba6e-1b56-5566-97e8-a4a13fd6a40d",
    "entry": "貞潔",
    "reading": {
      "primary": "ていけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
