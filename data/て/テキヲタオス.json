    "definitions": [
      {
        "index": 1,
        "gloss": "to kill one's enemy (opponent)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
