          "literary": [
            {
              "text": "三男は子供のときから手癖が悪いので、おまきの方から追い出してしまった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "手癖が悪い――泥棒だというのである。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お前の妻君は、さう言つちや悪いけれど、少し手癖が悪いんぢやないかい。",
              "citation": {
                "source": "閾",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして女中頭はああ手癖が悪いのか？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにせ、うちの奴らはみんな手癖が悪いだから？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから台所をちょっと覗いて、召使たちが満足な物を食っているかどうかと調べるような顔をして、玉菜汁と粥を鱈腹つめこみ、一同を誰彼なしに、手癖が悪いの、身持がよくないのと罵りちらしておいてから、自分の部屋へと戻った。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "東の野郎は手癖が悪い」「一杯機嫌で行ったんだ。",
              "citation": {
                "source": "ある温泉の由来",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕事どころではない、店にはおきぬがいて、長次が塀の板を剥がして持っていった、見ていたあたしが証人だ、あの子はまえから手癖が悪い、泥棒根性のある子だ、などとまくしたてた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "鶯ばか",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴はあれで手癖が悪いのです。",
              "citation": {
                "source": "湖畔亭事件",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
