    "definitions": [
      {
        "index": 1,
        "gloss": "to fall into someone's hands",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこでこの原稿はバラバラになって職工の手に渡る。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも気紛れな株さえやらなかったら、新婚当時養家で建ててくれた邸宅まで人手に渡るようなことにもならなかったかも知れなかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから銭は大人の手から大人の手に渡るのであつて、子供には関係しないのである。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼奴の手に渡ると十二万円が赤の地下運動の軍資金になっちまうぜ」「ウン。",
              "citation": {
                "source": "オンチ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し敵の手に渡る様なことがあれば勝頼末代までの恥である。",
              "citation": {
                "source": "長篠合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし牛乳屋が正直にもとの家へ返したところで、まただれか新しい飼い主の手に渡るにしても結局はのら猫になるよりほかの運命は考えられないようなこの猫をみすみす出してしまうのもかわいそうであった。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正勝の口から言わしても、当然のこと開墾地の人たちが受け取るべきだという財産が、開墾地の人たちの手に渡らず、正勝の手に渡るようでは、わたしはとても死に切れません。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　ところで、何でも、その桜の枝と、瓢箪が、幇間の手に渡るのをきっかけに、おのおの賑やかなすて台辞で、しも手ですか、向って右へ入ると、満場ただ祇園の桜。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、倭文子が単に自分を離れるのなら、なお辛抱が出来るが、すぐ他の男性の手に渡ることを考えると、村川は堪えられなかった。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「他人の手に渡るときまつたら、屋根おさへにも出ないなんて、あの先生の御了見のほども仲々どうもおそれ入つたものぢやないか。",
              "citation": {
                "source": "鬼の門",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次の土曜日の条に、大高島から向こう岸の土手に渡る記事が書いてあった。",
              "citation": {
                "source": "田舎教師",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "日限の日になって観音が出来上がると万事用意が整っているのだから、五寸の立像の観音は、辷るように厨子に納まり、そのまま注文｜主の手に渡る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "「木寄せ」その他のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば、或る仏師の弟子の製作があるとして、それが塗師屋の手に渡る。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "仏師の店のはなし（職人気質）",
                "note": "青空文庫"
              }
            },
            {
              "text": "師匠の手に渡ると、造作を仕直し充分に手入れを致しましたが、これらの費用一切を精算して七百円で上がりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "堀田原へ引っ越した頃のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "これで三甚は思いも寄らない手柄をしたのですが、自身番へひかれて行った時に、金蔵はたいそう口惜しがって、どうでおれは遠島船を腰に着けている人間だから、遅かれ早かれ御用の声を聞くのは覚悟の上だが、いざお縄にかかるという時には、江戸で一、二といういい顔の御用聞きの手に渡る筈だ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "この鰊場もおそかれ早かれ彼奴の手に渡るだろう。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "どつちも、彼女の手に渡る前に、もう何人もの人手を通つて來たらしい、綴もグヅグヅになつてゐるやうな本であつたが、それでも彼女が讀んだあとといふものはよくわかるのだつた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしていつの日になっても、我々とは違った人種、我々よりももっと高い使命をもった生物が地球の遺産を相続するようなことはないであろうし、また人間のこれまでに成就した何物もそのままに他の者の手に渡ることはないであろう。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "十年前嫁入道具の一つとして郷里の土蔵に持込まれたまま、一度も使用されず、その箪笥がひと手に渡るのは彼にとっても身を削がれるような気持だった。",
              "citation": {
                "source": "秋日記",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "全国に二〇数か所設けられた実顕地生産物供給所にまとめて輸送され、そこから活用者グループのまとめ役にとどけられ、最後に活用者一人ひとりの手に渡る。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しその金が彼女の手に渡るまでには、かなり永い時日が経った。",
              "citation": {
                "source": "棄てる金",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サンドオがバルザツクに会つた時、この数字の意味を問ひ訊すと、それは著者が十万部売切れた場合、著者の手に渡るべき印税の額だつたと云ふ。",
              "citation": {
                "source": "点心",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "家は伯父の遺して行つた借債の為に人手に渡る。",
              "citation": {
                "source": "乳の匂ひ",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……即ち、もしもこの書類が公表されるか、又は司直の手に渡るかした暁には、如何に凡クラな司法官でも、直ぐに吾輩を嫌疑者として挙げずにはおられないように出来ているのだ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間の後には人手に渡るべき一枚の五円紙幣に電気アイロンをあてて見る気にはなれない。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫れを因藤裁判長殿の手許に押えて置いて能勢弁護士の手に渡るようにして呉れないのであります。",
              "citation": {
                "source": "支倉事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川で始めてこの者どもの手に渡るのである。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "亀之介の方でも、とくにそのことを感付いていて、告白書が兄の手に渡るや否や、あとは大風が自分の方へ向って吹きまくるであろうこと、そして多分自分は放逐されるだろうと先の見透しをつけた。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからおまえの実験は、このきれぎれの考えのはじめから終わりすべてにわたるようでなければいけない。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからおまへの實驗はこのきれぎれの考へのはじめから終りすべてにわたるやうでなければいけない。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
