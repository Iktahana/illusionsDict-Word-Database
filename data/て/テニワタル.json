[
  {
    "uuid": "f426744a-a08c-5a1b-a2b2-986c1e8e501a",
    "entry": "手に渡る",
    "reading": {
      "primary": "てにわたる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
