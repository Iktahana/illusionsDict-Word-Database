  {
    "uuid": "52f24fb5-7052-537d-b6b9-6a9228381d5d",
    "entry": "顛倒",
    "reading": {
      "primary": "てんどう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
