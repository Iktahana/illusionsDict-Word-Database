[
  {
    "uuid": "3e4c4eae-74b5-5f65-a08e-0be2d99bcc2f",
    "entry": "手をつく",
    "reading": {
      "primary": "てをつく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現",
        "動詞-五段-カ行"
