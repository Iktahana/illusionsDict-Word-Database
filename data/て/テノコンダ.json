        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは精力的に手の込んだ建築であった。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "気取ったポーズや、手の込んだジャスティフィケイションのかげに助平根性を隠そうとするのが、みっともないと言ってるんだ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "全く、どうにも手の込んだ大馬鹿野郎・度しがたい大根役者だよ。",
              "citation": {
                "source": "狼疾記",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の込んだ復讐と言うべきものだ。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな手の込んだ準備をしたり、それだけの金を出すほどではない。",
              "citation": {
                "source": "赤毛連盟",
                "author": "THE RED-HEADED LEAGUE",
                "note": "青空文庫"
              }
            },
            {
              "text": "インテルはマイクロコンピューターの誕生二十五周年を記念して、実に手の込んだ展示ページを用意しています。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯にも、何か手の込んだものがこしらへてみたくなつて、暫く打つちやつて置いた料理の本などを引出して見る。",
              "citation": {
                "source": "脱殼",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "無論、手間賃は幾らでもいゝと云うのですが、この男の痩せた生白い背中に、それほど手の込んだ二人立が乗る訳のものではないので、もう些と軽いものをと色々に勧めたのですが、清吉はどうしても肯かない。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "画は尺八か何かの大きさで、随分手の込んだ密画で、出来も決して悪い方では無かつた。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の今日の娘の生活という見出しで、たとえばルポルタージュ写真を撮るとなれば、これも手の込んだ仕事になるだろう。",
              "citation": {
                "source": "若い娘の倫理",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の込んだ細工の銀台といい、立派な菱形に截った石の大きさ、艶といい、調和のよい上衣の色を背景に、非常に美しく見える。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "突破口となったキャッシュレジスターに続いて、ミシンや編機にマイクロコンピューターが採用され、手の込んだ模様を簡単に縫い込めるタイプがブームを呼んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼はヴァイオリンの音を聞きながら、ヨハンの案内の仕方も手の込んだ劇を見せる変化に苦心を払っているのだと呑み込めた。",
              "citation": {
                "source": "罌粟の中",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、それは単純素樸な肯定にはなり得ないけれども否定を否定することに依つての肯定を、無限に持続して行くものだと見れば、茲に仏教特有の不可思議な、甚だ手の込んだ生の肯定が自らにして否定の深淵の底から、水沫の如く浮き上つて来るやうにも思へるではないか。",
              "citation": {
                "source": "ニイチエ雑観",
                "author": "超人の如く潔き没落を憧憬するニイチエの日本精神に就て",
                "note": "青空文庫"
              }
            },
            {
              "text": "技術としては相当手の込んだものです。",
              "citation": {
                "source": "文化とは",
                "author": "――力としての文化　第一話",
                "note": "青空文庫"
              }
            },
            {
              "text": "罪の性質はとにかく、それがいかにも手の込んだ仕方で巧妙に蔽はれ、それも完全に尻尾をみせないのではなく、却つて無慈悲なかたちで、久しく疑ひのまま残されてゐたといふことは、まつたく例のないことのやうに思はれた。",
              "citation": {
                "source": "ある夫婦の歴史",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、子供の我儘と云つてはすまされない、手の込んだ芝居である。",
              "citation": {
                "source": "日本人とは？",
                "author": "――宛名のない手紙――",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒塗の印籠、または金蒔絵をしたり種々手の込んだ優美な品につける根附は、高尚な趣味のものでなければならず、吸殻あけなどは簡単な人が持つのでしょう。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人は『烏』の頂きで手の込んだ朝食をすませ、山稜に沿って南へ『｜烏の嘴』までくだり、タッコンナの氷河を渡って、いよいよそこからグラン・ミューレの大難場、氷の絶壁へととりかかる。",
              "citation": {
                "source": "ノンシャラン道中記",
                "author": "アルプスの潜水夫　――モンブラン登山の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただマイダス王も、この時ばかりは、こんな手の込んだ、高価な魚の模型よりも、真物の川鱒がお皿に乗っていた方がどんなにいいか知れないと思いました。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "）父子の一つ鞠ががめずらしく手の込んだ難しい曲技を次々と見せてくれた。",
              "citation": {
                "source": "随筆　寄席風俗",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚いたことは、砂を吐かすなどという手の込んだことは知らないので、どの貝も必ず砂をもっている。",
              "citation": {
                "source": "西洋の浜焼",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "細君は、どれがどうだかわからずに、それでも粗末な涎掛けのために、手の込んだ、金のかかる刺繍を選び出す。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、一挙両得というわけだ」「すると、あの抉れたような痕は」「それは、短い外趾の端が触れた痕だ」「何のためにそんな手の込んだことを」　源内先生、閉口して、「いや、諄い男だ。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "萩寺の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "象の腹で金魚を飼いやしまいし、こんな手の込んだことをする馬鹿はない。",
              "citation": {
                "source": "平賀源内捕物帳",
                "author": "山王祭の大象",
                "note": "青空文庫"
              }
            },
            {
              "text": "いはゆる「代返」なる習慣には、たまに眼をつぶることはあつても、この種の手の込んだ、或は合法的かもしれぬが、一方、教師として黙認すべからざる学生の協同謀議に対して、なんらかの手を打つべきではないかと、彼は考へた。",
              "citation": {
                "source": "計算は計算",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、いきなり初めて見てその瞬間に恋愛なんて、そんな手の込んだ気持なんか起りつこ無いわけでしようし、無理だわ。",
              "citation": {
                "source": "浮標",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "国家的瑞兆という三段抜きの大｜標題で手の込んだ記事を書上げ、名士、博士を総動員して感想を執筆させた。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨戸は上下の桟がおりた上、念入りに輪鍵まで掛けてあるのですから、八五郎等六人が飛び込む隙に、外からこんな手の込んだ締めようは絶対不可能です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
