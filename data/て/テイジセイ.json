        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "新聞は、原因は定時制高校を落第し、将来を悲観した純君に、朝子さんが同情しての覚悟の心中行とみられる、と報じていた。",
              "citation": {
                "source": "赤い手帖",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "案外、定時制高校の生徒なのかもしれなかった。",
              "citation": {
                "source": "軍国歌謡集",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "中学を出た長女のはるは、父親の勤めている郵便局へ就職し、夜は定時制高校へかよいだした。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女が勤めに出ず、定時制高校にゆかず、家で寝ていたことだけは確かであった。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾根隆助の話によると、相手は二階に間借りしている二十二の青年で、孝ちゃんといい、昼は運送店に勤め、夜は定時制高校にかよっている。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
