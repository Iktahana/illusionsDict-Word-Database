        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ペエテルはペピイの体に異状の無いのを見届けた上、手の甲に載せた腮をずらせて、半分右へ向く。",
              "citation": {
                "source": "老人",
                "author": "GREISE",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京の真中で大びらに恋をしよう、ね」　小初の涙が薫の手の甲を伝って指の間から熱砂のなかに沁み入った。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「わたくしは富蔵の顔を睨んで、やい、てめえの頸のまわりや手の甲に引っかき疵のあるのはどうしたんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おばあさんはやれやれと腰をのばして、手の甲で額を一寸こすりながら、二人の方を見て云ひました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどき頬のガアゼを手の甲でかるく叩いてゐた。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　おばあさんはやれやれと腰をのばして、手の甲で額を一寸こすりながら、二人の方を見て云いました。",
              "citation": {
                "source": "十月の末",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正何年であったか正月の三日に、国原がフロックコートで初出社をすると、左手の甲に仰山らしく繃帯をしている。",
              "citation": {
                "source": "呑仙士",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か言い出しそうにしては口のあたりを手の甲で摩るのでございます。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の甲をはげしく擦る釘のようなものを感じた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "きゅうに手の甲がぴりぴりしだした。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼れはこの有樣を見ると思はず、手の甲で眼をかくしながら二三歩たじろいて後ろを向いてしまつた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "内心痛し、頗る痒しで、皺だらけの手の甲を顋の下で摺ってござった。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「然う言はれる、申される……」　と杖を持つた手の甲を、丁と敲き、「如何にも、もし、それが惡い……」「行つては不可いと云ふのかね。",
              "citation": {
                "source": "三人の盲の話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "小十郎はちゃんとかしこまってそこへ腰掛けていかの切り込みを手の甲にのせてべろりとなめたりうやうやしく黄いろな酒を小さな猪口についだりしている。",
              "citation": {
                "source": "なめとこ山の熊",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手の甲から腕の関節にかけて、二寸程の細長い瘢痕のあるのをぢつと見つめた。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、俯向けていた地薄な角刈の頭を擡げて、はぐらかす気か、汗ばんだか、手の甲で目を擦って、ぎろりと巽の顔を見た。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と手の甲で引擦る。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は分厚い唇にたまった泡を、素早く手の甲で拭きとった。",
              "citation": {
                "source": "秋深き",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "バタバタと羽根を散らして上の方へ飛び退いたが、なおも真黒い手が掴みかかって来るのを見ると、その手の甲へ勇敢に逆襲して、死に物狂いに喰い附いた。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　僕のそういったような言葉はどうやら青扇の侮蔑を買ったらしく彼は、さあ、と言ったきりで、自分の両手の手の甲をそろっと並べ、十枚の爪を眺めていた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから急に大声で笑い出して、涙を手の甲で拭い、王子の目をも同様に拭いてやって、「さあ、今夜はあたしと一緒に、あたしの小さな動物のところに寝るんだよ。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手の甲はわつぷるのふくらみでその手の指は氷砂糖のつめたい食慾ああ　この食慾子供のやうに意地のきたない無智の食慾。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手の甲はわつぷるのふくらみでその手の指は氷砂糖のつめたい食慾ああ　この食慾子供のやうに意地のきたない無恥の食慾。",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「口惜しいけれど、おいしいわよ」　お絹は唾液がにじんだ脣の角を手の甲でちょっと押えてこういった。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手首からすぐ丸い掌がつき、掌から申訳ばかりの蘆の芽のような指先が出ているかの女のこどものような手が、意外に翩翻と翻って、唄につれ毬をつき弾ませ、毬を手の甲に受け留める手際は、西洋人には珍しいに違いなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幾条もの傷を手の甲に拵へながら、口惜しさに夢中で薄の穂をもぎ折つた幼い頃の記憶を私は秋になるとなつかしく想ひ出す。",
              "citation": {
                "source": "秋の七草に添へて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃はもう私も十五六になつてゐたし、手の甲には靜脈の青い血管がうつすりと透いて見えて、からだも異樣におもおもしく感じられてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはお嫁に行ってから十日と経たない頃の事であったが、手の甲がひどく汚くなっていた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちる時手を放して、僕は左を下に倒れて、左の手の甲を花崗岩で擦りむいた。",
              "citation": {
                "source": "花吹雪",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、文化面をもひきくるめてのこういう誤った全体主義の見かたが、どうして今日大衆の進歩的な部分、知識人の進歩的な部分によって、それが当然受けるべきだけ十分、論点をはっきりさせた反撃をうけずにいるかということである。",
              "citation": {
                "source": "全体主義への吟味",
                "author": "――今日の民衆、知識人への課題――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
