[
  {
    "uuid": "b6eef45d-9d93-5d33-b051-6dad2dd06dc6",
    "entry": "鉄ちゃん",
    "reading": {
      "primary": "てっちゃん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
