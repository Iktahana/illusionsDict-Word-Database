        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ウチは座敷のほかにテーブル席も、スタンドもあるのです。",
              "citation": {
                "source": "裏切り",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥のテーブル席に、失業者のような初老の男性たちが三人いた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方の壁ぎわの、ブースになったテーブル席で、トマト・サラダを食べながら、彼はビールを飲んでいた。",
              "citation": {
                "source": "時差のないふたつの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふたりはテーブル席で差し向かいとなった。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "カウンターの向かい側には、煉瓦の壁に沿って四人用のテーブル席が三つならんでいた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは中原のすぐうしろのテーブル席についた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "テーブルの向こうは横に一列のカウンター、そしてテーブルの左側の奥は、階段を数段降りて広がるテーブル席のスペースになっていた。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
