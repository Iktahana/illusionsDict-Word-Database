[
  {
    "uuid": "2a6147ad-cc52-53ec-9c4b-3686a6cde5cc",
    "entry": "天草",
    "reading": {
      "primary": "てんぐさ",
      "alternatives": [
        "テングサ"
      ],
      "is_heteronym": false
    },
    "grammar": {
