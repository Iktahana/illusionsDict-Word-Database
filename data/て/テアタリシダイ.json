[
  {
    "uuid": "32c747f1-7cae-5104-b58f-43a0f2f251f7",
    "entry": "手当たり次第",
    "reading": {
      "primary": "てあたりしだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "副詞",
        "表現"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "using anything one can lay one's hands on",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は手当たり次第に積みあげ、また慌しく潰し、また慌しく築きあげた。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まず手近な盆栽や菓子やコップなどと手当たり次第にかいてみた。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし座右にある最近の「アララギ」や「潮音」その他を手当たり次第に見ていると、中にはほとんど前記の第一例に近いものも、第二例に近いものも、また第三例に近いものもあるが、また中には形式においてずっと変わった特徴の見られるものも少なくはない。",
              "citation": {
                "source": "連句雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、その夏休みに国へ帰ってから手当たり次第の材料をつかまえて二三十句ばかりを作った。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのほか、自分の家から少しばかり離れた所に親戚があって、そこへ行くといつも書物を出しては、手当たり次第に読んでみた。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "猫さえ見れば手当たり次第にものを投げつけなければならない事のように思っていた。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなお、上から押し付けたり、その辺に脱ぎ捨てられている衣類を、なんでも、手当たり次第に掩い掛けてやるのであった。",
              "citation": {
                "source": "山茶花",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "がらがらとこの店のものを手当たり次第に投げ出したんですよ。",
              "citation": {
                "source": "街頭の偽映鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ほう、どうも者ども、手当たり次第にひっつかんだようだ。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからこそ手当たり次第に持って行ったのです。",
              "citation": {
                "source": "ライギット・パズル",
                "author": "THE REIGATE PUZZLE",
                "note": "青空文庫"
              }
            },
            {
              "text": "珠算｜独り学びなどいう本まで、珠算なんてする気もなく読んだし、ドンキホーテも、渡辺崋山も、占易の本から、小学地理、歴史、修身、全く何でもかでも活字の並んでいるものは手当たり次第に読んだよ」と、藤原は、何だか、河の堤防が決壊しでもしたように渦を巻いて彼の話を話し出した。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただなんでもいいせっせと手当たり次第したくをしておかなければ、それだけの心尽くしを見せて置かなければ、目論見どおり首尾が運ばないように思ったので、一ぺん横になったものをまたむくむくと起き上がった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくの間葉子は引きつけられるようにそういう紙片を手当たり次第に手に取り上げて読みふけった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ずいぶん紙灰が散らかっているようですな、きっとこのおやじに怨みのある債務者が、手当たり次第に証文を焼いたもんでしょう」「評判のよくない奴でしたからな。",
              "citation": {
                "source": "祭の夜",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の髪の毛とか動物の毛とかあるいは血液とか尿とか、あるいは各種の絵の具とか、手紙に用いる封蝋とかあるいは衣服の繊維など手当たり次第に研究し、しかもある場合には立派に鑑別ができるので、俊夫君は有頂天になって喜び、それこそ寝食を忘れて実験室にとじこもり、十数日の後にはもう紫外線通となってしまいました。",
              "citation": {
                "source": "紫外線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "近所の路次うちの悪太郎どもが、古｜板塀を破って庭から闖入し、手当たり次第持ち出して行ったらしい形跡が、板塀の破れ目から縁側まで落ち散っている雑書や何かを見ても解ったが、昔ものの手堅い古建具、古畳、建築の余材、そんなものもいつの間にか亡くなってしまった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし芸術を作らない普通の人が、何に限らず食べたがる普通人が、あらゆる女に対してそれ相当の興味を感じ出したり、手当たり次第に食慾を感じたりしてくれては無数の色魔が現れて危険だ。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "自らの「問い」なくして手当たり次第に読書することは、その割合いに効果乏しく、また批判の基準というものが立ちがたい。",
              "citation": {
                "source": "学生と読書",
                "author": "――いかに書を読むべきか――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでも平常出入りの百姓が一番先に立って、闇の晩に風呂敷で顔を包んで行って、問屋の家の戸障子と言わず、押入れと言わず、手当たり次第に破り散らして、庭の植木まで根こぎにしたとかいう話を聞いたこともあるよ。",
              "citation": {
                "source": "夜明け前",
                "author": "第二部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "この肉身を原子病治療法発見の貴重な資料に使うのであるから、でたらめな実験をめくら滅法やってみるのではない、おぼれる者はわらをもつかむというあわて方で、迷信だろうとインチキ薬だろうと手当たり次第飲んでみるのでもない。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "大波止に着くと、二百九匹鹿児島あずけ百十匹備前岡山あずけと、犬扱いに、手当たり次第髪をつかんでは団平船の中に投げこまれ、夫は広島に、妻は金沢に、子供は松山にというふうに、はなればなれに積みこまれてしまいました、そしてこれを国々に流したのでございます。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでさし当たりの問題としては、断片的に先生の人間の片鱗を手当たり次第に描いて、そういう文章を沢山集めて、漠然とした形ながら、科学と文学との融合した形に於ける先生の全貌を伝える試みが残されているばかりである。",
              "citation": {
                "source": "「寺田寅彦の追想」後書",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼らは徒党をくんで富家に闖入し、手当たり次第に飲み食った。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダン　それにぼくは見えても見えなくても手当たり次第に叩いちゃうから！",
              "citation": {
                "source": "不思議の国のアリス　ミュージカル版",
                "author": "ALICE IN WONDERLAND: DREAM-PLAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かと決めかねているうちに、コックはスープのおなべを火から外すと、いきなりあたりのものを手当たり次第に御前さまと赤ちゃんに投げつけだしてね――火元の金具がまず飛んできて、そのあと続いて小なべやお大皿小皿が雨あられ。",
              "citation": {
                "source": "アリスはふしぎの国で",
                "author": "ALICE IN WONDERLAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ無批判に手当たり次第に訳したのではない。",
              "citation": {
                "source": "まざあ・ぐうす",
                "author": "北原白秋訳",
                "note": "青空文庫"
              }
            },
            {
              "text": "手当たり次第に買われた、学校の教科書や小説や脚本などがあった。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は患者筋の人々を追い帰し、用件の面会を断わり、帰りを急いで手当たり次第の汽車に乗った。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "――二人の女の顔と手当たり次第に読んだ若干の書物。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
