[
  {
    "uuid": "443a4589-165f-59c4-98a0-7a3d7868dcec",
    "entry": "天平時代",
    "reading": {
      "primary": "てんぴょうじだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
