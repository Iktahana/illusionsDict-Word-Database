          "literary": [
            {
              "text": "到底僕は佐藤と共に天寿を全うする見込みはない。",
              "citation": {
                "source": "佐藤春夫氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五条　天寿を全うするは人の本分を尽すものなり。",
              "citation": {
                "source": "修身要領",
                "author": "慶応義塾",
                "note": "青空文庫"
              }
            },
            {
              "text": "死は天道の常則にして、我人の免るべからざるところなれども、天寿を全うすることあたわざるは、多くその人自ら招くところなることは、実際に照らして明瞭であります。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "天寿を全うすることは、大自然の原則である。",
              "citation": {
                "source": "霊訓",
                "author": "SPIRIT TEACHINGS",
                "note": "青空文庫"
              }
            },
            {
              "text": "飽くまで天寿を全うするまで勝ち抜いて、この世に見事に生命の太い線を描いて見せなければ、兵法者として一人前に生きた者とはいわれないのである。",
              "citation": {
                "source": "宮本武蔵",
                "author": "火の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
