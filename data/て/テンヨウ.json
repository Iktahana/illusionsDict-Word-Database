[
  {
    "uuid": "12eac387-9d04-5fb3-b6ed-983b8d83375d",
    "entry": "転用",
    "reading": {
      "primary": "てんよう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
