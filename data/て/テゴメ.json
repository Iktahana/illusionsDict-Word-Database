        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兄には、決してごめいわくをおかけしません。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄には、決してごめいわくをおかけしません（この辺は真実ならんも、また、あてにすべからず）「太宰がちょっとした失敗をして、困っているから、」と申して（申してとは、あやしき言葉なり、無礼なり）借りて下さい。",
              "citation": {
                "source": "誰",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうもう、あたしは、人の世話なんてごめんですよ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが茶かすようで気に入らなければ、そんな無理を云わないで、誰それの愛を書けと明暸に所有主を示して貰いたい、いくら僕が愛の客観的存在を認めても、ただの愛はかけない、根こぎにして引っこ抜いた愛だけはかけない、根こぎにして引っこ抜いた鉢植の松を描けという難題と同じ事だからと云ってごめんこうむります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしまで泣いたりしてごめんなさい、でもわたし、やっぱり泣けるのよ、といいながら。",
              "citation": {
                "source": "その人の四年間",
                "author": "――婦人民主クラブの生い立ちと櫛田ふきさん――",
                "note": "青空文庫"
              }
            },
            {
              "text": "士族の町人、百姓に対する斬りすてごめんのなくなったことを徳とした。",
              "citation": {
                "source": "平和への荷役",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "へへへへへ、つい酔っているもんですから、飛んだ失礼をしてごめんなすっておくんなさい」　無論、額風呂の客にはちがいありますまいが、作り笑いをした眼元に一癖のある町人が、ヒョコヒョコ頭を下げながらぷいと縁先から姿をかくしました。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "トントンピーピのわるとびに、おひげとられてごめんなさい。",
              "citation": {
                "source": "トントンピーピ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おひげなくしてごめんなさい。",
              "citation": {
                "source": "トントンピーピ",
                "author": "村山籌子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「意地わるしてごめんなさい。",
              "citation": {
                "source": "若草物語",
                "author": "LITTLE WOMEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "前置きが長すぎてしまってごめんなさい。",
              "citation": {
                "source": "艶色落語講談鑑賞",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきでたらめをいってごめんなさい。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　リョウヘイは決してごめんなさいといった覚えがないときでも、おばさんはリョウヘイにかわってこういった。",
              "citation": {
                "source": "ふたりのおばさん",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "お邪魔してごめんなさい。",
              "citation": {
                "source": "泉",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "お母さんにしてやられましたねと女房が言ふと、ふふと嬉しさうに笑つて、枯れた手つきで札をあわててめくつて、二枚下の分までめくつてごめんごめんと言つたりした。",
              "citation": {
                "source": "故郷を辞す",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "てごめにされたとは古い奴だぞ。",
              "citation": {
                "source": "中山七里　二幕五場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "「邪魔してごめんなさい。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も行く人がなくてごめんなさい。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「遅れてごめんなさい」陽子は微笑しながら言った。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへお豊が帰って来、「おそくなってごめんなさい、ちょっと顔をなおして来たの」と云いながら、長火鉢の向うへ坐った。",
              "citation": {
                "source": "花も刀も",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「困らせてごめんなさい、あまえてみたかったの」　とかよは云って、万三郎をやさしく睨んだ。",
              "citation": {
                "source": "風流太平記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おそくなってごめんなさい」とおみやは囁いた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四には、てごめになって、どこかへ、つれさられるようなばあいに、このバッジを、道におとしておけば、方向を知らせる目じるしになる。",
              "citation": {
                "source": "透明怪人",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞄を閉じたハチミに、「引き止めてごめんなさいね」　と母親は丁寧に言った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "きみは父親に反抗して、よその人にキャッチ・ボールを教えてもらったんだ」「男のこでなくてごめんなさい、という気持ちがずっとあって、でもそれだけだといつまでたっても私としてはつらいだけなのね。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "男のこではなくてごめんなさい、という気持ちを、男のこでなくておあいにくさま、というふうに変えたいと思ったわ。",
              "citation": {
                "source": "夏と少年の短篇",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな夜更けに訪ねてきて心配させてごめんなさい。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "言い過ぎてごめんね。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "「すみません、まちがえてごめんなさい」　とあやまる声は哀願するかのようだった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "あけすけに話してごめんなさいね。",
              "citation": {
                "source": "ギルレイ",
                "author": "The Man Called Gilray",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
