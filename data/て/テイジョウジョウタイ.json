        "examples": {
          "standard": [
            {
              "text": "化学反応は、ある時点から定常状態に入り、変化しなくなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "システムが定常状態に達するまで、しばらく時間がかかることがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            },
            {
              "text": "「この装置は、定常状態での性能が最も安定している。」と、エンジニアは説明した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash-lite"
              }
            }
          ],
          "literary": [
            {
              "text": "生体のすべての構成物質は機能的であれ構造的なものであれ、構成が単純であれ複雑なものであれ、急速に流れている定常状態にあることを示唆している現代生化学の幾つかの結果をこの中に提出するつもりである。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "定常状態に達したときに飽和酸の重水素含量および合成速度は不飽和酸のものより高いことが第２図の曲線から見られるであろう。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここに示した新しい結果は燃料だけでなく構造材料もまた流れている定常状態にあることを示している。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            },
            {
              "text": "定常状態にあると思われる動物たちで正の窒素出納が見られたのはこのためと考えられる。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
