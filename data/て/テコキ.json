          "literary": [
            {
              "text": "粗食を与えられ、虐待され、身体中こづき廻され、番兵の命令によってこき使われる。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "渋谷にてこきむらさきの杜若採ろと水際につくばんで濡れた袂をしぼる身は、ふと小娘の気に返る。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな女にどうしてこき使われているんだ。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作者までいっしょになってこき下ろすのは止そう。",
              "citation": {
                "source": "恋の伝七郎",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、彼女が料理を作るときには、ぼくは雑役としてこき使われる。",
              "citation": {
                "source": "頬よせてホノルル",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
