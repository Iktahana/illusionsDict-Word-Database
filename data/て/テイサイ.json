    "definitions": [
      {
        "index": 1,
        "gloss": "(outward) appearance",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「お母さん、体裁の悪い！",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやもう体裁なんて、そんなことが言つてられやあしない。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々アインシュタインに会って雑談をする機会があるので、その時々の談片を題目とし、それの注釈や祖述、あるいはそれに関する評論を書いたものが纏まった書物になったという体裁である。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーは器械が役に立ちさえすれば体裁などは構わなかった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうやらランプの体裁だけはしている。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じ思想が、支那服を着ていてそうして栄養不良の漢学者に手を引かれてよぼよぼ出て来たのではどうしても理解が出来なかったのに、それが背広にオーバー姿で電車の中でひょっくり隣合ってドイツ語で話しかけられたばかりに一遍に友達になってしまったような体裁である。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そりゃそうだろうけど、菜物なんかこの前に植えちゃお客にも見えるし、体裁が悪い。",
              "citation": {
                "source": "老夫婦",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間ならばざっと荷物をこしらえて試みにちょっとさげてみたというような体裁であった。",
              "citation": {
                "source": "蜂が団子をこしらえる話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "体裁よく飾りつけられた屋内のさまざまなものが、片ッぱしからめちゃめちゃに放り出された。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「馬鹿々々しい上ッつらの体裁ばかり作りやがって、支柱をやらんからへしゃがれちゃったんじゃないか！",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉田はその話相手に捕まっているのが自分なので体裁の悪さに途方に暮れながら、その女を促して道の片脇へ寄せたのであったが、女はその間も他へ注意をそらさず、さっきの「教会へぜひ来てくれ」という話を急にまた、「自分は今からそこへ帰るのだからぜひ一緒に来てくれ」という話に進めかかっていた。",
              "citation": {
                "source": "のんきな患者",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つには、彼自身体裁屋なので、年頃の信子の気持を先廻りしたつもりであった。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その次に磁石の説が来るのは今の科学書の体裁と比較して見れば唐突の感がある。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、同じような体裁で、同じような内容の雑誌が、発音まで似かよったいろいろの名前で陳列されている。",
              "citation": {
                "source": "丸善と三越",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "発音は自己流でいいかげんのものであるが、およその体裁だけはわかるであろう。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐吉さんが何も飲まないのだから、私一人で酔っぱらって居るのも体裁が悪く、頭がぐらぐらして居ながらも、二合飲みほしてすぐに御飯にとりかかり、御飯がすんでほっとする間もなく、佐吉さんが風呂へ行こうと私を誘うのです。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見えすいたお体裁に対するたたかいです。",
              "citation": {
                "source": "美男子と煙草",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、抜け目の無い男で、「オベリスク」の編集は世間へのお体裁、実は闇商売のお手伝いして、いつも、しこたま、もうけている。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうたくさん、なんて断っているお嬢さんや何か、あれは、ただ、色気があるから体裁をとりつくろっているだけなのよ。",
              "citation": {
                "source": "グッド・バイ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に体裁の上からでも毒々しい広告欄をのけてしまったら今の新聞はもう少し気持ちのいいものになりはしないだろうか。",
              "citation": {
                "source": "一つの思考実験",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも曲の体裁を知るためと思って我慢して聞いていると、店員が何かぐあいでも直すためか、プラグを勝手に抜いたりまたさしたりするのでせっかくのシンフォニーは無残にもぶつ切れになってしまった。",
              "citation": {
                "source": "路傍の草",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が死んでから、兄は兄だけの才覚をして店の体裁を変へて見たりした。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「全大地において、一疋も体裁よき彼らはあらず。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえ見た姿は体裁よからずとも、彼らは兎に角、光明裡に在る。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して、心を腐らし、自分から宇宙に遍満する光明方面を遮って暮している人間は、一見体裁よくとも、生命の底の幸福や逞しさに欠けている惨めな救われ難い存在であるというのです。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "サの字が無ければ、今夜も優柔しく、と言えば体裁が可い、指を銜えて引込もうと、屹と思って熟と視ると、波打つ胸の切符に寄せる、夕日に赤い渚を切って、千鳥が飛ぶように、サの字が見えた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来る丈け体裁よく、出来る丈け有利な方法が取り得られるならば、まづ其方法に出る。",
              "citation": {
                "source": "瘢痕",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで旦那が、御覧じやした通りの体裁、や、抜けつ潜りつ、こやの軽いのにゃ飽倦ッちゃって、二人とも大汗になって、トド打掴え、掛けたのを外しにかかると、俯向けに倒れながら、まだ抵抗う気だ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏道小町はさもなかったそうでござりますが、通一筋道は、まるで、諸道具、衣類、調度が押流されました体裁、足の踏所もござりませなんだ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（とても娑婆じゃないからな、どうだ、まるで白い鰻の、のたくッている体裁じゃないか、そういう自分は何か。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
