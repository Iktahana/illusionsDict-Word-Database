[
  {
    "uuid": "5fbce132-18fe-5135-a13b-cc126aac0dae",
    "entry": "体裁",
    "reading": {
      "primary": "ていさい",
      "alternatives": [
        "たいさい"
      ],
      "is_heteronym": false
    },
    "grammar": {
