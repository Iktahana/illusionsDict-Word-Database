        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ちと人が悪いようなれども一切｜只にて拝見したる報いは覿面、腹にわかに痛み出して一歩もあゆみ難くなれり。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間と人間とが覿面に出合ったのだ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には覿面その狂いが酬って来て、今さら後悔の臍を噛むようなことが沢山あります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬で峠を越そうなぞと強がった天罰｜覿面、谷へ落ちなかったのが何よりのめっけもの。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "この井戸は水の質も良く、水の量も比較的に多いので、覿面に苦しむほどのことはなかったが、一日のうちで二時間｜乃至三時間は汲めないような日もあった。",
              "citation": {
                "source": "郊外生活の一年",
                "author": "大久保にて",
                "note": "青空文庫"
              }
            },
            {
              "text": "だって、覿面に綺麗な鬼になったじゃあないか。",
              "citation": {
                "source": "眉かくしの霊",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等が要らざる詮議立てして、罪も無き罪人を作る閑暇に、わが如き大悪人を見逃がしたる報いは覿面。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝等男女こそ覿面の因果応報、思ひ知らずやと云ひも終らず、馬十の脳天を唐竹割にし、奈美女の死骸を打重ねて止刺刀を刺し、その上より部屋の中の珍宝、奇具を片端より覆へして打重ねたるまゝ本堂の下を潜りて外に出で、血刀と衣服を前なる谷川に洗ひ浄めて、悠々と方丈に帰り来りぬ。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "因果｜覿面バイ』『オイオイ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天に口なし、鼻を以て云わしむる」という事を覿面に証拠立てるものであるという事が、もし本当に人類全体にわかったらどうでしょう。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "覿面に此の効果はあがって謡言は終熄したが、要するに今後の問題は、持久戦に漸く倦んだ士気を如何に作興するかにある。",
              "citation": {
                "source": "小田原陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "時折挟んだ銀貨や牡蠣といった脱線話は、譫言と思わせるのには覿面だ。",
              "citation": {
                "source": "瀕死の探偵",
                "author": "THE ADVENTURE OF THE DYING DETECTIVE",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは覿面に死の天使を見たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "又この未曾有なもの、唯一なものが、覿面にそれを見てゐる人の心を、どんなに動かし狂はすかといふことも、とても想像せられまい。",
              "citation": {
                "source": "うづしほ",
                "author": "A DESCENT INTO THE MAELSTROM",
                "note": "青空文庫"
              }
            },
            {
              "text": "覿面、その剃刀で殺ったですでな。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "絵も覿面だから解りました。",
              "citation": {
                "source": "雪柳",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "死霊の祟りよりもこの祟りの方が覿面に怖く思われて、文字春はまた蒼くなった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "津の国屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い夜の頃でも、朝の眠たさが覿面に自分を窘めるにも拘はらずうそ／＼と歩いて見ねば臭い古ぼけた蚊帳の中に諦めて其身を横たへることが出來ないのである。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し報いは覿面で俄然三十六番に落ちてしまつた。",
              "citation": {
                "source": "開業醫",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "事によったら例のファキイルと云う奴がアルラア・アルラアを唱えて、頭を掉っているうちに、覿面に神を見るように、神経に刺戟を加えて行って、一時幻視幻聴を起すに至るのではあるまいか。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは先ず第一に、不学・不心得の報いを覿面に受けているためで、十年も経つ時はその人も必ず自ら目覚めて後悔するようになる。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくては如何なる言をもて夫はこれに答へんとすらん、我はこの理の覿面当然なるに口を開かんやうも無きにと、心｜慌てつつ夫の気色を密に窺ひたり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の野卑な、狡猾な行為が、子の上に覿面に報いて来たことが、恐ろしかった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　この言葉は覿面だった。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "英漢數教授の利目は覿面で、その看板が揚がると、三四名の學生がどやどやとはいつて來ました。",
              "citation": {
                "source": "詩集の後に",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪魔立て致すとは何を暴言申さるるか、霊地の庭先荒さば仏罰覿面に下り申すぞッ」「控えさっしゃい。",
              "citation": {
                "source": "旗本退屈男　第六話",
                "author": "身延に現れた退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "この井戸は水の質も良く、水の量も比較的に多いので、覿面に苦しむほどのことはなかったが、一日のうちで二時間ないし三時間は汲めないような日もあった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　作家がその描寫の對象に愛情を失ふと、てきめんにこんなだらしない文章をつくる。",
              "citation": {
                "source": "道化の華",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "効果はてきめんだった。",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ、飲みすぎ食べすぎのたたりてきめん、身心がだるい、熱い溢れる湯にはいりたくなり湯田へ行かうかとも思つたが止めにして戻る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
