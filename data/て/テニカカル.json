    "definitions": [
      {
        "index": 1,
        "gloss": "to fall into someone's hands",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
