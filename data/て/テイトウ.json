[
  {
    "uuid": "24a81936-555f-58fe-8102-83dcffe9cf9a",
    "entry": "低頭",
    "reading": {
      "primary": "ていとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
