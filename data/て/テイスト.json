        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "五分刈頭の学者肌の人柄で、高島屋が、牧野さんはドラマテイストだと紹介すると、本郷氏は凝つと私の顔を見て鷹揚にうなづいた。",
              "citation": {
                "source": "文学的自叙伝",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五分刈頭の學者肌の人柄で、高島屋が、牧野さんはドラマテイストだと紹介すると、本郷氏は凝つと私の顏を見て鷹揚にうなづいた。",
              "citation": {
                "source": "文學的自叙傳",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ゑかき」も變だし「アーテイスト」「ペインター」もいけない。",
              "citation": {
                "source": "砂がき",
                "author": "竹久夢二",
                "note": "青空文庫"
              }
            },
            {
              "text": "八郎は、プラグマテイストをもつて自らを任じてゐる洋画家である。",
              "citation": {
                "source": "ゾイラス",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "フロオベエル以前の唯一のラルテイストだつたメリメエさへスタンダアルに一籌を輸したのはこの問題に尽きてゐるであらう。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、更に「范の犯罪」はモオパスサンの「ラルテイスト」（？",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ラルテイスト」の主人公はやはり女の体のまはりへナイフを打ちつける芸人である。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、「ラルテイスト」の主人公は如何に女を殺さうとしても、多年の熟練を積んだ結果、ナイフは女の体に立たずに体のまはりにだけ立つのである。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども西鶴の「子供地蔵」は勿論、モオパスサンの「ラルテイスト」も志賀直哉氏の作品には何の関係も持つてゐない。",
              "citation": {
                "source": "文芸的な、余りに文芸的な",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわゆるアテイストではなくて、いわば宗教不感症なのである。",
              "citation": {
                "source": "チェーホフ序説",
                "author": "――一つの反措定として――",
                "note": "青空文庫"
              }
            }
          ]
        }
