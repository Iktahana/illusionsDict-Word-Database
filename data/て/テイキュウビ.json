        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふたりは、はじめての定休日に、クロを見にきたのでした。",
              "citation": {
                "source": "正坊とクロ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その翌日は食堂の定休日にあたるというので、お三輪もやや安心して、東京の方へ向う支度をした。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずそこには「定休日」と書いた漆塗りの札も下つてゐた。",
              "citation": {
                "source": "歯車",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずそこには「定休日」と書いた漆塗りの札も下っていた。",
              "citation": {
                "source": "歯車",
                "author": "芥川竜之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "中日というのは何をする日か私ははっきり知らないが、何んでも死んだ父の話によると、この日は地獄の定休日らしいのである、そしてこの日の落日は、一年中で最も大きくかつ美しいという事である。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の如き不精者がたまたま散髪屋へ行くと本日定休日という札が掛けてある。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎月の例によって、本日は定休日だから、オレの頭を持ってきてやった」「オレはヘタだよ」「承知の上だ」「料金が高いぜ」「承知の上だよ。",
              "citation": {
                "source": "町内の二天才",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "記代子さんに急用ができたんですけど、記代子さんがあいにく会社をサボッてとか、定休日でとか、そんな風に言うのよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "また月二回の全員定休日のほかに、交替でさらに月一回の休みをつくり、これでやや改善されたが、毎年四月、十二月などのとりわけ忙しい月はまだまだ過労の様子が見られ、さらに進んで一週一日の休みと勤務時間短縮の必要が考えられるのである。",
              "citation": {
                "source": "一商人として",
                "author": "――所信と体験――",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞が朝日その他月曜は二頁きりだったのが今度からは毎月二十五日定休日が出来るそうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四二年（昭和十七年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからたとえば、都電のある東京光景を、消える前に可能なかぎり撮ってほしい」「撮りますよ」「楽しみにしてる」３　直子の喫茶店は今日は定休日だ。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "定休日、とだけ書いた小さなカードが、ドア・ガラスの枠に差し込んであった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「来週の定休日に」「今日とおなじ時間に店へ来て」「雨が降っても撮ります」　彼は玄関へ歩いた。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶店の定休日ごとに撮影をおこなった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして次の定休日に、客のいない喫茶店のテーブルで、直子とふたりで点検した。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "その四十枚を一点ずつ黒い台紙に貼った原田は、九月第一週の定休日の夕方、直子の喫茶店へ持っていった。",
              "citation": {
                "source": "七月の水玉",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっきおっしゃったとおり、定休日にでもゆっくり会いましょう」「この店もご贔屓に」　そう言った福山はカウンターの端までいき、外へ出て来た。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかほかの場所がよろしければ、僕はどこへでも出向きます」　福山の提案を受けて、日比谷は定休日の店へいくことにした。",
              "citation": {
                "source": "道順は彼女に訊く",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "月一回を小説定休日としてしまう。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
