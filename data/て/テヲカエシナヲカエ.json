        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そこへＣやＤやＥやＦやＧやＨやそのほかたくさんの人物がつぎつぎに出て来て、手を変え品を変え、さまざまにＢを中傷する。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を変え品を変え、実にいろんな罰金を彼女は思いついたものである！",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお言葉を聞いて私は立ち去ります」　とも、手を変え品を変え宮のお心を動かそうとして説く衛門督であった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を変え品を変えして今はこの教師をうんと言わせさえすれば、万事うまく行くとしているその親たちに、彼の防備は役立ちそうにも見えなかった。",
              "citation": {
                "source": "白い壁",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "……では独身となったと知ると、同じような種類の若武士どもが、手を変え品を変え立ち代わり入り代わり！",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そいつが手を変え品を変えて、百ぺん千べん、いつ見ても種は一つことの繰返しだ。",
              "citation": {
                "source": "かもめ",
                "author": "ЧАЙКА",
                "note": "青空文庫"
              }
            },
            {
              "text": "お島の身許は手を変え品を変えて調べたが、芸人のくせに恐ろしく生真面目で一と晩も家を明けたことがねえ」「ヘエ――」「あれは名人というものだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "八人芸の女",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を変え品を変えお前を苦しめるやつは、私が元気でいる限り、恐らく間違いなく私がじわじわと焼き殺してやる！",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親が心配して、兄のふさいでいる訳を、手を変え品を変え尋ねても、少しも打開けません。",
              "citation": {
                "source": "押絵と旅する男",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
