[
  {
    "uuid": "b8c65bb0-b5a7-5cb3-a308-9b33d693116d",
    "entry": "手踊り",
    "reading": {
      "primary": "ておどり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
