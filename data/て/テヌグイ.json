        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それから、江戸時代の神社仏閣の御手洗にかけてある奉納手ぬぐいを、至るところの休み茶屋や、室で見ることである。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しびっこで恐ろしく背の高いやせこけた老翁であったが、破れ手ぬぐいで頬かぶりをした下からうすぎたない白髪がはみ出していたようである。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、わずかに数本の箸と手ぬぐいとだけで作った屈伸自在な人形に杯の笠を着せたものの影法師を障子の平面に踊らせるだけのものであった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "箸と手ぬぐいの人形の影法師から幻燈映画へはあまりに大きな飛躍であった。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "英語の先生のＨというのが風貌魁偉で生徒からこわがられていたが、それが船暈でひどく弱って手ぬぐいで鉢巻してうんうんうなっていた。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "くりくり坊主の桃川如燕が張り扇で元亀天正の武将の勇姿をたたき出している間に、手ぬぐい浴衣に三尺帯の遊び人が肱枕で寝そべって、小さな桶形の容器の中から鮓をつまんでいたりした。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "言葉どおりにぼろぼろの着物をきて、頬かぶりをした手ぬぐいの穴から一束の蓬髪が飛び出していたように思う。",
              "citation": {
                "source": "蒸発皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり暑いので耳たぶへ水をつけたり、ぬれ手ぬぐいで臑や、ふくらはぎや、足のうらを冷却したりする安直な納涼法の研究をしたこともあった。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手甲、脚絆、たすきがけで、頭に白い手ぬぐいをかぶった村嬢の売り子も、このウルトラモダーンな現代女性の横行する銀座で見ると、まるで星の世界から天降った天津乙女のように美しく見られた。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぬぐい一筋でも箸一本でも物は使いよう次第で人を殺すこともできれば人を助けることもできるのは言うまでもないことである。",
              "citation": {
                "source": "さるかに合戦と桃太郎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなもなんだか、その男も三郎も気の毒なようなおかしながらんとした気持ちになりながら、一人ずつ木からはねおりて、河原に泳ぎついて、魚を手ぬぐいにつつんだり、手にもったりして家に帰りました。",
              "citation": {
                "source": "風の又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはちょうど手ぬぐい浴衣もあればつづれ錦の丸帯もあると同様なわけであって、各種階級の購買者の需要を満足するようにそれぞれの生産者によって企図され製作されて出現し陳列されているに相違ない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日など泥まみれの足を手ぬぐいでごしごしふいて上がるのはいいが絹の座ぶとんにすわらされるのに気が引けた記憶がある。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朝顔や手ぬぐい掛けにはい上る」という先生の句があったと思う。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その手ぬぐい掛けが六畳の縁側にかかっていた。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぬぐいに顔を包んでいながらも、それが年の若い色白の女であることを元八は認めたので、暫くたたずんで彼女のうしろ姿を見送っていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると敵の中から、ひとりが手ぬぐいを棒の先につけて、こちらへやってきました。",
              "citation": {
                "source": "草",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ手ぬぐいで足から腰をふいて、パンツとズボンをはいた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳一君と久助君は、めいめいの手ぬぐいを提供して、兵太郎君のかた足ずつをふいた。",
              "citation": {
                "source": "川",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "食事をして風呂にはいって、肩まで湯の中に浸って、そうして湯にしめした手ぬぐいを顔に押し当てた瞬間に、つぶった眼の前に忽然と昼間見た活動女優の大写しの顔が現われた、と思うとふっと消えた。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白い手ぬぐいを眉深にかぶった下から黒髪が額にたれかかっている。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "通りがかりの行商人などがよく門前で荷をおろし、門流れで顔を洗うたぬれ手ぬぐいを口にくわえて涼んでいる事がある。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "手ぬぐい地の肌着から黒い胸毛を現わしてたくましい腕に木槌をふるうている。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白地の手ぬぐいをかぶった後ろ姿、一村の問題に登るだけがものはある。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうそうこの前の稲刈りの時にもおれが鎌で手を切ったら、おとよさんは自分のかぶっていた手ぬぐいを惜しげもなく裂いて結わいてくれた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「省作さん、流しましょうか」「ええ」「省作さんちょっと手ぬぐいを貸してくださいな」　おとよさんは忍び声でいうので、省作はいよいよ恐ろしくなってくる。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "省作は手ぬぐいをおとよさんに貸してからだを湯に沈めている。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとよさんは「ありがとうございました」と小声でいうて手ぬぐいを手渡しながら、一層かすかな声で「省作さん」というた。",
              "citation": {
                "source": "隣の嫁",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆しぼりの手ぬぐいをほおかむりにして、歌もうたわずただ黙もく掃除している。",
              "citation": {
                "source": "告げ人",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢野はおっくうそうに物をいいながら、はかまの腰なる手ぬぐいをぬき、足袋のほこりをはたいて上へあがった。",
              "citation": {
                "source": "廃める",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
