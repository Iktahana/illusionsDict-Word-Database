        "examples": {
          "standard": [
            {
              "text": "彼は車の修理に関してはベテランのテクニシャンだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "システムに障害が発生したため、すぐにテクニシャンを呼んで対応してもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "この精密機械の組み立てには、熟練したテクニシャンの手が必要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "わずかに小市民のテクニシャン達の一握りが、多少感傷的な技術礼讃をやっているにすぎない。",
              "citation": {
                "source": "技術的精神とは何か",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "処が又大学アカデミーは、文化的技術は有っていても使い途が明らかになっていないから、盲目的なテクニシャンしか産まない。",
              "citation": {
                "source": "私の見た大学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に、彼、犯人氏はテクニシャンでさ。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
