        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女は「お伯母さまが、なにもかにも奪ってってしまいなさるのだわ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうぞ私をあなたの所へ連れてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか私を連れてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか私をあなたのところへ連れてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうか私をあなたの所へつれてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「北の青いお星さま、あなたの所へどうか私を連れてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「東の白いお星さま、どうか私をあなたの所へ連れてって下さい。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてって、来やうとしたから来たんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "きっとここから落ちればすぐ北風が空へつれてってくれるだろうね。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "政夫さん、一所に連れてって下さい。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "連てってやろうか」　呉清輝は、小鼻でくッくッと笑って、自分の所有物を纏めた。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どっちへでもいい、ええかげんで連れてって呉れよ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「愉快ね、軍曹が銃を持ってって土匪になるって、愉快ね。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　古江の鬚面は焚き火で紅くほてっていた。",
              "citation": {
                "source": "まかないの棒",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうしてって、来ようとしたから来たんです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四「あの、電車の切符を置いてってくださいな」靴の紐を結び終わった夫に帽子を渡しながら、信子は弱よわしい声を出した。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり人造でもマーブルか、乳色ガラスのテーブルの上に銀器が光っていて、一輪のカーネーションでもにおっていて、そうしてビュッフェにも銀とガラスが星空のようにきらめき、夏なら電扇が頭上にうなり、冬ならストーヴがほのかにほてっていなければ正常のコーヒーの味は出ないものらしい。",
              "citation": {
                "source": "コーヒー哲学序説",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はたと困惑、濡れ鼠のすがたのまま、思い設けぬこの恥辱のために満身かっかっとほてって、蚊のなくが如き声して、いま所持のお金きっちり三十銭、私の不注意でございました。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            }
          ]
        }
