        "examples": {
          "standard": [
            {
              "text": "停戦協定の締結により、長年の内戦に終止符が打たれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "交渉の結果、両勢力間で新たな停戦協定が結ばれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "停戦協定が破られ、再び武力衝突が発生する危険が高まっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "時の広田外相は同月五日の閣議に於て云っている、「今回の事件は先の北支停戦協定違反事件と異り、純然たる外交交渉案件である故、専ら外交当局をして折衝せしめている。",
              "citation": {
                "source": "世界の一環としての日本",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "広田外相は五日の閣議に於て云っている、「今回の事件は先の北支停戦協定違反事件と異り、純然たる外交交渉案件である故、専ら外交当局をして折衝せしめている。",
              "citation": {
                "source": "社会時評",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ソ停戦協定成る、安心した。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
