[
  {
    "uuid": "ad87eae0-4914-50d0-8c63-6395c2bb2a67",
    "entry": "帝座",
    "reading": {
      "primary": "ていざ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "imperial throne",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "是より先に霊台奏す、文曲星帝座を犯す急にして色赤しと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "既に倒れたる帝座は、又起ちてペトルスの椅子（法皇座）となり、天下の王者は徒跣してこゝに來り、その下に羅拜せり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれこそは此世の名譽といふ名譽が、只った一人王樣となって、坐る帝座ぢゃ。",
              "citation": {
                "source": "ロミオとヂュリエット",
                "author": "ROMEO AND JULIET",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に穂先を逆に返して帝座の真中を貫けとばかり抛げ上げた。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり、次代の天皇たる資格のお方が出直されるまで、仮りに帝座に即いて、待つてゐられるのである。",
              "citation": {
                "source": "神道に現れた民族論理",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし門下の松前という武士には、まだ天文未熟のためか、五帝座を貫いている不吉の赤気も、五諸侯星座の動揺しているのも、観望することが出来なかった。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、ご覧」と儒者風の人物、「五帝座の中心｜黄帝星が、幸臣星のために犯されようとしている。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『幸臣星は五帝座の東北、親愛の臣を主る、明きらかなればすなわち吉、罔なればすなわち凶』ところで今は罔なのだ。",
              "citation": {
                "source": "任侠二刀流",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今度、自分が都へ上ったのも、その伝献の荷駄について上洛いたしたので、無事お役を果したので、帰り途だけ閑暇を賜わって、ひとり見物がてら仙台までもどる途中でござる」　といい、また――「諸侯のうちで、城内に、帝座の間を設らえてあるのは、わが青葉城があるばかりでござろう。",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "青葉城に、帝座の間をおき、瑞巖寺に王座をしつらへておいたなど、政宗のあたまには、將軍家はお人形だつた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばしのほど」　列を離れて出た宰相の趙哲、参議の文彦博のふたりが、帝座に伏して奏上した。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "孔明を迎えて蜀を征し、三国の一方を占めて帝座にのぼった人物。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "今や天下多事、よろしくこの際ただ今の天子に代うるに、陳留王をもってし、帝座の廃立を決行したいと考えるが、いかがあろうか。",
              "citation": {
                "source": "三国志",
                "author": "桃園の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると侍従の一人が、「彼らも、帝座の重きことはわきまえておりましょう。",
              "citation": {
                "source": "三国志",
                "author": "群星の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏切者どもめ」　いかにして先頃の恥をそそごうかと、おごそかな帝座に在って、時々、爪を噛んでいた。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときに、張飛の子｜張苞が、帝座の下に来て、かく告げた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝座のあたりを守る白旄黄鉞、また黄羅の傘蓋まで、ことごとく凍って、水晶の珠簾が揺ぎ進むようだった。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "辛毘、あざなは佐治、これは潁州陽※の生れ、大才の聞え夙にたかく、いまや魏主曹叡の軍師として、つねに帝座まぢかく奉侍している。",
              "citation": {
                "source": "三国志",
                "author": "五丈原の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして再び貴公が都に帰って、帝座の周囲を鼓舞する日のあらんことを、神かけて祈る。",
              "citation": {
                "source": "私本太平記",
                "author": "婆娑羅帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりは、“幕府、伐つべし”“まつりごとを、王朝の古に復せ”　となす、同志的な結合をもつ後醍醐の帝座にすれば、先帝の遺臣など、いわば水に油であったのである。",
              "citation": {
                "source": "私本太平記",
                "author": "みなかみ帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なおまだ一｜刻の名残りの酒もりが、帝座に武士も交じえて酌まれていた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "したが、その分らぬ小智恵では、生じ帝座の繞りへ近づかなんだ方が、かえってよかったことかもしれぬ。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "御警固の儀も、ここからは、それがしの手を離れて、隠岐の配所における一切まで、これなる清高が代って、朝夕、勤侍つかまつることと相なりますゆえ、道誉同様に、何なと仰せつけ下しおかれますように」　と、警固引き継ぎの言上とともに、清高を、帝座の人々へひきあわせた。",
              "citation": {
                "source": "私本太平記",
                "author": "世の辻の帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "直々の面語も苦しゅうはないぞ」　密使の岩松吉致は、その晩、帝座に召されておそくまでさまざまな下問にこたえていた。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝座といっても、廃寺の一院を補修したにすぎない行宮だ。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "根気よく、帝座の灯のあたりをうかがいながら、「はてな」　と、もう幾足かを忍ばせて行った。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "このままお船の帝座を、自領の阿波ノ国へお迎えしたいというのである。",
              "citation": {
                "source": "私本太平記",
                "author": "八荒帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "美々しい回しをつけた力士が堂々としてにらみ合っていざ組もうとすると、衛士だか行司だかが飛び出して来て引き分け引き止める。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はあれを覚えてていざとなったら母もだしにつかいかねなかった……」「そんなに私に逢わなけりゃならなかったの」「嫌だ。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛のごとく吼ゆるもの、　図体の憎々しく大きく、群獣をぬいて高く怒号するもの、　うそぶき、笑い、闊歩するもの、　孱弱く疲れていざり寄るもの、　ごろりと仰向きに臥ている牡、右の前｜鰭で、はたりはたりと煽いでいるもの、（暑いんだな、あいつ鰭を団扇にしているんだ。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
