          "standard": [
            {
              "text": "ジャズバンドのライブで、テナーサックスのソロが会場を沸かせた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼はテナーサックスを吹くために、日々練習を重ねている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "渋い音色が魅力のテナーサックスは、多くのファンを持つ楽器だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "高志が音楽室に入ってきたとき、慶一は、もうスネアはやめにして、なにか管楽器にしよう、テナーサックスか、それがダメなら、アルトでもいい、と考えていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "正装をしたセッション・ミュージシャンたちが、テナーサックス、トランペット、トロンボーン、ヴァイオリン、チェロをかかえて、準備をしている。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
