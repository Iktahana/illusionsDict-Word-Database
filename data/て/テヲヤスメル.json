    "definitions": [
      {
        "index": 1,
        "gloss": "to rest (from work, studying, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」「急用なら中止しましょう」と紳士は一寸手を休める。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "働きの手を休めるわけには行かないのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉蔵が其と見て、「やあ」と云って仕事の手を休めると、「やあ」と若者も同じ様に云って、吉蔵の傍へ停ち止まった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヨロヨロの四分音符にかき消されて、そのことばはだれの耳にもとどかなかったが、全員が手を休めるチャンスがきたのを知って、即座に静寂がおとずれた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたし我慢をしているから」　彼はそう云われると、不覚にも涙が出て来て、撫でてる腹の手を休める気がしなくなった。",
              "citation": {
                "source": "春は馬車に乗って",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉吉はなか子の上に馬乗りになつてせいせい云つてゐたが、胸を締めてゐた両の手を休めると、お互ひに森となつて、よくお化けだお化けだと云つてゐたことを二人とも不図思ひ出してゐたのだ。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お住は庖丁の手を休めるなり、孫の顔を見つめずにはゐられなかつた。",
              "citation": {
                "source": "一塊の土",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、わたしの内にある祖先の血の弱さよ、はかなさよ、明方の霜の置く木の箱の家の中で、わたしは鐘の声を聞きながら、じつと滅入つて筆の手を休める。",
              "citation": {
                "source": "晶子詩篇全集",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を休めるとき、あの人を思ひだす、とても苦しい。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代へて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、手を休めると、とつぜん愉しげに笑ひだした。",
              "citation": {
                "source": "麓",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "手を休めるとき、あの人を思いだす、とても苦しい。",
              "citation": {
                "source": "戯作者文学論",
                "author": "――平野謙へ・手紙に代えて――",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か相当の自信がなければ、かりにも一流指南の看板は出せないはずと、少しも軽蔑の色なく慇懃に挨拶をしますと、おやじ、「さあ、どうぞお通りなさい」と言ったが、自分は少しも絵馬描きの手を休めるのではありません。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋の主人は馬の脚を膝に載せたままで、車が勢よく走りすぎるのを見ながら、手を休める。",
              "citation": {
                "source": "驛傳馬車",
                "author": "アーヴィング",
                "note": "青空文庫"
              }
            },
            {
              "text": "鍛冶屋は、馬車が通ると、馬の踵を両膝に抱きこんだまま、手を休める。",
              "citation": {
                "source": "駅馬車",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の近付く跫音を村の衆位に思っていたのであろう、何気なくこっちを見ておどろいたように鎌の手を休める。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "書く手を休めると、物音もやむ。",
              "citation": {
                "source": "博物誌",
                "author": "HISTOIRES NATURELLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィリップは手を休める。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私がポンプの手を休めると直ぐまたぐるりと丸い青空になった。",
              "citation": {
                "source": "夢幻泡影",
                "author": "外村繁",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが一日でも手を休めるなら、なお大きな苦痛が生活に迫る。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫長も三人の漕ぎ手も、交代で漕ぐ手を休める間に、服をきた。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「弁信さん」　お雪が呼ぶと、「はい」「茂ちゃんもごらんなさい、こんなに卒都婆が斬れていましたよ」「ええ」　二人はいい合わせたように栗を数えた手を休めると、お雪は卒都婆を縁の上へ置いて、「誰が悪戯をしたんでしょう」といって、茂太郎の面を見ると、「あたいは知らないや」　茂太郎がいいわけをする。",
              "citation": {
                "source": "大菩薩峠",
                "author": "無明の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はこれを引張り上げ、それからドサンと落すのだが、それをやる途中、恐しく気味の悪い一種の歌を歌う為に、手を休める。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "一時間ほど経ち、ふと手を休めるとけたたましい電話のベルが鳴る。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
