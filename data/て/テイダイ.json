[
  {
    "uuid": "9e49d66e-600d-5a10-8929-69512fb97304",
    "entry": "帝大",
    "reading": {
      "primary": "ていだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
