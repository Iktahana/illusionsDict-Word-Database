        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "それは、今日世上に、家庭問題を論究しつつある人々の内にも、必しも不円満な家庭中の人｜許りは居るまい、人の模範となるべき家庭を保って居る人も、多いであろうけれども、実行の伴わない論者も、決して少くはあるまいと思う。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "円満な家庭中の人が、却って不円満な家庭の人から講釈いわるるような、奇態の事実がありはせまいか。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "五日、甲※、将軍家、諸人の庭中に言上する事を聞かしめ給ふ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尾を地へ着けないで、舞いつつ、飛びつつ、庭中を翔廻りなどもする、やっぱり羽を馴らすらしい。",
              "citation": {
                "source": "二、三羽――十二、三羽",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭中心であった近藤氏の家庭では、夫人は一家の太陽であった。",
              "citation": {
                "source": "大島が出来る話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お父様がお庭中をすっかり掘り返して、畠にしておいでになります。",
              "citation": {
                "source": "青水仙、赤水仙",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つね子さんも、お月さんの国へ　もう帰らずにここのお庭の兎におなり草履切れたらまた買つてあげよう赤い簪また買つてあげようと、お庭中うたつて歩きました。",
              "citation": {
                "source": "つね子さんと兎",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "子兎もつね子さんの後について、お庭中うたつて歩きました。",
              "citation": {
                "source": "つね子さんと兎",
                "author": "野口雨情",
                "note": "青空文庫"
              }
            },
            {
              "text": "結婚生活はまさに至福で、初めて所帯主になったこともあり、私の熱意はすっかり家庭中心に注がれていた。",
              "citation": {
                "source": "ボヘミアの醜聞",
                "author": "A SCANDAL IN BOHEMIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙洞忠勤のおんむかし、九夏三伏のあつさにも、あせをのごひて終日庭中にかしこまり。",
              "citation": {
                "source": "山家ものがたり",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥さんは性急な、しかし良家に育った人らしい調子で、「宅じゃこの通り朝顔狂ですから、小諸へ来るが早いか直ぐに庭中朝顔鉢にしちまいました――この棚は音さんが来て造ってくれましたよ――まあこんな好い棚を――」　と高瀬に話した。",
              "citation": {
                "source": "岩石の間",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "美事な孟棕の植込みを遠景にして、庭中に漫々とたたえた水のなかの岩組みに水晶｜簾の滝がかかっていて、ちょうどそれが薄暮であったので、青々した寒竹の茂みから燈籠の灯に透けて見えるのも涼しげであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は子供部屋の畳を取りかえると云って中庭中に、台を持ち出してひどい風に吹かれながら縫いなおしの表をさして居た。",
              "citation": {
                "source": "通り雨",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて雪が降りつもつて、庭中を蔽うて仕舞つた。",
              "citation": {
                "source": "夢",
                "author": "相馬泰三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭中に撒き散らして、火事のようにして下さい。",
              "citation": {
                "source": "花子の陳述",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭中を火事のようにするんです。",
              "citation": {
                "source": "花子の陳述",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔も鎧も血で真ッ赤、やうやく浜松の城に辿りつき、門をしめるな、開け放しておけ、庭中に篝をたけ、言ひすてゝ奥の間に入り、久野といふ女房に給仕をさせて茶漬を三杯、それから枕をもたせて、ゴロリとひつくり返つて前後不覚にねてしまつた。",
              "citation": {
                "source": "黒田如水",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "段々庭の様子に馴れて来た鳥はせまい竹垣の中では辛棒が仕切れなくなって大抵の時は、庭中にはねくり返って、縁側が土だらけになったり、食事をして居ると障子の棧の間から四つの首をそろえて突出したりする様になったので、日暮れに鳥屋に追い込む時の騒と云ったら、まるで火事と地震が一度に始まった様であった。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのね、今先ぐ家へ行って、庭中さがして御覧、　きっと、その眼玉がおっこって居るから。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苅あと青い芝生も、庭中の花と云う花も蔭に入り、月下香の香が高く一庭に薫ずる。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此が門ぼめの形式に移つて行つたので、寧、庭中・屋内のほめの儀が重んぜられて居たものと見るべきである。",
              "citation": {
                "source": "國文學の發生（第三稿）",
                "author": "まれびとの意義",
                "note": "青空文庫"
              }
            },
            {
              "text": "其｜守庭吏と爲るや、庭中に土豚を設けて、掃除を事とせず。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし目が働いているならば、ほうきの先のみすみす重くなる紙くずを庭中ころがしまわるのも不思議です。",
              "citation": {
                "source": "女中訓",
                "author": "羽仁もと子",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭へ出て見ると、白い、肥った、脚の短い豚が死物狂いに成って、哀しく可笑しげな声を揚げながら、庭中逃げ廻っていた。",
              "citation": {
                "source": "千曲川のスケッチ",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "池が一つあるために庭中が凉しくなるような気がするのよ。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "日当の悪い木立の奥に青白い紫陽花が気味わるく咲きかけるばかりで、最早や庭中何処を見ても花と云ふものは一つもない。",
              "citation": {
                "source": "花より雨に",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛞蝓の匐ふ縁側に悲しい淋しい蟇の声が聞える暮方近く、室の障子は湿つて寒いので一枚も開けたくはないけれど、余りの薄暗さに堪兼ね縁先に出て佇んで見ると、雨の糸は高い空から庭中の樹木を蜘蛛の巣のやうに根気よく包んで居る。",
              "citation": {
                "source": "花より雨に",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると空は無論隙間なく曇りきつて居ながら、日が照るのかと思ふ程に明くなつて、庭中の樹木は茂りの軽重に従つて陰影の濃淡を鮮かにし、凡ての物の色が黄昏の時のやうに浮き立つて来るので、感じ易い心は直様秋の黄昏に我れ知らず耽けるやうな果しのない夢想に引き入れられる。",
              "citation": {
                "source": "花より雨に",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "園丁五郎を呼び蝋梅芍薬瑞香など庭中の草木に寒中の肥料を施さしむ。",
              "citation": {
                "source": "断腸亭日乗",
                "author": "断膓亭日記巻之二大正七戊午年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
