          "standard": [
            {
              "text": "新しい技術開発のために、優れた提携先を探している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "提携先との連携を強化し、事業の拡大を図る。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "今回のプロジェクトでは、複数の提携先と協力して進める予定だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "これに先だってＲＣＡ社との技術提携に踏み切った日立製作所は、提携先の路線にもとづいてＩＢＭ機用に開発されたプログラムをそのまま利用できる互換路線をとった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "自由化に向けた業界再編以降も、グループを組んだ東芝と提携先のハネウェルとの意見調整に手間取った日本電気は、累積赤字を積み増していった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
