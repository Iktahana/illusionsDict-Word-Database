[
  {
    "uuid": "ee90be17-439e-5e2c-be11-88f5a59ba774",
    "entry": "鉄索",
    "reading": {
      "primary": "てっさく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cable",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鉱山も今日はひっそりして鉄索もうごいていず青ぞらにうすくけむっていた。",
              "citation": {
                "source": "十六日",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "土工夫の一行は、この小駅に降り、せまい構内を出るとすぐ足下にある谷に懸つてゐる鉄索の釣橋を列をなして渡り、樹林の中に分けて入つた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "当直下士官は、すっかり雨合羽に全身をつつみ、胴中を鉄索にしばりつけて、すっくと立っている。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "モーターで鉄索を廻し、それに小さいボックスをつるして、薪炭、米などの類を、三四里向うの村から持って来、持って行きするのである。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十度から四十五度の大傾斜六千尺を一条の鉄索に引かれて我我の車は疾走しつつ昇る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "右衛門の危難を救わんものと、鉄索の籠に打ち乗って走り参ったと申すことを後日両人より聞きましてござる」「感ずべき人達！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "上州峠の上州側には六林班の鉄索運転工場がある。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大方上州峠の途中にあるというお助小屋か、さもなくば鉄索運転の番小屋であろうと思う。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "延間峠の方へは一条の径とともに鉄索が通じている。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南を望むと鋸山から鳶岩を連ぬる支山脈が近く脚下に横たわり、鳶岩の右の肩には上州峠の頂上にある鉄索の小屋まで見えている。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六時頃峠の上の鉄索の小屋についた。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "六林班の鉄索運転所であろう。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "立ち聞きした様子では何でも番場島あたりに鉱山の派出所が新に建てられて、電話も其処まで通じているし、近く鉄索工事に取り掛る筈だという。",
              "citation": {
                "source": "黒部川奥の山旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十七字、季題という鉄索にしばられている俳句にあっては、或範囲内のことに限局されている。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            },
            {
              "text": "前に言った十七字・季という鉄索の下にある俳句では到底出来ない相談であることを要求する。",
              "citation": {
                "source": "俳句への道",
                "author": "高浜虚子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
