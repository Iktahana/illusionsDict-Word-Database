        "examples": {
          "standard": [
            {
              "text": "政府は、市場の安定化を図るため、農産物の停止価格を設定した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "停止価格が設定されたことで、生産者は一定の収入が保証された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "停止価格制度には、メリットとデメリットがある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "今は停止価格で片方７円か八円、マア十円どまりでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "元町へ、サノヘでネクタイ二本、輸入物だが停止価格で三円九十銭といふ安さ、籐のステッキを――これから大いに歩かねばならぬことで――買ふ、これも十五円ウィンナ製。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
