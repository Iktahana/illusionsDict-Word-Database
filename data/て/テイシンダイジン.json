    "definitions": [
      {
        "index": 1,
        "gloss": "Minister of Communications and Transportation (1885-1949)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
