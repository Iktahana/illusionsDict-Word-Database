        "examples": {
          "standard": [
            {
              "text": "低所得世帯を対象とした家賃補助制度が新設され、多くの申し込みが殺到している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "急激な物価高騰は、特に低所得の人々の生活を直撃しており、社会問題となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "低所得であっても、質の高い教育を受けられるような支援体制を整えるべきだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "もっとも進んだ国においてすら低所得グループは病気の蓄積所になっている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "パニオロのようなハワイ系の、どちらかといえば低所得の人たちがほとんどだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒人、農村、老人、低所得者たちが、豊かな中産階級の影に、とりのこされていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "都市と機械が勝ちを示していく日々の影で、農村、黒人、そして都市の低所得者たちが、とりのこされていった。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし政府が低所得層に助成金を出したいのなら――」　怒号で後は聞こえない。",
              "citation": {
                "source": "四日白魔",
                "author": "THE FOUR WHITE DAYS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
