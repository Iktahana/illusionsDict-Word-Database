        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地車のとどろと響く牡丹かな　牡丹という花は、夏の日盛りの光の下で、壮麗な色彩を強く照りかえすので、雄大でグロテスクな幻想を呼び起させる。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "空には秋のような日が照り渡って、地上には麦が実り、大鎌や小鎌を持った農夫たちが、至るところの畑の中で、戦争のように忙がしく働いている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "怒りて書物を投げすてひとり校庭の草に寢ころび居しがなにものの哀傷ぞはるかに彼の青きを飛び去り天日直射して　熱く帽子の庇に照りぬ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "河とは名ばかりの黄色き砂に水の気なくて、照りつく日のきらめく暑そうなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋の日がかんかん照りつけるので柿の葉が乾燥してじりじりと巻き上がるのでいつの間にかそっくりと雀を包んで動けないように縛ってしまう。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "右舷へ出ると西日が照りつけて、蝶々に結った料理屋者らしいのが一人欄へもたれて沖をぼんやり見ている。",
              "citation": {
                "source": "高知がえり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕合せに晴天が続いて毎日よく照りつける秋の日のまだなかなか暑かったであろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年時少年時黝い石に夏の日が照りつけ、庭の地面が、朱色に睡つてゐた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏血を吐くやうな　倦うさ、たゆけさ今日の日も畑に陽は照り、麦に陽は照り睡るがやうな悲しさに、み空をとほく血を吐くやうな倦うさ、たゆけさ空は燃え、畑はつづき雲浮び、眩しく光り今日の日も陽は炎ゆる、地は睡る血を吐くやうなせつなさに。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "輕く興奮してほてる顏を更に強い西日が照りつけて、丁度酒にでも微醉したやうな心持で、そしてからだが珍しく輕快で腹がいゝ工合に空つて居た。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　今迄かつと照り渡つてゐた初秋の空に僅か飛行船程の暗雲が浮んだ。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛍光のような幽美な光りが女神の身体から照り放たれ、その光りの輪廓は女神の身体が進めば闇に取り残され、取残されては急いで、進む女神の身体に追い戻る。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔は少し横向きになっていたので、厚く白粉をつけて、白いエナメルほど照りを持つ頬から中高の鼻が彫刻のようにはっきり見えた。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よだかはその火のかすかな照りと、つめたいほしあかりの中をとびめぐりました。",
              "citation": {
                "source": "よだかの星",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "西ぞらのちぢれ羊からおれの崇敬は照り返され（天の海と窓の日覆ひ。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）おれの崇敬は照り返され。",
              "citation": {
                "source": "圖書館幻想",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空梅雨に代表的な天気で、今にも降り出しそうな空が不得要領に晴れ、太陽が照りつけるというよりはむしろ空気自身が白っぽく光り輝いているような天候であった。",
              "citation": {
                "source": "ゴルフ随行記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝港内をこめていた霧が上がると秋晴れの日がじりじりと照りつけた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと没交渉に秋晴の太陽はほがらかに店先の街路に照り付けていた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "水のように澄みきった秋の空、日は一間半ばかりの辺に傾いて、僕等二人が立って居る茄子畑を正面に照り返して居る。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうへ、きちがひじみた太陽がむしあつく帽子の上から照りつけるので、おれはぐつたり汗ばんでゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なまじっかなこと云い出せないもの」　じりじりと照りつける陽の光と腹匍いになった塚の熱砂の熱さとが、小初の肉体を上下から挟んで、いおうようない苦痛の甘美に、小初を陥れる。",
              "citation": {
                "source": "渾沌未分",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "広東湾の白堊の燈台に過去の燈は消えかけて、ハッピーバレーの嶮峻にかかった満月が年少の同志の死面を照りつけた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに窓から見える病院の芝生の庭には一昨日のやうに、昨日のやうに、ぎらぎらした午後の太陽が照りつけ、處々に咲く松葉牡丹の花が陽炎の中に燃えるやうな紅を映してゐる、動く物一つない靜けさだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明りに照り反された、黒くたるんだ瞼の陰にありありと羞恥の色を見せながら、まぶしさうに私を見詰めた眼は深く凹んで、その奧には生活に疲れきつてゐるやうな暗い影が差してゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて彼が心は人々の知らぬ間に亡び、人々は彼と朝日照り炊煙棚引き親子あり夫婦あり兄弟あり朋友あり涙ある世界に同居せりと思える間、彼はいつしか無人の島にその淋しき巣を移しここにその心を葬りたり。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔なべてはしけく　よそほひて〕宮沢賢治なべてはしけく　　よそほひて暁惑ふ　　　　　　改札をならび出づると　　ふりかへる人なきホーム　　　陸の橋歳に一夜の　　　　旅了へしをとめうなゐの　　ひとむれに黒きけむりを　　　そら高く職場は待てり　　　春の雨",
              "citation": {
                "source": "〔なべてはしけく　よそほひて〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "見よ　此處に無用の石路傍の笹の風に吹かれて無頼の眠りたる墓は立てり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "平然と立ち上つて、狸の火傷にれいの唐辛子をねつたものをこつてりと塗る。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新火山のことだから、土の締まりは、しッくりしていない、むしろ危ッかしいほど、柔脆の肉つきではあるが、楽焼の陶器のような、粗朴な釉薬を、うッすり刷いた赤る味と、火力の衰えた痕のほてりを残して、内へ内へと熱を含むほど、外へ外へと迫って来る力が、十方無障碍に放射することを感ずる。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
