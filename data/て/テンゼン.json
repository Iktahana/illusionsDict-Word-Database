        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と、知つてか知らずか、さつきまでの醜體にも恬然とした表情で、何時の間にかきちんと身仕舞をととのへて、女は腰掛の上に坐り込んでゐた。",
              "citation": {
                "source": "女盗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻で」恬然として仲平は答えた。",
              "citation": {
                "source": "安井夫人",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろＦは珍らしい客だからね……」と、私は惰性で心にもないことを呟いて、恬然としてゐた。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "まっかになってうつむいていた姉娘の代わりに、それらの首の提供者であった小塚ッ原の獄門番人の見るからにけがらわしい中年の非人が、べろり舌なめずりをして恬然と答えました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "生首の進物",
                "note": "青空文庫"
              }
            },
            {
              "text": "でなくて誰が酔狂にこの寒さに斯んなものを……」と彼は恬然としてうそぶいた。",
              "citation": {
                "source": "スプリングコート",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は兎角何事をも明日に譲つて恬然としてゐたがる。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども強制的にさうした処に堕ち込んだ憐れむべき女でさへも食べる為、生きる為と云ふ動かすことの出来ない重大な自分のために恬然としてゐます。",
              "citation": {
                "source": "青山菊栄様へ",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "分からんのが神仏だ」　宇平の態度は不思議に恬然としていて、いつもの興奮の状態とは違っている。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "五百がどの位親切に世話をしたか、勝がどの位｜恬然として世話をさせたかということが、これによって想像することが出来る。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに安んじて恬然としていなくてはならない。",
              "citation": {
                "source": "余興",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "中から無腰の宇津木が、恬然たる態度で出て来た。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれはCliqueの名なのです」大村は恬然としてこう云った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰やらの書いたものに、人は夢の中ではどんな禽獣のような行いをも敢てして恬然としているもので、それは道徳という約束の世間にまだ生じていない太古に復るAtavismeだと云うことがあった。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれは Clique の名なのです」大村は恬然としてこう云った。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰やらの書いたものに、人は夢の中ではどんな禽獣のような行いをも敢てして恬然としているもので、それは道徳という約束の世間にまだ生じていない太古に復る Atavisme だと云うことがあった。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そんな事はないよ」と、木村は恬然として答えた。",
              "citation": {
                "source": "あそび",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩壇はかう言ふ薄田氏に古典主義者の名を与へながら、しかも恬然と薄田氏の拓いた一条の大道に従つて行つた。",
              "citation": {
                "source": "人及び芸術家としての薄田泣菫氏",
                "author": "薄田泣菫氏及び同令夫人に献ず",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の恬然と本名を署して文章を公にせる最初なり。",
              "citation": {
                "source": "学校友だち",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」東雲の煤ふる中や下の関　四、彼は昨日「小咄文学」を罵り、今日恬然として「コント文学」を作る。",
              "citation": {
                "source": "病牀雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞くものにして江戸つこならざらんか、面罵せらるるも猶恬然たらん。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "恬然とその上にかう書いたさうです。",
              "citation": {
                "source": "正岡子規",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "何となれば娼婦型の女人は啻に交合を恐れざるのみならず、又実に恬然として個人的威厳を顧みざる天才を具へざる可らざればなり。",
              "citation": {
                "source": "娼婦美と冒険",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまに短尺など送つて句を書けと云ふ人あれど、短尺だけ恬然ととりつ離しにして未だ嘗書いたことなし。",
              "citation": {
                "source": "わが俳諧修業",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒然としてこの改定案を示し、恬然として責任を果したりと做す、誰か我謹厳なる委員諸公の無邪気に驚かざらむや。",
              "citation": {
                "source": "文部省の仮名遣改定案について",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "況や妻子を養ふ以外に人生の意味を捉へ得ない、幸福なる天下の渡し守は恰も天才の情熱を犬の曲芸とでも間違へたやうに、三千年来｜恬然と「狂うて見せ候へ」を繰り返してゐる。",
              "citation": {
                "source": "金春会の「隅田川」",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "痩せ男はこの着物の中に、傲慢不遜なあぐらを掻くと、恬然と煙草をふかし始めた。",
              "citation": {
                "source": "着物",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は――堀川保吉はもう一度あのお嬢さんに恬然とお時儀をする気であろうか？",
              "citation": {
                "source": "お時儀",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ何も僕のやうに、恬然と未完成の作品ばかり発表する気にはなれぬ訳である。",
              "citation": {
                "source": "佐藤春夫氏",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし僕はどう考えても、今更｜恬然とＫ君と一しょにお時宜をする勇気は出悪かった。",
              "citation": {
                "source": "年末の一日",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、恬然として大井に賛成した。",
              "citation": {
                "source": "路上",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
