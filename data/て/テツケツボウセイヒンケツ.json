          "standard": [
            {
              "text": "めまいがひどく、病院で検査したら鉄欠乏性貧血だと診断された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "鉄欠乏性貧血の予防には、鉄分を多く含む食品を摂ることが大切だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "医者から鉄欠乏性貧血の治療薬を処方された。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ロマン派の人たちが中世のことを詮索しないでその頃のことを取り扱うときには結核や萎黄病（＊鉄欠乏性貧血）のような長患いを非常に好んだ。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人たちの悩みが萎黄病（＊鉄欠乏性貧血）や鬱病によるのか明らかに恋愛の結果であるかは確かめることができない。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
