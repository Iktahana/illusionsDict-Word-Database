[
  {
    "uuid": "cb92c584-21a6-59c3-b86b-3d7c32458451",
    "entry": "手に取る",
    "reading": {
      "primary": "てにとる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
