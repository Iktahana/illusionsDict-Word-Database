        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第二次の実験は隅田川の艇庫前へ持って行ってやったのだが、その時に仲間の一人が、ボイラーをかついで桟橋から水中に墜落する場面もあって、忘れ難い思い出の種になっている。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫く話し合っているうち、私は彼女が、私の学生時代、合宿していた艇庫の近くのある料理屋の娘と分る。",
              "citation": {
                "source": "野狐",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇庫には、もう、寝てしまった艇番｜夫婦をのぞいては、誰一人いなくなっています。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱が出たようにあつい額を押え、憤りと悔いにギリギリしながら、艇庫につき、念を入れてもう一回、押入れなぞ改めてはみましたが夜も更け、人気のない二階はたださえ、がらんとして、いよいよ、もう駄目だ、という想いを強めるだけです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡査は、ぼくの傍にきて、じっとみつめてから、なんだという顔になり、「ああ君はＷの人じゃないか」といい、大学の艇庫ばかり並んでいる処ですから、ボオト選手の日頃の行状を知っていて、「いいねエ、君等は、飲みすぎですか」と笑いかけます。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ぼく達も、隅田川での恋人、「さくら」が、一足先きに艇庫に納まり、各国の競艇のなかに、一際、優美な肢体を艶やかに光らせているのをみたときは、なんともいえぬ、嬉しさで、彼女のお腹を、ペたペたと愛撫したものです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "微笑ましかったのは、米国のスカアル選手のダグラスさん、六尺八寸はあろうと思われる長身｜巨躯が軽々と、左手にスカアル、右手に、美しい奥さんを抱いて、艇庫から、船台まで運び、そこで別れの接吻などしてから、お互いに、片手をあげては、スカアルの小さくなるまで、合図を交していました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、ぼく達も、隅田川での恋人、「さくら」が、一足先きに艇庫に納まり、各国の競艇のなかに、一際、優美な肢体を艶やかに光らせているのをみたときは、なんともいえぬ、嬉しさで、彼女のお腹を、ぺたぺたと愛撫したものです。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "艇庫には、もう、寝てしまった艇番夫婦をのぞいては、誰一人いなくなっています。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "微笑ましかったのは、米国のスカアル選手のダグラスさん、六尺八寸はあろうと思われる長身巨躯が軽々と、左手にスカアル、右手に、美しい奥さんを抱いて、艇庫から、船台まで運び、そこで別れの接吻などしてから、お互いに、片手をあげては、スカアルの小さくなるまで、合図を交していました。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがここから見ると、丁度大学の艇庫に日を遮られて、ただごみごみした黒い一色になって動いている。",
              "citation": {
                "source": "ひょっとこ",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の乗ってきた魚雷型潜水艇は、彼女の手によって、艇庫におさめられた。",
              "citation": {
                "source": "地球要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それには、さっき僕たちが入っていった博士の艇庫の内部がうつっていた。",
              "citation": {
                "source": "海底都市",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鐘ヶ淵の紡績会社や帝国大学の艇庫は自分がまだ隅田川を知らない以前から出来ていたものである。",
              "citation": {
                "source": "夏の町",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋場辺の岸から向岸を見ると、帝国大学のペンキに塗られた艇庫が立っていて、毎年｜堤の花の咲く頃、学生の競漕が行われて、艇庫の上のみならず、そのあたり一帯が競漕を見にくる人で賑かになる。",
              "citation": {
                "source": "向島",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　残暑の夕日が一しきり夏の盛よりも烈しく、ひろ／″＼した河面一帯に燃え立ち、殊更に大学の艇庫の真白なペンキ塗の板目に反映してゐたが、忽ち燈の光の消えて行くやうにあたりは全体に薄暗く灰色に変色して来て、満ち来る夕汐の上を滑つて行く荷船の帆のみが真白く際立つた。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れ渡つた空の下に、流れる水の輝き、堤の青草、その上につゞく桜の花、種々の旗が閃く大学の艇庫、その辺から起る人々の叫び声、鉄砲の響。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　残暑の夕日が一しきり夏の盛よりも烈しく、ひろびろした河面一帯に燃え立ち、殊更に大学の艇庫の真白なペンキ塗の板目に反映していたが、忽ち燈の光の消えて行くようにあたりは全体に薄暗く灰色に変色して来て、満ち来る夕汐の上を滑って行く荷船の帆のみが真白く際立った。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れ渡った空の下に、流れる水の輝き、堤の青草、その上につづく桜の花、種々の旗が閃く大学の艇庫、その辺から起る人々の叫び声、鉄砲の響。",
              "citation": {
                "source": "すみだ川",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつもよりは活気づいて艇庫に船を蔵めた。",
              "citation": {
                "source": "競漕",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆は思いのほかかかったのに落胆して、しおれながら艇を一番最後に艇庫へ入れた。",
              "citation": {
                "source": "競漕",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私たち日本人、殊に男が何か仕事に打ち込んだ場合、たいていこの宗五郎のようになってしまいます。",
              "citation": {
                "source": "政治家と家庭",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間が海の底を探險しても、たいていここが海底のどんづまりだと見極めて引上げて行くのです。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（未だ書かぬ自分の作品の計畫を語る場合に於いては、作者はたいていこのやうにあどけない法螺を吹くものである。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これはほんの一例であるが、まあ、たいていこんな按配で、とても讀んで行けない。",
              "citation": {
                "source": "津輕地方とチエホフ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その余威を駆って、と言っては不穏かもしれないが、自然派以外の作者たちは、たいていこの一派でやっつけられた。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はあの救助係の大きな石を鉄梃で動かすあたりから、あとは勝手に私の空想を書いていこうと思っていたのです。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かつて襲われたという家を私も二軒知っているが、そのいずれもが剛慾で人の持っているものを叩き落してでも自分が肥っていこうという家であったのを見ると、海賊というものにも、たゞ者を掠めとる一点ばりでなく、復讐的な気持や、剛慾者をこらしめる気持があったらしい。",
              "citation": {
                "source": "海賊と遍路",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしていつかそれに気がついてみると、栄養や安静が彼に浸潤した、美食に対する嗜好や安逸や怯懦は、彼から生きていこうとする意志をだんだんに持ち去っていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の手を触れる限りの物体にはたいていこの種の皮膜が知らぬ間に付着しているので、ガラスの表面の性質と思っているものが実はこの皮膜の性質であることがはなはだ多い。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
