    "definitions": [
      {
        "index": 1,
        "gloss": "the best in the land",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "捷術　隋の沈光字は總持、煬帝に事へて天下第一驍捷の達人たり。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐちかくのトンネルの入口にも「天下第一」という大文字が彫り込まれていて、安達謙蔵、と署名されてある。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この辺のながめは、天下第一である、という意味なのであろう。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "遊覧客たちの、そんな嘆声に接して、私は二階で仕事がくるしく、ごろり寝ころんだまま、その天下第一のながめを、横目で見るのだ。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "富士があって、その下に白く湖、なにが天下第一だ、と言いたくなる。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "所謂「天下第一」の風景にはつねに驚きが伴わなければならぬ。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、かえって、そのような富士の姿に、崇高を覚え、天下第一を感ずる。",
              "citation": {
                "source": "富士に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に太閤の其の言は、如何に當時に於て、太閤が福を分つて惜まざる天下第一の人で有つたかといふ事を語つて居るものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下第一の名人となるためには、どうあつても飛衞を除かねばならぬと。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれが本當だとすれば、天下第一を目指す彼の望も、まだまだ前途程遠い譯である。",
              "citation": {
                "source": "名人傳",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下第一の名人となるためには、どうあっても飛衛を除かねばならぬと。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしそれが本当だとすれば、天下第一を目指す彼の望も、まだまだ前途程遠い訳である。",
              "citation": {
                "source": "名人伝",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そうだ、あんたの天下第一の我儘がしきりに見度いと仰しゃって私に案内をさせなされた」「まあ私の我儘を今更何で先生が………」　そのとき麗姫の顔には愁しいとも恥かしいとも云い切れない複雑な表情が走った。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、それがしもその天下第一の風流男に会いとうなりました。",
              "citation": {
                "source": "猿飛佐助",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴殿に、そのお志があれば、天下第一の人相見になれるだろう」　と、左膳は云った。",
              "citation": {
                "source": "奉行と人相学",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に秀吉のその言は如何に当時に於いて秀吉が福を分かって惜しまない天下第一の人であったかという事を語っているものである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "欅の竝木は、恐らくは此處が天下第一なるべくや。",
              "citation": {
                "source": "菅の堤の櫻",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　もう一つ春の花の印象として忘れられないのは、北京の郊外の玉泉山のあの天下第一泉の碑の立つてゐるところで、柳の花の飛ぶのを見たことであつた。",
              "citation": {
                "source": "花二三ヶ所",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "池には天下第一泉の清い水が滾々として湧き出してゐる。",
              "citation": {
                "source": "花二三ヶ所",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして越前少将忠直卿は、天下第一人といったような誇りを持しながら、その年八月、都を辞して揚々とした心持で、居城越前の福井へ下った。",
              "citation": {
                "source": "忠直卿行状記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下第一の器量人、名宰相伊豆守ですらも舌を巻いて、あれは無比無双じゃと折り紙つけたむっつり流、狂い知らずのその眼に狂いがあったのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "献上博多人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、例の烱々としたまなこをらんらんと光らして、おもむろに、あごのまばらひげをつんつんとひっぱっていたようでしたが、いっしょにずばりと天下第一の胸がすく名｜啖呵が言い放たれました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "曲芸三人娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「たわけじゃと申すわい」「有難きしあわせ、早乙女主水之介は天下第一の大たわけ者でござります。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "天下第一のお経　次にまた、その名前のよく知れ渡っているという点では、あの『論語』にも匹敵するのであります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして論語が天下第一の書といわれているように、この『心経』もまた昔から天下第一の「経典」といわれているのであります。",
              "citation": {
                "source": "般若心経講義",
                "author": "高神覚昇",
                "note": "青空文庫"
              }
            },
            {
              "text": "理屈は別としたところで一体歌よみは和歌を一番善いものと考えた上でどうするつもりにや、歌が一番善いものならばどうでもこうでも上手でも下手でも三十一文字並べさえすりゃ天下第一のものであって、秀逸と称せらるる俳句にも漢詩にも洋詩にも優りたるものと思い候ものにや、その量見が聞きたく候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎の者などは御歌所といえばえらい歌人の集り、御歌所長といえば天下第一の歌よみのように考え、従ってその人の歌と聞けば読まぬ内からはや善きものと定め居るなどありうちのことにて生も昔はその仲間の一人に候いき。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "理窟は別とした処で、一体歌よみは和歌を一番善い者と考へた上でどうするつもりにや、歌が一番善い者ならば、どうでもかうでも上手でも下手でも三十一文字並べさへすりや、天下第一の者であつて、秀逸と称せらるる俳句にも、漢詩にも、洋詩にも優りたる者と思ひ候者にや、その量見が聞きたく候。",
              "citation": {
                "source": "歌よみに与ふる書",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
