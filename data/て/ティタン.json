        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "土星の衛星ティタンには、地球に似た大気が存在すると言われている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "カッシーニ探査機は、ティタンの表面を詳細に観測した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "将来、ティタンへの有人探査が実現する日が来るかもしれない。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
