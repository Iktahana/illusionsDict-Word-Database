    "definitions": [
      {
        "index": 1,
        "gloss": "inside of a store (restaurant, café, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "目立たない洋髪に結び、市楽の着物を堅気風につけ、小女一人連れて、憂鬱な顔をして店内を歩き廻る。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝茶店内部　夜更けて――　表戸を開けて七五郎のお袋のお勘婆さんが顔を出す。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが雨のあとなどだと、店内の片すみへ川が侵入して来ていて、清冽な鏡川の水がさざ波を立てて流れていた。",
              "citation": {
                "source": "涼味数題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これだな」と、一行は澄ました顔をしてその前を素通りしながら、そっと横眼を使って店内を眺めると、有るわ有るわ、天幕、写真器械、雑嚢など、一行の荷物は店頭に堆高く積んである。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼の食事の時刻も移ったと見えて店内の客はぽつ／＼立上って行く。",
              "citation": {
                "source": "巴里祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやうく踏みとどまり、冷汗三斗の思いでこそこそ店内に逃げ込んだ。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、いったい、それはどういうものなんだろうと思ったが、いいよ、それで、と返事をし、店内をさまよわせていた目を、外の広い交差点にむけた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時間と言い、戸締りが厳重で外部から侵入の余地がない点と言い、犯人は明かに店内の者です。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いいですか、一層はっきり言えばですね、昨夜この店内にいた者と言うのです。",
              "citation": {
                "source": "デパートの絞刑吏",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、彼はしばらくためらった後、思い切って店内へ足を踏みこんだ。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "このとき、店内には、客は一人もおらず、白い詰襟の上下服を着た中国人ボーイが五六名、団扇をつかって睡そうな顔をしているところだった。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "水夫は、去年の祭り日にこの競争で誉をたてゝ、「幸福の花環」を授けられたのに、今は何故斯んな不幸に出遇つてゐるのだらうなどと不思議に思つてゐると、イダーリアの店内から花々しい声が巻き起つた。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "直ぐさま背後には物売りが人垣を作り、まえの商店からは腕力家の番頭が走り出て来て、有無を言わさず君を店内へ拉致するだろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはなるほど店員の刺激にはなるだろうけれど、時として店の空気を不純にし、かつ多くの場合、客に自由に店内を見てまわる気をなくさせ、監視されているような感じを起させやすい。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "店内は日本の品物をもって埋まり、蓙・雨傘・浮世絵・屏風・茶碗・塗物・呉服・小箱・提灯・人形・骨董・帯地・着物・行李・火鉢・煙草盆――一口に言えば何でもある。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "その車から出た老人は店員が頭を下げている前を通って店内に消えた。",
              "citation": {
                "source": "新しい美をつくる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もない或る日、国立出版所の店へ行くと、どこか店内の模様がかわっている。",
              "citation": {
                "source": "五ヵ年計画とソヴェト同盟の文化的飛躍",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たくなって、もう一遍混雑をきわめた店内へ戻って、奥の方で開けて眺めているうち、大決心をして到頭買って来た。",
              "citation": {
                "source": "ヴォルフの世界",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "喧しい店のことであるから、料理場にものを通したり、表を通る客に声をかけるに大きな声を張りあげるので、彼女たちの咽喉はつぶれて、それが店内に濛々としてゐる煙草の煙のために一層荒れて了つてゐる。",
              "citation": {
                "source": "日本三文オペラ",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぴったり閉じられたガラスの中なので話は聞えなかったが、電気の消えた店内の暗さを背景にしているため、漸く通りの明るみを受けた支配人とボーイ三四人の顔が、水族館の中の鮫のように物物しく映って見えた。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜間営業で、店内は頭痛のするやうな明るさで、造花の桜の枝が方々に飾ざつてある。",
              "citation": {
                "source": "朝夕",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは光りの流れてくる資生堂（食堂）の明るい店内を見ていた。",
              "citation": {
                "source": "一世お鯉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一寸腰かけようか」　はる子が頷くと、重吉はすぐそばの硝子戸を押して、ひろい真直な視線で繁華な店内のざわめく光景を見わたしながら、派手なチョコレート製の塔が大きい飾窓に出ている喫茶店に入って行った。",
              "citation": {
                "source": "雑沓",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　大きな硝子戸は閉められていて、店内へ入ろうとする人影がさすと、下足番のようにしてそこにいる男がその硝子戸をあけた。",
              "citation": {
                "source": "道づれ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ僅か残っている客への礼儀から、ばたばたはしないが、それでも店員たちのそら鳴ったぞ、という気のせき立ちは店内の空気が上下とりかわって急に流れ出したような遽しさを漂わせはじめるのであった。",
              "citation": {
                "source": "道づれ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪でしめらされ、群集の湿気でむされる大鋸屑からは鼻のつんとするような匂いが立ちのぼって、午後の三時ごろからもう電燈の煌いている店内に、何とも云えず陽気な雰囲気をふりまくのである。",
              "citation": {
                "source": "広場",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそのまま、帰りたくもなりましたが、皆で来ているのでそれもならず、再び店内に入ると、もはや、ほろ苦くなった酒を呻るのも止めてしまった。",
              "citation": {
                "source": "オリンポスの果実",
                "author": "田中英光",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
