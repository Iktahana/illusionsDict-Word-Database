[
  {
    "uuid": "3fdff350-6ff5-58a0-9687-a29e28bb945e",
    "entry": "手放す",
    "reading": {
      "primary": "てばなす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
