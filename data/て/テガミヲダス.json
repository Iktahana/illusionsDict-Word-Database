[
  {
    "uuid": "113c5d33-f616-5809-810b-5ea9fca93d9d",
    "entry": "手紙を出す",
    "reading": {
      "primary": "てがみをだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
