    },
    "definitions": [
      {
        "index": 1,
        "gloss": "heaven and earth",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何事も、一切の係累を捨ててしまつて、遠く南米の天地に移住したいと語つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶯や駒鳥はいつも鳴いてゐるし、樹陰の深い緑は所々にあるし、それだけで山間の別天地をなした鮮新な温泉町としてゐる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "透明な光は天地に充ちてそよとの風もない。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、私は嘆息する、天地の間には、風が吹くのでなければ、霧が流れるのだ、そのたびに、天幕の中へ、ザアと小粒の雨がそそぎ入る、柱代りの金剛杖が、キュッと呻る、杭に纜われた小舟が、洪水に飜弄されるように、油紙の屋根が、ペラペラ動く。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "「天地のわかれし時ゆ、神さびて」と歌った山辺赤人は旅人であった。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　石楠花　いつごろからのいいならわしか、富士の五合目を「天地の境」と称している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここ「天地の境」五、六合目の等高線、森林を境として、山を輪切りにしたところの御中道を彷徨する私は、路の出入に随って、天に上り、地を下る、その間を、鳥と、虫と、石楠花が、永久｜安棲の楽土としている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "朱樺の火は燃え出した、その明るくなることは、花が発くのと同じで、万象の色が真の瞬間に改まる、槍と穂高と、兀々した巉岩が、先ず浄い天火に洗われて容を改めた、自分の踏んでいる脚の下の石楠花や偃松や、白樺の稚いのが、今眠から醒めたというように朝風に身振いしてソヨソヨと顫った、天地皆新しい。",
              "citation": {
                "source": "奥常念岳の絶巓に立つ記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の山懷の一隅には非常時の嵐が未だ屆いて居ないのか、妙にのんびりした閑寂の別天地である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地の間にあるものは唯向ふの森と家と芋畑とそして一枚のスケッチ板ばかりであつた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地万有が活きて動いて変化している間はこの力学の応用はあらゆる学術技芸に一日も欠く事は出来ぬ。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蝶が天地大に姿をフォーカスし去ると、そこに二階の窓々で飾人形を掃除している並木越しの商店街を見出した。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "天地もまだ若く、人間もまだ稚純な時代であった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人を悠久に飽かしめない感動点として山は天地間に造られているのであろう。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たそがれは天地に立籠め、もの皆は水のいろに漂いはじめたが、ただ一つ漂わされぬものがあって山ふもとの薄明りの野に、一点の朱を留めていた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かがり火は、薪木の性と見え、時折、ぷちぱちと撥ね、不平そうに火勢をよじりうねらすが、寂莫たる天地は何の攪き乱さるる様子もなく、天地創ってこのかた、たそがれちょうものの待つ、それは眠るにも非ず覚めたるにも非ざる中間に於て悠久なるものを情緒に於て捉えようとするかれ持前の思惟の仕方を続けている。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁が呆然眺め上げる福慈岳の山影は天地の闇を自分に一ぱいに吸込んで、天地大に山影は成り切った。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう見られる黝み方で山は天地を一体の夜色に均された。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたが、山の神の眷属としてわたくしを、ただ眷属中での褒められ者として育つのを望んだ娘は、この福慈岳に籠れる選まれた偉大ないのちの中に綯い込められ、いまや天地大とも久遠劫来のものとなってしまいました。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑うときは峯の雪を日に輝して東海一帯の天地を朗なものにした。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "悟るということは、生命の遍満性、流通性を体証したことで、一｜匹の鯉魚にも天地の全理が含まれるのを知ると同時に、恋愛のみが全人生でなく、そういう一部に分外に滞るべきでないとも知ることです。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり突如として入った別天地に私は草臥れるのも忘れて、ただ、せっせと主人について歩いて行くうちどのくらいたったか、ここが峠だという展望のある平地へ出て、家が二三軒ある。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かりそめに叱りうべしや吾子といへどこの天地のひとりの男の児　この歌は下手ですが子供を叱ったあとの気もちです。",
              "citation": {
                "source": "家庭愛増進術",
                "author": "――型でなしに",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくどこへ行っても、行く先々に勇敢な彼等のための天地が開けて行きそうな気がする。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京にこんなところがあったかと思うような別天地である。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず現代の応用科学の産み出した文化は天地間のエネルギーを駆使して多くの唸り声や吼声を製造するに忙しい。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであるのに科学と芸術とは一見没交渉な二つの天地を劃しているように思われる。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学が価値道徳の問題から離れて自由な天地を得たために始めて手足を延ばしたのである。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "例之ば「天地」と云ふことは「あめつち」よりか「てんち」の方が行はれて居る。",
              "citation": {
                "source": "假名遣意見",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
