        "examples": {
          "standard": [
            {
              "text": "敵対国による工作活動を防ぐため、情報機関は監視を強化している。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "敵対国の指導者が交代したことで、外交ルートを通じた対話の可能性が開けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            },
            {
              "text": "経済的な制裁措置として、敵対国へのハイテク製品の輸出を禁止した。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-3-flash-preview"
              }
            }
          ],
          "literary": [
            {
              "text": "以て、彼の棒道が、いかに非常のときにものをいって、その電撃ぶりと共に、敵対国にとっては、苦手なものであるかという察しもつく。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩祭　ここ両三年の越後と甲斐とは、依然、宿命的な敵対国として双方、国境を堅持しながらも、その活動は、各※べつな方へ向けられていた。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう類の風説は、いわゆる埋言の計と申して、他国から敵対国へ来ている者が、そっと火だねを埋けて行った場合が相応に多いもの。",
              "citation": {
                "source": "新書太閤記",
                "author": "第六分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして同じ敵対国にたいしては、常に重きをなしているから無言の防塁はつねに織田の後方を確乎として扶翼している。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
