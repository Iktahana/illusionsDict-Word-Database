[
  {
    "uuid": "1968dc82-81cc-598a-9f20-e94d17370c98",
    "entry": "敵視",
    "reading": {
      "primary": "てきし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "looking upon (someone) as an enemy",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから主觀性のない文學は、私の意味での「詩」でない上に、自分の藝術上の立場として、對蹠的な地位に敵視するものでなければならぬ。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "日に十里を楽々と走破しうる健脚を有し、獅子をも斃す白光鋭利の牙を持ちながら、懶惰無頼の腐りはてたいやしい根性をはばからず発揮し、一片の矜持なく、てもなく人間界に屈服し、隷属し、同族互いに敵視して、顔つきあわせると吠えあい、噛みあい、もって人間の御機嫌をとり結ぼうと努めている。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "実に自分は長い間、日本の文壇を仇敵視し、それの憎悪によって一貫して来た。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち貴族主義と民衆主義とは、同じ一つの線の上で、互に敵視しながら向き合っている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴族組と平民組と、この二つの黨派に屬する生徒等は、互に敵視してにらみ合つてた。",
              "citation": {
                "source": "非論理的性格の悲哀",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "桂子を敵視する同業者の家もあつた。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一事が万事、なにかいつも自分がそのために人から非難せられ、仇敵視されているような、そういう恐怖感がいつも自分につきまとって居ります。",
              "citation": {
                "source": "わが半生を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜田博士もそれに触れて、「津軽に於いては、安東氏没落し、津軽氏独立して南部氏と境を接して長く相敵視するの間柄となつた。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人をして、此相敵視せる二大潮流を観察せしめよ。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "智識と経験とが相敵視し、妄想と実想とが相争戦する少年の頃に、浮世を怪訝し、厭嫌するの情起り易きは至当の理なりと言ふ可し。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが狹義の人民（δημο※）で、Platon はこれを敵視すると明言して憚らない。",
              "citation": {
                "source": "古い手帳から",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は從來濫りに人を敵視したがる癖があつた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄板製の煙突の代りに、赤い煉瓦造りの大煙突が、遠くの遠くから敵視の目標となった。",
              "citation": {
                "source": "黒い地帯",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から夜まで、仲間の労働者さえも、見習いの僕を敵視するように思われた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これいまだ人を敵視することである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "佛教が道教と相敵視して相攻撃するに至つた時、佛教者の標的となつたものは正一派であつたのを見ても、それが道教の大本山であることは明知せらるゝのである。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "美女は悪女を仇視せず、君子は小人を敵視しない。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "物怪といっても、育てた姫君に愛を残した乳母というような人、もしくはこの家を代々敵視して来た亡魂とかが弱り目につけこんでくるような、そんなのは決して今度の物怪の主たるものではないらしい。",
              "citation": {
                "source": "源氏物語",
                "author": "葵",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしかれのいだいている不審は、単に彼を敵視するという以外に、もっと大きな怖れを含んでいるのであった。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彫工会の方はもとより心から谷中派を敵視しているわけでないから、そういう要求は快く容れましたので、谷中側の人も大分入会したような訳でした。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "発会当時およびその後のことなど",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の亡父に唾棄されたり、子等に敵視され続けてゐるＧこそ、心がらとはいふものゝ飛んだ役廻りを負つたものだ！",
              "citation": {
                "source": "村のストア派",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしの友達として、あなたは彼の人を敵視しても関はないわ、それには充分な理由があるんですもの。",
              "citation": {
                "source": "Ｒ漁場と都の酒場で",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "知識と経験とが相敵視し、妄想と実想とが相争闘する少年の頃に、浮世を怪訝し厭嫌するの情起り易きは至当の者なりと言うべし。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして互いに敵視し反感する二種族が、社会の両極を形づくることとなる。",
              "citation": {
                "source": "征服の事実",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が生前極力排斥し、敵視した異端邪宗の教の国に来て、反って岸本は父を視る眼をさえ養われた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何分にも大きな声を出すことを許されぬ場合のこととて、互に敵視しながらも一言も云わず、必死と眼を光らし合った。",
              "citation": {
                "source": "電気風呂の怪死事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにして世運正に欧化時代に際す、先生ますます回瀾事業の必要を感じ、まさに大いに道を弘めて時弊を匡救せんとす、当時政論の中衰せるに会し、欧化主義に反対して政論を立つるものは自ら政府の敵視するところとなり、政論社会は窃にこの論派の激烈なるを危ぶみ、なお第二期における民権論派を視るがごとくせり。",
              "citation": {
                "source": "近時政論考",
                "author": "陸羯南",
                "note": "青空文庫"
              }
            },
            {
              "text": "円満なる地球には東も西もなかったが、前に述べた土耳古人の障害物によりて地球は二に割られ、ここに始めて東と西とに分立し、互に敵視していたが、爾来｜星霜幾変遷するに従い、自分個人のみにては完全ならざることを悟り、近来真面目に人生を考うるものは、西洋人で東洋に憧がれ、東洋人は西洋を慕う有様にある。",
              "citation": {
                "source": "東西相触れて",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "東西の諒解を図るに当って、勿論国家の斡旋は欠くべからざる条件であるが、これは寧ろ形式、法理の上のことであって、事実上、精神的にこの目的を遂行するには高き人道の立場あるいは深き学理に基いて、理由もなきに常に他国を敵視するが如き、狭小なる国家主義を脱したものの力によらざれば、実現は不可能である。",
              "citation": {
                "source": "東西相触れて",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "分け登る麓の途こそ東西南北の差あれ、達する末は高嶺なる如く、種々に分かるる人種、互に敵視する数多の国家の使命も終局の点に於て一に帰するであろう。",
              "citation": {
                "source": "東西相触れて",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
