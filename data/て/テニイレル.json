    "definitions": [
      {
        "index": 1,
        "gloss": "to obtain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "菱や色々の樹の実は土佐に限らぬものであろうが、しかしこれらの都会の食味の中に数えられないためか、どこでも手に入れることが出来ない。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「手に入れる工夫はないだらうか。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「手に入れる工夫はないだろうか。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの読み物を手に入れることは当時のわれわれにはそれほど容易ではなかった。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本では外国の書物を手に入れるのがなかなか不便である。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さまでにして、手に入れる餌食だ。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎ならば、異国の商船が絶えず出入りをしている土地ですから、モルヒネの睡り薬を手に入れることが出来る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "十五夜御用心",
                "note": "青空文庫"
              }
            },
            {
              "text": "著物を手に入れるあてもなく、まごまごしていたずらに時間を空費しておれば、雪子の空腹は増すばかりだと、小沢は淀屋橋から地下鉄に乗った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "五厘銅貨でやつとなでしこ小袋を手に入れることができた。",
              "citation": {
                "source": "行乞記",
                "author": "山口",
                "note": "青空文庫"
              }
            },
            {
              "text": "街へ出て、米すこしばかり手に入れる、餅ばかりでは困る。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "王子のことを思い、死なない魂を手に入れることを、じっと思っていました。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "さもなければ、死ぬことのない魂を、手に入れることができないのです。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "得ようとしても、いまとなっては、手に入れることのできないお姫さまなのです。",
              "citation": {
                "source": "人魚の姫",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんな高価な紙鳶を手に入れるどういふ目論見なのか解らなかつたが、その声の中には、きつと返して見せるといふ凜とした意志の閃があつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根の山を越え、沼津に到り、四方八方捜しまはり、やつと一つ、二つの美事な苗を手に入れる事が出来、そいつを宝物のやうに大事に油紙に包んで、にやりと笑つて帰途についた。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度欲しいと思ふといつもの癖で、明日とは言はずに今直ぐ手に入れる工夫はないものかと、その出來ない工夫までしてみた。",
              "citation": {
                "source": "病室より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから女を自分に蕩し込むにはまず囮の女を立てゝそれに競争心を起させ釣り込むこと、周囲にあらぬ噂を立てさせ嘘から出たまことの寸法で破れかぶれになった女を自分の手に入れる。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを聞いた時は、そんな優しい、おとなしい娘を手に入れることが出来るのかと心中｜窃かに喜んだのだが、それ程物堅い親子が揃って来るとなると、松源での初対面はなんとなく壻が岳父に見参すると云う風になりそうなので、その方角の変った晴がましさは、末造の熱した頭に一杓の冷水を浴せたのである。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたと道連れにならなければ、これを手に入れることは出来なかったでしょう。",
              "citation": {
                "source": "指輪一つ",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の偉大なものになると、泰平の世に何十万石の知行とか何万両の財産とかを手に入れるため、十数年もしくは数十年の間忠実無二の性格を鼻の頭に輝かしつつ明かし暮らす事が出来るのであります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして空しく七年が過ぎて殆ど諦めかけていたある日、遂にそれを手に入れることが出来た。",
              "citation": {
                "source": "世相",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球戦の入場券一枚を手に入れるために前夜からつめかけて秋雨の寒い一夜を明かす勇敢な人たちの話は彼を驚かし感心させた。",
              "citation": {
                "source": "野球時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬はひどく喜んで、すぐ旅装を整えて、客に従いて金陵へ往ったが、その客がいろいろと頼んでくれたので、二つの芽を手に入れることができた。",
              "citation": {
                "source": "黄英",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南はこうして紹介せられておれば、手に入れることはぞうさもないと思った。",
              "citation": {
                "source": "竇氏",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、実際問題としては、その実験の材料を手に入れることが困難であった。",
              "citation": {
                "source": "三稜鏡",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私は、暴力沙汰はいやだと云いましたら、彼の本性の悪漢振りをまる出しにして、私を口ぎたなく罵りながら、どうしても彼の女を手に入れるんだと、タンカを切って出ていったのでした。",
              "citation": {
                "source": "自転車嬢の危難",
                "author": "コナン・ドイル",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は己の店に来る客から、区会議員をしている質屋の主人にかこわれている女が、芸人と関係して媾曳していると云うことを聞いたので、それを脅迫して手に入れるつもりでその場所を突きとめ、その帰りを待っていて脅迫状を投げ込んだところであった。",
              "citation": {
                "source": "水魔",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、剱を手に入れると、六つの人形のこらずにこうやくをぬってやりました。",
              "citation": {
                "source": "旅なかま",
                "author": "REJSEKAMMERATEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "１がつ１たちに　なっても　おしはらいが　ないので、　ピクルスは　いぬのライセンスを　てにいれるのも　ままなりません。",
              "citation": {
                "source": "ジンジャー＆ピクルスのはなし",
                "author": "THE TALE OF GINGER AND PICKLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
