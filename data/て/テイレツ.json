[
  {
    "uuid": "61b00c95-f5c1-557b-8756-71ed42f76937",
    "entry": "低劣",
    "reading": {
      "primary": "ていれつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容動詞",
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "low grade",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "翻訳者にして、もしヘツポコ詩人であるとすれば、原詩の価値もまた、低劣なヘツポコ詩に過ぎないのである。",
              "citation": {
                "source": "詩の翻訳について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、どのようなロマンスにも、神を恐れぬ低劣の結末が、宿命的に要求される。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたは、結局、低劣になったのだぞ。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠井さんは、流石に少し侘びしく、雨さえぱらぱら降って来て、とっとと町を急ぐのだが、この下諏訪という町は、またなんという陰惨低劣のまちであろう。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪魔のように見える低劣な人間性も人間向上の培養素になるではないかというのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世を隠遁したり、誘惑を恐れて必死になって逃げようとするなどは仏教の方でも低劣な小乗仏教と言って嫌います。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし定律詩には既成の必然的韻律がある故に、いかに内容の低劣な者と雖も、尚多少の韻律的美感を讀者にあたへることができる。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "之れに反して自由詩の低劣な者には、全然どこにも韻律的な魅惑がない、即ち純然たる散文として印象される。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながらそのことは、必しも内容の無良心や低劣を意味しない。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもまだ不幸なことに、彼等の味覚は低劣であり、胃袋は駄菓子によって傷害されている。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに反して精神のない低劣の俳句は、詩情が機智的の趣味性に止まっているため、観照に於ける描写的手法のみが感じられ、真の強い詩的情熱を感じさせることがない。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "俳句が「感情の意味」で読まれずして、機智的なる「知性の意味」で読まれるのは、かかる低劣なる作品のためである。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして古来、人類が作って来た各種の文化の中でも、最も醜悪低劣なこの科学文明の内容を人々が反省し初めるに連れて、グングンと進化し分化し初めた。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしそはその人の低劣を自白するだけのことである。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば下層社会の低劣な品性の如きも教育の不備よりはむしろ精神欠陥に帰し、一時好んで下層社会に出入するやライフの研究者を任ずると共に下層社会に共通する悪俗汚習の病因たる精神欠陥を救うの教師を自任し、細さに下級の生活状態を究めて種々の自己流の精神医療の方法を案出して試みた。",
              "citation": {
                "source": "二葉亭四迷の一生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "――稀に出した本であつたがわたしは手にとるのも気おくれがする程の低劣至極な出来栄えだつた。",
              "citation": {
                "source": "茜蜻蛉",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "民国革命後も日本の明治維新の如く国民皆兵に復帰する事が出来ず、依然「好人不当兵」の思想に依る傭兵であり、十八世紀欧州の傭兵に比し遥かに低劣なものでその戦争に於ては武力よりも金力がものを言った。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "今となつて外地へ持ち出す一本の映画もないと叫び、その原因をあげて映画芸術家の無能低劣のゆえに帰し、口を極めてこれをののしる人がある。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、かくも無能低劣なる我々に映画を任せきりにして今まで省みようともしなかつたのはだれの責任であるかと。",
              "citation": {
                "source": "映画と民族性",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学の才能も、世間で見くびっているほど低劣ではなかった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｋ―自身の正義観から見ると、彼の環境は低劣で悪徳に充ちてゐた。",
              "citation": {
                "source": "倒れた花瓶",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　バルザックが、彼の作品でとりあげたのは正にそのロマンチストたちにとって俗悪・低劣とされたところの金銭及び金銭に絡む大小俗人の、こまごまとして塵のひどい日々夜々、そのベッドにまで這い上って来る悲喜劇であった。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の新しい歴史教科書『国のあゆみ』がその精神において低劣なのは、あの本のどこにも日本人民のエネルギーの消長が語られていず、まるで秋雨のあと林にきのこが生える、というように日本の社会的推移をのべている点である。",
              "citation": {
                "source": "なぜ、それはそうであったか",
                "author": "――歴史・伝記について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目漱石が「吾輩は猫である」のなかで、婦人の精神の低劣さを諷刺した文章は、今日、もう日本の女性のおろかしさを語るものではなくなった。",
              "citation": {
                "source": "未来を築く力",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "思いやりのない、ひとを Hurt することの平気な、一寸した正しさの自己満足にひたりたい、低劣な心持、いかにも彼のいやな部分が出た、と感じた。",
              "citation": {
                "source": "一九二三年夏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、このとき、卑怯な低劣さでもって、この通俗を通俗として恐れ、その真実であり必然である人間性の通俗から遠ざかれば遠ざかるに従って、その意志とは反対に通俗になっているという逆説的な人間描法の魔術に落ち込んだ感傷家が、われわれ日本の純文学の作家であったのだ。",
              "citation": {
                "source": "純粋小説論",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何を読んでも、何を聴いても、何を眺めても、一切が悉く低劣卑賤に思われる。",
              "citation": {
                "source": "情意の干満",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてなお云えば、文学は必要なものに奉仕するの低劣さをやめて、必要以上のものに奉仕しなければならないし、吾々は必要なものにも多く事欠く現代に於てさえ、必要なものを蔑視して、あらゆる欲望を燃え立たせるがよいと、そう信ずるのである。",
              "citation": {
                "source": "必要以上のもの",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "某女史は、精神的に立派な人であるが、悲しくも、美しからぬ低劣な鼻を持っている。",
              "citation": {
                "source": "美醜",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "凡人の手に弄ばれる時、それは卑俗低劣に堕し、擯斥すべきものとなる。",
              "citation": {
                "source": "愉快な話",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
