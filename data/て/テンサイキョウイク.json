        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "話頭は転じて、いわゆる「天才教育」の問題にはいる。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり一種の天才教育である。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その点から一面、人間中心芸術中心の天才教育があってもよいと思います。",
              "citation": {
                "source": "女流作家として私は何を求むるか",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なあに僕のは天才教育だからさ。",
              "citation": {
                "source": "変な男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "實生活を顧慮しない天才教育のやうなものであつた。",
              "citation": {
                "source": "語學修業",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "藝術教育や天才教育を受けた凡人は、却つて學窓を出た後、衣食を得るに困難するばかりである。",
              "citation": {
                "source": "語學修業",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "天才教育で有名な中学の制服で、よれよれの黒ネクタイをした長男の透が、神経質な眉をヒクつかせて帰つてくると、つづいて故人の後妻の梅代が、着なれぬ喪服の裾をばくばくさせながら、青ぶくれの顔の眼のふちを真赤に染めて帰つてくる。",
              "citation": {
                "source": "地獄",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "動植物の施す教育は、全く天才教育、自由教育である。",
              "citation": {
                "source": "海螢の話",
                "author": "神田左京",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
