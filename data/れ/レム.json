[
  {
    "uuid": "8cffe6db-3eb9-51d2-ac6e-8ad5bd796429",
    "entry": "ＲＥＭ",
    "reading": {
      "primary": "レム",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rapid eye movement",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "正しく風に動力を借りるオランダ低地の風車は美でもあり、経済的でもあったろうが、レムブラントの名手に油絵、またはエッチングに取り入れられたあの風車の風景も、近来は電気工業に取って代られ、引き合わないために、風車はだんだん取り毀たれ、オランダ風物の代表は、全く失われんとしているとも聞いた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば自分はそのエルサレムへ急ぐ巡礼だった。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜が更けると、米良は陳子文とイサックを伴って電車路からクインス・スタチウの花園の附近にあるマダム・レムブルクの夜の家を訪れる。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族｜希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグ美容院で女の肉体を占領した同志は同時に自己の領地を外国に棄てたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグを抱えた米良が舞踊場に機械が造り出した人間の造花の美と、同志の終りに近づいた純潔を撒き散らした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "舞踊場で未来の墓誌銘に現代の道徳を刻んだ同志と、レムブルグ美容院の舞踊場の楽隊の奏でる哀悼歌に合唱して、米良は柩車のように螺旋をえがいて踊りながら、彼は絶えず東支那海の電信夫がもたらす秘密結社の女シイ・ファン・ユウの恋の便りを受取った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグの電信室の受信器には女に変装して上海に逃れた重慶共産主領｜楊闇公の銃殺を暗号電報は報ずるのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レムブルグは商取引所に於ての最近の銀の相場の高騰にあって、軍閥の勝利をたしかめると同時に同志の破滅を予感した。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レムブルグの毛深い部屋でこの陳独秀の悲壮な報告が終って、彼は自己の生涯の最後を南支那海のビイクトリア島においたのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "斑なシュミーズをつけたレムブルグの女弟子が部屋に飛込むと陳子文がバルコニで自殺したことを告げた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然レムブルグが悲鳴をあげて廊下に飛出す、米良はバルコニに駈け上ると暈れた空気に蒼白めた闘争に窶れた同志の死体が沈むのを見た。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグの黄色い涙が夜を濡らした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "突然、うとうととしていた米良をマダム・レムブルグがたたき起して一通の電報を手渡すと、　――広東に夜中反乱が起ったのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――レムブルグ、鍵穴をうめてください。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとマダム・レムブルグは素早く太い胴体を飜えして、この近代の機能の発明家は青い化粧的で、牛の舌みたいな腕で扉を閉めると、再び細目に開けて、　――それどころですか。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――レムブルグ、貴女の恋心。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグの愛情が彼を慰めるように、　――妾の最愛の子供！",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良はレムブルグの寝室の扉をノックした。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉が開くと青い衣裳の彼女の腕が彼の首に巻いて、米良は鋼鉄のようなレムブルグの乳房を感じた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が覚めるとレムブルグの抜け殻の跡は既に冷たくなっていた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグ美容院の整頓された朝がやってきた。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "希臘商人が自転車で忙がしく商取引所方面に疾走し出すころ、マダム・レムブルグが瀝青の浮いた黒襦子の着物をつけて朝のミルクのなかで接吻をすると、海峡を船脚｜迅く航行する汽艇、陳独秀が汕頭に行く姿を指さすのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグが朝の情熱に癇高い声を震わして云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――レムブルグ、これからは今日の戦勝者が明日の戦勝者に粉砕される無意義な動乱が揚子江を挟んで軍閥の雇兵達によって繰かえされるのです。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "レムブルグが嘆息して云った。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "――レムブルグ、貴女の女らしい夢想。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダム・レムブルグのオアシスはいまでは相場師で埋もれてはいないであろうか？",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はマダム・レムブルグの家でアングロ・サクソンの英諾威人、ケント族の仏伊人、スラブの露墺人、アイオニアンの血族希臘人の商人、オットマン帝国の土耳古人等と夜食を共にするのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
