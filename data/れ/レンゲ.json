    "definitions": [
      {
        "index": 1,
        "gloss": "lotus flower",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "霊山の雲霧のごとく立昇る湯気の中に、玲瓏玉を溶かせるごとき霊泉の中に紅白の蓮華が一時に咲き満ちたような感じがしたのであった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白馬岳の又の名を越後方面では大蓮華山といっている、或人の句に「残雪や御法の不思議蓮華山」とあるからは、これも一朶の白蓮華、晶々たる冬の空に、高く翳されて咲きにおうから、名づけられたのかも知れない。",
              "citation": {
                "source": "梓川の上流",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい石祠がある、屋根には南無妙法蓮華経四千部と読まれた、大日如来と書いた木札が建ててある、私たちの一行より、二十日も前に登山した土地測量技師や、昨年登山した東京の人たち、山麓｜蘆安村でよく聞く名の森本某、名取某の名刺が散らばっている。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "金刀比羅宮、男山八幡宮、天照皇大神宮、不動明王、妙法蓮華経、水天宮。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯願ふらくはかの如来大慈大悲我が小願の中に於て大神力を現じ給ひ妄言綺語の淤泥を化して光明｜顕色の浄瑠璃となし、浮華の中より清浄の青蓮華を開かしめ給はんことを。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯願うらくはかの如来大慈大悲我が小願の中に於て大神力を現じ給い妄言綺語の淤泥を化して光明｜顕色の浄瑠璃となし、浮華の中より清浄の青蓮華を開かしめ給わんことを。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種と蓮華草のモザイクに数限りない雲雀の声と蝶の羽根が浮き上っている。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老母は立ち上り部屋の奥に入り、一かかえの白蓮華と一振りの銅刀を持ち出で来り、炉の側に坐る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（老女は銅刀で乳房を裂き、白蓮華の一枚々々に乳房の血を塗り、炉の火中にくべる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（阿難少時｜緘黙、再び激昂の調子になり）その刹那、血塗った蓮華が何処よりともなくばらばらと飛んで来て、わたしの身心に纏い付き、そしてわたしは無闇にここへ運ばれて来た。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日出でなばすべての色像を現わし、池を照し蓮華を開かせる。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえその罪によって、一度は地獄畜生の界に堕ちるにしても、わたしはあなたの為に紅焔のなかの青蓮華となり、あなたを無事に包みましょう。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "み仏のさずけ給える一筋の蓮華の糸が、今わたしの手に在る。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞑目した眼を徐ろに開くと、青蓮華のような切れの鋭い眼から濃い瞳はしずかに、斜に注がれた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けむりの中から出て来たのは、今度こそ全く支那風の五色の蓮華の花でした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くその蓮華のはなびらは、ニュウファウンドランド島、ヒルテイ村ビジテリアン大祭の、新鮮な朝のそらを、かすかに光って舞い降りて来るのでした。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですけれども、真夜中ですもの、川の瀬の音は冥土へも響きそうで、そして蛇籠に当って砕ける波は、蓮華を刻むように見えたんですって。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "……夜の蓮華の白いのの、いま真青な、麓の川波を綾に渡って、鼓の緒を捌くように響いて。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　波頭、雲の層、累る蓮華か、象徴った台座の巌を見定める隙もなしに、声とともに羽織の襟を払って、ずかと銅像の足の爪を、烏の嘴のごとく上から覗かせて、真背向に腰を掛けた。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の池の行水だね、しかし白蓮華は丈高い。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "下山の時の面影は、富士川の清き瀬に、白蓮華の花びらにも似られよとて、切に本腹を祈つたのである。",
              "citation": {
                "source": "雨ふり",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "血は上ずっても、性は陰気で、ちり蓮華の長い顔が蒼しょびれて、しゃくれてさ、それで負けじ魂で、張立てる治兵衛だから、人にものさ言う時は、頭も唇も横町へつん曲るだ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "藁が散り、木の葉が乱れた畑には、ここらあたり盛に植える、杓子菜と云って、株の白い処が似ているから、蓮華菜とも言うのを、もう散々に引棄てたあとへ、陽気が暖だから、乾いた土の、ほかほかともりあがった処へ、細く青く芽をふいた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "おありがたや親鸞様も、おありがたや蓮如様も、それ、この杖に蓮華の花が咲いたように、光って輝いて並んでじゃ。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手には机に近く茶器を並べた水屋と水棚があって、壁から出ている水道の口の下に菜種と蓮華草の束が白糸で結わえて置いてある。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "涅槃は熱帶の夜明けにひらく巨大の美しい蓮華の花かふしぎな幻想のまらりや熱かわたしは宗教の祕密をおそれるああかの神祕なるひとつのいめえぢ――「美しき死」への誘惑。",
              "citation": {
                "source": "蝶を夢む",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあくる日の夕方、私は運動にとりかかる前に、先づきのふの墓標へお參りしたら、朝の驟雨で亡魂の文字はその近親の誰をも泣かせぬうちに跡かたもなく洗ひさらはれて、蓮華の白い葉もところどころ破れてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私の家では代々の法華宗で、殊にも私の代になりましてから、深く日蓮様に帰依仕って、朝夕｜南無妙法蓮華経のお題目を怠らず、娘にもそのように仕込んでありますので、いまさら他宗へ嫁にやるわけには行きません。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の思ひ出摘み溜めしれんげの華を　　夕餉に帰る時刻となれば立迷ふ春の暮靄の　　　　土の上に叩きつけいまひとたびは未練で眺め　　さりげなく手を拍きつつ路の上を走りてくれば　　　　（暮れのこる空よ！",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "れんげ草を摘もうとしました。",
              "citation": {
                "source": "花子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
