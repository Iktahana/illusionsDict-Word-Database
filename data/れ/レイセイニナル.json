          "literary": [
            {
              "text": "私はだん／＼涙もろくなるやうだ（その癖、自分自身に対しては、より冷静になる）。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし私はすぐ冷静になり、冷静になると同時に自分の驚きの大きさがばかばかしくなつた。",
              "citation": {
                "source": "発病",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌允　みんなが冷静になる迄待つさ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "眩暈がして倒れそうになったが、軈ていくらか落付きを取り戻し、冷静になると昨夜からのいろいろのことが頭に浮んできた。",
              "citation": {
                "source": "妖影",
                "author": "大倉※子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小松教訓　清盛邸の一間に押こめられたままの新大納言成親は、次第に冷静になるにつれて、陰謀露顕の理由をあれこれと考えていた。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第二巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に腹を立てて、すざまじい見幕で手紙を書こうとする人でも、いざ書き始めるという迄には、充分冷静になる丈の時間がある。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "物事は我々が落ちついて冷静になるとき、本当にちがったものに見えるであろう。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「新婚」は、冷静になると、やって居られない馬劇。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "血の中に立つと、勇者は常よりも冷静になるし、怯者はその反対になる。",
              "citation": {
                "source": "宮本武蔵",
                "author": "風の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユダヤ人がよく冷静になるのは心底怒ったときだ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでござりますな、よそながら、お会いになっておいでになっては」「は……なんと、お礼の言葉もござりませぬ……」弦之丞は冷静になるべく悶えていた。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "江戸の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことにサ、旅になんぞ出てみると、よけいに冷静になるからなア」「じゃアどうでも、吾々と目的を一ツにして行く気はないというのだな」「オイ天堂｜氏。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "木曾の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
