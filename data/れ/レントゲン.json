        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "草取りに来てゐた人も院長の車夫もレントゲンの助手もみな面白がって手伝ひに来た。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと悪性のものだから切らん方がよいという医師の意見と処法に従ってレントゲンなどかけていたが。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "繃帯を除くとレントゲンの光線｜焦けと塗り薬とで鰐皮色になっている堆いものの中には執拗な反人間の意志の固りが秘められているように思われる。",
              "citation": {
                "source": "食魔",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レントゲンにかけられ、血液も尿もとられた。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦学の泥の跳ねあとを棘の舌ですっかり嘗めてしまった猫のような青年紳士は蜘蛛の糸の研究者で内地レントゲン器械製造会社との密約者。",
              "citation": {
                "source": "百喩経",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レントゲンを掛けて腎臓結核だとわかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "退院まで四十日も掛り、その後もレントゲンとラジウムを掛けに通ったので、教師をしていた間けちけちと蓄めていた貯金もすっかり心細くなってしまい、寺田は大学時代の旧師に泣きついて、史学雑誌の編輯の仕事を世話してもらった。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、その胃潰瘍が程なく全快して、出血が止ったので念のために、この胃潰瘍が癌になっているかいないかを調べる目的で｜Ｘ光線にかかって、レントゲン主任の内藤医学士から「異状無し」と宣告されたのでホットして帰って来て寝台に引っくり返ったばかりのところであった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その矢先に突然にレントゲン室から帰って来た弟が、私の枕元に突立ったままメソメソ泣出したのだから、面喰わざるを得ない。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "大動脈瘤に罹っているんです」「まあ……大動脈瘤と申しますと……」「前月の二十七日にＱ大学で心臓をレントゲンにかけてもらったのです。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "受取って見ると、「レントゲン専門医学士｜古木亘」と明朝体で印刷してある。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はこの男の肉眼までが、レントゲンで出来ているのじゃないかと疑った。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "レントゲン専門の方で……」「そうです。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の深透レントゲンが大繁昌でね。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ここはどこ……」「古木レントゲン病院……」　私は唖然となった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲月斎玉兎嬢ことウノ子さんは未だ興行界を引退なさらない前からいつも私の処へ来て深透レントゲンをやっておられたのです。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "又は美人のレントゲン写真に類する者かも知れぬ。",
              "citation": {
                "source": "探偵小説の真使命",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "レントゲンをかけ腎臓結核だときまると、華陽堂病院が恨めしいよりも、むしろなつかしかった。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」――の「哲学と科学の王国」に兵士となつて、レントゲン映画といふものゝ完成に没頭してゐるファウスタスの後裔である。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "レントゲン光線の中に現れた、その人体はスパルタ風の体操を始めてゐた。",
              "citation": {
                "source": "痴酔記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それあ誰でもレントゲンで見れば、八パーセントまで故障があるんだから、心配する必要はないんださうです。",
              "citation": {
                "source": "老苦",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は香ぐわしい空気を呼吸しながら、レントゲン室や、医務室の渡廊下を過ぎ左折して、しめやかな気の湛うている第二病棟の廊下を踏んだ。",
              "citation": {
                "source": "草藪",
                "author": "鷹野つぎ",
                "note": "青空文庫"
              }
            },
            {
              "text": "平和の鳩の生まれ変かと思われる姫草ユリ子の純真無邪気な姿が、見る見るレントゲンにでもかけられたような灰色の醜い骸骨の姿に解消して行く光景を幻視した。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中に私は二本の「レントゲン映画」――と彼が云つた――といふものを観た。",
              "citation": {
                "source": "交遊秘話",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを行うには検査台の上に人を立たせ、後ろからレントゲン線で照らし、前にシアン化白金バリウムの盤をあてて見るのです。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "シアン化白金バリウムは、レントゲン線にあたると蛍光を発します。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "レントゲン線は衣服や筋肉は通過しやすいですが、金属や骨は通過しにくいですから、これらは影となって盤の上にあらわれるのです。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やっ」　と言いながら木村さんは、つかむように受け取って、「ど、どうしてこれが……」「レントゲン検査に行ったのは、これを取りかえすためだったのです」　と、俊夫君は説明しました。",
              "citation": {
                "source": "暗夜の格闘",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            }
          ]
        }
