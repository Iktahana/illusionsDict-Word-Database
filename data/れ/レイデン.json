        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "四囲の自然に攻め立てられて、万物の霊殿も小さくなって了いそうだ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "御兄弟が沢山おありですか、精霊殿？",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おお、いえ、親切な精霊殿よ、あの子は助かると云って下さい。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「半時間、精霊殿、たった半時間！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「精霊殿、これは貴方のお子さん方ですか。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私はこれから来る聖降誕祭の精霊殿のお前に居りますので？",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そうで御座いますか、精霊殿？",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "御案内下さい、精霊殿！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ですが、私にはそれだけの力がないのです、精霊殿。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "精霊殿、お願いで御座います！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でないと、今しがた出て来たあの暗い部屋がね、精霊殿、いつまでも私の眼の前にちらついているでしょうからね。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いえ、精霊殿、おお、いえ、いいえ！",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "「善良なる精霊殿よ」と、彼は精霊の前の地に領伏しながら言葉を続けた。",
              "citation": {
                "source": "クリスマス・カロル",
                "author": "A CHRISTMAS CAROL",
                "note": "青空文庫"
              }
            },
            {
              "text": "悪霊殿　この頃｜桂子は浮藻や小次郎と、京都二条の自分の館に、陰惨として住んでいた。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廃園の中に廃屋が、悪霊殿を持ちながら、滅亡の相をなして立っている。",
              "citation": {
                "source": "あさひの鎧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "11665霊殿がその辺にお住いになっているか、それはしかとは分からない。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮中に皇霊殿の設けられたのも明治四年のことである。",
              "citation": {
                "source": "日本歴史の研究に於ける科学的態度",
                "author": "津田左右吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
