[
  {
    "uuid": "ecbcdd75-8a8e-5f00-ba46-c0b4f3c33605",
    "entry": "連係",
    "reading": {
      "primary": "れんけい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
