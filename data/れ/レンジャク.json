    "definitions": [
      {
        "index": 1,
        "gloss": "waxwing (any bird of family Bombycillidae)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
