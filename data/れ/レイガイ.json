[
  {
    "uuid": "d4b8ff89-13bd-592b-be8c-8e88ef74a638",
    "entry": "例外",
    "reading": {
      "primary": "れいがい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "exception",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "唯一の例外は、二児を連れて焼津へ行った時だけだった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "病人は床に起きあがつて、殆んど例外なしに悲慘である所の、多くの天才の末路について物語つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "島崎藤村氏が、獨り彼等の中での例外だつた。",
              "citation": {
                "source": "永遠の詩人",
                "author": "宿命生涯を貫く",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に、私の作品に、悪罵を投げる人を、例外なく軽蔑する。",
              "citation": {
                "source": "自作を語る",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の場合歴史詩人等の如きはやゝ例外とす。",
              "citation": {
                "source": "地上組織",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとり日本の子供だけが、例外的に老成ぶつて、親父と同じやうな興味のもの――現實的で事實に即した物語や、合理性のある童話や――を悦ぶと考へられない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした俳句嫌いの僕であったが、唯一つの例外として、不思議にも蕪村だけが好きであった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕があらゆる俳句を理解し得ず、俳句を本質的に毛嫌いしながら、一人例外として蕪村を好み、彼の俳句だけを愛読したという事実は、思うにおそらく、蕪村の情操における特異なものが、僕の趣味性や気質における特殊な情操と密に符合し、理解の感流するものがあったためであろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が俳句を毛嫌いし、芭蕉も一茶も全く理解することの出来なかった青年時代に、ひとり例外として蕪村を好み、島崎藤村氏らの新体詩と並立して、蕪村句集を愛読した実の理由は、思うに全くこの点に存している。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度万葉集の和歌が、古来日本人の詩歌の中で、最も「若い」情操の表現であったように、蕪村の俳句がまた、近世の日本における最も若い、一の例外的なポエジイだった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人と一緒になる場合は、極く稀れに特別の例外でしかない。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或ひはまた、彼の國に於いては全く見受けられない單純な清い信仰（理想といつてもよい）を、日本の人がすべて例外なく持つてゐるらしい事にも氣がつきます。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお一歩を譲って、例外的に特殊の個人の体験として西洋の文化にも「いき」が現われている場合があると仮定しても、それは公共圏に民族的意味の形で「いき」が現われていることとは全然意義を異にする。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも、一つ一つの仮名によって、多少状態を異にし、「え」「け」などはただ一、二の例外に止まるが、「そ」「と」などは比較的例外が多く、殊に、奈良朝末期においては相当に多くなっている。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、イとウには例外がある。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "古代の国語では、母音一つで成立つ音が語頭以外に来ることは殆どないのであって、ただ「い」（ｉ）と「う」（ｕ）の場合に極めて少数の例外があるに過ぎない。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "（十一）　前に述べたように、我が国古代には、母音一つで成立つ音は語頭以外に来ることはほとんどなく、ただ、イ音ウ音の場合に少数の例外があるに過ぎなかった。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　連音上の法則の変遷（一）　ハ行音が変化して、現今のような音（ｈではじまる音）になった後も、語頭にのみ用いられることはかわらない（ただし、複合語などの場合には多少の例外がある）。",
              "citation": {
                "source": "国語音韻の変遷",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごく少数の、例外と見られるものがありますけれども、これは何か他の説明が出来るものと思います。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこの龍麿の研究を見ますと、その中には今申した事に対する例外と認められるものが大分出ているのでありまして「何々とあるは正しからず」という風に、右のようなきまりに合わない例があげてあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはつまり例外なんで、二類に分れて混ずることなしと言いながらしかも例外、すなわち分れていない例がある。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その文字を訂正すれば例外とならないものを、それが出来なかったために正しくない例が出来たものもあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいはまた文法の考えが発達していなかったために、二つに分けるべきものを一つにしたために、例外としなければならなかったものもあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、カ行四段動詞の已然形と命令形は、仮名で書けば両方とも同じ「け」でありますけれども、昔の万葉仮名では、別の類の文字で書いてあって、区別すべきでありますのに、龍麿はこの二つの形を同じと考えたものでありますから、多少例外が出来て、二つの類の仮名が混じて用いられているように見えたものもあります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に『万葉集』巻十四の東歌および巻二十の防人の歌において例外が取分け多いのでありますが、私の見る所では、これは東国の言語で、大和その他中央部とは違った田舍の言語であるがためにそういう例外が多いのであるという風に考えられるのであります。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "前売り切符だの、ぷれいがいどなどは、便利に見えるのは、金のかゝらぬと言ふ点だけで、却て手数が多くかゝる様になつた。",
              "citation": {
                "source": "芝居見の芝居知らず",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただれいがいとして、サミユル艇長だけは艇からおろされ、町に住まわせられていた。",
              "citation": {
                "source": "怪星ガン",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それいがいにもチラホラ腑におちぬ風聞があり、さらに今暁の、足利千寿王の失踪という突発事も起ったので、「念のためだ。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
