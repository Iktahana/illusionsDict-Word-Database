  {
    "uuid": "e64294fd-f25f-5e4e-af0a-8ee85634e9b1",
    "entry": "冷製",
    "reading": {
      "primary": "れいせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold dish (e.g. at a restaurant)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "第二は冷製魚肉玉子掛汁および寒天｜寄物（マヨナイズ　ド　サモン、アンギール　ア　ラ　ゼリー）にて冷製魚肉玉子掛汁は鮭の冷肉に玉子の黄身にて作りたる掛汁を添え寄物は鰻の肉をゼリーにて寄せしものなり。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の料理は雁肝冷製寄物（アスピック　ド　ホアグラ　ド　ストランボルダ）といい雁の肝をゼリーにて寄せたるもの。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四は豚肉冷製寄物（ジャボン　デコレ　ア　ラ　ジェリー　バアンド　フルツ　アッソルチ）にしてハムを寄せしもの。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第五は冷製混肉および冷製｜饂飩粉入鳥肉（パテ　ド　ジビィ、ガランチン　ド　ワライ）とて混肉は軍鶏の肉へ豚の肉を砕きて詰めしもの。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "使用人たちは冷製の肉のスライスを、キャビアの壺を、スライスパンを、純物のバターを、本物のコーヒーを、そして酒を、ふんだんに運び込んだ。",
              "citation": {
                "source": "いえ、いえ、ラゴーフにはもう！",
                "author": "C. スミス　C. Smith",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
