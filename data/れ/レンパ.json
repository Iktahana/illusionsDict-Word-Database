          "literary": [
            {
              "text": "」「白｜鮠のこれんぱかしのは無いかい。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「石斑魚のこれんぱかしのは無いかい。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「岩魚のこれんぱかしのは無いかい。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「川｜鯊のこれんぱかしのは無いかい。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これんぱかしの若鮎はないかい。",
              "citation": {
                "source": "川",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、「あれんぱつちの子供を集めて託兒所なんて言うと、コッケイに見えるでしようね？",
              "citation": {
                "source": "肌の匂い",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            }
          ]
        }
