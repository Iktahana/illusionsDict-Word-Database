        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "露西亜革命の博物館だが、ろしあ共産党の歴史博物館でもあり、同時にまたレイニンの個人博物館をも合わせているのだ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月七日（土曜）　朝十二時頃よりクレムリンの中の歴史博物館へ行ったが、ブブノワ女史の紹介して呉れた人居ず。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "○歴史博物館へ行った。",
              "citation": {
                "source": "日記",
                "author": "一九二八年（昭和三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから歴史に關係ある品物ばかりを陳列した博物館は歴史博物館といひます。",
              "citation": {
                "source": "博物館",
                "author": "濱田青陵",
                "note": "青空文庫"
              }
            },
            {
              "text": "よって、歩を歴史博物館に転ず。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本はトゥウェルスカヤ通りの方から来た通行人が、歴史博物館の赤煉瓦の建物のよこから、レーニン廟の前をとおり、広場をよこぎって、時計台の下からモスク※河岸へ下りてゆく道。",
              "citation": {
                "source": "道標",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
