[
  {
    "uuid": "42a37ac0-7a9a-532c-9810-919cc094bc28",
    "entry": "列島",
    "reading": {
      "primary": "れっとう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
