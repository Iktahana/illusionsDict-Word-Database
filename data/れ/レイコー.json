        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冷コーヒーに、ケーキ。",
              "citation": {
                "source": "神戸",
                "author": "古川緑波",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷コーヒーに、ロイヤル・プディング。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "銀座の風月二階で、冷コーヒー飲みつゝ藤山を待つ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あやふやだが、一回の仕事故いゝ加減にして、風月へ行って食事、ポタアジュ、鮃、マカロニ、肉、チキンライスそして冷コーヒーに菓子。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなかき揚げを平げ、すしの方へ行き、喫茶で冷コーヒーとみつ豆と菓子。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "喫茶で冷コーヒー二杯。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷コーヒーをのみて座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕一路へ寄り冷コーヒーを飲み、帝劇三階稽古場へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "京宝前の伴淳三郎の店ＶＡＮで冷コーヒーをのみ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＶＡＮに寄り冷コーヒーのみて出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニットーで冷コーヒーを飲み、座へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "堀井夫妻も一緒に下車、駅前で冷コーヒーを飲み、女房・清・荒井と堀井夫妻で、ハイヤー、大仁へ向ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘球盤を買ふつもりが、小さいのしかないので、止めて、四階の新を呼んで食堂で冷コーヒー、伊東屋へ寄って、カルムを買って、本社へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "近くのクラブで一荘やり、浅草へのして、来々軒のワンタンに中華丼、王国の生駒のとこでハトヤの冷コーヒー、結局みやこのウイと、浅草を満喫し、酔ひの帰り。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから喫茶店で栗ぜんざいと冷コーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "女房と京極へ出る、太智吉瀬戸物屋を見たが欲しいものなく、ＶＡＮへ寄り、冷コーヒーとみつ豆食って、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブラジレイロへ寄り冷コーヒーのみ、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "白井氏漸く来り、冷コーヒーのみて、レヴィウ話をし、一緒に大阪へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷コーヒーとバナゝが出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "プラムプディングと冷コーヒー。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
