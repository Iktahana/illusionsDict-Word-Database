[
  {
    "uuid": "88039eb4-c5bc-5b86-aa06-94609ed14dea",
    "entry": "霊媒",
    "reading": {
      "primary": "れいばい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
