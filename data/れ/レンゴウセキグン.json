          "literary": [
            {
              "text": "連合赤軍の五人は河合楽器の浅間山荘に、管理人の妻を人質に立てこもった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌三月、連合赤軍内のリンチによる死亡者の遺体、続々と発見。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "連合赤軍による事件が浅間山荘への立てこもりから内部でのリンチによる殺人へと大きくその相を変えた時期、タケシは合格の報せを受けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
