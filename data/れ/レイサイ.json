[
  {
    "uuid": "61f6c6f7-dd00-5b71-b162-e01735be2047",
    "entry": "例祭",
    "reading": {
      "primary": "れいさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "regular festival",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "六所明神の例祭は三日に始まって、六日の朝に終る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "尚津名郡大谷村の大谷八幡宮に就いて、「例祭六月十五日。",
              "citation": {
                "source": "淡路人形座訪問",
                "author": "竹内勝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "一社の特殊神事で、全国に亙る通例祭事ではなかつた。",
              "citation": {
                "source": "村々の祭り",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "十一月十五日の例祭にオレは山上の社殿の前から八方に向って三十本の神の矢を放す。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十七　狼大明神",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁日は毎月の十二日で、例祭は八月十二日、甚内が処刑せられた日ということになっている。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそれがこの金沢八幡社の恒例祭日にも行われているのだ。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "伊藤君記述の『八幡神社略記』に、「八幡宮の北方に当る村落を仙北の北浦と称し、此地方に於ける妙齢の女子、恒例祭に社参し、一夜の参籠を為すに非ざれば、嫁がざるもの多しと。",
              "citation": {
                "source": "春雪の出羽路の三日",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "例祭四月八日、九月十九日。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "山上ニ竜神大明神社ヲ勧請ス、村中ノ鎮守ニテ例祭九月初子ノ日。",
              "citation": {
                "source": "二、三の山名について",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（青根村）大室社二　一ハ村ノ鎮守、例祭九月廿日、相殿ニ八幡山神ヲ置。",
              "citation": {
                "source": "マル及ムレについて",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "例祭は五月五日で、前祭として五月二日にお鏡磨祭、同三日には競馬祭、同四日に御綱祭がある。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "猫眼の男",
                "note": "青空文庫"
              }
            },
            {
              "text": "加茂や祇園の例祭には桟敷もかかり、人出も多かった。",
              "citation": {
                "source": "東山時代における一縉紳の生活",
                "author": "原勝郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "播州明石市の稲爪神社の例祭には、牛乗権兵衛という神事がある。",
              "citation": {
                "source": "穀神としての牛に関する民俗",
                "author": "中山太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三峰の例祭は、三日間とある。",
              "citation": {
                "source": "宮本武蔵",
                "author": "二天の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮島を以て知られている羽前大沼の浮島稲荷神社も古くから例祭は四月八日で、祭神宇迦之御魂というも元は宇賀神すなわち弁才天の信仰に始ったものらしい。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにまた野州葛生の峰渡権現においても、昔蛇体となったという長者の妻の供養を、同じくこの日に行う例であったといい、四月六日を以て例祭とする近江伊香郡の大音神社にも、やはり弘法大師が池の主を済度したという、かのせせらぎ長者の妻虎御前の話（同上四巻三三九頁）と相似たる話を遺している。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "京都内外の古い大きな神社でも、申の日｜酉の日または卯の日等を以て、毎年の例祭を執り行うものが、稀ではない。",
              "citation": {
                "source": "年中行事覚書",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "熱海来宮の七月十六日の例祭に、古来行われていた鹿島踊の記録は、かなり精密なものが『民俗芸術』三の八に報告せられている。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "是がもし植物の自然の要求ならば何でもないが、晩稲が今のように普及してからでも、我邦の稲収穫期はまず旧九月一ぱいで、十月は神無月、『延喜』の四時祭式を見ても、一社にも例祭の無い月である。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな神社の中にも、卯の日を例祭の日としたものが幾つかあるが、それよりも著しいのは田の神の祭、または稲作に伴なう色々の行事、および正月の年の神の去来について、特に卯の日を重視する風は、現在もなお到る処に残っている。",
              "citation": {
                "source": "海上の道",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
