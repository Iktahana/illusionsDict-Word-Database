    "definitions": [
      {
        "index": 1,
        "gloss": "wrench",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その新しい草双紙で、ヴアレンチノや林長二郎のやうな美男が扮する、架空の人物を現實の夢にたづねて、いぢらしくも處女の胸をときめかして居る。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜子（西瓜のたね）　烏秋（台湾烏）　　赤嵌楼（蘭人の所謂プロヒレンチヤ城なり）蕃童蕃童は※仔を射る。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "瓜子（西瓜のたね）烏秋（臺灣烏）赤嵌樓（蘭人の所謂プロヒレンチヤ城なり）鴛鴦飛ぶ禽としも、幽かだに思ひかけずておろかさよ、こずゑの雪に鴛鴦のたつる羽音を觀しや君。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ、下手人はもみあげの長いヴァレンチノだろう。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フレンチロールですかコッペーですか。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "フランチエスカの君はかの士官の妻になるべき約を定めて、遠からずフイレンチエなるフアビアニ家の莊園に遷らんとす。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダンテは千二百六十五年フイレンチエに生れぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "フイレンチエはその自然の美しき、その畫廊の備れる、居るに宜しきところなれど、再生祭の後こゝに歸らんことは、今より姫の樂むところなり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "フイレンチエまで共に行き給はずや。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "我はまたフイレンチエの畫廊に往きて君とけふ物語れることを想ふべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われは姫の供したる人の男ならざりし嬉しさに、幸あらん夜をこそ祈れと聲高く呼びて去らんとせしに、姫進み寄りて、惡しき人かな、早くフイレンチエに遁れ行かばやといひつゝも、手さし出せるを握るに、かなたも親く握り返しつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "フイレンチエにや行くらん。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "姫はフイレンチエにての事細かに語りて、さて精進日の羅馬はいかなりしと問ひぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "此に至りて、自ら我手中の詩篇を顧みれば、復た前の綽約たる姿なくして、彼三王日の前夜フイレンチエ市を擔ひ行くなる「ベフアアナ」といふ偶人の、面色極めて奇醜にして、目には硝子球を嵌めたるにも譬へつべきものとなりぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "初め我は先づフイレンチエに往き、かしこよりボロニア、フエルララを經て、ヱネチアに達せんと欲せしに、今は忽ち前の計畫を擲ち、スポレツトオより雇車を下り、暗夜身を郵便車に托してアペンニノの嶺を踰え、ロレツトオの地をさへ、尊き御寺を拜まずして馳せ過ぎつ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "フィレンチェ派学ぶはミケランジェロ、ヰンチイが幽霊、和蘭派学ぶはルウベンス、ファン・ヂイクが幽霊、我国のアルブレヒト・ドュウレル学びたりとも、アルブレヒト・ドュウレルが幽霊ならぬは稀ならむ。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯ブレンチウス（Brentius）いう、人が患難に会したる時はその患難を以てその人を審判くべからずその人格を以てその患難を審判くべしと。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　返事がなかったので、妾は、右手のフレンチ・ウィンドーを、片側だけ斜に外へ押した。",
              "citation": {
                "source": "オパール色の手紙",
                "author": "――ある女の日記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃は「アイ・アイ・アイ」とか「ヴアレンチア」とか「ライト・キヤバレ」などといふ相当の難曲（？",
              "citation": {
                "source": "雪景色",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "本はアメリカでできたフレンチ・ブックとかいうので、英語でフウト・ノートがついていた。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレンチ・ノベリスト（仏国文学）。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまた今、「マソー・レンチャンテッド」（訳名アンネットとシルビー）を読んでおりますが、まだほんの初めですから、はっきりしたことはいわれませんが、私はこの作者の見方や、感じ方についても、或る疑いを抱いております。",
              "citation": {
                "source": "十年の思い出",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――今週何があるかしら――バレンチノ――荒鷲なんての素敵だったな」　志野が、自分の宝を自慢するように吹聴した。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからフレンチペーストをたべる。",
              "citation": {
                "source": "「黄銅時代」創作メモ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "フレンチ・ドアを背にして置かれた長椅子は、鄙びた紅天鵝絨張り、よく涙香訳何々奇談などと云った小説の插画にある通りの円い飾玉のついた椅子。",
              "citation": {
                "source": "長崎の一瞥",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「同月十三日フレンチ（被告人の家の主治医）は被告人からのノートを受け取つた。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の所に駆けつけたフレンチは、マンディーが浴槽の中に既に死んでいるのを見出した。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の田之助でも五代目菊五郎でも又は今日の中車、源之助などの顔には、如何にも、のんびりとした、粋な、東洋風なところがあったが、今日の役者衆の顔は例外もあるが、どうも、この間のびの味がなく、キリッとしたいい男だが、どうも、バレンチノといったようなところ、または重役様のおぼっちゃんといった感じがする。",
              "citation": {
                "source": "新古細句銀座通",
                "author": "岸田劉生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムーアはＰＣＣのメンバーで８００８を使ってコンピューターの自作を経験していたゴードン・フレンチを誘い、ハードウエアを中心としたサロンを別に作ろうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
