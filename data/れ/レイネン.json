    "definitions": [
      {
        "index": 1,
        "gloss": "average (normal, ordinary) year",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
