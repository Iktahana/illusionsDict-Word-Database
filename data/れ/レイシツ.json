[
  {
    "uuid": "88ea7105-2f93-5c56-81b4-b3486af57ecb",
    "entry": "令室",
    "reading": {
      "primary": "れいしつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
