[
  {
    "uuid": "ce88069c-f625-5ff5-8e46-ccbb94353553",
    "entry": "例規",
    "reading": {
      "primary": "れいき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
