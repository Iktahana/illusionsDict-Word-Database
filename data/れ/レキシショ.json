    "definitions": [
      {
        "index": 1,
        "gloss": "history book",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてまた各種の戦記や野史（在野の人が編纂した歴史書）にも軍気に関する記事が散見するのを認める。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「海賊族の信仰」と題するいとも怪しげなる歴史書であつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ちその當時にあつてはそれみづからが一の歴史敍述であり、一の歴史書であつたものが、後世の歴史家にとつては一の史料となる。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロゴス的史料のうちには嘗ての歴史書がその注目すべき一部分として含まれてゐる。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "云ふまでもなく、あらゆる他の種類の史料と同じく、歴史書も史料として、存在としての歴史と決して等しくはない。",
              "citation": {
                "source": "歴史哲學",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　矢代は父が寝てしまってからも、自分の書斎でひとり呟き、基経、時平あたりの歴史書を急に開いてみたりした。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この物語によって読者は絵画的に具象化されたかの革命とその時代とについて歴史書以外の知識と感銘とを得るであろう。",
              "citation": {
                "source": "二都物語",
                "author": "上巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日印刷歴史書やその他で本木について書かれる傳記的文章は、主としてこれから出てゐると謂はれるが、それは五百字詰の用紙にすると二十枚足らずであらうか。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし「安政の開港」といへば、幾多の歴史書が示すとほり、最も重要點を嘉永六年から安政二年の間におく。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの歴史書が傳へるやうに、當時幕府の「御武備御手薄之故」彼の砲身の長い大砲と、煙を吐いてはしる黒船に、ある程度は氣壓されたと殘念ながら認めねばなるまい。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の印刷歴史書が説くところに從へば、十五世紀中葉グウテンベルグの「流し込み」活字は、十八世紀に至つて第二の開花期に達してゐたのであつた。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "西洋の印刷歴史書では、彼がロンドンの活字鑄造所で見覺えた趣きも書いてあるが、「自傳」に書かれてゐる限りでは簡單すぎてグウテンベルグ以來の鑄造法にどれほどの改良を加へることが出來たかは判斷できない。",
              "citation": {
                "source": "光をかかぐる人々",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "理性と感性との分離もまだ出来ていなかった古代人の心理は、歴史書からはもちろん覗けない。",
              "citation": {
                "source": "『死者の書』",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "在来の道元の伝記のうち、『元亨釈書』及び『本朝高僧伝』に載するところは、明治大正の歴史書に載するところの簡単にして無意義なる叙述とともに、単に彼の生活の重大ならざる輪郭を伝えたに過ぎぬ。",
              "citation": {
                "source": "日本精神史研究",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾々のもつほとんど一切の伝染病の歴史書は、伝染病は一般に、下層階級の間で主として猖獗を極めると書いて、この仮定を確証する傾きがある。",
              "citation": {
                "source": "人口論",
                "author": "AN ESSAY ON THE PRINCIPLE OF POPULATION",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖書六十六巻、その中には歴史書もあり、法律書もあり、伝記もあり、古代社会の生活記録もあり、詩歌もあり、格言集もあり、その範囲の広範にして材料の豊富であること、その描写が素朴であり自然であって人間性の深さに徹していること。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘブライ語聖書で「預言者」と呼ばるる部分は、預言者のほかに、古い時代にできた歴史書（ヨシュア記、士師記、サムエル書、列王紀略）を含む。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらの歴史書はサムエルに端を発した預言者たちが編纂したものと認められ、預言者精神によって貫かれている。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三の「知恵」と呼ばるる部分は、詩篇、箴言、ヨブ記、エレミヤ哀歌、ダニエル書並びに新しい時代に書かれた歴史書（歴代志略、エズラ書、ネヘミヤ記、ルツ記）を含むものであって、紀元前第二世紀終わり乃至第一世紀始めごろにはできあがっていたものと思われる。",
              "citation": {
                "source": "キリスト教入門",
                "author": "矢内原忠雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして近時刊行される一切の工藝に関する歴史書もこのことを表示する。",
              "citation": {
                "source": "工藝の道",
                "author": "柳宗悦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新たに移動された書物は全て現代のもので、歴史書、科学論文、地理書、作文法、哲学書、および最近の新聞雑誌類だった。",
              "citation": {
                "source": "チャールズ・デクスター・ウォードの事件",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は太郎と朝一緒に出て、図書館へ行って、近いから調べるものしらべて、例の婦人作家の歴史書いてしまいたいと思います、咲枝二十一日間はいるかもしれませんから、病院に。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、この本は歴史書のようなところもあるし、宗教的でもあるし、美術として考えている個所もあるし、また旅行記として書かれた文章も入っている。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "栄養学は分析化学および一般生理学の発展に大きく依存してきたが、これらの歴史書は既に存在している。",
              "citation": {
                "source": "栄養学小史",
                "author": "A Short History of Nutritional Science",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして時あらば常にそのファンタジー世界の断片を歴史書の中に書き込もうとするのだ。",
              "citation": {
                "source": "ナショナリズムについての覚書",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴史書に曰く、余りにも激しかったので周囲八十キロメートルの海上はちりと液火に覆われ、誰も近づけなかった。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、渋沢のその原文は、萩野由之の歴史書をもとにしたものである。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして現われた歴史書は、歴史｜捏造の書物としては、おどろくべき巧妙なものであつた。",
              "citation": {
                "source": "天皇",
                "author": "誰が日本民族の主人であるか",
                "note": "青空文庫"
              }
            },
            {
              "text": "近時の歴史書ブームの盛行をみてもそれはいえる。",
              "citation": {
                "source": "随筆　私本太平記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
