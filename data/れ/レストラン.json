    "definitions": [
      {
        "index": 1,
        "gloss": "restaurant (esp. Western-style)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この橋のあるあたりの小高い崖の上に、湯元ホテルとかいふ木造のホテル兼レストランがある。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後七時になるとレストラントの扉が一斉に開く。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里のレストラントを一軒一軒食べ歩くなら、半生かかっても全部｜廻れないと人は云っている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し巴里のレストラントの数は東京の比ではない。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角中流以下のレストラントには必ず何人かの常客がいて、毎日同じテーブルに同時間に同じ顔を見ることが出来る。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "巴里に行った人で一度はレストラン・エスカルゴの扉を排しないものはないであろう。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エスカルゴとは蝸牛のことで、レストラン・エスカルゴは蝸牛料理で知られている店である。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝸牛はどれでもこれでも食べられるのではなくて、レストラン・エスカルゴ等で食べさせるのはブルゴーニュという地方で産するものである。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝸牛の季節には巴里のレストラントのメニュウには大抵それが載っている。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスのレストラントへ行ってメニュウを探して見るとポークカツレツというのがあるから、喜んで注文するとそれはわれわれの予期するカツレツではなくて日本の所謂ポークチャップであった。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "倫敦で会った人の話に、その人もトンカツを英語とばかり思っていたので、レストラントへ行ってトンカツレツをくれと云ったがどうしても通じないで非常に弱ったそうだ。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外国の日本人経営のクラブとかレストランでは先例によって女を雇入れることはめったにないことなのだが、私は天津の日本租界、敷島町の或るレストランに近頃日本の少女が青磁の衣服をつけてそれでなくとも感傷的になった旅人の私の心を瞑想的にするのに会ったことがある。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ等の人間が急行列車桜、高速力巡航船、ホテル、トーキー常設館、オフィス、レストラン、冬期競馬場、少女歌劇場、それらの場所にいたあらゆる階級人が、驚愕するような事件が勃起した。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは英介氏のむかし馴染みの女友だちがたずねてやってきて、英介氏を郊外の酒場へさそったり、彼女たちのアパルトマンでポーカーを一晩中やったり、英介氏にタキシードを着せてテッフィン（レストラン）に連れだしたりしたからだ。",
              "citation": {
                "source": "職業婦人気質",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでもちゃんとした礼装をして、頭髪を綺麗に分けて、顔を剃り立てて、どこの国の一流のレストランのボーイにもひけを取らないだけの身嗜みをしていた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もこの男に限らない事ではあるが、私はすべてのレストランのボーイというボーイの顔のどこかに潜んでいるある特別な表情を発見する事が出来ると思う。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに酒を飲むにしても、どこか川っぷちのレストランみたいなところで、橋の上からだとか向こう岸からだとか見ている人があって飲んでいるのならどんなに楽しいでしょう。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "レストランの高い建物が、思わぬところから頭を出していた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "またときには露店が店を畳む時刻まで街角のレストランに腰をかけていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストーヴに暖められ、ピアノトリオに浮き立って、グラスが鳴り、流眄が光り、笑顔が湧き立っているレストランの天井には、物憂い冬の蠅が幾匹も舞っていた。",
              "citation": {
                "source": "冬の日",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし入れ歯のできあがった日に、試みに某レストランの食卓についてまず卓上の銀皿に盛られたナンキン豆をつまんでばりばりと音を立ててかみ砕いた瞬間に不思議な喜びが自分の顔じゅうに浮かび上がって来るのを押えることができなかった。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろあるレストランで友人と食事をしていたら隣の食卓にインドの上流婦人らしい客が二人いて、二人ともその額の中央に紅の斑点を印していた。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "生きている時には父のこしらえた一等料理もそこらのレストランの料理も見境なく食った。",
              "citation": {
                "source": "食魔に贈る",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "アウル・グリル・エンド・レストラントか？",
              "citation": {
                "source": "少女",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "晝頃になつて、私は町のレストラントに坐つて居た。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼頃になつて、私は町のレストラントに坐つて居た。",
              "citation": {
                "source": "散文詩集『田舎の時計　他十二篇』",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "むす子が、起きてから珈琲を沸すのが面倒な朝や、夜更けて帰りしなに立ち寄るかも知れない小さい箱のようなレストランや、時には自炊もするであろう時の八百屋、パン屋、雑貨食料品店などをむす子に案内して貰って、一々立ち寄ってみた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの女達は、むす子を頼んで置くその青年医を一夕、レストランへ招待した。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
