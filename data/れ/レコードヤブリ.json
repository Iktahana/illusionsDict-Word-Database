          "literary": [
            {
              "text": "彼の聴講者は千二百人というレコード破りの多数に達した。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「‥‥」渠は吹き出したかつたが、かの女の多少は遠慮してゐるらしい聲が、持ち前の癇性を運んで、ぴんと靜かな聽衆の耳に響いたと思はれたので、この演奏會のレコード破りをやつたやうな申しわけ無さを感じた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに若い機関長のレコード破りというのが評判で、アタリ八方、持てたの候のってお話にならなかったが、実をいうとコイツが悪かったんだね。",
              "citation": {
                "source": "焦点を合せる",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ行く」といって再び細菌科長の方を振りかえり、「今日はレコード破りだぞ。",
              "citation": {
                "source": "蠅",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "いよいよ儂たちは新聞の社会面でレコード破りの人気者となったよ。",
              "citation": {
                "source": "恐怖の口笛",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "今年はあのひとが戸塚に来たので、どてらの直しや何かたのめて、レコード破りのポンポコになりました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三八年（昭和十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、日本の失業統計のレコード破りである。",
              "citation": {
                "source": "現実の必要",
                "author": "――総選挙に際して――",
                "note": "青空文庫"
              }
            },
            {
              "text": "雨の日曜なのでぎっしり大満員、六月の宝塚としてはレコード破りらしく皆驚いてゐる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
