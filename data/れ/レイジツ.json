        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "苔はまことに、ひんやりいたし、いはうやうなき、今日の麗日。",
              "citation": {
                "source": "在りし日の歌",
                "author": "亡き児文也の霊に捧ぐ",
                "note": "青空文庫"
              }
            },
            {
              "text": "二月十七日　〔市ヶ谷刑務所の顕治宛　上落合より（国枝金三筆「麗日」の絵はがき）〕　二月十七日　日曜日。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三五年（昭和十年）",
                "note": "青空文庫"
              }
            }
          ]
