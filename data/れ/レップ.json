    "definitions": [
      {
        "index": 1,
        "gloss": "chaste, strong-minded woman",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "女にも烈婦があった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "倫理學説が其の價値を認めずとするも、忠臣義士は長へに忠臣義士たり、孝子烈婦は長へに孝子烈婦たり、人間の最も美はしく貴むべき現象たることに於ては毫も渝るところ無き也。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "古の忠臣義士、孝子烈婦の遺したる幾多の美談は、道徳の名によりて傳はれりと雖も、實は一種の美的行爲のみ。",
              "citation": {
                "source": "美的生活を論ず",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで彼はあたって見たところ、烈婦の気性ある織江であった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にハリウッドの女優のような知性と生活技法、経済的基礎とをもってしても、離合のたびに女性の品位は堕落し、とうてい日本の貞女烈婦のような操持ある女性の品位と比ぶべくもないのである。",
              "citation": {
                "source": "人生における離合について",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は久しぶりに「烈婦」という文字を、この老女史でおもい出した。",
              "citation": {
                "source": "烈婦",
                "author": "高田保",
                "note": "青空文庫"
              }
            },
            {
              "text": "それならば、青年男女の夢を養ふものはなにかといふと、これまでは、多くは、英雄偉人の立志伝であり、或は、貞女烈婦の美談でありました。",
              "citation": {
                "source": "青年の夢と憂欝",
                "author": "――力としての文化　第五話",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふでが、お家の危急を知つて自ら小松姫と名のつて、二条家に入り込んで、愛護を助け、二つの宝を悪人の手に渡さなかつた、といふ話は、遠からずして表れた「ひらがな盛衰記」の烈婦おふでの導火である。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞍・大刀は、綾丸の大刀・遠山の鏡と名が変つて、烈婦小松が志賀六（黒道）を殺して、奪ひとつて、二条家に献じた宝と言ふ事になつてゐる。",
              "citation": {
                "source": "愛護若",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "降る亜米利加に肌を濡らさじと言って自害した烈婦の出ない事を、今の世に問うて慨嘆するのは無理であろう。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "降る亜米利加に肌を濡らさじと言つて自害した烈婦の出ない事を、今の世に問うて慨嘆するのは無理であらう。",
              "citation": {
                "source": "冬日の窓",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "われらはみな、英雄たり、烈婦たるの素質を恵まれてゐるのである。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈婦べつに小店を開き、茶を煮て客に供し以て夫を養う。",
              "citation": {
                "source": "蓮月焼",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくばくもなく夫死し、寡居みずから守る云々というもので、要するに、夫を養い後家をとおした烈婦だというにある。",
              "citation": {
                "source": "蓮月焼",
                "author": "服部之総",
                "note": "青空文庫"
              }
            },
            {
              "text": "……処刑するには惜しい烈婦じゃ。",
              "citation": {
                "source": "仇討姉妹笠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼曰く「節母烈婦あり、然りて後孝子忠臣あり、楠、菊池、結城、瓜生諸氏において、これを見る」と。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "里人からそんなにまで慕ってもらいました私が、やがて病の為めに殪れましたものでございますから、その為めに一｜層人気が出たとでも申しましょうか、いつしか私のことを世にも類なき烈婦……気性も武芸も人並すぐれた女丈夫ででもあるように囃し立てたらしいのでございます。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この烈婦の心にそむいて結婚することはできない。",
              "citation": {
                "source": "庚娘",
                "author": "蒲松齢",
                "note": "青空文庫"
              }
            },
            {
              "text": "病床十年を切り抜けたところで夫の死を見た彼女は、烈婦のカガミのような人であった。",
              "citation": {
                "source": "我が愛する詩人の伝記",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しょげることはないさ」「……あんなに、貞女と烈婦には決してなるまいと思って暮して来たのに――」　ひろ子は、このとき重吉のとなりにかけている中年男が自分たち二人の言葉のやりとりに関心をもってきいているのを知った。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家が大事と思い込まれていたおくめは、烈婦になった心持で、離別を承諾した。",
              "citation": {
                "source": "黄昏",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな気持がなければ、もっともっと烈婦らしい書きぶりの手紙さし上げたことでしょう。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "体つきから云っても、わたしは烈婦ではないかもしれないけれども、少くとも勇婦ではあり得そうです。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "烈婦というものはね、やせ型で、眉根キリリと、つり上り唇薄くやや三白眼なのよ。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、ぬけ上った額が黒赤く光って、肩の骨の張った烈婦よりも、桃太郎風の勇婦が気に入ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かというとおどすんですね」「それがさ、妾におどされるのが、お前にはひどくうれしそうじゃアないか」「またあねごときた日には、あっしをおどかすのがうれしそうですねえ」「おどかされっぷりがいいからさ」「ところであねごはおどしっぷりがいいや。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "タッタ今二千円をイタブッて出て行ったばっかりのところなんだが……どうも彼奴の呉れっぷりが美事なんでね。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」さもさも感心したように、「いやもくれっぷりのよいことだの。",
              "citation": {
                "source": "三甚内",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は、あの狭い笈の中へ押込められて、馬の背に揺られ通して来たけれど、さして眠いとも思わず、またさして疲労も感じないのに、弁信さんの眠たいことと、疲れっぷりは随分ひどいと、今更のようにながめました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "禹門三級の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "さしもの遊民どもが手出しができないのみならず、あいた口がふさがらないのは、その荒れっぷりの乱暴と迅速とのみならず、六尺豊かの髯面の大男の、威勢そのものに呑まれてしまったからです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "他生の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
