[
  {
    "uuid": "feb4b382-9be6-55d0-b4b3-0d2872a7df9e",
    "entry": "冷水",
    "reading": {
      "primary": "れいすい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold water",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お蘭は冷水で絞った手拭を持って来てやったり、有り合せの蕨餅に砂糖をかけて出してやったりした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "真赤になるほど焼いたのを冷水中に投じても何の異状もないというのが特長である。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "厚い錫の茶碗の中に、汲み立ての冷水を盛つて飮むのである。",
              "citation": {
                "source": "ラムネ・他四編",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "神経衰弱か何かの療法に脊柱に沿うて冷水を注ぐのがあったようであるが、自分の場合は背筋のまん中に沿うて四五寸の幅の帯状区域を寒気にさらして、その中に点々と週期的な暑さの集注点をこしらえるという複雑な方法を取ったわけである。",
              "citation": {
                "source": "自由画稿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "考えただけでも、背中に冷水をかけられたように、ぞっとして、息がつまる。",
              "citation": {
                "source": "待つ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "驚きましたねエ、僕は頭から冷水をかけられたように感じて、其所に突立って了いました。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "音が近づくにつけて大きくなる、下草や小藪を踏み分ける音がもうすぐ後ろで聞こえる、僕の身体は冷水を浴びたようになって、すくんで来る、それで腋の下からは汗がだらだら流れる、何のことはない一種の拷問サ。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は起きぬけに冷水浴をすまして朝飯を食ふと、三人顏を寄せて事々しく何か相談しながら家を出て行くのだ。",
              "citation": {
                "source": "小さき影",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、冷水を腦の心に注ぎこまれたやうに彼れの全身はぞつとした。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「冷水が可いぜ、汲立のやつを持って来てくんねえ、後生だ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若様、もうお忘れ遊ばしたでしょう、冷水は毒でございますよ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若君は轡を鳴らして、しっかと取りつつ、冷水の洋盃を長く差伸べて、盆に返し、「沢山だ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍浴場内に大の字に成ってへた張ったところ、三人して頭からガジャガジャ冷水の洗礼を見舞うとこ、たちまち家屋を震動せしむるウエーウエーの大声を連発する数回。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "猛惡なる猴の本性として、容易に手を出さない、恰も嘲る如く、怒るが如く、其黄色い齒を現はして、一聲高く唸つた時は、覺悟の前とはいひ乍ら、私は頭から冷水を浴びた樣に戰慄した、けれど今更どうなるものか。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "老人に冷水、堪ったもんじゃねえ。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "宴席どなりの空部屋へ轉げ込むと、ぐたりと寢たが、したゝか反吐をついて、お冷水を五杯飮んだとやらで、ウイーと受持の、一番さんへ床を取りに來て、おや、旦那は醉つて轉げてるね、おかみさん、つまんで布團へ載つけなさいよ。",
              "citation": {
                "source": "木菟俗見",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）　酔ぱらいさん、さあ、冷水。",
              "citation": {
                "source": "紅玉",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、銭湯で湯舟に永く浸り、湯気のふき出している体に冷水を浴びることが好きだった。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "全身に冷水を浴びせられた気持でした。",
              "citation": {
                "source": "ろまん燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、Ｋ・Ｓさんは、日本へ一枚でも残す方がいいと売価をおつけでしたが」　かの女は冷水のあとにまた温かい湯をうちかけられたような気がした。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と冷水につけた手で顔をごしごし擦り乍ら氏は私に云う。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達の部屋より表門に近い氏の部屋へ氏は主人をまず招じて座布団をすすめ、洗面器へ冷水を汲み、新らしいタオルを添えるなど、この気の利かない私よりもずっと行き届いた款待振りである。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽は殆ど椰子林に没して、酔い痴れた昼の灼熱から醒め際の冷水のような澄みかかるものを湛えた南洋特有の明媚な黄昏の気配いが、あたりを籠めて来た。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は自分の身をもよく冷水で拭き清めた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷水摩擦をはじめよ。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、総身に冷水を浴びせられたように、ぞっとしました。",
              "citation": {
                "source": "ヴィヨンの妻",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はそれを聞いて、全身に冷水をあびせられたような気がして立ちすくんだ。",
              "citation": {
                "source": "雀",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
