          "literary": [
            {
              "text": "当時、私の仕事はあるプロダクションに依頼されたラジオの連続ドラマだった。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、彼女らは「現実的」にはつねに正しく、強く、その彼女らの生きているのは、日々の暮し、というかぎりなく日常的な、またそれが日常生活であるがゆえのきりもない連続ドラマだけだ。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "まるで半年ごとに放送される連続ドラマのようだ。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
