          "literary": [
            {
              "text": "『列氏零下五度、こまかい雪が降っていましてね、猛烈に寒い朝でしたよ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、腐ったペンキのにおい、列氏三十度の暑さ、しめ切ったむんむんする空気、人混み、前の日にたずねたばかりの人間が殺された話――こうしたものがいっときに、空腹の体へきたんだからね！",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "列氏の十八度とは恐れ入りましたね。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            },
            {
              "text": "列氏十八度ですからね。",
              "citation": {
                "source": "板ばさみ",
                "author": "オイゲン・チリコフ　Evgenii Nikolaevich Chirikov",
                "note": "青空文庫"
              }
            },
            {
              "text": "すんなりと　たびは　すすみ、　ヨーロッパに　ついた　ババールは　れっしゃを　おりまして。",
              "citation": {
                "source": "ババールとサンタのおじさん",
                "author": "BABAR ET LE PERE NOEL",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
