        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただ一人、部屋に籠って明々と燃えているファイヤープレイスの前に揺椅子をひき据えていました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども勿論、そんな真暗な大雨の夜に窓から訪れて来る様な酔狂なお客様の影なぞは見とめるべくもなかったので、再びファイヤープレイスの前に戻りました。",
              "citation": {
                "source": "象牙の牌",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "淡紅色の下袴　三つの死體を運搬自動車で送り出したあと、ソオルは更に辛抱強い探査をつづけてゐたが、やがて何の氣もなく應接間の長椅子の褥をひよいと持ち上げた途端に突如として眼に著いた生々しい血染めの布、何とそれは婦人の肌に著ける贅澤なレイスで縁取りした絹の下袴の斷片ではないか？",
              "citation": {
                "source": "死の接吻",
                "author": "――スウェーデンの殺人鬼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "サリィの方はペッカム、メイフィールド・プレイス三の下宿におります。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後私は、都に出て図書館に出入し、プラトン、アナクレオン、アリストートル、ユーリビテス、ソフオクレイスを漁り、「悲劇・喜劇の発生」「その否定」に就いて考へたり、また友達に出遇ふと、都のバアとダンス・ホールと劇場と、そして体育競技場と――何も彼も素晴しい、夢のやうだ！",
              "citation": {
                "source": "喜劇考",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "プレイストシーン期に、北米に棲んだ馬数種ありて南米まで拡がった。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、普通の馬と別ちがたい遺骨が、欧州とアジアのプレイストシーン層より出るを見れば、現存種の馬が始めて世に出たは、よほど古い事と見える。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "サウシーの『コンモン・プレイス・ブック』四輯に、コングリーヴの一犬ペンクリッジ寺の修繕一年に竟り誰も詣でざるに、日曜ごとに独り欠かさず詣でたと載す。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "季娘大に怖れて聖僧ブレイスに救ひを求め、毎夜祈祷し十字を畫いて寢よと教へられた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな怪しい父なし子を生んだは怪からぬと其母を法廷へ引出し生埋の宣告をするとメルリン忽ち其母を辯護し、吾れ實は強勢の魔の子だが聖僧ブレイス之を豫知して生れ落ちた即時に洗禮を行はれたから邪道を脱れた。",
              "citation": {
                "source": "人柱の話",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その窓にはあたりに不相応なレイスカアテンのかけられてあるのを見た。",
              "citation": {
                "source": "モウタアの輪",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして片手間で受合仕事のレイス細工なぞをされたが、その方は大した足しにもならなかつた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "おくみは行李からレイス糸を出して、いたづらに、小さい肩掛袋を編みかけた。",
              "citation": {
                "source": "桑の実",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「追い出しの曲」は、予定どおり、アニマルズの〈ウィーヴ・ガッタ・ゲット・アウト・オヴ・ディス・プレイス〉（〈朝日のない街〉！",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "６おれたち、ここから抜け出さないとたとえ、そんなことなど、できないとしても〈ウィーヴ・ガッタ・ゲット・アウト・オヴ・ディス・プレイス〉アニマルズ　興奮と憂鬱が同時に押しよせて、一九六六年六月が終わりつつあった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラジオからは、〈サムバディ・トウ・ラヴ〉を歌う、グレイス・スリックの声が流れてくる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "アニマルズの〈ウィーヴ・ガッタ・ゲット・アウト・オヴ・ディス・プレイス〉のベースラインが流れ、答案用紙に鉛筆を走らせる四組を、立った視線の高さから、横移動でゆっくりと見せる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "」……「あの綺麗な噴水の傍らで、リラやカーネイシヨンの花籠を抱へたピピヤスが、ホーレイスの歌か何かを歌ひながら道往く人々に花を売つてゐる有様を、シツダルの肩にでも凭りかゝつて眺めながら、この辺で一杯飲んでゐれば、屋台店の密造酒だつてレイマンの氷で冷した灌奠酒よりも旨く飲めるといふものさ。",
              "citation": {
                "source": "山彦の街",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと部屋に籠もって勉強しているのか、それとも時には創作慾の刺戟を求めにシネマ・パレイスや武蔵野館へ行くとか、蓄音器を聞きながら、お茶を呑みに喫茶店へ入ったりして感興を唆とうとしているのか。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "襟のところに涼しげな白いレイスのついた愛らしい服装が、彼女の体をいくらか小いさく見せていたが、窶れも顔に見えていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近移ったばかりの信濃町の雪枝の家の少し手前で、タキシイを乗り棄て、白いレイスの衿飾りのある黒いサテンの洋服を着た葉子は、和装の時ほど顔も姿も栄えないので、何か寒々した感じだったが、気分も沈みがちであった。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "むこうに本館が見えて、あけはなした窓に白いレイスが動いている。",
              "citation": {
                "source": "踊る地平線",
                "author": "虹を渡る日",
                "note": "青空文庫"
              }
            },
            {
              "text": "立木に取りまかれているが、そのすきまから悲しい窓が覗いて、私の通ったときはすっかりレイスのカアテンが垂れ、人の気はいもなかった。",
              "citation": {
                "source": "踊る地平線",
                "author": "白夜幻想曲",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、その一つ一つの入口に、今朝はだしで魚を呼び売りしてたような女たちが、それぞれ木綿レイスの編み物なんかしながら客を待ってるのを見かけるだろう。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が通ると、レイス編みを中止して何か呪文を唱える、金十エスクウドの相場。",
              "citation": {
                "source": "踊る地平線",
                "author": "しっぷ・あほうい！",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそのハンケチが西班牙旧教葬の寝棺にかける黒レイスの切れはしであることを認めて、その通り彼女に告げた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "わずかに評論・報告集二冊をのこして一九二五年ごろ死んだラリーサ・レイスネルがある。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイスネルはレーニングラード大学教授の娘であった。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ラデックが「十月」にもう反革命の組織者の一人であったことをラリーサ・レイスネルは知らないで死んだ。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、さきにふれたラリーサ・レイスネルだ。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
