[
  {
    "uuid": "0563cca1-c595-5876-81d8-94b6decf4f62",
    "entry": "礼節",
    "reading": {
      "primary": "れいせつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
