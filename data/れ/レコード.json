    "definitions": [
      {
        "index": 1,
        "gloss": "(phonograph) record",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてレコードに吹き込んで呉れるかも知れない……ニツトー……ツバメか……鷲、さあ……」　私は何時の間にやらロマンチックな浮々しさになつてゐた。",
              "citation": {
                "source": "その頃の生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "真に今日、日本の現実する社会相と接触し、民衆のリアルな喜怒哀楽を表現してゐる芸術は、蓄音機のレコード等によつて唄はれてる、町の流行唄以外にないのである。",
              "citation": {
                "source": "流行歌曲について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "珈琲店　醉月坂を登らんとして渇きに耐へず蹌踉として醉月の扉を開けば狼藉たる店の中より破れしレコードは鳴り響き場末の煤ぼけたる電氣の影に貧しき酒瓶の列を立てたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人はジューリングと一緒に気球で成層圏の根元に近づき一時失神しながらも無事に着陸したという経験をもっていて、搭乗気球としての最高のレコードの保持者であった。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、お前がいくら頑張ったって、船長も云ったように、一億円の船会社にゃ、勝てっこないんだから」　セコンドメイトは、デッキの上と橋板の上とでは、レコードの両面見たいに、あべこべの事を云い始めた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "蓄音機と云へば、宿へ着いた時につい隣りの見晴らしの縁側に旅行用蓄音機を据ゑて、色々な一粒選りの洋樂のレコードをかけてゐる家族連の客があつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも心配事があると直ぐレコードをかけて直ぐ紛らかしちまう癖があるんだけれど。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "枝垂桜の前の広場のやぐらからレコードが鳴り響いて、下には二十人ばかり円を描いて踊っている。",
              "citation": {
                "source": "祇園の枝垂桜",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "バーからひびくレコード音楽は遠いパリの夜の巷を流れる西洋｜新内らしい。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルリン大学にける彼の聴講生の数は従来のレコードを破っている。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の聴講者は千二百人というレコード破りの多数に達した。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この二つの短詩形の中に盛られたものは、多くの場合において、日本の自然と日本人との包含によって生じた全機的有機体日本が最も雄弁にそれ自身を物語る声のレコードとして見ることのできるものである。",
              "citation": {
                "source": "日本人の自然観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはいずれにしても、今のうちにこれらの滅び行く物売りの声を音譜にとるなり蓄音機のレコードにとるなりなんらかの方法で記録し保存しておいて百年後の民俗学者や好事家に聞かせてやるのは、天然物や史跡などの保存と同様にかなり有意義な仕事ではないかという気がする。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その証拠には、街頭を歩いているラッパズボンのボーイらが店頭からもれ出るジャズレコードの音を聞けば必ず安物の器械人形のように踊りだす。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "音声の保存はすでに金属製の蓄音機レコード原板によって実行されている。",
              "citation": {
                "source": "映画時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後再び高松を通過した時に遭った暑さも、私有レコード中の著しいものである。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漆喰の土間の隅には古ぼけたビクターの蓄音器が据えてあって、磨り滅ったダンスレコードが暑苦しく鳴っていた。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのレコード止してくれない」聴き手の方の青年はウエイトレスがまたかけはじめた「キャラバン」の方を向いてそう言った。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、鳥の「モシモシカメヨ」と人間のそれとのレコードを分析し、比較するだけの手数でいずれとも決定されるからである。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともかくも、人間の音声に翻訳した鳥の鳴き声と、本物とのレコードをたんねんに比較してみるという研究もそれほどつまらない仕事ではないであろうと思われるのである。",
              "citation": {
                "source": "疑問と空想",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はジンバリストの演奏したこの曲のレコードを持っている。",
              "citation": {
                "source": "秋の歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なおそのほかに探険船シビリアコフ号を艤装して途中でいろいろの観測研究をすると同時にただひと夏に北氷洋を乗り切るという最初のレコードを作ろうという計画を立て、それが立派に成功したのである。",
              "citation": {
                "source": "北氷洋の氷の割れる音",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代では競技会でメダルやカップやレコードを仕留めるだけが目的の空中曲技も、昔の武士は生命のやりとり空中組み打ちの予行練習として行なったものと見える。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この結果としてこの一年間にいろいろの珍しいレコードが多数にできあがった。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカゴ市のある男は七十九秒間に生玉子を四十個まるのみしてレコードを取ったが、さっそく医者のやっかいになったとある。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今度のレコードは食った量のほかに所要時間を測定してあるのが進歩である。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "食いしんぼうのレコード保有者でも少し風変わりなのは、パリのムシウ・シエールである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、五時間と十七分というレコードを得たのである。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この競技は速度最小という消極的なレコードをねらうところに一種特別の興味がある。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "シガーの灰の最大な団塊を作ったというレコードもやはりドイツ人の手に落ちた。",
              "citation": {
                "source": "記録狂時代",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
