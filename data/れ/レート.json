        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "豚のびっくりするような大きいチョコレート菓子可愛ゆい麦粉菓子のヒヨコ、馬鈴薯が本物かと思ったらやっぱり何かを練ってつくったお菓子なのです。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "純白に襞の多い着物と、頭の白い花の冠が非常によく似合い、私に持って来たクリスマス・プレゼントのチョコレートの箱の飾リボンの縁が、清楚にうつり合った色彩は、私に思わずつかつかと傍へ寄らしてしまったような、好もしい感じを与えました。",
              "citation": {
                "source": "伯林の降誕祭",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "開いた紙障子の方から現はれた顏はチヨコレート色の目鼻立の正しい印度人の男の顏であつた。",
              "citation": {
                "source": "秋雨の追憶",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」○チョコレートを食べられる暇さえある職業だったら職業というものは何という好もしいものでしょう。",
              "citation": {
                "source": "現代若き女性気質集",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれは、チョコレートででもできてゐるやうに、すっときれいにはなれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "〕チョコレートよりも、もっとおいしいけれども、こんな雁が飛んでゐるもんか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "塩釜から小さな汽船に乗って美しい女学生の一行と乗合せたが、土用波にひどく揺られてへとへとに酔ってしまって、仙台で買って来たチョコレートをすっかり吐いてしまった。",
              "citation": {
                "source": "夏",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "屋根はスレート葺きだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちゞれ雲西に傷みて、　　　　いささかの粉雪ふりしき、警察のスレートも暮れ、　　　売り出しの旗もわびしき。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれは、チョコレートででもできているように、すっときれいにはなれました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョコレートよりも、もっとおいしいけれども、こんな雁が飛んでいるもんか。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「僕はチョコレートがほしいなあ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チョコレートもある。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝのチョコレートは大へんにいゝのだ。",
              "citation": {
                "source": "ひかりの素足",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グレートヘンである。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は前庭の日なたで繭を※ながら、実際グレートヘンのように糸繰車を廻していることがある。",
              "citation": {
                "source": "温泉",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらず物理学をデモンストレートする先生がたはなかなかこの目前の好個の問題を手に取り上げて落ち着いて熟視しようとはしないのである。",
              "citation": {
                "source": "日常身辺の物理的諸問題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たわいもない幻影を追う目がガラス棚のチョコレートに移ると、そこに昔の夢のビスケット箱の中のメールコーチが出現し、五十年前の父母の面影がちらつき、左団次の知盛が髪を乱して舞台に踊るのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが既往の失敗とがめず、もいちど信じてだまって持たせて呉れたなら、私いのち投げてもプレート守ったにちがいない。",
              "citation": {
                "source": "二十世紀旗手",
                "author": "――（生れて、すみません。）",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお日さまも僕たちが前に土の底でコングロメレートから聞いたとは大へんなちがひではありませんか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コングロメレートのはなしではお日さまはまっかで空は茶いろなもんだと云ってゐましたが今見るとお日さまはまっ白で空はまっ青です。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、しかしあのコングロメレートといふ方は前にたゞの砂利だったころはほんたうに空が茶いろだったかも知れませんね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が前にコングロメレートから聞きましたがどうも僕らはこのまゝ又土の中にうづもれるかさうでなければ砂か粘土かにわかれてしまふだけなやうですよ。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "するとそれは、チヨコレートででもできてゐるやうに、すつときれいにはなれました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "チヨコレートよりも、もつとおいしいけれども、こんな雁が飛んでゐるもんか。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお日さまも僕たちが前に土の底でコングロメレートから聞いたとは大へんなちがいではありませんか。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "コングロメレートのはなしではお日さまはまっかで空は茶いろなもんだと云っていましたが今見るとお日さまはまっ白で空はまっ青です。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さあ、しかしあのコングロメレートという方は前にただの砂利だったころはほんとうに空が茶いろだったかも知れませんね。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
