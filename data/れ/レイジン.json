    "definitions": [
      {
        "index": 1,
        "gloss": "court musician",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "表面は蛟龍雲を吐いて神有の祕密をそめて見るや裏面には伶人｜額をたれて物思ひ煩ふなよび姿才華悧悧たる眼ざしには工匠が怨みもこもりけんよ。",
              "citation": {
                "source": "古盃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "聖徳太子が四十三歳の時に信貴山で洞簫を吹いていたら、山神が感に堪えなくなって出現して舞うた、その姿によってこの舞を作って伶人に舞わしめたとある。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "伶人の奏楽一順して、ヒュウと簫の音の虚空に響く時、柳の葉にちらちらと緋の袴がかかった。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "法皇の伶人には恰好なる童なり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "法皇の伶人もこれには優らざるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "ピアツツア、コロンナに伶人の群あり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "伶人の群をば棚の二箇處に居らせて、其聲相應ずるやうにせり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "斯て此大劇場の觀棚に對して立てる時、わが視る所は譬へば黒洞々たる大坑に臨める如く、僅に伶人席の最前列と高き觀棚の左右の端となる人の頭を辨ずることを得るのみ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "伶人の奏楽一順して、ヒユウと簫の音の虚空に響く時、柳の葉にちら／＼と緋の袴がかゝつた。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右に伶人レオニが開きぬといふ、水に臨める酒店あり。",
              "citation": {
                "source": "うたかたの記",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "船｜下ろしの最初の日は御所の雅楽寮の伶人を呼んで、船楽を奏させた。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜になってしまったことを源氏は残念に思って、前の庭に篝をとぼさせ、階段の下の苔の上へ音楽者を近く招いて、堂上の親王がた、高官たちと堂下の伶人とで大合奏が行なわれるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "伶人への物は白の一襲、あるいは巻き絹などと差があった。",
              "citation": {
                "source": "源氏物語",
                "author": "胡蝶",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論その尊敬は、悲壮と云うような観念から惹き起される一種の尊敬心で、例えば頽廃した古廟に白髪の伶人が端坐して簫の秘曲を奏している、それとこれと同じような感があった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "神輿の御座船は一｜際美しい屋形船で、旗｜幟や、玉｜串などの立ち並ぶ下に、礼装した神官たちがいずまい正し、伶人が楽を奏でるなかに、私の鈴子は美しい巫女の装いして、今宵は化粧も濃く匂うばかりに立ちまじっているのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はどうもこの子は伶人らしい、或いは俳優の子じみたところがあると思った。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々は陶然と酔って夕べに近いころ、伶人が召し出された。",
              "citation": {
                "source": "源氏物語",
                "author": "藤のうら葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "伶人の着けた小忌衣竹の模様と松の緑が混じり、挿頭の造花は秋の草花といっしょになったように見えるが、「求の子」の曲が終わりに近づいた時に、若い高官たちが正装の袍の肩を脱いで舞の場へ加わった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（下）",
                "note": "青空文庫"
              }
            },
            {
              "text": "伽藍過ぎ宮を通りて鹿吹きぬ伶人めきし奈良の秋風　山川草木一切成仏といひ有情非情同時成道などといつて大乗仏教には人とその他とを区別しない一面がある。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "風を擬人する遣方は作者の常套で前にも伶人めきし奈良の秋風があつたが、あとにも亦出て来る。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "十列の稚児はもと／＼伶人なんでせう。",
              "citation": {
                "source": "春日若宮御祭の研究",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し尚、巡游伶人の手を経たものと考へられる廉がある。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十三首が、かなりの価値のあるものだと言ふ事が、巡游伶人の手を経なかつた理由にはならぬ。",
              "citation": {
                "source": "相聞の発達",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡遊伶人の生活　　　　　一　祝言職人の厭ふ業病をかつたいといふ事は、傍居の意味なる乞食から出たとするのがまづ定論である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ものよしが、近代風の乞食者となるまでには、古い意味の乞食者即、浮浪祝言師――巡遊伶人――の過程を履んで来て居る事が思はれる。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も、巡遊伶人であることは、確かである。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡遊伶人として、芸道の方面に足を踏み込む様になつても、本業呪言を唱へる為事は、続けて居たと言ふ事は考へられる。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほかひと言はれる道具の元は、巡遊伶人が同時に漂泊布教者であつた事を見せて居り、長旅を続ける神事芸人の団体が、藤原の都には既に在つた事を思はせるのは、微妙な因縁と言はねばならぬ。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　叙事詩の撒布ほかひが部曲として、語部の様に独立して居なかつた事は、巡遊伶人としての為事に、雑多な方面を含む様になつた原因と見る事が出来る。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "尠くとも、奈良朝以前から既に、巡遊伶人があつた事情から見ても、一層強い原動力を此処に考へないのは、嘘である。",
              "citation": {
                "source": "国文学の発生（第二稿）",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
