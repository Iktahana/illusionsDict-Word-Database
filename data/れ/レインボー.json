        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつぞや、レインボーのサロンで、君の眼前でこれを読み、君に読後感を叩かれた時は、内心今度と同じ面白さを感じてゐたにも関はらず、つい、それをそのまゝ云ひ損つてしまつた。",
              "citation": {
                "source": "〔小林秀雄氏への公開状〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "あしたの午後レインボー・グリルで待つ。",
              "citation": {
                "source": "出発",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二月十四日　日　レインボーで、一時から東女子大学の人十数人で茶話会。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田嶽夫と海音寺潮五郎が芥川賞をもらった時だと思うが、レインボーで文士をまねいて授与式があった。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆうべは、かえって来た野上さんや何かの歓迎会があってレインボーへ行って、外へ出たら大きい牡丹雪が舞い狂って居りました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "レインボー・カラーの、ニットのビキニだ。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "レインボーで軽く食事、座へ出る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十五年",
                "note": "青空文庫"
              }
            },
            {
              "text": "二時、大阪ビルレインボーで永井龍男と奥野何子嬢の結婚式あり。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひるの部終るとすぐ内幸町へ、レインボーグリルの文藝春秋祭へ行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "一回終って、レインボーの「只野凡児」出版記念会へ出席。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和九年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時半に、約束より大分おくれてレインボーへ、川口松太郎、もうあいつも気が早い、出かけちまった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四時、日劇へ寄って留守中ダレないやう注意して、五時、レインボーへ、東宝新雑誌「エス・エス」の菊池寛氏に芝居をきく座談会へ出席、まづい定食食ひつゝ六時半迄ゐて、本二三求め、七時十分発で修善寺へ向ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから日劇へ寄り、六時半にはレインボーへ、「エス・エス」の座談会で行く。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "旬報へ電話し、友田と橘のとこへ麻雀しに出かけることゝし、レインボーで食事する、一円半の定食、はるかにマーブルに劣る。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "大草実とレインボーグリルで夕食。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "七時に切り上げて、上森とレインボーグリルの京極の会へ行く、何うも盛なもので、実に多人数だ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "レインボーグリルへ寄り、菊池先生に会ひ、慰問の会二つ引受け、文藝春秋のボーイを役者にとたのまれる。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
