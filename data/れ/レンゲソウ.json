    "definitions": [
      {
        "index": 1,
        "gloss": "Chinese milk vetch (Astragalus sinicus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
