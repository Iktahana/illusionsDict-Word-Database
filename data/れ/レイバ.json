        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ただそれがＱの冷罵とペルゴレシの音楽とのすぐ後に出くわしたばかりに、偶然自分の子供らしいイーゴチズムに迎合したのかもしれない。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は英雄主義を冷笑し、日本武士道を嘲り、国士の行動を冷罵す。",
              "citation": {
                "source": "警戒すべき日本",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "落伍者だと云つて世人から冷罵を浴びせかけられて居る人があるが、俺もその落伍者になつて居るらしい。",
              "citation": {
                "source": "畜生道",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　としらふで冷罵れば、巡査は全身の怒気頭上に上りて、「無礼者め。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "若い、新米の主人に対する職工たちの侮辱と、冷罵とを予期させられつつ……。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに他の一人は聲高く之を冷罵して、「止めい、陰徳家よ」と叫んだので、車を推した學生は手を離して駈け拔けて仕舞つて、既に車より前に進んで居た冷罵者に追ひ及んで、前の如く相竝んで坂を上つたのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに冷罵を加へて、※何ぞ自ら欺くやと云はぬばかりに刺笑したるが爲に、一青年の心は牽牛花の苗の只一足に蹂躪されたるが如く、忽然として其の力を失ひ、突如として車を捨てて走るに至つたのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾人も亦時に彼の冷罵を加へたる青年の如き擧動を無意識の間に爲すことが無いには限らぬ。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "東　論より証拠西　論語読みの論語知らず　東のは寸鉄人を殺すの語、西のは冷罵骨に入るの句なり。",
              "citation": {
                "source": "東西伊呂波短歌評釈",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ヘン笑かすぜ、」「にやけていやがる、」友達が熱笑冷罵する。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "女性を冷罵する事、東西厭世家の平なり。",
              "citation": {
                "source": "厭世詩家と女性",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるのに、他の一人が声高くこれを冷罵して、「止めろ、偽善家」と叫んだので、車を押した学生は手を離して駆け抜けて仕舞って、既に車より前に進んで居た冷罵者に追い着いて、今まで同様に相並んで坂を上って行ってしまったのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "であるのに、冷罵を加えて「君なんぞ自ら欺くや」と言わんばかりに刺笑した為に、一青年の心はアサガオの苗が、ただ一足で踏み潰されたみたいに忽ちその力を失い、突如として車を捨てて走るに至ったのである。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "我々もまた、時に彼の冷罵を加えた青年のような行動を、無意識の間にすることが無いとは限らない。",
              "citation": {
                "source": "努力論（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分の悪口を云つたり、自分が一生懸命でした仕事に難癖をつけたり、此方が何の邪念もない言葉を皮肉にからかはれたり、愚劣な冷罵を与へたり、軽蔑的な批評を浴せたりする人に出遇ふと（それらのことを彼女は、彼とその母から最も多く経験した。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼の母のことを冷罵し返して、勝手に噴き出したりしたことがあつた。",
              "citation": {
                "source": "秋晴れの日",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノホホンだの後生楽だの仙人だの若隠居だのという冷罵を我々は何百遍何千遍も浴びせられた。",
              "citation": {
                "source": "駆逐されんとする文人",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学を職業たらしむるだけの報償を文人に与えずして三文文学だのチープ・リテレチュアだのと冷罵するのみを能事としていて如何して大文学の発現が望まれよう。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "咏嘆したり長※したり冷罵したり苦笑したりするも宜かろう。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の文人は好い加減な処で忽ち人生の見巧者となり通人となって了って、底力の無い声で咏嘆したり冷罵したり苦笑したりする。",
              "citation": {
                "source": "二十五年間の文人の社会的地位の進歩",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時代を離れては緑雨のこの句の興味はないが、月落ち烏啼いての調子は巧みに当時の新らしい俳風を罵倒したもので、殊に「息を切らずに御読下し被下度候」は談林の病処を衝いた痛快極まる冷罵であった。",
              "citation": {
                "source": "斎藤緑雨",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "単に歴史をありのままに見せるに過ぎないという、一種の冷罵を意味している名称で、絵入新聞に仮名垣魯文がこう書いたのが嚆矢であるとか伝えられている。",
              "citation": {
                "source": "明治劇談　ランプの下にて",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は耳もとに思ひきり冷罵し、あざ嗤ふ、ある人々の聲を聞いた。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しそれはやはらかな冷罵を帶びた斷わりの返事だ。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "放浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっしがしゃべりだすと、かれこれいばった口をおききなさるが、このとおり伝六の話にはむだがねえんだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "左刺しの匕首",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
