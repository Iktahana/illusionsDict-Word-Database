[
  {
    "uuid": "1105a6ff-7fdf-555e-85b3-748d2638adf9",
    "entry": "冷語",
    "reading": {
      "primary": "れいご",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "hard words",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "渠はこの一冷語のためにいたく苦痛を感じたる状見えつ。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "嬉しがったは八左衛門、ひざ頭を片手でたたきながら、愉快そうに冷語を飛び出させた。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "口からは毒々しい語がしきりに放たれ、弛みを見せまいとしている女のちょっとした冷語にも、体中の肉が跳びあがるほど慄えるのが、自分ながら恐ろしくも浅ましくもあった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "病める老人の用しげく婢を呼ばるるゆえ、しいて「わたくしがいたしましょう」と引き取ってなれぬこととて意に満たぬことあれば、こなたには礼を言いてわざと召使いの者を例の大音声にしかり飛ばさるるその声は、十年がほども継母の雄弁冷語を聞き尽くしたる耳にも今さらのように聞こえぬ。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども沙翁の諷刺嘲罵は平々坦々たる冷語の中に存し、スウィフトのは熾熱せる痛語の中にあり。",
              "citation": {
                "source": "「油地獄」を読む",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、一旦「外面」となると、快活で愛想がよく、不景気のフの字も見せず、万事いやな顔などせずきれいごとで行こうという、お嬢さまの圭子だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "様々の、情熱を失った道義観やきれいごとの底を割って人間のぎりぎりの姿を露呈させよ、という。",
              "citation": {
                "source": "人間の結婚",
                "author": "――結婚のモラル――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日物わかりのよいとされている女の先生などでも、その生活への感情は案外にひ弱くて、所謂いい生活というものの絵図が水っぽいきれいごとだけで、塗りあげられていて、子供の心が直感した生活のそんなユーモアもわからないということが一つ。",
              "citation": {
                "source": "子供の世界",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「イヤこれは助高屋ものできれいごとだと思つたら、ごみと枯ツ葉で、梅幸が世話物でつかひさうだ。",
              "citation": {
                "source": "狂言の買冠",
                "author": "三遊亭円朝",
                "note": "青空文庫"
              }
            },
            {
              "text": "きれいごとでない形。",
              "citation": {
                "source": "日記",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そりゃ今までの帳面が、どうもきれいごとにいかんというのは、俺が悪いと言えば、悪いさ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "その意味では、ひろ子が重吉に示す生活感情も計らぬきれいごととなっているとも思えた。",
              "citation": {
                "source": "風知草",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このごろゆうれいごっこが流行るのかしら。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "口さきでのきれいごとは誰にも通用しはしないのだから。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀（太原にいてかえったの）がなかなか写真上手で、まだきれいごとですが、なかなかセンスのある作品を作って面白うございます。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四〇年（昭和十五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――柳町なんかは一流とかなんとかいってさ、いやにお高くとまってきれいごとな遊びしかさせやしないさ、そこへいくとあたいたちはみえも気取りもありやしない、脂の乗ったこってりしたところをそれこそ食傷するほど……」　わあっと笑って叩いたり叫んだり、障子が音をたてるような騒ぎが起った。",
              "citation": {
                "source": "契りきぬ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが世間というものは、きれいごとだけで生きてゆけるものではない。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中立なんて、きれいごとをいうとったところで、いつまで経っても、うだつが上がりゃせんよ」　と、何回となく、くりかえした。",
              "citation": {
                "source": "花と龍",
                "author": "火野葦平",
                "note": "青空文庫"
              }
            },
            {
              "text": "有職のちらしてのをとって呉れたがこれはきれいごとで結構だった。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十二年",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくは、妓をよんで、いわゆる通な“きれいごと遊び”に時をすごしていたが、そのうち斜向いの、わけて一軒すばらしい大籬の揚屋に、チラと見えた歌舞の菩薩さながらの人影に、「おや、豪勢なお取巻きだね、あの花魁はいったい誰？",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
