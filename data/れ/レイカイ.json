[
  {
    "uuid": "ce8301c9-7f12-52b0-9cb6-5361be9910f7",
    "entry": "例会",
    "reading": {
      "primary": "れいかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "regular meeting",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "この夜はあたかも嫩会の若き人々わが家にあつまりて劇談会を催す例会の夕なりしかば、通知するまでもなく皆々来りあつまる。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年二月廿七日、パン例会。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "学会にはそれぞれ例会や総会がある。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞社へ来訪したのが、ちょうど編輯会議の例会のある十日の夕方だったので、私は二氏に会議の席へ顔出しして、何かちょっとした演説でもしてもらおうとした。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ことしの七月と八月は暑中休会であったが、秋の彼岸も過ぎ去った九月の末、きょうは午後一時から例会を開くという通知を受取ったので、あいにくに朝から降りしきる雨のなかを小石川へ出てゆくと、参会者はなかなかの多数で、いつもの顔触れ以外に、男おんなをまぜて新しい顔の人びとが十人あまりも殖えていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "開会の辞",
                "note": "青空文庫"
              }
            },
            {
              "text": "「例会は大抵午後五時か六時からお集まりを願うことになって居りますが、こんにちはお話し下さる方々が多いので、いつもよりも繰り上げて午後一時からおいでを願った次第でございます。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "開会の辞",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が来てから初めての記者月例会の開かれたのも、恰度一尺程も雪の積つた、或土曜日の夕であつた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "『然し芸妓も月例会に出た時は、大変大人しくして居ますね。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "親善を厚うするとか、相互の利害を議するとか、連絡を図るとか、趣意は頗る立派であつたけれど、月例会は要するに、飲んで、食つて、騒ぐ会なので、主筆の所謂人の悪い奴許りだから、随分と方々に円滑な皮肉が交換されて、其度にさも面白相な笑声が起る。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "月例会に逢つた限の菊池君が何故か目に浮ぶ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先日の晩にも例会が開かれて、通信局、管船局各課の高等官の卵共が、ずらりと田中局長の前に並んだ。",
              "citation": {
                "source": "茶話",
                "author": "大正六（一九一七）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方から柿の会三月例会、一洵、三土思、無水、藤君、和蕾の五君だけ来庵、今晩は女性を欠いだ、なごやかな句座であつた、席上で朱鱗洞句碑建立の具体案がやゝまとまつたのはよかつた、十一時頃散会。",
              "citation": {
                "source": "松山日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方早々散歩しながら汀居往訪、柿の会例会である、会者七人、これはといふ句は出なかつた、真摯なのがうれしい、席上雑話をして月村さんから、画家乃至画工のうらおもてを聞かされたが、本物でない芸術家はあさましいあさましい。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、無水君来訪、俳談閑談しばらく、ほどなく一洵老来訪、九月例会について談合する。",
              "citation": {
                "source": "一草庵日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎週社で開かれていた社会主義研究会の例会日だった。",
              "citation": {
                "source": "自叙伝",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "和歌の例会の日には、黒塗の抱え車が門前にずらりと並んで、筆頭には、その頃錦鶏の間祗候田辺太一の愛娘であった花圃をはじめ、名家名門の令嬢紳士たちが花の如く集って来た。",
              "citation": {
                "source": "婦人と文学",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時の哲学会の例会で、私どもの先輩であった土田杏村氏が話をされた後で、私は質問をした。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "その百六十八　此年乙酉の八月十三日上野不忍池の上なる静宜亭に催された例会の席上の作と、中秋の作との中間に、※斎詩集は「送森島敦卿還福山」の七絶一首を載せてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十三日は仙駕亭例会の日であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の方へ横に羅馬字でDIDASKALIAと書いて、下には竪に十一月例会と書いてある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "上の方へ横に羅馬字で DIDASKALIA と書いて、下には竪に十一月例会と書いてある。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウォーレンたちは、当初例会を開いているスタンフォード大学でフェアーを催すことを考えたが大学から断られ、思い切ってサンフランシスコの大きな催し物会場を借りることにした。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたしはその間に、舞踊研究会をまとめて、歌舞伎座で大会を二回、紅葉館で例会を六回催した。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "その当時は「ぷろふいる」を中心に神戸をはじめ名古屋、京都、大阪、はては仙台、札幌、遠くは大連にまで探偵小説クラブという会が出来て同好の連中が集まり毎月例会の消息を知らせてくるという盛況ぶりであった。",
              "citation": {
                "source": "探偵小説思い出話",
                "author": "山本禾太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "会合は月に一回の予定であるが、会員は総て「言葉の俳優」たる資格試験をパスしなければならず、例会には、交互に、「その研究」を発表する権利と義務を負ふものである。",
              "citation": {
                "source": "なんとかせねばならぬ",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "永代橋の「都川」で例会があった時、倉田白羊が酔っぱらって大虎になり、橋の鉄骨の一番高いところへ攀じ登ったが川風で酔いが醒めて、さてこんどは降りられない。",
              "citation": {
                "source": "ヒウザン会とパンの会",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、彼と共に、ＶＩＫＩＮＧの例会に出席した。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その例会は、阪大の中の一室で行われた。",
              "citation": {
                "source": "久坂葉子の誕生と死亡",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて彼等の機関誌ができ、サロン風の例会が毎週欠かさず行はれて、まつたく自然の推移のうちに、会員達の有志によつて、候鳥アンサンブルや合唱団が組織された。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二図　七枝刀銘文　かくて高橋君は、十月の考古学会の例会において、「京畿旅行談」の一部として、この神宝のことを述べられた。",
              "citation": {
                "source": "石上神宮の神宝七枝刀",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
