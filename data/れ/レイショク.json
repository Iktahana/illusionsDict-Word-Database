[
  {
    "uuid": "e8c66dda-a85d-54d5-9855-ea117fca621f",
    "entry": "令色",
    "reading": {
      "primary": "れいしょく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "fawning look (on one's face)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（一行あけて）ほととぎす、いまわのきわの一声は、「死ぬるとも、巧言令色であれ！",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "その光栄の失敗の五年の後、やはり私の一友人おなじ病いで入院していて、そのころのおれは、巧言令色の徳を信じていたので、一時間ほど、かの友人の背中さすって、尿器の世話、将来一点の微光をさえともしてやった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが肉体いちぶいちりん動かさず、すべて言葉で、おかゆ一口一口、銀の匙もて啜らせ、あつものに浮べる青い三つ葉すくって差しあげ、すべてこれ、わが寝そべって天井ながめながらの巧言令色、友人は、ありがとうと心からの謝辞、ただちにグルウプ間に美談として語りつがれて、うるさきことのみ多かった。",
              "citation": {
                "source": "創生記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あはれ願くは巧言、令色、媚びて吾人に対せよ、貞操淑気を備へざるも、得てよく吾人を魅せしむ。",
              "citation": {
                "source": "醜婦を呵す",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "非常に惰弱になって巧言令色である。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、死ぬるとも、巧言令色であらねばならぬ。",
              "citation": {
                "source": "めくら草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧言令色足恭、怨ヲ匿シテ其ノ人ヲ友トスルハ、丘｜之ヲ恥ヅ　とか、生ヲ求メテ以テ仁ヲ害スルナク身ヲ殺シテ以テ仁ヲ成スアリ　とか、狂者ハ進ンデ取リ狷者ハ為サザル所アリ　とかいうのが、それだ。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "縱令色は衰ふとも、才情はむかしのまゝなるべし。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京が如何に巧言令色を以て吾々を招くとも、これに眩惑されてはならぬ。",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわく「巧言令色｜鮮ないかな仁」。",
              "citation": {
                "source": "演技指導論草案",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "肩をそびやかして諂い笑い、巧言令色、太鼓持ちの媚を献ずるがごとくするはもとより厭うべしといえども、苦虫を噛み潰して熊の胆をすすりたるがごとく、黙して誉められて笑いて損をしたるがごとく、終歳胸痛を患うるがごとく、生涯父母の喪にいるがごとくなるもまたはなはだ厭うべし。",
              "citation": {
                "source": "学問のすすめ",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の父はこう云う時には頗る巧言令色を弄した。",
              "citation": {
                "source": "点鬼簿",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "曲解されたる教訓　なおこれと関連して世に誤解された教訓は、「巧言令色鮮かな仁」ということである。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語を鄭重にしたり温和にすれば、すぐに巧言と解し、威儀をもって語れば令色と曲解し、すぐに鮮かな仁と結論をくだす。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばここに笑みを含んで話するものがあるとすれば、甲はこれを、「巧言令色の人、阿諛※佞の人」　と評するし、乙は、「よいぐあいに世渡りする上手者、愛嬌を振りまく八方美人」　という。",
              "citation": {
                "source": "自警録",
                "author": "新渡戸稲造",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから色、すなわち性慾のことだって、あいつのは、なにも特に巧言令色に構えこんで、色魔だとか、誘惑だとかいう手段で行くのではない、眼の前へ異性の女の肉のかおりがうごめいて来る時に、ついついたまらなくなってかぶりつくまでのものだ。",
              "citation": {
                "source": "大菩薩峠",
                "author": "白雲の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからばすなわち善人も、悪人も、賢者も、愚者も、その治国平天下の経綸ある人も、その巧言令色の人も、いやしくも有為の志あるものはいずくんぞその眼孔を官途の一辺に注がざるを得んや。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "従って巧言令色は道具屋の専売とはかぎらない。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "道具屋輩をして呆然たらしめるようなより以上な巧言令色はお茶人｜気質の旦那筋にこそあって、本当の商売人という凄腕は果たしていずれであろうかが分明しない現実もある。",
              "citation": {
                "source": "現代茶人批判",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧言令色、追従などという、そういういやらしいことが行なわれず、生一本で正直だ。",
              "citation": {
                "source": "剣侠",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "譎詐、権謀、巧言、令色、こういうことは彼らにとって、朝飯前の仕事であった。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「世渡り」といっても巧言令色、やたらにツベコベ世辞愛嬌を並べ立てることじゃない。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "人との交渉における忠、朋友との交わりにおける信――習わざるを伝えないのも弟子に対する忠であり信であるが――それらは巧言や令色によって実現せられるものではなく、ただ良心の審判によってのみ判定さるべき誠意の問題なのである。",
              "citation": {
                "source": "孔子",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく議事堂や警視庁の建築をながめたあとで、眼を返してお濠と土手とをながめるならば、刺激的な芸のあとに無言の腹芸を見るような、もしくは巧言令色の人に接したあとで無為に化する人に逢ったような、深い喜びを感ずるであろう。",
              "citation": {
                "source": "城",
                "author": "和辻哲郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし聖賢はこれを巧言令色というね。",
              "citation": {
                "source": "武者ぶるい論",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　本章は「巧言令色、すくなし仁」という文語訳で有名である。",
              "citation": {
                "source": "現代訳論語",
                "author": "下村湖人",
                "note": "青空文庫"
              }
            },
            {
              "text": "巧言令色には凡そ無縁の仁者であつた。",
              "citation": {
                "source": "浜尾新先生",
                "author": "辰野隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "やしき内でおえらいのは世間へ通用いたしません」「それですから、照彦様は学校へおいでになってもつまらないらしいです」「巧言令色をお喜びになる傾向がある。",
              "citation": {
                "source": "苦心の学友",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お気のよい公達は、依然、何事も拝伏して肯く衆臣と、巧言令色の訪問者と、また、利用すべく彼を操る者の力にうごかされつつ――この大変動期をそれとも自覚せずに過しているのである。",
              "citation": {
                "source": "新書太閤記",
                "author": "第十分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、今の彼たるや人臣の栄爵を極め、その最高にある身だけに、その巧言令色にたいする歓びも受けいれかたも、とうてい、宮門警手の一上官などの比ではない。",
              "citation": {
                "source": "三国志",
                "author": "図南の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
