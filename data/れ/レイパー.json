        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "伝説的な長距離電話ただがけ装置、ブルーボックスの開発で知られる反体制派技術者、キャプテンクランチことジョン・ドレイパーは、アップル※用にワードプロセッサーを書き、イージーライダーをもじってイージーライターと名付けて好評を博していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "これに目を付けたＩＢＭは、ドレイパーに依頼してＰＣ用に書きなおさせていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は翌年、電話荒らしのヒーロー、キャプテンクランチことジョン・ドレイパーが逮捕されるまでに、二〇〇台のブルーボックスをさばいて六〇〇〇ドルを売り上げ、賢明にもこの段階で商売を切り上げた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "カヴァナフとレイパー(19)は重水素脂肪酸を使った。",
              "citation": {
                "source": "生体構成物質の動的状態",
                "author": "THE DYNAMIC STATE OF BODY CONSTITUENTS (1942)",
                "note": "青空文庫"
              }
            }
          ]
        }
