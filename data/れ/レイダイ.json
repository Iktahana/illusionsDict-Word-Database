    "definitions": [
      {
        "index": 1,
        "gloss": "example",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文典の巻末にある作文や翻訳の例題と同格な応用数学的論文もなくはない。",
              "citation": {
                "source": "数学と語学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "故に始めに例題した多数者の通解も、後に説いた個人的な特殊な場合も、すべてこの場合には同じであって、無差別一様に考え得られる。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先生が出て来て、黙って床の間の本棚から算術の例題集を出してくれる。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題一】このやうな加へ算がある。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題二】Ｎといふ文字で現された數字が五箇所に入つてゐる加へ算である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題三】これは國民學校の一年生でもできるであらう。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題四】この問題を見ると、虫喰ひ穴が八箇所もある。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題五】この問題では、二桁の除數が穴になつてゐるし、答も十位が穴だし、計算の中にも六箇所の穴があいてゐる。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで例題の解説にうつる。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題六】これは「覆面算」である。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題七】一目見ただけでこれが難問題といふことがはつきり分る。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "このへんで例題の解説は打切ることとする。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしやり方に詰つたら、その前の例題を復習して、虫喰ひ算の解き方のこつを會得せられ、それからもう一度問題と取組んでいただきたい。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーン先生の名著“パヅル　ペーパーズ　イン　アリスメチック”は本當に愛すべき書物でありますが、その卷頭に於ける例題の「解き方」の解説が間違つてゐるのは御愛嬌であります（その書第九頁）。",
              "citation": {
                "source": "虫喰ひ算大會",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題一】　次頁のような加え算がある。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題二】　Ｎという文字で現わされた数字が五箇所に入っている加え算である。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題三】　これは国民学校の一年生でもできるであろう。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題四】　この問題を見ると、虫喰い穴が八箇所もある。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題五】　この問題では、二桁の除数が穴になっているし、答も十位が穴だし、計算の中にも六箇所の穴があいている。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題六】　これは「覆面算」である。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "【例題七】　一目見ただけでこれが難問題ということがはっきり分る。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしやり方に詰ったら、その前の例題を復習して、虫喰い算の解き方のこつを会得せられ、それからもう一度問題と取組んでいただきたい。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブーン先生の名著『パズル・ペーパーズ・イン・アリスメチック』は本当に愛すべき書物でありますが、その巻頭に於ける例題の「解き方」の解説が間違っているのは御愛嬌であります（その書、第九頁）。",
              "citation": {
                "source": "虫喰い算大会",
                "author": "佐野昌一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「つまり、死闘の時間が徴候の度に比例するからなんだが、まさにこの死体は、法医学に新しい例題を作ると思うね。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これには充分質問例題とする価値があるぜ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "支倉君、それが、また実に面白い例題なんだよ」と続いて云いかけた法水の顔に、みるみる暗影が差してゆき、彼は過敏そうに眼を光らせた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが熊城君、実に面白い例題なんだよ」とそれから煖炉の前で、法水は紅い※に手をかざしながら続けた。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し、またそうかと云って、その間浄善が失神していたのでないと云う事は、痙攣の跡がない――と云う一事だけでも、瞭然たるものなんだよ」　然し、立ち上ると法水は、ブルッと胴慄いして、明らかにその顔色には、容易ならぬ例題に直面しているのを、語るものがあった。",
              "citation": {
                "source": "夢殿殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
