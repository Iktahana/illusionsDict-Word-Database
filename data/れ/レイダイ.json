[
  {
    "uuid": "c21d3a35-2b8d-5dca-af0e-5ca41dc6c479",
    "entry": "例題",
    "reading": {
      "primary": "れいだい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
