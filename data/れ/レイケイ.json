    },
    "definitions": [
      {
        "index": 1,
        "gloss": "your elder brother",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は未だ此大佐とは甞て面會した事は無いが、兼て聞く櫻木海軍大佐とは無二の親友で、また、私の爲には終世忘るゝ事の出來ない、かの春枝夫人の令兄――日出雄少年の爲には叔父君に當つて居る人。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "先刻一目見て直ぐ誰人かに似て居ると想つたのは其筈よ、誰あらう、此日の出艦長こそ、春枝夫人の令兄、日出雄少年の叔父君なる松島海軍大佐であつたのかと。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と語り終つて令兄なる大佐と良君武文との顏を婉然に見た。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "林駒生氏は本伝第二回に紹介した杉山茂丸氏の末弟で、令兄とは雲泥、霄壌も啻ならざる正直一本槍の愚直漢として、歴代総督のお気に入り、御引立を蒙っていた統監府の前技師であった。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "令兄の杉山茂丸氏の如きは、そのズッと以前から後悔の臍を噛んでいたらしい。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "八代、武谷両聖人が今更のように眼をパチクリして湊屋の顔を凝視しているところへ、鼾を掻き止めた令兄杉山茂丸氏がムクムクと起上って、赤い眼をコスリコスリ、「ハハア。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中にタッタ一人林技師が如何にも不満そうにグビリグビリと手酌でやっているのを見た人の悪い令兄が、「オイ。",
              "citation": {
                "source": "近世快人伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "旧藩以来福岡市内｜薬院に居住し、医業を以て聞こえている前医師会理事故権藤寿三郎氏（現病院長健児氏令兄）は梅津只圓翁の係医として翁の臨終まで診察した人であるが、嘗て筆者にかく語った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "因にこの時の只圓翁の上京問題に就ては当時在京の内田寛氏（信也氏父君）、米田與七郎氏（米田主猟頭令兄）が蔭ながら非常な尽力をされたそうである。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "醫學博士で歌人であつた故豊島烈氏の令兄である。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は非常によい折と思うて令兄に乞うて氏の墓所に參し、それから山道づたひに繪島の墓に向つたのであつた。",
              "citation": {
                "source": "伊那紀行",
                "author": "今井邦子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令兄の言うように、小父さんにどんな目論見があろうとも、そのために小父さんを憎む気にはどうしても成れなかった。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "暮羊君来庵、同道して、四時の汽車で防府へ行く、令兄のところで御馳走になる、悪筆を揮ふ、十時の汽車で帰る、駅前でＩさんに逢ふ、三人で飲む、近来にない愉快な一夜だつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "商業新聞のやりかたにいためられてはじめは会うのも話をするのもいやがっていた令兄子之吉氏は、やがて『文学新聞』というもののたちがわかって、ぼつぼつ話しはじめたと書かれている。",
              "citation": {
                "source": "それに偽りがないならば",
                "author": "――憲法の規定により国民の名において裁判する――鈴木裁判長",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮令兄には懐いても、嫂には懐かないという家庭の空気の中に子供等を置くことの結果をも考えた。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "鹿島君は私どもよりは一年先輩であるが、令兄が大学で文科をやられていたのによるであろうか、私どもを全く驚かしたほど外国の作家のことを知っていた。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした私は芹沢慎一氏――光治良氏の令兄――にひっぱられてボート部に入り、組選を漕ぐことになった。",
              "citation": {
                "source": "読書遍歴",
                "author": "三木清",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「麻布令兄御｜女子御両処へ宜奉願上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "「麻布令兄様御女子御両処へ宜奉願上候。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "令兄は信美であらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "菅茶山が「麻布令兄」と書した所以であらう。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "寛先生自身又その令兄達皆幼時からそれぞれ寺に養はれた事実があるが、それがこの歌のモチイフを為してゐること勿論の話だ。",
              "citation": {
                "source": "晶子鑑賞",
                "author": "平野萬里",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は令兄の文吉さんを知つてゐるが、今また令弟と相知る機会を得たのである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ以前の事を私はよく知らないが、はじめはなんでも君の令兄都築豺膓子君がずつと以前天の川に投句してゐた関係から、同君がすゝめたのであると聞いたやうに記憶してゐる。",
              "citation": {
                "source": "不器男句集",
                "author": "芝不器男",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は昨年三月二十二日、先生と先生の令兄淺野正恭中将と岡田熊次郎氏とにお伴して駿河台の主婦の友社来賓室に於て九條武子夫人と語る霊界の座談会に列した。",
              "citation": {
                "source": "小桜姫物語",
                "author": "02 序",
                "note": "青空文庫"
              }
            },
            {
              "text": "正月の初めに偶然この伊豆温泉の相模屋へ泊り合せた五人――臺灣總督府の石井光次郎さん、日本評論社の茅原茂さん、野口米次郎の令兄である高木藤太郎さん、それに私達夫婦が――昨夜からの突然な思ひ立出で、三里先きの海上にある初島を觀に行かうと決めたのです。",
              "citation": {
                "source": "初島紀行",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "春が近づいた頃私は辰夫の令兄から甚だ感傷的な、それはまるで小女雑誌の投書のやうな長文の手紙を受取つてゐた。",
              "citation": {
                "source": "母",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "令兄は法学博士岡野啓次郎氏という事であった。",
              "citation": {
                "source": "自作肖像漫談",
                "author": "高村光太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、水之趣味社竹内氏の令兄が黒姫から妙高の奥へ測量に行って実見した話である。",
              "citation": {
                "source": "蛙を食う岩魚",
                "author": "佐藤垢石",
                "note": "青空文庫"
              }
            },
            {
              "text": "春が近づいた頃私は辰夫の令兄から甚だ感傷的な、それはまるで小女雑誌の投書のような長文の手紙を受取っていた。",
              "citation": {
                "source": "母",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
