    },
    "definitions": [
      {
        "index": 1,
        "gloss": "the regular time",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "主は疾に会社に出勤せし後にて、例刻に来れる髪結の今方｜帰行きて、まだその跡も掃かぬ程なり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "次の日も例刻になれば狂女は又｜訪ひ来れり。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "槍は降りても必ず来べし、と震摺れながら待たれし九日目の例刻になりぬれど、如何にしたりけん狂女は見えず。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日も例刻に学校へ行って講義を聞いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は約束だから、天長節にもかかわらず、例刻に起きて、学校へ行くつもりで西片町十番地へはいって、への三号を調べてみると、妙に細い通りの中ほどにある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　時雄は例刻をてくてくと牛込矢来町の自宅に帰って来た。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日｜経って後、時雄は例刻に社から帰って火鉢の前に坐ると、細君が小声で、「今日来てよ」「誰が」「二階の……そら芳子さんの好い人」　細君は笑った。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は学校が午ぎりだから例刻を待ちかねて麻布まで車代二十五銭を奮発して老人に逢って見る。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は思ふ仔細があるから、例刻より早ャ目に出校して山嵐を待ち受けた。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は腰を掛けながら、毎朝例刻に先を爭つて席を奪ひ合ひながら、丸の内方面へ向ふ自分の運命を顧みた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は例刻に歸つて來た。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日も例刻に学校へ行つて講義を聞いた。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌日は約束だから、天長節にも拘はらず、例刻に起きて、学校へ行く積りで西片町十番地へ這入つて、への三号を調べて見ると、妙に細い通りの中程にある。",
              "citation": {
                "source": "三四郎",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日は思う仔細があるから、例刻より早ヤ目に出校して山嵐を待ち受けた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は例刻の五時がとうの昔しに過ぎたのに、妙な酔興を起して、やはり同じ所にぶらついていた自分を仕合せだと思った。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "田崎は例のごとく日々来たりては、六畳の一間に控え、例のごとく事務をとりてまた例刻に帰り行く。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その日は、お房が入院してから一週間余に成るので、森彦も病院へ見舞に寄って、例刻よりは早く自分の娘の方へ来た。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくすること毎日少しも変わらず、例刻に到り米舂場の辺り田畑の畔に琅々の声聞うれば、弟玉木文之進（松陰の叔父なり）常に笑って曰く、「ヤアまた兄さんのが始まった」と。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "九時の例刻を待ちかねて病院へ出掛ける。",
              "citation": {
                "source": "坑夫",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "例刻に食堂へ下りて飯を食ったら、知らない西洋人といっしょの卓へ坐らせられた。",
              "citation": {
                "source": "満韓ところどころ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時彼は外套も雨具も着けずに、ただ傘を差しただけで、何時もの通りを本郷の方へ例刻に歩いて行った。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "健三はさっさと頭から白襯衣を被って洋服に着換えたなり例刻に宅を出た。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "十　彼は例刻に宅へ帰った。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "五十三　翌日例刻に帰った健三は、机の前に坐って、大事らしく何時もの所に置かれた昨日の紙入に眼を付けた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "例刻に帰った時、彼は洋服のままでまた細君の枕元に坐った。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は腰を掛けながら、毎朝例刻に先を争って席を奪い合いながら、丸の内方面へ向う自分の運命を顧みた。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗助は例刻に帰って来た。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕飯を皆でたべてから、後はお前達二人の都合にすればよかろう」　例刻に病院から帰ると、玄関の沓脱石に、黒革の半靴が、きっちり揃えてあった。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノルマンは、さんざ、巨人ハルクを、利用するだけ利用したうえ、ハルクが毒蛇のためにかまれて、もう再起する力がないと見るや、れいこくにも、ハルクを倉庫の中にすててしまった。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
