        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そうして一時はその御弟子に、黎元洪を選んだと云う事である。",
              "citation": {
                "source": "上海游記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「朕｜黎元を撫育する事梢に年歳を経たり。",
              "citation": {
                "source": "大和古寺風物誌",
                "author": "亀井勝一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "黎元洪を彼は推していたんだ。",
              "citation": {
                "source": "いやな感じ",
                "author": "高見順",
                "note": "青空文庫"
              }
            },
            {
              "text": "烟を望みて黎元を撫でたまひき、今に聖帝と傳ふ一一。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
