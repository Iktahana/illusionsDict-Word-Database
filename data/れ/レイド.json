    "definitions": [
      {
        "index": 1,
        "gloss": "zero degrees (Celsius)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
