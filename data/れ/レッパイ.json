    "definitions": [
      {
        "index": 1,
        "gloss": "defeat of the weaker",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
