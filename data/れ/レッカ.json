[
  {
    "uuid": "b6b6f344-6d24-5dc5-a68c-04a773f66921",
    "entry": "劣化",
    "reading": {
      "primary": "れっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
