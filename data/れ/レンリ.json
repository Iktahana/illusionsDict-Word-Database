    "definitions": [
      {
        "index": 1,
        "gloss": "trees with entwined branches",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
