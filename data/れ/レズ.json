        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "雑誌リュテースを編輯してゐたレオ・トレズニカは、アムール・ジョーヌと『歎き』（ラフォルグの詩集）の作者との明らかな類縁に驚いて、コルビエールに肩を持ちながら両者を比較してラフォルグを荒だてたのであつた。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポール・カリグに手解されてゐたトレズニカ独り、良心を以てコルビエールを読んでゐたのである。",
              "citation": {
                "source": "トリスタン・コルビエールを紹介す",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "このなじみのロンドンに詳しければ、その会社の事業所とやらがフレズノウ街にあって、アッパ・スウォンダム横町から出たところにあるとわかるだろう。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が変になりそうなくらい、不安と恐れでいっぱいになり、横町を走り出たのだが、たまたま運の良いことに、フレズノウ街で警察の一隊にぶつかった。",
              "citation": {
                "source": "唇のねじれた男",
                "author": "THE MAN WITH THE TWISTED LIP",
                "note": "青空文庫"
              }
            },
            {
              "text": "從テ國家ノ物價調節ハ一絲紊レズ整然トシテ行ハルベシ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "此ノ原野ハ六千年間婦人ニ耕ヤシ播カレズシテ殘レリ。",
              "citation": {
                "source": "日本改造法案大綱",
                "author": "北一輝",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁につけて、レズリー・スピーカーのついていないハモンド・オルガン、アップライト・ピアノ、ヴィデオコーダーと呼ばれる、小さなトランクほどの大きさがある重い機械がおかれ、天井近くに十九インチのテレビがある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヤードバーズ〈フォー・ユア・ラヴ〉、アウトサイダーズ〈タイム・ウォント・レット・ミー〉、ナシュヴィル・ティーンズ〈タバコ・ロード〉、ビーチボーイズ〈アミューズメント・パークス・ＵＳＡ〉、それに、ナンシー・シナトラやレズリー・ゴーアなんてものまである。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "シルヴィーにくらべれば、レズリー・ゴーアも、コニー・フランシスも、「ゼーンゼン目じゃない」のだそうだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティーヴィーみたいな、攻撃的な音がほしいだけだが、レズリー・スピーカーがついていないのだから、それも不可能だ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも、ふたりが問題にしているのは、ハモンドの性能やレズリーの有無ではない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "右ハ至情不得止ニ出ルト雖モ、畢竟私憤ヲ以テ、大禁ヲ破リ、私義ヲ以テ、公権ヲ犯ス者ニシテ、固擅殺ノ罪ヲ免レズ。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと骨格をつければ暢びて行くだろうとは考えていたので、それにはいくらか自身のレアレズムの畑へ引き込んでみるのも悪くはあるまいと思っていた。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウルフは、英国の上流人であるレズリー・ステフン卿の娘に生れ、家庭で教育されている。",
              "citation": {
                "source": "夫婦が作家である場合",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "このキット式のコンピューターをアルテアと名付けたのは、『ポピュラーエレクトロニクス』のテクニカルエディター、レズリー・ソロモンの娘だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同書第一巻、政治の部の註に、本文自主・任意・自由ノ字ハ、我儘放盪ニテ、国法ヲモ恐レズトノ義ニ非ラズ、総テ其国ニ居リ、人ト交テ、気兼ネ遠慮ナク、自分丈ケ存分ノコトヲナスベシトノ趣意ナリ、英語ニ之ヲ「フリードム」又ハ「リベルチ」ト云フ、未ダ的当ノ訳字アラズ。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "那珂氏は菅氏の説に對しては筑前博多ヨリ贈於郡ニ至ルニ、豐前豐後日向ノ東ニ沿ヒテ、佐多岬ヲナレバ、信ゼラレズ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士ハ魏志文ヲ引クニ、伊都國ヨリ邪馬臺マデノ行程ヲバ略カレタレドモ、コレラノ行程ハ、國々ノ位置ヲ求ムルニ必要ナル者ナレバ、多少ノ誤謬ハ免レズトモ、全クハ棄ツベキ者ニアラズ。",
              "citation": {
                "source": "倭女王卑彌呼考",
                "author": "白鳥庫吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "※生ノ腹ヲ曝スハ甚ダ傲ニ失シテ君子ノ笑ヲ免レズ。",
              "citation": {
                "source": "土用干ノ記",
                "author": "※上漁史",
                "note": "青空文庫"
              }
            },
            {
              "text": "嗚呼吾ト汝ハ如何ナル宿因有テカ、一度莫逆ノ交ヲ訂セシヨリ旦暮相離レズ。",
              "citation": {
                "source": "祭活字子文",
                "author": "成島柳北",
                "note": "青空文庫"
              }
            },
            {
              "text": "局所を中心にして腹部と股に蜘蛛の巣がイレズミされてゐる。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "腹のイレズミも見事だけれども、あなたの顔には及ばない。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのはづかしさを思ひつめ、強迫観念になやまされたが、友達の話にヒントを得てひそかにイレズミをやつた。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるべきところに毛がないてえのを悩みぬいたあげくにイレズミをしてさらに悲歎を深め、わが運命を無限の失恋とみる、悶々の嘆きが凝つて酔へば前をまくつてタンカをきる、この胸の中はせつないね。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "イレズミは構図も彩色も着想も見事な妙味があるのだから、物自体としちや最もユニックな見世物なんで、単にエロ、下品、露骨と見せちやいけないやね。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "めんどうくさくて、準備的な行動だけで一日すごし得るところヤリキレズ。",
              "citation": {
                "source": "日記",
                "author": "一九三〇年（昭和五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "千八百六十一年八月十四日の午前十一時四十分に、サー・レズリ・スティーヴン Sir Leslie Stephen の一行が絶巓に立って以来、幾度の壮烈な悲劇は、その山頂に山腹に、絶えずくりかえされつつ、今日に至ったのである。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の子のイレズミもはやったし、男女混浴という同権思想も肉体の探究もはやり、忙しく文明開化をとりいれて今にもまさる盛時であった。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにイレズミとか傷アトぐらいは考えられるが、お直の目にわかる特徴だからたぶん着物の下に隠れる種類のものではありますまいね。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その二十　トンビ男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
