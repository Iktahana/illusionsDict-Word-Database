    },
    "definitions": [
      {
        "index": 1,
        "gloss": "successive generations",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下　眞田家の領地信州川中島は、列國に稀なる損場にて、年々の損毛大方ならざるに、歴世武を好む家柄とて、殖産の道發達せず、貯藏の如何を顧みざりしかば、當時の不如意謂はむ方無かりし。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蘭軒前後に亘つた「歴世略伝」も亦同じである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ根本材料は伊沢｜徳さんの蘭軒略伝乃至歴世略伝に拠るとする。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に歴世略伝に有信の父と云ふものが載せてあるが、これは正久とは別人でなくてはならない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴世略伝にある六人は、男子が榛軒常三郎柏軒、女子が天津長順である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "曾能は歴世略伝に拠るに、一子二女を生んだ。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に程赤城があり、胡兆新があると、歴世略伝に見えてゐる。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴世略伝に拠るに、是より先榛軒は狩谷庭、辻本｜斎である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "按ずるに歴世略伝榛軒の部に、「文政四年七月二十八日備中守阿部正精公侍医」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴世略伝を検するに榛軒の子は柏、久利の二女を載するのみである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "蘭軒の遺弟子は所謂又分家の良子刀自所蔵の門人録に八十一人、所謂分家の徳さん所著の歴世略伝に二十一人が載せてあつて、二書には互に出入があり、氏名の疑似のために人物の同異を辨ずるに苦むものもある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし蘭軒自筆の勤向覚書に僅に門人七人の氏名が見えてゐて、その門人録及歴世略伝に載するもの四人、門人録に載せて、歴世略伝に載せざるもの二人、二書並に載せざるもの一人である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是に由つて観れば、門人録も歴世略伝も、猶脱漏あることを免れぬものと見える。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の名は八百、杉田玄白の女だと、歴世略伝に云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "是は歴世略伝に拠るのである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴世略伝に「安政丙辰阿部公侍医」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "平川は歴世略伝の柏軒門弟の部に載せてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "歴世略伝には只九人の名が載せてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "方庵の事は歴世略伝に見えない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "以上は歴世略伝の載する所である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "極く初歩の参考書を云うと、服装、風俗では、「歴世服飾考」「貞丈雑記」「近世風俗類聚」など、食物は、宇都宮黒滝氏の「日本食物史」、旅行は、鉄道省の「日本旅行記」吉田十三氏の同名の書。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本にて之に類するものは、舊暦三月三日上巳の節句、家々に雛を飾り、俗に云ふお内裏樣とて雛の棚の上段に奉るは、蓋し日本國中の至尊たる歴世の天皇と皇后との御兩體を表したるものならん。",
              "citation": {
                "source": "帝室論",
                "author": "福沢諭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "本朝の部では上題の人物は最も廣く、聖徳太子、行基菩薩、役小角、玄※、鑒眞、空海、傳教以下の智識高僧や、良岑宗貞、大江定基、源滿仲、藤原顯基等の名流や、藤原氏歴世の貴紳、源平兩家の武將中で聞えた人、その外詩歌、藝能、術數の道などで凡そ名ある者の限りが出て來る。",
              "citation": {
                "source": "父兄の方々に",
                "author": "和田萬吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "而仍不戻乎我國歴世相沿之禮教民情。",
              "citation": {
                "source": "支那近世の國粹主義",
                "author": "狩野直喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "その『万葉』の古文辞より、王代の政刑律例に及び、『古事記』より王代歴世の史に到り、その他歌詞雑文の学より、延いていわゆる一種の神典に及ぶまで、彼らが探討講索の結果は、復古的革命を激成するの媒介たらざるはなかりき。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで藩士分限録と歴世名臣伝というのをしらべてみたところ、筆者の本名は永井民部といい、百石ばかりの小姓から、晩年には七百石あまりの中老に出世した人であった。",
              "citation": {
                "source": "若き日の摂津守",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "天壤無窮に、わが皇室とわれ等民族は、一器の水を器から器へ移すやうに、歴世、その建國の大精神をこぼすことなく傳へてきた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "白と黒の地界　天智、天武、持統、聖武天皇などの歴世を通じて、仏教の興隆このかた、全国に創建された寺院の数はたいへんなものである。",
              "citation": {
                "source": "平の将門",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "空家を攻めても効はないが、歴世十何代、足利義昭にいたって、将軍家はみずから職を抛って遁亡した。",
              "citation": {
                "source": "新書太閤記",
                "author": "第四分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
