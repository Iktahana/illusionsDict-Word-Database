[
  {
    "uuid": "bb85a98e-9d6b-5273-9b15-5c57f65b020c",
    "entry": "歴世",
    "reading": {
      "primary": "れきせい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
