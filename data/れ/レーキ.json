[
  {
    "uuid": "d99d8c5a-6b15-5833-b362-feba5102b3c5",
    "entry": "レーキ",
    "reading": {
      "primary": "レーキ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "rake",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "文彦は、「ブレーキを悉皆かけてくれ。",
              "citation": {
                "source": "月世界競争探検",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん宿屋は、湖畔のレーキホテルを選定した。",
              "citation": {
                "source": "夏帽子",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハンドルが水牛の角のやうな形をし、ブレーキと荷｜掛けとチエーンのカバーがない。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ブレーキが利かんだつたと見えるな」と年とつた方の紳士がいつた。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこかの年とつた男がブレーキのきかない自轉車で、速力を抑へることが出來ず、ま一文字にかけ下りて、坂下の油屋にとびこみ、死んだのである。",
              "citation": {
                "source": "坂道",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でも、おやおやと思うほど駄目になって、意志のブレーキが溶けて消えてしまうのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私のこんな情ない有様を、母や兄が見たなら、どんなに残念がることか、地団駄踏んで口惜しがることだろう、としきりに悲しく思っても、もはや私は、意志のブレーキを失っている。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、それを知っていたが、どうにも意志のブレーキが、きかないのである。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手ははっとして、機械的にブレーキをかけた。",
              "citation": {
                "source": "焦土に残る怪",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨だらけの円タクが加奈子を突倒しでもするように乗りつけて来てブレーキをかけても異様な音と共に一二｜寸乾いた土の上を滑る。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――だが、私共はいくつでもブレーキを持って居るのです。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、その沢山のプレーキの歯止めを噛ませるうちには、どれかの歯止めが役に立つのです。",
              "citation": {
                "source": "ガルスワーシーの家",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」豹一は思わず叫んでいたが、頓間な運転手は多鶴子の車を掴えることばかしに気を取られていたので、豹一がそう叫んだ時、既にまるで当然のようにブレーキを掛けてしまっていた。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "機関手はブレーキに手をかけた。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉川機関手は周章てレギレーターを戻しブレーキを入れた。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、もうブレーキでは間に合わなかった。",
              "citation": {
                "source": "汽笛",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜中ごみ焼をしている人だちは、火影に顔をまっかに染めながら、長いレーキ（ごみさらい）で、火をつゝいたりごみをくべたりしていた。",
              "citation": {
                "source": "惨事のあと",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "出版社のこうした販売政策は、本来ならどんどん進んで当然の電子辞書の普及にブレーキをかけてきました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼崎君は襯衣一つに成つてホーレーキを擔いて學校園を歩いて行く處である。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホーレーキといふのは立鎌と熊手とを背中合せにくつゝけて拵へた農具である。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼崎君がホーレーキを擔いて出るやうに成つてから雜草が除かれた。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふと見ると窓の外から沼崎君がホーレーキを擔いた儘微笑しながら覗き込んで居る。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや兎角く此道ではブレーキが利きにくいものだ。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "藤原は、産業予備軍が海員においては、組織的に、ボーレンによって動員準備されてある、かつ事情不明のためストライク・ブレーキングが平気で行なわれることを知っていた。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで諸君のうち英語のできるお方に私はスコットランドの教授ブレーキの書いた“Life and Letters of David Livingstone”という本を読んでごらんなさることを勧めます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからその次にこのブレーキ氏の書いた『デビッド・リビングストン』という本です。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで諸君のうち英語のできるお方に私はスコットランドの教授ブレーキの書いた \"Life and Letters of David Livingstone\" という本を読んでごらんなさることを勧めます。",
              "citation": {
                "source": "後世への最大遺物",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてクリムソンレーキを水に薄く溶かしたよりもっと鮮明な光を持った鱗の色に吸いつけられて、思わずぼんやりと手の働きをやめてしまう。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろからきた服部が急ブレーキをかけ、そのうしろのほうが混乱したらしく、ハードケースが壁にぶつかる音がした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
      "homophones": [],
      "synonyms": [],
      "antonyms": [],
      "related": []
    },
