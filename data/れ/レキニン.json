        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "情報処理営業支援本部でユーザー教育にあたる教育部長を三年経験してから、高山はパーソナルコンピュータ企画室長代理、パーソナルコンピュータ販売推進本部長代理を歴任していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治元年二月内國事務參與職ニ補セラレ、尋デ公議院ノ議長、左院小議官等ニ歴任シ、或ハ元老院議官ニ、或ハ貴族院勅選議員ニ任ゼラレ、明治三十七年十月病テ歿ス。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "秋月古香略傳",
                "note": "青空文庫"
              }
            },
            {
              "text": "既ニシテマタ権大法官、五等判事ニ歴任ス。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "東京府師範学校教諭、中学校教諭ニ歴任シ、傍家塾ヲ開キ徒ヲ聚メテ業ヲ講ズ。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "世良田は明治初年に地方の府県知事を二ヶ所歴任したあと、地方行政、税法、選挙制度など研究の任務をおびて洋行し、十一年間遊学して帰朝したのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その三　魔教の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の大阪府判事、神奈川縣知事、租税權頭、及び元老院幹事等の諸官を歴任して、前半期の終結たる明治十一年の隱謀事件に至るまで、伯の胸中に畫きしものは唯だ藩閥政府を顛覆せむとするの戯曲のみ。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の大阪府判事、神奈川県知事、租税権頭、及び元老院幹事等の諸官を歴任して、前半期の終結たる明治十一年の隠謀事件に至るまで、伯の胸中に画きしものは唯だ藩閥政府を顛覆せむとするの戯曲のみ。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            },
            {
              "text": "土井利位が度々異数の抜擢を受けて、幕府の重職を歴任したのは、泉石のこういう方面での助力もあずかって力あったものらしい。",
              "citation": {
                "source": "『雪華図説』の研究後日譚",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジンサーはコロンビア大学を卒業してからスタンフォード大・コロンビア大・ハーバード大の微生物学・免疫学の教授を歴任した教育・研究の第一人者であるとともに第１次世界大戦にさいしては中部ヨーロッパなどにおいて防疫に従事し戦後は国際連盟の代表としてロシアに滞在した。",
              "citation": {
                "source": "ネズミ、シラミ、歴史",
                "author": "――専門家でない読者に必要な12章を含む発疹チフス一生の伝記",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の名誉職ばかりをいくつも歴任し、自宅に人を集めて集会を開いたり宴会をしたりするのが、彼の仕事だった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "大岡家は、十一家もあり、ここの忠右衛門｜忠真は、本家格ではないが、お徒士頭、お先鉄砲組頭、駿府｜定番などを歴任し、いまは、閑役にあるといえ、やしきは大きなものだった。",
              "citation": {
                "source": "大岡越前",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すでにして郷に還り、即日、収を瑞龍山先塋の側に相し、歴任の衣冠魚帯を※め、載ち封し載ち碑し、自ら題して、梅里先生の墓と曰ふ。",
              "citation": {
                "source": "梅里先生行状記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "献言百諫　直江大和守実綱は、謙信の父祖以来三代に歴任して来た宿将中の宿将である。",
              "citation": {
                "source": "上杉謙信",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五代の執権代、十二代の連署など、補佐の重職を歴任してきた彼だった。",
              "citation": {
                "source": "私本太平記",
                "author": "新田帖",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
