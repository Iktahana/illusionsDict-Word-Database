[
  {
    "uuid": "328e648b-86de-56c2-9f99-2a8736a9c8c4",
    "entry": "列車",
    "reading": {
      "primary": "れっしゃ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
