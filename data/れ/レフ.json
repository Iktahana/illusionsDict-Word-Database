[
  {
    "uuid": "9d7df4d5-9395-522d-9e7f-1e7b5fc13521",
    "entry": "レフ",
    "reading": {
      "primary": "レフ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
