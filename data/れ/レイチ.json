[
  {
    "uuid": "bac6de8c-9fc9-5e17-9bd1-fb7e2c0e9e59",
    "entry": "霊地",
    "reading": {
      "primary": "れいち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
