          "literary": [
            {
              "text": "八雲氏令孫の筆を染めたという書名題字もきわめて有効に本書の異彩を添えるものである。",
              "citation": {
                "source": "小泉八雲秘稿画本「妖魔詩話」",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れども後遂に其の妓、緑珠が事によりて、中書令孫秀がために害せらる。",
              "citation": {
                "source": "唐模樣",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに、近年勾当の令孫君、余が学校を訪われ君が祖父故葛原勾当自記の四十余年間に亘れる仮名文字活字日誌を示され、且、其生存中に於ける事業の大要及び勾当の趣味等につき、詳に語らる。",
              "citation": {
                "source": "盲人独笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
