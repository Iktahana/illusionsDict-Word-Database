        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ふつうのパンフレットです」「すぐそんなことを言うからな。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二、三日中に、文芸春秋社から「新ハムレット」が出る筈です。",
              "citation": {
                "source": "私の著作集",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "水色の壁に立てけけた真白な石膏細工の上にパレットが懸って布細工の橄欖の葉が挿してある。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブリキを火箸でたたくような音が、こういうリズムで、アレグレットのテンポで、単調に繰返される。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "此邊の子供には大分專門的の知識があつて「チューブ」だの「パレット」だのといふ言葉を云つて居るのが聞こえた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「春の香水、ヴィオレット・ド・バルム」気が利き過ぎて却って張り合いがない。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　近ごろ Sanremo Casino の賭博室で、ルーレットが十一番に六回続けて当ったという事件があった。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "柱作りに適するローヤル・スカーレットという薔薇がある。",
              "citation": {
                "source": "雑記帳より（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "主義に於ても、内容に於ても、殆んど全然『感情』を標準にしたところのパンフレットが続々として後から後から刊行された。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アメリカのほん屋でオリヴァ・ギャレット、グロバー・ジョンス、ヴィンセント・ローレンスあたりです。",
              "citation": {
                "source": "五題",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "堪え切れなかった侮辱のため投げられたガウントレットを拾い上げたのだ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾達が最初におあいしたのは、カバレット・トアズンドルの舞踊会でした。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・トアズンドルの舞台では、ターバンを巻いた印度人が、細腰のヒンズー女を抱いて、宗教的な怪奇な踊りを舞っていました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーレットのモナコ、悪徳の町、三十九の機会の町、妾の運命、そんなとりとめのない頽廃した意思が妾を支配していたのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣室からルーレットの玉の転げる音が、悪魔の囁きのように妾の耳に響いて来ました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロダンさんは妾に数枚の赤札を買って下さいましたが、みるみるルーレット係の役人の手によって、玉の転げる音と共に消えてしまいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐野は最後の百｜法をルーレット係に渡して白札を求めているのです。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット銀座の情婦、無智な妖婦から電話がかかってくる。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレットのキャラバン、酒場から酒場へ近道の建札、夜の美粧院に吊された青蛙の料理写真にしたらんたん、足の化粧法、日本人を日本人らしく見せない整型学、醜いものをグロテスクにするための進歩主義、あわただしい木馬競走に見惚れる観衆の喝采。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は花田君子柳の下に棄てて、カバレット銀座、未来の情婦、万国の血をみて狂うメイ・フレデリック、私を見るや彼女の情熱死物狂い（その頃喫茶店インタナショナルの芸術家は珈琲とフランス菓子に驚歎して昆虫類が今後人間に代ってエゴイズムと排他主義、実行する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・ポンペアの低い嬉びに、世界各国の鶏の歌奏でるユダの主人、私はシャンパン、緑色の天井、進撃勇ましい、桃色の月、見上げて、十人のコウカサスの女に接吻する。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのカバレット・トア・ズン・ドルの淡い憶いがネムの花に夢のように、あらわれるのだが、彼女は何もかも知らぬふりをして、私の用事を待つ、それが英国種の牝犬のように無関心な顔をして、その実細心なデコルテを内にかくしてかしこまっている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "で僕はむくむく起きあがると贅六らしくだらしなく身繕いして、そっと自分の服装を見たんだが、カバレット・トア・ズン・ドルの歴史がべたべたそのまま張られているのに気がついたのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はマルセーユのカバレット・トア・ズン・ドルの東洋の女を一人忘れものしたのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾は即座にカバレット・トア・ズン・ドルにお別れを告げると、ローヌ河でパンツを洗濯してすっかり清浄な心と魂を持つ女になったのです。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・バビロンの白煉瓦の高層な建物から流れるワルツの曲が街角に直立した赤い帽子の印度巡査をモスモロスの道化役者風にしたててバビロンの入口の廻転ドアの前に金モールのいかめしい英国人の門衛が莞爾とした笑いをたたえている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜の界わいを、極度に断截された近代娘たちが、短いスカートと男のような乳房と新しい恋愛教科書によった独立の精神をもった彼女たちが、キャバレットとバーと夜の百貨店へくりだした。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "流行品店とキャバレーのあるアスファルトの露地に、黒いケープレットのついた夜の衣裳をつけて、ハイ・ヒールのエナメルの靴を穿いた都会の売笑婦。",
              "citation": {
                "source": "戦争のファンタジイ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "」……　最後にジミーは、一人のボルシェビイキの猶太人からリーフレットを受取って、それを二日のうちに全部まいてしまった。",
              "citation": {
                "source": "反戦文学論",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "もと使った絵の具箱やパレットや画架なども、数年前国の家を引き払う時に、もうこんなものはいるまいと言って、自分の知らぬ間に、母がくず屋にやってしまったくらいである。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
