    "definitions": [
      {
        "index": 1,
        "gloss": "money (given as thanks)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
