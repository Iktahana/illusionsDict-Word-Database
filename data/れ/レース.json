    "definitions": [
      {
        "index": 1,
        "gloss": "race",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "鉄門という言葉は明治時代の隅田川のボートレースと土手の桜を思い出させる。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄門が無くなって、隅田堤がコンクリートで堅まれば、ボートレースの概念もやはり変って来る。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうどボートレースに、櫂からの雫が、河面にポタポタして、小さな円い輪を描いたのに似ている。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えばタレースは始めて金字塔の高さを測るために、塔の影の終点の辺へ小さな棒を一本立てた。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓はターリング・プレースの花園に隣った寺の墓地の静かな片隅にある。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（明治四十年十月十五日『東京朝日新聞』）　　　　　　　　　二十　　　　　　ボートレースに無線電話　今年の七月、北米の大湖エリーの水上で端艇競漕のあった時、その時々刻々の景況を陸上に報ずるためテルマと名づくる小蒸気船に無線電話機を載せて現場に臨ませた。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "米良は空中滑走する、戦い疲れた陳独秀とビクトリア・カップよりセント・ジョウジ・プレースに至る山頂火車のなかで彼等は力なく握手して、空中の鏡の上にモーニング姿の印度人のイサックを発見するのであった。",
              "citation": {
                "source": "地図に出てくる男女",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "スリップにつけたレースがまんかいしてスカートから臑のあたりに××××るのはあまり感心しないがどうしたものか。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "のみならずこのシュテンドウシがアラビアから来たマレイ語で「恐ろしき悪魔」という意味の言葉に似ており、もう一つ脱線すると源頼光の音読がヘラクレースとどこか似通ってたり、もちろん暗合として一笑に付すればそれまでであるが、さればと言って暗合であるという科学的証明もむつかしいような事例はいくらでもある。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてまさにこの点で彼が、彼の駁撃を加えているヘラクリトス、エンペドクレース、アナクサゴラスの輩をいかにはるかに凌駕しているかを見る事ができよう。",
              "citation": {
                "source": "ルクレチウスと科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アリストテレースなどは贓品の蔵を建てた男である。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、双晶のオーソクレースが仲裁に入った。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、プラヂョさんといふのはプラヂオクレースで青白いから医者なんだな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ははあ、プラジョさんというのはプラジオクレースで青白いから医者なんだな。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井田は自分の室からソフォクレースの悲劇集を持つて來て開いて讀まうとすると、書生が來て湯の事を云ふので這入りに行つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "書齋の唐紙を開けると明るいランプの下に井田はソフォクレースを讀んで居た。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「唯今……湯に這入りましたか」と云つて相島は井田の机の上に眼をやつて、「其のソフォクレースの表裝は大したものですね」と腕を伸してそれを取つた。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソフォクレースの悲劇集の中にはさんであつた、内山の去年の夏の手紙の中の、「われとわが思ひ定めし人の行末は、知る人も知る神もなし……彼女は益※われに忠實なれば、わが心は切らるるが如し……煙を見よ」と云ふ樣な煩悶の句がちぎれ／＼に頭に浮んで來る。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ファニーは――ファニーは頸飾りのレースだけが眼立つほど影になった室の隅から軽く頸をかしげて微笑を送ってよこした。",
              "citation": {
                "source": "フランセスの顔",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして薄いレースの窓帷を時々優雅な人影が横切った。",
              "citation": {
                "source": "アンドロギュノスの裔",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "……）　彼女は白いレースの飾のしてある枕に泪を滾しながら、赤い煙突と彼女自身の身の上を憐んだ。",
              "citation": {
                "source": "赤い煙突",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元のスタンドランプには、幸子が編んだ南京玉のついたレースの覆いがかけてあった。",
              "citation": {
                "source": "勝敗",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし堅気にしておけばおいたで、目に見えない金が消え、先の生活の保証のつく当てもなく、ゴールのないレースを無限に駈けつづけているに等しかった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのありさまは、まるで、キラキラ光る白いレースもようのようでした。",
              "citation": {
                "source": "雪だるま",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の眼には真佐子のやや、ぬきえもんに着た襟の框になっている部分に愛蘭麻のレースの下重ねが清楚に覗かれ、それからテラコッタ型の完全な円筒形の頸のぼんの窪へ移る間に、むっくりと搗き立ての餅のような和みを帯びた一堆の肉の美しい小山が見えた。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜はやや更けて、天地は黒い塀を四壁に立てたように静まり閉すにつれ、真向うの池の端の町並の肉色で涼しい窓々の灯、軒や屋根に色の光りのレースを冠せたようなネオンの明りはだんだん華やいで来た。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
