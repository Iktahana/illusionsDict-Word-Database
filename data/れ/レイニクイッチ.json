    "definitions": [
      {
        "index": 1,
        "gloss": "unity of body and spirit",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
