        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "写真やイラストを組み込んだり、頁ごとにレイアウトを変えるには、そのための追加操作が必要です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイアウトや文字組の処理は、マシンにとってかなり込み入った仕事です。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイアウトが工夫できて、いろいろなフォントが使えるソフトウエアを書いたとしても、これまでのようなギザギザの目立つプリンターしか使えないのでは台無しです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ライノトロニックと名付けられたその装置にかければ、マックでレイアウトし、レーザーライタで確認したデータからそのまま製版用のフィルムが作れました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "同年の七月には、高度なレイアウト処理を可能にするページメーカーと名付けられた編集用ソフトがアルダスから出荷され、ＤＴＰの主役がそろいます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと見には印刷としか思えないものが簡単に作れるとなると、社内用の文章も多少はレイアウトを工夫して、レーザーライタでプリントしたくなってきます。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "少しレイアウトを工夫して写真を入れれば、ちゃんとした感じになるだろう。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "本文を抜粋して中味を紹介することはできても、レイアウトや、写真、図版の類を見せて実際の雰囲気を伝えることはできません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポストスクリプトほど厳密には、レイアウトを決めません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういうレイアウトにするかといった約束事には、一切踏み込みません。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "書籍の紙面をレイアウトするソフトに原文データをかけて、大きな文字で印刷し、製本する。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "縦組み対応のウェッブブラウザーという仕立てにおいても特徴的なａｚｕｒは、字下げなどのレイアウト、漢文返り点などに対応し、さらには、コメント欄に書き記された情報を手がかりに圏点や各種の傍線まで、紙の本そのままに再現してくれる。",
              "citation": {
                "source": "「天に積む宝」のふやし方、へらし方",
                "author": "著作権保護期間延長が青空文庫にもたらすもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "込み入ったレイアウト然り。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イラストの凹凸に沿って一行の長さが伸びたり縮んだりするレイアウトを見ると、オレの頭は今でも自然と垂れる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "コンピューターの頭脳部分から、文字の形や並び、絵柄をプリンターや画面に伝えるさい、全体のレイアウトをあらかじめしっかり作った上で詳しい指示書の形で渡す方法がある。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ページ記述言語（例の一頁まるごと仕上げたレイアウトを、コンピューターが画面やプリンタに渡す方式の総称だ）への対応という新しい段階で、ポストスクリプトが統一方式の候補の一番手となったことまでは白ビットの教えの通り。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "図形や表組、スキャナーで取り込んだイメージなどを文章の中に取り込むことができ、二段組みや三段組みといった段組みも可能なダイナデスクは、文章を作るという機能を超えて、表現力の大きな文書を自由にレイアウトできる新しいジャンルに踏み出していた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "打ち出しの内容をあらかじめ確認できることで、ユーザーは画面上で手直しを繰り返してイメージどおりのレイアウトを固めてから、プリンターの電源を入れることができた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "文章の構造をはっきりさせるための技術を転用していて、レイアウトに対する考慮がないためだ。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アドビ社のアクロバットという技術を使うと、しっかりレイアウトした文書がインターネットでやりとりできる。",
              "citation": {
                "source": "短く語る『本の未来』",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
