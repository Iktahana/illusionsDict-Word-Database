[
  {
    "uuid": "e926f38e-0f2d-5a2a-bbd3-f818894f239b",
    "entry": "霊感",
    "reading": {
      "primary": "れいかん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
