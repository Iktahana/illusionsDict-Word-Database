[
  {
    "uuid": "a4952378-5ccc-5b2e-8c9a-007dfe58b382",
    "entry": "隷従",
    "reading": {
      "primary": "れいじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
