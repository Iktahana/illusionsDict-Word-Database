          "standard": [],
          "literary": [
            {
              "text": "それは、理化学の進歩の結果としてあらゆる交通機関が異常に発達したのはよいが、その発達が空間的時間的に不均整なために、従来は接触し得なかったような甚だしい異質的なものの接触が烈しくなり、異質間の異性質のグレディエントが大きくなった。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　運慶が木材の中にある仁王を掘り出したと云われるならば、ブローリーやシュレディンガーは世界中の物理学者の頭の中から波動力学を掘り出したということも出来るであろう。",
              "citation": {
                "source": "スパーク",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "）牧者（一歩出る）「レディスアン、ゼントルメン、わたくしが一つ唱ひます。",
              "citation": {
                "source": "ポランの広場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メレディス氏より鄭重な手紙を戴く。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レディ第一一（辛抱とは、どういう意味の？",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「兄は、貴女もご存じのとおり、長く米国におりましたから、すっかりレディ・ファストなのよ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、レディにご親切だから……」「じゃ、今までは僕に愛人なんかいないだろうと、心配していて下さったんですか。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "お名前はアーミティッジ――パーシィ・アーミティッジ――アーミティッジ家の次男で、レディングのそばのクレイン・ウォータにお住みです。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "列車がレディングを過ぎてずいぶんした頃、最後のひとつを座席の下に突っ込むと、葉巻入れをこちらに差し出した。",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は、遊蕩的な笑ひを浮べて、「レディの美しさに大方圧倒されてゐるんだらう。",
              "citation": {
                "source": "或る日の運動",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動写真でも、バァセルメスやナヴァロは、きっとレディを助けて奮闘するわ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ところで、せっかく県教委が理想とする男女交際をしているところに恐縮だが、しばらく、このレディをお借りできないかね」　と、寮長は令子の肩に両手をおき、高志を見た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "『パパ、カムダウン、サッパー、イズ、レディ』と三人の子供が上り段のところから、声を揃えて案内するのが例でした。",
              "citation": {
                "source": "思い出の記",
                "author": "小泉節子",
                "note": "青空文庫"
              }
            },
            {
              "text": "エミイル・ヴェルハアレン珊瑚礁　　　　　ホセ・マリヤ・デ・エレディヤ波の底にも照る日影、神寂びにたる曙の照しの光、亜比西尼亜、珊瑚の森にほの紅く、ぬれにぞぬれし深海の谷隈の奥に透入れば、輝きにほふ虫のから、命にみつる珠の華。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "床　　　　　　　ホセ・マリヤ・デ・エレディヤさゝらがた錦を張るも、荒妙の白布敷くも、悲しさは墳塋のごと、楽しさは巣の如しとも、人生れ、人いの眠り、つま恋ふる凡べてこゝなり、をさな児も、老も若も、さをとめも、妻も、夫も。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征　　　　　　ホセ・マリヤ・デ・エレディヤ高山の鳥栖巣だちし兄鷹のごと、身こそたゆまね、憂愁に思は倦じ、モゲルがた、パロスの港、船出して、雄誥ぶ夢ぞ逞ましき、あはれ、丈夫。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホセ・マリヤ・デ・エレディヤは金工の如くアンリ・ドゥ・レニエは織人の如し。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "エミイル・ヴェルハアレン　珊瑚礁　　　　ホセ・マリヤ・デ・エレディヤ波の底にも照る日影、神寂びにたる曙の照しの光、亜比西尼亜、珊瑚の森にほの紅く、ぬれにぞぬれし深海の谷隈の奥に透入れば、輝きにほふ虫のから、命にみつる珠の華。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "床　　　　　　ホセ・マリヤ・デ・エレディヤさゝらがた錦を張るも、荒妙の白布敷くも、悲しさは墳塋のごと、楽しさは巣の如しとも、人生れ、人いの眠り、つま恋ふる凡べてこゝなり、をさな児も、老も若も、さをとめも、妻も、夫も。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "出征　　　　　ホセ・マリヤ・デ・エレディヤ高山の鳥栖巣だちし兄鷹のごと、身こそたゆまね、憂愁に思は倦じ、モゲルがた、パロスの港、船出して、雄誥ぶ夢ぞ逞ましき、あはれ、丈夫。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏訳詩集",
                "note": "青空文庫"
              }
            },
            {
              "text": "エミイル・※ルハアレンホセ・マリヤ・デ・エレディヤ珊瑚礁波の底にも照る日影、神｜寂びにたる曙の照しの光、亞比西尼亞、珊瑚の森にほの紅く、ぬれにぞぬれし深海の谷隈の奧に透入れば、輝きにほふ蟲のから、命にみつる珠の華。",
              "citation": {
                "source": "海潮音",
                "author": "上田敏",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十歳のバルザックはレディギュール通りの屋根裏で、ストーブもたけず、父親の古外套で慄える体をくるみながら、ひどい勢で先ず幾つかの喜歌劇を書いた。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年前彼が二十の時、レディギェール通りの屋根裏部屋から愛する妹のロオルに切々と訴えた二つの希望「有名になって、愛されたい」という大きい希望に今やもう一つの、更に困難で、投機的ないかにも当時らしい性質をもった大望が加えられた。",
              "citation": {
                "source": "バルザックに対する評価",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "では、レディ達をルウ・ドュ・コマルス街の珈琲店の椅子へ一時預けにしておいて、出帆前にちょっとそのポウト・サイドの奥の奥と言うのを覗いて来るとしようか。",
              "citation": {
                "source": "踊る地平線",
                "author": "海のモザイク",
                "note": "青空文庫"
              }
            },
            {
              "text": "エドマンド・モラン卿及びレディ・モラン。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "ロイド・ジョウジの一家族は土曜日のキャンヌのレディ・ブウトの晩餐会を振り出しに、舞踏と招待とリセプションとが十五分おきに全旅程を埋めつくしていた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "現在米国でも、相当の知識階級の、青年男女は、殆ど滑稽な外観のレディファースト（婦人第一）を決して誇ってはいないのです。",
              "citation": {
                "source": "男女交際より家庭生活へ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
