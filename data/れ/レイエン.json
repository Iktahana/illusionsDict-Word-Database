          "literary": [
            {
              "text": "遺骨は多摩霊園二四区内に埋葬された。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "「多磨霊園ですよ」「多磨霊園？",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「霊園前、というところで降ります」　リカが言った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ナナエは嫌がってるはずだ」「きっと」　霊園前という停留所で三人はバスを降りた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂道を上り、霊園のゲートを入った。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　雛段になった墓地の一角から、霊園のぜんたいをトモは眺めわたした。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊園のなかの坂道を下り、バスの停留所まで三人は歩いた。",
              "citation": {
                "source": "少女時代",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
