    "definitions": [
      {
        "index": 1,
        "gloss": "brick",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "煉瓦塀に春を発見した福助人形の影法師孤児の下駄が置き忘れてありました公園の入口ペンキのはげた立札心よ！",
              "citation": {
                "source": "（風船玉の衝突）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤き煉瓦の長壘、夢の如くに遠く連なり、地平に落日の影を曳きたり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "我れ少年の日は、常に麥笛を鳴らして此所を過ぎ、長き煉瓦の塀を※りて、果なき憂愁にさびしみしが、崖を下りて河原に立てば、冬枯れの木立の中に、悲しき懲役の人人、看守に引かれて石を運び、利根川の淺き川瀬を速くせり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "王宮と河一つ隔てた広場に面した四角な煉瓦造りの建物で、これは有名なシンケルの建てた特色のある様式の建築として聞こえたものだそうである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一に根気二に根気で集輯した素材を煉瓦のように積んで行くのである。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "県庁の入口に立っている煉瓦と石を積んだ門柱四本のうち中央の二本の頭が折れて落ち砕けている。",
              "citation": {
                "source": "静岡地震被害見学記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドイツの町を歩いていたとき、空洞煉瓦一枚張りの壁で囲まれた大きな家が建てられているのを見て、こんな家が日本にあったらどうだろうと云って友人等と話したことがあった。",
              "citation": {
                "source": "颱風雑俎",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "根津を抜けて帰るつもりであったが頻繁に襲って来る余震で煉瓦壁の頽れかかったのがあらたに倒れたりするのを見て低湿地の街路は危険だと思ったから谷中三崎町から団子坂へ向かった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣の家の前の煉瓦塀はすっかり道路へ崩れ落ち、隣と宅の境の石垣も全部、これは宅の方へ倒れている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "土蔵もみんな焼け、所々煉瓦塀の残骸が交じっている。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この室と煉瓦壁を隔てた一室が寝室であって、この隔壁に穴をあけて音響学実験の際に便利なようにした。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は高い、暑い煉瓦塀にそうて重苦しさうに歩いてゐた。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだそれが其處にあるかどうかを確めるためのやうに、ときどきその煉瓦塀を手搜りしながら。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "カバレット・バビロンの白煉瓦の高層な建物から流れるワルツの曲が街角に直立した赤い帽子の印度巡査をモスモロスの道化役者風にしたててバビロンの入口の廻転ドアの前に金モールのいかめしい英国人の門衛が莞爾とした笑いをたたえている。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "高い煉瓦塀にせばめられた暗い路次を通り拔けて、Ｋ街の大通へ出ると、街燈の鈍い光の中に客待ちしてゐた五六人の支那人の俥引達がばらばらと二人の側へたかつて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかり葉をふるひ落した裸のポプラ並木、からからに凍りついた歩道、明りを消し、二重窓を降して冷たい沈默を包んでゐる煉瓦や石造りの暗い家並、毎日毎夜の不安な空氣に脅かされてゐる町は、朝から曇つたままに暮れ落ちた暗澹たる夜空の下に、わけても眞夜中過ぎのその夜は、人通さへ稀に無氣味な程に鎭まり返つてゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "商店の倉庫らしい建物の立ち並んだ、高い、じめじめした煉瓦塀の兩側から迫つた、二三間幅の道。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、振り向かうともせずに、何か知らむつと塵芥くさい臭ひのする、右左に煉瓦塀のすれすれになるやうな道をせかせかと歩き續けて行くのだつた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな赤煉瓦の建物が岬に續く高い丘の斜面に見えた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "廣い緑の牧場と、靄にかすんだ海峽の水と、黄ばんだポプラの林と、赤煉瓦の清楚な修道院の建物と――それ等が秋らしい靜かな色の調和を作つて快く私の瞳に沁み渡つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとう前の木造の修道院は燒けてしまひましたつけ……今の煉瓦造りになつてから、十年餘りですよ。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、ある丘の、もと露西亜軍の兵営だった、煉瓦造りを占領して、掃除をし、板仕切で部屋を細かく分って手術台を据えつけたり、薬品を運びこんだりして、表へは、陸軍病院の板札をかけた。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い煉瓦の三階建だった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等の周囲にあるものは、はてしない雪の曠野と、四角ばった煉瓦の兵営と、撃ち合いばかりだ。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "料理場の跡らしい煉瓦の竈の崩れたのもそのままになっていた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "裁判所だか海軍省だかの煉瓦を背景にした、まだ短夜の眠りのさめ切らぬような柳の梢に強い画趣の誘惑を感じたので、よほど思い切って画架を立てようかと思っていると、もうそこらを歩いている人が意地悪く此方へ足を向け始めるような気がする。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "八　道路の真中に煉瓦の欠けらが転がっていた。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ重い荷物を積んだ自動荷車が来かかって、その一つの車輪をこの煉瓦に乗り上げた。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "煉瓦はちょうど落雁か何かで出来てでもいるようにぼろぼろに砕けてしまった。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この瞬間に、私の頭の中には「煉瓦が砕けるだろうか、砕けないだろうか」という疑問と「砕けるだろう」という答とが、ほとんど同時に電光のように閃いた。",
              "citation": {
                "source": "鑢屑",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
