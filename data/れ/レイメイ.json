  {
    "uuid": "1fcf5b27-98fc-5900-84a5-7462bb60e651",
    "entry": "霊名",
    "reading": {
      "primary": "れいめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "Christian name",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「又分家」の先霊名録には寿山院が寿山室に作つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "只先霊名録の蘭軒庶子｜女の下に母佐藤氏と註してあるだけである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録には快楽院が快楽室に作つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録に「知遊童女、隆升軒末女安佐、安永八年己亥十一月」として十日の条に載せてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録に第二女として智貌童子の戒名が書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録に「寂照軒勇機鉄心居士、（中略）墓在西窪青竜寺」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録に従へば、伊勢国薦野の人黒沢退蔵の子であつた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録二日の下に、「馨烈童子、芳桜軒妾腹之男也、名良吉、母佐藤氏、墓在本郷栄福寺、文化十五年戊寅正月」と記してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録には実を伝へてかう云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録に覚心禅童女の法諡が載せてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは先づ先霊名録に拠つて蘭軒の妻｜益の姉の死を記せなくてはならない。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "先霊名録に「究竟室妙等大姉、葬于谷中正運寺」と云つてある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮き世で呼ばれていた姓名も捨てて、テレジアとか、カタリナとか、コレタとかの霊名しか持っていない。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "へりくだり　誠一の霊名はヤコボ喜左衛門だね。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "中にはただ霊名だけわかって俗名のわからぬ者さえある。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "誠一が生まれた七日目、洗礼を受けるとき、お父さんは多くの聖人のうちからこの聖ヤコボ喜左衛門を選んで、霊名の聖人になっていただいた。",
              "citation": {
                "source": "この子を残して",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
