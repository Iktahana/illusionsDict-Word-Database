[
  {
    "uuid": "9237a34f-baf9-5d17-a1e4-956de0a32a09",
    "entry": "令名",
    "reading": {
      "primary": "れいめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
