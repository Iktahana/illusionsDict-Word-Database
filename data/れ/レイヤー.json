    "definitions": [
      {
        "index": 1,
        "gloss": "layer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冬にはゲートボール場になっている向かいの広場が見渡せていたのが、葉が育ち、小さな実がなり始めると、ボールを叩く高い音は聞こえても朝起き鳥の元気なプレイヤーの姿は見えなくなった。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "製品の第一段としては、一九九三年半ばをめどにしてＣＤ―ＲＯＭを備えたプレイヤーの開発を進めるという。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが企業の論理としてはわかっても、情報家電の全面展開を打ち出したジョン・スカリーの胸のうち、彼がどのような機器を作りたいと思っているのかは、さまざまな日本企業との提携関係の中でビジネス手帳風、ＣＤ―ＲＯＭプレイヤー風とさまざまな商品イメージが打ち出されるに連れてどうもわからなくなってきた。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした形にもっていけば、ブックマン用に開発されたタイトルは、ＣＤ―ＲＯＭ　ＸＡのプレイヤーを繋いだＰＣでも利用できるというわけだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬のあいだはゲートボール場になっている向かいの広場が見渡せていたのが、葉が育ち、小さな実がなり始めると、ボールを叩く高い音は聞こえても朝起き鳥の元気なプレイヤーの姿は見えなくなった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポータブルのプレイヤーが放り出してある。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "片桐が慶一に「形見」として遺した、このＡＭラジオつきポータブル・プレイヤーも、うっかりすると蹴飛ばしそうになる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "片桐なんて人間がこの寮にいた証拠は、このプレイヤーだけだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "弦や管のプレイヤーまでいる、ごちゃごちゃしたスタジオに、ミック・ジャガーが坐っていた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一はプレイヤーのストップボタンを押した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐに気配を察して、プレイヤーは手をとめ、戸口を見た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "四階にたどりついた慶一は、そこに壊れたアナログ・プレイヤーを見た。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさいには、それは人間のすがたをしていたが、慶一の目には、ベルトの切れたプレイヤーにしか見えなかった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「生き残れば、すべてが消えるのを見ることになる」　高志は、プレイヤーのスタート・ボタンを押し、目的の曲にもっていき、バックワードをかけ、マイナス一秒でポーズ・ボタンを押した。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "マンハッタンでサッポロラーメン屋がつぶれたって、だれも気づきもしませんよ」　ワラが、もうひとつのプレイヤーをスタートし、おなじ手順で、ゲートに入った馬のように、いまにも走りだしそうなディスクの手綱を握った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ニューヨークでコマーシャル写真のカメラマンをしていたマイケル・シュレイヤーは、広告業界の猛烈主義と欺瞞に嫌気がさして、一九七〇年代の半ばにこの世界から足を洗った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この集まりでシュレイヤーは、プログラムを書く際に入力や訂正作業に使えるユーティリティーを集めたものをもらった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "プログラムは自分で書くのが当然の当時のホビイストにとって、このソフトウエアは便利な小道具だったが、シュレイヤーは自分ならもっとましなものが書けると考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "実際にシュレイヤーが書いてみたユーティリティーはホビイストの人気を集め、彼はソフトウエアの会社を起こしてそのプログラムを売った。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイプライターを使ってマニュアルを打ちなおす作業に飽き飽きしたシュレイヤーは、文書が作成できて手直しがきき、プリンターから打ち出せるようにするためのプログラムを書こうと考えた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九七六年の十二月、シュレイヤーはアルテア用にワードプロセッサーのプログラムを書き上げ、これをエレクトリックペンシルと名付けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "厄介な仕事を手短にすませるために書いたエレクトリックペンシルだったが、このソフトウエアがシュレイヤーにもっとたくさんの仕事を運んできた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホビイストの集会でシュレイヤーが自分の書いたワードプロセッサーを誇らしげに紹介すると、エレクトリックペンシルは大評判を呼んだ。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまけに今度は、つながっているプリンターに合わせる必要もあったために、シュレイヤーは手直しに追いまくられた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "事業家としてのし上がっていくことに興味を持てなかったシュレイヤーは、作業を代わりにやってくれるプログラマーを見つけてきて、自分はこの大騒ぎからさっぱりと身を引いた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＣＰ／Ｍ上で使うことを前提として書かれたワードスターに関しては、マイクロプロはシュレイヤーの悩まされた機種ごとの手直し作業に追われることはなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "シュレイヤーが手直しの作業に忙殺されたように、それぞれのハードウエアはそれぞれの特徴を持っていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポングと名付けられた次のゲームは、ディスプレイをはさんで向き合った二人のプレイヤーが玉を打ち合う、電子式の卓球だった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一八六二年六月、英国のバークンヘッドのレイヤード造船所で建造中のアラバマ号は完成にちかづいており、それが軍艦であることも明白になったので、米国公使アダムスは英外相ラッセル伯にたいして、アラバマ号の用途を公文書をもって指摘し、建艦の中止を要求した。",
              "citation": {
                "source": "黒田清隆の方針",
                "author": "服部之総",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
