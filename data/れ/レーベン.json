        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わたしがもし自分のゲシュレヒツ・レーベンを書いて見たら恐らく相手の異性の数は当時の地方のその点放埒にされている青年よりずっと少ないかも知れない。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この次にはケナンの著シビリーン三冊（シベリア紀行）と、ルシツシェ・ゲフェングニツセと、およびツェルトレーベン・イン・シビリーンとの三冊を合本にて送ってくれ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺の楽天主義には科学的なレーベンスワイスハイト（「哲学」）がある。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はしみじみとミットレーベンということを感じゴッホのコラボレーションを思います。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえば愛は真理であることをエルレーベンして、そしていかにして愛に程度を付することができましょう。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、正夫さんが私のそばにいてくれるあいだ、私たちのミットレーベンをお守り下さいませと祈りました。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "通行の人も車も殆んどなく、アイスレーベンの手前で、後にスカーフをかぶつた女を乘せた自動車が矢の如く擦れちがつたくらゐなものだつた。",
              "citation": {
                "source": "キフホイザー",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "アイスレーベンの町を通り拔けながら、そこがマルティン・ルッターの生地だといふことを私は知らなかつた。",
              "citation": {
                "source": "キフホイザー",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんな振り返つて見たけれども、その時はもうそんなものは皆アイスレーベンの町と共に雨｜飛沫の中に消え去つてゐた。",
              "citation": {
                "source": "キフホイザー",
                "author": "野上豐一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく主張し得る道徳的根拠をエアレーベンしたるものを生の信者と呼ぶならば、私は生の信者として生きたい。",
              "citation": {
                "source": "愛と認識との出発",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのとき自分のたましいのウンタートーンとして青春のかがやかなほほえみと元気のあるレーベンスグラウベとが心にひろがってきた。",
              "citation": {
                "source": "涸沢の岩小屋のある夜のこと",
                "author": "大島亮吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の運命なるものが、もし観相学の対象であることに満足出来るならば、レーベンは「レーベンの哲学」の対象であることに満足も出来よう。",
              "citation": {
                "source": "思想としての文学",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまはこの男を大目に見よう、ちょうどマックワース神父がチャールズ・レーベンシューを助けたように。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私たち英国人はゲフェングニスレーベン――監獄生活と言っておりましたよ！",
              "citation": {
                "source": "秘密礼拜式",
                "author": "アルジャナン・ブラックウッド",
                "note": "青空文庫"
              }
            },
            {
              "text": "臨床家オポルツァー、22版を重ねた解剖学の教科書の著者ヒルトル、生理学者ブリュッケ、神経学者テュルクおよびウィーンの医学部長フォイヒテルスレーベンを挙げることにしょう。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            },
            {
              "text": "フォイヒテルスレーベンは43歳で死亡したが、政治家、詩人、哲学者および医師として有名であった。",
              "citation": {
                "source": "偉大な医師たち",
                "author": "伝記による医学史",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
