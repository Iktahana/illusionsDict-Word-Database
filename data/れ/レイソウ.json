[
  {
    "uuid": "4424f473-ac98-5c46-8797-a3e1aea0b38f",
    "entry": "礼装",
    "reading": {
      "primary": "れいそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "formal dress",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "いつでもちゃんとした礼装をして、頭髪を綺麗に分けて、顔を剃り立てて、どこの国の一流のレストランのボーイにもひけを取らないだけの身嗜みをしていた。",
              "citation": {
                "source": "雑記（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はいつのまにか紋付き袴の礼装をしている。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが自分の和服礼装に変相し、婚礼が法事に翻訳されたのかもしれない。",
              "citation": {
                "source": "三斜晶系",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかく、式の始まるまでは、まだ一時間もありましたけれども、斯うにぎやかにやられては、とてもじっとして居られません、私たちは、大急ぎで二階に帰って、礼装をしたのです。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "教会へ行く途中、あっちの小路からも、こっちの広場からも、三人四人ずついろいろな礼装をした人たちに、私たちは会いました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが祭壇の下オーケストラバンドの右側に、「異教徒席」「異派席」という二つの陶製の標札が出て、どちらにも二十人ばかりの礼装をした人たちが座って居りました。",
              "citation": {
                "source": "ビジテリアン大祭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "花嫁は裾模様の長い着物を着て、金襴の帯を背負ひ、角隠しつけて、堂々正式の礼装であつた。",
              "citation": {
                "source": "富嶽百景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには本郷座的に礼装した一群が卓を囲んでゐた。",
              "citation": {
                "source": "市街を散歩する人の心持",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "製本成るや、弟は礼装に身を正し、その一本を携へて、四海民蔵君を訪ひ、此の集に対する曾ての厚意を涙して感謝したものである。",
              "citation": {
                "source": "文庫版『雀の卵』覚書",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "監　　督　能を見ると、前述の舞い手、謡い手、囃方のほかに、謡い手と同じ礼装をした人間が一人もしくは二人、舞台の後方に座っている。",
              "citation": {
                "source": "能とは何か",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時はそれが公使館の館員ででもあるかと思うような、礼装をしてみごとな馬車に乗った紳士である事もあり、ある時はズボンの折り目もつけないほどだらしのないふうをした人相のよくない男でもあった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "礼装の群集がぎっしり詰まって動き廻っている。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人達もすべて明治の礼装だ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大礼装の紳士と淑女。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちも礼装して自動車を乗りつける。",
              "citation": {
                "source": "踊る地平線",
                "author": "テムズに聴く",
                "note": "青空文庫"
              }
            },
            {
              "text": "私と彼女は、理髪師のようなつめたいにおいを発散させながら礼装の肩を較べた。",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのいずれにも礼装の人々が充満して、このモンテ・カアロの博奕場を経営している「海水浴協会」――何と遠くから持って来た名であろう！",
              "citation": {
                "source": "踊る地平線",
                "author": "Mrs. 7 and Mr. 23",
                "note": "青空文庫"
              }
            },
            {
              "text": "母の臨終の床でも私はあまり泣かなかったし、それからいろいろの儀式のうちに礼装をした父が白いハンカチーフをとり出して洟をかむときも、並んで坐っている私はその父の姿を渾心の力で支えるような気持で矢張りあまり泣けなかった。",
              "citation": {
                "source": "母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "母のとき、私は何よりも父を落胆させまいとして、始終気を張り、心臓に氷嚢を当てながらも喪の礼装を解かずにがんばり通した。",
              "citation": {
                "source": "わが父",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "※　其麼工合故、礼装がなくて、儀式のときは和服をきました。",
              "citation": {
                "source": "洋服と和服",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "家族の晩餐のためにも礼装に着かえる某々卿にとって、ノックされるのが何より厭な暗い性のドアを、ローレンスはフランネル・シャツを着ている男にノックさせた。",
              "citation": {
                "source": "傷だらけの足",
                "author": "――ふたたび純潔について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は礼装して式場に並ぶのが大好きだった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "神輿の御座船は一｜際美しい屋形船で、旗｜幟や、玉｜串などの立ち並ぶ下に、礼装した神官たちがいずまい正し、伶人が楽を奏でるなかに、私の鈴子は美しい巫女の装いして、今宵は化粧も濃く匂うばかりに立ちまじっているのであった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "地方の軍隊は送迎がなかなか手厚いことを知っていたから、石田はその頃の通常礼装というのをして、勲章を佩びていた。",
              "citation": {
                "source": "鶏",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "花婿は礼装で身を飾っていたが、地に仆れている花嫁を抱いた。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "劇場から帰ってきて見ると死者の髯は綺麗に剃られ、顔も美しく化粧され、髪も香水がつけて梳ずられてあり、新しい礼装をさせられて花輪を胸に載せ、柩の中に横たわらせられてあった。",
              "citation": {
                "source": "マダム貞奴",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのあとから白襟の礼装のまま化粧だけ直した志村のぶ子が、近眼鏡をかけ直しながら、おずおずと這入って来たが、流石に云い知れぬ喜びと、初めて私の前に出て来る気味悪さとに包まれているらしく、心持ち顔色を青くしながら、縮れ毛を染めた束髪の頭を下げた。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣冠をつけた正式の礼装であった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "開拓使長官の使いを受けてその邸に参候するとこの礼装が用意されてあった。",
              "citation": {
                "source": "石狩川",
                "author": "本庄陸男",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はわざと宿で車を頼んでもらわずに、煉瓦通りに出てからきれいそうな辻待ちを傭ってそれに乗った。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
