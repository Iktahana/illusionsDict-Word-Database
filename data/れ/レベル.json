    "definitions": [
      {
        "index": 1,
        "gloss": "level",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あれは散々今の新しさが使用し尽された後のレベルから今｜一だん洗練を経た後に生れた女です。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを、何を好んで、俺等が、奴等と同じレベルにまでなりさがって働くって法があるかい！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私ごとき才能のない人間が今日作家として立って行けるのは、文壇のレベルが低いからだ。",
              "citation": {
                "source": "私の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "常識のレベルにさえ達していなかった。",
              "citation": {
                "source": "苦悩の年鑑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "テープの磨耗によって画質が劣化するビデオではなく、デジタルで記録した高いレベルの画像を長く保てるレーザーディスクこそ、映画をおさめる標準の器にふさわしいという主張が一点。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも、記念碑的なマシンやソフトウエアを動かしてもらって撮った映像が確かに映っているのが確認できると（レベルが低い！",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "キーボードなしでは、山や川のレベルまでならさすがに何なくこなせるが、十画を越えるあたりから警戒警報が鳴り始め、十五画を越えた漢字は霞の彼方にうすぼんやり浮かぶ、筆先の悲しみといったていたらくにあいなってしまったのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "パームトップでは一時間もやっていれば、十分で百字程度は入力できるようになり、かなりなれた段階で三、四級レベルにいって、そこが上限となる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一品生産的なハードの作り方はここでも変わっていなかったし、価格も技術屋連中が「どうやって上司をだまそうか」と頭を捻るレベルだった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "余談になるが（まだ本論に入っちゃいないか）、香川の高校生が四十人がかりでＸ６８０００狙いのウイルスを作ったと報じた一件を始め、『朝日新聞』のパーソナルコンピューター関連記事は実に、祭りに出張ってくる見せ物小屋のレベルで楽しませてくれる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがマニュアルを読むことに遺伝子レベルで禁則をかけられたこのスカートを履いたゴリラでも、マッキントッシュのアプリケーションは複数種類を日常的に自力でどうやら使いこなしている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ウイルスが果たして蛋白質製であるか、はたまたコードであるかといった生易しいレベルではない。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたレベルにこの分野の先駆けとなったマッキントッシュが到達する前に、もともと高機能のハードにおさまっているＵＮＩＸの側がソフトウエアで追い上げをかけて、ＤＴＰをさらってしまうシナリオは描けたろう。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "今再びぶり返しつつある漢字の多用の問題には、我々に先立つ世代の取り組みによって国家レベルでは常用漢字という枠が設けられている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "イタリックに至っては、かろうじて読めると言ったレベルだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "（漢字ＲＯＭをくっつけるというキヤノン販売の試みもあったけどね）　アップルコンピュータジャパンがＯＳレベルで日本語処理を実現した漢字Ｔａｌｋを発表するのは、エーアンドエーのＪＡＭやエルゴソフトのイージーワードが日本語への突破口を開いた後の、一九八六年夏のことだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "この学問の勃興期を支えた当のご本人に「終わった」と言われても、遺伝子レベルでの生命の探求や操作は事実成果を上げ始めている。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがこれ以降、分子生物学は生命の核に潜む仕組みを暴く代わりに、いったんは切り捨てたはずの知識の収拾に、分子レベルまで降りて舞い戻った。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後より一段突っ込んだレベルで、新しい謎が浮かび上がった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで今、これまでの成果を元に分子レベルでの生命へのアプローチが進んでいる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「分子機械は理解できる」と思ったが、二十世紀後半の我々はそのレベルに至っていなかった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただＯＳレベルでハイパーテキストをサポートした実身／化身モデル（マッキントッシュをお使いの方はハイパーカードのファイル構造をＯＳで提供することをご想像下され）というＢＴＲＯＮの売り物は、とにもかくにもこのマシンで味わえるのだ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "タイトルの提供者は、ＭＳ―ＤＯＳのレベルで自分流の参照と検索のための環境を用意することもできる。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで出てきたのが、一段上のＲＩＳＣ（吉野家）レベルでのＩＢＭ。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこまでやってはじめて、詰め組みはデザイナー諸氏の器用仕事のレベルをこえることができる。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "紙と活字の本が、映像としての本、仮想現実としての本に「まるごと」とってかわられるためには、モノのかたちやしくみだけではなく、人間の生活習慣、本とのつきあい方が、完全に、それこそ細胞レベルで変わっていなければならない。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "低い心のレベルで、二つのうらはらな心の動きを眺めてゐるうちに、動けば動く程消極的に縮んで行く玩具のコマになるより他に術がない気がした。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "犯人の頭脳のレベルは決して高いものではないね。",
              "citation": {
                "source": "カンカン虫殺人事件",
                "author": "大阪圭吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "延子の心はほんとうに正当で純なのだ、俺だけが悪いのだ、俺は自分勝手に低いレベルで極めて下賤な誰も見て呉れない独り芝居を打つて勝手に焦れてゐるのだ。",
              "citation": {
                "source": "坂道の孤独参昧",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、私は、ポーの作品を、今日のレベルから見て、そんなに優れているとは思いません。",
              "citation": {
                "source": "愛読作家についての断片",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
