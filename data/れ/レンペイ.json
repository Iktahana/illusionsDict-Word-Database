        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兵隊はいやなものでも、将校と云うものはいいものだろうと思っていたが、いつか練兵場で練兵するのを見ていたら、若い将校が一人の兵隊をつかまえて、何か声高に罵しっていた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原は今は練兵場や粟の畑や苗圃などになってそれでも騎兵の馬が光ったり、白いシャツの人が働いたり、汽車で通ってもなかなか奇麗ですけれども、前はまだまだ立派でした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　寺林というのは今は練兵場の北のはじになっていますが野原の中でいちばん奇麗な所でした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線電信――六〇六――石碑――W.C　――じゃ、間違いっこなし、明朝、練兵場よ。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "午前八時岡山練兵場出発――Ｆ飛行士は、彼は昔、自転車周回競争の選手だった。",
              "citation": {
                "source": "飛行機から墜ちるまで",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "呼出されるのを待つため、練兵場に並んだ時、送って来た者は入営する者の傍に来ることが出来ないので親爺と別れた。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二年兵の食器洗い、練兵、被服の修理、学科、等々、あとからあとへいろ／＼なことが追っかけて来るのでうんざりする。",
              "citation": {
                "source": "入営前後",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二度とも一週間の練兵休で、すぐまた、勤務につかせられたよ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "練兵場から、古いお城の麓の柴山の中にまで、五町ほど、鶩を追って、追いこんでしまった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから人力にゆられて夜ふけの日比谷御門をぬけ、暗いさびしい寒い練兵場わきの濠端を抜けて中六番町の住み家へ帰って行った。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の練兵場時代、鳥人スミスが宙返り飛行をやって見せたころにはきわめて顕著な孤立した存在であったこの木が、今ではちょっとどこにあるか見当がつかなくなっている。",
              "citation": {
                "source": "藤棚の陰から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（四十九聯隊の練兵場を横断して、まっすぐに行くと、もっと早い。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "早朝、練兵場の草原を踏みわけて行くと、草の香も新鮮で、朝露が足をぬらして冷や冷やして、心が豁然とひらけ、ひとりで笑い出したくなるくらいである、という家内の話であった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "練兵場の草原を踏みわけて歩いてみても、ひとりで笑い出したくなるようなことは無かった。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食の少しまえに、私はすぐ近くの四十九聯隊の練兵場へ散歩に出て、二、三の犬が私のあとについてきて、いまにも踵をがぶりとやられはせぬかと生きた気もせず、けれども毎度のことであり、観念して無心平生を装い、ぱっと脱兎のごとく逃げたい衝動を懸命に抑え、抑え、ぶらりぶらり歩いた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "練兵場をぐるりと一廻りして、私はやはり犬に慕われながら帰途についた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "もともと、この犬は練兵場の隅に捨てられてあったものにちがいない。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は、練兵場へいそいだ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "強いぞ」ほめてやって私は歩きだし、橋をかたかた渡って、ここはもう練兵場である。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしポチは、この練兵場に捨てられた。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからいま、また、この練兵場へ帰ってきたのだ。",
              "citation": {
                "source": "畜犬談",
                "author": "―伊馬鵜平君に与える―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　寺林といふのは今は練兵場の北のはじになってゐますが野原の中でいちばん奇麗な所でした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "うしろは五十万坪と称うる練兵場。",
              "citation": {
                "source": "伯爵の釵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八人の額に秋の寒さかな　その帰途、人々と共に代々木の練兵場をゆきぬけて、浄水所の堤に出づ。",
              "citation": {
                "source": "叔父と甥と",
                "author": "――甲字楼日記の一節――",
                "note": "青空文庫"
              }
            },
            {
              "text": "東練兵場へ出かけて模擬戦を観る、鉄条網、毒瓦斯、煙幕、タンク、機関銃、……労れて、少し憂欝になつて戻る。",
              "citation": {
                "source": "行乞記",
                "author": "広島・尾道",
                "note": "青空文庫"
              }
            },
            {
              "text": "かうなると、今まで少し沈んでゐた一座の空氣の中に、或る上つ調子な氣持が漂つて來て、四人の眼は意地惡く、Ｓ中尉の練兵燒けのした淺黒い顏にそそがれ始めました。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの狭い練兵場で、毎日、毎日、朝から晩まで、立てとか、すわれとか、百メートルとか、千メートルとか、云うて、戦争の真似をしとるんかと思うと、おかしうもなるし、あほらしうもなるし、丸で子供のままごとや。",
              "citation": {
                "source": "戦話",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
