  {
    "uuid": "24ef61bf-c8e9-5acc-94ff-1ad666661ff7",
    "entry": "漣々",
    "reading": {
      "primary": "れんれん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "flowing endlessly (of tears)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」　女の目よりは漣々と零れぬ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二　同時に、湖面の一点に、ざんぶと音がして、そのあたり一面に水煙が立ったかと見ると、漣々として、そこに波紋が、韓紅になってゆく異様の現象が起りました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "胆吹の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣血｜漣々として、思う所を竭す能わざるなり。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かんかんのう、きうのれす、きうはきうれんれん、にいくわんさん、いんぴんたいたい、しいくわんさん……。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "宙に浮く屍骸",
                "note": "青空文庫"
              }
            },
            {
              "text": "扇、船、水鳥などの形をした虫籠に緋色の総をさげてりんりんれんれん松虫や鈴虫を鳴かせてゐる。",
              "citation": {
                "source": "銀の匙",
                "author": "中勘助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
    "relations": {
