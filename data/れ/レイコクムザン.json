    "definitions": [
      {
        "index": 1,
        "gloss": "cruel and heartless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "冷酷無残の手紙を書いて出しました。",
              "citation": {
                "source": "未帰還の友に",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の本性というものは或いはもともと冷酷無残のものなのかも知れません。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな冷酷無残な話があるかしら。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "……死んだ父親の罪悪を、白昼公然と発き立てている、冷酷無残な精神病者であったのか……。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、仮令ば家族の中に、一人冷酷無残な人物があったとしよう。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、シローテの説く切支丹宗門の本義に関してのみは、白石の批判は冷酷無残で、博聞強記多学多識企て及ぶべしとも思はれぬこの人が、ひとたびその教法を説くに至つては一言の道理にちかいものもなく、智愚たちまちに地を変へて、さながら二人の言を聞くやうであつた、と述べてゐる。",
              "citation": {
                "source": "イノチガケ",
                "author": "――ヨワン・シローテの殉教――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一途の愛情の走るにまかせて全幅の信頼を傾けるには、あまりにも冷酷無残な卓一の心であつた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷酷無残な人情と、仮借なき法の運用に対する反抗は、昔から小説のよき題材ではあるが、わけてもヴィクトル・ユーゴーの『レ・ミゼラブル』は代表的で、法の冷たい執拗さの影に、人間の果敢なさ弱さを強調したものである。",
              "citation": {
                "source": "随筆銭形平次",
                "author": "捕物小説というもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ぜいたくをいうな」　八五郎は精一杯冷酷無残な顔をして、奥歯を噛みしめながら、キリキリと縄尻を締めるのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "怪盗系図",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　警官の問に答えて、「花房一郎といいます」「あッ」　これが、――この冷酷無残の無頼漢が、――名探偵花房一郎とは思いもよりません、さすがの警官も驚きましたが、鳴海司郎の驚きは又一倍です。",
              "citation": {
                "source": "悪人の娘",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、月の出が遅くなって、宵闇が濃くなると、冷酷無残な辻斬がまたも活動を始めたのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "辻斬",
                "note": "青空文庫"
              }
            },
            {
              "text": "町奉行自身、江戸の街を見廻るというのは、何年にも無い珍らしい事ですが、御改革の徹底を、面目にかけて期して居た鳥居甲斐守は、時には微行で、時には大びらに、江戸の町々を巡って、その冷酷無残な眼を光らせたのでした。",
              "citation": {
                "source": "礫心中",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "笠森仙太郎は幸運を掴むためには、他人の迷惑などは物の数とも思わなかったのですが、丹波丹六は一歩進んで、自分の地位を築き上げるためには他人を陥入れる位のことは、まことに――尾籠な譬で恐縮ですが、――屁とも思わないといった、冷酷無残な性格の持主でした。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷酷無残といわれながら、一代に積んだ巨億の富は、日本の政治界も実業界も、いや精神界をさえも支配するかに見えました。",
              "citation": {
                "source": "奇談クラブ〔戦後版〕",
                "author": "運命の釦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
