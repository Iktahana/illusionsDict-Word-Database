          "literary": [
            {
              "text": "一年後ぼくはレギュラーになり、二年後、第十回オリンピック選手としてアメリカに行きました。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "レギュラーになりたい奴らだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "レギュラーとしてそのバンドで人気をとり、スタジオの録音にも参加し、腕をあげると同時に、ファンをつかむ。",
              "citation": {
                "source": "エルヴィスから始まった",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＢＢＣは現代文学趣味のつまらぬレギュラー番組を流しているものの、目下のところ、詩を放送するための五分間を獲得する方が、嘘八百のプロパガンダ、ブリキ缶入り音楽、陳腐なジョーク、サクラによる「討論」、その他諸々を撒き散らすための十二時間を獲得するより困難なのだ。",
              "citation": {
                "source": "詩とマイクロホン",
                "author": "ジョージ・オーウェル　George Orwell",
                "note": "青空文庫"
              }
            }
          ]
        }
