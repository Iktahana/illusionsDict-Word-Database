[
  {
    "uuid": "2b062b0a-09e8-51a7-8f52-d2c6ceaf40ae",
    "entry": "零下",
    "reading": {
      "primary": "れいか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "名詞-の形容詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "below zero",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "黄いろの帆布一枚ぢやどうしてどうして零下の四十度を防ぐもなにもできやしない。",
              "citation": {
                "source": "氷河鼠の毛皮",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は一｜月末、雪と氷に埋もれて、川さへ大方姿を隠した北海道を西から東に横断して、着て見ると、華氏零下二十―三十度といふ空気も凍たやうな朝が毎日続いた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "時は一月末、雪と氷に埋もれて、川さえおおかた姿を隠した北海道を西から東に横断して、着てみると、華氏零下二十―三十度という空気も凍たような朝が毎日続いた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "その下には地球が刻々に零下二百七十四度に向って冷て行きつつあります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちがっかりして、零下何度のごきげんになってしまいました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべては零下何度の空気に包まれて、シンカンと寝静まっていた。",
              "citation": {
                "source": "復讐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等はそれから嶮岨な山道を越えたり、追剥や猛獣の住む荒野原を横切ったり、零下何度の高原沙漠を、案内者の目見当一ツで渡ったりして、やがて崑崙山脈の奥の秘密境に在る、遊神湖という湖の近くに到着するのです。",
              "citation": {
                "source": "狂人は笑う",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "火星の寒いところは零下四十｜度から零下七十｜度の寒さだ。",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなところたたいてもだめだわ　そこの扉をあけるんだわコオロギと蛙○やあ助かつたお父さん　ピチクンがこんなになつちまつたこりや失敗　しかし実験室はまだ零下四十度そこそこなんだよ早く温めてやらなければ……○なに大｜丈夫だよ　ほら目をあけたおや？",
              "citation": {
                "source": "小熊秀雄全集−22",
                "author": "火星探検―漫画台本",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜明けに近く、冷えるにいいだけ冷えきつた、零下二十度の空氣だつた。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者の法則によれば、外からの輻射を全く反射せずまた通過させない物体が自分自身で輻射する熱量はその物体の絶対温度（すなわち、摂氏零下二七三度を基点として数えた温度）の四乗に比例する。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし今日では、この凝縮は零下二〇〇度以上では起り得ないことが知られている。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにはたとえば、摂氏零下二七三度から数えた温度の対数を取って、これを温度の示度とすればそれだけでもよいのである。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "一例としてここに一グラムの氷の温度を零下一〇度から次第に高めてゆく場合にいかなる過程をとるかを考えてみる。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "この実験は零度以上の温度で行われたのであるが、パウルとプラルの方の実験の一部は液体空気の沸騰点（零下一九五度）で行われた。",
              "citation": {
                "source": "宇宙の始まり",
                "author": "スワンテ・アウグスト・アーレニウス　Svante August Arrhenius",
                "note": "青空文庫"
              }
            },
            {
              "text": "逆に温度を下げて零下二百七十三度という絶対温度にすると、万物ことごとく活動は止まってしまう。",
              "citation": {
                "source": "最終戦争論",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "『列氏零下五度、こまかい雪が降っていましてね、猛烈に寒い朝でしたよ。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "もうそちらは寒いでしょうね、零下何度ぐらいになりますか？",
              "citation": {
                "source": "二人の弟たちへのたより",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ今夜は零下五度の春の雨が盛にふってる。",
              "citation": {
                "source": "三月八日は女の日だ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪をよごして零下十二度の夜焚火をする樅の木売りも、モスクワの目抜きの広場からは姿を消した。",
              "citation": {
                "source": "モスクワの姿",
                "author": "――あちらのクリスマス――",
                "note": "青空文庫"
              }
            },
            {
              "text": "風呂場で、妙なセキが出るのね、と云ったとき、　菌のこと、自分にうつって居るかもしれぬ事　十八九日　朝零下のこと多し○七日　寺沢一時半に来る由、　冷静になろうとし、自分、机の前に来る。",
              "citation": {
                "source": "「伸子」創作メモ（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯たんぽ　八日　零下。",
              "citation": {
                "source": "「伸子」創作メモ（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰かが七歳と四歳になる二人の女の児を雪の深い森へ連れ込み零下十何度という厳寒の中へ裸にして捨てて行った。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "零下十五度のモスク※で牝鶏は卵を生まない。",
              "citation": {
                "source": "一九二九年一月――二月",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥穂頂上で零下二度。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気温はこの山行で十一月三十日夜常念の小屋で零度（降雪中）翌十二月一日大天井岳頂上で零下五度（晴、強風）であった。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "雄山の頂上で午前十一時だったのに零下二十一度にも下った。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはすでに十一時頃で気温も零下七度まで下っていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "室内温度は零下十二度くらいだったのに非常に寒く感じた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "されどわれいかでこの翁を忘れえんや。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
