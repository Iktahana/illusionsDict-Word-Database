        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔われかのひとをこととふに〕宮沢賢治われかのひとをこととふになにのけげんもあらざるをなにゆゑかのとき協はざるクラリオネットの玲瓏をわらひ軋らせわらひしや",
              "citation": {
                "source": "〔われかのひとをこととふに〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "霊山の雲霧のごとく立昇る湯気の中に、玲瓏玉を溶かせるごとき霊泉の中に紅白の蓮華が一時に咲き満ちたような感じがしたのであった。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた日は全山を玲瓏と人の眼に突付けて、瑕もあらば、看よ、看よと、いってるような度胸のよい山の姿である。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸に君達の生命も玲瓏乎としてゐる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもあれ春のをとめら、　　なべて且つ耐へほゝゑみて、水銀の目盛を数へ、　　　　　玲瓏の氷を割きぬ。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四｜面玲瓏、峯秀で溪幽に、亦と類なき奇石であつたので、雲飛先生涙の出るほど嬉しがり、早速家に持ち歸つて、紫檀の臺を造え之を安置した。",
              "citation": {
                "source": "石清虚",
                "author": "國木田獨歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい、近ごろにアインシュタインが突然第二の扉を蹴開いてそこに玲瓏たる幾何学的宇宙の宮殿を発見した。",
              "citation": {
                "source": "案内者",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "骨の中の髄漿と申しましょうか、明瑩々、玲瓏そのものであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "玲瓏つて云ふんですか、自分の手も、腕も、胸なんぞは乳のなり、薄掻卷へすつきりと透いて、映つて、眞綿は吉野紙のやうに血を壓へて、骨を包むやうなんです。",
              "citation": {
                "source": "淺茅生",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "改札口を冷く出ると、四邊は山の陰に、澄渡つた湖を包んで、月に照返さるゝ爲か、漆の如く艶やかに、黒く、且つ玲瓏として透通る。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌黎植うる處、牡丹もと紫、今は白紅にして縁おの／＼緑に、月界の採虹玲瓏として薫る。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "旭の光輝に照らされたる、人形の瞳は玲瓏と人を射て、右眼、得三の死体を見て瞑するがごとく、左眼泰助を迎えて謝するがごとし。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "折々の空の瑠璃色は、玲瓏たる影と成りて、玉章の手函の裡、櫛笥の奧、紅猪口の底にも宿る。",
              "citation": {
                "source": "五月より",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "美しき虹を、そのまま柱にして絵かれたる、十二光仏の微妙なる種々相は、一つ一つ錦の糸に白露を鏤めた如く、玲瓏として珠玉の中にあらわれて、清く明かに、しかも幽なる幻である。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　寂しく微笑むと、掻いはだけて、雪なす胸に、ほとんど玲瓏たる乳が玉を欺く。",
              "citation": {
                "source": "木の子説法",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　ここに醜怪なる蝦蟇法師と正反対して、玲瓏玉を欺く妙齢の美人ありて、黒壁に住居せり。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのに君は、実に浄らかな燦かな玲瓏たる紅顔を何時迄も保っている。",
              "citation": {
                "source": "絵姿",
                "author": "The Portrate of Dorian Gray",
                "note": "青空文庫"
              }
            },
            {
              "text": "幼兒は眞實であり、神は純一至高の感傷である、神の感傷は玲瓏晶玉の如くに透純である。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "感傷至上の三昧は玲瓏たり、萬有にリズムを感じ、魚鳥も屏息し、金銀慟哭す。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく見ると、そのようにおおらかな、まるで桃太郎のように玲瓏なキリストのからだの、その腹部に、その振り挙げた手の甲に、足に、まっくろい大きい傷口が、ありありと、むざんに描かれて在る。",
              "citation": {
                "source": "俗天使",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その夜はやがて、砂白く、崖蒼き、玲瓏たる江見の月に、奴が号外、悲しげに浦を駈け廻って、蒼海の浪ぞ荒かりける。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "生ける犬を屠りて鮮血を啜ること、美しく咲ける花を蹂躙すること、玲瓏たる月に向うて馬糞を擲つことの如きは、言はずして知るベきのみ。",
              "citation": {
                "source": "蛇くひ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疑と、驚きに、浅葱が細く、揺るるがごとく、父の家主の袖を覗いて、※った瞳は玲瓏として清しい。",
              "citation": {
                "source": "白金之絵図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "黛の他に玲瓏として顔に一点の雲もなかった。",
              "citation": {
                "source": "南地心中",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "他なし、お通がこの家の愛娘として、室を隔てながら家を整したりし頃、いまだ近藤に嫁がざりし以前には、謙三郎の用ありて、お通に見えんと欲することあるごとに、今しも渠がなしたるごとく、籠の中なる琵琶を呼びて、しかく口笛を鳴すとともに、琵琶が玲瓏たる声をもて、「ツウチャン、ツウチャン。",
              "citation": {
                "source": "琵琶伝",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "消防整列玲瓏たり、燦爛たり、不尽の山、麗らや大海はるかに辷りあがる。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "纏は金的、梯子は青竹、てつぺん玲瓏、人間さんらん、はつと逆さで大の字｜形。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "喞筒は一台、一念、一向喞筒の水はりうりうたり玲瓏たり、さんらんたり、不尽の山、喞筒の筒口りうりうたり。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "玲瓏たり燦爛たり、相模灘、もう一息だぞ、えんやらえんや。",
              "citation": {
                "source": "畑の祭",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "青｜瓊玉かゞやく天に、　　　　　れいろうの瞳をこらし、これはこれ悪業乎栄光乎、　　　かぎすます北斎の雪。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
