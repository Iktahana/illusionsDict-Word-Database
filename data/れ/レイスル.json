        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と強く命令するやうに言ふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝に　俺が命令する」　断然と言い放ち、Ｔ「此後断じて　舞台に立つ事ならぬ！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "『私について數を數へて下さい‥‥‥』と、滴壜を手にした助手は、命令するやうな句調でお前の耳元に囁いた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな眼に、すごい輝やきを持っている頑丈な老人が二人を取りおさえた者達に張りのある強い声で何か命令するように云った。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "クジマが「今後はペチカとランプと蝋燭以外に飛び出してはいけないぞ」と命令する場面で、ページの下半にはランプと蝋燭のクローズアップ。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と命令するように言ったので、私は瞬時へどもどした。",
              "citation": {
                "source": "美少女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と近藤は殆ど命令するように言った。",
              "citation": {
                "source": "牛肉と馬鈴薯",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声は低いけれども底力があって、なんだか私を命令するようでした。",
              "citation": {
                "source": "女難",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして読んでいけないと思う種類の書物を山積して毎日の日課として何十ページずつか読むように命令するのも一法であるかもしれない。",
              "citation": {
                "source": "読書の今昔",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺が命令するぞ」　婆やが何かいいながらチャブ台を引いた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この女の子、この間言ったあんたのお嫁さんじゃないの」　島吉は矢張り、うふふふふふと笑って、「奥さんにおじぎしないかよ」と、女の子に命令するように言った。",
              "citation": {
                "source": "酋長",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペンネンネンネンネン・ネネム裁判長　その威オキレの金角とならび　まひるクラレの花の丘に立ち　遠い青びかりのサンムトリに命令する。",
              "citation": {
                "source": "ペンネンネンネンネン・ネネムの伝記",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "貴様たちに命令する。",
              "citation": {
                "source": "饑餓陣営",
                "author": "一幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と伊都子は命令するように言った。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤峰頂上から下界へ向つて命令するが如き態度で、詩のやうな哲学、又哲学のやうな詩を絶叫しはしなかつた。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんは、でも、今は戸主だし、姉さんに命令する権利はあるわけだ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と老人は命令するようにいった。",
              "citation": {
                "source": "おしどり",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとがぼっとしているときには、ただ圧倒的に命令するに限るのである。",
              "citation": {
                "source": "座興に非ず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、人にかれこれ命令する権利は無い。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸術は、命令することが、できぬ。",
              "citation": {
                "source": "善蔵を思う",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "四篇の文、雄大にして荘厳、其大旨、義理の正に拠って、情勢の帰を斥け、王道を尚び、覇略を卑み、天下を全有して、海内に号令する者と雖も、其道に於てせざる者は、目して、正統の君主とすべからずとするに在り。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の思想の由つて來ることを尋ぬるに、蓋し人死して身猶存し、而して其の感思し料簡し命令する所以のものの存せざるに至れるを見たるより發したので有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "又身少しも動變せずして、而して其の感思し料簡し命令する所以のものの活動するに似たる夢といふものを認むるより發したのでも有らう。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪の如き、髮の如きものが、吾に屬して居るものでは有るが、我が料簡し、感思し、命令する所以のものとは甚だ遠き距離を有して居ることも明らかである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "盲腸の如き、生活状態の變化したる今日の吾人には何の用をもなさずして、卻て病患を貽すほかには作用無き物の體内に存在して居るのは、吾人が料簡し感思し命令する所以のものから言へば、摘出し驅除したくも覺ゆ可きものである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、謂わば政治的手腕も無ければ、人に号令する勇気も無し、教えるほどの学問も無い。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "下僕に命令する言葉も前夜よりは大分横柄になって来た。",
              "citation": {
                "source": "南島譚",
                "author": "幸福",
                "note": "青空文庫"
              }
            },
            {
              "text": "トナカイにめいれいする人がだれもいないのです。",
              "citation": {
                "source": "サンタクロースがさらわれちゃった！",
                "author": "A KIDNAPPED SANTA CLAUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "野村家だよ」　怪人は、運転席の部下にめいれいすると、箱の中から一枚の写真をとりだし、それを見ながら、変装にとりかかりました。",
              "citation": {
                "source": "怪人と少年探偵",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
