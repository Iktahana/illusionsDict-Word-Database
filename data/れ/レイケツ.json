      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold-bloodedness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "が、あの無気味にぬる／＼した、冷たい、執念深かそうな冷血動物が、僕は嫌いである。",
              "citation": {
                "source": "浮動する地価",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "キ……貴様はコノ俺を……オ……オモチャにして殺すのか……コ、コ、コノ冷血漢……」「科学はいつも冷血だ……ハハ……」　相手は白い歯を出して笑った。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "指先は冷血していて氷のようなのに、溜った興奮がびりびり指を縺して慄えている。",
              "citation": {
                "source": "金魚撩乱",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一斉に冷血のわななきは釘つけの身を逆にゑぐり刺す。",
              "citation": {
                "source": "邪宗門",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は自分達の夫であり、主人である伯父の死体が玄関前に横たわっているのを知っておりながら平気で私を取巻いて、この上もなく冷血な芝居をしている。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が完全に過去の記憶を回復しているのですからね……同時に、そのお蔭で、谷山家の養子事件を裏面からアヤツリ廻して来た、冷血残忍なＡの手の動きを、ハッキリと見透かしながら、お話する事が出来るのですからね……。",
              "citation": {
                "source": "キチガイ地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホームズってやつはちょっと科学がすぎるんだよ――冷血と言ってもいい。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は、一世の美男であればあるほど、この人の恋人になって安んじている自分にはなれない、冷血的な女だと思われてやむのが望みであると考えて、きわめて弱い人が強さをしいてつけているのは弱竹のようで、さすがに折ることはできなかった。",
              "citation": {
                "source": "源氏物語",
                "author": "帚木",
                "note": "青空文庫"
              }
            },
            {
              "text": "母親は息子の手を冷血漢のやうにものを言はしてくれ。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっと極端に申しますと現在の世界は、国際関係に於ても、個人関係に於ても、平気で良心を無視し、人道を蹂躙し得るほどの、残忍、冷血な者でなければ、絶対に勝利者となる事の出来ない世の中と申しても大した間違いはないと考えられるのであります。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪子と深尾みな子との面前であの紙片にしるされた自分の名前を読まれ、私の虚偽をばらされる屈辱に堪えられなかったために、妻の死顔にもあわないで、とんで帰ったその時の私の卑劣と冷血とは……ああそれを思うと、どうしても生きていることが不可能だ。",
              "citation": {
                "source": "秘密",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「莫迦にしているわ、奥さんなんて」「いくら冷血の博士だって、こう毎晩続けて奥さんが遅くっちゃ、きっと感づくよ」「もう感づいているわよオ、感づいちゃ悪い？",
              "citation": {
                "source": "俘囚",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、僕のような武骨一点張りの科学者が、恋愛などという文字を使用することにすら、滑稽を覚えるかも知れぬが、然し僕は君の考えて居るほど「冷血」ではなく、多少の温かい血は流れて居るつもりだ。",
              "citation": {
                "source": "恋愛曲線",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "村民の経済事情が悪化し剥脱されてゆく過程、市会議員の利権あさり、官僚的冷血、自然発生的に高まりやがて無気力な怨嗟にかわってゆく村民の心持の推移などを、作者は恐らく実地にあたって調査した上で書いているのであろう。",
              "citation": {
                "source": "文芸時評",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "農場主の妻デロア夫人の冷血さ、息子アンリイに対するマリイの感情、こういういきさつはしばしば小説の中に描かれている。",
              "citation": {
                "source": "若い婦人のための書棚",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "失業を増大させるしか手腕をもたない冷血貪慾な支配者たちは、彼らを生んだ母なる性の屈辱をもって自身の穢辱をさらしているといえるのである。",
              "citation": {
                "source": "貞操について",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう看護婦というものがどんな不徳、冷血、不潔でおそろしいものであったかディッケンズの小説によく描き出されている。",
              "citation": {
                "source": "フロレンス・ナイチンゲールの生涯",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その場合、その勤人は、勤め先そのものの機械性、冷血に苦しむ苦しさを、組合としての要求の中に一部吐露しうる。",
              "citation": {
                "source": "作家の経験",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "沁々考えてみると、そういう共通な不幸に感じを鈍くさせられて生きている生活の条件の荒っぽさ、冷血さはおそろしいと思う。",
              "citation": {
                "source": "『静かなる愛』と『諸国の天女』",
                "author": "――竹内てるよ氏と永瀬清子氏の詩集――",
                "note": "青空文庫"
              }
            },
            {
              "text": "最も近いそれらのひとびとから、政治的に何ぞというと掣肘を加えずに置かない冷血な、蒼白いアフラシャブに至る迄、今のスーラーブには一人として、心の通じ合う、誠を以て尽し合う者はなく感じられた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、出来ることなら擲りつけて、良人を独善的な、紳士的な、冷血な頑固さから突き出したかった。",
              "citation": {
                "source": "心の河",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し日本の労働組合の力が強くなり、社会の勤労が直接働く人のためのものとなれば、みんなが組合に属して働いている人であるから、社会全体としてそれを保護するということになれば、個人個人が、自分の人間らしさとひきかえに、冷血になったり、利己的になったりしないでやってゆける条件が出来ます。",
              "citation": {
                "source": "社会と人間の成長",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "といきなり当人に云ったと云う医者の態度があまり親切気がない様で切角主婦がああ云って居るのにそんな事を云っていやな思いをさせずともと、娘はすっかりいやな気持になって、　医者なんてまるで冷血動物だ。",
              "citation": {
                "source": "黒馬車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "深刻な空腹と、極度に緊張した冷血さが、彼の全身数百の筋肉に疼きみちみちて来た。",
              "citation": {
                "source": "白菊",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……すなわちその犯罪の外観と申しますは、或る富裕な一家の血統に属する数名の男女を、何等の理由も無いままお互い同志に殺し合わせ、又は発狂させ合ってしまったという、残忍冷血、この上もない兇行を中心として構成されているので御座います。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……どこかに潜み隠れている、正体のわからない、冷血兇悪な精神病患者……其奴が描きあらわした怪奇、残虐を極めた犯罪の記念品……そんなものを次から次に見せ付けられて、思い出せ思い出せと責め立てられるのではあるまいか。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "その脳髄文化の冷血、残酷さを見よ。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……コ……コンナ非道い……冷血な罪悪……ああ……ああ……僕はモウ頭が……」　私は大｜卓子の上に崩折れ伏した。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
