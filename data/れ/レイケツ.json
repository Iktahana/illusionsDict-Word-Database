[
  {
    "uuid": "e44bd653-08b1-5e5f-81bd-aedf0f839edd",
    "entry": "冷血",
    "reading": {
      "primary": "れいけつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
