[
  {
    "uuid": "7434ccb1-c579-5773-bd74-d35528832496",
    "entry": "冷然",
    "reading": {
      "primary": "れいぜん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞-たる",
        "副詞-と"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cold (attitude)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "わしは冷然無視したものか、気を盛り眼を明にして、これに備へをしたものか。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷然たる医者は一、二語簡単な挨拶をしながら診察にかかった。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "大眼に御覧あそばして」　巡査は冷然として、「規則に夜昼はない。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらに冷然として一定の足並みをもて粛々と歩み出だせり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蔦をその身に絡めたるまま枯木は冷然として答えもなさず、堤防の上につと立ちて、角燈片手に振り翳し、水をきっと瞰下ろしたる、ときに寒冷｜謂うべからず、見渡す限り霜白く墨より黒き水面に烈しき泡の吹き出ずるは老夫の沈める処と覚しく、薄氷は亀裂しおれり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "清逸は冷然として弟の顔から眼を原稿紙の方に振り向けた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家に著くや無理に、気持を引き立てて、腰の痛みをみせまいやうに一心に姿勢を作つて、『ただ今』といと冷然と云つた。",
              "citation": {
                "source": "亡弟",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　島野は冷然として、「何、犬に食われて死にゃあ可いんだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "濱島は冷然と笑ひ、春枝夫人は默然とした。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄色縮緬の頭巾目深に、唐草模様の肩掛を被て、三枚｜襲の衣服の裾、寛闊に蹴開きながら、衝と屑屋の身近に来り、冷然として、既に見えざる車を目送しつつ、物凄き笑を漏らせり。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お丹は冷然として、「不可ません。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかる群集の動揺む下に、冷然たる線路は、日脚に薄暗く沈んで、いまに鯊が釣れるから待て、と大都市の泥海に、入江のごとく彎曲しつつ、伸々と静まり返って、その癖｜底光のする歯の土手を見せて、冷笑う。",
              "citation": {
                "source": "売色鴨南蛮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お通はかねて忌嫌える鼻がものいうことなれば、冷然として見も返らず。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "美人は冷然として老媼を諭しぬ、「母上の世に在さば何とこれを裁きたまわむ、まずそれを思い見よ、必ずかかる乞食の妻となれとはいいたまわじ。",
              "citation": {
                "source": "妖僧記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "一平は冷然として、「幾らお前さん等が騷いだツてな、今日は先生がお出なさらねえうちは、何うしたツて此處を通す事ツちやねえ。",
              "citation": {
                "source": "解剖室",
                "author": "三島霜川",
                "note": "青空文庫"
              }
            },
            {
              "text": "（数枝）（顔を挙げ、冷然と父の顔を見守り無言）（伝兵衛）　小さい時から我儘で仕様がなかったけれども、しかし、こんな馬鹿な奴とは思わなかった。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "節子、冷然と坐ったままでいたのであるが、ふと、膝元の白い角封筒に眼をとめ、取りあげて立ち、縁側に出てはきものを捜し、野中のサンダルをつっかけ、無言で皆のあとを追う。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "地獄の門をさえ冷然とくぐったダンテもこの扉については、語るを避けた。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "どてらの襟を掻き合せ、努めて冷然と、「まあ、いいやうにして置いて下さい。",
              "citation": {
                "source": "清貧譚",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷及び氏郷の諸将は之を聞いて、ソリャコソ政宗めが陰謀は露顕したぞ、と思って眼の底に冷然たる笑を湛えて点頭き合ったに違いあるまい。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "女はグイとまた仰飲って、冷然として云い放った。",
              "citation": {
                "source": "貧乏",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "半禿げ上つた額、曲つた鼻、人情の何たるかを解しないやうな冷然たる眼。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "集金に行ってコップ酒を無理強いにするトラック屋の親爺などに逢えば面白いが、机の前に冷然としている、どじょう髭の御役人に向って、『今日は、御用はありませんか。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "三造は、わざと冷然と、父の顔を見上げた。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、もう夜伽などしようと云う者があっても皆断って、一人冷然として家を守っていた。",
              "citation": {
                "source": "魔王物語",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「寂しい、のみならず澄まし切ってる、冷然としたものだ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　小宮山は亭主の前で、女の話を冷然として刎ね附けましたが、密に思う処がないのではありませぬ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されど今ここに心づきて、わが心はなお冷然たりしか。",
              "citation": {
                "source": "舞姫",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "その姿を、上から、黒い牛のような顔が、今度こそ明瞭な侮蔑を浮かべて、冷然と見下す。",
              "citation": {
                "source": "牛人",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何だ貴様は……」　私は冷然と笑った。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
