[
  {
    "uuid": "d357df20-bc65-596a-8927-48a4a0b8bbfa",
    "entry": "霊能",
    "reading": {
      "primary": "れいのう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
