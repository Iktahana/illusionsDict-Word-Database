    },
    "definitions": [
      {
        "index": 1,
        "gloss": "spiritual ability",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
