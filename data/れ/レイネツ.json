    "definitions": [
      {
        "index": 1,
        "gloss": "coldness and hotness",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "夜は冷気のために雪が岩石の膚肌に凝結し、昼はそばから蒸発して行くので、冷熱の変化から岩石を破壊し、山体を陶器の破片のように滅茶滅茶にして散乱させる。",
              "citation": {
                "source": "高山の雪",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷熱の感覚はその当人の状態にもよりまた温度以外にその物体の伝導度によるのである。",
              "citation": {
                "source": "物理学と感覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "途端に、冷熱いずれともつかぬものが、彼の脊筋を走った。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "靜かに涙のあふれるやうな心持で、彼の冷たい手と、彼女の温かい手と、冷熱が入りみだれて、二つの手の存在が判然としなくなつた時、二人は空につゞくかぎりない白い路と、灰色の野の上に太陽の光線の箭に條づけられた雲の色とを、繪でも見るやうに眺めた。",
              "citation": {
                "source": "幸福への道",
                "author": "素木しづ",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも評価はあらわでない含蓄的の場合が多いかも知れませんが、ともかくも好悪の両面を記述して、しかも公平に記述すると云う事は、あたかも冷熱の二性を写して、湯と水を同一視しろと云う注文と同じ事で、それ自身において矛盾であります。",
              "citation": {
                "source": "創作家の態度",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことはお銀にも同じようにあるらしかったが、冷熱はいつも男よりか順調であった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "六十七　しかし、節子に許した岸本の心とても冷熱を繰返さずには動き進んで行くことが出来なかった。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "恋というものに対して、自らの魂のなかで、冷熱相戦った手記であると同時に、肉体と霊魂との持久戦でもあった。",
              "citation": {
                "source": "樋口一葉",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "被害者の血の冷熱を量刑の尺度とするローマ十二表法の一見奇異なる規定も、むしろ法律進化の過程における当然の現象というべきである。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "獅子宮は猛獸に因みて熱さを表はし、土星は寒さをあらはす（淨、一九・一―三註參照）、冷熱相混じ相調節してその影響温和なりと又曰く。",
              "citation": {
                "source": "神曲",
                "author": "LA DIVINA COMMEDIA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……氷炭相容れず、冷熱並び存しない筈だが、あれのうちには、それが二つとも、りっぱに存在し得るのだ。",
              "citation": {
                "source": "秦の出発",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ身体はひどく酔いながら、精神はもう酔いがさめたような、冷熱の合間にある心地でした。",
              "citation": {
                "source": "乾杯",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "手の甲というものは、冷熱の感覚がたいへん鋭敏である。",
              "citation": {
                "source": "ゴールデン・バット事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "かような事情になる諸家の素人窯から優秀なる名陶が生まれ出でようはずのないことは別段ここに氷炭冷熱をいわずともみずから明らかではないか。",
              "citation": {
                "source": "素人製陶本窯を築くべからず",
                "author": "――製陶上についてかつて前山久吉さんを激怒せしめた私のあやまち――",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷熱の分らないただ水銀のように重い感じのするものが、胃の底に流れ込んだのを感じた。",
              "citation": {
                "source": "蘇生",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "依子はこの冷熱の間に苦しめられて、彼や幾代の方へ逃げていった。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "要するに京都の議論は、その説明において冷熱の相違あり、その実行において、晦顕の差ありといえども、鎖国攘夷の精神に至っては、始終｜一轍に出でざるものなきは、当時の情勢断じて疑うべからず。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷熱一　世間の風潮といふものに、これほど頭をなやます自分がをかしいぐらゐであつた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだ、そうか、という失望に似た気持と、その後に尾を引く胸苦しいまでの悔恨とが、彼をしばらく、冷熱相交る感情のなかにさ迷わせたのである。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "天に温冷熱の三｜際あるは、人の肌は温に肉は冷か臓腑は熱すると同じ道理也。",
              "citation": {
                "source": "北越雪譜",
                "author": "鈴木牧之編撰",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに大筋をかいても一寸おわかりになりにくいでしょうし、又いい気持もなさらないでしょうが、それは冷熱こもごもの感じで、まだすっかり丈夫になっていない私には苦しいことなの。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "今、日本の天下は、王政の古えにかえるか、徳川の幕府につながるかという瀬戸際に於て、王城の地はその鼎沸の中心に置かれても、乞食となってみると、一向その冷熱には感覚がないのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "山科の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "会う前の恋いしさと会っての後の胸ぐるしさ、―――そう云う心の変りかたはこの女の場合に限ったことではなく、芸者と馴染んでいた時分にも少しは覚えのあることだけれども、しかしこんなに冷熱の度が激しいと云うのは、畢竟生理的の原因に依るからなので、それだけルイズは酔わせかたの強い酒なのであろう。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに彼は、上品で寛容で誇らかで宗教的で熱誠で、冷熱あわせ有する少年だった。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷熱の名称を、根源を、その他それに関連するあらゆる問題を、働きかけるもの・受け蒙るもの・の諸特質を、言ってくれなければならないのだ。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二に、色、味、匂い、音、冷熱といった印象がある。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、明らかに、哲学者たちの見解がどうであれ、色、音、冷熱、は感覚に現れる限り、運動や固性と同じ様式で存在する。",
              "citation": {
                "source": "人間本性論（人性論）",
                "author": "A Treatise of Human Nature",
                "note": "青空文庫"
              }
            }
          ]
        }
