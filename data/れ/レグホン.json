    "definitions": [
      {
        "index": 1,
        "gloss": "Leghorn (var. of chicken)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
