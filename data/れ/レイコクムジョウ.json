    },
    "definitions": [
      {
        "index": 1,
        "gloss": "cruel and heartless",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼は最も烈しい衝動によつて創作するところの、眞の情熱的詩人であつて、しかもまた同時に、最も冷酷無情の目を持つたニヒリスチツクの哲學者だつた。",
              "citation": {
                "source": "本質的な文學者",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎に角冷酷無情の男であったらしい。",
              "citation": {
                "source": "一緒に歩く亡霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやに冷酷無情だな。",
              "citation": {
                "source": "晩菊",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "墓の上にはとでも書かれようけれど、老齢の冷酷無情な面影からは、何一つ読みとることも出来はしないのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ここで客は、言葉が次ぎから次ぎへと、まるで隼のように後を追って飛びだして来そうになり、息もつけないほどであったから、その口を制するためには、そのとき彼女の親友が取ったような冷酷無情な態度を取るより他はなかったのだ。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　だが我等の主人公が、生まれつき、それ程までに冷酷無情で、憐憫も同情も知らないほど鈍感な性質であったとは、一概にいうことは出来ない。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに隙なく燃焼しつつある二人が全力で美しく愛情を支え合っているときにも、過去が現在の幸福を冷酷無情に顛覆して進んでゆくのである。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だって、あの男は冷酷無情なのかさっぱり判らない。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "若林博士は又、そんな試験ばかりをやっている冷酷無情な科学者なのではあるまいか？",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この少年を、追放してくれたまえ」　青年技師は、冷酷無情にも、そう命じると、数名の男は、矢庭に僕の肩や、手をとった。",
              "citation": {
                "source": "怪奇人造島",
                "author": "寺島柾史",
                "note": "青空文庫"
              }
            },
            {
              "text": "先天的に冷酷無情なのよ。",
              "citation": {
                "source": "恋をしに行く（「女体」につゞく）",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "246　　　１．彼は彼自身の兄弟の家族を滅ぼさうとしたほどの冷酷無情な男であつた。",
              "citation": {
                "source": "新獨逸語文法教程解説",
                "author": "關口存男",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の激浪に損われた跡がミジンも見えない貴公子のようなこの青年に、彼の過去がすべてそうであったように、現在も冷酷無情な現実がヒシヒシとりまいていることを、はじめて長平は知ることができた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄兜を眉の上までずりさげ、クリスマス・カロルの〈スクリージュ〉か、アン女王を倫敦塔の死刑場へ護送して行く首斬役人のような冷酷無情な顔つきで立っている。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "ナポレオンの遺骸は「まるで驢馬の死骸のように」冷酷無情に扱われ、アベ・ヴイグナルリの終油の式も、「いやな役目を一分でも早くすましてしまおうというふうに」急ぎに急ぎ、祈祷文の誦称も上の空、腹がたつほどお粗末なものだった。",
              "citation": {
                "source": "フランス伯Ｎ・Ｂ",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "はじめは眼をさけおうていたが、日が経つとちらと交した眼附にも、お互にまた来ているという言葉があらわれるだけで、あとは冷酷無情の眼のつつきあいしかなかった。",
              "citation": {
                "source": "姫たちばな",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "警視庁切っての俊才、検察ブレーン・トラストの第一人者、冷酷無情をもって知られる真名古こそ、こんな際には先に立って捜査の指揮にあたらなければならぬ筈なのに、これほどの大騒動を空吹く風と聞き流し、こんなところにへばり込んでいるのは、日ごろ敏捷明快なその人にははなはだふさわしからぬ態度である。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "細い眸の間から冷酷無情な眼差を覗かせ、じっと総監の方を眺めていたが、やがてゆっくりと、その傍に近づいて来ると、沈んだ響のない声で、「総監、職権によってあなたを逮捕します」　と、宣告した。",
              "citation": {
                "source": "魔都",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「冷酷無情な方ね。",
              "citation": {
                "source": "蜜のあわれ",
                "author": "室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまりと申せば冷酷無情……いかがでござりましょう。",
              "citation": {
                "source": "亡霊怪猫屋敷",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "世間の機構の不公正に対して、人間の狡猾と冷酷無情に対して……。",
              "citation": {
                "source": "はたし状",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかもその妻は、冷酷無情だと申したのか」　――あなたとは十五年以上もいっしょに暮して来たが、と云われたということです。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "「たぶん、冷酷無情というのにはなにか意味があるのだろう、十五年もともに暮した妻の口から、原田甲斐が冷酷な人間だと云ったとすれば、よし、覚えておこう」　――別宴のことを申上げます。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "根底には一族の誇り、呪われた誇りがあり、人間性をすべて抑圧し、心を冷酷無情な石に変えてしまう。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
