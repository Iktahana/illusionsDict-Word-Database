    "definitions": [
      {
        "index": 1,
        "gloss": "chilly rain",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "しとしとと晩秋らしい冷雨が降りしきつてゐる。",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こういう女が身体の血の気も漲っていれば、心の火の熱も熾んな若盛りで、しかも婚後の温い生活を楽んでいる際に当って、近親の定基の家には、卑しい身分の一艶婦のために冷雨悲風が起って、其若い妻が泣きの涙でいるということを知っては、其儘に他所の事だと澄ましかえっては居にくいことである。",
              "citation": {
                "source": "連環記",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その約束の日、由良氏は家を出ようとして、冷雨びしょびしょ。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」冷雨の中を、ふたり並んで歩いた。",
              "citation": {
                "source": "懶惰の歌留多",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓々には灯がともり柳の糸が蕭条と冷雨のように垂れ注いでいた。",
              "citation": {
                "source": "荘子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい四五日前までは夏のようであったが、町中のお寺の前の暗がりにふと金木犀のにおいを光らせて降る雨は、はや一雨一雨冬に近づく秋の冷雨だった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "闇の中に冷雨にそぼぬれていた熊笹がガサッと、人間を袈裟がけに切ったような無気味な音を立てた。",
              "citation": {
                "source": "軍用鼠",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "想はぬ快勝を見た「Ｗ」側の観衆は、鬨の声を挙げて総立となり、冷雨の降り止んだばかりの寒風も知らずに、上着までを脱いで踊り狂つた。",
              "citation": {
                "source": "サクラの花びら",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "暖くきらめく作者の感動は、「冷雨」において苦悩が　衆生のものでなくして私ひとりのものであったら何を　矜持として　生きるものかという、ひろがりをもっている。",
              "citation": {
                "source": "『静かなる愛』と『諸国の天女』",
                "author": "――竹内てるよ氏と永瀬清子氏の詩集――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「冷雨凄風林葉鳴、笠簑相伴訪柴荊」の句がある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷雨がにわかに降り出したので、そこの仕舞家の軒の下に、五人は雨宿りをしたものと見える。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今も冷雨は降っていた。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その冷雨に濡れながら、髪を乱し衣紋を乱した、若い美しい狂人の娘が、田沼家の前を行ったり来たりしていた。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これが冷雨の常である。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷雨の降った後である。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷雨幽※、切りに香玉を懐ひて牀頭の枕露けかりき。",
              "citation": {
                "source": "『聊斎志異』より",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "一月十二日◯昨夜モ敵三回来襲ス、薄雪アリ冷雨時ニ落チ冷エ込ムコト甚シ、遠方ニ男女ノ警防団員ノ声ス、皇土ヲ護ル当代ノ人々ナリ、感涙ヲ禁ジ得ズ。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして三人炬燵につかまりながら障子の中のガラスから縁側の方を眺めると、冷雨にまじつて、綿のやうな大きな雪片が靜かに舞ひ落ちてゐました。",
              "citation": {
                "source": "初雪",
                "author": "近松秋江",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は意を決して、あの冷雨の朝、Ｑ島政府差廻しの成層圏機の客として、（おそらく甚だ悲痛な顔をして）ハネダ空港を飛び立つた。",
              "citation": {
                "source": "わが心の女",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "本所鈴川の化物屋敷が刀影下に没して、冷雨のなかを白刃｜相搏つ血戦の場と化しさったころ。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "凄風冷雨のこの一日が来てから、教員等は政府に未払月給を請求したので、新華門前の泥々の中で軍隊に打たれ、頭を破り、血だらけになった後で、たしかに何程かの月給が渡った。",
              "citation": {
                "source": "端午節",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、七月には更に全國的に霜が降り、その間も冷雨がつゞき、咲きかけた槐の花もみな腐れ落ちた。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "二部将に引かれて、彼らは、味方にもそっと自陣を離れ、暗い冷雨に打たれながら、木津の川べりを北へ走った。",
              "citation": {
                "source": "私本太平記",
                "author": "帝獄帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "村のものらもかれこれいうと聞いてるので、二人揃うてゆくも人前恥かしく、急いで村を通抜けようとの考えから、僕は一足先になって出掛ける。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくして思慮深い労働者は、自分たちの運命を、自分たちの生活とは異なった生活をしながら、しかも自分たちの身の上についてかれこれいうところの人々の手に託する習慣を破ろうとしている。",
              "citation": {
                "source": "宣言一つ",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はア、何にも……」　お雪はそう言ったが、急に想い出して、「――あ、そうそう、あのお客様にこれを渡してくれいうて、ことづかりました」「お見せ？",
              "citation": {
                "source": "それでも私は行く",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "（現在その女の本当の名を忘れているのだが、想い出す都度簡単に花子だとしている）あの時、一緒に連れてくれいうたのに、のし、どない思て連れてくれなかっちゃんならと、彼女は並んで歩き出すと、言った。",
              "citation": {
                "source": "俗臭",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その静寂の時間がやや長くつづくと、石だ、石だ、という声が、こんどはだれいうとなく、石太郎よりもっとも遠い一角より起こってくる。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時に、落語やれいうのは、葬式の日にヤッチョロマカセを踊れいうより、殺生やぜ」　言いながら、涕き声になると、ひしとミネ子を抱きしめて、「ミネちゃん、おっさんの子になるか」「なる。",
              "citation": {
                "source": "昨日・今日・明日",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその事はもはやかれこれいうべき時期を過ぎた。",
              "citation": {
                "source": "弓町より",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
