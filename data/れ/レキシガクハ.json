    "definitions": [
      {
        "index": 1,
        "gloss": "historical school (of economics)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
