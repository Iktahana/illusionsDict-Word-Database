    },
    "definitions": [
      {
        "index": 1,
        "gloss": "blisteringly hot",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "暑中休暇の来るまで笹村は落着き悪い二階の四畳半に閉じ籠っていたが、去年の夏いた牛込の宿よりは居心がよかった。",
              "citation": {
                "source": "黴",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "飯島も、おだやかに、さア、秋まではどうかしらんが、夏いっぱいは大丈夫ですよ。",
              "citation": {
                "source": "昔の火事",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雅楽所で三沢に会うまでは、Ｈさんと兄とがこの夏いっしょにするという旅行の件を、その日の問題として暗に胸の中に畳み込んでいた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "従来の日本の専門店は、夏いそがしければ、冬はひま、冬いそがしければ、夏はひま、とかく営業が一方に傾いていた。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずっと後になって、家内や矢田部の甥などを連れて、一夏いたことがあったが、その時はもうこの人の代になり、厄介をかけたことがあった。",
              "citation": {
                "source": "故郷七十年",
                "author": "柳田国男",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔、鎌倉の明月谷というところに一夏いて、小説かいていたことがあります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから夏いっぱい、登は暇をみつけては彼の部屋へゆき、茶菓子をすすめたりしながら、さりげなく話しかけ、また彼から話をひき出すようにした。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "三度目の正直",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄一郎は傷が膿んだりして、それから夏いっぱい休み、ようやく治って、起きられるようになったときは、もう秋風が立ちはじめていた。",
              "citation": {
                "source": "いさましい話",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "藩主からの特旨で、父の助左衛門は夏いっぱいの静養が許された。",
              "citation": {
                "source": "落ち梅記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "漁師の子供たちは夏いっぱい川の魚やカニをとって遊ぶが、それを食べることがない。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "いわば尊氏はいま禁中のかごの鳥」「いやその父のみかどは、今夏いらい、尊氏の歓心を購うほうへ変っておられる。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供も彼女になついた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉に向つても姉さん／＼となついて、何か頻りと独言を云ひながら洗面台の掃除をして居た。",
              "citation": {
                "source": "お末の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼっちゃまは、アンネ・リスベットに、とてもなついていました。",
              "citation": {
                "source": "アンネ・リスベット",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "クラスの美少年たちもたいてい私になついてゐた。",
              "citation": {
                "source": "思ひ出",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "君だって、先王がおいでの頃は、この山羊のおじさんに、なついていました。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハムレットさえ、機嫌よく私たちに、なついてくれたら、このエルシノア王城の人心も治り、王も意を強うして外国との交渉に専心出来ますのに。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやにおばあちゃんになついてしまって、いい気になってへばりついてる。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "（火鉢に炭をついだり、鉄瓶に水をさしたり、あさの掛蒲団を直してやったり、いろいろしながら気軽い口調で話相手になってやっている）（あさ）　だって、あたしがいなくなった後でも、睦子がおじいちゃんになついて居れば、お前だって、東京へ帰りにくくなるだろうからねえ。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "甥は、二十五で、従弟は、二十一で、どちらも私になついていたのに、やはり、ことし、相ついで死んだ。",
              "citation": {
                "source": "秋風記",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "風景といふものは、永い年月、いろんな人から眺められ形容せられ、謂はば、人間の眼で舐められて軟化し、人間に飼はれてなついてしまつて、高さ三十五丈の華厳の滝にでも、やつぱり檻の中の猛獣のやうな、人くさい匂ひが幽かに感ぜられる。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、君枝が折角オトラになついて、オトラを慕っているものを、むげに引きはなしてしまうのも可哀想だと、翌る朝またオトラが飯をたきに来た時はもう他吉はきつい言葉を吐かなかった。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、新次は変な子供で、浜子を恋しがる風も見せずに、化物のように背の高い玉子にひたすらなついていたようでした。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、あんなにおれになついて、一日中番をしていたくらいだから、夜になったらまたかえって来るかも知れないと思いながら、それとはなしにまっていましたが、夜おそくなっても、犬はそれなりとうとうかえって来ませんでした。",
              "citation": {
                "source": "やどなし犬",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "親類たちは妙にこの婦人を白い眼で見て、「あんまり年を老ってから美しい奥さんを持つと決していいことはない」などとまだ子供の私に云い聞かせていた位であったが、義母の弓子は、この上もなく私を可愛がって実の母以上につくしてくれたので、私はむしろそんな親類に反感を持って義母になついていたものであった。",
              "citation": {
                "source": "冥土行進曲",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "町の人々は、アラジンになついていたものですから、アラジンが引かれて行くそばへよって来て、どうか、ひどい目にあわないようにと、おいのりをしてくれました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "私に、とてもよくなついて、女のお子さんなんか、病気中、まるで私がお母さんの代りなの。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供もよく、なついていて、ほんとうにいい方だったわ。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "今朝、どこからか迷って来たのが、もうすっかりなついてしまって、落ち着いているのだそうである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「否さ、景色がよくないから遊山に来ぬの、便利が悪いから旅の者が通行せぬのと、そんなつい通りのことぢやなくさ、私たちが聞いたのでは、此の野中へ入ることを、俗に身を投げると言ひ伝へて、無事にや帰られないんださうではないか。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
