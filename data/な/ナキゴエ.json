[
  {
    "uuid": "106c447e-47e1-5b45-bdd4-0d0d47cfc3e1",
    "entry": "泣き声",
    "reading": {
      "primary": "なきごえ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
