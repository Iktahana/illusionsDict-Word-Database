        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "菜の花や鯨も寄らず海｜暮ぬ　菜種畠の遠く続いてる傾斜の向うに、春昼の光に霞んだ海が見え、沖では遠く、鯨が潮を噴いてるのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種と蓮華草のモザイクに数限りない雲雀の声と蝶の羽根が浮き上っている。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種畑は結実でたわゝになっています。",
              "citation": {
                "source": "●「或る女」巻頭のホイットマンの詩",
                "author": "\"Not till the sun excludes you, do I exclude you;",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んの余波やら、庵にも、座にも、袖にも、菜種の薫が染みたのである。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種の花道、幕の外の引込みには引立たない野郎姿。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "アノ椿の、燃え落ちるように、向うの茅屋へ、続いてぼたぼたと溢れたと思うと、菜種の路を葉がくれに、真黄色な花の上へ、ひらりと彩って出たものがある。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "二個の頭、獅子頭、高いのと低いのと、後になり先になり、縺れる、狂う、花すれ、葉ずれ、菜種に、と見るとやがて、足許からそなたへ続く青麦の畠の端、玉脇の門の前へ、出て来た連獅子。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし箔のついた次男どのには、飛だ蝶々、菜種の花を見通しの春心、納戸で爪を磨がずに居ようか。",
              "citation": {
                "source": "一席話",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "次第に、麦も、田も色には出たが、菜種の花も雨にたたかれ、畠に、畝に、ひょろひょろと乱れて、女郎花の露を思わせるばかり。",
              "citation": {
                "source": "七宝の柱",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "右手には机に近く茶器を並べた水屋と水棚があって、壁から出ている水道の口の下に菜種と蓮華草の束が白糸で結わえて置いてある。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "すてきにいい天気で村々の家々に桃や椿が咲き、菜種畠の上にはあとからあとから雲雀があがった。",
              "citation": {
                "source": "あやかしの鼓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "婦人と雨　しとしとと降る雨の中を、かすかに匂つてゐる菜種のやうで、げにやさしくも濃やかな情緒がそこにある。",
              "citation": {
                "source": "宿命",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "はたけへ入って芋をほりちらしたり、菜種がらの、ほしてあるのへ火をつけたり、百姓家の裏手につるしてあるとんがらしをむしりとって、いったり、いろんなことをしました。",
              "citation": {
                "source": "ごん狐",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の祭にきた猿まわしとね、ぼく、菜種畑ん中でいきあったの。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくが菜種の花をちぎってなげてやったら、大きな猿が、とてもじょうずにうけとってね、小さいお猿に半分ちぎってやって、パクパクたべてったよ。",
              "citation": {
                "source": "病む子の祭",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "畷道少しばかり、菜種の畦を入つた處に、志す庵が見えました。",
              "citation": {
                "source": "雪靈記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "面を圧して菜種の花。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤楝蛇が、菜種の中を輝いて通ったのである。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此処よりして見てあれば、織姫の二人の姿は、菜種の花の中ならず、蒼海原に描かれて、浪に泛ぶらん風情ぞかし。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この山の裾へかけまして、ずッとあの菜種畠の辺、七堂伽藍建連なっておりましたそうで。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」十　菜種にまじる茅家のあなたに、白波と、松吹風を右左り、其処に旗のような薄霞に、しっとりと紅の染む状に桃の花を彩った、その屋の棟より、高いのは一つもない。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の黒髪、桃色衣、菜種の上を蝶を連れて、庭に来て、陽炎と並んで立って、しめやかに窓を覗いた。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目を開ける時、もし、あの丈の伸びた菜種の花が断崕の巌越に、ばらばら見えんでは、到底この世の事とは思われなかったろうと考えます。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畷道少しばかり、菜種の畦を入った処に、志す庵が見えました。",
              "citation": {
                "source": "雪霊記事",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその塔々には昼日中にも係らず菜種いろの電灯がほのかにつき、窓々には尾籠なほど濃い色彩の嵌硝子が唇で嘗め濡したように光っています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "菜種油で自動車を動かそうとする。",
              "citation": {
                "source": "豆腐買い",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとりそはそは、くるりくるくる、水車廻る畑のどぶどろに、葱のあたまがとんぼがへりて泳ぎゆく、ちびの菜種の真黄いろ堀に曳きずる肥舟の重い小腹にすられゆく。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "山々の段々畠に棚引く菜種、蓮花草の黄に紅に、絶間なく揚る雲雀の声に、行衛も知らぬ身の上を思ひ続けつゝ、幾度となく欠伸し、痴呆の如くよろめき行く様ひとへに吾が生胆を取られたる如し。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かえりに狐が、月夜のなたねばたけのなかを歩いていますと、たいへんよいにおいがします。",
              "citation": {
                "source": "狐のつかい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "丘の　南の　なたね畑の　中で　じつと　まつて　ゐた　仔牛の　頭に、やがて　小ちやく　生えて　來たのは、白鳥の　羽でも　なく、鹿の　角でも　なく、ふつうの　牛の　まるい　角でした。",
              "citation": {
                "source": "仔牛",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
