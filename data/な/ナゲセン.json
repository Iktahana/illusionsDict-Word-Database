[
  {
    "uuid": "a095cc20-90a6-56f3-862a-f4b0b37675a2",
    "entry": "投げ銭",
    "reading": {
      "primary": "なげせん",
      "alternatives": [
        "なげぜに"
      ],
      "is_heteronym": false
    },
    "grammar": {
