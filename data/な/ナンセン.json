[
  {
    "uuid": "3a179679-3206-57c4-ba48-1056c6770a70",
    "entry": "難船",
    "reading": {
      "primary": "なんせん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
