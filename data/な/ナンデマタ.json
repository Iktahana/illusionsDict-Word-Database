          "literary": [
            {
              "text": "）鯉七　何でまた、そのような飛んだ事を？",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまたこんな九州くんだりへ、来なすつただね。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまた、そんな牛みたいに、のつそりはいつて来るだね。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "五万八千円の一太郎と九万八千円の１―２―３が何でまた記者発表の机におかれているのかと思ったら、「たかだか原価二千〜三千円のソフトにこんな値段を付けるなんて、馬鹿げた高売りだ」と宣言するやマニュアルとフロッピー・ディスクを記者の目の前にほうり投げて、「写真取ってね」ときたもんね。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でまた飮まねえんだ、さうだにしんねりむつゝりしてねえで、ちつた威勢つけて見るもんだ、そうれ」と先刻からの爺さんは茶碗を突きつけた。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "三年で立派に一人前になれるところを、何でまた辛い目して、六年もやらうと云ふんだい。",
              "citation": {
                "source": "生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまたおれたちは彼奴のためにこんな目にあはなけりやならないんだ！",
              "citation": {
                "source": "一過程",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまた私なんぞの所へ云つて來たものかと思つてるんですけれど、しかし事情を聞いてみればいかにも尤もなことで、同情しないわけにはいかないんです。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「畑浦が……何でまた、そりや。",
              "citation": {
                "source": "續生活の探求",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でまた、そんなに借金をしたんですか」「だから私考へると厭になるのよ。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "ストア派の哲學者はゼノーもセネカも、自由獨立の靈にならうとして自殺を遂げたが、現在に獨立が出來ないなら、その表象である未來に何でまた獨立が得られよう。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "「――何でまたあんな浮気な店に出した、ちやんとええとこにつとめてをつたのに」　さう云はれて見ればさうも思へる。",
              "citation": {
                "source": "現代詩",
                "author": "武田麟太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまた、おれの髮の毛を乾草みたいだなんて吐かすのだらう？",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちっとも力なんぞ入れてやしねえ――その弱虫が、何でまた、あんな女ッ子とグルになって、おいらほどのものに煮湯を呑ませようとしやがったのだ！",
              "citation": {
                "source": "雪之丞変化",
                "author": "三上於菟吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でまた、そんなに借金をしたんですか」「だから私考えると厭になるのよ。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御嬢さんは何でまたあすこまで出張っていたんですか。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまたそれ程にする必要があったんかね？",
              "citation": {
                "source": "子をつれて",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまたそれ程にする必要があつたんかね？",
              "citation": {
                "source": "子をつれて",
                "author": "葛西善藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "からっきし、どうも、人間もこうなっちゃ、みじめですぜ」「何でまたこんな田舎へ流れ込んで来たのだい」「ちげえねえ、旦那のおっしゃる通りだ。",
              "citation": {
                "source": "草枕",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でまたあたしがあの席に必要だったの」「お前は継子の従姉じゃないか」　ただ親類だからというのが唯一の理由だとすれば、お延のほかにも出席しなければならない人がまだたくさんあった。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまたそんな事を気にかけるんだ。",
              "citation": {
                "source": "明暗",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何でまた私が、そうしたお疑いを受けるのでございましょう。",
              "citation": {
                "source": "ながうた勧進帳",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまた、私が手をかけてよろしゅう御座いましょう。",
              "citation": {
                "source": "ながうた勧進帳",
                "author": "酒井嘉七",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何でまた戦をするんだ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまた、捨てておかれよう。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――武門のためわしは主張するのだ」「今日まで、お怺え遊ばしたものを、何でまた、俄かにさまで仰せあるか。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「酔っているらしいね」「何でまた、戸外で酒など？",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまた、明りを消したのだ」　と、怪しみながら入って来た。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "何でまた、そんな物を、神棚へなぞ上げたのか」　金五は、中腰をすえ直して、炉の火を見つめた。",
              "citation": {
                "source": "新書太閤記",
                "author": "第九分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんでまた、こんな日に見合せんならんねん。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
