[
  {
    "uuid": "606a8323-00e6-5036-b842-d4a73451ba8c",
    "entry": "慣れる",
    "reading": {
      "primary": "なれる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
