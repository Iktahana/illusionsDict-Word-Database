    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to get used to",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だが慣れるにしたがつて、だんだんかうした新宿が嫌ひになつた。",
              "citation": {
                "source": "悲しい新宿",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう美しさも慣れると美しさを感じなくなるだろうという人もあるが、そうとは限らない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "これにつけても子供の教育は大切で、早くから人に慣れるやうに交際社會へ出してやらぬと、皆私のやうな變人になつてしまふ。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明るい所から暗い所に這入ったので、目の慣れるまではなんにも見えなかった。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "ともよは、初めは少し窮屈な客と思っていただけだったが、だんだんこの客の謎めいた眼の遣り処を見慣れると、お茶を運んで行ったときから鮨を喰い終るまで、よそばかり眺めていて、一度もその眼を自分の方に振向けないときは、物足りなく思うようになった。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殺風景だと思っていたコンクリートの倉庫も見慣れると賤が伏屋とはまたちがった詩趣や俳味も見いだされる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もしも、これで百歳まで生きる覚悟があったら、自分はやっぱり奮発していやな品に慣れる努力をするであろう。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし慣れるに従って星がだんだんにのろく見えて来る、一秒という時間が次第に長いものに感ぜられて来る。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "過去の世界で育ち過去の思想で固まった年寄りの自分らが、新しい世界を歩き、新しい思想に慣れるまでの難儀さ迷惑さはどのくらい大きいものか、若い人には想像するさえむつかしいであろうと思われる。",
              "citation": {
                "source": "試験管",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん見慣れるに従って頭の中の三毛の記憶の影像が変化して眼前の生きたものに吸収され同化されて行く不思議な心理過程に興味を感じた。",
              "citation": {
                "source": "備忘録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "均平は町の様子でも見ようと思い、さっき通って来た方へ歩いて行ったが、寂しいこの町も見慣れるにつれて、人の姿も目について来て、大通りらしい処へ出ると、かなりの薬局や太物屋、文房具屋などが、軒を並べていた。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "定律詩の困難は、最初に押韻の方則を覺え、その格調の心像を意識に把持する、即ち所謂「調子に慣れる」迄である。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "永久に、最後まで、調子に慣れるといふことがない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを十六本、右｜撚りなら右撚りに、最初は出来ないけれども少し慣れると訳なく出来ますことで、片撚りに撚る。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを十六本、右撚りなら右撚りに、最初は出来ないけれども少し慣れると訳なく出来ますことで、片撚りに撚る。",
              "citation": {
                "source": "幻談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そればかりではない、話に上ずつて來た先生の風貌は眼慣れるに從つて、堪らなく貧弱な、下品な物に見えて來た。",
              "citation": {
                "source": "猫又先生",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼が暗さに慣れるにつれ、中に散乱した彫像、器具の類や、周囲の浮彫、壁画などが、ぼうっと眼前に浮上って来た。",
              "citation": {
                "source": "木乃伊",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿の主は、先生を娘時から知っていて、「詩的に言えば、あゝいう女人が奥山に住み慣れると山姫になってしまうのじゃないですかな」と評しました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと慣れるようにし給え」　彼は掌を突き出して栖子を逐った。",
              "citation": {
                "source": "唇草",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は慣れることが出来ない。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "所で、一体、阿片の快楽に慣れるためには、はじめ一方ならぬ不快と苦痛とを忍ばねばならぬという。",
              "citation": {
                "source": "鏡花氏の文章",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにしろ流沙河で最も深い谷底で、上からの光もほとんど射して来ない有様ゆえ、悟浄も眼の慣れるまでは見定めにくかったが、やがて、薄暗い底の台の上に結跏趺坐したまま睡っている僧形がぼんやり目前に浮かび上がってきた。",
              "citation": {
                "source": "悟浄出世",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくまだ自覚しない将来の使命に慣れるための練習を無意識にしているのかもしれない。",
              "citation": {
                "source": "ねずみと猫",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろ連日射ってしまった方が身体が慣れるとのことで、一日置きは副作用の面では、負担の大きい選択でした。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとことでいってしまうならば、それは、われわれが印刷という複製技術が存在しない世界に慣れるまでにかかるであろう時間である。",
              "citation": {
                "source": "本はどのように消えてゆくのか",
                "author": "津野海太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し目の慣れるまで、歩き艱んだ夕闇の田圃道には、道端の草の蔭で※が微かに鳴き出していた。",
              "citation": {
                "source": "百物語",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "慣れると、なかなか気持のよいものである。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼は、毛布も何も一切掛けずに、ただ寝巻を着たままでベッドの上にごろ寝をしているのだが、慣れると清潔な感じがして来て、かえって気持がいい。",
              "citation": {
                "source": "パンドラの匣",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が異国人と夜のまったく明けはなれるまで談じ合うほど語学ができるかどうか、そういうことからして怪しいもんだと私は思っている。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も誰でも熾んに考へた直ぐ後体感的な気持になれるものではない。",
              "citation": {
                "source": "高橋新吉論",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
