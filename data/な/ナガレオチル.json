[
  {
    "uuid": "29f05b6e-dceb-541c-9d4a-a95d45599f30",
    "entry": "流れ落ちる",
    "reading": {
      "primary": "ながれおちる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-一段"
      ],
