        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "だから、国境を越えた哀れな旅人たちは、暫らくのあいだは茫然自失の体で、全身にかいた冷汗を拭き拭き十字を切りながら、ただ『えい、何てこった！",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「やれやれ、何てこった。",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝から晩まで流しの上には、よごれものがたまって新らしい茶碗の縁が三日と無疵で居たためしがないとなあ、三十九にもなって何てこったし、あまり昼、夫婦づれで、仮寝ばかりしているからだなっし、貴方。",
              "citation": {
                "source": "農村",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「ええ何てこったい？",
              "citation": {
                "source": "可愛い女",
                "author": "DUSHECHKA",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何て……何てこったろうほんとに」　シットリと湿けた枝差しだしている傍らの柘榴の股になっているところへのせて置いたお線香二本、つづいて圓朝は左右の線香立てへ供えた。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「フーム……何て……何てこったろう小勇が……」　文字通り開いた口が塞がらなかった。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「旦那をおいて、貴様のその言い草は何てこった。",
              "citation": {
                "source": "次郎物語",
                "author": "第一部",
                "note": "青空文庫"
              }
            },
            {
              "text": "ブスマン　何てこった！",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "……なんてこった、敵前でぼんやり腹を見せて縦隊行進をするなんて！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「……なんてこった！",
              "citation": {
                "source": "はだかの王さま",
                "author": "THE EMPEROR'S NEW SUIT",
                "note": "青空文庫"
              }
            },
            {
              "text": "人をだましていい生活をするほど悪がしこくないから、だんだん追いつめられて、あんなばかげたことをして、二円、三円を強奪して、そうして五年も十年も牢へはいっていなければいけない、はははは、おかしい、おかしい、なんてこった、ああ、ばかばかしいのねえ。",
              "citation": {
                "source": "燈籠",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてこった、じぶんが計画をたて隊長にまでなりながら、まさに出発という間際にスイと身を退くなんて……これまで度胸六分の戦車的突進を誇りとした彼を思えば、ますます分らなくなってくる。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ちぇっ、なんてこったい！",
              "citation": {
                "source": "接吻",
                "author": "ПОЦЕЛУЙ",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんてこった」　と俺が思わず叫ぶと、ロボットは腕をおろし、無表情で元の場所に戻った。",
              "citation": {
                "source": "理想",
                "author": "THE IDEAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんになんてこった」　庭番もやはりいくらかけげんそうな様子だったが、大したことでもなく、またちょっと小首をひねった後、くるりと向きを変え、自分の小部屋へ引っ込んでしまった。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとに、なんてこったろう。",
              "citation": {
                "source": "源蔵ヶ原",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんてこった、けったいだ。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてこった、ナイフが無ければ、全員一度にのしてやるんだが。",
              "citation": {
                "source": "幽霊島",
                "author": "The Island of Shadows",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてこった、見ろ。",
              "citation": {
                "source": "鉄面皮",
                "author": "A Front of Brass",
                "note": "青空文庫"
              }
            },
            {
              "text": "私が二、三回忠告しましたが、なんてこった、聞き入れません。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
