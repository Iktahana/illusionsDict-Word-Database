        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とまれ何者かに依拠してゐるのは事実であらう。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然と人とは互に冥通する何者かを失うことなしに或は争い或は親しんだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かが起き上らうとしてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かが、その樹に體を縛られたまま、起き上らうとしてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし私が今までとは別な何者かであるとしたら、自分にはいかなる知人もないことは明らかなことだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉を踏んで頂に達し、例の天主台の下までゆくと、寂々として満山声なきうちに、何者か優しい声で歌うのが聞こえます、見ると天主台の石垣の角に、六蔵が馬乗りにまたがって、両足をふらふら動かしながら、目を遠く放って俗歌を歌っているのでした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "又かの怪しい女は何者か、その女と藤吉とのあいだに何かの関係があるのか無いのか、役人たちもその判断に苦しんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師の診断によると、おみよは何者かに絞め殺されたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると、何者かがおみよを絞め殺して、その帯を解いて抱え出して、わざわざ帯取りの池へ投げ込んだものであろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍視をしてはなりませぬぞ」　何者かが何処かで自分を窺っているのだと気がついて、お蝶も急に身を固くした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "お作は何者かを咎めるような口ぶりで、「誰、そこから覗くのは誰」と云っているのが耳にはいったので、おそらく近所の若い者が戯ってでもいるのであろうと思いながら、お伊勢は蚊いぶしを煽いでいる団扇の手をやめて、台所の方を見かえると、うす暗いところに一人の女が立っている姿がぼんやりと浮かんで見えた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、こういうことは、自分の意志に反して、何者かに促されてやっているのだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かに取ッつかれたようだった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "森の中を行っている者が、何者かにびっくりしたもののようにパチパチうちだした。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "前者は川沿いのある芝地を空風の吹く夜中に通っていると、何者かが来て不意にべろりと足をなめる、すると急に発熱して三日のうちに死ぬかもしれないという。",
              "citation": {
                "source": "化け物の進化",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると何者かが確かに僕の背なかにくっつくようにして足を止めた。",
              "citation": {
                "source": "郊外",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "片側の商店の、夥しい、瓦斯、洋燈の灯と、露店のかんてらが薄くちらちらと黄昏の光を放って、水打った跡を、浴衣着、団扇を手にした、手拭を提げた漫歩の人通、行交い、立換って賑かな明い中に、榎の梢は蓬々としてもの寂しく、風が渡る根際に、何者かこれ店を拡げて、薄暗く控えた商人あり。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "此時にふと心付くと、何者か私の後にこそ／＼と尾行して來る樣子、オヤ變だと振返る、途端に其影は轉ぶが如く私の足許へ走り寄つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と彼は日頃の豪壯なる性質には似合はぬ迄、氣遣はし氣に、恰も何者か空中に力強き腕のありて、彼を此塲に捕へ居るが如くいとゞ立去り兼ねて見へた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど私は心付くと、響の源は决して近い所ではなく、四邊がシーンとして居るので斯く鮮かに聽えるものゝ、少くも三四｜哩の距離は有るだらう、何は兎もあれ斯る物音の聽ゆる以上は、其處に何者かゞ居るに相違ない、人か、魔性か、其樣な事は考へて居られぬ、兎に角探險と覺悟したので、そろ／＼と丘を下つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "この何者かは誰にも分らぬ。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かこれ、天地を枕衾として露下月前に快眠せる漢子は、数歩のうちにありて※を立てつ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "白糸はひたと雨戸に身を寄せて、何者か来たるとかんと面を顰めつつ、よたよたと縁を伝いて来たりぬ。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ずほっとして歩きながら、更に考え直すと、女は何者か知れないが、暗い夜道のひとり歩きがさびしいので、恐らく私のあとに附いて来たのであろう。",
              "citation": {
                "source": "御堀端三題",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "加之も堆かき枯葉を蹴って、何者かと挑み闘うように聞えた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かと松明を突き付ける間もなく、彼は蝗の如くに飛んで来て、七兵衛の持ったる松明を叩き落した。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（三十一）　この時、背後の方から不意に物の気息が聞えて、何者か忍び寄るようにも思われたので、市郎は手早く蝋燭を把って起上ると、余りに慌てたので、彼は父の死骸に蹉いた。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "市郎は眼を定めて熟視ると、穴の入口と覚しき所で何者か火を照しているらしく、其光に映じて例の金色が見えつ隠れつ漂うのであった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜村境で発見した惨殺死体は、面の皮を剥がれているので何者か判らぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男も言語不通であるから何者か未だ判らぬ。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
