[
  {
    "uuid": "614321df-3981-54ba-8eea-311cff51486f",
    "entry": "成り立つ",
    "reading": {
      "primary": "なりたつ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
