    "definitions": [
      {
        "index": 1,
        "gloss": "people living on Honshu",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "坂をおりて、内地人町の大通りへ出てから、友達はもう家へ帰ると言出した。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "三　ここらの驟雨は内地人が想像するようなものではなかった。",
              "citation": {
                "source": "麻畑の一夜",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "見たところは内地人にちっとも変らず、言葉は純粋の鹿児島弁でした。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の母親は内地人だと皆が云っていた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "口には出さなかったけれども、神経質な彼が此の事についても又、事新しく、半島人とか内地人とかいう問題にくよくよ心を悩ましたろうことは推察に難くない。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "――裸の、弱虫の、そして内地人ではない、半島人の、彼を見せてくれたことが、私に満足を与えたのだった。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人の、茶色の髭を伸ばした、これは一見して内地人ではないと解る方の男にも私は一寸頭を下げた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈍い目に微かに好奇心と怯えとを見せて、此の島には珍しい内地人たる私の姿に見入つてゐた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラオ女には珍しく緊つた顏立で、恐らく内地人との混血なのではなからうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官は、此の用件と、もう一つ僻遠諸離島の人頭税取立てとを兼ねて、一人の島民巡警を引連れ、内地人の乘ることなど殆ど無い・そして年に僅か三囘位しか通はない此の離島航路の小船に乘つたのであつた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年について一歩日向の砂の上に踏出した時、タマナ樹の梢から眞白な一羽のソホーソホ鳥（島民が斯う呼ぶのは鳴き聲からであるが、内地人は其の形から飛行機鳥と名付けてゐる）が、バタ／＼と舞上つて、忽ち、高く眩しい碧空に消えて行つた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤ、この土俗學者先生、中々油斷がならないな、と驚いてゐる中に、扉をあけてはひつて來たのが、内地人ではなく、堂々たる體躯の島民女だつたので、もう一度私は驚いた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、内地人の集まりの場所で、偶※私が山本有三氏の名を口にしたところ、それはどういふ人ですと一齊に尋ねられた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、マリヤンは、内地人をも含めてコロール第一の讀書家かも知れない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方など、何時も内地人の商人の細君連の縁臺などに割込んで話してゐる。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見日本人との混血と分る顏立だが、二人とも内地人の標準から見ても確かに美人である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "※トラック　月曜島には、公學校校長の家族の外に内地人はゐない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈍い目に微かに好奇心と怯えとを見せて、この島には珍しい内地人たる私の姿に見入っていた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラオ女には珍しく緊った顔立で、恐らく内地人との混血なのではなかろうか。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官は、この用件と、もう一つ僻遠諸離島の人頭税取立てとを兼ねて、一人の島民巡警を引連れ、内地人の乗ることなどほとんど無い・そして年に僅か三回位しか通わないこの離島航路の小船に乗ったのであった。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年について一歩日向の砂の上に踏出した時、タマナ樹の梢から真白な一羽のソホーソホ鳥（島民がこう呼ぶのは鳴き声からであるが、内地人はその形から飛行機鳥と名付けている）が、バタバタと舞上って、たちまち、高く眩しい碧空に消えて行った。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤ、この土俗学者先生、なかなか油断がならないな、と驚いている中に、扉をあけてはいって来たのが、内地人ではなく、堂々たる体躯の島民女だったので、もう一度私は驚いた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "或る時、内地人の集まりの場所で、たまたま私が山本有三氏の名を口にしたところ、それはどういう人ですと一斉に尋ねられた。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐らく、マリヤンは、内地人をも含めてコロール第一の読書家かも知れない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方など、いつも内地人の商人の細君連の縁台などに割込んで話している。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "一見日本人との混血と分る顔立だが、二人とも内地人の標準から見ても確かに美人である。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "※トラック　月曜島には、公学校校長の家族の外に内地人はいない。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "パラオ女には珍しく緊つた顔立で、恐らく内地人との混血なのではなからうか。",
              "citation": {
                "source": "夾竹桃の家の女",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この男は沖縄人で相貌が内地人らしくないので疾うから覘われていたのだそうだと、当人が後に来ての話である。",
              "citation": {
                "source": "最後の大杉",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちこの時以来内地人はどしどし沖縄に這入って来る、沖縄人はぞろぞろ内地へ出て行く、士族は田舎へ下って行く、田舎人は都会に集って来る、といったように、沖縄がかきまぜられた。",
              "citation": {
                "source": "進化論より見たる沖縄の廃藩置県",
                "author": "伊波普猷",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
