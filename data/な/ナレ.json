[
  {
    "uuid": "90faa76c-68f9-5879-99f6-85a103f7f42b",
    "entry": "慣れ",
    "reading": {
      "primary": "なれ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
