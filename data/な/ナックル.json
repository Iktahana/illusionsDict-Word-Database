        "examples": {
          "standard": [
            {
              "text": "転んで手を地面についた時、思い切り指のナックルを擦りむいてしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "ボクサーは拳を保護するために、バンテージを巻いてからグローブをはめるが、特にナックル部分は厳重に保護される。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "古武術には、ナックルを使って相手の急所を狙う技がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "新潮社装幀室の緒方修一氏には、デザインのお世話になっただけでなく、決定的な場面で事態を打開する、ナックル・ボールのような数々の助言をいただいた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
      {
