[
  {
    "uuid": "bcc8f932-2245-5500-b570-64dc2ff850c8",
    "entry": "投げ出す",
    "reading": {
      "primary": "なげだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
