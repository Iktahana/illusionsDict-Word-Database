    "definitions": [
      {
        "index": 1,
        "gloss": "bush clover blossoming in the summer (esp. Lespedeza thunbergii)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "萩も夏萩などがあつて、梅雨あがりのしめつた地に咲き枝垂れてゐるのを見る。",
              "citation": {
                "source": "秋草と虫の音",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその床几と人物の背後には、夏萩があります。",
              "citation": {
                "source": "虹と感興",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏萩は白い花をいい頃合に着けて、夕暮れ頃の雨上りの露を含んでおります。",
              "citation": {
                "source": "虹と感興",
                "author": "上村松園",
                "note": "青空文庫"
              }
            },
            {
              "text": "「末枯」「さざめ雪」「三の切」「冬至」「影繪」「夏萩」「潮の音」「老犬」の八篇、何れも無戀愛小説である。",
              "citation": {
                "source": "貝殼追放",
                "author": "「末枯」の作者",
                "note": "青空文庫"
              }
            },
            {
              "text": "庭の桔梗の紫｜揺き、雁来紅の葉の紅｜戦ぎ、撫子の淡紅｜靡き、向日葵の黄｜頷き、夏萩の臙脂乱れ、蝉の声、虫の音も風につれて震えた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "左側は祠で、一番太鼓のとゞろきと共にそこへお燈明がさし入れられ、ほんのりその灯が夏萩の茂みを濡らした。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「本郷若竹亭」と前書して、夏萩や小せんおぶはれ楽屋入りの句が私にあるが、盲で腰の立たなかつた先代小せんを車夫がおぶつて楽屋入りして行く哀れの姿は、ほんたうは向つて右側の庭を通つていつたのだから、おそ夏の夜更け、病小せんの襟首冷やりと濡らしたものは、じつは夏萩ではなく丈高い若竹の葉の露であつたらう。",
              "citation": {
                "source": "寄席風流",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "この墓、暮春は傍らの亭々たる梨の大木が青白い花を悩ましく咲かせ、盛夏は夏萩が濃やかに門人ぽん太の墓碑を覆ひかくすのが常である。",
              "citation": {
                "source": "根津遊草",
                "author": "正岡容",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
