    "definitions": [
      {
        "index": 1,
        "gloss": "Homage to the Three Jewels (Buddha, Dharma and Sangha)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（どなた、）と納戸の方でいったのは女じゃから、南無三宝、この白い首には鱗が生えて、体は床を這って尾をずるずると引いて出ようと、また退った。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「南無三宝、はははは。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝、こりゃ加州まで行くことかと息切がして蒼くなりましたね。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝声がかかった。",
              "citation": {
                "source": "春昼後刻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに背後に人の足音が聴こえたので、南無三宝！",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "部室の外にどやどやと跫音して、二三人が来れる様子に、南無三宝飛び退りて再び日蔽の影に潜みぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹五郎　南無三宝、堂の下で誓を忘れて、鐘の影を踏もうとした。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……南無三宝、赤蜻蛉は颯と外れた。",
              "citation": {
                "source": "みさごの鮨",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "このふっくりした白いものは、南無三宝仰向けに倒れた女の胸、膨らむ乳房の真中あたり、鳩尾を、土足で蹈んでいようでないか。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝、魔物の唾じゃ。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほい、」　と視めて、「南無三宝。",
              "citation": {
                "source": "歌行燈",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝、電光に幕あるのみ。",
              "citation": {
                "source": "陽炎座",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝三十銭、支出する小遣がないから払ふ訳に往かない。",
              "citation": {
                "source": "いろ扱ひ",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――南無三宝、茶が切れた。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何方、）と納戸の方でいつたのは女ぢやから、南無三宝、此の白い首には鱗が生へて、体は床を這つて尾をずる／″＼と引いて出やうと、又退つた。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としめやかに朱唇が動く、と花が囁くやうなのに、恍惚して我を忘れる雪枝より、飛騨の国の住人以つての外畏縮に及んで、「南無三宝、あやまり果てた。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝と呆気に取られて、目を※った鼻っ先を、件の蝙蝠は横撫に一つ、ばさりと当てて向へ飛んだ。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と考え出すと、南無三宝、も一つの瓶には蝮が居たぞ、ぐるぐると蜷局を巻いた、胴腹が白くよじれて、ぶるッと力を入れたような横筋の青隈が凹んで、逆鱗の立ったるが、瓶の口へ、ト達く処に、鎌首を擡げた一件、封じ目を突出る勢。",
              "citation": {
                "source": "沼夫人",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝、此の柱へ血が垂れるのが序開きかと、其十字の里程標の白骨のやうなのを見て居る中に、凭かゝつて居た停車場の朽ちた柱が、風もないに、身体の圧で動くから、鉄砲を取直しながら後退りに其処を出た。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "元治元年、私が中津に行て、小幡篤次郎兄弟を始め同藩子弟七、八名に洋学修業を勧めて共に出府するときに、中津から先ず船に乗て出帆すると、二、三日天気が悪くて、風次第で何処の港に入るか知れない、スルと南無三宝、攘夷最中の長州室津と云う港に船が着た。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、忽然と浮き上がって来たのは、南無三宝！",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無三宝、これはたまらぬ」　あわてて彼は逃げかけた。",
              "citation": {
                "source": "北斎と幽霊",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　怒りを発した右近丸は今は平素の思慮も忘れ、ひたむきに一本の道を辿り、サーッばかりにひた走ったが、ハッとばかりに気が付いて立止まって背後を振り返ったが、「南無三宝！",
              "citation": {
                "source": "南蛮秘話森右近丸",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝草の根につまずき、「あッ」　倒れた！",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と義党の面々、三十郎の一味の後を、真一文字に追っかけたが、南無三宝機を失した！",
              "citation": {
                "source": "猫の蚤とり武士",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、扨て、愈々第一の人物に会見し、南無三宝！",
              "citation": {
                "source": "金談にからまる詩的要素の神秘性に就て",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何さ、お前さんの前身が闇を世界の姐御などにはとても見えねえと云ったまでさ」南無三宝！",
              "citation": {
                "source": "赤格子九郎右衛門の娘",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「さっき名のった言葉によれば、日本全国六十余州に、散在している陰陽師の司、中御門中納言の由縁の者、山尾とか申す女の由……」　それを聞くと思わず五右衛門は、よろよろと背後へよろめいたが、「南無三宝！",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南無三宝」と心の中で叫び、島君は身を反わせて遁がれようとしたが早くもその肩を掴まれた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南無三宝｜躊躇はならぬと一散に木蔭より駈け出したものの彼らの群へ行き着くより先に、火が地雷火へはいったなら、万事休すと考えて、駈け行く足が縮むばかり、その時｜忽然と浮かびましたのは、受け剣と共に習い覚えたる投げ剣の一手にござります。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
