      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "catfish (esp. the Amur catfish, Silurus asotus)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "もしも温度の影響が大きくその他の微細な雑多の影響が収斂しなかったら、ゼンマイ秤で目方を測るのは瓢箪で鯰を捕える以上の難事であろう。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ときどきは不精そうな鯰も来た。",
              "citation": {
                "source": "鮨",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この古池の底には大きい鯰の主が住んでいると、一人の女が教えてくれたのでお蝶はぞっとした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "今頃は鯉か鯰の餌食になりよろう。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "どじょう、鯰、鼈、河豚、夏はさらし鯨――この種の食品は身体の精分になるということから、昔この店の創始者が素晴らしい思い付きの積りで店名を「いのち」とつけた。",
              "citation": {
                "source": "家霊",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と鯰が這うように黒被布の背を乗出して、じりじりと灸を押着けたもの、堪ろうか。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、勇んだの候の、瓜井戸の※は、べたりだが、江戸ものはころりと來るわ、で、葛西に、栗橋、北千住の鰌鯰を、白魚の氣に成つて、頤を撫でた。",
              "citation": {
                "source": "片しぐれ",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、勇んだの候の、瓜井戸の姉はべたりだが、江戸ものはコロリと來るわ、で、葛西に、栗橋北千住の鰌に鯰を、白魚の氣に成つて、腮を撫でた。",
              "citation": {
                "source": "二た面",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……洋服のもっ立尻を浮かして、両手を細工盤について、ぬッと左右の鯰髯。",
              "citation": {
                "source": "ピストルの使い方",
                "author": "――（前題――楊弓）",
                "note": "青空文庫"
              }
            },
            {
              "text": "いまは、その跡を慕って大鯰が池から雫をひたひたと引いて襲う気勢がある。",
              "citation": {
                "source": "怨霊借用",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰々だって、そういいましたら、伊豆の伊八、四丁艪の甚太夫、鯰の勘七、縄抜の正太郎、飛乗の音吉、秋刀魚の竹蔵、むささびの三次、――あのこの人の声だったんです、私に奥様のことを教えましたのは、」　夫人はお鶴の記憶の可いのと、耳の敏い、利発さと、そのかくのごとき運命とに、ただ何となく慄然とした。",
              "citation": {
                "source": "わか紫",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生め、鯰じゃねえか。",
              "citation": {
                "source": "浮舟",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」給仕に居てくれた島田髷の女中さんが、「鯰ですの。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」鯰の魚軒、冷たい綿屑を頬張つた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いや、羹も食はず、鯰を吐いた。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "港を前に鯰の皿、うらなつて思ふに、しけだなあ。",
              "citation": {
                "source": "麻を刈る",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　遥々と参った。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　（杖を袖にまき熟と視て）さては縁のない衆生でないの。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟹五郎　鯰入は御坊かい。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　これは、いずれも姫君のお身内な。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　（ふと、くなくなとなって得進まず。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　いやいや疲れはしませぬ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　ここまで辿って、いざ、お池へ参ると思えば、急にこの文箱が、身にこたえて、ずんと重うなった。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　（悄然として）いや、私が身に応えた処は、こりゃ虫が知らすと見えました。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……鯰入　いやいや、急に文箱の重いにつけて、ふと思い出いた私が身の罪科がござる。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　笑われますか、情ない。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　はあ、（とどうと尻餅つく。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　やあ、何と、……それを頼みたいばッかりに恥を曝した世迷言じゃ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　（わななきながら、文箱を押頂き、紐を解く。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "鯰入　文箱の中は水ばかりよ。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
