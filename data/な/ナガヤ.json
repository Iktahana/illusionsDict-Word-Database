        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "裏町の長屋｜住いをしていた蕪村。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "即ち蕪村は、ここで裏長屋の女房を指しているのである。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを故意に漂母と言ったのは、一つはユーモラスのためであるが、一つは暗にその長屋住いで、蕪村が平常世話になってる、隣家の女房を意味するのだろう。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "侘しい路地裏の長屋住い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＴＭの家の前が加賀様の盲長屋である。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのボロボロの長屋に柿色や萌黄の蛇の目の傘が出入りしている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蒲団を積んだ手荷車が盲長屋の裏を向うへ、ゆるやかな坂を向うへ上って行く。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それと、もう一つ、宅の門脇の長屋に住んでいた重兵衛さんの一家との交渉が自分の仮想的自叙伝中におけるかなり重要な位置を占めているようである。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "まさかあの聖諦の乙姫が、そんな長屋の夫婦喧譁みたいな事をたくらむとは考へられない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸の底で可笑しい位の事だから、二軒の長屋の主婦も、感慨無量な顔を見合はせて、「まあ」　と云つたまゝ、涙をこぼしながら笑ひ出した。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして弁当箱を首に巻きつけて、一杯飲んで食うことを専門に考えながら、彼の長屋へ帰って行った。",
              "citation": {
                "source": "セメント樽の中の手紙",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "余り帰りが遅くなるので、秋山の長屋でも、小林の長屋でも、チャンと一緒に食う筈になっている、待ち切れない夕食を愈々待ち切れなくなった、餓鬼たちが騒ぎ出した。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内一の財産家といふに、家内は祖母と此子二人、萬の鍵に下腹冷えて留守は見渡しの總長屋、流石に錠前くだくもあらざりき、正太は先へあがりて風入りのよき塲處を見たてゝ、此處へ來ぬかと團扇の氣あつかひ、十三の子供にはませ過ぎてをかし。",
              "citation": {
                "source": "たけくらべ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ、わたしはどこへ行くのか知らない、わたしのゆく道路の方角では、長屋の家根がべらべらと風にふかれてゐる、道ばたの陰気な空地では、ひからびた草の葉つぱがしなしなとほそくうごいて居る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝長屋の表　其処まで三次送って来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "勝坊長屋の奥を示して、Ｔ「この奥に姉ちゃんと二人で居るんだよ」　と言う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次にさあ早くお帰りと言われて何度も振り返って笑ったり手を振ったりし乍ら長屋の奥へ消えて行く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局三次追い詰められてお絹の長屋へ飛び込んだ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋の内部に　逃げ込んだ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋表　棚倉一味と捕方が、Ｔ「確にこの長屋だ――」　と叫ぶ。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋の外　捕方の一人が、Ｔ「もう袋の鼠だ」　と云う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "棚倉等は長屋へ入る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄五郎が、Ｔ「今其処の長屋へ盗人が逃げ込んだのだ」　三次何喰わぬ顔で「そうですかい」と云う。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋　棚倉等と捕方が協力して長屋を一軒一軒調べる。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）Ｓ＝長屋　井戸端でお内儀さん二三人の立ち話し。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋の表　三次淋しく出て来た。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｓ＝長屋の夜　棚倉一味の門弟がお絹を引抱えて無理に駕籠に押し込めて担ぎ去る。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんながやっとその栗の木の下まで行ったときはその変な子はもう見えませんでした。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "短い沈黙の後に、聞耳たてたひそひそばなしと、頓興ながやがや声とが入りまじつて起つた。",
              "citation": {
                "source": "夜烏",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下では、みんながやがや騒いでいる。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
