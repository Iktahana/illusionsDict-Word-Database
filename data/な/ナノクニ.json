    "definitions": [
      {
        "index": 1,
        "gloss": "Country of Na (a country that existed within Japan during the Yayoi period)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "爾は奴国の者であろう。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾は奴国の貴族であろう。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "爾は奴国の王子であろう。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "不弥のために奴国の王子を刺し殺せ。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴国の者が宮に這入った。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴国の者は何処へ行った。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「奴国の者を外へ出せ。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「彼は奴国の王子である。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　奴国の宮は、山の麓の篠屋の中から騒ぎ始めた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥え太った奴国の宮の君長は、童男と三人の宿禰とを従えて櫓の下で、痩せ細った王子の長羅と並んでいた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "長羅は過ぎた狩猟の日、行衛不明となって奴国の宮を騒がせた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「長羅よ、見よ、奴国の女は美しい。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は奴国の宮の乙女たちの中では、その美しい気品の高さにおいて嶄然として優れていた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "来れ、我は今宵爾に奴国の宮を与えよう。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "五　奴国の宮の鹿と馬とはだんだんと肥えて来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　奴国の宮からは、面部の※形の刺青を塗り潰された五人の使部が、偵察兵となって不弥の国へ発せられた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「奴国の宮で、もっとも美しき者は爾である。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "七　不弥の国から一人の偵察兵が奴国の宮へ帰って来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「爾は奴国の弓弦の弱むを欲するか。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、第三の偵察兵が奴国の宮へ帰って来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく、兵士を召集する法螺と銅鑼が奴国の宮に鳴り響いた。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、長羅を先駆に立てた奴国の軍隊は、兵部の宿禰の家の前を通って不弥の方へ進軍した。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "卑弥呼、我とともに爾は奴国へ来れ。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、奴国の兵士たちは血に濡れた剣を下げて、長羅の方へ乱入して来ると口々に叫び合った。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに続いて、血に塗られた奴国の兵の鉾尖が、最初の朝日の光りを受けてきらめきながら、森の方へ揺れて来た。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "葎と薊の花を踏みにじって奴国の方へ馳けていった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは不弥の国から引き上げて来た奴国の兵士たちの明りであった。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴国の武器庫を飾るであろう。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "我とともに、奴国の宮にとどまれ。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴国の亥猪は不弥の鹿より脂を持つであろう。",
              "citation": {
                "source": "日輪",
                "author": "横光利一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
