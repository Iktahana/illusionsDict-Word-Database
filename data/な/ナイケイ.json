          "literary": [
            {
              "text": "このナットの外径は二〇ミリ、内径は五ミリほどとする。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "五円玉の、ナットの外にはみだした部分がヴェランダ、内径のほうにはみだした部分が、中央階段の周囲をめぐっている廊下になる。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙のでる土管は、内径が二十｜糎くらいしかなかったのだ。",
              "citation": {
                "source": "四次元漂流",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "全くよくないけいこうですよ。",
              "citation": {
                "source": "秋果",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            }
          ]
        }
