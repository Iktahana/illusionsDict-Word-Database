[
  {
    "uuid": "eb614f52-6ceb-53c9-b1e4-87c45678eb62",
    "entry": "何者",
    "reading": {
      "primary": "なにもの",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
