      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "who",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "とまれ何者かに依拠してゐるのは事実であらう。",
              "citation": {
                "source": "我が詩観",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者とも知れぬ権威の命令で、自分は未来｜永劫この闇の中に封じ込められてしまったのだと思う。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自然と人とは互に冥通する何者かを失うことなしに或は争い或は親しんだ。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「殿、我良人、我子、これや何者」とて高く笑ひぬ。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "青空はぐん／＼伸びてゆく、何者がそれを阻むことが出來よう。",
              "citation": {
                "source": "編輯後記（大正十五年九月號）",
                "author": "『青空』記事",
                "note": "青空文庫"
              }
            },
            {
              "text": "さう周圍が眞暗なため、店頭に點けられた幾つもの電燈が驟雨のやうに浴せかける絢爛は、周圍の何者にも奪はれることなく、肆にも美しい眺めが照し出されてゐるのだ。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かが起き上らうとしてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者かが、その樹に體を縛られたまま、起き上らうとしてゐる。",
              "citation": {
                "source": "旗手クリストフ・リルケ抄",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてもし私が今までとは別な何者かであるとしたら、自分にはいかなる知人もないことは明らかなことだ。",
              "citation": {
                "source": "「マルテ・ロオリッツ・ブリッゲの手記」から",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "この不思議な事件の犯人は何者だらう？",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "恐るべき何者もなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は、今、気がねをすべき何者もなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何者にもとらわれることはいらなかった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "初めは何者とも知れませんでしたが、森を出て石垣の下に現われたところを見ると、十一か十二歳と思わるる男の子です。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "落葉を踏んで頂に達し、例の天主台の下までゆくと、寂々として満山声なきうちに、何者か優しい声で歌うのが聞こえます、見ると天主台の石垣の角に、六蔵が馬乗りにまたがって、両足をふらふら動かしながら、目を遠く放って俗歌を歌っているのでした。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽車が大磯を出ると直ぐ（吾等二人ぎりになつたので）『義母今の連中は何者でしよう。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "余にはこの翁ただ何者をか秘めいて誰一人開くこと叶わぬ箱のごとき思いす。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずかずかと歩み寄りて何者ぞと声かけ、燈をかかげてこなたの顔を照らしぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夜｜更けて何者をか捜す」「紀州を見たまわざりしか」「紀州に何の用ありてか」「今夜はあまりに寒ければ家に伴わんと思いはべり」「されど彼の寝床は犬も知らざるべし、みずから風ひかぬがよし」　情ある巡査は行きさりぬ。",
              "citation": {
                "source": "源おじ",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを知っているらしい彼の女は、いったい何者であろうかと、お徳は不安に思った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女はいってえ何者だろう」「ねえ、もしや川から出て来たんじゃ無いかしら」と、お徳は摺り寄ってささやいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "又かの怪しい女は何者か、その女と藤吉とのあいだに何かの関係があるのか無いのか、役人たちもその判断に苦しんだ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体その怪談がかった女は何者ですか」「いま時の方はまさか鯉の雌が女に化けて、自分の雄を取り返しに来たとも思わないでしょうが、昔の人間はみんなそう思ったんですよ」と、老人はまた笑った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "むらさき鯉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「一体その男は何者だか、おまえさんはちっとも知らねえか」「知りません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お化け師匠",
                "note": "青空文庫"
              }
            },
            {
              "text": "その帯の持主は、市ヶ谷｜合羽坂下の酒屋の裏に住んでいるおみよという美しい娘で、おみよは何者にか絞め殺されているのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "医師の診断によると、おみよは何者かに絞め殺されたのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "して見ると、何者かがおみよを絞め殺して、その帯を解いて抱え出して、わざわざ帯取りの池へ投げ込んだものであろう。",
              "citation": {
                "source": "半七捕物帳",
                "author": "帯取りの池",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍視をしてはなりませぬぞ」　何者かが何処かで自分を窺っているのだと気がついて、お蝶も急に身を固くした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "奥女中",
                "note": "青空文庫"
              }
            },
            {
              "text": "お伝は何者にか喉笛を啖い切られて死んでいた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "大風の吹く城の向うで化猫草の穗のゆらゆらとうごいてゐてなにものかかなしい追憶の敵が笑つてゐる。",
              "citation": {
                "source": "敵",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
