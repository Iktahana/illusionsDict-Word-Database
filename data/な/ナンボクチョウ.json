    "definitions": [
      {
        "index": 1,
        "gloss": "Northern and Southern Courts (of Japan; 1336-1392)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
