    "definitions": [
      {
        "index": 1,
        "gloss": "things being very eventful at home and abroad",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
