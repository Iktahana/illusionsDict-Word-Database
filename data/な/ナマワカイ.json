[
  {
    "uuid": "f1451db5-c7d5-5f68-b1ad-beef6ff692c1",
    "entry": "生若い",
    "reading": {
      "primary": "なまわかい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
