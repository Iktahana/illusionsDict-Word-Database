        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "山賊仲間に聖者のゐたためしは先づないが、修道院の中には天使から悪魔までがずらりとゐる。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰も心で尊敬するわけではないが、非常にジャーナリスチックな交遊をしたりするから、何か仲間の足溜りの役をなす。",
              "citation": {
                "source": "非文学的文士",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしその他の場合では、罪のない笑談を言ったりして、妻や子供の家族を笑わせ、女中までも仲間に入れて、一家｜団欒の空気を作った。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "『内のパパとママとは、だれにも解らない不思議な言葉でだれにも解らない神秘のことを話している』と、学校へ行ってる男の子が、自慢らしく仲間の子供に語ったほど、それは奇妙な別世界の会話であった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分たち詩人の仲間は、すべてが單純な情熱家であり、客觀的な觀照眼を殆んどもたない。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間はかならず二十代の美青年たるべきこと。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "資金として馬場が二百円、私が百円、そのうえほかの仲間たちから二百円ほど出させる予定である。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間、――馬場が彼の親類筋にあたる佐竹六郎という東京美術学校の生徒をまず私に紹介して呉れる段取りとなった。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕はつまらん奴を仲間にいれたなあ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間にいれてやることにした。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "思えば、たいへんな仲間ばかり集って来たものさ。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いやな仲間もまた一興じゃないか。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたと仲間になるなんて！",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後を祖母が耕二の顔に向つて「フンフンフン」といふ咬みつきたいやうな、肉親仲間以外では決してされることのない笑ひを一つかけた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "従つて彼等の間では彼等が世間に向つて抱くその野望からの当然の産物として出て来なければならなかつたのは、仲間同志に於ては、その仲間の誰でもを褒めたとも譏つたとも理由の分らない噂――まあまあ噂――さうつまり噂なんだ、それを作り出さんことに閑暇がない。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等仲間の党派に変動を来すのも、半分は此の月給日のことだつた。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は、連れ出した男を此の世に於ける唯一の寄すがり者のやうに思へる心に浮々した足取で、そのフェルトをペタペタ夜道に打つつけながら、解雇された仲間で一番給料も多かつた男の下宿の方に歩んだ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "その上僕の風変りな性格が、小学生時代から仲間の子供とちがって居たので、学校では一人だけ除け物にされ、いつも周囲から冷たい敵意で憎まれて居た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の生徒や教師に対して、一人一人にみな復讐をしてやりたいほど、僕は皆から憎まれ、苛められ、仲間はずれにされ通して来た。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くの人は、仲間と一緒の方を楽しむらしい。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "地球物理談話会もほんの五、六人の仲間であったが、その中にまだ若いコールシュッター氏も交じっていた。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "地理教室の図書の管理をしていた、オットー・バシンという人も同じ仲間であったがこの人は聴講に身が入って来ると引切りなしに肩から腕を妙に大業に痙攣させるので、隣席に坐るとそれが気になって困った。",
              "citation": {
                "source": "ベルリン大学（1909-1910）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "谷を距てた上野の動物園の仲間に比べるとここのは死刑囚であろう。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういう怖い仲間とはまるで感じのちがう×というのが居た。",
              "citation": {
                "source": "鷹を貰い損なった話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの長男は自分等よりはだいぶ年長で、いつもよく勉強をしていたのでその仲間にははいらなかったが、次男の亀さんとその妹の丑尾さんとが定連のお客であった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃は男の子と女の子が遊んでいると、他の遊び仲間から「おとことおなごとおにやんべ、やんがておややができやんしょ」と云って囃し立てられるのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかも、この狸たるや、アルテミス型の少女に惚れる男のごたぶんにもれず、狸仲間でも風采あがらず、ただ團々として、愚鈍大食の野暮天であつたといふに於いては、その悲慘のなり行きは推するに餘りがある。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども彼には、彼の仲間の留學生たちに對する自己嫌惡にも似た反撥もあり、明治三十七年、九月、清國留學生のひとりもゐない仙臺醫學專門學校に入學するのでありますが、それから二箇年間の彼の仙臺に於ける生活は、彼の全生涯を決定するほどの重大な時期でありました。",
              "citation": {
                "source": "「惜別」の意圖",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、津村信夫の仲間の詩人たちは、そんな氣障なものではなかつた。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "甲府のまちはずれに仮の住居をいとなみ、早く東京へ帰住したく、つとめていても、なかなかままにならず、もう、半年ちかく経ってしまった。",
              "citation": {
                "source": "春昼",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
