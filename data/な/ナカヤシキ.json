    "definitions": [
      {
        "index": 1,
        "gloss": "daimyo's spare residence or emergency refuge",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
