[
  {
    "uuid": "55eb7b47-8490-5c93-b934-08d715f8e69e",
    "entry": "内臓",
    "reading": {
      "primary": "ないぞう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
