        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「オ早ウゴザイマス、オ爺チャンハ朝ハイツモオ早イノネ」ソウ云ッテ、竹ノ皮ニ包ンダモノヲ二本、風呂敷ヲ解イテナイトテーブルノ上ニ置ク。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕ハ足音ヲ忍バセテイッタン寝室ヲ出、二階ノ書斎ノデスクカラ螢光燈ランプヲ外シテ、ソレヲ持ッテ戻ッテ来、ナイトテーブルノ上ニ置イタ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気が付いて螢光燈を消し、ナイトテーブルの小さいスタンドだけを点して、シェードの上に布を被せた。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "………　………六時、夕食の膳がナイトテーブルに運ばれて来たのを見、病人が何か云いたいことがあるらしく口を動かす。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベッドの枕元には縁飾りも大理石も付いてないナイトテーブルがあった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸いナイトテーブルの上の蝋燭がウージェーヌの顔を照らした時、そこに表れた表情をゴリオは見ていなかった。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
