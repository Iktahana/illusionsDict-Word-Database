          "literary": [
            {
              "text": "夏やせをする質だから、今頃は出あるかねえ。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏やせで少し身細りするにはしたが、目にさびゃ吹いちゃいねえよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に引眉毛の濃い粧りは夏やせの顔をややけわしく見せ、頬も色彩らぬつかね髪の年増女。",
              "citation": {
                "source": "大正女流俳句の近代的特色",
                "author": "杉田久女",
                "note": "青空文庫"
              }
            },
            {
              "text": "人々の夏やせはいつもの年よりは、目立って見えた、蝉もないた。",
              "citation": {
                "source": "錦木",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "うなぎ屋もこの時とばかり「土用の丑の日にうなぎを食べれば健康になる」とか「夏やせが防げる」とかいって、宣伝にいとまがない。",
              "citation": {
                "source": "鰻の話",
                "author": "北大路魯山人",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
