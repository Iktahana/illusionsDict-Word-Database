  {
    "uuid": "11f4798e-c300-5771-9978-d35aea7d6073",
    "entry": "投げ込み",
    "reading": {
      "primary": "なげこみ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
