[
  {
    "uuid": "0546e567-ce56-5afd-acda-ef84162bcc5b",
    "entry": "生臭い",
    "reading": {
      "primary": "なまぐさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "形容詞"
      ],
