  {
    "uuid": "c6383545-3d7b-57a4-a8d6-6b60834a8f06",
    "entry": "流し",
    "reading": {
      "primary": "ながし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
