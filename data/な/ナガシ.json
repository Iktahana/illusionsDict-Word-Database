    },
    "definitions": [
      {
        "index": 1,
        "gloss": "sink (e.g. in a kitchen)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "合い憎のことには、私の場合、犬馬の労もなにも、興ざめの言葉で恐縮であるが、人糞の労、汗水流して、やっと書き上げた二百なにがしの頁であった。",
              "citation": {
                "source": "創作余談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり、自転車に乗って三鷹郵便局にやって来て、窓口を間違ったり等して顔から汗をだらだら流し、にこりともせず、ただ狼狽しているのである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "まえにも何回となく言って言い馴れているような諳誦口調であって、文章にすればいくらか熱のある言葉のようにもみえるが実際は、れいの嗄れた陰気くさい低声でもってさらさら言い流しているだけのことなのである。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕は馬場さんを信じています」「はあ、そうですか」私の精一ぱいの言葉を、なんの表情もなく聞き流して、「今度の雑誌のことだって、僕は徹頭徹尾、信じていません。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」大隅君は軽く受流した。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "かれは涙を流しながら笑っていた。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまりかうした作家たちが、詩や俳句を作るのは、飽食の後で一杯の紅茶をのんだり、或は労作の汗を流し、一日の仕事を終つた後で、浴衣がけに着換へて麻雀でもする気持なのだ。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に就中蕪村の如く、文化が彼の芸術と逆流しているところの、一の「悪しき時代」に生れた者は、特に救いがたく不遇である。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "いかなれば涙を流してかくも黄色く古びたる紙頁の上にわが情熱するものを情熱しつつ寂しき人生を語り續けん。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労も不平も洗い流して蘇ったようになって帰る暗闇阪は漆のような闇である。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流し元で器皿を洗っている娘の淋しい顔はいつでも曇っているように思われた。",
              "citation": {
                "source": "やもり物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の突当りの流し。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しおれた白百合やカーネーションが流しの隅に捨ててある。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "小使が流しの上へ上がって、長い棒を押し立てて、何かゴボゴボ音を立てている。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この椀を流し口の穴の上に俯向きに当てて、押したり放したり押したりまた放したりする。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流し口の穴のつまったのをこうして疎通させる工夫と見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流しの鉛管をつまらせる事は日本人の特長であるらしい。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "廊下の東詰の流しの上の明かり窓から病院の動物小屋が見える。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "流しの板のすべりそうなのを踏んで向側へ越すと柵があってその上は鉄道線路、その向うは山の裾である。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "中折帽に着流しでゴム靴をはいて、そしてひどく考え込んだような風でゆっくり歩いて来る姿をはっきり覚えているように思うのであるが、しかし、これはよくある覚えちがいであるかもしれない。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "文明の波が潮のように片田舎にも押し寄せて来て、固有の文化のなごりはたいてい流してしまった。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "鬼ども、喜んだのなんの、キヤツキヤツケタケタと奇妙な聲を發し、よだれやら涙やらを流して笑ひころげる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それどころか、所謂さつきの鯉の吹流しの、愛すべき多辯家に過ぎないのではないかと思はれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌を拔かれてしまつたので、なんにも言へず、ただ、ぽろぽろ涙を流して泣いてゐるわよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、もう舌を拔かれて口がきけないのだからねえ、このひとがお照さんを搜してゐるといふ事を言つて聞かせてあげても、藪のあの奧で寢たまま、ぽろぽろ涙を流してゐるばかりなのよ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "可哀想に口がきけなくなつて、毎日ぽろぽろ涙を流して泣いてゐます。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きい眼でお爺さんの顏をじつと見つめて、さうして、ぽろぽろと涙を流した。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "秒刻は銀波を砂漠に流し老男の耳朶は螢光をともす。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "花袋は、その後「蒲団」や「一兵卒」など自然主義派の見本のような小説を作って、国木田独歩、岩野泡鳴ら同主義の作家と呼応して、自然主義を文壇思潮の主流たらしめ、硯友社その他の既成老衰作家などを、ひとたまりもなく押し流してしまった。",
              "citation": {
                "source": "紀行文家の群れ",
                "author": "――田山花袋氏――",
                "note": "青空文庫"
              }
            },
            {
              "text": "深いところは紫を浅いところは藍を流している。",
              "citation": {
                "source": "白峰山脈縦断記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            }
          ]
        }
