      {
        "index": 1,
        "gloss": "slashing (with the blade pressed against the object)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
