        "examples": {
          "standard": [
            {
              "text": "急な出費があったので、祖父の時計を七つ屋に預けた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "昔ながらの七つ屋は、地域の人々に親しまれている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この辺に七つ屋あったっけ？ちょっとお金が足りなくて…」と、彼が困った顔で尋ねた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "どこで聞いたんだ」「七つ屋ですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "首つり五人男",
                "note": "青空文庫"
              }
            },
            {
              "text": "いずれは堆朱か、螺鈿細工のご名品にちがいないが、それに珊瑚珠の根付けかなんかご景物になっていたひにゃ、七つ屋へ入牢させても二十金どころはたしかですぜ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "七つ屋へこかしこんでも一両がところは物をいいそうな上等のちりめんだが、いってえこんなところに結わいつけて、なんのまじないですかね」「それが手品の種よ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "幽霊水",
                "note": "青空文庫"
              }
            },
            {
              "text": "然れば夕べに七つ屋の格子を潜って、都々逸よりも巧みな才覚しすまして旦は町内のつきあいに我も漏れず、一日を他愛もなく興じ暮らして嚢中の空しきを悔いざる雅懐は、蓋し江戸ッ児の独占するところか。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は又、相場師生活の一例として、仕立てたばかりの春衣が仕附糸のまま、年の暮に七つ屋の蔵へ行くことなどを話した。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
