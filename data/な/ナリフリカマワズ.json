    "definitions": [
      {
        "index": 1,
        "gloss": "with no regard to appearances",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
