        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あいつは私とはこの間から仲が悪いのでどんなひどいことをするか知れません。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「なぜ仲が悪いのだ。",
              "citation": {
                "source": "月夜のけだもの",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源家は昔から親子兄弟の仲が悪いんだ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たのしく飲もう」　彼は、どたりと腰を下し、「お前たちは、夫婦仲が悪いな？",
              "citation": {
                "source": "親友交歓",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして君たちは、そんなに仲が悪いんだ。",
              "citation": {
                "source": "乞食学生",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "糸七さん一人だって、あなたは仲が悪いんでしょう。",
              "citation": {
                "source": "薄紅梅",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "当人同士の夫婦仲が悪いというのも珍らしくない。",
              "citation": {
                "source": "半七捕物帳",
                "author": "ズウフラ怪談",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、この子供たちはふだんから仲が悪いのか、それとも魚を取られたのが口惜しいのか、男の児は相手の女の児を指さして、こいつの家へはお化けが出るんだよ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「今になつてお母さんと仲が悪いなんていふことが知れると、それこそ皆なに馬鹿にされるぢやありませんか。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「君は、また莫迦に仲が悪いんだね。",
              "citation": {
                "source": "妄想患者",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "又臨時工と本工とが賃銀のことや待遇のことで仲が悪いのは、会社がワザとにそうさせているのであって、中には「合い見、互い見」で、仲間になっているものさえある。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親と母親とは重右街門とは始めから仲が悪いので、商売を為るとか言つて、其頃長野へ出て居つたから、家には只死に瀕した祖父一人。",
              "citation": {
                "source": "重右衛門の最後",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ナーニ、恰度アノ隣の理髪店の嬶が、小宮の嬶と仲が悪いので、其※事を云ひ触らしたに過ぎなかつたですよ。",
              "citation": {
                "source": "病院の窓",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、どうしてあの人とあんなに仲が悪いの？",
              "citation": {
                "source": "西瓜喰ふ人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」関雪と麦僊３・23（夕）　数多い竹内栖鳳氏の門下生のなかで、づばぬけて光つてゐて、負けず嫌ひで、おまけに犬と猿のやうに仲が悪い画家が二人ゐる。",
              "citation": {
                "source": "茶話",
                "author": "大正八（一九一九）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからいまにいたるまでこの二山がひどく仲が悪い。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "加うるに母と仲が悪いという重大な点がある。",
              "citation": {
                "source": "殺人鬼",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、お君さんとお松さんとの仲が悪いのは、何もお松さんが嫉妬をするせいばかりではない。",
              "citation": {
                "source": "葱",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしたことはちょっと聴くと仲が悪いようにきこえるが、喧嘩もしないような家庭が平和で幸福があるとばかりはいえない。",
              "citation": {
                "source": "松井須磨子",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "政党は国家の利益を増進するための機関である、しかるに甲の政党と乙の政党とはその主義を異にするために仲が悪い、仲が悪くとも国家のためなら争闘も止むを得ざるところであるが、なかには国家の利益よりも政党の利益ばかりを主とする者がある。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "この日師範学校の生徒は黙々塾に応援するつもりであった、師範と中学とは犬とさるのごとく仲が悪い、だがこの応援は中止になった、いかんとなれば審判者は師範の選手がたのまれたからである、で師範は中立隊として正面に陣取った。",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうやらお愛妾お半の方と、仲が悪いということだが」「そんなこと迄知ってるのか？",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先妻の子も同じ店で働いているが、親子非常に仲が悪い。",
              "citation": {
                "source": "永日小品",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲が悪いなんていふ生やさしい関係ぢやない。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女ははじめのうちはそれがよく分からなくて、彼の厄介になっている牡丹屋と自分の家とが親戚の癖に昔から仲が悪いので、自分が何の気なしに話したおよう達の事でもって何か明の気を悪くさせるような事でもあったのだろうと考えた。",
              "citation": {
                "source": "菜穂子",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "云うまでもなく二人の仲が悪いから、酔っ払って事が起きては面倒だというので、木村が南正面なら升田は東正面に当る位置に、間に数名の人をはさんで遠く離れているばかりでなく、顔を見合うこともできないような位置に二人の席を定めておいた。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "でもエリオットとは仲が悪いのです」　そう宋思芳少年は云った。",
              "citation": {
                "source": "鴉片を喫む美少年",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は私の父と仲が悪い上に私の継母にも少なからぬ悪感を持つてゐたのである。",
              "citation": {
                "source": "ある職工の手記",
                "author": "宮地嘉六",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
