    "definitions": [
      {
        "index": 1,
        "gloss": "to flow down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その音と、龍頭を流れ下る水の音とが、森閑とした眞夏の暑い沈默を靜かに破つた。",
              "citation": {
                "source": "實驗室",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは偶然規則的な図案になって大河底を流れ下る氷の渦紋のようにも見えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "おのれは竿を肩にし、弟は食料を提げ、父上はを持ち玉ひつゝ、折と見ゆる中を、篝火焚きつゝいと長き筏の流れ下るさまなど、画にも描くべくおもしろし。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして甘酸ゆい燐光の息するたびに、あをあをと眼に沁みる螢籠に美しい仮寝の夢を時たまに閃めかしながら、水のまにまに夜をこめて流れ下るのを習慣とするのである。",
              "citation": {
                "source": "水郷柳河",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "熔けたる巖の山腹を流れ下るさま、血の創より出づる如し。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "直立せる火柱はその幹、火光を反射せる殷紅なる雲の一群はその木の巓、谷々を流れ下る熔巖はその闊く張りたる根とやいふべき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはその何人なるを知らねども、姑く共に語らばやとおもひて、ヱズヰオの山の噴火の事を説き、その熔巖の流れ下る状など、外より來るものゝ目を驚かす由を云ひたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "巓よりは黒烟を吐き、半腹を流れ下る熔巖の上には濃き蒸氣｜簇れり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "山腹を流れ下る熔巖の色は海波に映じて、海もまた燃えんとす。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "流れ下る熱質の一部、その高きが爲めに分れて迸り落つることありて、その奇觀は岸｜拍つ波に似たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日簡易生活を叫ぶもののあるやうな譯で、時代の大勢は反對な或者を産み出す、河水が強く流れ下る時は其岸邊には上へ向く流れが生ずるやうなもので、墨子は放縱の世に際しておのづから敢然として節用を主張したのである。",
              "citation": {
                "source": "墨子",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして岸辺との摩擦によって私を囲む水も私自身も、中流の水にはおくれがちに流れ下る。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は自分の欲求の凡てに於て流れ下る。",
              "citation": {
                "source": "惜みなく愛は奪う",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "その相迫つた斷崖の底に極めて細く深く青み湛へた淵は、時にまた雪白な飛沫をあげた奔湍となつて流れ下る。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうして甘酸ゆい燐光の息するたびに、あをあをと眼に沁みる螢籠に美くしい假寢の夢を時たまに閃めかしながら水のまにまに夜をこめて流れ下るのを習慣とするのである。",
              "citation": {
                "source": "思ひ出　抒情小曲集",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "氷河また花の中に流れ下る所に、先きを揃えた牧場の軟草幾十里となくつづいている。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪渓より流れ下る水の美味さ。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "日ざしは、そのカーテンを通して射し入って、柔らかな光を、彼女のふさふさした金色の髪や、その清らかな首筋や、流れ下る肩の曲線や、優しい安らかな胸のあたりに、ふりそそいでいた。",
              "citation": {
                "source": "はつ恋",
                "author": "ツルゲーネフ",
                "note": "青空文庫"
              }
            },
            {
              "text": "その氷の下を例の水の勢で流れ下る音がする。",
              "citation": {
                "source": "路傍の雑草",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "箱根の山の裾へ来て聞く深い雨とも、谷間を流れ下る早川の水勢とも、いずれとも差別のつかないような音に耳を傾けながら、岸本は僅に言出した。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪渓の上を、しぶきをあげて流れ下る滝とも川ともつかないものが出来、積雪はどんどんやせていった。",
              "citation": {
                "source": "三十年後の東京",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、鼻の奥にむずむず涙腺から流れ下るものを感じた。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "飛沫をあげて水の流れ下る巖角に裾をまくった父が悠々此方を向いて跼んで居る。",
              "citation": {
                "source": "木蔭の椽",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷たい水が食道を流れ下る明瞭な重みに急に彼の眠気も醒めて来た。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "上流には小舟あり、ゆるゆると水門さして流れ下る。",
              "citation": {
                "source": "レモンの花の咲く丘へ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
