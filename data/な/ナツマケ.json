        "examples": {
          "standard": [
            {
              "text": "今年は特に暑かったから、夏負けしないように気をつけないと。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼は夏負けして食欲不振になり、体重が減ってしまった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "夏負けを防ぐには、バランスの取れた食事と十分な睡眠が重要だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "ジャンヌ・マリイの手ジャンヌ・マリイは丈夫な手してる、だが夏負けして仄かに暗く、蒼白いこと死人の手のやう。",
              "citation": {
                "source": "ランボオ詩集",
                "author": "OEVRES D'ARTHUR RIMBAUD",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は仕合わせなことに今のところまだ夏負けしないで、去年の苦しさと全くちがう新鮮な元気で、（へばりつつも）夏のあつさを感じて居ります。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四三年（昭和十八年）",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
