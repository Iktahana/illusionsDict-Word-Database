    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nappe",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」とナップ三月号で池田寿夫はいっている。",
              "citation": {
                "source": "農民文学の問題",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「砂糖とパイナップルは置いて来ればよかった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」彼は、パイナップルの鑵詰を取出した。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう云えば、あんたから送って来た戦地のスナップショット、どれもこれも、とてもお天気がいいね。",
              "citation": {
                "source": "兵士と女優",
                "author": "オン・ワタナベ（渡辺温）",
                "note": "青空文庫"
              }
            },
            {
              "text": "鞄のスナップのあまくなっている個所を修繕している。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ互いに食通振りを披瀝したが、結局、パイナップルの鑵詰の汁にまさるものはないという事になった。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃の鑵詰の汁もおいしいけど、やはり、パイナップルの汁のような爽快さが無い。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "パイナップルの鑵詰は、あれは、実をたべるものでなくて、汁だけを吸うものだ、という事になって、「パイナップルの汁なら、どんぶりに一ぱいでも楽に飲めるね。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "片方は糸で修繕した鉄ぶちの眼がねをかけ、スナップ三つあまくなった革のカバンを膝に乗せ、電車で、多少の猫背つかって、二日すらない顎の下のひげを手さぐり雨の巷を、ぼんやり見ている。",
              "citation": {
                "source": "HUMAN LOST",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "五時、夕食、ビーフシチウ・焼バナナ・パイナップル入クラレット。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "アピアの西郊ムリヌウ岬から其の附近一帯の広大な土地が独逸商会の農場で、其処でコーヒー、ココア、パイナップル等を栽培していた。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "折角苦労して沢山のパイナップルを作り、それを自分達で喰べもせずに、船に載せて他処へ運んで了うに至っては、土人の大部分にとって、全く愚にもつかぬナンセンスである。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "うちの畑でとれるもの――キャベツ、トマト、アスパラガス、豌豆、オレンジ、パイナップル、グースベリィ、コール・ラビ、バーバディン、等。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "じっさい司法参事官のクナップ氏などは、この主張にとても熱心で、さっそく主人役の奥さんを身方につけてしまったほどでした。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "司法参事官クナップ氏は、ハンス王時代のことに心をとられながら、うちへかえろうとしました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで参事官がなんの気なしにそれをはいたまま東通へ出ますと、もうすぐと、うわおいぐつの効能があらわれて、クナップ氏はたちまち三百五十年前のハンス王時代にまでひきもどされてしまいました。",
              "citation": {
                "source": "幸福のうわおいぐつ",
                "author": "LYKKENS KALOSKER",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらにＡＭＤは３８６互換製品のライン・ナップを拡充していった。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノートブック型マッキントッシュ、パワーブックのラインナップを始めとするアップルの新製品、各社からぞろぞろ出てきた手書きのペン・ベースのシステム、いわゆるマルチメディア関連、Ｗｉｎｄｏｗｓアプリケーションに『Count on it !』といった話ばっかりで、ＡＭＤのＡの字も聞こえてこないじゃないか。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三二（昭和七）年　プロレタリア詩人会が日本プロレタリア作家同盟（ナップ）へと発展的解消をし、これにともなってナップに参加。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九三三（昭和八）年　ナップ末期の詩集『戦列』に「母親は息子の手を」を発表。",
              "citation": {
                "source": "小熊秀雄全集-1",
                "author": "短歌集",
                "note": "青空文庫"
              }
            },
            {
              "text": "東山――こないだ東京駅の待合室で例の事件のあったとき、うちの記者がスナップしたのが運よくカメラにおさまったのです。",
              "citation": {
                "source": "探偵戯曲　仮面の男",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "道がひろくなったところで、慶一は立ちどまり、右肩にひっかけていたナップザックをおろし、高志のソリッド・ステート11をひっぱりだして、スウィッチを入れ、またナップザックにもどした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クソ、近くで買物できれば、こんなにあわてなくてすんだのに」　腹立たしげにいって、高志が〈ライト・マイ・ファイア〉を流していたラジオのスウィッチをきり、ナップザックにしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも……」「じゃ、おれのナップザックをもって」「そうしろ」　といいながら、高志が真新しいギンガムチェックの敷物をふりあげ、令子とじぶんにかぶせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、円海山までいってたら、いまごろ、ひでえことになってたな」　高志がナップザックからラジオを出し、ぬれていないことをたしかめ、スウィッチを入れると、グラス・ルーツの〈レッツ・リヴ・フォー・トゥデイ〉が飛びこんできた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイガイっていうんですって」　高橋路子先生が補足をして、腰掛けにおいた赤いナップザックの口を開いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰が芸術的に、ナップ〔全日本無産者芸術連盟〕所属の大部分の作家を、島崎藤村よりもすぐれていると考え得ただろう。",
              "citation": {
                "source": "昭和四年の文壇の概観",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
