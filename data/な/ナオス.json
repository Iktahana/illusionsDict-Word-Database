[
  {
    "uuid": "5f334d17-46a7-5b6a-8ba7-f2c68aeca777",
    "entry": "直す",
    "reading": {
      "primary": "なおす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to repair",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "汽車が東京駅を出たばかりの時、僕の連れの横手にゐる男がどちらまでですと訊ねたが此の男は返事もしないで見てゐた新聞をパシヤリと畳み直すと、又他の面を読みはじめた。",
              "citation": {
                "source": "三等車の中（スケッチ）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "（男一足下つて首をクネクネ廻して、頸の凝りを直す）夢だ…………常識主義者だ。",
              "citation": {
                "source": "夢",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "やはり弁証法に限る、と惚れ直すかも知れない。",
              "citation": {
                "source": "多頭蛇哲学",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから朝市の大きな西瓜、こいつはごろごろして台へ載りにくかったのをようやくのせると、神様へ尻を向けているのは不都合じゃと云い出してまた据え直す。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もちろん私も當初に於いては、この桃太郎をも、私の物語に鑄造し直すつもりでゐた。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、紅葉の季節に見直すといゝかも知れない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう二度と出直す勇氣がなくなつてそれつきりそのまゝになつてしまつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、紅葉の季節に見直すといいかもしれない。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとなでつけるのかと思ったら自分で新たに巻き直すと見える。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "では真向きの全身――椅子を直すふりして女客は立ち上った。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉に訊いたら、あるいは消息を知ったかも知れないが、薄情を怒るどさくさ紛れに、つい訊くのを忘れたのを今更残念に思うものの、取って返して訊き直すこともならない。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども少年はしばらくすると機嫌を取直す。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "むかしの男たちへの罪滅しのために若いものの世話でもして気を取直すつもりかと思っていたが、そうでもない。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女が手を延ばして直す風をした。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれはこんな赤いすれっからしが本統にそれを直すかどうかと考へながら黙ってそれを見てゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けだし音楽を図形に直すことは自由であるし、おれはそこへ花で Beethoven の Fantasy を描くこともできる。",
              "citation": {
                "source": "花壇工作",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "またお箸の手が違ったよといえば、すぐ右に直すけれど、少しするとまた左に持つ。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち電気単位の測定を決定的にやり直すことであった。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "レーリーはレニョーの実験における浮力の補正に誤りのあることに気付いたので、もう一度詳しくやり直す必要を感じたのである。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こう考えて来ると少なくも彼の税関吏の場合はやや従前とはちがった光の下に見直すことが出来る。",
              "citation": {
                "source": "チューインガム",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体津田君の主張するように常に新たな眼で自然を見直すという事は科学者にとっても甚だ重要な事である。",
              "citation": {
                "source": "津田青楓君の画と南画の芸術的価値",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事情あつて原稿のまま燒き捨てようと思つたが、最近また考へ直す所があつて發表した。",
              "citation": {
                "source": "室生犀星に與ふ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "三次「違ったかな」と、も一度見直す。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて鏡を手に取り、ネクタイを直す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘は直に箪笥を拭き始め、その上の品物を一々拭きて工合好く据直す。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、女は何故か憚るやうにあわてて扉を締めて、置いた火鉢を抱へ直すとけむつぽい顏を横に曲げながら、私の側に近寄つて來た。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は何となくひやりとして、もう一度見直すやうに振り返つたが、もうその時は何の影も見えなかつた。",
              "citation": {
                "source": "自分の變態心理的經驗",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "安全装置を直すのを忘れていたのだ。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一度切り取られた脚は、それを生れたまゝのもとの通りにつけ直すことは出来ない。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『さうか、』と言つて志村は其儘再び腰を下ろし、もとの姿勢になつて、『書き給へ、僕は其間にこれを直すから。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
