        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゴム長靴の脛だけの部分、アラビアンナイトの粟粒のような活字で埋まった、表紙と本文の半分以上取れた英訳本。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからまた古いナイト・テエブルの抽出を手にして、歩き※りながら、それを誰にでも差しつけてゐる老婆もありました。",
              "citation": {
                "source": "巴里の手紙",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそこにロダンの傑作、黄銅時代、ダナイト、美しき冑造り、接吻等に変って、バルザックの寝巻姿が私達の心に憂鬱な余生を送る心理学者のように映るのを見るのであった。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "人造人間の弾機によって、そのたびに粋なナイト・ドレスをつけた夜の女が、写真に絵姿となってあらわれるのだ。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜の顛末の物語はなんとなくアラビアンナイトを思い出させるような神秘的なロマンチックな詩に満ちたものであったが、惜しいことに細かいことを忘れてしまった。",
              "citation": {
                "source": "Ｂ教授の死",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうよあたしアラビアンナイトで見たわ。",
              "citation": {
                "source": "〔「銀河鉄道の夜」初期形一〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一方ではゲーテの「ライネケ・フックス」や、それから、そのころようやく紹介されはじめたグリムやアンデルセンのおとぎ話や、「アラビアン・ナイト」や「ロビンソン・クルーソー」などの物語を、あるいは当時の少年雑誌「少国民」や「日本の少年」の翻訳で読み、あるいは英語の教科書中に採録された原文で読んだりした。",
              "citation": {
                "source": "科学と文学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの国の有名な画廊にある名画の複製や、アラビアンナイトとデカメロンの豪華版や、愛書家の涎を流しそうな、芸術のための芸術と思われる書物が並んでいて、これにはちょっと意外な感じもした。",
              "citation": {
                "source": "火事教育",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供だっているかぐらいあります」「そうよ、あたしアラビアンナイトで見たわ」姉は細い銀いろの指輪をいじりながらおもしろそうにはなししていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "※９　天河石＝アマゾナイトのこと。",
              "citation": {
                "source": "インドラ［※１］の網",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうよ、あたしアラビアンナイトで見たわ。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある人の話では電気の絶縁のためにエボナイトを使ってある箇所を真鍮で作って、黒く色だけをつけておいた器械屋があるという。",
              "citation": {
                "source": "断水の日",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビヨウキノ　サルヲ　キツテモ　シカタナイト　イフノデ、五人ノ　サムライハ、ソノ　サルヲ　ツレテ　ユキマシタ。",
              "citation": {
                "source": "サルト　サムライ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ソレヂヤ　シカタナイト　オモツテ、ハジメノ　デンデンムシハ、ベツノ　オトモダチノ　トコロヘ　イキマシタ。",
              "citation": {
                "source": "デンデンムシノ　カナシミ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカシ、イタチダケヲ　ヨバナイト　イタチハ　キツト　オコルニ　チガヒ　アリマセン。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひょっとかしたらベントナイトとかいうものが出るかも知れないなぞと小川の向う側の無花果の葉の茂みの蔭に、わたくしは茣蓙を敷き、肘枕をして流水の涼しい気を受けながら見るともなく見ております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "頁岩からは天然のセメントが出るし、もう少しの研究でベントナイトが得られるとかどうかとかで、そのベントナイトから防湿紙が作り出せるなど、その他いろ／＼話に、研究に、この町は活気を呈して参りました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "警官が要領を得ずに引きあげて行くと、やがてラストのグッドナイトの曲が聴えて来た。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰か連れて行くでしょう」「ばかね」「エーヴリ・ナイト！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「面白い小説を書こうとしていたのはわれわれの間違いでした」と大衆文学の作者がある座談会で純文学の作家に告白したそうだが、純文学大衆文学を通じて、果して日本の文学に「アラビヤン・ナイト」や「デカメロン」を以てはじまる小説本来の面白さがあったとでもいうのか。",
              "citation": {
                "source": "可能性の文学",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "英文の印刷されたプログラムによって、その狂言がアラビアン・ナイトであることを知ったが、登場俳優はみなスマトラの原住民だそうで、なにを言っているのか僕らにはちっとも判らなかった。",
              "citation": {
                "source": "マレー俳優の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "つまり涙香物が浅く感じられて来ましたので、逆にアラビヤンナイト式のお伽話的怪奇趣味の中にモグリ込んでしまいました。",
              "citation": {
                "source": "涙香・ポー・それから",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかったかの」　筆者は何となくアラビアン・ナイトの中の人間になったような気持で田圃通りに筥崎へ向った。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "祥子は、かわいそうな話と恐い話が好きで、アラビアン・ナイトの悪魔を壺へ封じ込める話など、幾度もくり返して聴きたがった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト俺ハ現在ノ父母ノ子デナイトイフ理論ガ成リ立ツ。",
              "citation": {
                "source": "六白金星",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "エボナイトのような弾力と光沢を持った、あらゆる樹木の梢に群がる木の芽は、ずんずんと日｜毎にふくらんで行き、いろいろの小鳥は思い思いの音色で木の枝に囀り廻っていた。",
              "citation": {
                "source": "緑の芽",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今でも西部のはずれでは、ダナイト団もしくは誅天使団という名称は、不吉なもの、まがまがしいものとされている。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "顎のあたりに結わえてあったものというのは、いつものナイトキャップがないのでそのかわりに頭から巻きつけておいた絹のハンケチなのであった。",
              "citation": {
                "source": "早すぎる埋葬",
                "author": "THE PREMATURE BURIAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "翅のすきとほつたスヾメ蛾、大きな紫翅のオホムラサキ、コムラサキのまぼろしのやうに翅の色を光りに反射して奇怪な明暗を浮べるものや、銀色の鐙兜をつけたスパルタのナイトのやうに颯爽たるカミキリムシや、鋏のやうなノコギリクワガタなど悉く正ちやんの採集に寄るものであつた。",
              "citation": {
                "source": "魚籃坂にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
