    "definitions": [
      {
        "index": 1,
        "gloss": "what article (of a legal document, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
