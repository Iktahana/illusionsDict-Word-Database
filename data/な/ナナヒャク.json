          "literary": [
            {
              "text": "このトランジスターを用いた第二世代機でも、ＩＢＭは科学技術計算用で大型の７０００シリーズ、事務処理用で比較的小型の１４００シリーズを成功させた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "１から７００までの七百枚の写真が、僕たちの父親の人生の痕跡だ。",
              "citation": {
                "source": "ラハイナまで来た理由",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうもね、ななひゃくねん、というらしいんだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうも、ななひゃく、では困る。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「もう百年あとには、しちひゃくでもないし、ななひゃくでもないし、全く別な読みかたも出来ているかも知れない。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
