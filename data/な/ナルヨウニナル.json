    "definitions": [
      {
        "index": 1,
        "gloss": "whatever will be, will be",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "あとはただ、万事を神々と運命の庇護にまかせて、恐れるところも憂うるところもなく、成るように成るのを待とうという気高い決意をしただけであった。",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああどうでもいい、なるようになるんだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎はおのれの仙術でもって、よい男になるようになるように念じはじめた。",
              "citation": {
                "source": "ロマネスク",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後の土壇場までほつておき、その時が來たとき、「なに、なるようになるさ！",
              "citation": {
                "source": "第一義の道",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "と僕を――（爆笑）はっはっはっは、なるようになるさ。",
              "citation": {
                "source": "安重根",
                "author": "――十四の場面――",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらくは将来はそのようになるようになるでしょう。",
              "citation": {
                "source": "青春の息の痕",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "にわかに大尽になるようになるはなしだけれど。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "その答のうちには（どうでもなるようになるがいい！",
              "citation": {
                "source": "地上",
                "author": "地に潜むもの",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあなるようになるだろう。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「どうにか、なるようになるだろう。",
              "citation": {
                "source": "三つの悲憤",
                "author": "――近代伝説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるようになるでしょう。",
              "citation": {
                "source": "波多野邸",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なに、なるようになる分のこと、そこまでは考えていられませぬわい」「拙者は離縁状だけは渡してまいりました。",
              "citation": {
                "source": "四十八人目",
                "author": "森田草平",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活的に男に従属するなんて、そして、たった一人の男が戦争にとられただけで、世界の全部がなくなるようになるなんて、なんということだろう。",
              "citation": {
                "source": "青鬼の褌を洗う女",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "秋子も順一も自分自身も、どうとでもなるようになるがいい！",
              "citation": {
                "source": "幻の彼方",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "兄さんの心事は悲痛であろうが、他人の私から見れば、勝手になるようになるがいいさ、あなたの場合はそれよりほかに仕方がなかろう、と云う以外に何もないような気がする。",
              "citation": {
                "source": "安吾人生案内",
                "author": "その七　宮様は一級紳士",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうにでもなるようになるがいい。",
              "citation": {
                "source": "生あらば",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから先はどうにでも、なるようになるがいい！",
              "citation": {
                "source": "理想の女",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何もかも、依子も、なるようになるがいいや、そういう気がした。",
              "citation": {
                "source": "子を奪う",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "イルやコーヒーの世話をする方がなけりゃ、月給の半分を茶亭で飲んでおしまいになるようになるのも無理はありませんわ。",
              "citation": {
                "source": "決闘",
                "author": "ДУЭЛЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　まア仕方がないよ、なるようになるほか仕方がない！",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いくらどうしたってなるようになるよりほかに道はないんだから。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "これから先もなるようになるだろうよ。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "10705まあ、どうにかなるようになる事だろう。",
              "citation": {
                "source": "ファウスト",
                "author": "FAUST. EINE TRAGODIE",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうでもなるようになるがいい、と彼は思った。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんでもかんでもなるようになるがいい。",
              "citation": {
                "source": "小フリイデマン氏",
                "author": "DER KLEINE HERR FRIEDEMANN",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるようになるのだ。",
              "citation": {
                "source": "無人島に生きる十六人",
                "author": "須川邦彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのネズミを殺しちまや、また金のリンゴがなるようになる。",
              "citation": {
                "source": "三本の金の髪の毛をもっている鬼",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるようになる他はない。",
              "citation": {
                "source": "黄色い日日",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "むしろその運命というようなものに好意でも持っているかのような顔つきで、「何事もするようにはならんで、なるようになる」といった。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるようになるだろうさ。",
              "citation": {
                "source": "レ・ミゼラブル",
                "author": "LES MISERABLES",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
