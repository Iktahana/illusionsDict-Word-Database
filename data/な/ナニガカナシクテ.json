          "literary": [
            {
              "text": "――婆さんや、お前は何が悲しくて泣くんだい。",
              "citation": {
                "source": "小熊秀雄全集-14",
                "author": "童話集",
                "note": "青空文庫"
              }
            },
            {
              "text": "「見ればうら若い娘だのに、何が悲しくて泣いておるぞ？",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このような深夜にこのような処で若い女子がただ一人何が悲しくて泣いておるぞ」　こう云いながら頼正は乙女の側へ寄って行った。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が悲しくてお泣きなさる」　こう云う声は顫えていた。",
              "citation": {
                "source": "八ヶ嶽の魔神",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何が悲しくて泣くのだえ？",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
