    },
    "definitions": [
      {
        "index": 1,
        "gloss": "long, leisurely bath",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「心の切り方が悪いからよ」と婆やはたしなめる様に云うと、おすめは其には答え無いで突立ったまま、何処を睨むか見当の付かない様な斜視の眼を据えて、「婆やさんの長湯にも呆れるなあ、やあ垢擦りだ、やあ糠だのって」と云って口を尖らした。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが母親は娘の長湯を気にしていた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「また例の通り長湯ですね。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "道子は何て親というものはうるさいものだろうと弱って「なぜそう私の長湯が気になるの。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなに長くお湯につかってるんじゃありませんよ」　母親が呆れて叱ったけれど、道子は自分の長湯を信用させるために顔を真赤にしてまで堪えて、長くお湯につかっていた。",
              "citation": {
                "source": "快走",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな長湯をしたつもりでもなかったのですが、風呂の番頭さんに背中を流してもらったり、湯あがりのお化粧をしたりして、かれこれ三十分ほどの後に自分の座敷へ戻って来ますと、夫の姿はそこに見えません。",
              "citation": {
                "source": "鰻に呪われた男",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "おすがは默つてぼちり／＼と手拭の音をさせながら成丈長湯をするやうになつた。",
              "citation": {
                "source": "芋掘り",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "長湯をして出てもまだ西日が残っていた。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ようやく長湯をなすったいわく因縁がわかりましたがね。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "長湯にもよりけりだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の長湯をすまして帰って来たのは五ツ半を廻った頃で、往来のすくない雨の夜に大抵の店では大戸を半分ぐらい閉めていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひっつめ鬢の昔も子供臭く、髱は出し、前髪は幅広にとり、鏡も暇々に眺め、剃刀も内証で触て、長湯をしても叱られず、思うさま磨き、爪の垢も奇麗に取って、すこしは見よげに成ました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "顔を剃つてさつぱりした、私自身も驚くほどの長湯、それほどよい湯であつた。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ついこの四、五日前に、長湯をしたと言って怒ったのが因で、アクザモクザ罵った果てに、何か厄介者でも養っていたようにくやしがって、出て行け、今出て行けと呶鳴ったことなども、我ながら浅ましく思われた。",
              "citation": {
                "source": "新世帯",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "上さんはそのために長湯も出来ず、※々風呂を出てしまったそうです。",
              "citation": {
                "source": "温泉だより",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "「吉乃さんの長湯」といって、大抵の者は知っている。",
              "citation": {
                "source": "操守",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "おばあさん達は世間話などしながら思はず長湯をして、お湯を出た時は大分夜がふけてゐました。",
              "citation": {
                "source": "狐に化された話",
                "author": "土田耕平",
                "note": "青空文庫"
              }
            },
            {
              "text": "病後の吉左衛門にとって長湯は大の禁物だった。",
              "citation": {
                "source": "夜明け前",
                "author": "第一部上",
                "note": "青空文庫"
              }
            },
            {
              "text": "後から女中が二人の浴衣を持って行き、それから狭い座敷の仕度をして電気｜煖炉の火をつけ、やや暫くして他の客を案内しようと再び風呂場の戸をあけかけると、今だに二人の話声がしているので、その長湯に驚き跫音を忍ばせて立去った。",
              "citation": {
                "source": "ひかげの花",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "一週間振りではあり、ほろ酔の好い気持ちで、長湯して戻って来ると、奥の御座所に隣る広間が私共の座敷に充てられ、一同は既に膳についてビールを飲んでいた。",
              "citation": {
                "source": "朝香宮殿下に侍して南アルプスの旅",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲間でも長湯で知られた助六、二時間は御定法だった。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "「番頭さんは長湯かえ」　錢形平次は不意に口を挾みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何刻ぐらい入っていましたかい」「一刻（二時間）とも入りはしません」「そんな長湯ですか、お前さんは？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "朱塗の筐",
                "note": "青空文庫"
              }
            },
            {
              "text": "「番頭さんは長湯かえ」　銭形平次は不意に口を挟みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "遺言状",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何刻位入つて居ましたかい」「一刻とも入りはしません」「そんな長湯ですか、お前さんは？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "朱塗りの筐",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「新六郎は、いつでも湯が長いか、それとも今晩に限つたことか、それも訊かなかつたらう」「相濟みません」「褌を洗つて長湯をしたわけぢやあるめえ」　八五郎はまことに散々の體です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「零下、二十五度より寒けりゃ働かしてなんねえっていう規則がソヴェト政府から出てるんだ」　みんながゆっくり飯場にかまえこんでいるところへ、ハゲ小林が入って来た。",
              "citation": {
                "source": "ズラかった信吉",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「みんながゆかなければ、俺たち五｜人のものが助けにゆく。",
              "citation": {
                "source": "黒い人と赤いそり",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが前々日になると、旅行志望者はきゅうにふえて、岬ではマスノをのけてみんながゆくということになった。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
