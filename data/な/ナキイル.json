    "definitions": [
      {
        "index": 1,
        "gloss": "to burst into tears",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と泣き入る涙も尽き果てて血をも絞らむばかりなり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉さん思案にあまることがあるなら、いくらでも力になってやるよ、わけを言って見な」　女はますます袂へ顔をうずめて泣き入るばかりであった。",
              "citation": {
                "source": "狢",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして泣き入るのだった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（玉琴泣き入るを、おしおは慰める。",
              "citation": {
                "source": "平家蟹",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（云いかけて、又泣き入る。",
              "citation": {
                "source": "人狼",
                "author": "――Were-Wolf――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして泣き入る葉子を大事そうにかかえたまま、倉地は上体を前後に揺すぶって、赤子でも寝かしつけるようにした。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "（お冬は声を立てて泣き入る。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "）の壺を、その場で取り落してしまい、激しく肩を揺すって、さめざめと泣き入るのでございます。",
              "citation": {
                "source": "白蟻",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "背からおろしといたばかしで、女もなくなっただァ」と云いかけて、斜視の眼から涙をこぼして、さめ／″＼泣き入るが癖である。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "J'ai honte, vous savez, j'ai tellement honte! ……（泣き入る）二ホテルの一室――寝台が二つ並んでゐる。",
              "citation": {
                "source": "牛山ホテル（五場）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "冷やけき土地にひたりて、しく／＼と泣き入る憂ひ。",
              "citation": {
                "source": "小曲二十篇",
                "author": "漢那浪笛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（泣き入る）札木合　（片手に抱いて）これ、なにもそんなに悲しむことはない。",
              "citation": {
                "source": "若き日の成吉思汗",
                "author": "――市川猿之助氏のために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "』　敦子さまは最初はただ泣き入るばかり、とても話をするどころではなかったのですが、それでも修行場の内部へ入って、そこの森とした、浄らかな空気に浸っている中に、次第に心が落ついて来て、ポツリポツリと言葉を切るようになりました。",
              "citation": {
                "source": "霊界通信　小桜姫物語",
                "author": "浅野和三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　それから暫く下女のお仲は、泣き入るお弓の相手ですごしてしまひました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここへ入り込んで、宇太八と謀し合せて、父親の怨みを晴らす心算だったに違いないが、そんな事をするにしちゃ、お照さんは人間が立派すぎた」「…………」　平次は畳の上に両手を突いて、顔を挙げられないほど泣き入るお照を見やりながら続けました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "巨盗還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "二　それからしばらく下女のお仲は、泣き入るお弓の相手ですごしてしまいました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "井戸の茶碗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「父上様」　浪江は半蔵の小脇に身を顫わせて、ヒタ泣きに泣き入るばかりです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "殺され半蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分さん、神とも仏とも、――」　五十近い幸右衛門は恥も体面も忘れて大泣きに泣き入るのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "おはま　（泣き入る）おふみ　（引返し来る）もう駄目なんでした。",
              "citation": {
                "source": "瞼の母　二幕六場",
                "author": "長谷川伸",
                "note": "青空文庫"
              }
            },
            {
              "text": "此處へ入り込んで、宇太八と謀し合せて、父親の怨みを晴らす心算だつたに違ひないが、そんな事をするにしちや、お照さんは人間が立派過ぎた」「――」　平次は疊の上に兩手を突いて、顏を擧げられないほど泣き入るお照を見やり乍ら續けました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "巨盜還る",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸の側に身を俯向けて、ヒタ泣きに泣き入るのは母親のお組でせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "親分さん、神とも佛とも、――」　五十近い幸右衞門は恥も體面も忘れて大泣きに泣き入るのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "雪の夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "死骸の側に身を俯向けて、ヒタ泣きに泣き入るのは母親のお組でしょう。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "矢取娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、私のワイシャツの上に顔をつけて、熱い涙が私の肌に感じられた程も、さめざめと泣き入るのだった。",
              "citation": {
                "source": "陰獣",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "新一さん、わたし本当に……」　いいさして京子は新一の身体に取縋り、烈しく泣き入るのであった。",
              "citation": {
                "source": "偉大なる夢",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　烈しい口調で言ったかと思うと、悲しみにゆがんでくる顔を、ハッと両手で蔽い隠し、そのまま肩を震わせて泣き入るのであった。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "家庭は裁判所ではないのだし、伊志田氏も明智探偵も裁判官ではないのだから、泣き入る綾子を無慈悲に追求することはできなかった。",
              "citation": {
                "source": "暗黒星",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「では……弟はわしに会いたいというて、おもとを使いによこしたわけか」「ええ……」梢は、打ち悄れたまま、「いっそ、二人して死んでしまおうかと、何度も、刃物を手に取ってみましたが、やはり、死ぬこともできません」と、肩をふるわせて泣き入るのであった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
