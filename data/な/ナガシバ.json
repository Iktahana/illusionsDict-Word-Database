    "definitions": [
      {
        "index": 1,
        "gloss": "place for showering next to a tub",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "井戸ばたの流し場に手水をすました自分も、鶏に興がる子どもたちの声に引かされて、覚えず彼らの後ろに立った。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふらふらして流し場から脱衣場へ逃れ出ようとすると、佐吉さんは私を掴え、髯がのびて居ます。",
              "citation": {
                "source": "老ハイデルベルヒ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は井戸替え連中の帰るのを見すまし、まだ泥土でねばねばしている流し場を草履で踏み乍ら、井戸替えの済んだばかりの井戸側のまわりに集ってなかを覗く。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "婆やはそれを、いつも同じ量程に撮み取って、湯殿の流し場の隅の水桶から小さな盃にとりわけた水を指で掬って溶いて、するするとかやの襟元から塗り始めるのであった。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "よくお湯を流して、滑に温められた流し場の板敷の上へ行儀よく坐って、後ろ首に白粉をのばす婆やの手の重みに少し前かがみになると、かやの眼の前には向き合って居る婆やの細長く垂れた、二つの乳房がふらふらとゆれて居た。",
              "citation": {
                "source": "かやの生立",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると彼女は蛇紋石の流し場に片手を支いたまま、横坐りをして、唇をシッカリと噛んでいた。",
              "citation": {
                "source": "鉄鎚",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕が風呂の流し場に足を踏みいれたとたんに、やあ、と大声をあげたものがいた。",
              "citation": {
                "source": "彼は昔の彼ならず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供達は井戸替へ連中の帰るのを見すまし、まだ泥土でねば／＼してゐる流し場を草履で踏み乍ら、井戸替への済んだばかりの井戸側のまはりに集つてなかを覗く。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、さっさと流し場へ行って、からだを洗った。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "黄昏の銭湯の、流し場の隅でひとりこそこそやっている老人があった。",
              "citation": {
                "source": "もの思う葦",
                "author": "――当りまえのことを当りまえに語る。",
                "note": "青空文庫"
              }
            },
            {
              "text": "井戸端の流し場に手水を濟した自分も、※に興がる子供達の聲に引かされて、覺えず彼等の後ろに立つた。",
              "citation": {
                "source": "奈々子",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「湯が煮たったから、ふすまをかいておくれ、兼吉」　流し場から細君の声で兼吉はほうきをおいて走っていく。",
              "citation": {
                "source": "箸",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "薄暗いなかでよくは判らないが、その話し声が近所の下駄屋の亭主であるらしいので、流し場へ出たときに窺うと、果たして彼は下駄屋の善吉であった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "大森の鶏",
                "note": "青空文庫"
              }
            },
            {
              "text": "大体の構造は今も昔も変らないが、浴槽も流し場もすべて木造で、人造石やタイル張りのたぐいは殆ど見出されなかった。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "＊　毎年十月の候になると、流し場の壁や羽目に「例年の通り留桶新調仕候」というビラが掛けられる。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、湯屋や髪結床の評判が芝居や寄席の人気にも相当の影響をあたえたらしく湯屋の脱衣場や流し場には芝居の辻番附や、近所の寄席のビラが貼られていた。",
              "citation": {
                "source": "明治時代の湯屋",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして杉田が一度浸つて流し場へ上つた頃に、二人は漸と入つて来た。",
              "citation": {
                "source": "草いきれ",
                "author": "徳田秋聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼の前の湯の中に動いてゐる微塵に似た湯垢の一つ／＼にはかすかに虹の樣な日光の影が宿り、湯槽の縁から溢れ出る湯は同じくほがらかに日が當つて乾き切つてゐる流し場の一端に細い小波をたてゝ流れて行つてゐます。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "湯ばかりは清く澄み湛へてゐたが、その流し場にはほんの一部を除いて處狹く例の松毬が取り入れられてあつた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "火山をめぐる温泉",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は流し場で無造作に湯を使ひながら、「あたしね、いつでも、何だか隣りの野郎が気味が悪くつて、夜なんかとても独りぢや這入れないわ。",
              "citation": {
                "source": "風流旅行",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鸚鵡返しにこんな挨拶をしながら、薬局生はうずたかい柚を掻きわけて流し場へ出た。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなことをそれからそれへと手繰り出して考えながら、わたしはいつの間にか流し場へ出て、半分は浮わの空で顔や手足を洗っていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　徳さんはいい加減に唄ってしまうと、誰に云うとも無しに挨拶して、流し場の方へすたすた出て行ってしまった。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　鸚鵡返しにこんな挨拶をしながら、薬局生はうずたかい柚をかきわけて流し場へ出た。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　徳さんは好い加減に唄ってしまうと、誰にいうともなしに挨拶して、流し場の方へすたすた出て行ってしまった。",
              "citation": {
                "source": "ゆず湯",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは警察署の聴取書綴のなかから発見したものであったが、事件は築地の或る公衆浴場の流し場で、仲間同士らしい裸の客がわあわあ喋っているのを、盗み聞きしていた一｜浴客が、後にまたそれを他の者へ得々として喋っているところを御用となったものであった。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのデマによると、当夜浴場の流し場で喋っていた本人は、どうやら左官職らしかったという。",
              "citation": {
                "source": "東京要塞",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして流し場へきちやうめんに坐つて手をついた。",
              "citation": {
                "source": "茶話",
                "author": "大正七（一九一八）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆ながしばらく黙っているところへ、辰男は階子段を軋ませて、のっそり下りてきて炬燵の空いた処へ足を入れた。",
              "citation": {
                "source": "入江のほとり",
                "author": "正宗白鳥",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなこと、ちっとも話さなかったじゃないか」　みんながしばらく沈黙している間をおいて、また、伸子がいった。",
              "citation": {
                "source": "二つの庭",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
