        "examples": {
          "standard": [
            {
              "text": "バイクに乗る際は、寒さや衝撃から手を守るためにナックルガード付きのグローブを着用する。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "冬のサイクリングでは、凍える指先を保護するナックルガードが必須アイテムだ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このグローブは、耐久性の高い素材でできたナックルガードが内蔵されている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
