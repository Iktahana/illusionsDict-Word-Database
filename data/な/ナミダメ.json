        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "まだ総角の姫君に死別した悲しみに茫然となっていて、涙目の人になっていると中納言のことの言われているのを聞いて中の君は、中納言の姉君に持っていた愛は浅薄なものではなかったと、いっそう今になって身にしむようにその人の恋が思われるのであった。",
              "citation": {
                "source": "源氏物語",
                "author": "早蕨",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁起を祝う結婚の初めに、尼姿で同車して来たのさえ不都合であるのに、涙目まで見せるではないかと蔑んだ。",
              "citation": {
                "source": "源氏物語",
                "author": "東屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "尼夫人は昨日よりもまだひどい涙目になって中将を見た。",
              "citation": {
                "source": "源氏物語",
                "author": "手習",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙目で舞台を見ていた。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくとも涙目は演技じゃない。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこにいたのは浮浪者風の若い女、涙目が怒りでメラメラ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "静粛で、従順で、涙目であった。",
              "citation": {
                "source": "悪の帝王",
                "author": "THE MASTER CRIMINAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "モード嬢が涙目で言った。",
              "citation": {
                "source": "トリガーセンの妻",
                "author": "TREGARTHEN'S WIFE",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間、僕は絶望的だね」　メアリの声が震え、涙目になった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "それなのに」　言葉に詰まり、涙目になった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　ペイシャンスが見上げて、涙目で弱々しく笑った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "何年続いているのですか」　レディ・ダッシュウッドが両手を握りしめ、涙目になった。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "出発前に二〜三言いたいことがある」　メアリが涙目で微笑んだ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも邸宅を燃やそうとした人物は永久に分からないだろうなあ」　メアリが涙目で、笑って言った。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "ビートリスが涙目になった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "メアリが体の向きを変え、涙目をぬぐった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたとお知り合いにならなければ良かったと思わざるを得ません」　アイダの涙目を見て、グレイが言った。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
