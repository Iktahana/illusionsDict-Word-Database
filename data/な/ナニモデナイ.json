        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "予は其小部分を外套の隱しへ押し込んで、峠は夜になるだらうが何も出ないだらうなと自分ながら弱い音を吐いた。",
              "citation": {
                "source": "痍のあと",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "われも人も肩を軋って後れじと専念する際にはいかな碩儒も自分特有の勘弁も何も出ないのだ。",
              "citation": {
                "source": "十二支考",
                "author": "羊に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "それよりも、唯、わく／＼して言葉も何も出ないんですもの……。",
              "citation": {
                "source": "時子",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "霧原警部の察した如く死体の身許を申し出るものは一人もなく、また短刀の出所の取調べもすべて徒労に帰し、拘留された二人を犯人と判断し得べき直接証拠は何も出ないばかりか、二人が巣鴨へ来る以前の行動も少しもわからなかった。",
              "citation": {
                "source": "呪われの家",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "水谷氏と顏を見合せて『何も出ないでも好いです。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸掘れば直ぐに完全な物が出る位に考へて居た見物連は、一｜向何も出ないので、釣を見るよりも未だつまらぬなど、そろ／＼惡口を掘出すのである。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "笑ひ事では無い、既う何か出ても好い頃だと、心中いろ／＼苦悶して居るが如何も出ない、破片、獸骨、そんな處しか見出さぬ。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "大森貝塚の發掘",
                "note": "青空文庫"
              }
            },
            {
              "text": "活東子がゴホン／＼咳をしながら、赤土の下まで掘入つて、何も出ないと零したのも其頃。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "權現臺の懷古",
                "note": "青空文庫"
              }
            },
            {
              "text": "殘念でならぬので、自分の持場を一｜生懸命に掘つたけれど、何も出ない。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "權現臺の懷古",
                "note": "青空文庫"
              }
            },
            {
              "text": "其時は生憎何も出ないので、採集袋へ摘草を入れて歸つた事もあつた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "權現臺の懷古",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も出ないのであるがこれを吸わねば寝着かれなかった。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ何も出ないだろうが、手をぬくわけにもいくまい。",
              "citation": {
                "source": "復員殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「高等教育」は受けていないので、イデオロギーのような話は何も出ない。",
              "citation": {
                "source": "単純な質問",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そら大変でしたな……新聞にも何も出ないものですからお見舞にも出ませんで……」「しかし、やりますよ、私は徹底的に戦う積りです」「大いにおやりなさい……それについてですな、実は面白い話があるのです。",
              "citation": {
                "source": "空中征服",
                "author": "賀川豊彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "底からも何も出ない。",
              "citation": {
                "source": "田園の憂欝",
                "author": "或は病める薔薇",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして涙も何も出ない目で、きらきら光る湖水の面を見詰めた。",
              "citation": {
                "source": "みれん",
                "author": "シュニッツレル　Arthur Schnitzler",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
