      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to burst into tears",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「門司の旅館で船を待つ間、船の汽笛が鳴るたびに、火のつくやうに泣き出すのには閉口させられた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "無理の圧迫が劇しい時には弱虫の本性を現してすぐ泣き出すが、負けぬ魂だけは弱い体躯を駆って軍人党と挌闘をやらせた。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人が女優らしく胸を張ってバイロンの大洋の歌を独吟しては泣き出す。",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで声さえ平時と変り、僕は可怕くなりましたから、しく／＼泣き出すと、父は益々狼狽え、『サア言え！",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "とも子さすがに感情せまって泣き出す。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遂にしくしく泣き出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（師に始めて言葉をかけられたので阿難はどっと泣き出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "娘さめざめと泣き出す。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小兒たちが、また惡く暖いので寢苦しいか、變に二人とも寢そびれて、踏脱ぐ、泣き出す、着せかける、賺す。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――小児たちが、また悪く暖いので寝苦しいか、変に二人とも寝そびれて、踏脱ぐ、泣き出す、着せかける、賺す。",
              "citation": {
                "source": "夜釣",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "母は心配する、姉は泣き出す。",
              "citation": {
                "source": "思い出草",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き出すと仲々止らず、加速度的に泣声が大きくなり、豹一を抱きあげたお君はまるでその声に顔を打たれているような気がし、泣き止まんと池へ放うりこんだるぞ、構へんか。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、弟の杉作が泣き出すまへの笑ひ顔でいひました。",
              "citation": {
                "source": "疣",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その癖、王さまや王妃さまに何か言われると大勢の臣下の前もはばからず、めそめそ泣き出す。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "（伝兵衛）　お前ひとりのために、お前ひとりのために、この家が、お前ひとりのために、どれだけ、（何か呟きながら、泣き出す）数枝、睦子を抱いたまま静かに立って、奥の階段のほうへ行く。",
              "citation": {
                "source": "冬の花火",
                "author": "―――三幕",
                "note": "青空文庫"
              }
            },
            {
              "text": "（急に泣き出す）あんまりですわ。",
              "citation": {
                "source": "春の枯葉",
                "author": "―――一幕三場",
                "note": "青空文庫"
              }
            },
            {
              "text": "才兵衛はその夜お嫁を隣室に追いやり、間の襖に念入りに固くしんばり棒をして、花嫁がしくしく泣き出すと大声で、「うるさい！",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の因果で、このような難儀に遭うか、と水底をさぐりながら、めそめそ泣き出す人足まで出て来たのである。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と言って、さらに妹を固く抱きしめてこれも泣き出す。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私程不幸なものはない――と、時時さう思つて、悲しくなりますの……』　と、大に同情を求めて、仕舞ひには身を震はして泣き出すんだ。",
              "citation": {
                "source": "Ｓ中尉の話",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、お前さんは泣き出すし、爺さまもお念仏をお唱えだって。",
              "citation": {
                "source": "海異記",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "額こッつりで小児は泣き出す、負けた方は笑い出す、涎と何んかと一緒でござろう。",
              "citation": {
                "source": "春昼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の事にしくしく泣き出すと、こりゃ餒うて口も利けぬな、商売品で銭を噛ませるようじゃけれど、一つ振舞うて遣ろかいと、汚い土間に縁台を並べた、狭ッくるしい暗い隅の、苔の生えた桶の中から、豆腐を半挺、皺手に白く積んで、そりゃそりゃと、頬辺の処へ突出してくれたですが、どうしてこれが食べられますか。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の顔は歪んで来て、小さな桃色の口を開けて泣き出すという段取でした。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしがやゝ安心して泣き出す姿形を見て、師匠は「なんてい野暮な泣き方をするんだ」と叱言を言ったり、「下手だなあ、それで芸人の泣き方といえるか」と窘めたり、口では終えなくて箸を逆持ちにした太い方で少年のわたしの小腕をぴしりと打つときもあり、自分が代って泣き方の模範を示して呉れるときもある。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い帽子は笑ひ出す、黒い帽子は泣き出す、青い帽子は怒り出す。",
              "citation": {
                "source": "とんぼの眼玉",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」口惜しさうに声が泣き出す。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして暫らく立つと、また／＼痛い／＼と泣き出す。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "發展",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれかこれかと問い詰めた揚句ワッとばかりに泣き出すので、やっとわかるなぞいうのがあります。",
              "citation": {
                "source": "鼻の表現",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達が、一緒に泣き出す声を聞くと、急に盲目の眼を、ショボショボさせたかと思うと、お巡査さんの方へ、手さぐりに寄りながら、「もう、旦那さん、勘忍して下さい。",
              "citation": {
                "source": "納豆合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
