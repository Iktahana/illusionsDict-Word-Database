[
  {
    "uuid": "dabc311b-564d-509e-b2a8-8fe13be69aa4",
    "entry": "泣き出す",
    "reading": {
      "primary": "なきだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行",
        "動詞-自動詞"
      ],
