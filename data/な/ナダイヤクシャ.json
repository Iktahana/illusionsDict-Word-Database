        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "その芝居では、市川海老蔵が名題役者として舞台を引っ張った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "あの名題役者の演技は、見る者を惹きつける魅力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "かつては若手だった彼も、今では立派な名題役者だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "竜池は中村、市村、森田の三座に見物に往く毎に、名題役者を茶屋に呼んで杯を取らせた。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十年頃、団七から名題役者になつたばかりの市川新十郎は、「文芸倶楽部」の上において当時の家橘・栄三郎――梅幸――の美しさを讃へた。",
              "citation": {
                "source": "市村羽左衛門論",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "入谷の親分が一人、子分に見放され、千五百石の旗本が潰れ、名題役者が一人首を縊りました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "活き佛",
                "note": "青空文庫"
              }
            },
            {
              "text": "根岸の親分が一人、子分に見放され、千石取の旗本が潰れ、名題役者が一人首を縊りました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "活き仏",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
