          "literary": [
            {
              "text": "泣いても笑ってもいけないのだ。",
              "citation": {
                "source": "怪夢",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "「泣いても笑っても今日はもう仕方がねえ。",
              "citation": {
                "source": "半七捕物帳",
                "author": "湯屋の二階",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう泣いても笑っても仕方がないと、お染もきのう今日は諦めてしまった。",
              "citation": {
                "source": "鳥辺山心中",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "腕を組んで漫歩する紳士が、枝に止まった小鳥のように目白押しする彼等の、その真正面で、ペッと地面に不作法な唾を吐く――　其でも彼等は体を揺って、ハハと笑う、ハハと笑う……　皆が侮る黒坊、泣いても笑っても、白くは成れない黒坊……南の国で卿の仲間が火で燃き殺される、その煙、その臭い――。",
              "citation": {
                "source": "一粒の粟",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人が終ったら、あとはもう泣いても笑ってもこの私だ。",
              "citation": {
                "source": "小説　圓朝",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いても笑ってもあと何日――町へ出てみると、しみじみとそんな気がするのだった。",
              "citation": {
                "source": "丹下左膳",
                "author": "乾雲坤竜の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "今さら泣いても笑っても、できた事で致し方なしだ。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いても笑っても、もう追付かないので、何もその日にきっかり出来ずとも、最も良い結果を得さえすれば、三日四日の日などを、故の先生は気にもお止めなさるまいということになって、一週間の猶予が善良なる故牧師の霊から与えられることになった。",
              "citation": {
                "source": "貧しき人々の群",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣いても笑っても一人である。",
              "citation": {
                "source": "暦",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
