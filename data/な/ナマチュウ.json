    "definitions": [
      {
        "index": 1,
        "gloss": "medium-size draft beer",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
