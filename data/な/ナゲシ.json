[
  {
    "uuid": "6b1ba951-7d04-5248-a846-c7aeaec1912c",
    "entry": "長押",
    "reading": {
      "primary": "なげし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
