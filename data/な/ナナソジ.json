          "literary": [
            {
              "text": "今老いて、七十路過ぎて、さらさらに何の事なし。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "縁側もない破屋の、横に長いのを二室にした、古び曲んだ柱の根に、齢七十路に余る一人の媼、糸を繰つて車をぶう／＼、静にぶう／＼。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "七十路の歳にたわまぬ猛男には老の奴も怖ぢおそるらん酒。",
              "citation": {
                "source": "禮嚴法師歌集",
                "author": "與謝野禮嚴",
                "note": "青空文庫"
              }
            },
            {
              "text": "当世の韓蘇、大史公、奇しき力を身に兼ねて、七十路経たる来し方も千歳の業を立てましぬ。",
              "citation": {
                "source": "晶子詩篇全集拾遺",
                "author": "與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "照りかわくほこり路に七十路の人の影いともちいさしちさきまま消えやらぬそのかげよ愛憎はげにも果てなし　僕は、歩きながら、こんな詩を作った。",
              "citation": {
                "source": "次郎物語",
                "author": "第三部",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
