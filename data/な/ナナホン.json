    "definitions": [
      {
        "index": 1,
        "gloss": "seven (long cylindrical things)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
