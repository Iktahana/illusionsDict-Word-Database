[
  {
    "uuid": "f4288bc2-1b59-52b4-841b-c9e301b7609f",
    "entry": "慰む",
    "reading": {
      "primary": "なぐさむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
