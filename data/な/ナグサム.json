    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to feel comforted",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ミスタンゲットを取り去ってもミスタンゲットの顧客は他に慰む手段もあろう。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ダミアを取り去るときダミアの顧客に慰む術は無い。",
              "citation": {
                "source": "巴里の唄うたい",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、それを慰むべき手段は次第に潜行的に、意表に出てくるのだった。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "当座の花だ、むずかしい事はない、安泊へでも引摺込んで、裂くことは出来ないが、美人の身体を半分ずつよ、丶丶丶の令息と、丶丶の親類とで慰むのだ。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "かく氣の沈んで居る時には、賑はしき光景にても眺めなば、幾分か心を慰むる因ともならんと考へたので、私は兩人を引連れて、此時一｜番に賑はしく見えた船首の方へ歩を移した。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "と言語を尽して慰むれば、頷くように眼を閉じぬ。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これではならぬ、と御迎の使者相望めば、御機嫌を見計らいて侍女は慰むる。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの女は幽霊の真似をして人を威して慰むような剽軽者ではございません。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、会社のほうでは穏便がいいというので、むろん片手落ちの裁判だけれど、私が因果を含められて、雇を解かれたのさ」　白糸は身に沁む夜風にわれとわが身を抱きて、「まあ、おきのどくだったねえ」　渠は慰むる語なきがごとき面色なりき。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミスタンゲットを取り去つてもミスタンゲットの顧客は他に慰む手段もあらう。",
              "citation": {
                "source": "ダミア",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、年頃になるまで外国で育つた桑子のすることには、日本の習慣に馴れない一種の愛嬌があつて慰むこともある。",
              "citation": {
                "source": "花は勁し",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ覆載の間、朝野の別を問わず、人皆、各自の天職に心力を労すればまたその労を慰むるの娯楽なかるべからざるは、いかにも本然の理と被存候。",
              "citation": {
                "source": "不審庵",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつも引籠勝で、色も香も夫ばかりが慰むのであったが、今日は寺町の若竹座で、某孤児院に寄附の演劇があって、それに附属して、市の貴婦人連が、張出しの天幕を臨時の運動場にしつらえて、慈善市を開く。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何も悪気のある人ではなし、私とお米との仲を知ってるわけもないのでございますから、驚かして慰むにも当りません、お米は何にも知らないにしましても、いっただけのことはその日ありましたに違いないのでございますもの。",
              "citation": {
                "source": "政談十二社",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「南鍋町の風月堂の二階の洋食といえば、もとはお店の手代衆が前垂れかけで皿を運んで来たもんだが、へえ、そうかねえ、いつからそんなボーイ姿になったのかねえ、あれも旧舗らしくてよかったものだがねえ」　むかしの話も初老前後の男女たちには何かと心慰むよすがになると見えます。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁淺からず、ひとごとならず思へば、時をりに行きては墓を清め、花などをささげて、我と亦自ら慰む。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生を慰むるといふ事より、Pleasure なるものが、詩の美に於て、欠くべからざる要素なる事を知るを得べし。",
              "citation": {
                "source": "明治文学管見",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "因縁浅からず、ひとごとならず思へば、時をりに行きては墓を清め、花などをささげて、我と亦自ら慰む。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "之を窺ふに堤坊の决壞せるもの往々にしてあり、其水※を對岸の景致をみれば、心慰むるの趣なきに非ずと雖、抑も亦其沿岸居民の慘あるを思へば悄然として憂なきに非るなり。",
              "citation": {
                "source": "草津行",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "明治三十年七月、予上毛草津の温泉に浴しき、地は四面めぐらすに重疊たる山嶽を以てし、風物の一も眼を慰むるに足るものあることなし。",
              "citation": {
                "source": "長塚節歌集　中",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて作り畢りたるとき、われ穉き物語して慰むるに、かれも今はわが國の詞を解して、面白がりたり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "外に出でゝ風に吹かれなば、心寂しきけふを慰むるに足ることもやと思ひて、獨り街に立ち出でぬ。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "身の周圍なる事々物々、皆我を慰むるものに似たり。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "さればこの假の世を、フラミニアの厭ひしも、アヌンチヤタの去りぬるも、なかなかに慰む方ありとやいふべき。",
              "citation": {
                "source": "即興詩人",
                "author": "IMPROVISATOREN",
                "note": "青空文庫"
              }
            },
            {
              "text": "かかるものをいかなる言もて慰むべき。",
              "citation": {
                "source": "誓之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "單純な境涯にある眞奈が心には、平氣なやうな苦悶があるやうな、手古奈の詞が十分に呑込めないから、そんなこといつたつてと一言云うたぎり、手古奈を慰むるすべも知らないのである。",
              "citation": {
                "source": "古代之少女",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "他に嗜好のない私には妻の美貌といふことが私を慰むべき唯一の條件であるのです。",
              "citation": {
                "source": "教師",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "余は無教会となりたり、人の手にて造られし教会今は余は有するなし、余を慰むる讃美の声なし、余のために祝福を祈る牧師なし、さらば余は神を拝し神に近くための礼拝堂を有せざるか。",
              "citation": {
                "source": "基督信徒のなぐさめ",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あるいは人生の長き実験より、あるいは深き学識より、あるいは温き同情より彼を慰むれどもいずれも問題の中心に触れない。",
              "citation": {
                "source": "ヨブ記講演",
                "author": "内村鑑三",
                "note": "青空文庫"
              }
            },
            {
              "text": "庄屋は此の畜生、おれの女房をなぐさむつもりかも判らないぞと、外から縁側へあがって庖厨の障子の破れから覗いて見ると、狸は女房と話をしておる。",
              "citation": {
                "source": "怪談覚帳",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
