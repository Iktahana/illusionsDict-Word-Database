        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "強いていおうならば北斗南面して看るという唐ようの古語にでも表現を譲るより仕方はあるまい。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "場所は切支丹屋敷内であって、その法庭の南面に板縁があり、その縁ちかくに奉行の人たちが着席し、それより少し奥の方に白石が坐った。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昌、絲を以て虱を※に懸け、南面して之を臨む。",
              "citation": {
                "source": "術三則",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "十八日、丙戌、霽、子剋、将軍家南面に出御、時に灯消え、人定まりて、悄然として音無し、只月色蛬思心を傷むる計なり、御歌数首、御独吟有り、丑剋に及びて、夢の如くして青女一人前庭を奔り通る、頻りに問はしめ給ふと雖も、遂に名乗らず、而して漸く門外に至るの程、俄かに光物有り、頗る松明の光の如し。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "九日、壬辰、常の御所の南面に於て、終日諸人の愁訴を聴断し給ふ、各藤の御壺に候して、子細を言上す。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "身は高皇帝の子にして、南面して王となる、豈能く僕隷の手に辱しめられて生活を求めんやと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "北面に鷲、南面に菊の御紋章が浮彫りにしてあった。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "少女が入って往って、「傘の主｜詣で給うを誘い奉る」と云うと、真女児が出て来て、南面の室に豊雄をあげた。",
              "citation": {
                "source": "蛇性の婬",
                "author": "雷峯怪蹟",
                "note": "青空文庫"
              }
            },
            {
              "text": "紀久子はその隙に敬二郎の死骸を抱き上げて、南面している戸口のほうからバルコニーのほうへ駆け出していった。",
              "citation": {
                "source": "恐怖城",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南面した山の中腹に鳳來寺がある。",
              "citation": {
                "source": "鳳來寺紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "なほしかもその廣大な原野は全體にかすかな傾斜を帶びて富士を背後におほらかに南面して押しくだつて來てゐるのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "駿河灣一帶の風光",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもなほその廣大な原野は全帶にかすかな傾斜を帶びて富士を背後におほらかに南面して押し下つて來てゐるのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "四邊の山より富士を仰ぐ記",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、あとへ退って、南面に、不忍の池を真向いに、高欄の縁下に添って通ると、欄干の高さに、御堂の光明が遠くなり、樹の根、岩角と思うまで、足許が辿々しい。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "南面の窓に並んで、鉄筋｜混凝土の上層建築が半分ほど出来あがっていた。",
              "citation": {
                "source": "都会地図の膨脹",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "成敗存亡禍福古今の道を歴記し、然して後に要を乘り本を執り、清虚以て自ら守り、卑弱以て自ら持す、これ人に君として南面するの術也。",
              "citation": {
                "source": "道教に就いて",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその崖を登り切ると其處にはまた眼も及ばない平野がかすかな傾斜を帶びて南面して押し下つてゐたのである。",
              "citation": {
                "source": "樹木とその葉",
                "author": "自然の息自然の聲",
                "note": "青空文庫"
              }
            },
            {
              "text": "六里ヶ原と呼ばれてゐる淺間火山の大きな裾野に相對して、白根火山の裾野が南面して起つて居る。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "六里ヶ原と呼ばれている浅間火山の大きな裾野に相対して、白根火山の裾野が南面して起って居る。",
              "citation": {
                "source": "みなかみ紀行",
                "author": "若山牧水",
                "note": "青空文庫"
              }
            },
            {
              "text": "その地位は、二重橋を這入った正面の御玄関からぐるりと廻って南面したところの御玄関先ということに決まりました。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "木彫の楠公を天覧に供えたはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドクロが荘子に向かって己れのたのしみは南面王にも真似は出来まいといって大気焔をあげている。",
              "citation": {
                "source": "だだをこねる",
                "author": "辻潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "此大墓石と共に南面して、其西隣に小墓石がある。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（臨渙裴明府席遇張十一房六）県城南面漢江流、江嶂開成南雍州。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "中央の室に南面された院のお席に向き合って太政大臣の座があった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "幻花子は佛骨子と共に、松下南面の左端から掘り進み。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "嶺の千鳥窪",
                "note": "青空文庫"
              }
            },
            {
              "text": "然う斯うして居る間に、松下南面の方は大概掘り盡して了つた。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "嶺の千鳥窪",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは根方地で、街道から南面し、右手に小徑がある、それを曲つてから、又右手の畑が目的地だ。",
              "citation": {
                "source": "探檢實記　地中の秘密",
                "author": "馬籠と根方",
                "note": "青空文庫"
              }
            },
            {
              "text": "されバ今如此の事を聞くハ、定めて小人共私の頭上に其賢大夫のおらぬをうれたみ、ゆハゆる南面してせいすれバ北方うらむの儀ならんか。",
              "citation": {
                "source": "手紙",
                "author": "慶応三年三月六日　印藤肇あて",
                "note": "青空文庫"
              }
            },
            {
              "text": "ショー台の南面はスキー場になっていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "円柱の南面には、長方形に削り取られた中に、もう磨滅しきった朧な仏の立像が、かすかにそれと見分けられる。",
              "citation": {
                "source": "地水火風空",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "宮城から南面して宗廟の方は左に在つて社稷の方が右に在る、宗廟とは歴代祖先の御靈舍で、御靈を祀つて居りますが、社稷の方は御靈舍ではありませぬ、壇を拵へて、その上で天のお祭りをするのであります。",
              "citation": {
                "source": "支那の古代法律",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            }
          ]
        }
