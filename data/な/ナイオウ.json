  {
    "uuid": "f1d102f2-857c-5386-85c5-878f5b1cc171",
    "entry": "内応",
    "reading": {
      "primary": "ないおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
        "動詞-サ変",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "secret understanding",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すぐ堪へ切れない内応者があつて、細胞はまた一時に爆発した。",
              "citation": {
                "source": "過去世",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "こゝに於て誠を遣りて燕に還らしめ、内応を為さしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "待設けたる斉泰は、たゞちに符を発し使を遣わし、往いて燕府の官属を逮捕せしめ、密に謝貴張※をして、燕府に在りて内応を約せる長史葛誠、指揮盧振と気脈を通ぜしめ、北平｜都指揮張信というものゝ、燕王の信任するところとなるを利し、密勅を下して、急に燕王を執えしむ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "小田の重臣に内応するものあり、乗ずべしとて、佐竹方や多賀方の豪傑どもを招き、その内応の手紙さへ示したるに、豪傑ども、三楽に加勢することを諾す。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "然るに愈々小田城に押しよせて見れば、一向内応の模様なし。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸将こは如何にと怪しめば、実は内応ありたるに非ず。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯々連歌の酒宴ある夜なれば、内応にもまして都合よし。",
              "citation": {
                "source": "秋の筑波山",
                "author": "大町桂月",
                "note": "青空文庫"
              }
            },
            {
              "text": "城方は兵糧がない上に、山田｜右衛門作と申す者が、有馬勢に内応の矢文を射た」という噂が人々の心を引き立たせた。",
              "citation": {
                "source": "恩を返す話",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "開戦間際に味方を出し抜き、こっそり敵陣へ来られたからには、内応と見当をつけるが当然。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人間の欲望押しつめると、二つの外には出ませんからなあ」聞こえる物音　内応であろう？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……ところで内応の方法は？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「結構な内応、満足でござんす。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "これらは日本の中において旧勢力と抱き合っているばかりでなく、世界のファシズム的傾向に内応する要素で民主化にとって害悪のあるものです。",
              "citation": {
                "source": "討論に即しての感想",
                "author": "――新日本文学会第四回大会最終日に――",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして外面から来る誘惑、就中異性の誘惑は、この自ら喜ぶ情と媚とが内応をするので、己の為めには随分｜防遏し難いものになっているに相違ないのである。",
              "citation": {
                "source": "青年",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "右衛門作、氏は山田、肥前の人で、島原の乱に反徒に党して城中に在ったが、悔悟して内応を謀り、事｜覚われて獄中に囚われていたが、乱｜平ぎたる後ち、伊豆守はこれを赦して江戸に連れ帰り、吉利支丹の目明しとしてこれを用いた。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "○同九月十九日、九条公｜復た出でて事を視、近衛公内覧を辞す（九条公は去る四日関東内応の非難を被り、公卿の衆議に迫られて辞職したるもの）。",
              "citation": {
                "source": "吉田松陰",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬戸内には、村上、来島一族の水軍も味方にひかえ、大坂の本願寺衆とはかたく結び、摂津そのほか所在の内応も少なくない。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご推察にたがわず、三木城の別所｜長治の手勢にちがいないものが約三百名、北方二里ほど先のご領外まで潜行しており、あの辺の林や山に潜んで、ひたすらこの御着の城内から内応の合図があるのを待ちかまえておる様子でございまする。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "なぜならば、この城が、その程度の兵力と要害しか持たないものであるばかりでなく、外より攻めずとも、内に有力なる毛利の内応者がいるからである。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひそかに連絡を取って、日時を約し、　――内応の火の手をあげよ。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「事情はわからぬが、明後日の夜半と期していた城中の内応が、突然、たった今、火の手となって勃発いたした。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "城門附近にいた内応組の伊丹亘が居あわせた足軽組をひきつれて来て、荒木方の武者を、圧倒的な兵数で叩きはじめたのである。",
              "citation": {
                "source": "黒田如水",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして万一、奉天軍が兵を起こせば、張景恵が我方に内応して、奉天独立の軍を起こして、その後の満洲事変が一気に起こる手筈もあったのだが、奉天派には賢明な蔵式毅がおって、血迷った奉天軍の行動を阻止し、日本軍との衝突を未然に防いで終った。",
              "citation": {
                "source": "私が張作霖を殺した",
                "author": "河本大作",
                "note": "青空文庫"
              }
            },
            {
              "text": "次でホンデュラスの征服も企てられたが、その遠征隊の司令官がキュバ総督に内応したため、コルテスは自ら一部隊を率い陸路ユカタン半島の根元を横断してホンデュラスの北岸へ赴いた。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "九条村では信者の親戚や知己の家を転々して隠れていたが、掠奪に来た荒木の兵士やそれに内応した村人たちに対し、危険を顧みず敢然としてフロイスを庇ったのは、その父がキリシタンであったという一人の異教徒であった。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "若江の城は信長が将軍義昭を逐うた頃には三好義継の居城となって居り、義昭もさしずめ宇治の槇の島からこの若江の城に送りつけられたのであったが、その冬信長の軍に攻囲せられた時、池田丹後は他の部将たちと共に信長方に内応し、義継を自殺せしめたのである。",
              "citation": {
                "source": "鎖国",
                "author": "日本の悲劇",
                "note": "青空文庫"
              }
            },
            {
              "text": "なれども、このおり、岐阜においては三七どのがふたゝび上方をてきになされて柴田がたに内応あそばし、やまとの筒井じゅんけいどのも日ならずうらぎりをなさる手筈がきまっておりましたそうでござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
