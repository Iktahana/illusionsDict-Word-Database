[
  {
    "uuid": "09621e3d-aad8-5814-81ec-ebc94533e370",
    "entry": "内奥",
    "reading": {
      "primary": "ないおう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
