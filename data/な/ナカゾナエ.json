        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と云うので、中備を十時伝右衛門、後備は宗茂と定った。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "前備小野和泉が出登しようとして居る処へ馳け込んだのは中備の将十時伝右衛門である。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "伝右衛門は総勢を一所に集めて、「敵を間近に引寄せて置いて急に後方に血路を開き、中備の隊まで引取るべし。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "我部隊中備と合したならば直ちに取って返し一文字に突破すべし。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "中備小野和泉入替って戦うたが易く破れる気色もない。",
              "citation": {
                "source": "碧蹄館の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「志我津の子ら」とあるから、志我津即ち今の大津あたりに住んでいた女で、多分吉備の国（備前備中備後｜美作）から来た采女で、現職を離れてから近江の大津辺に住んでいたものと想像せられる。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "六　後の備前美作備中備後の四國の總稱。",
              "citation": {
                "source": "古事記",
                "author": "校註　古事記",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち、あなたのお考え一つでは、備中備後の二ヵ国を進ぜようとまでの御誓紙でござる。",
              "citation": {
                "source": "新書太閤記",
                "author": "第七分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
