        "examples": {
          "standard": [
            {
              "text": "冬が近づき、庭に咲く名残の花が寂しげに揺れている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "このコスモスは、今年の秋の名残の花だね。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "春の終わりに咲く桜は、まさに名残の花という風情がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "葉桜の水たまりでは蛙がしんみり鳴き、料理屋では名残の花見客がドンチヤン騒いでゐた、私たちも酔ふた、酔歩まんさんとして、自動車に揺られて戻つた、戻るなり前後不覚でぐつすりと睡つたのである、ありがたし／＼。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十四年",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の周囲には繍線菊が多く、いまだに名残の花をつけている。",
              "citation": {
                "source": "雲仙岳",
                "author": "菊池幽芳",
                "note": "青空文庫"
              }
            },
            {
              "text": "春の名残の花は散り椎の落葉はつもりたり。",
              "citation": {
                "source": "偏奇館吟草",
                "author": "永井壮吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
