    "definitions": [
      {
        "index": 1,
        "gloss": "above anything else",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "感覚、つまり自然を何よりも大事に守つて居るからである。",
              "citation": {
                "source": "草野心平詩集『母岩』",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ふに私のやうな貴族的な性情をもつて生れた人間にとつて何よりも寂しいことは、あのなつかしい「愛」の欠陥である。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて稀にみる子供らしい純一無垢な性情と、そして何よりも人間としての純潔さを、私共は互に愛し悦びあつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "夫人にとっては、それがまた何より面白いので、話がおのずから雄弁になり、子供に聞かすようにしてなだめ話した。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも私は、彼の「聰明さ」が氣に入らなかつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼は、詩の表現效果について意見を述べた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも不可解なのは、一面極めて冷靜なる理智の人でありながら、一面狂氣じみた情熱に内燃してゐる人のやうであつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼の矛盾は、一面に於て「典型的な小説家」でありながら、一面に於て「典型的な詩人」であることだつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも芥川君は、私を本質的によく理解してくれた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あなたのお手紙の文面が、やさしく正直なのも大きな悦びでありましたが、それよりも何よりも、私にはあのお手紙の長さが有難かったのです。",
              "citation": {
                "source": "返事",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "噂に拠れば、男女川はその身長に就いての質問を何よりも恐れるそうである。",
              "citation": {
                "source": "男女川と羽左衛門",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」山田君は、何よりも先に、その箇所に目をそそいで言った。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間修業」だの、「自然に親しむ」なぞといふことが云はれるが、それはもとより大切乍ら、それと詩とは只関係が密接なだけで、先づ何よりも先人の作品は読まれなければならぬ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼はもと善良な人で、その善良は今も依然存するが、彼の善良は働きを失つてゐる。",
              "citation": {
                "source": "詩に関する話",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりもその證據は、子供たちの悦ぶ映畫が、常に忍術使ひの出るチヤンバラ劇と、奇々怪々の夢に充ちた漫畫映畫と、ポンチ的諧謔のチヤツプリンとに限られてゐる。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代日本語の整理を意圖する上に、何より必要にして必須なことは、國語のデタラメ發音を一掃して、日本語をその正しく純粹な音韻に統一することである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも我々は、國語問題の急務として、今日「耳の健康」を囘復せねばならないのである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "現代の通用化した日本語が、時代の過渡期混亂によつて、悉く皆音痴的に病疾されたものだとすれば――正にまたその通りであるが――時代の新しい更生教育は、何より先づその醫療に努めねばならないのである。",
              "citation": {
                "source": "ローマ字論者への質疑",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも彼の心は、そうした「家郷」が欲しかったのだ。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　おそろしい冬に於て、何よりも人々は火を愛した。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中、信州の渋とか湯田中といふやうな百姓めいた温泉、言はば「田舎者の湯治場」といつた感じのする所は何より嫌ひだ。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの辺は、伊香保にとつて何より大切な第一印象であるから、も少しフレツシユな色調をもたせることが必要である。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何よりも気温の高くなるのが、ありがたいのである。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分はこの事を考えると、何よりも年老いた父に気の毒だ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "葡萄棚もあり、枝折戸もあり、何よりも値が安く、六圓五十錢なので、それが嬉しかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舍者の私には、それが何より頼もしく思はれた。",
              "citation": {
                "source": "郷愁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その天空に浮遊するかの如き、嶮にして美なる林道を「天の浮橋」と呼ぶそうであるが、何よりも喬木林の陰森さにおどろかされる。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こんな好い加減の目の子勘定を並べてありふれの年賀状全廃説を称えていたが、本当はそういう国家社会の問題はどうでもよいので、実際はただせっかくの書きいれ時の冬の休みをこれがために奪われるのが彼の我儘に何より苦痛であったのである。",
              "citation": {
                "source": "年賀状",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "白つぽい砂礫を洗ふ浅緑色も一種特別なものであるが、何よりも河の中洲に生えた化粧柳の特異な相貌はこれだけでも一度は来て見る甲斐があると思はれた。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "今からその時に備えるのが、何よりも肝要である。",
              "citation": {
                "source": "津浪と人間",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
