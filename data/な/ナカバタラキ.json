    "definitions": [
      {
        "index": 1,
        "gloss": "maid (not working in the kitchen or living quarters)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "七兵衛は四谷の忍町に五代つづきの質屋を営んでいて、女房お此と番頭庄右衛門のほかに、手代三人、小僧二人、女中二人、仲働き一人の十一人家内で、おもに近所の旗本や御家人を得意にして、手堅い商売をしていた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その五月末の夕がたに、お元が仲働きのお国と共に近所の湯屋へ行った留守をうかがって、お此は夫にささやいた。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのせいか、今朝はあたまが重くって、何をたべる気もなしにぼんやりしていますと、仲働きと女中の話し声がきこえまして……。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　あまりに気分が悪いので、お元は台所へ水を飲みにゆくと、女中部屋で仲働きのお国が女中お芳に何か小声で話しかけている。",
              "citation": {
                "source": "鼠",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲働きのカレンが見てゐた時、二人は前の馭者台に並んで乗つてゐて、その車が恐ろしい速度で中庭の芝生を通つて、薔薇の花壇を蹂躪して走つて来たさうだ。",
              "citation": {
                "source": "薔薇",
                "author": "ROSEN",
                "note": "青空文庫"
              }
            },
            {
              "text": "一体どうしたんです」「きのうのお午すぎに仲働きのお竹どんを連れて、浅草の観音様へお詣りに行ったんですが、途中でお菊さんにはぐれてしまって、お竹どんだけがぼんやり帰って来たんです」「きのうの午過ぎ……」と、半七も顔をしかめた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "奥はお寅親子と仲働きのお竹と、ほかに台所を働く女中が二人いることも、半七はことごとく記憶していた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲働きのお竹にも逢った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "石燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "半七　ここの家はお冬どんという小綺麗な仲働きがいる筈だ。",
              "citation": {
                "source": "勘平の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、ちょいと来ておくれと云うに……」　女の声が耳にはいったので、半七はふと見かえると、どこかの寮らしい風雅な構えの門の前で、年頃は二十五六の仲働きらしい小粋な女が、一人の按摩の袂をつかんで曳き戻そうとしているのであった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "それですから、仲働きのお時さんには気の毒ですけれども、この頃は無理に振り放して逃げてくるので……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "万事の首尾は仲働きのお時が呑み込んでいて、ほかの者にはちっとも知らさなかった。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから仲好しの仲働きに云い付けて、おきんが廓から夜遅く帰って来るところを、無理に寮のなかへ呼び込んで、さんざん怨みを云った上で、まあひどいことをするじゃありませんか。",
              "citation": {
                "source": "半七捕物帳",
                "author": "春の雪解",
                "note": "青空文庫"
              }
            },
            {
              "text": "その報告によると、上州屋の奉公人は番頭小僧をあわせて男十一人、仲働きや飯炊きをあわせて女四人である。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "男どもの方は後廻しにして、半七は先ず女の方のしらべを訊くと、仲働きはお清、三十八歳。",
              "citation": {
                "source": "半七捕物帳",
                "author": "筆屋の娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "頓死にもいろいろあるが、どんな死に方をしたのだ」「それにもいろいろの噂があるのですが、わっしがお千代という女中をだまして聞いたところじゃあ、まあ、こんな話です」　関口屋ではお由、お千代、お熊という三人の女を使っているが、お由は仲働きで、他の二人は台所働きである。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だんだん聞いてみると、お由という女は仲働きのように勤めてはいるが、実は主人の姪だそうで……」「唯の奉公人じゃあねえのか」「主人の兄きの娘です。",
              "citation": {
                "source": "半七捕物帳",
                "author": "かむろ蛇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「こうなれば何もかも申し上げますが、実は仲働きのお冬という女に手をつけまして……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "勘平の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "内儀さんは背の低い、品のない、五十四、五の女で、良人に羽織を着せる時、丈一杯｜爪立てする様子を、お庄は後で思い出し笑いをしては、年増の仲働きに睨まれた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十　こっちの仲働きが向島のと入れ替った。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　こっちの仲働きは内儀さんからこう言い渡されたとき、奥から下って来ると厭な顔をして、黙って火鉢の傍で莨ばかり喫していた。",
              "citation": {
                "source": "足迹",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤も此の様を見ずとても下女や仲働きが「秘書官」と云う様な文章も観察と共に優れた本を著わし得る筈はない故、少し考えればお酉でないと充分に分る所では有るのサ。",
              "citation": {
                "source": "幽霊塔",
                "author": "黒岩涙香",
                "note": "青空文庫"
              }
            },
            {
              "text": "去年の秋、須田の家へ仲働きとして入って以来、何ともなかったのに、時候が暖かくなるにつれ、却て工合が悪かった。",
              "citation": {
                "source": "氷蔵の二階",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "然しあれは仲働きの候補で、いやだから一日でよしたと云つた。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "毒藥を飮む女",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとうにこの一週間程の真剣さと云ったら彼女自身でも驚く程でしたところへ昨日仲働きへ電報で姉が危篤だと云うのです。",
              "citation": {
                "source": "二月七日",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほんとは、もっと早く奉公に出されぬ前、祖母が死ぬと直きに、弟をねんねでおんぶした仲働きが、人形町までといって出た、あたしの買いものの供に付けて出されたが、この女中は二十歳を越していて、何かよくわかったから、却って道案内をしてくれて、神田小川町の竹柏園の門に立ったことがあったのだ。",
              "citation": {
                "source": "渡りきらぬ橋",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "へい、私は仙介という者で」　などお三どんや仲働きや、庭掃きの爺やにまで愛嬌を振り撤いた。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご用聞きには惜しいわね」などとお三どんは仙介のことを、仲働きへ噂したりして、仙介の評判は来た日から良かった。",
              "citation": {
                "source": "十二神貝十郎手柄話",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "須永の家は彼と彼の母と仲働きと下女の四人暮しである事を敬太郎はよく知っていたのである。",
              "citation": {
                "source": "彼岸過迄",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お散歩どすか」　奥から飛んで出てきた仲働きのお手伝いさんが、慌てて宿屋の焼印のある下駄を踏石の上に揃えた。",
              "citation": {
                "source": "蠅男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
