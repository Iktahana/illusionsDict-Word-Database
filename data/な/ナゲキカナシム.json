[
  {
    "uuid": "35ccde18-d879-55ab-90d2-7c9ed857f1a5",
    "entry": "嘆き悲しむ",
    "reading": {
      "primary": "なげきかなしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行"
      ],
      "ctype": null,
