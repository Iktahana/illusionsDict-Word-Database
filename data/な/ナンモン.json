    },
    "definitions": [
      {
        "index": 1,
        "gloss": "south gate",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ある人は「南門殿還幸」を意味すると言っていたがそれはあまり当てにはならない。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "幸村茶臼山に陣し、毛利勝永は天王寺南門に備え、大野治長の先鋒銃隊東に在り、左方岡山口は大野治房を配し、迂回すべき遊軍は明石｜全登が精兵三百を率いた。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "また、同じ刻限、天王寺表の嚮導、石川伊豆守、宮本丹後守等三百余人が平野の南門に着した。",
              "citation": {
                "source": "真田幸村",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中をだんだん南門のほうに遠ざかって行く倉地を見送っていると葉子はとてもそのままそこに居残ってはいられなくなった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「勝手にせい……ばかっ」　やがてそう激しくいい捨てると思うと、倉地は腕の力を急にゆるめて、洋傘を拾い上げるなり、あとをも向かずに南門のほうに向いてずんずんと歩き出した。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "沼南にはその後段々近接し、沼南門下のものからも度々噂を聞いて、Ｙに対する沼南の情誼に感奮した最初の推服を次第に減じたが、沼南の百の欠点を知っても自分の顔へ泥を塗った門生の罪過を憎む代りに憐んで生涯面倒を見てやった沼南の美徳に対する感嘆は毫も減ずるものではない。",
              "citation": {
                "source": "三十年前の島田沼南",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは東京日日新聞の従軍記者として満洲の戦地にあって、遼陽陥落の後、半月ほどは南門外の迎陽子という村落の民家に止宿していたが、そのあいだの事である。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "遼陽の南門外に宿っている時、宵から大雨、しかも激しい雷鳴が伴って、大地震のような地響きがするばかりか、真青な電光が昼のように天地を照らすので、戦争に慣れている私たちも少なからず脅かされた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "南門外は一面の畑で、馬も隠るるばかりの高粱が、俯しつ仰ぎつ秋風に乱れている。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "（同上）　　　盂蘭盆　撫州の南門、黄柏路というところに七という兄弟があって、帛を売るのを渡世としていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "異聞総録・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "この宮城の正南門の承天門から、皇城の正南門の朱雀門を經て、京城の正南門の明徳門に至るまで、南北を一貫せる大通りがある。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "青龍寺は西明寺とは反對に、左街の東邊の新昌坊の南門の東に在つた。",
              "citation": {
                "source": "大師の入唐",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その結果勅命で國都洛陽の西郊の白馬寺の南門外に壇を築き、壇上に道經を積み火を放つた所が、道士等の祕術を盡したにも拘らず、道經は悉く焚け盡し、術に破れたる道士等は悉く出家して佛門に歸したと記載してある。",
              "citation": {
                "source": "老子化胡經",
                "author": "桑原隲藏",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌｜朝は馬車を駆つて市の南門を出で、セエル河を渡つて郊外のサンタ・※ルタン村に遊んだ。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "長春城は伊通河の左岸に臨み、北門から南門まで約十八町、東門から西門まで約三十町、周囲九十六町、不規則な長方形を成し、幅の薄い瓦壁を繞らしてゐるのは近代の築造だからである。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は南門内にある城隍廟を一拝した。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "南門を出ると伊通河に長い木橋が掛つてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "×　引返して南門外の古物市場（俗称小盗市）の雑沓を見て、再び商埠地を過ぎ、東支鉄道の終端駅である寛城子へ行き、露西亜街の広く静かな地区の高い楡の並木の蔭を一巡した。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "商鞅が秦の孝公に仕えて相となったとき、その新政の第一着手として、先ず長さ三丈の木を市の南門に立てて、もしこの木を北門に移す者あらば十金を与うべしという令を出した。",
              "citation": {
                "source": "法窓夜話",
                "author": "穂積陳重",
                "note": "青空文庫"
              }
            },
            {
              "text": "僧三　私はあの時鳥羽の南門までお供をいたしました。",
              "citation": {
                "source": "出家とその弟子",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "即、正南門の朱雀門に、対当する建て物であつた。",
              "citation": {
                "source": "唱導文学",
                "author": "――序説として――",
                "note": "青空文庫"
              }
            },
            {
              "text": "（（中略））なお同人の同僚につきいろいろ承り候ところ、彼は軍中の悪まれ者ながら戦争のみぎりは随分相働き、すでに金州攻撃の際も、部下の兵士と南門の先登をいたし候由にて、今回もなかなか働き候との事に御座候。",
              "citation": {
                "source": "不如帰　小説",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお同人の同僚につきいろいろ承り候ところ、彼は軍中の悪まれ者ながら戦争のみぎりは随分相働き、すでに金州攻撃の際も、部下の兵士と南門の先登をいたし候由にて、今回もなかなか働き候との事に御座候。",
              "citation": {
                "source": "小説　不如帰",
                "author": "徳冨蘆花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ神祇官の中臣が、榊の枝を笏に取り添へて、南門から這入つて、定座に着いて、寿詞を申し上げる。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　それから次ぎの室で伎楽面などを見ながら待っていてくれたＨ君に追いついて、一しょに宝蔵を出て、夢殿のそばを通りすぎ、その南門のまえにある、大黒屋という、古い宿屋に往って、昼食をともにした。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は法隆寺へゆく松並木の途中から、村のほうへはいって、道に迷ったように、わざと民家の裏などを抜けたりしているうちに、夢殿の南門のところへ出た。",
              "citation": {
                "source": "大和路・信濃路",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は南門の守備長で、いつも鉄槌をひっさげていた。",
              "citation": {
                "source": "蔦葛木曽棧",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて、じくさいさんは　どんな、なんもんを　ようい　しているのでしょう？",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると　じくさいさんは、ゆうゆうと　おちつきはらって、「さて、しゅうけんさん、わたしが　これから　なんもんを　だしますから、りっぱに　こたえてください。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし、しゅうけんさんが　わたしの　なんもんに　こたえられなかったら、今日の　ごちそうは　おあずけにします。",
              "citation": {
                "source": "一休さん",
                "author": "五十公野清一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
