[
  {
    "uuid": "d197a617-4a9c-5a67-b2f7-565f1a8e9812",
    "entry": "南門",
    "reading": {
      "primary": "なんもん",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
