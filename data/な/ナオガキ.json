        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なお書き続けていっていくつかの節目を迎えたとして、原稿の終わりに「えいやっ」とエピローグを置く踏ん切りが、自分で付けられたかどうか。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "……大切なお書き附けでございますもの。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大事なお書き附けでございますもの」　ここでお浦はおかしそうに笑い、甘えるような声でいった。",
              "citation": {
                "source": "血煙天明陣",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、それだから、なお書きたいような気持にもなるのだ。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "その思いは、云わば膝の上に板一枚のせただけでも、あらわせるものだったし、更にその板を奪われても、なお書きつづけられるようなものなのであったから。",
              "citation": {
                "source": "播州平野",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミンナは手紙を書いていたが、テーブルの上から彼に手を差出し、なお書きつづけながら、気乗りのしない様子で彼の消息を尋ねた。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "綱宗（書判）　周防どの　甲斐は尚なお書きのところを、ややしばらく見まもっていた。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜兵衛は尚なお書きをするように、続けて云った。",
              "citation": {
                "source": "樅ノ木は残った",
                "author": "第四部",
                "note": "青空文庫"
              }
            },
            {
              "text": "出来るだけ委しくと、なおなおがきの付いた手紙を受取ったとき、孝之進はお咲を入れて置く部屋の準備にせわしかった。",
              "citation": {
                "source": "日は輝けり",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
