          "literary": [
            {
              "text": "すでに命なり余はまた何をかいわんや。",
              "citation": {
                "source": "将来の日本",
                "author": "徳富蘇峰",
                "note": "青空文庫"
              }
            },
            {
              "text": "但し目的は温泉に非ずというならば、これ路傍の人、また何をかいわんや。",
              "citation": {
                "source": "四十年前の袋田の瀑",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああまた何をかいわんや！",
              "citation": {
                "source": "モンテーニュ随想録",
                "author": "ESSAIS DE MONTAIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "城を出る方針は中止とする」　陳宮は、彼の室を出ると慨然と長大息して――「……ああ、もはや何をかいわんやだ。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "多くをいうな」　そこまでの深慮遠謀があってのことなら、何をかいわんやと、劉曄は慙愧して、魏帝の前を退いた。",
              "citation": {
                "source": "三国志",
                "author": "出師の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "……もはや、何をかいわんや。",
              "citation": {
                "source": "私本太平記",
                "author": "風花帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "歌をうたってすむものなら、なにをかいわんや。",
              "citation": {
                "source": "ノア",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            }
          ]
