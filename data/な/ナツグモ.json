        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さびしい來歴むくむくと肥えふとつて白くくびれてゐるふしぎな球形の幻像よそれは耳もない　顏もない　つるつるとして空にのぼる野蔦のやうだ夏雲よ　なんたるとりとめのない寂しさだらうどこにこれといふ信仰もなく　たよりに思ふ戀人もありはしない。",
              "citation": {
                "source": "青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは耳もない　顏もない　つるつるとして空にのぼる野蔦のやうだ夏雲よ　なんたるとりとめのない寂しさだらう！",
              "citation": {
                "source": "定本青猫",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に雨もよいの夏雲の閉した空は、星あるよりも行方｜遥かに、たまさか漏るる灯の影は、山路なる、孤家のそれと疑わるる。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處の山窪の上の空には夏雲雀が無數に啼いてゐた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "若葉の頃と旅",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、　　　見ぐるしき馬にのりけり雲の峰　　　　　斗入　雲の峰は夏季にして夏雲多奇峰の意なり。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "隅から隅まで小波も立てずに流れる魂の上に、種々の思いが夏雲のように湧いて来る。",
              "citation": {
                "source": "追慕",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、にわかに箱の中から、白く冷たい幽霊のような霞が音もなく夏雲のように立ちのぼり、どっと現れた。",
              "citation": {
                "source": "夏の日の夢",
                "author": "THE DREAM OF A SUMMER DAY",
                "note": "青空文庫"
              }
            },
            {
              "text": "宗教の或ものは、時として、夏雲の秀出でた樣に、その尖頭を神秘の紫電に焦すことはあるが、忽ち枯燥の形式に縮まつてしまう。",
              "citation": {
                "source": "神秘的半獸主義",
                "author": "岩野泡鳴",
                "note": "青空文庫"
              }
            },
            {
              "text": "磐の嗣子｜信治さんは今｜赤坂氷川町の姉壻｜清水夏雲さんの許にいる。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "当主は赤坂氷川町の清水夏雲さん方に寓してゐる信治さんである。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "今茲大正六年に東大久保にある伊沢分家では徳五十九、母柏改曾能八十三、姉長（在福山津山碧山未亡人）六十四、子信匡十六、女たかよ二十九、ちよ二十一、赤坂区氷川町清水氏寓伊沢又分家では信治二十一、母良六十二、姉その（清水夏雲妻）三十四、ふみ二十一、麻布鳥居坂町の宗家を継いだ叔父信平五十七である。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "一昨日この下宿のあるデエーツコエ・セローの公園のずっと先の広い野原で夏雲を眺めながら摘んで来た花であった。",
              "citation": {
                "source": "おもかげ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はピッタリやんでしまって、陰欝な圧しつけられるような夏雲に、夕照の色の胸苦しい夕ぐれであった。",
              "citation": {
                "source": "駅夫日記",
                "author": "白柳秀湖",
                "note": "青空文庫"
              }
            },
            {
              "text": "机の前に坐っていると、目に入るのは、六畳の方の窓からの外へ杉木立、夏雲、村の牛乳屋の細い煙突、二つ三つの藁屋根と、その傍にゆれている薄叢。",
              "citation": {
                "source": "日記",
                "author": "一九四一年（昭和十六年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "ほやり／＼水蒸気立つ土には樹影黒々と落ち、処女の袖の様に青々と晴れた空には、夏雲が白く光る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "思ひにみだるる時の間を夏雲重げに崩れぬる緑か、朱か、君、あかしやの樹かげにあやしき胸の汚染。",
              "citation": {
                "source": "有明集",
                "author": "蒲原有明",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして夏雲のやうな放心。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "玻璃窓の外には、遠く白い夏雲を望んだ。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "何故なら、ちょうどその時、それは羊の毛を浮かべたような夏雲の奥へ飛び込んだところだったからです。",
              "citation": {
                "source": "ワンダ・ブック――少年・少女のために――",
                "author": "A WONDER BOOK FOR BOYS AND GIRLS",
                "note": "青空文庫"
              }
            },
            {
              "text": "その目鏡で私たちは向うの世界の赤坂や麻布の家々の屋根とその上の青い空も、白い夏雲も覗くことが出来た。",
              "citation": {
                "source": "豚肉　桃　りんご",
                "author": "片山廣子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ、夏雲が、水の上に漂っているかと思うと、いつしか、それは消えてしまいました。",
              "citation": {
                "source": "お父さんの見た人形",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "空の上で雷の眷族が大騒ぎをしているような音がし、夏雲の中からプラチナの針金がきらめくような光のマスがあらわれたと思うと、間もなくそれが飛行機のかたちになった。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "映画の〈大地〉のイナゴの場面のようにあとからあとから夏雲の中から、無限に湧いてくる。",
              "citation": {
                "source": "だいこん",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "右の「地災集覧」は白野夏雲氏の編纂したものである。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "白野夏雲氏については、ついでに書いておく事がある。",
              "citation": {
                "source": "地震なまず",
                "author": "武者金吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "山路来て　真夏日明きかそけさに　見つすみとほる空の夏雲　きらゝなり。",
              "citation": {
                "source": "鵠が音",
                "author": "折口春洋",
                "note": "青空文庫"
              }
            },
            {
              "text": "今に彼がやってきたら、俺の胸の内に湧き上る、この夏雲のような心意気を、ぜひ何とかうまく、彼に伝えたいものだが……。",
              "citation": {
                "source": "ある偃松の独白",
                "author": "中村清太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "おだやかな入り海はいかにも夏らしくぎらぎら光って、母のいる一本松の村は白い夏雲の下にかすんで見えた。",
              "citation": {
                "source": "二十四の瞳",
                "author": "壺井栄",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
