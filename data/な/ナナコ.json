    "definitions": [
      {
        "index": 1,
        "gloss": "metal surface decoration with raised fine protrusions resembling fish eggs",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "此間を、男も女も、一頃揃つて、縮緬、七子、羽二重の、黒の五紋を着て往き來した。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帝は高祖｜武帝の第七子にして、誉は武帝の長子にして文選の撰者たる昭明太子統の第二子なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "長子将持、次子将弘、第三子将門、第四子将平、第五子将文、第六子将武、第七子将為と系図には見えるが、将門の兄将弘は将軍太郎と称したとある。",
              "citation": {
                "source": "平将門",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなの人々は、多くはその上に黒い紋付を羽織つて居たが、兔に角、七子か羽二重の紋付の裾から紅緑の彩色の高砂の尉姥、三番叟、龜に乘る人、「大漁」の扇を持つ人、また龍宮、寶船、七福神などの模樣の出て居る所は、また南國の海邊に似付かはしい「眞面目」の服裝であると頷かしめる。",
              "citation": {
                "source": "海郷風物記",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "『和漢三才図会』に蝮の子生まるる時尾まず出で竹木を巻き母と子と引き合うごとく、出生後直ぐに這い行く、およそ六、七子ありという。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "時雄は茶色の中折帽、七子の三紋の羽織という扮装で、窓際に立尽していた。",
              "citation": {
                "source": "蒲団",
                "author": "田山花袋",
                "note": "青空文庫"
              }
            },
            {
              "text": "金物の彫りの方では、唐草の地彫り、唐草彫り、蔓彫り、コックイ（極印）蔓などで地はいずれも七子です。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "彫刻修行のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "村上天皇の第七子｜具平親王六｜世皇孫である俊寛が、南蛮の女と契るなどは、何事であろうと考えた。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "七子の羽織に仙臺平のりうとした袴、太い丸打の眞白な紐を胸高に結んだ態は、何處かの壯士芝居で見た惡黨辯護士を思出させた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "七子の羽織に仙台平のリウとした袴、太い丸打の真白な紐を胸高に結んだ態は、何処かの壮士芝居で見た悪党弁護士を思出させた。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日は故意と日本服で、茶の糸織の一ツ小袖に黒七子の羽織、帯も何か乙なもので、相変らず立とした服飾。",
              "citation": {
                "source": "浮雲",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "そそくさと御仕度をなすって、黒七子の御羽織は剣菱の五つ紋、それに茶苧の御袴で、隆として御出掛になりました。",
              "citation": {
                "source": "旧主人",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "仙台平を窮屈そうに穿いて七子の紋付を人の着物のようにいじろじろ眺めているのもある。",
              "citation": {
                "source": "趣味の遺伝",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「……極上誂織の白七子をお納戸の紋附に染め、江戸褄模様に翻れ梅、紅白の上絵彩色銀糸にて松葉を散らしに縫わせ……英泉の筆意を頼み、下着は縮緬鼠のさや形、帯は花色勝山に色糸を以て阿蘭陀模様を竪縞の如く縫わせたらば類なくてよかろうか。",
              "citation": {
                "source": "残されたる江戸",
                "author": "柴田流星",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の保さんは抽斎の第七子で、継嗣となったものである。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　于鱗は嘉靖七子の一人｜李攀竜のことであらう。",
              "citation": {
                "source": "芭蕉雑記",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "平田は私立学校の教員か、専門校の学生か、また小官員とも見れば見らるる風俗で、黒七子の三つ紋の羽織に、藍縞の節糸織と白ッぽい上田縞の二枚小袖、帯は白縮緬をぐいと緊り加減に巻いている。",
              "citation": {
                "source": "今戸心中",
                "author": "広津柳浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "縮緬、七子、市楽、薩摩、御召、大島、結城位の区別で、その上に、何々御召と名のつき出したのは、ここ二十年位の事で、私は、父が「こう、変った名ばっかりつけよったら、一々憶えられんがな」　と、ぶうぶう云っていたのが、今でも、眼の中にある。",
              "citation": {
                "source": "死までを語る",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "三重吉はどこで買ったか、七子の三つ折の紙入を懐中していて、人の金でも自分の金でも悉皆この紙入の中に入れる癖がある。",
              "citation": {
                "source": "文鳥",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "松葉形に繋ぎ合せた鎖の折れ曲って、表に向いている方が、細く光線を射返す奥に、盛り上がる七子の縁が幽かに浮いている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "富貴の色は蜷局を三重に巻いた鎖の中に、堆く七子の蓋を盛り上げている。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "濃に刻んだ七子は無惨に潰れてしまった。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "両蓋に隙間なく七子を盛る金側時計が収めてあった。",
              "citation": {
                "source": "虞美人草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬えば親戚や自宅の電話番号なども、六七四というのを空（むなし）と覚えるという風で、自宅の二五七九を、「太藺（ふとい）と七子（ななこ）だ。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "織物二つで覚えいいだろう」などといわれましたが、余人にはそれもむつかしいというので、後には「藤色七子」と赤い紙に書いたのが、電話器の下の柱に貼られたようでした。",
              "citation": {
                "source": "鴎外の思い出",
                "author": "小金井喜美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『一八八九年七月十七日付法令、第三条、第三項、嫡子タルト庶子タルトヲ問ハス、生存セル七子ヲ有スル父及母ハ人頭並ニ動産ニ対スル課税ヲ免セラルルモノトス』「いいか」――家に帰って、ノワルミエは妻に向かって言った。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫡子タルト庶子タルトヲ問ハス、生存セル丁年未満ノ七子ヲ有スル父及母ニシテ十フラン以下ノ人頭動産税ヲ課セラルルモノハ、此ノ課税ヲ免除セラルルモノトス』「そらね、なるほど、九フラン五十サンチームの税金を納めるので、つまり十フラン以下だ。",
              "citation": {
                "source": "ぶどう畑のぶどう作り",
                "author": "LE VIGNERON DANS SA VIGNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　大次郎は、優しい顔に似げなく額部の照りに面擦れを見せて、黒七子紋付きの着流し、鍛え抜いた竹刀のように瘠せた上身を、ぐっと千浪のほうへ向けた。",
              "citation": {
                "source": "煩悩秘文書",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "義助　そななことをいうとると、またいつかのように落ち崩るぞ。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "吉治　どななことしても若旦那には効き目がありゃしません。",
              "citation": {
                "source": "屋上の狂人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
