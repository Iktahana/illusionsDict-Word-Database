          "literary": [
            {
              "text": "近衛内閣総辞職、大命、平沼男に降下するらしい。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "……内閣総辞職とは驚いた、日本もいよ／＼更始一新だ。",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "六月六日（火曜）晴　内閣総辞職　原首相が殺されてから、高橋是清が総理大臣となり、始めは人気があったが、追々不信任案が生じ、二ヵ月ほど前、元田、中橋をぬいて改造案を起したが通らず、ずるずるで、ともだおれ、今日となったのだ。",
              "citation": {
                "source": "日記",
                "author": "一九二二年（大正十一年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "近頃こんな書きにくいものにぶつかったことなし　平沼内閣総辞職。",
              "citation": {
                "source": "日記",
                "author": "一九三九年（昭和十四年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "夜、内閣総辞職のニュースをきく。",
              "citation": {
                "source": "日記",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "九　東条内閣総辞職の報が伝はつた。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十日（木）　東條内閣総辞職す。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "是れ半歳ならずして内閣総辞職の止む可からざりし所以なり。",
              "citation": {
                "source": "明治人物月旦（抄）",
                "author": "鳥谷部春汀",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
