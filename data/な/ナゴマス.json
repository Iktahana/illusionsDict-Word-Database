        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の温かい笑顔は、周囲の人々の心を和ませる力がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "休日の午後は、好きな音楽を聴いて心を和ませるのが私の習慣だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "先生の優しい言葉が、緊張していた生徒たちを和ませた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "諦め切ったという男には、たとえ不甲斐ないことにはなったにしろ、またこんなに女を和ます力があるのでしょうか。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それがフランチソースでその中へ生の玉葱の細かく切ったのと湯煮た青隠元とジャガ芋と人参なんぞを極く小さく切って和ます。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "それはかつて旅をしたとき何処かでみた景色であつたが、こんなに心をなごますのは、この世の眺めではないらしい。",
              "citation": {
                "source": "小さな庭",
                "author": "原民喜",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
