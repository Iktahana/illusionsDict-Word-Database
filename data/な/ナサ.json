        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "代表者となったボブ・スタインは、妻だったアリーン・スタインとボイジャー・プレスを作った人物で、ここから引き継いだ社名は、ＮＡＳＡの惑星探査機から取ったそうです。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユタ大学の大学院ではアラン・ケイの同期で、卒業後はＮＡＳＡのために飛行士訓練用のフライトシミュレーターの開発に携わっていました。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "第二次大戦後、ＮＡＳＡの前身の航空宇宙諮問委員会（ＮＡＣＡ）エイムズ研究所で風洞の研究に携わったエンゲルバートはやがて、人類の多くを進歩させるような意義のあるはでな仕事につきたいと、若者らしい野心を抱くようになった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九五七年にスタンフォード研究所に移ったエンゲルバートは、軍やＮＡＳＡの援助を取り付けて、人間の能力を〈増大〉させるシステムの研究計画を軌道に乗せていった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "ディスプレイの表示は、ＮＡＳＡから借りた最新のビデオプロジェクターによって、縦横二〇フィートのスクリーンに投射された。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "厳しいＮＡＳＡの規準には適合できなかったものの、地上でなら充分使い物になるトランジスターを部品メーカーから大量に調達したり、電子機器メーカーから用済みとなった計測器を仕入れてきたりと、環境の特殊性を存分に生かして、マッカラムは教室の整備に努めた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサデス　ツユノ　ヒカルミチコブヲ　トラレタ　オヂイサンツマラナサウニ　ホホヲ　ナデオヤマヲ　オリテ　ユキマシタ　瘤は孤獨のお爺さんにとつて、唯一の話相手だつたのだから、その瘤を取られて、お爺さんは少し淋しい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "後のミットモナサ……。",
              "citation": {
                "source": "ビール会社征伐",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "アサデス　ツユノ　ヒカルミチコブヲ　トラレタ　オヂイサンツマラナサウニ　ホホヲ　ナデオヤマヲ　オリテ　ユキマシタ　瘤は孤独のお爺さんにとつて、唯一の話相手だつたのだから、その瘤を取られて、お爺さんは少し淋しい。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「オヤ　ミナサン」ト　ソノ　トキ　ウマノ　ヲバサンガ　イヒマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「マダ　ヒラカナイ　ツボミサン　モウ　ハルデスヨ、オンモニ　デテ　イラツシヤイ」「マダ　ネンネシテル　ツボミサン　オメメヲ　サマシナサイ」　スルト　ツボミガ　コタヘマシタ。",
              "citation": {
                "source": "ウマヤノ　ソバノ　ナタネ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ、アサダカラ、メヲ　ダシナサイ。",
              "citation": {
                "source": "デンデンムシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミナサン、ゲンキヲ　ダシナサイ。",
              "citation": {
                "source": "ヒロツタ　ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ムスコハ、イロイロ　サガシタガ、アマリ　ヨイ　キカイガ　ナイノデ、ラツパヲ　カツテ、「コレヲ　サカサマニ　シテ　ミミニ　ツケテ、ラツパノ　シリカラ　キキナサイ。",
              "citation": {
                "source": "ラツパ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴランナサイ　コノ　ミミノ　ナガイ　コトヲ。",
              "citation": {
                "source": "ウサギ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サカナサン、カンザシヲ　ヒロツテ　クダサイ」ト　ヲンナノ　コガ　サカナニ　タノミマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジブンデ　オヒロヒナサイ」　ヲンナノ　コハ　コマツテ　シマヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミナサン」ト　モルモツトハ、シンパイサウニ　シテ　ヰル　ミンナノ　カホヲ　ミマハシテ　イヒマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "奉行ヲヤメサセナサイ。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は机の上の用箋に、「草田ノ家ヘ、カエリナサイ」と書いて静子さんに読ませた。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "草田ノ家ヘ、カエリナサイ。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "トニカク、カエリナサイ。",
              "citation": {
                "source": "水仙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アガンナサイ、アンタ。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして、さっきのボタンを三つ、小さな掌をひらいて彼の前に出し、「コメンナサイ。",
              "citation": {
                "source": "プウルの傍で",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "京子の手紙六　加奈子のダンナサンが今夜、加奈子に優星学（作者註、優生学の間違いならん）の話をしてました。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子のダンナサンは私を馬鹿だと思ってるんでしょうか。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "加奈子のダンナサン何故へんな画ばかりかくんでしょう。",
              "citation": {
                "source": "春",
                "author": "――二つの連作――",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ミナサン、ボク　ト　アソンデ　クダサイ』ト。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　サカナタチ　ハ、ソレデハ　ココマデ　オヨイデ　キナサイ、ト　ヤマキチ　ニ　イイマス。",
              "citation": {
                "source": "山のコドモ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソンナニ外ガ見タカッタラ、教場ノ外ヘ出テイナサイ」　窓の外へ立たされて、殊勝らしくじっとうつむいていた顔をひょいとあげると、先生は背中を向けて黒板に字を書いていた。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
