        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ところで、ひとつやくそくしてくれなきゃいけない。",
              "citation": {
                "source": "蟹のしょうばい",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時僕たちはどうしても北の方に行かなきゃいけないようになるんだ。",
              "citation": {
                "source": "風野又三郎",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぼくたち、気分がわるいんだもの」「じゃ、おまえたちは、げざいを飲まなきゃいけないね」と、オーレ・ルゲイエが言いました。",
              "citation": {
                "source": "眠りの精",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "相手がしんけんなら、こちらもしんけんにならなきゃいけない、と久助君はそのつもりになって、一生けんめいにやりだしたが、そうするうちに、まもなくまた、つぎの疑問がわいてきた。",
              "citation": {
                "source": "久助君の話",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "明後日放送があるんですって、だから明日は八時までに練習所へ、顔を出さなきゃいけないんですって……練習所は、荏原の方だから、早起きしなければいけないんですってね……」　美沢の噂をするのなら、せめて（お姉さんによろしくといっていたわ）とか、（お姉さんに会いたいといっていたわ）とか、あっていいはずである。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「戸を叩いた方がいいとわかっていたんですが、ええ、わかってます叩かなきゃいけないんです。",
              "citation": {
                "source": "土色の顔",
                "author": "THE YELLOW FACE",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これが何事か知らなきゃいけない。",
              "citation": {
                "source": "緋のエチュード",
                "author": "A STUDY IN SCARLET",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そしてぼくは南の国へと旅立たなきゃいけない。",
              "citation": {
                "source": "おやゆび姫",
                "author": "LITTLE TINY OR THUMBELINA",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「校正は、自分でやらなきゃいけないのかね。",
              "citation": {
                "source": "祝盃",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だ、誰です、あなたは……」「しずかにしていなきゃいけないというのに。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時こそ、私を庇護ってくれなきゃいけない人なのに、先生は私を突き落とすようなことをしたのよ。",
              "citation": {
                "source": "仮装人物",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「この次ぎからじゃないよ、今すぐやめなきゃいけないよ。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あなたはどうしてもその人と結婚しなきゃいけないんですか。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "「明日はもう帰らなきゃいけないでしょう。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の洗面所でその手紙をとりついだしづ子が、「……これ……お金出してくれた人たちに一わたり見せなきゃいけないわねえ」と柳に相談をもちかけた。",
              "citation": {
                "source": "舗道",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれど、「さ、寺田君手伝ってくれたまえ……」　そう耳元でいう水木の声に、ハッと気がつくと、もう今までの考えは、煙のように、どこへともなく揮発して、「玄関にあんな足袋があると変だから、片づけなきゃいけないね……」　そんな悪智慧をすら浮べる、彼だったのだ。",
              "citation": {
                "source": "魔像",
                "author": "蘭郁二郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「警察へね、毛布だのお弁当だのを持っていくんだよ、警察だけですめばいいけれどもね」「お母さんが弁当をこさえてくれればぼくが持っていくよ」「それがね、お金を弁当屋にはらって、さしいれしてもらうのでなきゃいけないんだよ」「いくら？",
              "citation": {
                "source": "ああ玉杯に花うけて",
                "author": "佐藤紅緑",
                "note": "青空文庫"
              }
            },
            {
              "text": "「隠さないで、はっきりいわなきゃいけないね。",
              "citation": {
                "source": "地獄の使者",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だからさ、早く行かなきゃいけないんだよ。",
              "citation": {
                "source": "在学理由",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "この店は味を売る店だから、余分の愛嬌はいらないことだが、タシナミと明るさがなきゃいけない」　と訓辞を与えておく。",
              "citation": {
                "source": "ニューフェイス",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「それじゃあ、僕は返事をしなきゃいけないのかい？",
              "citation": {
                "source": "宝島",
                "author": "宝島",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうして妾独りがそんなにお喋りしなきゃいけないの。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "おとなしくしていなきゃいけないぞ」　丁坊は、黙ってうなずいた。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、どう無理をしてもエンジンは出さなきゃいけない。",
              "citation": {
                "source": "大空魔艦",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちと、しっかりしなきゃいけない。",
              "citation": {
                "source": "地底戦車の怪人",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、私まで女史を意識しなきゃいけないみたいで嫌。",
              "citation": {
                "source": "華々しき瞬間",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日はお名残りの宴会やりましょう」「でも、もう、汽車にのらなきゃいけないから」「あら、小田原ぐらい、何時の汽車でもよろしいじゃないの。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "じゃア先生お料理はありませんけどお酒はありますから、ちょっと飲んでらして」「暗くならないうちに着かなきゃいけないから」「あら御自分のうちのくせに。",
              "citation": {
                "source": "オモチャ箱",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "結局、みんな、アイノコにならなきゃいけないじゃないですか。",
              "citation": {
                "source": "退歩主義者",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            }
          ]
        }
