[
  {
    "uuid": "cc4b3a1b-72ef-569e-ac40-d346d41c86df",
    "entry": "形体",
    "reading": {
      "primary": "なりかたち",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
