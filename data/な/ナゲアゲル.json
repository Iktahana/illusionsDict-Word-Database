        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "子供の時分に蜻蛉を捕るのに、細い糸の両端に豌豆大の小石を結び、それをひょいと空中へ投げ上げると、蜻蛉はその小石を多分｜餌だと思って追っかけて来る。",
              "citation": {
                "source": "烏瓜の花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤や青の火の玉を投げ上げる。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "子供の時分にとんぼを捕るのに、細い糸の両端に豌豆大の小石を結び、それをひょいと空中へ投げ上げると、とんぼはその小石をたぶん餌だと思って追っかけて来る。",
              "citation": {
                "source": "からすうりの花と蛾",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを転がすか投げ上げるかして動いている所を横から射止めるのである。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "泡だらけな峡谷のそばに、ぎざぎざした、突拍子もない形のものを投げ上げる。",
              "citation": {
                "source": "トニオ・クレエゲル",
                "author": "TONIO KROGER",
                "note": "青空文庫"
              }
            },
            {
              "text": "石を空中に投げ上げるよりも、それを落下させる方がはるかに容易である。",
              "citation": {
                "source": "ジャン・クリストフ",
                "author": "JEAN-CHRISTOPHE",
                "note": "青空文庫"
              }
            },
            {
              "text": "踏みつぶされたいかッ」　叩きつける、踏み放す、つまんで投げ上げる。",
              "citation": {
                "source": "三国志",
                "author": "臣道の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
