    "definitions": [
      {
        "index": 1,
        "gloss": "to stop crying",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "豚吉は泣き止むと一所にビックリしまして、「エッ。",
              "citation": {
                "source": "豚吉とヒョロ子",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか、自分自身が、頼りなく、哀れまれて、大ゲサな感傷に揺り立てられて、容易に泣き止むことが出来なかった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "枕元に居た近所の人々は勘次とおつぎの泣き止むまでは身體を動かすことも出來ないで凝然と冷たい手を懷に暖めて居た。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "おつぎは與吉を膝へ抱いて泣き止むまでは兩手で掩うて居る。",
              "citation": {
                "source": "土",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "俥が壁の前に来る頃、彼はあきらめて泣き止むと、どうかして母の注意をそつちに向けまいとして、急に途方もない質問をして反対の方を指した。",
              "citation": {
                "source": "池のまはり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の声もいたしましたけど、何故にかく泣き止むのでしょう？",
              "citation": {
                "source": "東京人の堕落時代",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、しばらくして泣き止むと、「失礼いたしました。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "万之助が泣き止むのを待って、新一郎は静かにいった。",
              "citation": {
                "source": "仇討禁止令",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、有王が泣き止むのを待って、有王の右の手を掴んで、妻を麾くと、有王をぐんぐん引張りながら、自分の小屋へ連れて帰った。",
              "citation": {
                "source": "俊寛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、放してやれば直ぐ泣き止むらしい泣き方だったので放さないでいると、いよいよ悠長な本泣きに変ってきた。",
              "citation": {
                "source": "御身",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "たまらなく可愛いので、やたらに抱くので、もう私と看護婦の手を覚えて、どんなに泣いて居ても、二人の内が抱くと、きっと泣き止む。",
              "citation": {
                "source": "暁光",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "レミヤの児は同じようにして本当の父親をその霊感に依って容易に区別し得るであろう事を……アルマとマチラの二人の中、自分の父親でない方が抱いたならば直ぐに泣き出すであろうと同時に、本当の父親が抱いたならば直ぐに泣き止むであろう事を……。",
              "citation": {
                "source": "霊感！",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしておとなしく彼女の泣き止むのを待っていた。",
              "citation": {
                "source": "行人",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "なきやむまでゆすぶつてゐなければ、ぶたれます。",
              "citation": {
                "source": "てがみ",
                "author": "アントン・チエーホフ　Anton Chehov",
                "note": "青空文庫"
              }
            },
            {
              "text": "――宜いかえ、内儀は絞め殺された上、嫌がらせに庇にブラ下げられたに違ひないが、人間一人を綱で庇へ吊るためには、その吊られる人間より、重い人間でなきやむづかしいわけだらう」「？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "敵持ち",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
