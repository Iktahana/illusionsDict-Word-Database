        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一人はルイザ・レイナーズというオーストラリア人で、舞台の大ベテランだ。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "レイナーズ嬢は自分で運転するか、運転手に頼んで、そうですね、バーハムジャンクションまで行ったでしょう。",
              "citation": {
                "source": "真劇シリーズ",
                "author": "REAL DRAMAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それにちなんで「パイプライナーズ」という名前の会社を作った。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "北アメリカ大陸から飛行機でホノルルに到着してすぐに、彼はヒッチハイクでアラモアナの「パイプライナーズ」に来た。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "「波が来る」　と言ってエマニュエルが興奮した日、ラリー・デイヴィスは「パイプライナーズ」の商用で北アメリカ大陸にいって留守だった。",
              "citation": {
                "source": "波乗りの島",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
