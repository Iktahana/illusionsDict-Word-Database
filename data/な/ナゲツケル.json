        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」その子が投げつけるやうにうしろから叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "お願ひですから、子供にだけは、子供にだけはみじめな思ひをさせないやうにね」「分つた、分つた」　不意にうるんだ妻の瞳を刹那に意識しながら、夫はわざと投げつけるやうに言つた。",
              "citation": {
                "source": "畫家とセリセリス",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、おそく、――一時すぎに――帰ってきて、棒切れを折って投げつけるように不機嫌なことがあるのだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "睡ってゐる人の枕もとに大きな石をどしりどしりと投げつける。",
              "citation": {
                "source": "秋田街道",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とまるで怒ったような声で云ってわざと頭に実を投げつけるようにして泣かせて帰しました。",
              "citation": {
                "source": "手紙　四",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その子が投げつけるようにうしろから叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "おふみ、室中の物を太郎左衛門に投げつける。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はそんな言葉を捜し出したとき、直ぐそれを相手に投げつける場面を想像するのですが、この場合私にはそれが出来ませんでした。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ザネリ、烏瓜ながしに行くの」ジョバンニがまだそう言ってしまわないうちに、「ジョバンニ、お父さんから、ラッコの上着が来るよ」その子が投げつけるようにうしろから叫びました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ジヨバンニがまださう云つてしまはないうちに、その子が投げつけるやうにうしろから、さけびました。",
              "citation": {
                "source": "銀河鐵道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "大人は抵抗力がないといふだけの理由で、勝手放題な仕向けを子供の世界に對して投げつける。",
              "citation": {
                "source": "子供の世界",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "豆｜煎り網のように大地は揺れ、地上のものはみな鳴り、小径から彼方の村へかけて裂いて投げつけるような女子供の叫び声が挙がる。",
              "citation": {
                "source": "宝永噴火",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "博士は斯く云いつつ、瓶を差し上げて太陽の光線に透かしてみたが、「オオ、あるある果してみょうな物があるある」と叫んで、好奇心は満面にあふれ、口栓を抜くのももどかしと、かたわらの巖石をめがけて投げつけると、瓶は微塵に砕け、なかから黄色い紙に何か細々と記した物が出て来た。",
              "citation": {
                "source": "南極の怪事",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨夜の娘は何のために裸のままここを逃げ出したのだ」針助「うーむ」と、うなっていたが、いきなり畳の上の針を手に取って、次から次へ小沢めがけて投げつける。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "やや風が吹き出して、河の天地は晒し木綿の滝津瀬のように、白瀾濁化し、ときどき硝子障子の一所へ向けて吹雪の塊りを投げつける。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポンと小気味のよいその音は逃げて行った細君へ投げつける虚ろな挑戦の響きの高さに冴えていた。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　怒ったのか――と見上げた木崎の顔へ、陽子は投げつけるように、「げすッ！",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "その陽子の所へ、女を連れて泊りに行く――これは陽子へ投げつける京吉の一種の軽蔑であり、悔恨のようなものだ。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何処で投げつけるやうなあかんぼの声がする。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分は足元の松葉をかき寄せて投げつける。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今までとんと忘れていたけれど、もうこの貝殻も持っていたってつまらないと思って、一つずつ出しては離れの屋根を目がけて投げつける。",
              "citation": {
                "source": "千鳥",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "牛はそこへ飛び降りて一息ついていると、追って来た連中は上からいろいろの物を投げつける。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この牛が桟橋へあがって、自分たちの家へ飛び込まれては大変だから、料理番や下足番や船頭たちが桟橋へ出て、こっちへ寄せつけまいといろいろの物を投げつける。",
              "citation": {
                "source": "牛",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんだか忌々しいような気になったので、彼はそこらの小石をひろって投げつけると、鶏は羽摶きをして姿を消した。",
              "citation": {
                "source": "夢のお七",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "甚六と甚六の女房は驚いてそのほうへ顔をやると、堂の中から何人かが投げつけるように位牌や瓦盃が飛んで来た。",
              "citation": {
                "source": "一緒に歩く亡霊",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は車掌に切符を投げつけるやうに渡しており、走るやうに十足ばかり行つて振り返つて見ると、動き出した電車に添うて、中折帽を着た彼の刑事らしい者が此方を見て立つてゐた。",
              "citation": {
                "source": "白いシヤツの群",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　美佐子は投げつけるようにして怒鳴った。",
              "citation": {
                "source": "秘密の風景画",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子が出て行く時には一人として葉子に雑言をなげつけるものがいなかった。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――石をなげつけるんです。",
              "citation": {
                "source": "新しきシベリアを横切る",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか分らず　Ａが、私にボムをなげつける、それが、黄色と赤の平たく丸い、菊の花のようなの。",
              "citation": {
                "source": "一九二五年より一九二七年一月まで",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
