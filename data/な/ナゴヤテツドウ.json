          "standard": [
            {
              "text": "名古屋鉄道、通称名鉄は、愛知県を中心に路線網を持つ大手私鉄だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "名古屋鉄道の特急列車に乗って、犬山まで行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "名古屋鉄道の駅では、ユニークなデザインのミュースカイを見かけることができる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "御殿場は太郎坊附近がスキー場になっているので、名古屋鉄道局管内ならスキー割引の切符が発売されているし、乗合自動車が馬返しまで行ってくれる。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
