[
  {
    "uuid": "d1bbe5de-6aec-5c76-9bc5-f2360d983fdc",
    "entry": "成る",
    "reading": {
      "primary": "なる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
