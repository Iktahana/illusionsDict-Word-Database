  {
    "uuid": "656f230c-72d2-50ec-8370-a07f987f9595",
    "entry": "鳴る",
    "reading": {
      "primary": "なる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to sound",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "〔こんにやくの〕宮沢賢治こんにやくのす枯れの茎をとらんとて水こぼこぼと鳴るひぐれまぢかの笹はらを兄弟二人わけ行きにけり",
              "citation": {
                "source": "〔こんにやくの〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪峡宮沢賢治塵のごと小鳥なきすぎほこ杉の峡の奥よりあやしくも鳴るや　み神楽いみじくも鳴るや　み神楽たゞ深し天の青原雲が燃す白金環と白金の黒の窟を日天子奔せ出でたまふ",
              "citation": {
                "source": "雪峡",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「門司の旅館で船を待つ間、船の汽笛が鳴るたびに、火のつくやうに泣き出すのには閉口させられた。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "さても私の境涯の、その最初の門出は「門司の旅館で船を待つ間、船の汽笛が鳴るたびに火のつくやうに泣き出」したのであり、「その日はそれに、吹く降るの日で」あつたのである。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しののめの、よるの海にて汽笛鳴る――心よ、起きよ目を覚ませ。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "しののめの、よるの海にて汽笛鳴る。",
              "citation": {
                "source": "一つの境涯",
                "author": "――世の母びと達に捧ぐ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "記憶は見知らぬ波止場をあるいてにぎやかな夜霧の海にぽうぽうと鳴る汽笛をきいた。",
              "citation": {
                "source": "記憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と怒鳴ることは出来なかつた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ね、此の草は吹くと鳴るのよ。",
              "citation": {
                "source": "蜻蛉",
                "author": "――飜弄さる",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんなこと自由ぢやないの……」「えゝ、さういへばさうだけど、自由なんて引つぱり出すと却つて不自由だ、怒鳴りたい時は怒鳴るが好いつてのが自由でせう……」「ぢや若し、隣の人達が女だから好いけれど、荒くれ男共だつたら如何するの」　低声で言つた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "悲壮な、痛々しい、骨の鳴るような人生が、一本の枯木を通して、蕭条たる自然の背後に拡がって行く。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは柚の花の侘しく咲いている、昔々の家に鳴るオルゴールの音色のように、人生の孤独に凍え寂しむ詩人の心が、哀切深く求め訪ねた家郷であり、そしてしかも、侘しいオルゴールの音色にのみ、転寝の夢に見る家郷であった。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "反対に蕪村は、どんな蕭条とした自然を見ても、そこに或る魂の家郷を感じ、オルゴールの鳴る人生の懐かしさと、火の燃える炉辺の暖かさとを感じている。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まばらに殘る林の中に看守の居て劍｜柄の低く鳴るを聽けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "姉上等がかえると御てらしが消えて御神燈の灯がバチバチと鳴る。",
              "citation": {
                "source": "祭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "盾に鳴る鋼の音は叫喊の声に和して、傷ついた人は底知れぬ海に落ちて行った。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうなれば宿帳つけに来し男の濡れ髪かき分けたるも涼しく、隣室にチリンと鳴るコップの音も涼しく、向うの室の欄干に倚りし女の白き浴衣も涼しげなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "船長がいきなり「ノーフラージュ（難船）」と怒鳴ると、移動がぴたりと止まるのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "樹脂の香に　朝は悩まし　　うしなひし　さまざまのゆめ、森竝は　風に鳴るかなひろごりて　たひらかの空、　　土手づたひ　きえてゆくかなうつくしき　さまざまの夢。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "上手に子供を育てゆく、母親に似て汽車の汽笛は鳴る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の近くを走りながら、母親に似て汽車の汽笛は鳴る。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日の事ですから、魚の方ですっかり承知していて、寺の食事の鐘が鳴るともう前の淵へ集って来て待っています。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "青年は、あるいは「釜中の鯉魚」と答え、あるいは「網を透る金鱗」と答えはするが、ついに鯉魚あるを知らず、おのれに身あるを知らず、眼前に大衆あるを知らずして、問いに対する答えの速かなること、応変自由なること、鐘の撞木に鳴るごとく、木霊の音を返すがごとく、活溌、轆地の境涯を捉えました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョバンニは、ばっと胸がつめたくなり、そこら中きぃんと鳴るやうに思ひました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ごとごと鳴る汽車のひびきと、すすきの風との間から、ころんころんと水の湧くやうな音が聞えて来るのでした。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "玄関のベルが鳴ると女中は吉田敏子の来訪を告げた。",
              "citation": {
                "source": "かれいの贈物",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "サイレンが鳴ると思ったら眼が覚めた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "電車のゴウゴウと鳴る音のエネルギーの源をだんだんに捜して行くと思い掛けない甲州の淋しい山中の谷川に到着する。",
              "citation": {
                "source": "電車と風呂",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "自働電話の送信器の数字盤が廻るときのカチカチ鳴る音と自働連続機のピカピカと光る豆電燈の瞬きもやはり同じような考えを応用して出来た機構の産物であると見れば見られなくはないであろう。",
              "citation": {
                "source": "変った話",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊に女には今日の表現が明日の存在になるんだ。",
              "citation": {
                "source": "不可入性",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
