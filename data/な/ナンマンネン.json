    "definitions": [
      {
        "index": 1,
        "gloss": "tens of thousands of years",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
