    "definitions": [
      {
        "index": 1,
        "gloss": "if (it) doesn't exist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "と又、Ｔ「引ッ込ま無きゃ　ひきずり下す！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "因ってその僧が南無きゃらたんのうとらやあ／＼と唱えるや否や犬出家に狎れ近づく。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "喜十がどうしても甲府へ出るんならば、致し方無え、丁度整理する時期も来ているで、銀行に渡してしまう……百姓　うーむ……中年　なんしろ、あすこでもかしら息子が兵隊に出て以来、居まわりでやっている二町歩足らずでも精一杯だで……こうなると論でも無きゃ筋でもねえ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……そで無きゃ火の神さまあ、家のむね離れてしまうて、よそに居る亭主は、つっころげたまま、それっきりになってしまわあ。",
              "citation": {
                "source": "おりき",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まだ女房が無え、情ねえ男だな、女房が無きゃア女給でも守っ娘でも剥いで来るがいい――」　二人は何時の間にやら日比谷の電車通へ出て居りました。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「打ちあけ無きゃいけませんよ、御新造、殺されたお嬢さんや、お新が可哀想だ」「――でしょう、ですから私は、堅くお新と約束しましたが、思い切って親分さんに申し上げようかと思ったんです」「それは、御新造」　平次は少しせき込みました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "人違い殺人",
                "note": "青空文庫"
              }
            },
            {
              "text": "何んか変ったことが無きゃいいが――」「お前の口吻だと、変ったことを待って居るようだぜ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "春宵",
                "note": "青空文庫"
              }
            },
            {
              "text": "幽霊でも無きゃ、そっと忍び込める道理はありませんね」　八五郎は得々として説くのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "万両分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「庫裡に居ましたよ、正体もなく睡りこけて、両手にひしと曙染の大振袖を抱いたまま」「装束を変えて逃げたのか」「曲者はその小姓にきまって居ますが、何処へ逃げたか、まるで見当もつかず、第一、三千両を持って行ったとすると、合棒が無きゃなりません」　八五郎は八五郎だけの知恵を傾けるのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "群盗",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、お前一人では手が廻るまいが朝っから誰も外へ出た者は無いか、外から来た者は無いか、第一番にそれを調べるんだ、一人も出入りした者が無きゃ、下女のお六は此家の何処かに居るに違いない」「そんな事なら、あっし一人で沢山で」　八五郎は気軽に飛んで行きます。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "恋患い",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だって、ツイ先刻、田圃で彰義隊の落武者が捕まって、斬ったとか斬られたとか、大変な騒をしたようだから、此方に何んか変りが無きゃ宜いと思って――」　お浜の調子のさり気ない滑らかさは、およつに取っては、此上もない威嚇でした。",
              "citation": {
                "source": "芳年写生帖",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日たった今百円でも二百円でも無きゃ、私等ぁ生きちゃ行けないんだ。",
              "citation": {
                "source": "廃墟（一幕）",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "手荷物が無きゃ、コニーも私も宿が取れないことは手だれのあんたが一番知ってるだろ。",
              "citation": {
                "source": "煉獄",
                "author": "The Nether Millstone",
                "note": "青空文庫"
              }
            },
            {
              "text": "知ってなきゃそんな無茶苦茶な事が云える筈がなかろうじゃないか。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "一人でなきゃ駄目さ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "老妓も笑って「いつの時代だって、心懸けなきゃ滅多にないさ。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰らなきゃなるまい。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "いの一番に言わなきゃァならねェ肝心なのを忘れて居たよ。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "通らなきゃならなかった路だ。",
              "citation": {
                "source": "小さき良心",
                "author": "断片",
                "note": "青空文庫"
              }
            },
            {
              "text": "やってやらなきゃならんのだった！",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それじゃ、初めっから争議なんどやらなきゃええ。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "石井翁は帯の間から銀時計の大きいのを出して見て、「三時半です」「イヤそれじゃもう行かなきゃならん。",
              "citation": {
                "source": "二老人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうせ行かなきゃならんのだ。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「俺等がやめなきゃ、いつまでたったってやまるもんか。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "徹底的に犠牲にあげなきゃいかん！",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ところが、此頃は、その囮に、又囮をつけなきゃあぶなくなっていますよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「笞の下をくゞり、くゞって底からやって行かなきゃならないんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんなに卑屈に落ちぶれたって、やっぱしコツコツと働かなきゃならないのが工人だ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「これを持って行かなきゃ駄目なんだよ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そうでもしなきゃ、留置場から出られねえんだ。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
