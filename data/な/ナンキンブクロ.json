        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "吉田は、南京袋のような臭気を持っている若者にねじ伏せられて、息が止まりそうだった。",
              "citation": {
                "source": "雪のシベリア",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにバターと、南京袋の臭いがまざった。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "調理台で、牛蒡を切っていた吉永が、南京袋の前掛けをかけたまま入口へやって来た。",
              "citation": {
                "source": "渦巻ける烏の群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには、獣油や、南京袋の臭いのような毛唐の体臭が残っていた。",
              "citation": {
                "source": "パルチザン・ウォルコフ",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "――「糞壺」の階段を南京袋のように漁夫が転がって来た。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「うん」　一太は立ちどまって、善さんが南京袋をかついで来ては荷車に積むのや、モーターで動いている杵を眺めた。",
              "citation": {
                "source": "一太と母",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは内証だけれど、船で泥棒をした苦力を南京袋へ押し込んで、海ん中へぶち込んぢやつたりしてね。",
              "citation": {
                "source": "沢氏の二人娘",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い毛布を利用して大きな南京袋をこしらえる。",
              "citation": {
                "source": "明日は天気になれ",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "全部はリュックに入らないから、野菜類は二ツの南京袋に入れて縄でくくって、リュックの両側へぶらさげた。",
              "citation": {
                "source": "我が人生観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄でしばった南京袋の前だれをあてて、直径五寸もある大きな孟宗竹の根を両足の親指でふんまえて、桶屋がつかうせんという、左右に把手のついた刃物でけずっていた。",
              "citation": {
                "source": "白い道",
                "author": "徳永直",
                "note": "青空文庫"
              }
            },
            {
              "text": "さうすると、之も酒に酔払つて、街から帰つて、南京袋の中へ這入つて寝て居る吉田が、家の中から、『八釜敷いわい、奴畜生、静かにせい！",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
