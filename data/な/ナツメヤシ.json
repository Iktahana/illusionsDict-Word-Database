        "examples": {
          "standard": [
            {
              "text": "中東の砂漠地帯では、なつめやしの実が主要な食料源となっている。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "なつめやしの木は、幹が高く伸びていて存在感がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "干したなつめやしは、栄養豊富で非常食にもなる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "スミルナの無花果、ボスラーの棗椰子、エスコールの葡萄――。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "棗椰子や山毛欅や棕櫚の木などに蔽われて林の中は暗かった。",
              "citation": {
                "source": "加利福尼亜の宝島",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
