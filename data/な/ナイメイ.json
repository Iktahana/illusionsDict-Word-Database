[
  {
    "uuid": "93e0fcf4-cd79-54ce-b2f1-b9af39754c6b",
    "entry": "内命",
    "reading": {
      "primary": "ないめい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
