    },
    "definitions": [
      {
        "index": 1,
        "gloss": "private or secret orders",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その上、若殿から蛸もぜひとの内命があったのだから、どうしても蛸をお供の人数に差加えないわけにはゆかぬ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「二月七日辰刻、将軍家｜渡御中泉｜先献御膳｜暫有於奥之間大御所御対面本多佐渡守｜同上野介召御前｜御密談移刻」　四月初旬には、多くの諸侯に、出征準備の内命を発している。",
              "citation": {
                "source": "大阪夏之陣",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "「不思議な縁ですね、まだ下極りで、世間に発表はしないけれども、今度、仙台の――一学校の名誉教授の内命を受けて、あと二月ぐらいで任に赴く。",
              "citation": {
                "source": "白花の朝顔",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何笑ひおる、」と伊勢武熊は真摯に力味返つて、「功名咄をするやうぢやがナ、此前牛飼君が内閣の椅子を占められた時、警部長の内命を受けたが、大丈夫｜豈田舎侍を甘んぜんや。",
              "citation": {
                "source": "貧書生",
                "author": "内田魯庵",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ご立腹ごもっともにござりまするが、てまえは伊豆守様のご内命こうむりまして、お出迎えご警固に参りました八丁堀の同心、役儀のある者でござりましてものぞいてはなりませぬか」「ならぬならぬッ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "おそらく首にして連れいとの御内命があったに相違ない。",
              "citation": {
                "source": "旗本退屈男　第十一話",
                "author": "千代田城へ乗り込んだ退屈男",
                "note": "青空文庫"
              }
            },
            {
              "text": "近ごろでどこぞにご内命をうけて、内偵に参られたことござりましたか」「大ありじゃ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "千柿の鍔",
                "note": "青空文庫"
              }
            },
            {
              "text": "お奉行さまからご内命うけたのは、この敬四郎じゃ！",
              "citation": {
                "source": "右門捕物帖",
                "author": "妻恋坂の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「私、殿の内命を受け、杉窪の里へまかりこし、二代目の長楠右衛門について、取り調べましたところでは、それに相違ございません」「だがそれにしても紀州の伯父上、何ゆえ天狗などに身をやつされ、杉窪などへ行ったのであろう？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただいつまでも今の処に尻を据ゑて居るべしと内命せしとか。",
              "citation": {
                "source": "従軍紀事",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "」或筋から内命が下だつて、露領の沿海州まで、日本ではまだ本當にやつてゐない遠洋漁業の組織で密漁船を出す計畫を、自分が仲間に這入つてやりかけたこと。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "斷橋",
                "note": "青空文庫"
              }
            },
            {
              "text": "其瞞着の仕方と云ふものは、郡吏と云ふものが色々考えた末、郡長の内命だとか或は郡長の代理だとか言ふては出張し、人民を呼び上げて、一段歩に付き二圓若くは一圓の金を呉れるから永世苦情を言はぬと云ふ書付に判を捺せ。",
              "citation": {
                "source": "公益に有害の鑛業を停止せざる儀に付質問書",
                "author": "田中正造",
                "note": "青空文庫"
              }
            },
            {
              "text": "この期間の末の一年、嘉永元年に至って枳園は躋寿館の一事業たる『千金方』校刻を手伝うべき内命を贏ち得た。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "公儀へ召されるといったのは、奥医師などに召し出されることで、抽斎はその内命を受けていたのであろう。",
              "citation": {
                "source": "渋江抽斎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "内命ありて尾張大納言殿御見舞申す。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "瀬田、小泉が陰謀の与党だと云ふことは、既に平山が云つたので、荻野等三人に内命を下すにも、跡部は綿密な警戒をした。",
              "citation": {
                "source": "大塩平八郎",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして清休の子廓清が妻にせいと内命した。",
              "citation": {
                "source": "壽阿彌の手紙",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "派手になることを院は避けようとされたのであったが、宮中の御内命によって行なわれるこの賀宴は、すべて正式どおりに略したところのないすばらしいものになった。",
              "citation": {
                "source": "源氏物語",
                "author": "若菜（上）",
                "note": "青空文庫"
              }
            },
            {
              "text": "当分は江戸屋敷に在るべしとの将軍家の内命に従い、母子共に行列｜厳しく、北国街道を参勤とはなった。",
              "citation": {
                "source": "怪異黒姫おろし",
                "author": "江見水蔭",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府の事情が凡そ斯う云う風であるから、今度の一行中にも例の御国益掛の人が居て、その人の腹案に、今後日本にも次第に洋学が開けて原書の価は次第に高くなるに違いない、依て今この原書を買て持て帰て売たら何分かの御国益になろうと云うので、私にその買入方を内命したから、私が容易に承知しない。",
              "citation": {
                "source": "福翁自伝",
                "author": "福翁自伝",
                "note": "青空文庫"
              }
            },
            {
              "text": "英国の密偵であるという嫌疑の深いエリク・ヘンダスン少佐をものにして、ある秘密を聞き出すべき内命を受けたマタ・アリは、いまソフィア地方へ急行しつつある。",
              "citation": {
                "source": "戦雲を駆る女怪",
                "author": "牧逸馬",
                "note": "青空文庫"
              }
            },
            {
              "text": "また我藩では世子の小姓の菅沼忠三郎というが内命を佩びて九州方面へ使者に行ったのを、馬関海峡で長州巡邏船で捕えた。",
              "citation": {
                "source": "鳴雪自叙伝",
                "author": "内藤鳴雪",
                "note": "青空文庫"
              }
            },
            {
              "text": "容易に踏み込んで来られますのに、それを来ないというものは、私一人を逃がせよという貴郎からの内命があったからでしょう。",
              "citation": {
                "source": "正雪の遺書",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "政府では僕のこの研究をねたんで、警察に内命を下したとみえて、しじゅう探偵しています。",
              "citation": {
                "source": "椎の木",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "その中で僕をふと微笑ました話――　Ｙは愈々帰朝の内命を受けてぼつぼつ旅の支度に取りかゝつた。",
              "citation": {
                "source": "甘い話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも案外なもので、猫も犬も掛らなかったらしいが、食物のせいか、あんまり運動が不足だったのか、幾日経っても卵のタの字さえ生まないので親父さんの内命を受けて遊びに来た孝ちゃんがどうしたのだろうと、家の鳥博士にきき出した。",
              "citation": {
                "source": "二十三番地",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "すぐ用意にかかれ」この報告と内命に、一同は躍りあがらんばかりによろこんだ。",
              "citation": {
                "source": "宇宙戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "鰡八は、道庵風情を相手に喧嘩をすることを大人げないと思っていますけれども、あんまり無茶なことをするものだから腹に据えかねて、いくらかかってもよいから、道庵を退治するように出入りの者に内命を下しました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "大尽から内命を下された出入りの者は、いかにしてこの暴慢なる道庵を退治すべきかに肝胆を砕きました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "道庵と鰡八の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべてそれらのよろこびは、ソヴェト市民の一人一人が一九一七年以来、たえまないめいめいのたたかいを通じて自分たちのものとして築いた社会でつくり出された事情なのである。",
              "citation": {
                "source": "あとがき（『宮本百合子選集』第八巻）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
