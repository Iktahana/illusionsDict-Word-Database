        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ステッキが用のない人のぜいたく品ならば、なるべく早くいけなくなって、始終新しく取り換えるほうがいいかもしれない。",
              "citation": {
                "source": "ステッキ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そばに母でもいてこの癖をなるべく早く説明してもらうよりほかはなかった。",
              "citation": {
                "source": "笑い",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "柿江はわざと例のとぼけたような声を取りだして、生徒たちからなるべく早くのがれようと試みつつ、暗い貧乏町の往来に出た。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "遠慮はなるべく早く切り上げるようになさるがいい」　私は良人にこう云われると、持ち前の子供らしさが出てつい小さな欠伸を一つ出して仕舞いました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "外へ出ても、なるべく早く帰って、晩ごはんは家でたべる事にしている。",
              "citation": {
                "source": "新郎",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、なるべく早く漕ぐことにしましょう。",
              "citation": {
                "source": "アド・バルーン",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち書物をなるべく早く読んで、それで理解力を養うにはぜひ、たくさんの書物を読むように心がける必要がある。",
              "citation": {
                "source": "わが中学時代の勉強法",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「しかし私は、なるべく早く帰国なすって、しばらく静かな生活を送られたほうがよろしかろうと思います」「え、国へ帰れ……」と、彼はその顔に嘲笑の色を浮かべて言った。",
              "citation": {
                "source": "世界怪談名作集",
                "author": "北極星号の船長　医学生ジョン・マリスターレーの奇異なる日記よりの抜萃",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、半七は八丁堀へ出向いて、きのう取り調べただけの結果を報告すると、藤四郎はなるべく早く調べあげてくれと催促した。",
              "citation": {
                "source": "半七捕物帳",
                "author": "張子の虎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく早くね、七時半頃に家を出ましょうねぇ。",
              "citation": {
                "source": "第二の接吻",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく早く書いて回してくれ。",
              "citation": {
                "source": "入れ札",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "三四郎はただ結構ですと答えて、なるべく早く自分のほうを片づけて帰ろうとした。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「大宅君はなるべく早く家へ帰してあげて下さい。",
              "citation": {
                "source": "山吹町の殺人",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "明朝なるべく早くがいいですな。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく早く死にたい。",
              "citation": {
                "source": "仲々死なぬ彼奴",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽船の出発は、なるべく早くしたいとおもうが、準備の都合もあり、夜に入るとおもう。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく早くやってくれ」　弥助を出してやった後に、半七はかんがえた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "河豚太鼓",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ故私は、なるべく早くチャンスを見つけて最も激烈な手段で、凡ての敵に対する復讐心を一時に満足せしむるような計画を建てるべく心がけるに至りました。",
              "citation": {
                "source": "痴人の復讐",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな時はなるべく早く帰る方が得策だ、長座をすればするほど失敗するばかりだと、そろそろ、尻を立てかけると「あなた、顔の色が大変悪いようですがどうかなさりゃしませんか」と御母さんが逆捻を喰わせる。",
              "citation": {
                "source": "琴のそら音",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん暑くもなることだから、もし都合がいいようなら、なるべく早く行くがいい。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "家屋はできるだけの手を尽して、なるべく早く売払うことにしたいが、なかなかそう思うようにも行くまい。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるべく早く売るように。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "コフマンの目ざすところは「何でも必要な事実だけ、科学的な事実だけをそれもなるべく早く知らせてそれに子供たちの興味を起させ、その興味の成長によって大きくなった子供たちが、健康な人生の内容を、自分で形づくって行くよう」に導いて行こうというにある。",
              "citation": {
                "source": "科学の常識のため",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "『お父さんも大分年を取ったし、お前一人を力にしているんだから、お前もそのつもりでなるべく早く帰って来るように心掛けていておくれ』ッてお母さんの方から書いてよこしました。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "義雄兄からはなるべく早く帰って来てくれとした手紙が来るように成った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分でもなるべく早くこのような状態から脱却したいと考えているのだが、あせッてみたところで仕方がないと思っている。",
              "citation": {
                "source": "変なあたま",
                "author": "――最近の心境を語る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "己はさう云ふ催しのある所へ来たのでは無いかと思つたので、手紙を受け取つたら、なるべく早く此別荘を立ち去らうと決心した。",
              "citation": {
                "source": "復讐",
                "author": "BALTHASAR ALDRAMIN. KURZE LEBENSGESCHICHTE AUS DEM ALTEN VENEDIG.",
                "note": "青空文庫"
              }
            },
            {
              "text": "別なことでもないが、これをどこかの病院へ入れなけりやアならんので??今夜と云つても、もう、時間がおそ過ぎるだらうから、あす、なるべく早く君の紹介で頼みたい。",
              "citation": {
                "source": "泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            },
            {
              "text": "別なことでもないが、これをどこかの病院へ入れなけりやアならんので――今夜と云つても、もう、時間がおそ過ぎるだらうから、あす、なるべく早く君の紹介で頼みたい。",
              "citation": {
                "source": "――泡鳴五部作",
                "author": "憑き物",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
