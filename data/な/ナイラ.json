          "literary": [
            {
              "text": "ナイラや骨軟病や骨膜炎、齒根膜を冒される病氣など、一體に非常に病氣にかかり易くなる。",
              "citation": {
                "source": "東旭川村にて",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "其矢當らず、然れども王プリアモス生める息、ゴルギュチオーン、勇猛の武者の胸をぞ貫ぬける、カスチァナイラ、彼の母、麗容神女に似たる者、＊アイシュメーより嫁し來る此麗人は彼生みき。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ドウモソウデハナイラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "今デハ女ヨリモ仕事ノ方ガ面白クッテ溜ラナイラシクモアル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ステージダンサーデモ幾分カソウナルケレドモ、アタシハ幸イニシテナラナカッタワ」浄吉ガ彼女ニ魅セラレタノハ彼女ノ姿態ニアルコトハ確カダガ、ロク／＼学校モ出テイナイノニ、頭モ悪クハナイラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何ダ、モウ起キテタノカ」「アタシコソ昨夜ハ寝ラレナカッタワ」予ガ窓ノブラインドヲ上ゲルト、寝起キノ顔ヲ見ラレタクナイラシク、慌テヽ浴室ヘ逃ゲテ行ッタ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "佐々木ガ心配シテ毎日予ヲ仰向ケニ臥カセ、膝ヲ交互ニ組ミ合ワサセテ脚気ノ検査ヲシテイルガ、脚気デモナイラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者ニモドンナニ説明シテモ呑ミ込メナイラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「佐々木サンカラ伺イマシタガ、大丈夫デスカオ爺チャン、オ痛イコトハオ痛イデショウガ、ソンナコトヲナサラナイデモ今ニキット直リマスヨ」婆サンハ気ガ気デナイラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "帰宅シテ見ルト、颯子ハマダ帰ッテイナイラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "明日来テ又モ失敗ト云ウヨウナコトガアッテハ困ルノデ、博士モモウ一度ト云ウ気ハナイラシイ。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ソンナモノハ戴キマセンヨ、コレデ宜シケレバマダゴザイマスカラ、イクラデモ仰ッシャッテ下サイ」佐々木ハ何ニ使ウノカ全ク見当ガツカナイラシク、呆気ニ取ラレテイル。",
              "citation": {
                "source": "瘋癲老人日記",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガ敏子ハコノ縁談ニハドウモ気乗リガシテイナイラシイ。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソノ後奥サンハイカガデスカ、オ見舞イニ伺ウハズナノデスガ」ト云ウノデ、「アレカラマタ睡眠剤ヲ飲マシタノデマダ寝テイル、別ニ苦シンデハイナイラシイカラ心配ニ及バヌ」ト答エル。",
              "citation": {
                "source": "鍵",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
