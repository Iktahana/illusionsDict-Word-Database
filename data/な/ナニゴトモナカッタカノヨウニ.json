[
  {
    "uuid": "73d4b5b6-5c1d-5287-87f6-1703560d8329",
    "entry": "何事もなかったかのように",
    "reading": {
      "primary": "なにごともなかったかのように",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "表現"
      ],
      "ctype": null,
