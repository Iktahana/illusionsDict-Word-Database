        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何のこったやっぱり民子を見に来たんじゃないかと、自分で自分を嘲った様なことがしばしばあったのである。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と大笑をして行き過ぎたが、何のこった知らんと、当座は気が着かずに居たっけがね。",
              "citation": {
                "source": "化銀杏",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、何のこった。",
              "citation": {
                "source": "日本脱出記",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「といってだよ、たとえば、水棲人といえるものになって沼の底へはいったにしろ、もう三上は到底生きちゃいまい」　「ええ、何のこった？",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "「といってだよ、たとえば、水棲人といえるものになって沼の底へはいったにしろ、もう三上は到底生きちゃいまい」「ええ、何のこった※」とカムポスは煙にまかれたように、「君はよく、水棲人というと笑ったじゃないか。",
              "citation": {
                "source": "人外魔境",
                "author": "水棲人",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、折竹はボロリと眼鏡を落し、「ザチ」　と、さながら放心したような呟き、「ザチ※　いったい何のこったね」　とセルカークが訊いても聴えぬかのように、「覗き穴はある。",
              "citation": {
                "source": "人外魔境",
                "author": "地軸二万哩",
                "note": "青空文庫"
              }
            },
            {
              "text": "御客は五人、ネイルドブーツの足ごしらえ極めて厳重に、それぞれシーを携え、ガイド二人までつれている様子が、ただならず見うけられたから、参考の為に聞いて見たら、何のこったグリンデルワルトに行くんだそうな、大袈裟な。",
              "citation": {
                "source": "スウィス日記",
                "author": "辻村伊助",
                "note": "青空文庫"
              }
            },
            {
              "text": "オヤオヤ何のこった、自分が迷子で二人に案じられていようとは。",
              "citation": {
                "source": "初旅の大菩薩連嶺",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「私にも何のこったか、ちっとも分らなかったんですが、安之助の講釈を聞いて始めて、おやそうかいと云うような訳でしてね。",
              "citation": {
                "source": "門",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一人は何のこったか好く解らなかった。",
              "citation": {
                "source": "阿Ｑ正伝",
                "author": "魯迅",
                "note": "青空文庫"
              }
            },
            {
              "text": "せっかく起きたらすぐ出かけようと意気込んでいた矢先であったから、何のこった！",
              "citation": {
                "source": "ナリン殿下への回想",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕食しに、アラスカ迄行ってみたら何のこったい今日は休業とあって、くさり、宿へ帰ってはかない夕食を一人で食ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和十一年",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お通さん、ふげんて何のこったい？",
              "citation": {
                "source": "宮本武蔵",
                "author": "空の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、家の中の弥右衛門は、げらげら笑って、「何のこった、納屋の中に抛りこんである俺の古刀を、日吉が、持ち出そうというだけか」「そうなんです」「戦の真似事でもする気なのだろう」「それがいけないんです」「男の子だ。",
              "citation": {
                "source": "新書太閤記",
                "author": "第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何のこった、また楮幣のいざこざか」「いやおれもゆうべ、同じ目にあった。",
              "citation": {
                "source": "私本太平記",
                "author": "建武らくがき帖",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんだい、なんだい、へんなことを云ってるじゃないか、なんのこったい」　お幸ちゃんと並んでいた学生の一人がコップを口にやりながら云った。",
              "citation": {
                "source": "萌黄色の茎",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのこったと思うと、僕はひとりでに面白くなって、襖をがらっと勢よく開けましたが、その音におとうさんやおかあさんが眼をおさましになると大変だと思って、後ろをふり返って見ました。",
              "citation": {
                "source": "僕の帽子のお話",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんのこった、第二村木液だなんて仰山な名前をつけて、こりゃただの水に葡萄酒をたらして着色しただけのもんだ」　その翌朝村木博士は鎌倉の実験室の中で、屍体となって発見された。",
              "citation": {
                "source": "人造人間",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな小娘ひとりもてあまして、なんのこった！",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "坂口安吾の「堕落論」なんて、なんのこったこんな当り前のこと言ってやがるにすぎないのか、こんなことは当然にきまってるじゃないか、バカ／＼しい、そう言うにきまっている。",
              "citation": {
                "source": "坂口流の将棋観",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "まったく、なんのこった、よ。",
              "citation": {
                "source": "猪鹿蝶",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "人が金につまって、にっちもさっちも行かず、あわや首っつりの瀬戸ぎわだというのに、あの女ときたら、なんのこったい、金銭のことにかかずらわりたくございませんので、払わないとぬかしやがる！",
              "citation": {
                "source": "熊",
                "author": "МЕДВЕДЬ",
                "note": "青空文庫"
              }
            },
            {
              "text": "品川砲台の大砲でも盗まれましたか」「そんなはっきりしたメドのあるはなしじゃないンで」「なるほど」「……じつは、小鰭の鮨なんですが……」「ほほう」「このせつ、むやみに美しい娘が行きがた知れずになります」　アコ長は笑い出して、「そりゃア、いったい、なんのこった。",
              "citation": {
                "source": "顎十郎捕物帳",
                "author": "小鰭の鮨",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　まったく、なんのこった、よ。",
              "citation": {
                "source": "姦（かしまし）",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "しょうばい人たあなんのこった、と勘六はひらき直って左の腕を捲った。",
              "citation": {
                "source": "青べか物語",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人間は学問が大切だって、あたしつくづくそう思ったのよ」とおりつは茂次を見返して云った、「若棟梁はちいさこべって知ってるわね」「なんのこった」「ちいさこべよ、知ってるんでしょ」　茂次は黙って首を振った。",
              "citation": {
                "source": "ちいさこべ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ウチじゃア、いつも、赤城先生だ」「なんのこった。",
              "citation": {
                "source": "肝臓先生",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一馬は座敷の縁側へ近づいて、「なんのこった。",
              "citation": {
                "source": "不連続殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんのこった……」苦労して、訪ねてきただけに、期待が外れて、彼は、がっかりした。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "通っているとすれば、それは今いった女の所へだろう」「なんのこった」「この社会に生きた聖などはない」「範宴でさえそうとすれば、吾々が、坂本へ忍んで、女や酒を求めるのは、まだまだ罪の軽いほうだな」「なんだか、社会がばからしくなってきた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
