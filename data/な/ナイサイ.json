  {
    "uuid": "36131c13-b501-551c-8f52-3c806080a06f",
    "entry": "内妻",
    "reading": {
      "primary": "ないさい",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "common-law wife",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "久米は平内妻の姓であるとか。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "名高かった店などの印象",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　ハハア…内妻ですな？",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何う云ふお続柄で――』『内妻――』　さう云つて龍子はふつとくすぐつたい笑ひを洩らさうとした。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "『ハヽア、すると内妻ですな』　巡査は至極真面目くさつて書きつけた。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "龍子は巡査のその言葉を聞くと何かくすぐつたいやうな気持と一緒に、何も彼も解り切つた事までも根掘り葉掘り聞かなければ承知の出来ない巡査が、その曖昧な答を馬鹿にのみ込みよく問ひ返しもせずに『内妻』としたのを妙な気持で眺めてゐたが、ふつとＥの何時もの言葉を思ひ出して、危くふき出さうとした。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何時の間にか平気で自分の口から『内妻』と云ひ得るやうになつたのだ。",
              "citation": {
                "source": "監獄挿話　面会人控所",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "桃枝は学士の内妻に等しい情人だった。",
              "citation": {
                "source": "赤外線男",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はお金で買われた内妻の一人です。",
              "citation": {
                "source": "南京虫殺人事件",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "高円寺の大火――昭和八年二月二十三日午後十一時頃、高円寺一丁目に居住する文士青地大六（30歳）の外出中の借家より発火し火の手は折柄の烈風に猛威を揮って留守居たりし大六氏の内妻房枝（29歳）及び一子守（２歳）は無惨にも逃げ遅れて焼死を遂げた。",
              "citation": {
                "source": "陳情書",
                "author": "西尾正",
                "note": "青空文庫"
              }
            },
            {
              "text": "近いうちにまたお宿下がりをもらうから、そのときあっしの好きなところてんを、うんとこさえてくれるとぬかしましたよ」「そいつあもっけもないさいわいだ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまえは造りぬしだが、おれはおまえの主人だ――いうことをききないさい！",
              "citation": {
                "source": "フランケンシュタイン",
                "author": "FRANKENSTEIN, OR THE MODERN PROMETHEUS",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
