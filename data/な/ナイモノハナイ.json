  {
    "uuid": "613a0014-9f95-568f-8b40-000f0d84a5fc",
    "entry": "無い物は無い",
    "reading": {
      "primary": "ないものはない",
      "alternatives": [
        "ないものない"
      ],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
