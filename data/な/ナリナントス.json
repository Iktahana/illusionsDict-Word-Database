    "definitions": [
      {
        "index": 1,
        "gloss": "to close in on (a certain age, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
