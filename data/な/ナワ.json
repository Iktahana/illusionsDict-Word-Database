        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "自縄自縛という言葉がある。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿屋の店頭には、かがり火をたき、白木の金剛杖をたばに組んで、縄でくくり、往来に突きだしてある。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "縄なひリレーは十四区から五人づゝの選手が出て、一メートルづゝ縄を綯つて、一定の長さに達した時、石を載せた箱を引つ張つて張力を試験して見た。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは殆んど同時に綯ひ上つた組が多く、石が軽かつたために、切れた縄もなかつた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、まるで縄になつてゐないで、さゝくれ立つてゐて、おそる／＼石を引つ張つて賞に入つた、といふので「縄の規格」の審査をやれ、といふ声が上つた。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何しろ、優勝区には、増産奨励の酒が一升づつ出ることになつて村長の机の上に六本並んでゐるのだから、他の賞品になら寛容の美徳を現はす連中も、この縄綯ひリレーだけは、勝敗が明確でないといふことにした。",
              "citation": {
                "source": "運動会の風景",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "ポムプを除り、竹を抜き、さて井戸屋さんが、縄を伝つて井戸の底へ降りて行つた。",
              "citation": {
                "source": "井戸の底に埃の溜つた話",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "あいつ等は一体、護送されているのなら、捕縄をかけられていなけりゃならないんだのに。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへは、縄梯子をガットにかけて下りるより外に方法はなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "十五六呎の長さの縄梯子でなければ、底へは届かなかった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな小さな穴からは、丈夫な生きた人間が「一人」で、縄梯子を伝って降りるより外に、方法は無かった。",
              "citation": {
                "source": "労働者の居ない船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、土方風の男が一人縄で何かガラガラ引きずりながら引っぱって来るのを見ると、一枚の焼けトタンの上に二尺角くらいの氷塊をのっけたのを何となく得意げに引きずって行くのであった。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "相撲は人間の体力の活技で、一方から見れば霊妙な複雑な器械の戦いである、いずれにしても運用する力はいわゆる器械力で、力の作用する目的物は質量を有する物体だから、やはり相撲も力学の広い縄張の中へ入れても好かろうと思う。",
              "citation": {
                "source": "相撲と力学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きな楢の木の下に、兄さんの縄で編んだ袋が投げ出され、沢山の草たばがあちこちにころがっていました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしておいてから、田代公吉を縄張問題から同業の暴漢になぐらせ負傷させ卒倒させておいてそこへ前のダンサーを通りかからせ、そうして目的のアパートへ連れて行かせる。",
              "citation": {
                "source": "初冬の日記から",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガリレーはその執拗な旋毛曲りのために縄目の苦しみを受けなければならなかった。",
              "citation": {
                "source": "科学上における権威の価値と弊害",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして単に野生の木の実を拾うような「観測」の縄張りを破って、「実験」の広い田野をそういう道具で耕し始めてからの事である。",
              "citation": {
                "source": "言語と道具",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "少なくも、恋愛の世界を勧善懲悪の縄張りから解放すべきものと考えていたのではないかと思われるふしが少なくないのである。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "科学のどこを掘り返しても「不可不」は出て来ないし、その縄張りの中を隈なく捜しても「神」は居ない。",
              "citation": {
                "source": "文学の中の科学的要素",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "活動写真の勝利の進軍は教育の縄張りにも踏み込んでくる。",
              "citation": {
                "source": "アインシュタインの教育観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "一本の麻縄に漸次に徐々に強力を加えて行く時にその張力が増すに従って、その切断の期待率は増加する。",
              "citation": {
                "source": "地震雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は社に向ってゆく、空は未だ全く暗くなってはしまわぬ、右手の農家の前では筒袖をきて手拭を冠った男が藁しべなどを掃いている、左手の何か大きい四角の石で女らしいのが頻りに藁を打って居る、夜なべに縄をなうか、草履でもつくるのであろう。",
              "citation": {
                "source": "八幡の森",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうして現に日本の方言にも東北地方や沖縄の方でも出雲地方でもハ行音を「ファフィフェ」など言うのは、昔の音が田舍に遺っているのです。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "パピプペポと発音するのは、今でも沖縄の田舍に残っております。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが何時の間にか伝統の縄張りが朽ちて跡方もなくなって、普通選挙の広い野原が解放されてしまった。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "事務長ガ無電ヲ神戸港ノ司令部ニ打ツ　兵来リテ汽車ニテ○○へ急グ　航行中ノ運送船ヨリ縄梯子ヲ降シ、モーターボートヨリ兵乗リウツル。",
              "citation": {
                "source": "陣中日誌（遺稿）",
                "author": "附・戦線便り",
                "note": "青空文庫"
              }
            },
            {
              "text": "首に縄が掛かるんだ」Ｓ＝二階　石松、一人。",
              "citation": {
                "source": "森の石松",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "半次、急ぎ彼女の許へ駈け寄って縄を解く。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが身を見たり、夏としなれば、そのやうなわが身を見たり。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなわけで、信義に乏しい現今は、芸術家達が、恐らく甚だしい孤独に逐ひ込められてゐる筈である。",
              "citation": {
                "source": "詩と現代",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
