[
  {
    "uuid": "14f89349-3034-58f8-ba59-3739204bb43b",
    "entry": "波風",
    "reading": {
      "primary": "なみかぜ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
