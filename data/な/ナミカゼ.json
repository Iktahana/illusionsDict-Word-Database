    },
    "definitions": [
      {
        "index": 1,
        "gloss": "wind and waves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そして負けじ魂と強い腕の力で波風をしのいでいる人のように見える。",
              "citation": {
                "source": "宇都野さんの歌",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "後年まで彼につきまとったユダヤ人に対するショーヴィニズムの迫害は、もうこの頃から彼の幼い心に小さな波風を立て初めたらしい。",
              "citation": {
                "source": "アインシュタイン",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、余り世間の荒い波風に当らなかったか弱い、あるいは生一本な処女が、家庭を持ってその主婦となり、周囲の煩瑣な事件や境遇にひどくいたぶられた時、それに呼応して起った心内の愛欲苦悶が素直にはけ口を得ずして鬱屈し、これに加えて肉体的の過労や病気がますますヒステリーを引き起す助縁となります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "船はそれまで、ぐるりぐるりと長者園の浦を廻って、ちょうどあの、活動写真の難船見たよう、波風の音もせずに漂うていましたげな。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "┌風に見えてしきり羽ばたく稲穂雀遠き穂づらに散りまぎれつつ　　　（新作）（26）┤　　　└ちりぢりに雀まぎるる垂穂波風は入日の田に吹きかはる　　　　　　（新作）　小笠原の正覚坊の歌十四首などは殆ど棄てて了つた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別平和を破るような事のない羽田の家に、おりおり波風の起こるのは、これが原因である。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "私達は、屋島の戦いに敗れた平家の話や、腺病質の弱々しい少女が荒い世の波風にもまれている話を聞くとき、その哀れな一種の美しさにうたれます。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、波風のまぎれに声高に申ししが、……船助かりし後にては、婦人の妍きにつけ、あだ心ありて言いけむように、色めかしくも聞えてあたり恥し。",
              "citation": {
                "source": "河伯令嬢",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "つねの時がすでに不安の状態にあるのだから、少し波風が荒いとなっては、その先どうなるのかほとんど見込みのつかないほど極度の不安を感ずるのだ。",
              "citation": {
                "source": "去年",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別平和を破るやうな事のない羽田の家に、折々波風の起るのは、是が原因である。",
              "citation": {
                "source": "高瀬舟",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "格別平和を破るやうな事のない羽田の家に、折々波風の起るのは、これが原因である。",
              "citation": {
                "source": "高瀬舟",
                "author": "森林太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうすればいいであろう、京へ帰ることもまだ免職になったままで本官に復したわけでもなんでもないのであるから見苦しい結果を生むことになるであろうし、まだもっと深い山のほうへはいってしまうことも波風に威嚇されて恐怖した行為だと人に見られ、後世に誤られることも堪えられないことであるからと源氏は煩悶していた。",
              "citation": {
                "source": "源氏物語",
                "author": "明石",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の梶のとり方ひとつで、どんな波風と闘ってもきっと向うの岸へ流れ寄ることが出来る。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、どちらであるにしても、内濠とある以上は、たとい天下、波風一つ起こらぬ泰平のご時勢であったとて、濠は城の鎧兜、このあたり一帯の警戒警備に怠りのあるはずはない。",
              "citation": {
                "source": "右門捕物帖",
                "author": "毒を抱く女",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、舟に積んでいる荷物を片端から海へ投げ込みましたが、波風はなかなか鎮まりそうもありません。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "稽神録",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の二十七人を乗せた舟がこの渡し場を出ると間もなく、俄かに波風があらくなったので、舟はたちまち顛覆して、一人も余さずに魚腹に葬られてしまった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "輟耕録",
                "note": "青空文庫"
              }
            },
            {
              "text": "言話のみでなく、凡ての事が然う云つた調子で、隨つて何日でも議論一つ出る事なく、平和で、無事で、波風の立つ日が無いと共に、部下の者に抑壓はあるけれど、自由の空氣が些とも吹かぬ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "戰ひに慣れた心が、何一つ波風の無い編輯局に來て、徐々睡氣がさす程「無聊の壓迫」を感じ出したのだ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "言語のみでなく、凡ての事が然う云つた調子で、随つて何日でも議論一つ出る事なく、平和で、無事で、波風の立つ日が無いと共に、部下の者に抑圧はあるけれど、自由の空気が些とも吹かぬ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "戦ひに慣れた心が、何一つ波風の無い編輯局に来て、徐々眠気がさす程「無聊の圧迫」を感じ出したのだ。",
              "citation": {
                "source": "菊池君",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "一九四七年の日本インフレーションのこんなすさまじい波風にもまれて、電柱に和服裁縫内職の紙のひらめいている光景は、実に悲惨な時代錯誤の感じを与える風景だと思う。",
              "citation": {
                "source": "衣服と婦人の生活",
                "author": "――誰がために――",
                "note": "青空文庫"
              }
            },
            {
              "text": "父祖十代の御恩を集めて此君一人に報し參らせばやと、風の旦、雪の夕、蛭卷のつかの間も忘るゝ隙もなかりしが、思ひもかけぬ世の波風に、身は嵯峨の奧に吹き寄せられて、二十年來の志も皆｜空事となりにける。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "四方の波風靜にして、世は盛りとこそは見ゆれども、入道相國が多年の非道によりて、天下の望み已に離れ、敗亡の機はや熟してぞ見えし。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "只々｜金枝玉葉の御身として、定めなき世の波風に漂ひ給ふこと、御痛はしう存じ候』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "只※｜金枝玉葉の御身として、定めなき世の波風に漂ひ給ふこと、御痛はしう存じ候』。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その波風の間で、では、何がわたしたちの日夜、まともに伸びたいとねがっている人間性の砦となり、その人の文学の足場となってゆくのだろう。",
              "citation": {
                "source": "新しい文学の誕生",
                "author": "――若い人に贈る――",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は父の三十七の時に生れた子だが、父にも母にも色めいた波風はひとつも起らなかった。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
