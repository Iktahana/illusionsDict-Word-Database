        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "熊本高等学校に入学した年の冬の休みに長崎から佐世保へかけての見学をした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊本から百貫まで歩いて夜船で長崎へ渡りそこで島原の方から来る友人四、五名と落ち合ったのである。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その頃の長崎にはロシアの東洋艦隊の勢力が港町の隅々まで浸潤していた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎を立って時津に向かう途中でロシア人専門の遊廓だというところを通ったら二階から女どもが見下ろして何かしら分らないことを云って呼びかけた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔長崎を見物した時に見た露文の看板の記憶が甦って来るのを感じた。",
              "citation": {
                "source": "札幌まで",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし『永代蔵』中の一節に或る利発な商人が商売に必要なあらゆる経済ニュースを蒐集し記録して「洛中の重宝」となったことを誌した中に、「木薬屋呉服屋の若い者に長崎の様子を尋ね」という文句がある。",
              "citation": {
                "source": "西鶴と科学",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "卒業後長崎三菱造船所に入って実地の修業をした後、三十四年に帰京して大学院に入り、同時に母校の講師となった。",
              "citation": {
                "source": "工学博士末広恭二君",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時どき私はそんな路を歩きながら、不圖、其處が京都ではなくて京都から何百里も離れた仙臺とか長崎とか――そのやうな市へ今自分が來てゐるのだ――といふ錯覺を起さうと努める。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "このことは姓と結び合せて自分を宮城縣人と思ふ人もあるらしいが、たゞ生誕の地といふだけで、三ヶ月後には仙臺を去り、それから土木技師である父の轉勤につれて東京・神戸・熊本・博多・長崎と轉住した。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎には住むこと七年、小學校課程の大半をこゝで過し、少年時代の追想の懷しい町である。",
              "citation": {
                "source": "自分のこと",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "先づ四馬路の菜館で廣東料理に舌皷を打ち、或る外國人のバアでリキユウルをすすり、日本料理屋で藝者達の長崎辯を聞き、更にフランス租界の秘密な阿片窟で阿片まで吸つてみた。",
              "citation": {
                "source": "麻雀を語る",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにしても、自分の少年期の長崎時代の思出に漸く殘る粗末な感じの座棺に收められて、その人をよく知る者の十指に充たぬ人達の葬送を得るに過ぎぬとは何といふ佗びしさか？",
              "citation": {
                "source": "日曜日から日曜日まで",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "新しもの好き、珍しいもの好きで、そしてそれを得るためには、昔の不便な時代に遥々長崎まで行くだけの熱心があったから、今の世に生れたら、あるいは相当な科学者になったかもしれない。",
              "citation": {
                "source": "断片（２）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "時どき私はそんな路を歩きながら、ふと、そこが京都ではなくて京都から何百里も離れた仙台とか長崎とか――そのような市へ今自分が来ているのだ――という錯覚を起こそうと努める。",
              "citation": {
                "source": "檸檬",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "横川は業平橋報恩寺橋長崎橋の下を経、総武鉄道汽車の発著所たる本所停車場の傍を過ぎ、北辻橋南にてかの隅田川と中川との連絡するところの竪川に会し、南辻橋菊川橋猿江橋の下を過ぎて小名木川に会し、扇橋その他の下を過ぎて十間川に会し、なほ南して木場に至る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "シロオテは、長崎へ護送された。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "伴天連らしきものとして長崎の獄舎に置かれたのである。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、長崎の奉行たちは、シロオテを持てあましてしまった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎では、とうとう訊問に絶望して、このことを江戸へ上訴した。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎の奉行たちがシロオテを糺問して失敗したのは宝永五年の冬のことであるが、そのうちに年も暮れて、あくる宝永六年の正月に将軍が死に、あたらしい将軍が代ってなった。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "シロオテは長崎から江戸までの長途を駕籠にゆられながらやって来た。",
              "citation": {
                "source": "地球図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が長崎の県知事をしていたときに、招かれて、こちらの区長に就任したのでございますが、それは、ちょうど私が十二の夏のことで、母も、その頃は存命中でありました。",
              "citation": {
                "source": "誰も知らぬ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "多分、蔵元屋の行末に見限りを付けたお艶婆と申合わせて、お金奉行の御威光で、蔵元屋の残り金を欲しいだけ奪り上げて、役目柄案内知った長崎あたりから、日本国の外へでも出る了簡で御座いましっろうか。",
              "citation": {
                "source": "狂歌師赤猪口兵衛",
                "author": "――博多名物非人探偵",
                "note": "青空文庫"
              }
            },
            {
              "text": "先ず如何して此等の事実が僕に知れたか、其手続を簡単に言えば、母が鎌倉に来てから一月後、僕は訴訟用で長崎にゆくこととなり、其途中山口、広島などへ立寄る心組で居ましたから、見舞かた／″＼鎌倉へ来て母に此事を話しますと、母は眼の色を変て、山口などへ寄るなと言います。",
              "citation": {
                "source": "運命論者",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それもそのはずで、読む手紙も読む手紙もことごとく長崎より横須賀より、または品川よりなど、初めからそんなのばかり撰んで持ち合ったのだから、一として彼らの情事に関しないものはない、ことごとく罰杯を命ずべき品物である。",
              "citation": {
                "source": "遺言",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "マダマ・アリサは私のフランス語の仕上げをして呉れるために――結果はそうなったのだが実は今長崎の果てに居る私のたった一人の叔母（キリスト教信者で縁家を逐われそれから何をそんな遠くでして居るのか）がわざわざ私の家事や手芸のために紹介してよこして呉れた外国婦人――三四年前から私の家へ出入りして居る。",
              "citation": {
                "source": "智慧に埋れて",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは、長崎の廓で、京から稚い時かどわかされた娘に、癆※の死際に逢って、応挙があわれな面影を、ただそのままに写生したと言う伝説の添った絵なのである。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……洲崎の土手へ突き當つたつて、一つ船を押せば上總澪で、長崎、函館へ渡り放題。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、さて談話というて、差当り――お茶代になるのじゃからって、長崎から強飯でもあるまいな。",
              "citation": {
                "source": "夜叉ヶ池",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎日光の辺にて、はこべといひ、奥州にてへこしといふも、こはたゞ名称の異なれるのみ。",
              "citation": {
                "source": "当世女装一斑",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
