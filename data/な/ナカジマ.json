    "definitions": [
      {
        "index": 1,
        "gloss": "island in a pond or river",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "池の中島にほうけ立った草もそうであった。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "○三ッ叉の名はこれより起り、一は築地に沿ひて西南に流れ、一は越中島に沿ひて東南に流る。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて永代橋以南の深川寄りの方を記せば、熊井町より大島町に沿ひて越中島の北の方を、富岡門前町と並行して木場に至り、またその南の方を東して遠く洲崎の遊廓に達するの一渠あり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "別に一水の熊井町中島町の間を北に行きて油堀仙台堀を連ぬるあり。",
              "citation": {
                "source": "水の東京",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の中島にガルバをすえて、小船でサーモジャンクションを引っぱりあるいては、時々の水温の水平ならびに垂直分布を測った。",
              "citation": {
                "source": "池",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父は話を途切らそうか続けようかと躇らった風だったが、きゅうに調子を変えて、中島の養子というのを眼下扱いにして話を続けた。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中島に養子にはいるについちゃあれはわしが口をきいてやったようなものだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "父が三里も道程のある島松まで出かけていって、中島の養子に遇った気持にはそうしたものがあったはずだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中島を見ろ、四十五まであの男は木刀一本と褌一筋の足軽風情だったのを、函館にいる時分何に発心したか、島松にやってきて水田にかかったんだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「中島は水田をやっているうちに、北海道じゃ水が冷っこいから、実のりが遅くって霜に傷められるとそこに気がついたのだ。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "川中島さへ遙に思ふ。",
              "citation": {
                "source": "魔法罎",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "下　眞田家の領地信州川中島は、列國に稀なる損場にて、年々の損毛大方ならざるに、歴世武を好む家柄とて、殖産の道發達せず、貯藏の如何を顧みざりしかば、當時の不如意謂はむ方無かりし。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "茶番をやる水兵もある、軍樂を奏する仲間もある、武村兵曹は得意に、薩摩琵琶『河中島』の一段を語つた。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋杖を小脇に、外套の襟をきりりと立てたのと、連立つて、門前通りを裏へ――越中島を畝つて流るゝ大島川筋の蓬莱橋にかゝると、汐時を見計らつたのだから、水は七分來た。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……それから仲通を越中島へ、蓬莱橋を渡ること――其の谷崎さんの時と殆ど同一に、嘗て川へ落ちた客が、津浪之碑を訪ねたので、古石場、牡丹町を川づたひに、途中、木の段五つを數へる、人のほか車は通じない牡丹橋を高く渡つた。",
              "citation": {
                "source": "深川淺景",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○東京府令によって市内の劇場を十カ所と定められたれば、在来の三座のほかに、京橋区中橋の沢村座、日本橋区久松町の喜昇座、おなじく蠣殻町の中島座、四谷の桐座、本郷区春木町の奥田座など、相前後して新築開場せり。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "一番目は「川中島」、二番目は「大丸屋騒動」。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人は裏四番町に屋敷をもっている杉野という八百五十石取りの旗本の用人で、中島角右衛門という名札をわたくしの前に出しましたから、こっちも式のごとくに初対面の挨拶をしていますと、槇原の旦那は待ち兼ねたように云うんです。",
              "citation": {
                "source": "半七捕物帳",
                "author": "朝顔屋敷",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄謙信も晩年までは凝る氣が脱せずして、川中島四郡に半生の心血を費したのである。",
              "citation": {
                "source": "努力論",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "丁度東京の相生橋と同じやうな状であるが、其の中島が素ばらしい大きな一つ巖であるのが、目ざましくも稀らしい景色をなしてゐる。",
              "citation": {
                "source": "華嚴瀧",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "一面に草が茂つて、曠野と云つた場所で、何故に一度は人家の庭だつたか、と思はれたと云ふのに、其の沼の眞中に拵へたやうな中島の洲が一つ有つたからです。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "風情は一段で、汀には、所々、丈の低い燕子花の、紫の花に交つて、あち此方に又一｜輪づゝ、言交はしたやうに、白い花が交つて咲く……　あの中島は、簇つた卯の花で雪を被いで居るのです。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "中島の上へ舞上つた、と見ると輪を掛けて颯と落した。",
              "citation": {
                "source": "人魚の祠",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字禍中島敦-------------------------------------------------------【テキスト中に現れる記号について】：ルビ（例）霊｜：ルビの付く文字列の始まりを特定する記号（例）一々｜尋ねた。",
              "citation": {
                "source": "文字禍",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それぎり何事もなく、汽車は川中島を越え、浅間の煙を望み、次第に武蔵の平原に近づきまする。",
              "citation": {
                "source": "湯女の魂",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "交潤社の客で一代に通っていた中島｜某はＡ中の父兄会の役員だったのだ。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "交潤社の客で一代に通っていた中島某はＡ中の父兄会の役員だったのだ。",
              "citation": {
                "source": "競馬",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "二次会は新中島という宏壮な家で有志の人たちだけで催された。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は黒の背広の上に薄緑のレーンコートをつけ、白の運動帽をかぶった上から、浴室用の厚いタオルをかぶり、それも吹き飛ばされないために、その首根っこを、また一つの手薄なタオルで、後ろからキッと引き締めて、首で結んで、あまりを長く垂らした、まるで白い兜を冠った川中島の信玄といった風である。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "お供をいたしたひと／″＼は、日向のかみをはじめとして、なかじましん兵衛、なかじま九郎次郎、きむらたろじろう、木むら与次、浅井おきく、わきざかさすけ、などのかた／″＼でござります。",
              "citation": {
                "source": "盲目物語",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
