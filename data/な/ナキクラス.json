        "examples": {
          "standard": [
            {
              "text": "夫を亡くして以来、彼女は毎日を泣き暮らしていた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "困難な時期、彼は酒に溺れ、泣き暮らす日々を送った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "映画の主人公は、悲しみのあまり泣き暮らす生活を送っていたが、やがて立ち直った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "女とはかようなものかと夕蝉の、草の葉末に取りついて、心も空に泣き暮らすばかり。",
              "citation": {
                "source": "名娼満月",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "つれづれとわが泣き暮らす夏の日をかごとがましき虫の声かな　蛍が多く飛びかうのにも、「夕殿に蛍飛んで思ひ悄然」などと、お口に上る詩も楊妃に別れた玄宗の悲しみをいうものであった。",
              "citation": {
                "source": "源氏物語",
                "author": "まぼろし",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
