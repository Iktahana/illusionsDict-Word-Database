        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "すなわち約七割の利益になる。",
              "citation": {
                "source": "ランプのいろいろ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "陳長財の報告は、七割まではあてにならない。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな中腰の態度で、芝居を見物する原因は複雑のようですが、その五割｜乃至七割は舞台で演ずる劇そのものに帰着するのかも知れません。",
              "citation": {
                "source": "虚子君へ",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "「その七割は俺のものだ。",
              "citation": {
                "source": "心の王者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "○芸｜娼妓の七割は、精神病者であるとか。",
              "citation": {
                "source": "古典風",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さな島のくせに、全サモアの紛争の七割は、此処から発生する。",
              "citation": {
                "source": "光と風と夢",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七割は自殺者だそうである。",
              "citation": {
                "source": "柿の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "七割ぐらいの座席が埋まり、その大部分が十代の少女のようだ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうち七割は飲食店や、菓子、缶詰なぞいう食料品店。",
              "citation": {
                "source": "街頭から見た新東京の裏面",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論、制帽などは無かったから、思い思いの帽子をかぶったのであるが、帽子をかぶらない生徒が七割であって、大抵は炎天にも頭を晒してあるいていた。",
              "citation": {
                "source": "綺堂むかし語り",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸数の七割五分は何の家も患者を出し、或家では一家を挙げて隔離病舎に入つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "戸數の七割五分は何の家も患者を出し、或家では一家を擧げて隔離病舍に入つた。",
              "citation": {
                "source": "赤痢",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "農村では、全農家の七割が貧農経営であって、地主による半農奴的な搾取がつづけられている。",
              "citation": {
                "source": "労働者農民の国家とブルジョア地主の国家",
                "author": "――ソヴェト同盟の国家体制と日本の国家体制――",
                "note": "青空文庫"
              }
            },
            {
              "text": "肥料なんど七割近い騰貴で、問題にならぬ。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "第一次五ヵ年計画のすんだ今では全農戸の七割が集団農場化し、耕作機械、刈入機械の配給所は三千百ヵ所にまで殖えた。",
              "citation": {
                "source": "今にわれらも",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "煙草の増税で二千万円ばかり収入があったそうだが、七割はバットだってね。",
              "citation": {
                "source": "打あけ話",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本の全人民が収入の七割以上を税金にとられ、終戦費がそこから出されてもゆく、そのどこにワルト・ホイットマンの時代の社会があるというのだろう。",
              "citation": {
                "source": "真夏の夜の夢",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "モスクワ市内にだけでもこういう理想的な厨房工場を、五つも六つも増設し、五ヵ年計画の終りには都会入口の七割五分、農村の五割を公衆食事で養おうという勢いだ。",
              "citation": {
                "source": "ソヴェト労働者の解放された生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんな文化人が物価七割の値上げから自由であろう。",
              "citation": {
                "source": "前進的な勢力の結集",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あらゆる形で大衆課税がとりたてられ、たとえ所得税の税率がいくらか引き下げられたとしても、汽車賃の二倍半までの増額、公定価格の七割ほどの引上げ、通信料の四倍、煙草の二割から八割の値上げは、あらゆる家計を破綻させている。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今議会ですべての公定価格を七割値上げした政府は官立専門学校大学の月謝を三倍の値上げに決定した。",
              "citation": {
                "source": "今日の日本の文化問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生活の困難は益々おびただしく、いまでは国民所得の七割が税になって、不安定も底をついたと云っていいほどだし、六・三制の予算は、僅か七億にきりちぢめられた。",
              "citation": {
                "source": "再版について（『私たちの建設』）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "人口の七割は死んだやうですが後から変調を来たして死ぬる人を加へるともつと多いいでせう。",
              "citation": {
                "source": "書簡",
                "author": "家族・親族宛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお四人以上の子供を有する者は、家族数の多いがためにという原因の方に編入されているのだが、もしそれを合計するならば、第一級の貧乏人のうち約七割四分だけのものは、毎日規則正しくかせいでいながら、ただ賃銭が少ないかまたは家族数が多いがために貧乏線以上に浮かび得ぬのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "今中等の上を略し、最後の最富者の部分を一瞥するに、人数より言えば全人口のわずかに百分の二に相当するだけのものたるにかかわらず、その所有に属せる富は、英国にあっては全国の富の約七割二分、フランスにあってはその六割強、ドイツにあっては五割九分、米国にあっては五割七分に相当しているのである。",
              "citation": {
                "source": "貧乏物語",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だいちうちにいれば家は只貸しだし、ほんとに困るときは給料の前貸しもしてやるし、そしてその金を貸しても普通の相場の七割の利子しかとらないし、狭くはあっても野菜畑を一枚に、釜や鍋までも貸してやってあるじゃないか。",
              "citation": {
                "source": "何が私をこうさせたか",
                "author": "――獄中手記――",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の資本家が利潤において五割七割という配当を行っているのに、労働者が利潤の方面には手を着けず、全く無関心に放任して置いて、その賃銀ばかりの値上を迫っているのは、資本家と対等な人格的独立者としての権利的要求でなくて、徹頭徹尾資本家の隷属として社会的低位にある人間の哀訴的要求であると思います。",
              "citation": {
                "source": "階級闘争の彼方へ",
                "author": "与謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し着実な其道の人の批判では仮ひ一円に下つても会社経営では四五割、個人経営では六七割の利益は確かだと云つて居る。",
              "citation": {
                "source": "巴里より",
                "author": "與謝野寛、與謝野晶子",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し住民の七割強が支那人であるのは長春の日本市街と同様である。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
