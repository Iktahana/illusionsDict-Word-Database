          "literary": [
            {
              "text": "何は無くともこんな好い心持の時に戴くとお美いものですね。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何は無くとも、先ず一献、斯う云う所だが然うは云わねえ。",
              "citation": {
                "source": "天主閣の音",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何は無くとも、これだけあれば演劇になる――さういふものを、先づ見出さうとしてゐるのであります。",
              "citation": {
                "source": "演劇一般講話",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "霞ヶ関の日比谷公園寄りにある海軍省などは、何は無くとも、諸外国に新興日本の「威」を示すために、官庁のイレモノは立派にと、当時の伊藤政府が心をくだいて打建てた記念物で、これがコンドル博士の設計に成るものである。",
              "citation": {
                "source": "東京の風俗",
                "author": "木村荘八",
                "note": "青空文庫"
              }
            },
            {
              "text": "野球と同じくらい馬が大好きでな、何は無くともポケットには必ず馬のリストが入ってるんだ。",
              "citation": {
                "source": "老人と海",
                "author": "THE OLD MAN AND THE SEA",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
