    "definitions": [
      {
        "index": 1,
        "gloss": "professional female mourner",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "喪主らしい男は、一人だけ粗麻の喪帽をかむり、泣き女はわんわんほえながらあとにつゞいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "行儀正しくあとにつゞいている粗麻の喪主と、泣き女はくたびれると、欠伸をして変に笑った。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "源は棺桶を買ってきて泣き泣き女の死骸を中に納めて送り出そうとしたが、棺は空の時の重さと少しも変らなかった。",
              "citation": {
                "source": "緑衣人伝",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――切実な悲鳴、どこの兵隊でも死に際には切実な声をあげる――と諸君は言ふだらう、だが支那の兵隊は、特に各国の兵士よりも高い悲鳴をあげるのだ、棺はしづかに運ばれて泣き女は棺に泣きながらついてゆく、空涙をかほどまでにも真実らしく流す技術をもつた国民は世界の何処を探してもないだらう。",
              "citation": {
                "source": "小熊秀雄全集-6",
                "author": "詩集（５）飛ぶ橇",
                "note": "青空文庫"
              }
            },
            {
              "text": "途中、笛と跫音と泣き女のいとも哀しい支那の葬式にあう。",
              "citation": {
                "source": "踊る地平線",
                "author": "踊る地平線",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十がらみの泣き女はもはや再び泣くことに没頭してゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "泣き女の一団へ酔つ払つた洋服男がわりこんでゐた。",
              "citation": {
                "source": "吹雪物語",
                "author": "――夢と知性――",
                "note": "青空文庫"
              }
            },
            {
              "text": "大衆党幹部のポケットへ札束が入り女工たちの要求は勝手にゆがめられた失業地獄のどん底で垢ほどの手当が何になる泣き　泣き女工たちの帰って行くのは何処なのか豊年飢饉になやみ　疲れくたばりかけの農村へ！",
              "citation": {
                "source": "農村から",
                "author": "――失業反対――",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて家に着いて見ると、家の女たちや傭ってきた泣き女が、泣きつ叫びつ騒いでいた。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "（泣き女というのは、死者のあった家に傭われて慟哭する職業婦人であって、悲しみをそそり、かつ近隣への死亡通知になったものです）。",
              "citation": {
                "source": "イエス伝",
                "author": "マルコ伝による",
                "note": "青空文庫"
              }
            },
            {
              "text": "中でも一つの車上には、髪をふりみだした“泣き女”と称する女性が、それこそ誇張でなく、白昼の下に、声をかぎり号泣をしつづけて行くのである。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "行列の中では、銅鑼が鳴り、鉦が叩かれ、泣き女の異様な啼泣と相和して、それは何とも不思議な音階を町に流しつつ練り歩くものだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "居留地の南京街でも、豪商とか何とかいわれる著名人の葬式でもあると、泣き女も一人や二人ではなく、彩旗はへんぽんと相沢の町に続き、五色紙の散蓮華やら餅菓が路傍の見物人へ撒かれたりして、ぼくら子供は、その演出と天来の奇観にはしゃぎ立ッて、ぞろぞろ葬列の後について駈け歩いたものだった。",
              "citation": {
                "source": "忘れ残りの記",
                "author": "――四半自叙伝――",
                "note": "青空文庫"
              }
            },
            {
              "text": "二日間たえまなく、議政壇上は泣き女めいた長広舌で満たされた。",
              "citation": {
                "source": "死刑囚最後の日",
                "author": "LE DERNIER JOUR D'UN CONDAMNE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、清国式の大げさな葬式にはぶたの丸煮と共に、ぜひともなくてはならない「泣き女」の職業に。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "職業婦人の「泣き女」は、その葬式の先頭に立って、人力車の上でオイオイと声をあげて泣くのが商売だった。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その「泣き女」の細君と懇意なのか、お光さんは、家の中で立ち話をしていたが、トム公の声を聞くと、すぐに出て来た。",
              "citation": {
                "source": "かんかん虫は唄う",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
