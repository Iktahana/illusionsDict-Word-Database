        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "一つには貧しい生活が貧しい乍らに愈々複雑になつて、愈々一人ばかり歌つたり歌ばかりに苦しんでゐられなくなつたのであつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "萩原君の云ふ如く、而も君は生れ乍らにして神の愛を体得した人の一人であつた。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集のはじめに",
                "note": "青空文庫"
              }
            },
            {
              "text": "君を憶へば、身はこれ敵国の東海遠き日本の一詩人、敵乍らに、苦しき声あげて高く叫ぶよ、（鬼神も跪づけ、敵も味方も汝が矛地に伏せて、マカロフが名に暫しは鎮まれよ。",
              "citation": {
                "source": "詩",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "其女の母をも同時改葬しけるに、遙に先だち死たる者なれども其の體變らで續き乍らに有ける。",
              "citation": {
                "source": "詛言に就て",
                "author": "南方熊楠",
                "note": "青空文庫"
              }
            },
            {
              "text": "妻は姉の毛を引張って、後ろ倒しにしてやった事を涙乍らに語りました。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "智惠子は神の御心に委ねた身乍らに、獨ぼツちの寂しさを感ぜぬ譯にいかなかつた。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "チャント中味を知り抜き乍らに。",
              "citation": {
                "source": "ドグラ・マグラ",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "癪持ちの女を写生したと見えて、まだ／＼きれいに見える容貌殊にさうなつても、生きいきしたよさに徹した頸筋の動脈なども、美しさは美しい乍らに、写実のいやらしさを感じさせた。",
              "citation": {
                "source": "街衢の戦死者",
                "author": "――中村魁車を誄す――",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝉の方がよつぽど大きく、筋骨逞しい様子のくせに、カマキリの奴生れ乍らにして蝉の急所まで心得てゐる。",
              "citation": {
                "source": "孤独閑談",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこまでも事物を離れずして、事物其物なりと取つて行く所に、素朴乍らに甚だ力強いものがある。",
              "citation": {
                "source": "安藤昌益",
                "author": "狩野亨吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "畜生｜乍らに、亡くなつた主人を慕ふかと、人々も憐んで、是から雪の降る時節にでも成らうものなら何を食つて山籠りする、と各自に言ひ合つた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝太郎は何やらサッパリ分らぬ乍らに礼を述べ、頭を上げた時には早姿は消えてゐました。",
              "citation": {
                "source": "孝太郎と悪太郎",
                "author": "槇村浩",
                "note": "青空文庫"
              }
            },
            {
              "text": "然し小さい乍らにも、信用もあり店を張つて居ると、それを全く打捨てることも出来ないのである。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "朝早く、又晩遅く、貧民窟の路次路次を巡回して見ると、小さい乍らにも皆生きるために努力して居る。",
              "citation": {
                "source": "死線を越えて",
                "author": "死線を越えて",
                "note": "青空文庫"
              }
            },
            {
              "text": "氣の毒なことにお夢は生れ乍らに足が惡く、踊ることも驅けることも出來ない女だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "一と目千兩",
                "note": "青空文庫"
              }
            },
            {
              "text": "物置と下男部屋とが背中合せになつて居り、物置の二階に積んだ、モロモロのがらくたが、下男部屋からは寢乍らにしてよく見えます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "萬兩分限",
                "note": "青空文庫"
              }
            },
            {
              "text": "これほどの美しい娘が、涙乍らに頼んだとしたら、どんな恐ろしい事が起るか、よく解るやうな氣がしたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "結納の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "伜はお喜多さんに呼出されて、裏の空地で話して居たんです」　涙乍らに言ふ老母の言葉の、妙に辻褄の合つた眞實性が、八五郎の胸に徹へます。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "蜘蛛の巣",
                "note": "青空文庫"
              }
            },
            {
              "text": "――それにも拘らず、大事の御墨附を失つては、御使者に立つた父相澤半之丞も生きては居られません」　半之丞の娘お秀、涙乍らに斯う語り進みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "父親の勘兵衞は、涙乍らにその支度をしてゐる。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "ガラツ八祝言",
                "note": "青空文庫"
              }
            },
            {
              "text": "へツへ」　むしろ好んで皮肉を衒ふやうなその歪んだ口許に深い皺を寄せ乍らにや／＼と傲りがに裕佐の顔を見てゐた孫四郎はかう云つて高く笑ひ出した。",
              "citation": {
                "source": "青銅の基督",
                "author": "――一名南蛮鋳物師の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "船頭直助の母親は、涙乍らに平次のところへ飛込んで來たのは、その翌る日。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "呪ひの銀簪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの時、シベリアの寒村で、革命党の刃に倒れた尊いお姫様の一方が、今は最期という時、その胸につけて居られた青ダイヤを外して、涙乍らに私に下されたのです。",
              "citation": {
                "source": "呪の金剛石",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくヘクトール隊中を進み乍らに同僚を勵まし敵の塹濠を渡り行くべく説き勸む。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "』しかく陳じて原上を走り乍らにポセードーン、高らに叫ぶ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "サルペードーンこれに次ぎ、耀く槍を投げ飛ばし、　465打てど覘を誤りぬ、されど其槍敵將の馬ペーダソス右の肩打てばはげしく嘶きて、倒れて塵の中に伏し叫び乍らに息絶えぬ。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "イドメニュウスは之を聞き鬣美なる馬を驅り、恐怖の念を胸中に充たし乍らに舟に去る。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "ペーレーデース・アキリュウス訪ひて悲報を傳ふべく、涙乍らに戰場をあとに勇將かけいだす。",
              "citation": {
                "source": "イーリアス",
                "author": "ILIAS",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どうぞ旦那樣早くよくおなりなすつて」と臺所から出て來た下女は涙乍らに言つた。",
              "citation": {
                "source": "續俳諧師",
                "author": "――文太郎の死――",
                "note": "青空文庫"
              }
            },
            {
              "text": "之に反して、貧しき境遇にあるもの、生れながらによきキリストの血を受けて長く苦労せる人人の心には、自然とやさしい人情の種が蒔かれて居た。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
