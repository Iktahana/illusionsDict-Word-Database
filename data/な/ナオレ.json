    },
    "definitions": [
      {
        "index": 1,
        "gloss": "disgrace",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「五丁町の辱なり、吉原の名折れなり」という動機の下に、吉原の遊女は「野暮な大尽などは幾度もはねつけ」たのである。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんとしてもきょうのうちに、この大井川を渡って島田の宿に着かなければ、西国武士の名折れだぞ。",
              "citation": {
                "source": "新釈諸国噺",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのやうな面が將軍家のおん手に渡りて、これぞ伊豆の住人夜叉王が作と寶物帳にも記されて、百千年の後までも笑ひをのこさば、一生の名折れ、末代の恥辱、所詮夜叉王の名は廢つた。",
              "citation": {
                "source": "修禪寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "町人にうしろを見せては一生の名折れであると、水野は歯がみをして憤ったが、どうしても頽れかかった勢を盛返すことは出来なかった。",
              "citation": {
                "source": "番町皿屋敷",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをきいて七郎は、多少心細くも思ひましたが、こんなことでへこたれては武士の名折れだと力むで、戦闘の準備を計画いたしました――。",
              "citation": {
                "source": "〔編輯余話〕",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "少長どのに仕負けられては、独り御身様の不覚のみにてはこれなく、歌舞伎の濫觴たる京歌舞伎の名折れにもなること、ゆめゆめご油断なきよう御工夫専一に願い上げ候。",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "（しばらく考えてまた読み返す）京歌舞伎の名折れにもなること、うむ！",
              "citation": {
                "source": "藤十郎の恋",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしろ、よそからの預かり者を取り逃がしたんだから、事と場合によっちゃ、あっしども一統の名折れにもなるんだからね」「よし、そう聞いちゃ、相手がちっと気に入らねえが、おれも一口買って出よう！",
              "citation": {
                "source": "右門捕物帖",
                "author": "卍のいれずみ",
                "note": "青空文庫"
              }
            },
            {
              "text": "たかがいなかっぺいのけんつくぐれえに尾っぽを巻いて、江戸八百八町の名折れじゃござんせんか！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七化け役者",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふざけたまねしやがって、このうえおひざもとを荒らされたんじゃ、江戸一統の名折れではござらぬか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "達磨を好く遊女",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな代物にバカ高い金を払ったら、名折れだぜ」　あわててのこったビールを飲みほし、ドッグをひっつかんで、慶一は高志を追った。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのような面が将軍家のおん手に渡りて、これぞ伊豆の住人夜叉王が作と宝物帳にも記されて、百千年の後までも笑いをのこさば、一生の名折れ、末代の恥辱、所詮夜叉王の名は廃った。",
              "citation": {
                "source": "修禅寺物語",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "「若い女をおどしにかけて白状させたと云われちゃあ、御用聞きの名折れになる。",
              "citation": {
                "source": "半七捕物帳",
                "author": "金の蝋燭",
                "note": "青空文庫"
              }
            },
            {
              "text": "金蔵は妙なところへ見得を張る奴で、三甚のような小僧ッ子に召捕られたのは、おれの顔にかかわるとか、おれの名折れになるとか云って、むやみに口惜しがっているのだそうで……。",
              "citation": {
                "source": "半七捕物帳",
                "author": "廻り燈籠",
                "note": "青空文庫"
              }
            },
            {
              "text": "黒田武士の名折れじゃ。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "この家の名折れと承わりましたゆえ」「ウムッ。",
              "citation": {
                "source": "名君忠之",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "実は、吾輩もここでこの女に宿賃なんか払わしちゃ江戸ッ子の名折れになる。",
              "citation": {
                "source": "山羊髯編輯長",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "捕えられては、隼人の名折れになる）　小太郎は、顫える手で、脇差を握った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな半分しかない酒なんか飮んだら、三田公の名折れだつせ。",
              "citation": {
                "source": "大阪の宿",
                "author": "水上滝太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな者を相手に喧嘩をしたつて江戸っ子の名折れだから、車屋をつれて来てさつさと出て来た。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の新聞に辟易して学校を休んだ抔と云はれちや一生の名折れだから、飯を食つていの一号に出頭した。",
              "citation": {
                "source": "坊っちやん",
                "author": "夏目金之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "宿直をして鼻垂れ小僧にからかわれて、手のつけようがなくって、仕方がないから泣き寝入りにしたと思われちゃ一生の名折れだ。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな者を相手に喧嘩をしたって江戸っ子の名折れだから、車屋をつれて来てさっさと出てきた。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "今日の新聞に辟易して学校を休んだなどと云われちゃ一生の名折れだから、飯を食っていの一号に出頭した。",
              "citation": {
                "source": "坊っちゃん",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "邪魔にならぬものなら貰つておいてもよささうなものだが、そこは文人気質の潔癖から、そんなものを貰つては一代の名折れのやうに考へ、又は、よろこんで貰つたやうに思はれるのがいやさに、怒らなくてもいいところを怒るものがあるだらう。",
              "citation": {
                "source": "文功章",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "次に其の名所旧蹟にあるもの悉くがその地方の名折れになるやうなものであつてはならない。",
              "citation": {
                "source": "観光事業と文化問題",
                "author": "――日本観光連盟第六回総会に於ける講演――",
                "note": "青空文庫"
              }
            },
            {
              "text": "セーターを取り返すべく戸をこじあけて侵入せりは、たしかに名折れだなア。",
              "citation": {
                "source": "桂馬の幻想",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここで騒いだり、悲観しては帝国軍人の名折れです。",
              "citation": {
                "source": "太平洋雷撃戦隊",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、またあしたになって、金平ちゃんのおなかがなおれば、いっしょに遊べるからいいと思いました。",
              "citation": {
                "source": "かぶと虫",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "それ、その工兵も、その竜騎兵も、向うのてき弾兵も、みんなおれの兵隊だからな。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
