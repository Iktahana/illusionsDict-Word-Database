[
  {
    "uuid": "d48f82ac-19d0-5ea2-9794-617c2f53051e",
    "entry": "ＮＡＫ",
    "reading": {
      "primary": "ナック",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
