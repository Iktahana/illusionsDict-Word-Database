[
  {
    "uuid": "34c35e1d-51b2-518f-a82f-c9e2a6b11892",
    "entry": "難事業",
    "reading": {
      "primary": "なんじぎょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
