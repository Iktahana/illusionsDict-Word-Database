    "definitions": [
      {
        "index": 1,
        "gloss": "proceeding south",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "北国街道の一軍は、善光寺近くの旭山城に一部隊を残し、善光寺から川中島を南進し、海津城の前面を悠々通って妻女山に到着した。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど大通りの並木に平行して全速力で南進して行くのであった。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "と、見ると、火の手は、南進していたものが一転して東方に向って平押しに押し込んで、大通りに向う横町という横町へ、長蛇の走るよりも迅い勢いで吹き出して来た。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、風が西に変って強くなったものだから、一度南進した火先は、先方へ延びずに後へ退り、西飛の癖として、火先へ延びず、逆に尻火に延び、反対に退却した形になって仲町から田原町へと焼けて来た。",
              "citation": {
                "source": "幕末維新懐古談",
                "author": "浅草の大火のはなし",
                "note": "青空文庫"
              }
            },
            {
              "text": "独自の兵備によってこれに対抗し、断じて心配ないと言うているし、また一部南進論者は三年後には米国の製艦により彼我海軍力に大きな差を生ずるから今のうちに開戦すべしと論じている。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人達はな国策の線に沿ってこれから南進するのだぞ。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "その門構の前には既に南進者の群や見送人達があいかたまり集って待っていた。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　私達はマラソン選手達もまじえて、彼等南進者の群の影が見えなくなるまで再び目送し出した。",
              "citation": {
                "source": "親方コブセ",
                "author": "金史良",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしながら更に南進して黒潮を乗切ると、もう人間の力は幽霊と妖気に降服してしまっていた。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那の歴史は一面より觀れば、漢族の文化の南進の歴史ともいへる。",
              "citation": {
                "source": "晉室の南渡と南方の開發",
                "author": "桑原隲蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが更に七百年ほど経過すると、鉄器で武装した新しい民族がアルプスを越えて南下し、初めはポーの流域に集結したが、次第に南進して、ウンブリアからアペニンを越えてテベレの東方一帯の地に定住した。",
              "citation": {
                "source": "パラティーノ",
                "author": "野上豊一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――崩壊は引続き蔓延中――軍需工場地帯を南進中”“被害｜遂にニューヨーク市に波及。",
              "citation": {
                "source": "共軛回転弾",
                "author": "――金博士シリーズ・11――",
                "note": "青空文庫"
              }
            },
            {
              "text": "七月二十四日（月）　小磯（国昭）は二・二六事件の黒幕であり、有名な南進論者だ。",
              "citation": {
                "source": "暗黒日記",
                "author": "清澤洌",
                "note": "青空文庫"
              }
            },
            {
              "text": "声　　銚子第二監視哨報告……午後八時五十分、東北二千五百、重爆三機、高度三千、海岸に沿ひ南進す。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "別の声　　東金防空監視隊本部報告……午後八時五十二分、鳴浜東方三千、重爆三機、高度二千五百、九十九里海岸に沿ひ南進…………。",
              "citation": {
                "source": "空の悪魔（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "新潟県方面からは、糸魚川街道の大前｜若しくは平岩から大所に出で、夫より蓮華温泉に至り、蓮華鉱山跡を経て、鉢ヶ岳の南方越中との国境上に出で、山稜を南進して終に頂上に達するのであるが、距離も長く又信州口ほど楽でもない。",
              "citation": {
                "source": "白馬岳",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "荷を置いた所へ戻って、休みもせずに直に大天井岳に向って南進する。",
              "citation": {
                "source": "秩父宮殿下に侍して槍ヶ岳へ",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "自分らは五万分の一足尾図幅に、原から根利山に向って点線の路が記入してあるので、それを辿って先ず国境山脈に攀じ登り、南進して千九百五十七米の三角点をきわめ、引き返してその北の一峰から西に沢を下り、地図の道に出て砥沢に行き、翌日何処からか皇海山に登ろうという計画であった。",
              "citation": {
                "source": "皇海山紀行",
                "author": "木暮理太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある新聞記者の書いた「日本南進論」といふ本を読んでみようと思ひ、近所の本屋へ出かけて行つたが、その本はまだ来てゐなかつた。",
              "citation": {
                "source": "双面神",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "シナ大陸に沿って南進し、二十六日台湾海峡に入る。",
              "citation": {
                "source": "西航日録",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "茫茫支那海、唯見水連空、赤道将非遠、満帆三伏風、日沈暑威減、風転晩涼従、月下船南進、雲涯是呂宋。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "タスマニア州の首府ホバートに寄港するために、海峡を通過し、同州の東岸に沿いて南進す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "軽風平波、右方に一帯の連山を望みつつ南進す。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "南進舟踰赤道回、欲除残熱晩銜杯、酔余一枕涼如湧、風自大西洋外来。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日以来南進せる結果、夜十時半、太陽すでに地平線下に入る。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後三時に至り埠頭にて滝波氏と相わかれ、パシフィック会社汽船オリサ号（五千三百五十九トン）に移り、六時抜錨して南進に就く。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "しからば北進策を捨てて、南進策を取るとしてみると、この船をいずれの方に向け、いずれの地点に向わしむべきか。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "北進を捨てて南進を取るとすれば、駒井の念頭に起る最初のものは、亜米利加方面ということになるのは、当然の帰結でもあり、同時に当時の常識でもありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここには、北に対するつり合い上、南進という語を用うるけれども、亜米利加は必ずしも南とは言えない。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "北進を取ったのは、駒井としては寧ろ、よんどころなき避難の急のためであって、駒井の最初の頭は、右の意味での南進に傾いていたのです。",
              "citation": {
                "source": "大菩薩峠",
                "author": "京の夢おう坂の夢の巻",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
