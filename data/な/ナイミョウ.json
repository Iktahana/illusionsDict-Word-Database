    "definitions": [
      {
        "index": 1,
        "gloss": "adhyatma vidya (one of the five sciences of ancient India)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "若くは雨の止むこともあらんとの思ひに心休まらで、睡るとも無く睡らぬとも無く時を過ごしける中、いつしか我を忘れて全く睡りに入りけるが、兄上と揺り覚まされて、はつと我に返れば、灯火の光きら／＼として室の内明るく、父上も弟も既衣をあらためて携ふべきものなど取揃へ、直にも立出でんありさまなり。",
              "citation": {
                "source": "鼠頭魚釣り",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "室羅伐城の大長者の妻が姙んだ日、形貌非常に光彩あり、産んだ女児がなかなかの美人で、生まるる日室内明照日光のごとく、したがって嘉声城邑に遍かった。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "その女の後身が妙光女で、願の趣聞き届けられて、居所室内明照日光のごとくだった。",
              "citation": {
                "source": "十二支考",
                "author": "田原藤太竜宮入りの話",
                "note": "青空文庫"
              }
            },
            {
              "text": "印度で之を五明と申しますが、聲明、因明、醫方明、内明、工巧明、斯う云ふ五種類であります。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "内明が印度で哲學の樣なもので、大體に於て諸子、六藝に當ると思ひます。",
              "citation": {
                "source": "日本國民の文化的素質",
                "author": "内藤湖南",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時の安綱は、まだ鳥越の甚内明神へは納めないであったものと見えます。",
              "citation": {
                "source": "大菩薩峠",
                "author": "小名路の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「同日当分の内明倫堂督学勤向相勤候様にとの御事に候。",
              "citation": {
                "source": "下谷叢話",
                "author": "永井荷風",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは声明とて言語音声に関した一切の科学、医方明とて医学、因明とて論理学、工巧明とて工学、内明とて宗教的科学及び哲学でありますけれどそれをよく取り調べて明らかに通じて居る人はごく少ない。",
              "citation": {
                "source": "チベット旅行記",
                "author": "河口慧海",
                "note": "青空文庫"
              }
            },
            {
              "text": "世田谷区羽根木町なる山内明邸へ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "十二時半近く、山内明が「出棺は一時です、それ迄何卒お休み」といふやうなことを言ふ。",
              "citation": {
                "source": "古川ロッパ昭和日記",
                "author": "昭和三十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "柚子の心のなかに分け入って、そういう情緒は不潔だと、きめつけるつもりなら問題は別だが、形のうえでなら、非難することも、叱ることもできないみょうなぐあいのものである。",
              "citation": {
                "source": "春雪",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、その光の中へ、人間の顔ではなくて、なんともえたいの知れないみょうなものがあらわれたのです。",
              "citation": {
                "source": "大金塊",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの窓の、一つもないみょうな部屋は、きっと、隅田川の底にあったのです。",
              "citation": {
                "source": "妖人ゴング",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "窓の一つもないみょうな部屋です。",
              "citation": {
                "source": "電人Ｍ",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
