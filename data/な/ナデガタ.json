    "definitions": [
      {
        "index": 1,
        "gloss": "sloping shoulders",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
