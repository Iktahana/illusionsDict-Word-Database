        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "私は殆ど忘れて思い出せなかったが、あの作楽井氏の人懐っこい眼元がこの紳士にもあるような気がした。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人が「及ばずながら」と引受けると、人懐っこい眼を輝かしながら頻りに感謝の言葉を述べるのであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸見ると何だか土方のような奴で、其奴がこう手を背後へ廻しましてな、お宅の犬の寝ている側へ寄ってくから、はてな、何をするンだろう、と思って見ていますと、彼様な人懐っこい犬だから、其奴の面を見て、何にも知らずに尻尾を掉ってましたよ。",
              "citation": {
                "source": "平凡",
                "author": "二葉亭四迷",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたりやさんへ行くのはいいが、どうも根が生えっちまうんでねえ」　母親の眼からみると寿女は人懐っこい子で、誰れかれの別なく切りがなかった。",
              "citation": {
                "source": "※女抄録",
                "author": "矢田津世子",
                "note": "青空文庫"
              }
            },
            {
              "text": "倅が兵隊服を着て、あのまん丸な若々しい顔に人懐っこい微笑をうかべながら佇っている姿が、今もまざまざと見えるようだ。",
              "citation": {
                "source": "情状酌量",
                "author": "モーリス・ルヴェル　Maurice Level",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしたちはいつでも材料を探しまわつているので、この間のことで何か参考になるようなお話が伺いたいと思って出てきたんですよ」「でもわたし、なんにもお話しすることはございませんもの」　相手の人懐っこい穏やかな調子にいくぶん安心しながらも、まだ油断しないのだった。",
              "citation": {
                "source": "五階の窓",
                "author": "合作の四",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも彼らに共通な人懐っこい愛情はいつまでも失わずにいた。",
              "citation": {
                "source": "硝子戸の中",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "したがって、よくこれを諒解してくれさえすれば、いわゆる部落の人々はいずれも善人です、親切な人々です、人懐っこい人々です。",
              "citation": {
                "source": "融和促進",
                "author": "喜田貞吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "まことに人懐っこい態度であったから、法皇はひどく喜んだ。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第八巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "活溌だが、けッして出過ぎたというのでなく、無邪気で人懐っこいので、ただもうおのれの愉快を俺にも分け与えたいという風だッた。",
              "citation": {
                "source": "湖畔",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "どこか村のように古趣のあるこぢんまりとしたオアシスで、手頃な納屋の屋根には人懐っこい猫たちが思い思いにひなたぼっこしていた。",
              "citation": {
                "source": "闇をさまようもの",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると、中年の洋服紳士で、どことなく人懐っこい男である。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこへ持って来て、人懐っこい話相手。",
              "citation": {
                "source": "猟奇の果",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "挨拶ぬきで、にこにこ笑いながら、片手で頸のうしろをぐいと撫で、ひと懐っこい眼で夫人を見た。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「正直に申上げますが」半之助はひと懐っこい表情で、じっと夫人を見まもりながら、しんみりした声で言葉を継いだ。",
              "citation": {
                "source": "半之助祝言",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "人懐っこい表情がベナにも分かったが、こんな明るくて、かわいいのはこれまで見たことが無い。",
              "citation": {
                "source": "謎の四つ指",
                "author": "The Mystery of the Four Fingers",
                "note": "青空文庫"
              }
            },
            {
              "text": "「貴下の職工待遇問題に関する御意見を」　とか、何とか、新聞記者特有の、相手を呑んでかかった様な、それでいて、どこか無邪気な、人懐っこい調子で、その男はこう切出した。",
              "citation": {
                "source": "二銭銅貨",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ずいぶんいろいろな男の手から手に渡ったらしいのに、それだからたまには不愉快なほど人擦れがしているくせに、どこかさぐり寄るような人なつっこいところも持っている。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さらでだに、人恋しい船のりは、寂しい人なつっこい自然の情景の前で、滅多に来る事のない直江津の陸をながめて恋い慕った。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "孤独に親しみやすいくせにどこか殉情的で人なつっこい私の心は、どうかした拍子に、このやむを得ない人間の運命をしみじみと感じて深い悒鬱に襲われる。",
              "citation": {
                "source": "生まれいずる悩み",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こんな事を云われるのが嬉しいほど人なつっこい気持になって居た千世子はたびたびいかにもすなおな娘らしい調子で母親の処へ手紙を書いた。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうっとくびを撫でてやりたい様な気持を起させるほどすなおらしい人なつっこい目をして居る。",
              "citation": {
                "source": "旅へ出て",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "あんまり人なつっこいあんまり八方美人に芸術はなりかかって居る。",
              "citation": {
                "source": "無題（二）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "単調な人なつっこいその木霊が、また向こうの山から呼びかけてくる。",
              "citation": {
                "source": "浅間山麓",
                "author": "若杉鳥子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は人なつっこい笑顔で、お婆さんの親切に報いるべく、頭のつかえそうな、アンペラ張りの店へはいって行った。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "とても人なつっこいのですけれど、何となくこわいのです。",
              "citation": {
                "source": "お父さん",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにチョットわからないが、非道い近眼だったこと……これが一番大事な話のヤマなんだが、その近眼で人の顔をジイッと見る眼付が又、何ともいえず人なつっこい。",
              "citation": {
                "source": "近眼芸妓と迷宮事件",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文学者にはむしろ、人なつっこい淋しがりやが多いものだ。",
              "citation": {
                "source": "傍人の言",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "死顔はキリストに似ていて、あの独特なへんに人なつっこい若々しい笑みは底に潜んでいた。",
              "citation": {
                "source": "十一谷義三郎を語る",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "色は白紅淡紅でさし渡しは五分位、白い花のまん中に一寸と茶色の紋があるのなんかはものずきな御嬢さんが見つけたらキッとつまないではおかないほど人なつっこい花である。",
              "citation": {
                "source": "つぼみ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
