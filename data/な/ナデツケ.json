    "definitions": [
      {
        "index": 1,
        "gloss": "hair that is smoothed down",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その下の真物の髪毛は青い程黒く波打ったまま撫で付けにしてあったが、同時に鬘下で釣り上げられていた眉、眼、頬はふっくりと丸くなって、無邪気な、可愛らしい横顔に変ってしまった。",
              "citation": {
                "source": "暗黒公使",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "吾に帰って頭の毛を叮嚀に撫で付け初めた。",
              "citation": {
                "source": "二重心臓",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "……同じ寝台の足下の方に、さも窮屈らしく恭々しげな恰好をして坐っていたのは、第八、百人隊長のブブリウス・アクヴールスという喘息持で赭ら顔の肥満漢で、天辺のつるりと剥げた頭には疎らな胡麻塩の毛を後ろの方から両鬢へかけて撫で付けている。",
              "citation": {
                "source": "大衆文芸作法",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "男の見て居る前で、僅かに髪を撫で付けて、旅の手荷物もそこ／＼に取収めた。",
              "citation": {
                "source": "破戒",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭を撫で付けてあげようから。",
              "citation": {
                "source": "おせん",
                "author": "邦枝完二",
                "note": "青空文庫"
              }
            },
            {
              "text": "さてこれをどうしたら読むことが出来るかと散々考えられた末、鉛筆の芯を細かい粉に削ってその葉書の上に散らし、それを指先でそっと撫で付けてみたら、字がありありと出てきたという話なのである。",
              "citation": {
                "source": "先生を囲る話",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "出掛けるとなつて庭へ下りると、髪があんまりひどいから一寸撫で付ける迄待つて頂戴と云ふ。",
              "citation": {
                "source": "『団栗』のことなど",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "法印か何ぞのように常に後へ撫で付けられていた。",
              "citation": {
                "source": "道草",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "無精髯を手剃り乍ら剃り落して、伸び過ぎた毛は、何うやら彼うやらチックの力で後ろへ撫で付けて見ると、これも芸術家によくある型になって、なかなか悪くありません。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「頭は蜻蛉見てえに光って、身体が嫌に生っ白くなったじゃ無えか」「えッ……」　そう言われて見ると成程、私の手足は陽に焦けては居るが小薩張りと洗い浄められて、顔はわかりませんが、頭の毛も何うやら油か何んかで後ろへ撫で付けてあります。",
              "citation": {
                "source": "新奇談クラブ",
                "author": "第七夜　歓楽の夢魔",
                "note": "青空文庫"
              }
            },
            {
              "text": "一應自分の長屋に歸つて衣服を改め、髮を撫で付け、さて出かけようとして次の間の机の上に置いた文箱を取り上げて驚きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "血腥い事件の豫感に、平次は一寸憂欝になりましたが、直ぐ氣を變へて、ぞんざいに顏を洗ふと、鬢を撫で付け乍ら家へ入つて行きました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "一応自分の長屋に帰って衣服を改め、髪を撫で付け、さて出かけようとして次の間の机の上に置いた文箱を取り上げて驚きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "名馬罪あり",
                "note": "青空文庫"
              }
            },
            {
              "text": "血腥い事件の予感に、平次はちょっと憂鬱になりましたが、すぐ気を変えて、ぞんざいに顔を洗うと、鬢を撫で付けながら家へ入って行きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "許嫁の死",
                "note": "青空文庫"
              }
            },
            {
              "text": "その間に、化粧室に舞込んだ勇美子は、後から、前から、横から、言いようもなく美しい詩子を眺めながら、コッティの白粉を取ってやったり、クリームを取ってやったり、そっと髪を撫で付けてやったり、ハチ切れそうな好奇心で、お嫁に来る前からよく知って居る詩子のお化粧の世話を焼いて居りました。",
              "citation": {
                "source": "身代りの花嫁",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "又婿の声がしたので、パシエンカは「すぐ往くから、お待よ」と返事をして、髪を撫で付けて出て行つた。",
              "citation": {
                "source": "パアテル・セルギウス",
                "author": "VATER SERGIUS",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたくしは親の家にゐて、母が髪を撫で付けてくれてゐます。",
              "citation": {
                "source": "樺太脱獄記",
                "author": "コロレンコ　Vladimir Galaktionovick Korolenko",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十一、二か、三ぐらい、さっきの娘の姉なのでしょう、妹とよく似た面差しはしていますが、これは妹と違って細面の、艶やかな瞳……愛らしい口許……隆い鼻……やっぱりふさふさとした金髪を、耳の後方へ撫で付けて、丈も妹よりは、心持ち高いように思われます。",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "出かけるとなって庭へおりると、髪があんまりひどいからちょっとなでつけるまで待ってちょうだいと言う。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとなでつけるのかと思ったら自分で新たに巻き直すと見える。",
              "citation": {
                "source": "どんぐり",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣服の左前なくらいはいいとしても、また髪の毛のなでつけ方や黒子の位置が逆になっているくらいはどうでもなるとしても、もっと微細な、しかし重要な目の非対称や鼻の曲がりやそれを一々左右｜顛倒して考えるという事は非常に困難な事である。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その大きな鼻の穴からパッパッとせわしく煙草のけむりを吹き出しながら、そのとき軽部は、このことは誰にも黙ってるんだよ、と髪の毛をなでつけているお君にくど／＼と言いきかせた。",
              "citation": {
                "source": "雨",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "春吉君は、古手屋の遠助のあほうが、そんなろくでもないことを、手がら顔して語るのを聞きながら、それらのすべてのことを、あかぬけのした、頭をテカテカになでつけられた藤井先生が、どんなにけいべつされるかと思って、じつにやりきれなかったのである。",
              "citation": {
                "source": "屁",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」頭をテカテカになでつけた重松は、どっかにずるそうなところのある四十近い小男だった。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "こめかみに貼った頭痛膏にかかるおくれ毛をなでつけながら、自分のほうを向いたが、軽くうなずいて片頬で笑った。",
              "citation": {
                "source": "竜舌蘭",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "始終わたくしに目を向け――下品で膨れ面、赤髭の若い方で、額の両側に髪をなでつけて。",
              "citation": {
                "source": "自転車乗りの影",
                "author": "THE ADVENTURE OF THE SOLITARY CYCLIST",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして乱れかかる額ぎわの髪を、振り仰いで後ろになでつけたり、両方の鬢を器用にかき上げたりして、良工が細工物でもするように楽しみながら元気よく朝化粧を終えた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "葉子はそわそわと裾前をかき合わせて、肩越しに鏡を見やりながら涙をふいて眉をなでつけた。",
              "citation": {
                "source": "或る女",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お力はあの子息さんを覚えているだろう」　髪をなでつける人、なでつけて貰う人の間には、すべてが思い出の種でないものはなかった。",
              "citation": {
                "source": "食堂",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "捨吉の見ている前で、髪をなでつけたり自分で織ったよそいきの羽織に着更えたりして、いそいそと仕度した。",
              "citation": {
                "source": "桜の実の熟する時",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
