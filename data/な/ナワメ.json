[
  {
    "uuid": "6e03349d-1701-536a-9181-37e6c7aa11e6",
    "entry": "縄目",
    "reading": {
      "primary": "なわめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
