        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "軽井沢附近には、如何にも軽快な、そしてどこか冥想的な、如何にも散歩らしい気分のする道がすくなくない――尤もあの辺では、その目的のために、わざわざ並木を植ゑた遊歩地のようなものができてゐる――伊香保には、ほんとの散歩道といふものはない。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "馬車の往来が織るような街の両側の人道の並木の下には手を組んだ男女の群が楽しそうに通っている。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "欅の並木をつつむ真昼の寒い霧。",
              "citation": {
                "source": "病院風景",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "並木の影涼しきところ木の根に腰かけて憩えば晴嵐梢を鳴らして衣に入る。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道の並木の松さすがに昔の名残を止むれども道脇の茶店いたずらにあれて鳥毛挟箱の行列見るに由なく、僅かに馬士歌の哀れを止むるのみなるも改まる御代に余命つなぎ得し白髪の媼が囲炉裏のそばに水洟すゝりながら孫｜玄孫への語り草なるべし。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "街道に沿うた松並木の影の中をこの椎茸がニョキ／＼と飛んで行くのがドンナに可笑しかったろう。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "逝く夏の歌並木の梢が深く息を吸つて、空は高く高く、それを見てゐた。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "一歩境内に踏みいると、乱雑なる町家から仕切られて、吉野山の杉林を見るような、幽邃なる杉並木が、富士の女神にさす背光を、支持する大柱であるかの如く、大鳥居まで直線の路をはさんで、森厳に行列している。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "大杉公園といふのはどんな處かと思つたら、とある神社の杉並木のことであつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し杉並木は美しい。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園の中よりは反對の並木道を行つた方が私の好きな畫題は多いらしく思はれた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "餘りゆる／＼して居ては、折角此處迄來たのに一枚も描かずに歸る事になりさうなので、行き當り次第に並木道を左へ切れて行つて、そこの甘藷畑の中の小高い處に兎も角も腰をかけて繪具箱をあけた。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "町並のシャンゼリゼーが並木のシャンゼリゼーへ一息つくところに道の落合いがある。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　並木の有料椅子のランデヴウ。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蝶が天地大に姿をフォーカスし去ると、そこに二階の窓々で飾人形を掃除している並木越しの商店街を見出した。",
              "citation": {
                "source": "巴里のキャフェ",
                "author": "――朝と昼――",
                "note": "青空文庫"
              }
            },
            {
              "text": "それであたしはこの辺を散歩すると云って寮を出るし、男はまた鯉釣りに化けて、この土手下の合歓の並木の陰に船を繋って、そこでいまいうランデブウをしたものさね」　夕方になって合歓の花がつぼみかかり、船大工の槌の音がいつの間にか消えると、青白い河｜靄がうっすり漂う。",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "如何にも街道という感じのする古木の松並木が続く。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここから東の方だけ言っても　程ヶ谷と戸塚の間の焼餅坂に権太坂　箱根旧街道　鈴川、松並木の左富士　この宇津の谷　こういう場所は殊にしみじみさせる。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "土地より高く河が流れているらしく、やや高い堤の上に点を打ったように枝葉を刈り込まれた松並木が見えるだけであった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔の東海道の杉並木の名残が、蛇行する自動車道路を直線的に切っているのが面白い。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "焦心霜ふりてすこしつめたき朝を、手に雲雀料理をささげつつ歩みゆく少女あり、そのとき並木にもたれ、白粉もてぬられたる女のほそき指と指との隙間をよくよく窺ひ、このうまき雲雀料理をば盗み喰べんと欲して、しきりにも焦心し、あるひとのごときはあまりに焦心し、まつたく合掌せるにおよべり。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私どもは利根川の堤を松並木のおしまひに建つた旅館まで俥にのつた。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこを出て、夢中で、これまで見たことのない菩提樹の並木の間を、町の方へ走った。",
              "citation": {
                "source": "白",
                "author": "リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこから、だらだら坂になっているアカシア並木の赭土の途を揺られながら、ペル・※ュウ村の木立の上に風車の廻っているロダンさんの粗末なお宅につくと、薔薇園の木戸口に肉体の彫刻的に締った、銀髪のロダン夫人が立って、妾を迎えてくださいました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "仮装舞踊会のように私は日覆いして夜の明けるのを待ったのだが、タンゴの太い曲線が寝床の夢を誘うように、彼女が夢のなかで、宵闇せまればレジエント街の並木道を満艦飾の女が馬車でカールトン・バアで卸して頂戴ネと馭者に云う　と、低唱しながら屡々、ちえ！",
              "citation": {
                "source": "孟買挿話",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "４　一刻後、太田ミサコはタクシーのクッションにもたれて官省広場の並木道を疾走していた。",
              "citation": {
                "source": "女百貨店",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "通過記録計がまた一転廻すると、太田ミサ子が、情夫のアメリカ人を連れて、中之島の方面から並木道をつたってあらわれた。",
              "citation": {
                "source": "大阪万華鏡",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そよとの風もない部屋の蒸暑さ、窓の向うに見える緑の深い銀杏の並木さへ葉をうなだれてゐたが、私の感覺はただ顯微鏡の小さな孔から映つてくる鬼蘭の、青い格子縞のやうな纖維に集中されてゐた。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかり葉をふるひ落した裸のポプラ並木、からからに凍りついた歩道、明りを消し、二重窓を降して冷たい沈默を包んでゐる煉瓦や石造りの暗い家並、毎日毎夜の不安な空氣に脅かされてゐる町は、朝から曇つたままに暮れ落ちた暗澹たる夜空の下に、わけても眞夜中過ぎのその夜は、人通さへ稀に無氣味な程に鎭まり返つてゐた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "其處から私の泊つてゐるＭホテルまではまだ七八町の道程だつたが、送らうといふ水島君の詞を強ひて斷つて、薄暗い並木の蔭を私は一人俯向き勝ちに歩き始めた。",
              "citation": {
                "source": "ハルピンの一夜",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
