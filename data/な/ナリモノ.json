      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "farm products",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "最も力の籠っているのは、蔓と瓜の実とをつなぐ臍の柄で、生り物全体の重みを支えなければならぬだけに、秀れた茶壺の捻り返しを見るような、力と鮮やかさとを味わされることが多い。",
              "citation": {
                "source": "艸木虫魚",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "天子様が、すめらみこととしての為事は、此国の田の生り物を、お作りになる事であつた。",
              "citation": {
                "source": "大嘗祭の本義",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三千坪程の中に六十五戸の家敷が構へてあるので、生り物の木を植ゑとく家はいくらもない。",
              "citation": {
                "source": "五葉の松",
                "author": "横瀬夜雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会人のまちまちな嗜好を反映するように、これ等の畑地のなりものや野菜は一定していなかった。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "畑のなりもので見えなかったが、近寄ると新しく掘った用水があって、欄干のない橋がかかっていた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "渡は×にされると、いきなりものも云はないで、後から（以下十行削除）手と足を硬直さして、空へのばした。",
              "citation": {
                "source": "一九二八年三月十五日",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "余の国などでは、なりものともいうておる。",
              "citation": {
                "source": "くだもの",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "はなと言ふのは、なりものゝ前兆を示す、一種のさきぶれの事です。",
              "citation": {
                "source": "山の霜月舞",
                "author": "――花祭り解説――",
                "note": "青空文庫"
              }
            },
            {
              "text": "盂蘭盆や地蔵祭りに畑のなりもので様々な作りものをするのを見ると、神にも精霊にも招き寄せる方便は、一つであつたといふ事が訣る。",
              "citation": {
                "source": "盆踊りと祭屋台と",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "譬へば、中世以来の「柳の下の祝言」など言ふ行事は、今日も諸地方に「なりものおどし」の呪文として残つてゐる。",
              "citation": {
                "source": "日本文学の発生",
                "author": "折口信夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "○ますらをの鞆の音すなりもののふの大臣楯立つらしも　〔巻一・七六〕　元明天皇　和銅元年、元明天皇御製歌である。",
              "citation": {
                "source": "万葉秀歌",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "◯艦載機来襲以来、待避壕はかなりものものしくなった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "大空艇は、かなりものすごい落下速度を出しているが、速度の変りかたがうまくいっているので、からだには、あまりこたえない。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時分、万字楼の前で、十余人の茶袋がみんな刀を抜いて振り廻し、多数の弥次馬がそれを遠巻きにして、一人残さずやっつけろと叫んでいる光景は、かなりものすさまじいものでありました。",
              "citation": {
                "source": "大菩薩峠",
                "author": "黒業白業の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "スティンズ卿が中から姿を現わして、大きなスーツケースを二つ（かなりものうげに）さげながら、戸口に近づいた。",
              "citation": {
                "source": "ピンの先き",
                "author": "THE POINT OF A PIN",
                "note": "青空文庫"
              }
            },
            {
              "text": "「…………」「…………」親鸞は、それなりものをいわないし、弁円も黙ってしまった。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
