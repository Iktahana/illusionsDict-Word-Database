    "definitions": [
      {
        "index": 1,
        "gloss": "Christian churches built in Japan in the second half of the 16th century",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "）（予はその月の十八日に、手こずつてゐた南蛮寺門前がやつと出来上つた。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "予は氏の口から南蛮寺に対する言葉を聞いて大に感激した。",
              "citation": {
                "source": "パンの会の回想",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後景は京都四条坊なる南蛮寺の高き石垣。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南蛮寺の鐘鳴りはじむ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お主達も早う去なないと、見よ、今に南蛮寺の門に食はれるぞよ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊枝　その揚句には親達も、男子、女子も見さかい無う切り付くるのぢや……　　　　＊　　　　　＊　　　　　＊　　　　　＊二人の女の会話のうちに、常丸、母の傍より離れて南蛮寺の門に近づき、つくづくと内を覗う。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ここが南蛮寺の門ぢやとは、つひぞ気付かいでおぢやつたが……さてはこの門めが、中に引込んだと見ゆるよ……。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あの南蛮寺が拉つたのぢや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "千代　南蛮寺がわれら常丸を拉つておぢやつた。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南蛮寺が人を拉らふわけはしやほにおぢやらぬ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……この間に、南蛮寺の門扉内より音もなく自から閉まる。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊枝　あの、南蛮寺が人を拉うておぢやつたのぢや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南蛮寺が人を拉つておぢやつたと言やるか。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "提灯を持ちたる男　（私かに）此処は南蛮寺ぢや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うかれ男　南蛮寺なりや恐いことはおりない。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "うかれ男　南蛮寺の台所が善う見えるわい。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "などと、はは、南蛮寺の玄関で、誰やらがよい歌唄うておぢやつたわ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……（忽ち南蛮寺の門に気付きて）あれ、此処は邪法の窟宅、南蛮寺の門前なるよな。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）忽ち南蛮寺の前にてけたたましき響す。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "南蛮寺の門前ぢやてや。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長順　（舞踊の間に黒き法衣を脱ぎ華美なる姿となる）あれ、南蛮寺の中に奇しき響きがしておぢやるわ。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）第一の所化　（一歩前に踏み出し乍ら）やれ、口惜や、南蛮寺の妖術めに化されておぢやつたとは。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "長順　（蹌踉きながら立ち上りて、南蛮寺の門扉に至り倚る。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなはち心得たる体にて彼の唐人に誘はれ行くに、港の入口、山腹の中途に聳え立つ南蛮寺の墓地に近く、薬草の花畑を繞らしたる一軒の番小舎あり。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼ざめ来れば、身は南蛮寺下の花畑の中に在り。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのまゝ南蛮寺を後にして、諏訪神社の石の鳥居にも背を向け、足に任せて早岐の方を志す。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日正午ともなれば人一人斬らでは止み難く、斬れば早や香煙に酔ひたる心地して、南蛮寺下の花畑に走り行く。",
              "citation": {
                "source": "白くれない",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
