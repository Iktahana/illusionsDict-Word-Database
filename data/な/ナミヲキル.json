    "definitions": [
      {
        "index": 1,
        "gloss": "to cut one's way through the waves",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
