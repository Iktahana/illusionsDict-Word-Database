        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "（その芽生こそ凡ての幸福の苗であるのに。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "）あの偉大なるトルストイを始めとして、世の多くの貴族と生れながらのエゴイストとが、悩み苦しみて求めるものは、実にこの「生えざる」苗を求めんとして嘆き訴ふる悲しみの声に外ならない。",
              "citation": {
                "source": "愛の詩集",
                "author": "愛の詩集の終りに",
                "note": "青空文庫"
              }
            },
            {
              "text": "高田早苗に似てゐた。",
              "citation": {
                "source": "校長三代",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして詩の芽生えが、子供の心意する夢の世界と、その幻想的なフエアリイランドに苗づいてることは言ふ迄もない。",
              "citation": {
                "source": "童話と教育について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大正四、五年頃、今は故人となった佐野静雄博士から伊豆伊東の別荘に試植するからと云って土佐の楊梅の苗を取寄せることを依頼された。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷里の父に頼んで良種を選定し、数本の苗を東京へ送ってもらった。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてこの苗の生長を楽しみにしておられた博士は不幸にして夭折されたのである。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後さらに数年を経過した現在のこの楊梅の苗の運命がどうなっているか。",
              "citation": {
                "source": "郷土的味覚",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは藤枝の宿で、熊谷蓮生坊が念仏を抵当に入れたというその相手の長者の邸跡が今は水田になっていて、早苗がやさしく風に吹かれているのを見に寄ったり、島田では作楽井の教えて呉れた川越しの蓮台を蔵している家を尋ねて、それを写生したりして、大井川の堤に出た。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗字は違っているがね」　入って来たのは洋服の服装をきちんとした壮年の紳士であった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "造林のときは苗や何かを一杯つけた馬がぞろぞろここを行くんだぞ。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "野原は今は練兵場や粟の畑や苗圃などになってそれでも騎兵の馬が光ったり、白いシャツの人が働いたり、汽車で通ってもなかなか奇麗ですけれども、前はまだまだ立派でした。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい先日バラの苗やカンナの球根を注文するために目録を調べたときに所在をたしかめておいた某農園がここだと分かった。",
              "citation": {
                "source": "箱根熱海バス紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "二三日前に百花園からつるの手をつけてある目籠に長命菊つくし石竹の苗其他数種の青草を植込にしたやつを買って来て置いたのを持って往ったのであるきょうは暖炉の掃除をやったとの事で先生は八畳の座敷に石油暖炉をたき東向になってねていられた。",
              "citation": {
                "source": "根岸庵訪問の記",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗苗は青空に光り、子供は土地を掘る。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "生えざる苗をもとめむとして、あかるき鉢の底より、われは白き指をさしぬけり。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "田舎を恐るわたしは田舎をおそれる、田舎の人気のない水田の中にふるへて、ほそながくのびる苗の列をおそれる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　昨年、私は一尺五寸ほどの桃の苗を植えた。",
              "citation": {
                "source": "短命長命",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "つい二三年前までは毎年初夏になるとあの感傷的な苗売りの声を聞いたような気がする。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「早苗とる頃」で想い出すのは子供の頃に見た郷里の氏神の神田の田植の光景である。",
              "citation": {
                "source": "五月の唯物観",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔あくたうかべる朝の水〕宮沢賢治あくたうかべる朝の水ひらととびかふつばくらめ苗のはこびの遅ければ熊ははぎしり雲を見る苗つけ馬を引ききたり露のすぎなの畔に立ち権は朱塗の盃をましろきそらにあふぐなり",
              "citation": {
                "source": "〔あくたうかべる朝の水〕",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習は苗代掘りだった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "実習は今日も苗代掘りだった。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……先生はああ倒れたのか、苗が弱くはなかったかな、あんまり力を落してはいけないよ、ぐらいのことを云って笑うだけのもんだ。",
              "citation": {
                "source": "或る農学生の日誌",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "Ｔ「あば敬にも村上ッて歴とした苗字があるんですね」　其処へ敬四郎が現れた。",
              "citation": {
                "source": "右門捕物帖　三十番手柄　帯解け仏法",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼も家の出入には、苗床が囲ってあったりする大家の前庭を近道した。",
              "citation": {
                "source": "雪後",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "苗字のないという子がいるので聞いてみると木樵の子だからと言って村の人は当然な顔をしている。",
              "citation": {
                "source": "城のある町にて",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヘルンの机の座右には、常に日本の煙草盆と煙管がそなえてあった。",
              "citation": {
                "source": "小泉八雲の家庭生活",
                "author": "室生犀星と佐藤春夫の二詩友を偲びつつ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前たちね、今日はここへ非常なえらいお方が入らっしゃるんだから此処に居てはいけないよ。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "時々西洋へ出かけて目新しい機械や材料を仕入れて来ては田舎学者の前でしたり顔にひけらかすようなえらい学者でノーベル賞をもらった人はまだ聞かないようである。",
              "citation": {
                "source": "猫の穴掘り",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
