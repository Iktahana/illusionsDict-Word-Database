    "definitions": [
      {
        "index": 1,
        "gloss": "strait with a roaring tidal ebb and flow",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
