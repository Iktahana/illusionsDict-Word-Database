          "literary": [
            {
              "text": "そこへ新手の群衆が殺到して殴りかかる。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア、おいで」「この野郎」　大入道が拳をふるって殴りかかる。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅二郎は軽く躱して、「お危のうござる」「うぬ、手向いするか」　酔っているから無法だ、拳を挙げて殴りかかる、浅二郎上体を捻ってその拳を避けると、肱のところを掴んで逆に捻上げた。",
              "citation": {
                "source": "入婿十万両",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "男は身動きをした、彼がこぶなら殴りかかるだろうと思ったが、ちょっと身動きをしただけで、男は立とうともしなかった。",
              "citation": {
                "source": "さぶ",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジョージ卿は感情を表わさなかったが、全身言いようのない怒りに震え、コプリは分からなかったが、もう少しで殴りかかる寸前だった。",
              "citation": {
                "source": "本命馬",
                "author": "HARD PRESSED",
                "note": "青空文庫"
              }
            },
            {
              "text": "（びっくりして、なぐりかかるのを忘れて、それを見ていたが、やがて振返って戸口を見る。",
              "citation": {
                "source": "冒した者",
                "author": "――Ｓの霊に捧げる――",
                "note": "青空文庫"
              }
            }
          ]
        }
