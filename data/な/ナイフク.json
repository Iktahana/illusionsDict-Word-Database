[
  {
    "uuid": "bdc74f20-a1f1-51b2-abd3-172e530a77c9",
    "entry": "内服",
    "reading": {
      "primary": "ないふく",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞",
