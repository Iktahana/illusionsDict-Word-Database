[
  {
    "uuid": "e5c92549-bc6b-5212-a78e-519b364444cb",
    "entry": "何時",
    "reading": {
      "primary": "なんじ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
