    "definitions": [
      {
        "index": 1,
        "gloss": "the present (esp. as a privileged moment in eternity)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
