    "definitions": [
      {
        "index": 1,
        "gloss": "the seven spring flowers",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
