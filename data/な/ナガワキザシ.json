[
  {
    "uuid": "289f5378-229a-5c44-9733-90e5d53b5f56",
    "entry": "長脇差",
    "reading": {
      "primary": "ながわきざし",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
