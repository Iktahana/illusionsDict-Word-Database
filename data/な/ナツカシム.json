[
  {
    "uuid": "2f332f78-407c-5a21-99bd-7ed808887072",
    "entry": "懐かしむ",
    "reading": {
      "primary": "なつかしむ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-マ行",
        "動詞-他動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to yearn for (someone, something)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "その名工の建築を懐かしむ想いは、再度の富士旅行に、吉田の宿に足をとめた時に、更に新しくさせられた。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある時はビーヤホールのかたかげにその慎しい音色を懐かしむこともある。",
              "citation": {
                "source": "桐の花とカステラ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば日本の笛を取る心もちにもなほ鮮かな Stranger の驚異と感触を貴み、目白僧園の鐘の音にアベマリヤの晩鐘を忍ぶ以太利亜旅人の春愁を悟り、異国の菊の香に新らしい流離の涙をそそぐピエルロチが秋の心をまたとなく懐かしむ。",
              "citation": {
                "source": "桐の花",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "思慮のある男には疑懼を懐かしむる程の障礙物が前途に横わっていても、女はそれを屑ともしない。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "保元の乱は、藤原氏に於ける父子兄弟間の権力争ひが、皇室をまで、その渦中に引き入れ奉つた戦乱であるが、政権の争奪が、武力に依つて左右さるべきものであることを、如実に示したことに依つて、今まで他の勢力の爪牙を以て甘んじてゐた武士をして、遂に政権に対する野心を懐かしむるに至つたのである。",
              "citation": {
                "source": "二千六百年史抄",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕の徳、はたしてこれを懐かしむるに足るかどうか。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」としみじみ言って、女はそぞろに過ぎ去った自分の春を懐かしむよう。",
              "citation": {
                "source": "深川女房",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、今日の私に至るともかく愚か者は愚か者なりの精一杯の悪戦苦闘がそこに在ることを、私は切なく、懐かしむ。",
              "citation": {
                "source": "再版に際して〔『吹雪物語』〕",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "鶴見はそれをあたかも幼馴染が齎らして来たもののように懐かしむのである。",
              "citation": {
                "source": "夢は呼び交す",
                "author": "――黙子覚書――",
                "note": "青空文庫"
              }
            },
            {
              "text": "その呼び声を聞く時は西班牙を懐かしむ心などは跡方もなく消えてしまう！",
              "citation": {
                "source": "沙漠の古都",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「居残り」は私には狂馬楽・盲小せん・先代正蔵の時代を懐かしむ意味で何ともいえないものばかりでなく、この人のは先年もなかなか「品川」が描けていてよかった。",
              "citation": {
                "source": "随筆　寄席囃子",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく昔を懐かしむにまかせた。",
              "citation": {
                "source": "諜報部秘話",
                "author": "THE ROMANCE OF THE SECRET SERVICE FUND",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかもそのスパセニアが、私の姿を見ながら、確かに私と真正面に顔を合わせながら、懐かしむどころか！",
              "citation": {
                "source": "墓が呼んでいる",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "年を老るとつい目前の事物には反撥感が起って、事々に昔を懐かしむものであろうか。",
              "citation": {
                "source": "グリュックスブルグ王室異聞",
                "author": "橘外男",
                "note": "青空文庫"
              }
            },
            {
              "text": "元の吉水にお住いか、それともほかに」親鸞の懐かしむ様子に、「ちょっとお待ち下さい」と、明智房は、暗い顔して、うつ向いた。",
              "citation": {
                "source": "親鸞",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "唯能く統一した一首の声調に、物に親しみなつかしむ気持が現われて居るのである。",
              "citation": {
                "source": "歌の潤い",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべて敵に遭って却ってそれをなつかしむ、これがおれのこの頃の病気だと私はひとりでつぶやいた。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとの土でさえ、舗装の人造石やアスファルトの下に埋もれてしまっているのに、何をなつかしむともなく、尾張町のあたりをさまよっては、昔の夢のありかを捜すような思いがするのである。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "山の井に棹さす百合の雫かな　やがて下山いたし候へば、麓の流に棲むものの、露も水も珍しからぬを、花の雫をなつかしむや、沢蟹さら／＼と芦を分けて、三つ四つならず道ばたに出迎へ候。",
              "citation": {
                "source": "逗子より",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "をかしなことは自分が母親をなつかしむとき、屹度、三人の女の面影が胸に浮び、若い生母の想像の俤から老いた最後の養母まで、ずらりと面影を並べて、自分の思ひ出を独占しようと競ひ合ふ。",
              "citation": {
                "source": "上田秋成の晩年",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」といいながら、なつかしむようにマタンじいさんは、子どもの手を見つめていました。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、なつかしむようにいって、マタンの亜麻色のかみが、ぼうしのふちからのぞいているのをちらっと見て、「あなたのおかあさんは、亜麻色のかみをしていましょう。",
              "citation": {
                "source": "名なし指物語",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おじいさんはえらかったんだねえ」　そしてなつかしむように、かたわらの古いランプを見た。",
              "citation": {
                "source": "おじいさんのランプ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は私の含羞多きむかしの姿をなつかしむ。",
              "citation": {
                "source": "虚構の春",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "父のそのときの軽い苦笑には、相似るものをなつかしむと同時に嫌厭する遣る瀬ない気持が陰になって唇を掠めたのを覚えております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つは警戒の気持で、一つは何となく人をなつかしむ気持であります。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "陽子に挑んだのは、陽子はもう失われてしまったと信じ込んでいた京吉が、執拗に迫る嫉妬からのがれるためにきりひらく唯一の血路であり、また、失われたものをなつかしむ気持の逆説的なあらわれであったが、しかし、一つには、陽子は春隆に許したのだから、自分にも許してもいいだろうという現金な気持からでもあった。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "この時、病院の青白き裏口の戸に佇める看護婦は携へし鳥籠の青き小鳥の鳴くこゑをさびしみながら、角吹ける乗合馬車の遠き遠き黄のかがやきをなつかしむ。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "○　さらに私達のなつかしむのは、あの古典的な樹皮です。",
              "citation": {
                "source": "季節の植物帳",
                "author": "佐左木俊郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ホームズの声はなつかしむよう。",
              "citation": {
                "source": "サセックスの吸血鬼",
                "author": "THE ADVENTURE OF THE SUSSEX VAMPIRE",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
