        "index": 1,
        "gloss": "Ministry of Central Affairs (under the ritsuryō system)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
