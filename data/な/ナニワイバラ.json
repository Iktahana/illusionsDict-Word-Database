          "literary": [
            {
              "text": "夏は山百合、難波薔薇香にほのめきぬ　　　　ああひとつば、匂ひ香なきにうらびれて、一日は洞に　　　　ああひとつば、歎けど、姫は空耳に片笑みてのみ、　　　　ああひとつば。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "伏目にたたすあえかさに、ひと日は、白き難波薔薇夕日がくれに息づきし津の國の野を思ひいで。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波うばらいま月しろの上じらみ、ほのかに動く宵の間を、人待ちなれし眞籬根に、難波薔薇ぞ香ににほふ。",
              "citation": {
                "source": "泣菫詩抄",
                "author": "薄田泣菫",
                "note": "青空文庫"
              }
            },
            {
              "text": "三夏は山百合、難波薔薇香にほのめきぬ、　　　ああひとつば、匂ひ香なきにうらびれて、一日は洞に、　　　ああひとつば、嘆けど、姫は空耳に片笑みてのみ、　　　ああひとつば。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "二伏目にたたすあえかさに、ひと日は、白き難波薔薇、夕日がくれに息づきし津の國の野を思ひいで。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            },
            {
              "text": "難波うばら一いま月しろの上じらみ、ほのかに動ぐ宵の間を、人待ちなれし眞籬根に、難波薔薇ぞ香ににほふ。",
              "citation": {
                "source": "白羊宮",
                "author": "薄田淳介",
                "note": "青空文庫"
              }
            }
          ]
        }
