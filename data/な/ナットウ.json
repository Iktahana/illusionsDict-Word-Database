    "definitions": [
      {
        "index": 1,
        "gloss": "natto (fermented soybeans)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
