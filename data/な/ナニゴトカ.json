        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "誰しも陰気よりは陽気の方が凡そ好きなのに相違はないのに、「陽気な文学を」といふのが一つの文学上の提案となるためには少しくましな何事かであらねばならぬ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事か、ある説明のできない不安な焦燥と、恐怖に似た眞青の感情とが、火のやうに自分の全神經を驅けまはつた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "始めは何事か判らなかった店の者は余計なことをすると思って、少年の所作を途中で妨げたり、店先に立つ段になると叱って追い放ったりした。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "生命とか精神とかいうものを除いたいわゆる物質を取扱って何事かしようという時にはすぐに物理学的の問題に逢着する。",
              "citation": {
                "source": "物理学の応用について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "宇宙間無限の物象の影響を受けている身辺の現象について如何にして有限な言葉をもって何事かを云い表わす事が出来るであろうか。",
              "citation": {
                "source": "方則について",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かせ給ふは何ならん、何事かの御打合せを御朋友の許へか、さらずば御母上に御機嫌うかゞひの御状か、さらずば御胸にうかぶ妄想のすて所、詩か歌か。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "入口を這入る時から、下の方で何だか恐ろしく大きな声で咆哮している人がある事に気が付いていたが、席が定まってからよく見ると、それは正面の高い壇の中壇のような処に立って何事か演説している人の声であった。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに、始めに出た極度の大声を出す人が壇上に立ってまた何事か述べはじめた。",
              "citation": {
                "source": "議会の印象",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから少し方面はちがうがあまり評判のよくなかった芋銭の「石人」などからも何事かを教えられた。",
              "citation": {
                "source": "帝展を見ざるの記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事か、どこかの或る一つの點で、僕は肝心の芥川君に觸れてなかつた。",
              "citation": {
                "source": "芥川龍之介の追憶",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "必ず何事かを貫通せねば止まないだらう。",
              "citation": {
                "source": "室生犀星君の飛躍",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "家人が出て何事か言ひ爭つてる。",
              "citation": {
                "source": "酒に就いて",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かわからない、或る漠然とした一つの予感が、青ざめた恐怖の色で、忙がしく私の心の中を馳け廻った。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "確かに今、何事かの非常が起る！",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かわからなかった。",
              "citation": {
                "source": "猫町",
                "author": "散文詩風な小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "巡視の役人通り掛かって、　何事かと訊く。",
              "citation": {
                "source": "恋と十手と巾着切",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "嘉助老人の眼光の鋭さは何事か決心する所あるらし。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "お光が……」　半次何事ならんと児分と共に次室へ、　大吉、眼の玉一つ動かさず、まだ何事か考えて居る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと左衛門心配そうである。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さいオスワルドは熱心に何事か聞かうと思つて、フオオクに突き刺した肉を口に入れるのを忘れてゐた。",
              "citation": {
                "source": "祭日",
                "author": "DAS FAMILIENFEST",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにゆうべ夢に見たから、何事かありゃしないかというのですよ。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし幾ら手本無しに生活すると申ましても、そういう人でございましても、どうせ生々しいのでございましょうから、何事かに出合まして、五つや六つの調子を覚えましても、それから先は分りませんから、その五つか六つの調子をあらゆるものに当て嵌める事になってしまうのでございましょう。",
              "citation": {
                "source": "家常茶飯",
                "author": "ライネル・マリア・リルケ　Rainer Maria Rilke",
                "note": "青空文庫"
              }
            },
            {
              "text": "前髮を切り下て可愛く之も人形のやうに順しくして居る廣庭では六十｜以上の而も何れも達者らしい婆さんが三｜人立て居て其一人の赤兒を脊負て腰を曲げ居るのが何事か婆さん聲を張上げて喋白つて居ると、他の二人の婆樣は合槌を打つて居る。",
              "citation": {
                "source": "湯ヶ原ゆき",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "来年になったらこの古い巣に、もしや何事か起りはしないかというような予感がある。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてしゃ嗄れた、胸につまったような声で、何事かしきりに云っているのであった。",
              "citation": {
                "source": "小さな出来事",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何事かと思って出てみると、国際電報によって昨年度と今年度のノーベル賞金の受賞者の名前の報知が届いた、その一人はアインシュタインで、もう一人はコーペンハーゲンのニールス・ボーアという人だそうだが、このボーアという人はいったいどんな人でどういう仕事をした人かというのである。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おれも考えてみるから、おめえも考えてくれ」　云いかけて、半七はふと何事かを思い出したらしく、持っている団扇を下に置いた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "鬼娘",
                "note": "青空文庫"
              }
            },
            {
              "text": "四　行者は半七の顔をひと目みて、さらに何事かを問いたそうに式部を見かえると、半七は声をかけた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "女行者",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪に接している白い小さい唇が、彼等に何事かを叫びかけそうだった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那、支那、何事か行われているが、収拾しきれない支那！",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
