        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "機会宮沢賢治恋のはじめのおとなひはかの青春に来りけりおなじき第二神来は蒼き上着にありにけりその第三は諸人の栄誉のなかに来りけりいまおゝその四愛憐は何たるぼろの中に来しぞも",
              "citation": {
                "source": "機会",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる意外、何たる青天の霹靂だらう。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる拙いこの狼〔狽〕！",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる非礼のその直視！",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "新らしい袴を出し、新らしい足袋と白扇を進めて、それが威容の料とはならず、罪問ふ敵への礼儀とあらば、何たる切ないことであらう。",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）（おお、老いたる龍の何たる悦びであらう。",
              "citation": {
                "source": "龍と詩人",
                "author": "宮澤賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "メーヌ・ドゥ・ビランは、生来の盲人に色彩の何たるかを説明すべき方法がないと同様に、生来の不随者として自発的動作をしたことのない者に努力の何たるかを言語をもって悟らしむる方法はないといっている｛１｝。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば、日本の文化に対して無知な或る外国人に我々が「いき」の存在の何たるかを説明する場合に、我々は「いき」の概念的分析によって、彼を一定の位置に置く。",
              "citation": {
                "source": "「いき」の構造",
                "author": "九鬼周造",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる不憫のことだらう。",
              "citation": {
                "source": "田端に居た頃",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる意外の言だらう。",
              "citation": {
                "source": "常識家の非常識",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる薄情の者共だらう。",
              "citation": {
                "source": "大船驛で",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海野はその答を聞くごとに、呆れもし、怒りもし、苛立ちもしたりけるが、真個天真なる状見えて言を飾るとは思われざるにぞ、これ実に白痴者なるかを疑いつつ、一応｜試に愛国の何たるかを教えみんとや、少しく色を和げる、重きものいいの渋がちにも、「やましいことがないでもあるまい。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "闘文闘詩が一月に一度か二度ある、先生の講義が一週一二度ある、先ずそんなもので、其の他何たる規定は無かったのです。",
              "citation": {
                "source": "学生時代",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "洋の東西を問わず、また信仰の対象の何たるかを問わず、義の世界は、哀しいものである。",
              "citation": {
                "source": "父",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たるあはれのことぢゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「狐なんぞに神が物を教はるとは一体何たることだ。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たるあわれのことじゃ。",
              "citation": {
                "source": "二十六夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「狐なんぞに神が物を教わるとは一体何たることだ。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる人なつかしい音だろう！",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "何たる残刻無情の一語ぞ、自分は今もってこの一語を悔いている。",
              "citation": {
                "source": "まぼろし",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞳を定めてこれを讀めば――雲横秦嶺家何在、雪擁藍關馬不前――昌黎、時に其の意の何たるを知らず。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "心が愛するものを肉体で愛することの出来ないといふのは、なんたる邪悪の思想であらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんたる醜悪の病気であらう。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんたる冴えぬなが紅ぞ、　　朱もひなびては酸えはてし、　　紅土にもまぎるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "がりがり後頭部を掻きながら、なんたることだ、日頃の重苦しさを、一挙に雲散霧消させたくて、何か悪事を、死ぬほど強烈なロマンチシズムを、と喘えぎつつ、あこがれ求めて旅に出た。",
              "citation": {
                "source": "八十八夜",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蟻はまあ兵隊だし、強いからしかたもないが、あのおとなしいいたちめに教えられて、戸棚の下まで走って行って蟻の曹長にけんつくを食うとは、なんたるしゃくにさわることだとツェねずみは考えました。",
              "citation": {
                "source": "ツェねずみ",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「実は明日か、明後日あたり開くはずの公判を聴こうと思いましてね」「へへえ、なるほど、へえ」　渠はその公判のなんたるを知らざるがごとし。",
              "citation": {
                "source": "義血侠血",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてそのことを舵手を始め、船長も誰も知らないとは、ああ、なんたる失敗であろう！",
              "citation": {
                "source": "氷れる花嫁",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いやはや、なんたることじゃ！",
              "citation": {
                "source": "ナイチンゲール",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "「いや、はや、なんたることじゃ！",
              "citation": {
                "source": "ブタ飼い",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            }
          ]
        }
