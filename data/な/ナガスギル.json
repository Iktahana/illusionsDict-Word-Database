    "definitions": [
      {
        "index": 1,
        "gloss": "to be too long",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "少し長すぎるなと思つても、結構、しまひまで附合ひさせる面白さがあつた。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "全体が冗長すぎるばかりでなく、画面の推移の呼吸がちっとも生きていない。",
              "citation": {
                "source": "映画雑感（３）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "たとえばだいじのむすこを毒殺された親父の憂鬱を表現する室内のシーンでもその画面の明暗の構図の美しさはさまにレンブラントを想起させるものがあるが、この場面のいろいろなヴァリエーションが少なくも多くの日本人には少し長すぎるであろうと思われる。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛇が長すぎるということ。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "――あんまり長すぎる」　というルナアルの「博物誌」の中の言葉を想い出した。",
              "citation": {
                "source": "夜の構図",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは、背後から突き刺す男のごたぶんにもれず、クラスで最も貧弱な肉体をして、顔も青ぶくれで、そうしてたしかに父兄のお古と思われる袖が聖徳太子の袖みたいに長すぎる上衣を着て、学課は少しも出来ず、教練や体操はいつも見学という白痴に似た生徒でした。",
              "citation": {
                "source": "人間失格",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長すぎるならその柄をいいだけ切れと命じました。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "舌が長すぎるのだろうか。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つ欠席日数超過、二つ教師の反感を買っていること、三つ心身共に堕落していること、例えば髪の毛が長すぎる云々。",
              "citation": {
                "source": "髪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "歩いて来た私は、五六間も先から、すでに、群集の中に、この長すぎる身体をもてあましているような異様な風体の男を発見して、それに眼を注いでいた。",
              "citation": {
                "source": "虎狩",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌には長すぎるからだって。",
              "citation": {
                "source": "無名作家の日記",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "あわてるときはあわてすぎやがって、気がなげえとなりゃ長すぎるじゃねえか。",
              "citation": {
                "source": "右門捕物帖",
                "author": "袈裟切り太夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミスヤのもめん針にしちゃ長すぎるし、畳針にしちゃ短すぎるし、なんです！",
              "citation": {
                "source": "右門捕物帖",
                "author": "七七の橙",
                "note": "青空文庫"
              }
            },
            {
              "text": "敢えて、こき下ろすとすれば、この記事は長すぎる。",
              "citation": {
                "source": "地球発狂事件",
                "author": "海野十三（丘丘十郎）",
                "note": "青空文庫"
              }
            },
            {
              "text": "よし、すこし長すぎるけれど、これを使って加藤清正の虎退治とゆこう。",
              "citation": {
                "source": "空襲警報",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「さうだ／＼――よういとまけ／＼……」　ありのまゝの言葉づかひにしては、あまり間のびがしてゐて、恰度この河の流れのやうに悠長すぎるではないか――だから、それも私は、夢の中の歌ぢやないかな？",
              "citation": {
                "source": "ダニューヴの花嫁",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "早すぎるけれど早く起きた、短夜がまだ長すぎる、年はとりたくないものだ、朝酒の御馳走をいたゞく。",
              "citation": {
                "source": "旅日記",
                "author": "昭和十三年",
                "note": "青空文庫"
              }
            },
            {
              "text": "茎が長すぎるので、根が水を跳ねて、飛び出しさうになる。",
              "citation": {
                "source": "それから",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "おかみさんの東京下町人らしい不自然さ、父と娘との鍬打つ手つきの反力学性、幕合の比例を失して長すぎることなど、すでに指摘されていたと思う。",
              "citation": {
                "source": "『唯研ニュース』",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "倫敦じゃあスコットのステイキ――ええ、芝居はずいぶん見ましたし、その方面の人にもいろいろ会いましたが、日本の芝居はどうも時間が長すぎる。",
              "citation": {
                "source": "踊る地平線",
                "author": "黄と白の群像",
                "note": "青空文庫"
              }
            },
            {
              "text": "修業年限がおそらく長すぎるのである。",
              "citation": {
                "source": "九州の学生とともに",
                "author": "WITH KYUSHU STUDENTS",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の状態は、自分にとって長すぎる程継続した。",
              "citation": {
                "source": "小さき家の生活",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "例の饒舌僧とまた同宿した、知つたかぶりといふ言葉は彼のために出来たかと思はれるほどだ、人間はいゝけれど舌が長すぎる、下らない本を読んで、しかもそれを覚えすぎてゐる、『知る』といふことの価値が解らなければ宗教は解らない、といつてゐる私自身も知解情量の亜流だが。",
              "citation": {
                "source": "行乞記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "分けるには長すぎる髪の毛が、手入れをせぬと見えて、蓬々と乱れて顔にかかっているのが、死人のような顔の色を更に痛ましく見せている。",
              "citation": {
                "source": "黄昏の告白",
                "author": "浜尾四郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "十数時間の飛行機の旅は、この日の浜田にとって長すぎることはなかった。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "どんなに長い手紙でも長すぎると云ふ事はない。",
              "citation": {
                "source": "ある女の裁判",
                "author": "伊藤野枝",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとより黒く墨を入れているのでもなければ睫毛に油をうけているのでもなく、深い大きな眼に、長すぎるほどな睫毛が濃かった。",
              "citation": {
                "source": "江木欣々女史",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "雑誌むきのものではないし、又長すぎることもあるけれ共自分として最初のものがわずか二三十枚のものであろうことはのぞまないのだからしかたがない。",
              "citation": {
                "source": "日記",
                "author": "一九一六年（大正五年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "「きみのキツネ……この耳……ちょっとツノっぽい……ながすぎるよ！",
              "citation": {
                "source": "あのときの王子くん",
                "author": "LE PETIT PRINCE",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏目漱石の眼力もさることながら、僕は芥川に自決のことをいはれてから、芥川のながい睫をみてゐて、男にはながすぎる、これがいけない、と思つてたことがある。",
              "citation": {
                "source": "二つの繪",
                "author": "芥川龍之介の囘想",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
