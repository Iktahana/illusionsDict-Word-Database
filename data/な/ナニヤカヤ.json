        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そしてその凡そで以て何やかや書き出すやうになる。",
              "citation": {
                "source": "小詩論",
                "author": "小林秀雄に",
                "note": "青空文庫"
              }
            },
            {
              "text": "中老の男は私には丁寧に「自分も絵の端くれを描きますが、いや、その他、何やかや八百屋でして」　男はちょっと軒端から空を見上げたが「どうだ、日もまだ丁度ぐらいだ。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人は大学を出ると美術工芸学校やその他二三の勤め先が出来た上、類の少ない学問筋なので何やかや世間から相談をかけられることも多く、忙しいまま、東海道行きは、間もなく中絶してしまった。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかやそれぞれまとめて番ニョに乗せ、二人で差しあいにかつぐ。",
              "citation": {
                "source": "野菊の墓",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "違った店の気配に楼主その他も出て来て事情を聴き、何やかや持出して来たが、僧は淡如として言った。",
              "citation": {
                "source": "とと屋禅譚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私を見付けるとやつて来て何やかや話をして居た。",
              "citation": {
                "source": "二黒の巳",
                "author": "平出修",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうやって愛想気もない婆々が許でも、お休み下さりますお人たちに、お茶のお給仕をしておりますれば、何やかや賑やかで、世間話で、ついうかうかと日を暮しますでござります。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "お手廻りのものや、何やかや、いずれ明日お届け申します。",
              "citation": {
                "source": "草迷宮",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "毛布や何やかやあるから売れば金になるだろう」「そんなン……気の毒ですわ」「今から行って来るから、帰るまで待っていろ」　そう言って、小沢は出て行った。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "好奇心で一ぱいのかの女には却って何やかや観察の時間が与えられ都合がよかったが、常識的の社交の儀礼に気を使うらしい夫人は、ひどく手持ち無沙汰らしく、その上茶を勧めたり菓子を出したりして、沈黙の時間を埋めることを心懸けているように見えた。",
              "citation": {
                "source": "母子叙情",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕入れや何やかやで大分金が足らなかったので、衣裳や頭のものを質に入れ、なおヤトナ倶楽部を経営している昔の朋輩のおきんの所へ金を借りに行った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし、お宅かてお忙しいでっしゃろさかい、それに、帳面づけや何やかやは、隣組の人がしてくれはる言うことでっさかい」　玄関に立つと、蝶子は、「そんなら、ここで失礼して着せてもらいます」　と、黒いビロードのコートを羽織った。",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "家賃が安いが、借家となると何やかや手が掛かる。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも万々承知の上で、由兵衛夫婦は何やかやの支度に、この頃の短い冬の日を忙がしく送っていた。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかやに取りまぎれて、先生のところへもとかく御無沙汰がちになっていたが、大正三年の十一月、社用で神戸へ戻って来たので、そのついでに上京して、久しぶりで先生の家の門をくぐった。",
              "citation": {
                "source": "深見夫人の死",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その他何やかや大きな声で私は彼を叱り付けたようである。",
              "citation": {
                "source": "南島譚",
                "author": "※",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが私の「犬神博士」の方は不慣れなのと、追いかけられるのと、母の大病と、そのほか何やかやゴチャゴチャしたために思わぬ失態が百出しまして、とうとう打ち切られてしまいました。",
              "citation": {
                "source": "挿絵と闘った話",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "仕入れや何やかやで大分金が足らなかったので、衣裳や頭のものを質に入れ、なおおきんの所へ金を借りに行った。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかやで、蝶子は逆上した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「そこどころじゃねえ、フウそうして、」「あとで聞いたら何だとさ、途中の都合やら、何やかやで、まだその時お午飯さえあがらなかった、お弱い身体に、それだもの、夜露に冷えて堪るものかね。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "床の間にはたたんだ六枚折りの屏風が立てかけてあって、ほかに何やかやごてごてと置いてある。",
              "citation": {
                "source": "紅黄録",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "豊吉が品川から連れてきたお政という女は、もう年明け前でもあったが、それでも何やかやで三十両ばかりの金がいるので、豊吉は抱え主にたのんで先ず半金の十五両を入れて、女を自分の方へ引き取ることにした。",
              "citation": {
                "source": "半七捕物帳",
                "author": "雪達磨",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの一件につきましては、和泉屋さんでも、息子の死骸を引き取るやら何やかやで、随分の物入りであったそうで、なんとも申しようがございません。",
              "citation": {
                "source": "半七捕物帳",
                "author": "二人女房",
                "note": "青空文庫"
              }
            },
            {
              "text": "奴等も何やかやと材料を豊富にもつてゐる、だが鍋は完全に奴等から奪つたコックが腕利きなら材料は生きるんだ。",
              "citation": {
                "source": "小熊秀雄全集",
                "author": "―３―",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　狭山は女を顧みて、二言三言小声に語合ひたりしが、「何やかやで八百円ぐらゐは要りますので」「三千八百円、それだけ有つたら、貴下方は死なずに済むのですな」　打算し来れば、真に彼等の命こそ、一人前一千九百円に過ぎざるなれ。",
              "citation": {
                "source": "金色夜叉",
                "author": "尾崎紅葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「つれづれなるままに、そこはかとなく書きつけた筆のすさびが、いつともなしに世に洩れて、諸人の眼にも触れ耳にも伝えられ、何やかやと物珍らしげに言い囃さるるは、近ごろ面目もない儀でござるよ。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "少し手間が取れるともう、何やかやと、ろくでもねえことをいうんですよ。",
              "citation": {
                "source": "右門捕物帖",
                "author": "のろいのわら人形",
                "note": "青空文庫"
              }
            },
            {
              "text": "早めて式をあげたはいいが、話のとおり日本橋のほうでは人目もうるさいし、何やかやとまだごたついて、ゆっくり語らうこともできないところからして、こうして人世離れたこの寮へのがれて、しみじみと新婚の夢を結ぼうというのでした。",
              "citation": {
                "source": "右門捕物帖",
                "author": "朱彫りの花嫁",
                "note": "青空文庫"
              }
            },
            {
              "text": "すみませんけど新高さんと妾の写真も、着物も、貯金の帳面も、印形も、世帯道具や何やかやも、みんな一｜纏めにして、貴女のアテ名で送り出して置きました。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにお母さんが亡くなつて、家の方もなにやかや……」　ぢつと眼を伏せてゐるお里を見て、宗右衛門はだまつてしまつた。",
              "citation": {
                "source": "老主の一時期",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
