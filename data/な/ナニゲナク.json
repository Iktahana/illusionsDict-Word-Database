        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「大きい星だナ」彼は何気なくつぶやいた。",
              "citation": {
                "source": "地図",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人たちはしづかに席に戻り、二人も胸いっぱいのかなしみに似た新らしい気持ちを、何気なくちがった語で、そっと談し合ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラがまた何気なく叱るやうに叫びましたので、ジョバンニはまた思はず笑ひ、女の子はきまり悪さうにしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤シャツは右腕をあげて自分の腕時計を見て何気なく低くつぶやきました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何気なく笑って、その人と談してはいましたが、私はひとりで烈しく烈しく私の軽率を責めました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、そのまゝ何気なく帰ろうとして、外套に手を通しながら、ちょっとテーブルの方を見た。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼等は何気なく三軒目へ這入った。",
              "citation": {
                "source": "豚群",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お宅も鼠が出ますねえ」と、半七は何気なく云った。",
              "citation": {
                "source": "半七捕物帳",
                "author": "猫騒動",
                "note": "青空文庫"
              }
            },
            {
              "text": "古い錆のついた小銃弾を、ほかの屑物と一緒に買い取った屑屋が、何気なくそれをいじっていて、そこを巡警に見咎められ、ついに死刑にされたことさえあった。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　石炭酸の臭いがプン／＼している病院の手術室へ這入ると、武松は、何気なく先生、こんな片身をそぎ取られて、腹に穴があいて、一分間と生きとれるもんですか、ときいた。",
              "citation": {
                "source": "土鼠と落盤",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」番頭は何気なく、書きとめた帳を出して見る。",
              "citation": {
                "source": "窃む女",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人たちはしずかに席に戻り、二人も胸いっぱいのかなしみに似た新らしい気持ちを、何気なくちがった語で、そっと談し合ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」カムパネルラがまた何気なく叱るように叫びましたので、ジョバンニはまた思わず笑い、女の子はきまり悪そうにしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼が何気なくある崖下に近い窓のなかを眺めたとき、彼は一つの予感でぎくっとした。",
              "citation": {
                "source": "ある崖上の感情",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）と女は何気なく答えた、まず嬉しやと思うと、お聞きなさいよ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "看護員は何気なく、「そうです。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何気なく着て歩ける衣服がほしい。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅人たちはしずかに席に戻り、二人も胸いっぱいのかなしみに似た新しい気持ちを、何気なくちがった語で、そっと談し合ったのです。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "みんなかささぎだ」カムパネルラがまた何気なくしかるように叫びましたので、ジョバンニはまた思わず笑い、女の子はきまり悪そうにしました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何気なく笑って、その人と談してはゐましたが、私はひとりで烈しく烈しく私の軽率を責めました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺の木はあわてて枝が一ペんにがたがたふるへ、狐もそのけはひにどうかしたのかと思って何気なくうしろを見ましたら土神がまるで黒くなって嵐のやうに追って来るのでした。",
              "citation": {
                "source": "土神と狐",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "須利耶さまが歩きながら、何気なく云われますには、（どうだ、今日の空の碧いことは、お前がたの年は、丁度今あのそらへ飛びあがろうとして羽をばたばた云わせているようなものだ。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでも何気なく申されますには、（なるほど立派なもんだ。",
              "citation": {
                "source": "雁の童子",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "樺の木はあわてて枝が一ぺんにがたがたふるえ、狐もそのけはいにどうかしたのかと思って何気なくうしろを見ましたら土神がまるで黒くなって嵐のように追って来るのでした。",
              "citation": {
                "source": "土神ときつね",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と甲は書籍を拾い上げて、何気なく答える。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "その人が帰ったあと、私は母に何気なく「あの方、結婚してなさるの」と訊きますと、母は「してなさるが、どうも奥さんと面白くない噂でね」と云いました。",
              "citation": {
                "source": "扉の彼方へ",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「皆さん、妙なことを訊くようだが、もうお前さんも学校は卒業間際だから訊いとくが、何かい、お嫁なら向うの家の娘さんでも貰いなさるかね」　母親は、わざとお涌を娘さんといったり、息の詰るのを隠して何気なく云った。",
              "citation": {
                "source": "蝙蝠",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　お孝は何気なく頷いて、「清葉さんがお庇い遊ばして――まことに、お豪い芸者衆でいらっしゃいます。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "新聞の広告をなにげなく読む自分を見出すようになった。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なにげなくやっているのだったら腹も立ちません。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
