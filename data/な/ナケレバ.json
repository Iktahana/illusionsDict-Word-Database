    "definitions": [
      {
        "index": 1,
        "gloss": "if (it) doesn't exist",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "郷土の名を、わが空拳にて日本全国にひろめ、その郷土の名誉を一身に荷わんとする意気込みが無ければ、とても自身の生れた所の名を、家の屋号になど、出来るものではありません。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "友人が無ければ、人は犬や鳥とさえ話をするのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "諸君は、子供でも無ければ、大人でも無い。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "男でも無ければ、女でも無い。",
              "citation": {
                "source": "諸君の位置",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "眼鏡が無ければ、よく讀めないので。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は多少でも自分で實際に經驗した事で無ければ、一行も一字も書けない甚だ空想が貧弱の物語作家である。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この原稿の件さへ無ければ、私にとつて實に樂しい半日であつたのだ。",
              "citation": {
                "source": "大恩は語らず",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "郷土の名を、わが空拳にて日本全國にひろめ、その郷土の榮譽を一身に荷はんとする意氣込みが無ければ、とても自身の生れた所の名を、家の屋號になど、出來るものではありません。",
              "citation": {
                "source": "砂子屋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "私には、文学士の肩書も無ければ、それらしい何にも無い、参考にすべき外国の書籍も読めない。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "下品で嫌だなと思いながら、無ければ寂しい気がする。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "詩の生命と形式との関係には、石川君などの云ふよりは、もつともつと深い意味が無ければならぬと吾輩は信じて居るからである。",
              "citation": {
                "source": "『悲しき玩具』を読む",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな事が真実ならば、人は一に相応して居る訳で、星の数と人の数と同じで無ければならぬことになります。",
              "citation": {
                "source": "運命は切り開くもの",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人は花の大きからねば眼ざましからずとてもてはやさぬにや、香の無ければゆかしくもあらずとて顧みぬにや。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して其の人入れ親方なるものは、職業の性質上どうしても侠客肌の者で無ければならぬ処から、斯う云ふ種類の親方なるものは大抵侠客の名を以て呼ばれたもので、たとへば近世の大侠客相政の如きも亦た土州侯の人入れであつたし、新門辰五郎の如きも矢張りたゞの博徒ではない。",
              "citation": {
                "source": "侠客の種類",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "今夜は、生憎お酒も無ければ、お金も無い。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、この縁側に腰を掛けて、眼をショボショボさせている写真、これも甲府に住んでいた頃の写真ですが、颯爽としたところも無ければ、癇癖らしい様子もなく、かぼちゃのように無神経ですね。",
              "citation": {
                "source": "小さいアルバム",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからは、叔父さんが、私に、文学というものは特種の才能が無ければ駄目なものだと、苦笑しながら忠告めいた事をおっしゃるようになりました。",
              "citation": {
                "source": "千代女",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで親子の情があれば真実の親子であるが、無ければ他人だ。",
              "citation": {
                "source": "酒中日記",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "火鉢も無ければ、行火もなしに、霜の素膚は堪えられまい。",
              "citation": {
                "source": "露肆",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "サの字が無ければ、今夜も優柔しく、と言えば体裁が可い、指を銜えて引込もうと、屹と思って熟と視ると、波打つ胸の切符に寄せる、夕日に赤い渚を切って、千鳥が飛ぶように、サの字が見えた。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――泊めたかったが、お肯きでなし、……」　とお孝は独言のように云って、「途中で、またそうでもない、新聞にお名前の出るような事なんぞ無ければ可いが、」　と気を揉む頬の後毛は、寝みだれてなお美しい、柳の糸より優しいのである。",
              "citation": {
                "source": "日本橋",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "大佐は私の問に對して、悠々と鼻髯を捻りつゝ『若し不時の天變が無ければ、今より二年九ヶ｜月目、即ち之から三度目の記元節を迎ふる頃には、試運轉式を擧行し、引續いて本島を出發して、懷かしき芙蓉の峯を望む事が出來ませう。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ好漢、此男は實に壯快な男兒だが、惜むらくば少しく無鐵砲に失が無ければよいがと思ふ途端、忽ち『しまつたツ。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋が無ければ徒歩じゃ徒歩じゃと、一同ジャブジャブ水を漕いで渡るに、深さは腰にも及ばぬ程であるが、水流は石をも転ばす勢なので、下手をすれば足｜掬われて転びそうになる。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "剛健強勇を生命とする快男子は、須らく太陽に向かって突貫し、その力ある光勢を渾身に吸込む位の元気が無ければ駄目じゃ。",
              "citation": {
                "source": "本州横断　癇癪徒歩旅行",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "倒れかけたる祠には狐や宿を藉りぬらん、耳許近き木の枝にのりすれのりすれ梟の鳴き連るる声いと凄まじ、木の葉を渡る風はあれど、塵を清むる箒無ければ、蜘蛛の巣ばかり時を得顔に、霞を織る様｜哀なり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "と耳を澄まして窺えど、人の気附たる様子も無ければ、心安しと二階に上りて、壁を洩れ来る月影に四辺を屹と見渡せば、長き廊下の両側に比々として部屋並べり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして堅くなりすぎるか　自堕落になりすぎるかしなければ、　自分を保つすべがないやうな破目になります。",
              "citation": {
                "source": "寒い夜の自我像",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のことはない妄想家流であつて、ジャズだつてオネガだつてアッターベルヒだつてラヴェルだつてシトラウスだつてマーラーだつて、妄想家流――といつて妥当でなければ幻想家流である。",
              "citation": {
                "source": "音楽と世態",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "超現実派の詩論なぞも読んでをりますが、そして所々非常な卓見にも遭遇しますが、要するに読んだ後では「今時誰も結論には到達しないのだ」といふ何時も乍らの呟きを繰返さなければならない始末です。",
              "citation": {
                "source": "近時詩壇寸感",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
