    "definitions": [
      {
        "index": 1,
        "gloss": "diagonally upward",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "眼はうつろに斜め上方を見ながら謡うような小声で呟き出した。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜め上りになつてゐる澤の奥のつめの所に一竝び細く杉の木立の立ち續いてゐるのはいかにも靜けく明るく眺められます。",
              "citation": {
                "source": "樹木とその葉",
                "author": "伊豆西海岸の湯",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜め上から、船の動揺の度に、チラチラ薄い光の束が洩れていた。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "「今はシヤッポといふものがあるからそんなものもいらなからうが、昔はあゝいふ物を、斯う――」と年寄は反り身になつて片手を顔の斜め上にかゝげた。",
              "citation": {
                "source": "籔のほとり",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "今晩も、歩廊の拱から丁度斜め上に、北極星、大熊星が、キラキラ不思議な天の眼のように瞬いている。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "空はもうからりと晴れ上ってすばらしいお天気になり、暖かい太陽が斜め上に赫々と輝いていた。",
              "citation": {
                "source": "単独行",
                "author": "加藤文太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論そうすれば、索溝が斜め上方につけられるので、後で犯人は、その上に紐を当がって屍体を吊したのだよ。",
              "citation": {
                "source": "黒死館殺人事件",
                "author": "小栗虫太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし、斜め上から見たところがうつっている。",
              "citation": {
                "source": "洪水大陸を呑む",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただ一つ不思議なのは、池から斜め上に当る崖の上に、嘗ては粗末な稲荷堂があって、小さな石の鳥居がまだ残っていましたが、その鳥居の片足に、赤い布が巻きつけてあるのが、誰からともなく見出されました。",
              "citation": {
                "source": "崖下の池",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "運転手は、右腕を真直ぐに伸ばして、前方へ斜め上に突き出す礼をした。",
              "citation": {
                "source": "踊る地平線",
                "author": "長靴の春",
                "note": "青空文庫"
              }
            },
            {
              "text": "晩秋の淋しい光が、くっきりとした軒並の影で、斜め上から街路を蔽いつくしていた。",
              "citation": {
                "source": "野ざらし",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "俺達は怨めしげに、斜め上の二階を見上げた。",
              "citation": {
                "source": "神棚",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語の興味に惹かされて、一時間も読み続けてるうちに、一寸心に疲れた弛みが出来ると、しきりに右手の斜め上の方が気になり出した。",
              "citation": {
                "source": "都会の幽気",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "冴えきった冷い月の光が、斜め上から降るように落ちていて、その乳房と手と子供の赤い頬辺とに、蒼白い艶を投げかけていた。",
              "citation": {
                "source": "人間繁栄",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あれを見ろ」と魚戸は僕の身体を前方へ引摺るようにして、斜め上方を指し「探照灯は本艇が出しているのだが、あの青白い光の中に黒い小山のようなものが並んでしずかに動いているのが見えるだろう。",
              "citation": {
                "source": "宇宙尖兵",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その少し斜め上の壁に細棹の三味線が一つ、欝金木綿の袋にはいって鴨居から下っていた。",
              "citation": {
                "source": "掠奪せられたる男",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのゆらぐ火影が、うすい垂れぎぬに濾されて、じぶんの肩ごしに斜め上から女の顔へ落ち、その安らかな寝顔に、ちらちらと物かげを戯むれ走らせてゐるのである。",
              "citation": {
                "source": "鸚鵡",
                "author": "『白鳳』第二部",
                "note": "青空文庫"
              }
            },
            {
              "text": "爪先が一尺ほど斜め上をかいさぐっているとき、思いがけない感触があった。",
              "citation": {
                "source": "一の倉沢",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後、カオルとふたりではいりこんだ、亡くなった秋川夫人の部屋の窓々が、斜め上のあたりに、薄月の光をうけて、ほの白く光っている。",
              "citation": {
                "source": "あなたも私も",
                "author": "久生十蘭",
                "note": "青空文庫"
              }
            },
            {
              "text": "扉の斜め上にはまった小さな天窓によってほかの階段とはちがって比較的明るく照らし出されているこの扉は、上塗りのしてない角材で組み上げられ、その上にはティトレリという名前が赤い色で肉太の筆描きをもって書かれていた。",
              "citation": {
                "source": "審判",
                "author": "DER PROZESS",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、室の天井が少し低いのを見て取って、片八相、斜め上段になる。",
              "citation": {
                "source": "天狗外伝　斬られの仙太",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこは女たちを斜め上に見上げる位置になる。",
              "citation": {
                "source": "狂い凧",
                "author": "梅崎春生",
                "note": "青空文庫"
              }
            },
            {
              "text": "斜め上に、真剣な顔でその細君を見下ろしている紅潮した若い夫の顔が見えた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "女は斜め上を見上げた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女の視界の外へ出ていこうとしている立原のうしろ姿を、彼女は斜め上からとらえた。",
              "citation": {
                "source": "物のかたちのバラッド",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
