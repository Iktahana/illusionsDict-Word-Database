    "definitions": [
      {
        "index": 1,
        "gloss": "how (beautiful, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
