          "literary": [
            {
              "text": "楢茸、湿地茸、稀に紅茸、初茸は滅多になく、多いのが油坊主と云う茸だ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "楢茸、湿地茸も少しは立つ。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "よく楢茸の初物だの何だの採っては、味噌漉しに入れて持って来てくれた。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "最早楢茸が出ても、味噌漉しかゝえて、「今日は」と来る腰の曲った人は無い。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
