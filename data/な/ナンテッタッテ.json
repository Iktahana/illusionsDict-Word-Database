          "literary": [
            {
              "text": "何てったって、化けるのは俺の方が本職だよ。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てったって、お前はどうせ無代価で頂くもんじゃねえか。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ほんとはお前さんが何てったって、朝夕顔が見ていたいの。",
              "citation": {
                "source": "照葉狂言",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てったって、とてもいうことをお肯き遊ばさないお気なんだから仕ようがない。",
              "citation": {
                "source": "清心庵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "「直接のことじゃないから、何てったってちがうねえ。",
              "citation": {
                "source": "乳房",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何てったって開けるこっちゃないよ。",
              "citation": {
                "source": "釘抜藤吉捕物覚書",
                "author": "お茶漬音頭",
                "note": "青空文庫"
              }
            },
            {
              "text": "「なんてったって、ぼくがいちばん高くとんだんだ」と、ノミは言いました。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてったって、ぼくがいちばん高くとんだんだ。",
              "citation": {
                "source": "とびくらべ",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてったって、戸棚の前に座って、硫黄をいじくってる。",
              "citation": {
                "source": "木魚の配偶",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "誰がなんてったって小父さんだイ」「そうだそうだイ、この小父さんが、一本五厘の焼鳥なんだイ」　たまりかねて七分がらみ詰めていたお客たちがドーッと笑い崩れた。",
              "citation": {
                "source": "寄席",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハレマイヤ　俺たちは注文しないけどな、なんてったって、ロボットを発明したんだからな！",
              "citation": {
                "source": "ＲＵＲ――ロッサム世界ロボット製作所",
                "author": "R.U.R. (ROSSUM'S UNIVERSAL ROBOTS)",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてったって、こいつがいちばんほねのおれるしごとさ。",
              "citation": {
                "source": "いさましい　ちびの仕立屋さん",
                "author": "グリム　Grimm",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたし赤ちゃんを産みます、誰がなんてったって産みます、あたし独りでりっぱに育ててみせますから」　登は黙っていた。",
              "citation": {
                "source": "赤ひげ診療譚",
                "author": "氷の下の芽",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてったって男と女とじゃ、使うお金の桁がちがうんですもの」　私は、なんとなく変態的な夫婦というものは、ひどく仲がいいか、冷たく憎みあっているか、とにかく特別な愛情で結ばれているのだと思っていた。",
              "citation": {
                "source": "愛のごとく",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんてったって、毎日がひどく充実していた」　ふと信二は、小林と同じように、戦争をどこかでもとめている自分を感じていた。",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「茅ヶ崎のキャムプも、いまは黒ちゃんや韓国兵が多いってな、夜な夜な望郷の黒人霊歌や、うら悲しい朝鮮民謡の哀調がきこえてくるっていう話だ、戦争はどうでもかまわねえが、おれはあの陽気なキャムプがなつかしいな、なんてったって朗らかで、わりかた質が良かった」「じゃ、あそこの米軍は？",
              "citation": {
                "source": "その一年",
                "author": "山川方夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "「だめだよう」女は木内を押し倒した、「あたしをくどいといて、なにさ」と女は木内の上に馬乗りになった、「今夜は寝かさないからね、帰るなんてったって帰しやしないよ」　そして女は、木内の頬に吸いついた。",
              "citation": {
                "source": "へちまの木",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            }
          ]
        }
