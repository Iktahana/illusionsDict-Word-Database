    },
    "definitions": [
      {
        "index": 1,
        "gloss": "nano-",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "芸術家ハ、イツモ、弱者ノ友デアッタ筈ナノニ。",
              "citation": {
                "source": "ア、秋",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "オトウサンハ　ハナノ　下ニ　クロイ　ヒゲヲ　ツケテ　ヰタノデ、コドモタチハ　「ヒゲサン」ト　ヨンデ　ヰマシタガ、ヤガテ　タキクンノ　コトモ　「ヒゲサン」ト　ヨブヤウニ　ナリマシタ。",
              "citation": {
                "source": "センセイノ　コ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンザシ新美南吉　ヲンナノ　コガ　イケノ　フチカラ　ミズノ　ナカヲ　ノゾイテ　ヲリマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「アツ」ト　ヲンナノ　コガ　サケビマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンザシガ　ヲンナノ　コノ　アタマカラ　ヌケテ、イケノ　ナカニ　オチタカラデ　アリマス。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "カンザシハ　サカナノ　ソバニ　シヅンデ　キマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「サカナサン、カンザシヲ　ヒロツテ　クダサイ」ト　ヲンナノ　コガ　サカナニ　タノミマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ソレハ　カンザシト　イツテ、アタマニ　サスモノデス」ト　ヲンナノ　コハ　オシヘテ　ヤリマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジブンデ　オヒロヒナサイ」　ヲンナノ　コハ　コマツテ　シマヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヲンナノ　コハ　ナキナガラ　イツテ　シマヒマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ツギノ　ヒ　ヲンナノ　コハ　マタ　イケノ　フチニ　ヤツテ　キマシタ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "サア　カンザシヲ　オカヘシシマス」　ヲンナノ　コハ　ドンナニ　ヨロコンダ　コトデセウ。",
              "citation": {
                "source": "カンザシ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ミナサン」ト　モルモツトハ、シンパイサウニ　シテ　ヰル　ミンナノ　カホヲ　ミマハシテ　イヒマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ミンナノ　モノハ　タメイキヲ　シテ　カホヲ　ミアハセマシタ。",
              "citation": {
                "source": "ガチヨウノ　タンジヨウビ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "スルト　ポストノ　ウシロニ　タツテ　ヰタ　ガイトウガ　カラ　カラト　ワラツテ、「ポストノ　カゲナラ、ポストノ　ウシロニ　コロガツテ　ヰル　ソノ　ブカツカウナノガ　サウヨ」ト　イヒマシタ。",
              "citation": {
                "source": "タレノ　カゲ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ソコノウチノ人ハドレモミンナビンボウ人バカリナノデ、ビンボウナモノハミンナヨリアツマラナケレバ、カワイソウナモノダ、ト云ッテイタノ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "長イアイダ、タベモノヲ見タコトモナカッタトコロヘ、ハジメテソウシキノオソナエモノヲミルト、モウ矢モタテモタマラズ、目ガクラクラットシテ、ソレニ小サイ弟ヤ妹ナノデ、死ンダオ母ッチャニワルイトオモイナガラ、スキヲネラッテ、ミンナデムチュウニナッテタベテシマッタンダッテ。",
              "citation": {
                "source": "テガミ",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "談話者又報告者ノ言葉モナルベク保存シ、話ノ順序、ノ混雜シタノヤ不得要領ナノモ故意ニ其儘ニシテ置イタ、サウシタ方ガ史料トシテノ價値ヲ損ジナイト思フカラデアル。",
              "citation": {
                "source": "寺田先生と僕",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "シカモカタカナノ問題ハ現在ノ私ノ生活ニスコブル密接ナ関係ヲ持ツ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "キワメテアタリマエノコトナノデアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "一、ヒラガナノ活字ハソレ自身ガ美シクナイ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "文字トシテモ現今ノヒラガナヨリハ変態ガナノホウガ美シク、変態ガナヨリハ上代ガナノホウガ美シイ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ヒラガナノ活字ガイカニ醜イカトイウコトハ初号クライノ活字ヲ見タラダレニモワカルダロウ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ユエニ楷書ノ活字トヒラガナノ活字モマタ調和シナイノデアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "トコロガカタカナノ場合ハソノ成立ノ歴史カライツテモ楷書ノ漢字ノ一部分ヲチヨツト失敬シタマデデアルカラ、コレガ楷書ノ字ト一緒ニ並ンデイルトコロハアタカモ親ト子ガ並ンデイルクライヨク調和スル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "シタガツテ楷書ノ活字トカタカナノ活字モマタキワメテ調和ガヨイ。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "元来、ヒラガナノ構成単位ハ曲線デアリ、楷書トカタカナノ構成単位ハ直線デアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢字ノ活字ガ楷書一ツデタクサンデアルヨウニ、カナノ活字モカタカナ一種類デタクサンデアル。",
              "citation": {
                "source": "カタカナニツイテ",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
