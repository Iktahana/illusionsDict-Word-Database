[
  {
    "uuid": "6b144af5-628b-53ef-bdaa-e8d7b6a39c80",
    "entry": "縄張り",
    "reading": {
      "primary": "なわばり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
