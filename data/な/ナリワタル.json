[
  {
    "uuid": "aad53d75-53e3-571d-bb5f-b74657ed099f",
    "entry": "鳴り渡る",
    "reading": {
      "primary": "なりわたる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
        "動詞-自動詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to resound (echo) far and wide",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "彼女が踊りにおいてツレブラを好むように、彼女の色素の複雑さが、ジャズが夜中のサイレンのように鳴り渡る都会人の愛情を占領してしまった。",
              "citation": {
                "source": "新種族ノラ",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼食喇叭が鳴り渡る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "向うの蛋粉工場からも、呼応して鳴り渡る。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひッそとなりて、堂の裏｜崖をさかさに落つる滝の音どうどうと松杉の梢ゆう風に鳴り渡る。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "寺々の鐘が鳴り渡ると爆竹がとどろいてプロージット、プロージットノイヤールという声々が空からも地からも沸き上がる。",
              "citation": {
                "source": "銀座アルプス",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "』と叫ぶ響は砲聲の絶間、全艦に鳴り渡ると、軍艦「日の出」の士官水兵一時に動搖めき。",
              "citation": {
                "source": "海島冐檢奇譚　海底軍艦",
                "author": "押川春浪",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひツそとなりて、堂の裏崖をさかさに落つる滝の音どうどうと松杉の梢ゆふ風に鳴り渡る。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、ゴウツ、といふ異樣な音響が四方の空に鳴り渡るのを聞いた。",
              "citation": {
                "source": "樹木とその葉",
                "author": "地震日記",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき、じゃんじゃんと鳴り渡るすり半とともに、どやどやと駆けつけてきたものは、江戸の名物火事ときいて鳶の装束の一隊でありました。",
              "citation": {
                "source": "右門捕物帖",
                "author": "笛の秘密",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその誰もが、闇を裂いて鳴り渡る非常汽笛の音を恐しく待ち受けるやうに、しいんとした間を作つた。",
              "citation": {
                "source": "輝ける朝",
                "author": "水野仙子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時海も野も山も、砕くるばかりに鳴り渡る、　さも物凄い恐ろしい、真暗闇のただ中に、　彼の石男の眉間から、赤い光りが輝やいて、　額の骨が真二ツに、パッと割れたと思ううち、　真赤な鸚鵡が飛び出して、東の方へ飛んで行た。",
              "citation": {
                "source": "白髪小僧",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　の号令で、爆音一発、火蓋を切つて朝霧の中に殷々と鳴り渡る。",
              "citation": {
                "source": "鵞鳥の家",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はいつか山門の売店で陣太鼓を買つたことがあるが、それは力を入れて打てば破れるほどのおもちやであるのに、守吉の太鼓はあまり調子よく鳴り渡るので不思議に思つて遠くから注意して見ると、何処からあんな本物を探して来たのだらう――と、その時は思つたのである。",
              "citation": {
                "source": "泉岳寺附近",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが、怪しく妍麗な幻のやうに淙々として、私は次第に私のうらぶれた夢の中に鏘然と鳴り渡るものを感ずるらしかつた。",
              "citation": {
                "source": "天狗洞食客記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "声が、水の上を滑つて四囲の山々に響くと三重にもなつた山彦があちこちから鳴り渡るのであつた。",
              "citation": {
                "source": "沼辺より",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "なるほど梢のクマ蝉やアブラ蝉のわんわんと鳴り渡る声に交つて、蜩の、シロフオンを滑るやうな伴奏が八方から襲ひかかつてゐた。",
              "citation": {
                "source": "創作生活にて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "私も一度、試みに水門番にたづさはつて見たこともあるが、いざ堰を切る段になつて閂を引き、把手を肩にして満身の力を持つて開門しようとしても、曳哉／＼と叫ぶ掛声ばかりが水車の騒ぎよりも壮烈に鳴り渡るばかりで、打たうが叩かうが、それは私にとつては永遠に開かずの扉であつた。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "この合奏は天狗の歩みが続く限り、「附け」となつて、いとも厳かに鳴り渡るのである。",
              "citation": {
                "source": "バラルダ物語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "堂塔の上高く、二つの鐘が鳴り渡ると、石に木霊し、水に響き、塔はさながら楽器である。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "組織委員長レーワルト氏の式辞の後、ヒットラー総統の開会の辞がすむと、突然号砲が鳴り渡る。",
              "citation": {
                "source": "欧洲紀行",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "やゝありて人の立居する音の聞ゆるに、嬉しやと思ひきや、振鈴の響起りて、りん／＼と鳴り渡るに、是れはと駭く横笛が、呼べども叫べども答ふるものは庭の木立のみ。",
              "citation": {
                "source": "瀧口入道",
                "author": "高山樗牛",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし人間に無条件に通じ合う愛というものがあり得るなら、こうやって初冬の晴れた大空を劈いて休戦を告げる数百千の汽笛が鳴り渡るとき、どうして人々は敗けて、而も愛するものを喪った人々の思いを察しようとしないのだろう。",
              "citation": {
                "source": "時代と人々",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゆつ、ひゆつと何ごとかを告げるやうに空中に鳴り渡る。",
              "citation": {
                "source": "伊良湖の旅",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "風はまた一しきり勝利の聲をあげて鳴り渡る。",
              "citation": {
                "source": "山岳美觀",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "親骨を皆まぜて仕舞ったので立て付けの終ったのは日没の太鼓が鳴り渡る頃であった。",
              "citation": {
                "source": "小さな旅",
                "author": "富田木歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある日、それは甚太郎が、纐纈城へ入り込んでから、約十日ほど経った日の、大変輝かしい午後のことであったが、広い広い纐纈城の隅々隈々にまで鳴り渡るような鋭い女の叫び声が、大廊下の外れから聞こえて来た。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は天国へも昇れば、シルレルのところへお客にも行く――ところがまるで霹靂のように、こうした致命的な言葉が突然、彼の頭上で鳴り渡ると共に、彼はやはり自分が地上にあって、それも＊３センナヤの広場か、酒場の近くに佇んでいるのに気がつく、そして又もや味気ない日常生活が彼の面前にそそり立つのである。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第一分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "その声は雨音の鳴り渡る中に殆気味の悪い反響を起した。",
              "citation": {
                "source": "お富の貞操",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "ねがわくは、ある大妖術者が出現して、社会の幹から、天才の手に触れて始めて鳴り渡る弦をそなえた大琴を作らんことを祈る。",
              "citation": {
                "source": "茶の本",
                "author": "茶の本",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひゅうひゅうと帆綱になりわたる風は、弔いのときの人の泣き声のようだった。",
              "citation": {
                "source": "船旅",
                "author": "ワシントン・アーヴィング　Washington Irving",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
