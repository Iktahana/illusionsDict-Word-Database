        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "兄は窓際によつてぎらぎらと輝いてゐる夏空を見上げてゐたのだ。",
              "citation": {
                "source": "疑惑",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "狙ひしづかなり夏空、軍の真上、畏ろしく形無きもの風をはらむつかのま。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第七段頃しも弘安四年、閏七月の朔日、ああら不思議や、京にては晴れに晴れたる夏空に一朶の黒雲｜神立ち現れ、白羽はいだる鏑矢の見る見る輝き鳴動して、たちまち西へと飛び去りける。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "狙ひしづかなり夏空、軍の眞上、畏ろしく形無きもの風をはらむつかのま。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "」とＹ子にゆすられて眼を醒した時には、あたりは悉く開け放されて爽々しい微風が、梅雨あけの夏空に光つてゐた。",
              "citation": {
                "source": "小川の流れ",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ジガ蜂は引つかかつたなと思ふと、ぶるんと激しく足ぶるひして次の瞬間にはもう器用に抜け出して、そんなことがあつたともいはぬやうな顔で高い夏空さして飛んで行つた。",
              "citation": {
                "source": "ジガ蜂",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田の心の動搖は、彼がこゝの病舍で癩病患者および肺病患者のなかにあつて、彼等の日常生活をまざまざと眼の前に見、自分も亦同じ患者の一人としてそこに生活しつゝある間に、夏空に立つ雲の如くに自然にわいて來たものであつた。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "太田の心の動揺は、彼がここの病舎で癩病患者および肺病患者のなかにあって、彼らの日常生活をまざまざと眼の前に見、自分もまた同じ患者の一人としてそこに生活しつつある間に、夏空に立つ雲のごとくに自然にわいて来たものであった。",
              "citation": {
                "source": "癩",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "燃える夏空の下で驚歎をもって観察した。",
              "citation": {
                "source": "砂遊場からの同志",
                "author": "――ソヴェト同盟の共学について――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ノックの響きは夏空に快くこだました。",
              "citation": {
                "source": "光り合ういのち",
                "author": "倉田百三",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏空の下で、電気のような白日の光に溢れんばかりに浸されて、大地の色彩は、ほとんどこの世のものとは思われないほど美しく輝いていた。",
              "citation": {
                "source": "橋の上で",
                "author": "ON A BRIDGE",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう初夏空の輝く白い雲は仰げども見えない。",
              "citation": {
                "source": "海潮の響",
                "author": "吉江喬松",
                "note": "青空文庫"
              }
            },
            {
              "text": "都会の上に展がる夏空は嘘のように明るい光線だった。",
              "citation": {
                "source": "美しき死の岸に",
                "author": "原民喜",
                "note": "青空文庫"
              }
            },
            {
              "text": "原っぱへ出て、夏空の下の長い堤防や遠くの動かぬ貨車の列を見る時、ナースチャの眼に涙が浮んだ。",
              "citation": {
                "source": "赤い貨車",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏空は、燃えたって揺れもしない青い焔だ。",
              "citation": {
                "source": "ピムキン、でかした！",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "瞬時にその夏も亦暮れる、そして生活も暮れてしまふ、蒼い空の在ることをさへ忘れつくして、湿つた藁屋根の下に村人たちが呟くであらう嗄れた溜息が、明るい夏空の裏側に透明な波動となつて見え透いてゐる。",
              "citation": {
                "source": "黒谷村",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "振仰ぐと葉越しに濃厚な夏空が輝いており、砂丘一面に蝉の鳴き澱む物憂い唸りが聞えた。",
              "citation": {
                "source": "傲慢な眼",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "一　享保三年五月四日の午下り、よく真青に雲なく晴れわたつた夏空で、云ふまでもなく陰暦だから、いまなら六月末の日の光りがギラ／＼と眩しく暑い。",
              "citation": {
                "source": "吉原百人斬",
                "author": "正岡容",
                "note": "青空文庫"
              }
            },
            {
              "text": "夢は半ばとじた眼の前にゆれ、きらめく楼閣は流れる雲間にうかび、雲はたえず夏空に照りはえていた。",
              "citation": {
                "source": "スリーピー・ホローの伝説",
                "author": "故ディードリッヒ・ニッカボッカーの遺稿より",
                "note": "青空文庫"
              }
            },
            {
              "text": "足もとには、小さな家屋がたてこんで、物干しの洗濯物が、夏空の下で、風にひるがえり、すこしばかりの空き地で、子供が、鬼ごっこをして遊んでいました。",
              "citation": {
                "source": "風はささやく",
                "author": "小川未明",
                "note": "青空文庫"
              }
            },
            {
              "text": "その年は空梅雨で、早目に澄みかへつた夏空の藍が、はげしい炎暑を約束してゐた。",
              "citation": {
                "source": "垂水",
                "author": "神西清",
                "note": "青空文庫"
              }
            },
            {
              "text": "船の灯は星を散らしたやうですが、夏空が低く垂れて、花火の咲いてない時は、鉛のやうに眞つ暗です。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "笹の繁った山腹、キラキラ碧い夏空の下で、たった一点赤い自分の洋傘の色は、どんなに活々美しく見えるだろう。",
              "citation": {
                "source": "伸子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "高いところでラジオ拡声ラッパが二十一度の明るい北方の夏空へギター合奏を流している。",
              "citation": {
                "source": "子供・子供・子供のモスクワ",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕等が停車場へ馬車を駆った時には、水色の夏空が頭上に笑っていた。",
              "citation": {
                "source": "幸福への意志",
                "author": "DER WILLE ZUM GLUCK",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴミゴミしてくさいところにいて、疲れのため、遠い夏空に立っている梧桐の青い筈の葉が黒く見えていました。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九四四年（昭和十九年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "晴れた夏空のような、すがすがしさだった。",
              "citation": {
                "source": "胡堂百話",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "もとは兵営だったその建物も今は占領軍の宿舎になっているとかで、ぬり替えられた白い壁にくっきりと窓々のブルーの被いが、晴れた夏空に、いかにも暑さを静めるかのように並んでいる。",
              "citation": {
                "source": "妻の座",
                "author": "壺井榮",
                "note": "青空文庫"
              }
            },
            {
              "text": "とうとうから梅雨で終った夏空はあくまで晴れあがって、ぎらぎらと眼に痛いほど輝く白雲が二つ三つ、北へ移動しているきり雷の来そうなようすはどこにもみえなかった。",
              "citation": {
                "source": "新潮記",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "大きなマリオン窓を二枚、夏空に開け広げ、出窓のタイル花壇からモクセイソウやヘリオトロープのかぐわしい匂いが漂って来る。",
              "citation": {
                "source": "玉手箱",
                "author": "A Golden Argosy",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
