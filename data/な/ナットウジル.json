        "examples": {
          "standard": [
            {
              "text": "東北地方では、冬の寒い時期に温かい納豆汁を食べる習慣がある。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "家庭料理の納豆汁は、身体を芯から温めてくれる滋養のある一品だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "すりつぶした納豆を使った納豆汁は、独特の風味ととろみが特徴だ。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "寒さもまさり来るに急ぎ家に帰れば崩れかかりたる火桶もなつかしく、風呂吹に納豆汁の御馳走は時に取りての醍醐味、風流はいづくにもあるべし。",
              "citation": {
                "source": "俳諧大要",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "反椀は家にふりたり納豆汁「古くなつて木が乾くに従ひ反つて来る」とあれども反椀は初より形の反つた椀にて、古くなつて反つた訳には非るべし。",
              "citation": {
                "source": "墨汁一滴",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
