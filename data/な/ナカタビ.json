        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "さすがの豪傑連中度胆を抜かれてひれ伏してしまった。",
              "citation": {
                "source": "戦争史大観",
                "author": "石原莞爾",
                "note": "青空文庫"
              }
            },
            {
              "text": "テレタイプに取りついた生まれたてのコンピューターマニアの中でも、二人の熱中度は群を抜いていた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "六七　引滿中度、發無空箭。",
              "citation": {
                "source": "南洲手抄言志録",
                "author": "南洲手抄言志録",
                "note": "青空文庫"
              }
            },
            {
              "text": "汽笛声中度雪岑、鉄車傍水入岩陰、渓頭百里那東路、不見行人只見林。",
              "citation": {
                "source": "南半球五万哩",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "菊太郎君が高熱中度々失禁したことなんか喋られると、如何にもダラシのない人間のように思い込まれる。",
              "citation": {
                "source": "勝ち運負け運",
                "author": "佐々木邦",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬に向かう季節、そして冬という季節のなかでの直子と彼とのつながりは、直子に対する高い集中度によるつながりだった。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "直子に対して、高まりきったヨシオの集中度は、ごく淡く始まった春によって、魅惑的に中和され始めた。",
              "citation": {
                "source": "東京青年",
                "author": "片岡義男",
                "note": "青空文庫"
              }
            },
            {
              "text": "話しているうちに彼等の熱中度がどんどん高まってきて、ついにはこの二人の荒々しい熱愛者の間には表現の仕方を巡って奇妙な争いすら生まれた。",
              "citation": {
                "source": "ゴリオ爺さん",
                "author": "Le Pere Goriot",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
