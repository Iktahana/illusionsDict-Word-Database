        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何なら尋ねてご覧遊ばせ。",
              "citation": {
                "source": "みちのく",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "書かせ給ふは何ならん、何事かの御打合せを御朋友の許へか、さらずば御母上に御機嫌うかゞひの御状か、さらずば御胸にうかぶ妄想のすて所、詩か歌か。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "何なら虫眼鏡で一遍ずつ覗かせるのもいいかもしれない。",
              "citation": {
                "source": "雑記（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり倦みたれば、一ツおりてのぼる坂の窪に踞いし、手のあきたるまま何ならむ指もて土にかきはじめぬ。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "何なら豫め其の用心で、丁ど恁うして人通りはなし――構はず駈出したら可いでせう……」「私、駈けられませんの。",
              "citation": {
                "source": "艶書",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何なら露西亜へでもお出なさいな。",
              "citation": {
                "source": "貧民倶楽部",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬礼の控のように逆とじなどと言う悪はしてありませんから、何なら、初筆を一つ……」「いや、いずれ。",
              "citation": {
                "source": "露萩",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いずれにしても、加世子さんからそう言って来たのなら、行ってあげなきゃ……何なら私も行くわ。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "何なら子供に御案内させますですが。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何なら紹介しよう。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことをたびたびやられちゃ、使うのに骨が折れるから、何なら思うようにしてくれというの。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "妾……もっと真暗になるまでここにいるつもりですから、何でもお言葉に従いますわ……何なら非常線の解けるまでこの工場の中に泊っても構いませんわ。",
              "citation": {
                "source": "童貞",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "何ならちつとあげようか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何なら、わたしが代りに書いて上げます。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあ、貴郎、そうしていらっしゃる処ではありません、早く真砂町へおいでなすって、先生が何なら奥様まで、あんな許へは御相談なさいませんように、お頼みなさらなくッちゃ不可ません。",
              "citation": {
                "source": "婦系図",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり倦みたれば、一ツおりてのぼる坂の窪に踞ひし、手のあきたるまま何ならむ指もて土にかきはじめぬ。",
              "citation": {
                "source": "竜潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "……何なら今夜内へ宿めてやつても可いとおつ母さんが言つてお出でだつた。",
              "citation": {
                "source": "少年の死",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「何ならお供をいたしましょう、ええ、旦那。",
              "citation": {
                "source": "菎蒻本",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月　向日葵、向日葵、百日紅の昨日も今日も、暑さは蟻の數を算へて、麻野、萱原、青薄、刈萱の芽に秋の近きにも、草いきれ尚ほ曇るまで、立蔽ふ旱雲恐しく、一里塚に鬼はあらずや、並木の小笠如何ならむ。",
              "citation": {
                "source": "月令十二態",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "――旅の疲労も有らつしやらうか、何なら、今夜は私が小家へ休んで、明日の晩にも、と言ふたが、其には及ばぬ……若しや、其が真実なら、片時も早く苦艱を救ふて進ぜたい。",
              "citation": {
                "source": "神鑿",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あっさりした証拠には、さよう、何ならもう一人ぐらいこの茶飲み倶楽部の仲間に入れてもいゝじゃないか」　と答えています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "「鮭という魚や」「魚て何なら？",
              "citation": {
                "source": "わが町",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "而して其中間に※まれたる以太利は遂に如何ならむ。",
              "citation": {
                "source": "想断々（２）",
                "author": "北村透谷",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年に通譯させると、「二圓だけれど、何なら一圓五十錢でもいい」と言つてゐるのださうだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "少年に通訳させると、「二円だけれど、何なら一円五十銭でもいい」と言っているのだそうだ。",
              "citation": {
                "source": "環礁",
                "author": "――ミクロネシヤ巡島記抄――",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は九頭竜の主人が来て見ることになっているから、なんなら連れ立っておいでなさいといって飛び出してきた。",
              "citation": {
                "source": "ドモ又の死",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんならお前も今夜つれてつてやらうか。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんならもう一度外へ出して見ましょう。",
              "citation": {
                "source": "フレップ・トリップ",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんなら西教寺とこちらとの間に花屋が住っていますから、聞いて御覧なさいまし。",
              "citation": {
                "source": "細木香以",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんなら玉子でも持ってまいりましょうか」こう云って立ちそうにした。",
              "citation": {
                "source": "雁",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
