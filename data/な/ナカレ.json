        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "驛路に見送る人人よ悲しみの底に齒がみしつつ告別の傷みに破る勿れ。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "さあれ、怒ることこそ汝が最後なる目標の前にであれ、この言ゆめゆめおろそかにする勿れ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "以て木突となすこと勿れ、汝喚んで何とかなす！",
              "citation": {
                "source": "疑獄元兇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今の家庭問題に注意する人々に告ぐ、自分は自分だけの家庭を作れ、決して家庭読物などの談に心を奪わるる勿れ。",
              "citation": {
                "source": "家庭小言",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "お絹とは何人ぞ、君驚く勿れ、藝者でも女郎でもない、海老茶式部でも島田の令孃でもない、美人でもない、醜婦でもない、たゞの女である、湯原の温泉宿中西屋の女中である！",
              "citation": {
                "source": "湯ヶ原より",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "食を享くるもの、いやしくもこの理を忘るる勿れ。",
              "citation": {
                "source": "阿難と呪術師の娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "老公重ねて、「これより後は汝等一同杢に從ひ渠が言に背くこと勿れ、此儀しかと心得よ」と思ひも寄らぬ命なれば、いづれも心中には不平ながら、異議を稱ふる次第にあらねば、止むことを得ずお請せり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "韓湘慰めて曰く、愴むこと勿れ、吾知る、公恙あらず、且つ久しからずして朝廷又公を用ふと。",
              "citation": {
                "source": "花間文字",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "讀む人、其の走るもの汽車に似ず、飛ぶもの鳥に似ず、泳ぐもの魚に似ず、美なるもの世の廂髮に似ざる故を以て、ちくらが沖となす勿れ。",
              "citation": {
                "source": "怪談会　序",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "足は天地に垂降するの足、手は地上に泳ぎて天上の泉をくむの手、諸君、肉身に供養せよ、諸君、おん手をして泥土にけがさしむる勿れ、詩人をして賤民の豚と交接せしむる勿れ、生活に淫する勿れ、手をして恆に高く頭上に輝やかしめ、肉身をして氷山の頂上に舞ひあがらしめよ、ああ、香料もて夕餐の卓を薫郁せしめよ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "・　感情に溺れる勿れ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが誤解する勿れ、著者は民衆に諂らうところの民衆主義者でなく、逆に彼等を罵倒し、軽蔑するところの民衆主義者だ。",
              "citation": {
                "source": "詩の原理",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝穢わしき物は何も食う勿れ。",
              "citation": {
                "source": "正義と微笑",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬祭の儀は、一に漢の文帝の如くにして異にする勿れ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝陵の山川は、其の故に因りて改むる勿れ、天下の臣民は、哭臨する三日にして、皆服を釈き、嫁娶を妨ぐるなかれ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "葬祭の儀は、漢の文帝の如くせよ、と云える、天下の臣民は哭臨三日にして服を釈き、嫁娶を妨ぐる勿れ、と云える、何ぞ倹素にして仁恕なる。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "文帝の如くせよとは、金玉を用いる勿れとなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孝陵の山川は其の故に因れとは、土木を起す勿れとなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "嫁娶を妨ぐる勿れとは、民をして福あらしめんとなり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "臣愚謂えらく、今｜宜しく其意を師とすべし、晁錯が削奪の策を施す勿れ、主父偃が推恩の令に効うべし。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "皇道を行きて入り、陛に登りて拝せざる等、不敬の事ありしかば、監察御史曾鳳韶これを劾せしが、帝曰く、至親問う勿れと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "信曰く、殿下｜爾したもう無かれ、まことに事あらば当に臣に告げたもうべし、殿下もし情を以て臣に語りたまわずば、上命あり、当に執われに就きたもうべし、如し意あらば臣に諱みたもう勿れと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "卓敬を容るゝ能わざりしも、方孝孺を殺す勿れと云いし道衍は如何の人ぞや。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "人生　須らく歓楽すべし、長に辛苦せしむる勿れ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "衍曰く、南に方孝孺あり、学行あるを以て聞ゆ、王の旗城下に進むの日、彼必ず降らざらんも、幸に之を殺したもう勿れ、之を殺したまわば則ち天下の読書の種子絶えんと。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "使君よ　去りたまふ勿れ、我が民の　父なり　母なり。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "学は　貴ぶ　日に随つて新なるを、慎んで　中道に廃する勿れ。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "孳々として　務めて践形し、負く勿れ　七尺の身に。",
              "citation": {
                "source": "運命",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "どういふつもりで付けたのかまだ訊ねてみないが、僕が勝手に想像する所では、無口でそつとしておいて貰ひたい男が、誰でもが多かれ少なかれ感じてはゐても余りに底深い、流れだとして殆んど全く触れないで過ぎる態の非情を、人目にも立たず浚渫してゐるといつた風の心得であらうと思ふ。",
              "citation": {
                "source": "詩集　浚渫船",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああ汝の肖像、われらおよばぬ至上にあり、金屬の中にそが性の祕密はかくさる、よしわれ祈らば、よしやきみを殺さんとても、つねにねがはくば、われが樂欲の墓場をうかがふなかれ、手はましろき死體にのび、光る風景のそがひにかくる。",
              "citation": {
                "source": "光る風景",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
