[
  {
    "uuid": "5c893a39-9e20-5641-a953-e5e1401c9777",
    "entry": "長襦袢",
    "reading": {
      "primary": "ながじゅばん",
      "alternatives": [
        "ながじばん"
      ],
      "is_heteronym": false
    },
    "grammar": {
