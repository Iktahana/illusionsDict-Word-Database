        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "何回か東京で引っぱられた。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてその間、池上の言う通り食気不振で、無理に勧められるようにして何回かおきみから椀の粥を食べさせられました。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは何回かこういう危機を冒してかの女を庇い通して来た。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "信玄は、その後も神色自若、孫子の旗と法性の旗をかざして牀几を動かず何事もなかりしが如く軍配をふって指揮したと云うが、あまりそうでもなかっただろう（後団扇を検したところ八個所の痕があったというからよほど何回かうちおろしているわけである）。",
              "citation": {
                "source": "川中島合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "目上の人の前では勿論、誰の前でも滅多に踊らないが、葛西氏には特に望まれて何回か踊つたことがある。",
              "citation": {
                "source": "断想的に",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、次の週もとうとうなんの発見もなく過ぎて、パリにはいつもある、警察への偏見が何回かの容易ならぬ暴動とまでなった。",
              "citation": {
                "source": "マリー・ロジェエの怪事件",
                "author": "『モルグ街の殺人事件』続編",
                "note": "青空文庫"
              }
            },
            {
              "text": "「蔵敷料の他に僕は何回かに渡つて自分の絵具料や食料を借り足してゐる。",
              "citation": {
                "source": "凩日記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "その種目の一つに即ち、幼児の首をとらへて高く釣りあげて、これを何回か繰り返すといふ他動的体操が含まれてゐた。",
              "citation": {
                "source": "余の倅に就いて",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしはどんなことがあっても、これを夫に知らせたくなかったものですから、博士から要求をきかねば公表するとおどされて、つい、その後も何回か博士の餌食になっていたのでございました。",
              "citation": {
                "source": "或る探訪記者の話",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに一年三組でも、彼は何回か袋叩きにあっています。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "慶一は、何回かこの街にきたことがあるが、方向がよくわからない。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうせ、何回か撮らないとダメだろう。",
              "citation": {
                "source": "45回転の夏",
                "author": "第１章　ローラーコースター、１９６６年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何回かやれば、うまくいくかも」「よし、じゃ、〈アイル・ゲチュー〉、テイク・ワン」　広岡が右足でカウントして、頭のベースラインを弾く。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたし、もう慶一さんをだますのはやめましょうって、何回か兄さんにいったのよ。",
              "citation": {
                "source": "45回転の夏",
                "author": "第３章　フルサークル、１９９１年",
                "note": "青空文庫"
              }
            },
            {
              "text": "時間を置いて、何回かにそれを分けた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はその頃何回か先生の私宅へも伺つたことを記憶して居る。",
              "citation": {
                "source": "井上先生",
                "author": "西田幾多郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は、友達とは何回かさういふ処へ行つたことがあるが、父と一処に酒に酔ふのが好きだつた。",
              "citation": {
                "source": "父の百ヶ日前後",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "もめている間にもなお何回かくきる鰊を抛棄してしまうことは、空しく宝の山を逃がすことだった。",
              "citation": {
                "source": "鰊漁場",
                "author": "島木健作",
                "note": "青空文庫"
              }
            },
            {
              "text": "極めて最近、特別ニュース放送が日に何回かされるような事情のもとにあっては特にそうであるが、それでなくても昭和七年頃から百万を突破してラジオ黄金時代に入ったというところに、大衆の社会的関心の全く独特な性格、方向が語られているのである。",
              "citation": {
                "source": "「ラジオ黄金時代」の底潮",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "毎日新聞のこの方法は、何回かの調査のうちに或る均衡を見出そうとするある試みであったかもしれないが、文化賞のための具体的根拠とはなり得なかった。",
              "citation": {
                "source": "しかし昔にはかえらない",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中には、女人芸術その他にもう何回か作品を発表していた人もあったし、もっとひどいのは既に過去数年間、文筆家として生活して来たような人も加えてあった。",
              "citation": {
                "source": "プロレタリア婦人作家と文化活動の問題",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "（昭和八年、私が検挙された頃、青楓氏は何回か私との関係を雑誌などに書かれた。",
              "citation": {
                "source": "御萩と七種粥",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうして全くの遁世の生活を、人里離れた大原山の雪深い所に送る様になってからもう長い間の時が経ち、何回かの春秋を送り迎えした解である。",
              "citation": {
                "source": "現代語訳　方丈記",
                "author": "鴨長明",
                "note": "青空文庫"
              }
            },
            {
              "text": "この人間の体躯の美しさをば、苦労のありたけを、つくして、説明しているその科学的にめんじて、法律は浮世絵の如く裸婦像をば禁じないのだろう、でも年に何回かは撤廃を見る事があるのは甚だ遺憾ではあるが、これは今の半ぱな世では致し方のない事かも知れない。",
              "citation": {
                "source": "楢重雑筆",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "展覧会を一年のうちに何回か眺めておけば、日本現代の油絵からフランス現代にいたるまでことごとく安値に観賞し尽すことが出来る。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "とにかくエンジンの動く甲板へ立ちさえすれば、われわれが幾枚かの絵を塗りつぶしている間に欧洲航路の船長は、甲板という地上の断片に乗って印度洋を何回か往復するのである。",
              "citation": {
                "source": "大切な雰囲気",
                "author": "大切な雰囲気",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何回かそれをいいかけましたが、やはりいえませんでした。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は何回か意識が覚めたりぼんやりとしたりしてゐるうちに、遂に夢路に引き入れられて行つた。",
              "citation": {
                "source": "道化芝居",
                "author": "北條民雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "これは神さまに誓って断然そうするのよ、どんなに望まれたってお嫁になんかいかなくってよ、ええ決して、――でも衣装は模様物なんか止すわ、どうせ一度きりですもの、それより秩父織とか紬とか実用向の物をたくさん作って頂くことだわ、でもそうするとお式にはなにを着たらいいかしら、ああ困った、心配だわ心配だわ……」",
              "citation": {
                "source": "風流化物屋敷",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あたいは学校なんかいかねえ。",
              "citation": {
                "source": "諜報部",
                "author": "A Secret Service",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
