[
  {
    "uuid": "ce480e02-eea4-5c10-9e58-79ff745a11ae",
    "entry": "鳴り出す",
    "reading": {
      "primary": "なりだす",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-サ行"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "to begin making a sound (ringing, singing, crying, etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "竹村君は外套の襟の中で首をすくめて、手持無沙汰な顔をして娘の脱ぎ捨てた下駄の派手な鼻緒を見つめていたが、店の時計が鳴り出すと急に店を出た。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "警報くらゐでは立ち上らぬのだが、高射砲が鳴り出すと、仕事をやめて、五歳の女の子に防空頭巾をかぶせ、これを抱きかかへて防空壕にはひる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち料理番が肉なり野菜なりを竈に仕かけて煮えるのを待っていると丁度よい時分には電気仕掛けのピアノが鳴り出す、その煮物に相応したような曲を奏するというのである。",
              "citation": {
                "source": "話の種",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "のんだら、胃と腸が、雷のように鳴り出すだろう。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "人びとのなかでは聞こえなくなり、夜更けの道で鳴り出すそれは、彼の心の象徴のように思えた。",
              "citation": {
                "source": "ある心の風景",
                "author": "梶井基次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "市役所の時計が十二時を打つと同時に隣のヨハン会堂の鐘が鳴り出す。",
              "citation": {
                "source": "先生への通信",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「パリの屋根の下」で二人の友がけんかをしようとするときに、こわれたレコードのガーガーと鳴り出すその非音楽的な不快な騒音が異常に象徴的な効果をもって場面のやまを頂上へと押し上げる。",
              "citation": {
                "source": "映画芸術",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "オルガンが鳴り出すと相島は昂然として腰掛から立上つたが、餘の人は坐つた儘で居る。",
              "citation": {
                "source": "半日",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "）帆綱の影はぬれたデックに落ち津軽海峡のときと同じどらがいま鳴り出す。",
              "citation": {
                "source": "『春と修羅』補遺",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらく聴いてゐて、良寛さんは、やうやくそれが、異人達の住んでゐる出島の寺から、鳴り出す夕の鐘の音であることがわかつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "日が暮れるまで……日本の憂鬱な十月の夜の彼岸に寂しい三味線がちんちんと鳴り出すまで、なほも善主麿、おおらつしよの祈をつづけながら……無益にも……月の方に青ざめた帆前の黒い幻想を眺めながら……",
              "citation": {
                "source": "北原白秋氏の肖像",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ある曲の解説を読み始めると、その歌が鳴り出すのだ。",
              "citation": {
                "source": "本の未来",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも日が暮れて、寺々のゆう六ツの鐘が鳴り出すと、丁度それを合図のようにどこからかふらふらと出て来る。",
              "citation": {
                "source": "半七捕物帳",
                "author": "あま酒売",
                "note": "青空文庫"
              }
            },
            {
              "text": "――そして再会を約して、わずかな間の立ちばなしから別れたのであつたが、それからといふもの次第にその作品のことがあたまに拡がりはじめ、左うすると、刻々に、その作中の人物やら場面やらが夢のやうに美しく怪く浮彫になつて来て、これはやはり、とても得難い作品であつたといふことが、震える胸に鳴り出すのであつた。",
              "citation": {
                "source": "痩身記",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっと緒に触れば鐘が鳴り出すようにしあって、不正の裁判を受けた者、この緒を動かし鐘を知事の頭上で鳴らすと、知事｜躬らその冤訴を聴き公平の処分をする。",
              "citation": {
                "source": "十二支考",
                "author": "鶏に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、称して怒鳴り出すのが常だつた。",
              "citation": {
                "source": "「悪」の同意語",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷が鳴り出すと、家に落ちついてゐられずに、よく雨を衝いて出かけた。",
              "citation": {
                "source": "迅雷",
                "author": "田山録弥",
                "note": "青空文庫"
              }
            },
            {
              "text": "船のあらゆる部分が急にカリッ、カリッと鳴り出すと、水に濡れていた甲板や手すりに、氷が張ってしまった。",
              "citation": {
                "source": "蟹工船",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "皆は、太いコンクリートの煙突から就業のボーが鳴り出すと、腕を組んでその狭い入口めがけて「ワッショ、ワッショ！",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "強弱々、強弱々――と、いとも原始的な淋漓たる韻を踏んで鳴り出すバルヂンの音響に打たれると（歌詞は私より他に知る者とてもなかつたが――。",
              "citation": {
                "source": "酒盗人",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「悪魔と悪魔でなければ、騒々しい音響が出ないではないか、悪魔同志の罵り合ひを聞かせたら、さすがの地の霊も眠りをさまたげられて怒鳴り出すであらう――といふ。",
              "citation": {
                "source": "変装綺譚",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "勿論小さい雷ならば構わないでしょうが、少し強い雷が鳴り出すと、屋敷の侍が早駕籠に乗ってよし原へ駈けつけて、お見舞の菓子折か何かをうや／＼しく花魁に献上するというわけです。",
              "citation": {
                "source": "三浦老人昔話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "その自然に鳴り出すのは夜に限られていた。",
              "citation": {
                "source": "半七捕物帳",
                "author": "半鐘の怪",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の彼方では勇しく号鐘が鳴り出す。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "雷みたいな奴よ、雲次第で何時でも鳴り出す……。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ドヾドコドン、ドコドン――）と新しく太鼓が鳴り出す。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "（ドヾドコドン、ドコドン――）と新しく太皷が鳴り出す。",
              "citation": {
                "source": "鳥影",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "壁の彼方では勇しく號鐘が鳴り出す。",
              "citation": {
                "source": "足跡",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "ぢいつと茫然黄昏の中に立つて、なんだか父親の映像が気になりだすと一歩二歩歩みだすばかりです深夜の思ひこれは泡立つカルシウムの乾きゆく急速な――頑ぜない女の児の泣声だ、鞄屋の女房の夕の鼻汁だ。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "あまり凝りすぎてもからだにさわるから午前だけにしたいと思ったが、午前中に一段片付けたつもりで昼飯を食いながらながめていると間違った所が目について気になりだす、もう一筆と思ううちにとうとう午後の時間が容赦なくたってしまう。",
              "citation": {
                "source": "自画像",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
