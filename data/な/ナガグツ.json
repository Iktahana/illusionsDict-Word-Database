        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "ゴム長靴の脛だけの部分、アラビアンナイトの粟粒のような活字で埋まった、表紙と本文の半分以上取れた英訳本。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近付いて見ると、一人のせいの高い、ひどい近眼鏡をかけ、長靴をはいた学者らしい人が、手帳に何かせわしさうに書きつけながら、鶴嘴をふりあげたり、スコープをつかったりしてゐる、三人の助手らしい人たちに夢中でいろいろ指図をしてゐました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、黄いろなゴムの長靴をはいて、脚をきちんとそろえて、まっすぐに立って云いました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "グラドストーンは雪が長靴の革を滲透する特殊な力があるということを主張した。",
              "citation": {
                "source": "レーリー卿（Lord Rayleigh）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕は、大にこの好詩人を愛敬し、以後「露西亞長靴」といふニツクネームで呼ぶことにした。",
              "citation": {
                "source": "歳末に近き或る冬の日の日記",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ルーマニアの士官がネグロの楽隊に剣を腰から抜いて長靴を鳴らして見せました。",
              "citation": {
                "source": "バルザックの寝巻姿",
                "author": "吉行エイスケ",
                "note": "青空文庫"
              }
            },
            {
              "text": "地上には無数の長靴と空間には驢馬が犇めいていた。",
              "citation": {
                "source": "恋の一杯売",
                "author": "Love on Drought",
                "note": "青空文庫"
              }
            },
            {
              "text": "その顔は緊張して横柄で、大きな長靴は、足のさきにある何物をも踏みにじって行く権利があるものゝようだった。",
              "citation": {
                "source": "穴",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "聯隊の二階では、長靴に拍車をつけたエライ人が、その拍車をがち／＼鳴らしながら、片隅の一室に集って何か小声で話し合った。",
              "citation": {
                "source": "氷河",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして、河岸へ這い上ると、それぞれの物を衣服の下や、長靴の中にしのばして、村の方へ消えて行った。",
              "citation": {
                "source": "国境",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　そして彼は、イワンに橇を止めさせると、すぐとびおりて、中隊長と云い合っている吉原の方へ雪に長靴をずりこませながら、大またに近づいて行った。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の長靴は雪に取られそうになった。",
              "citation": {
                "source": "橇",
                "author": "黒島伝治",
                "note": "青空文庫"
              }
            },
            {
              "text": "汚れた黒い毛皮のコサック帽も、革の長靴も、腰がだぶつき、膝がしまっている青鼠のズボンも、昔に変らぬものを、彼等は、はいていた。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "やがて、何分間かたつと、せいのひくい、毛並のきたない、支那馬にまたがった白露兵がぐったりして、長靴を、地上に引きずりそうに、だらりと垂れて、薄暗い街燈の光の中に姿を現わした。",
              "citation": {
                "source": "武装せる市街",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兎はつひにつぐのはね、　　　ひとは頬あかく美しければ、べつ甲ゴムの長靴や、　　　　緑のシャツも着くるなり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たしかに茶いろのポケットの沢山ついた上着を着て長靴をはいてゐる。",
              "citation": {
                "source": "花椰菜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長靴を抱くようにして急いで脱って、少しびっこを引きながら、そのまっ暗なちらばった家にはね上って行きました。",
              "citation": {
                "source": "ガドルフの百合",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近付いて見ると、一人のせいの高い、ひどい近眼鏡をかけ、長靴をはいた学者らしい人が、手帳に何かせわしそうに書きつけながら、鶴嘴をふりあげたり、スコープをつかったりしている、三人の助手らしい人たちに夢中でいろいろ指図をしていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "頭巾黒く、外套黒く、面を蔽い、身体を包みて、長靴を穿ちたるが、わずかに頭を動かして、屹とその感謝状に眼を注ぎつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "赤い服、白い袴、黒い長靴の騎手の姿が樹の間を縫うて嵐のように通り過ぎる。",
              "citation": {
                "source": "ある幻想曲の序",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "あばれる子熊の横顔へ防寒｜長靴をはいた人間の足がいくつも飛んで来る。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "北氷洋の白熊は結局、カメラも鉄砲も繩も鎖もウインチも長靴も持っていなかったために殺され生け捕られたに過ぎないように思われる。",
              "citation": {
                "source": "空想日録",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゴム長靴が、どうにも異様だと言うのである。",
              "citation": {
                "source": "服装に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "海に沿った雪道を、私はゴム長靴で、小川君はきゅっきゅっと鳴る赤皮の短靴で、ぶらぶら歩きながら、「軍隊では、ずいぶん殴られましてね。",
              "citation": {
                "source": "母",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だんだん近づいて見ると、一人のせいの高い、ひどい近眼鏡をかけ、長靴をはいた学者らしい人が、手帳に何かせわしそうに書きつけながら、つるはしをふりあげたり、スコップをつかったりしている、三人の助手らしい人たちに夢中でいろいろ指図をしていました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "長靴のタールもなにももうめちゃくちゃになってるんだ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「おまえは英語はわかるかい、ね、センド、マイブーツ、インスタンテウリイすぐ長靴送れとこうだろう、するとカルクシャイヤのおやじめ、あわてくさっておれのでんしんのはりがねに長靴をぶらさげたよ。",
              "citation": {
                "source": "月夜のでんしんばしら",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "さっきから一心に跡けて来た巨きな、蟇の形の足あとはなるほどずうっと大学士の足もとまでつゞいてゐてそれから先ももっと続くらしかったがも一つ、どうだ、大学士の銀座でこさへた長靴のあともぞろっとついてゐた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その男は、黄いろなゴムの長靴をはいて、脚をきちんとそろへて、まっすぐに立って云ひました。",
              "citation": {
                "source": "耕耘部の時計",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところへ、その子のながぐつは、やけにやかましくギュウ、ギュウなるのですが、いっこうにへいきでした。",
              "citation": {
                "source": "雪の女王",
                "author": "SNEDRONNINGEN",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
