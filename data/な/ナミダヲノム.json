          "literary": [
            {
              "text": "天使も時に哀しめども蛇は地上に這ひて泣かず、感傷の人は恆に地に立ちて涙をのむ。",
              "citation": {
                "source": "散文詩・詩的散文",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」隆造が落着いて斯う云ふと、叔母は子供のやうに涙をのむでたゞウン／＼と点頭いて居た。",
              "citation": {
                "source": "白明",
                "author": "牧野信一",
                "note": "青空文庫"
              }
            },
            {
              "text": "涙をのむのに骨を折りながら、奥さんと二時間あまり話した。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            }
