    "definitions": [
      {
        "index": 1,
        "gloss": "auxiliary verb indicating the speaker's personal recollection or something they've heard (e.g. \"was\", \"wasn't it?\", \"is said to have ...\", etc.)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
