        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "校庭宮沢賢治さ霧する白き木柵幹彫れる桐のいくもと剥げそめし白きペンキの木柵に人人は倚りそのペンキあるいは剥げあるものは庭をのぞめり一鐘のラッパが鳴りて急ぎ行く港先生白堊城秋のガラスはひらごとにうつろなりけり",
              "citation": {
                "source": "校庭",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "この句の第三句は、多くの句集に「なりけり」となってるが、平安朝の言葉をもじった「なんめり」の方が、この場合ユーモラスで面白い。",
              "citation": {
                "source": "郷愁の詩人　与謝蕪村",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "北の屋蔭の苔むしたる井筒に、新調の洋服涼しげなる若人二人、巴里形の麥藁帽子見よげにかぶりて、細き櫻のステツキを手すさびに振り上げ、花もまだきなる紫陽花の葉を叩きつ、あやめを隔ててこなた、うちまもり給へるなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "切符賣る家の闇きらんぷの火影に見れば、先きほど隣室にてなやみし、醉ひしれたるをのこなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "潮入時なりければ、流を下るが却りて水に逆らふなりけり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "IIIIいといと淡き今日の日は雨｜蕭々と降り洒ぎ水より淡き空気にて林の香りすなりけり。",
              "citation": {
                "source": "山羊の歌",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "年々にわが悲しみは深くして　　いよよ華やぐいのちなりけり",
              "citation": {
                "source": "老妓抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "業平の、駿河なるうつの山辺のうつゝにも夢にも人にあはぬなりけり、あの昔の宇都の山ですね。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の欲を金に集めて、十五｜年がほどの足掻きかたとては、人には赤鬼と仇名を負せられて、五十に足らぬ生涯のほどを死灰のやうに終りたる、それが餘波の幾万金、今の玉村恭助ぬしは、其與四｜郎が聟なりけり。",
              "citation": {
                "source": "われから",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "二ツ三ツ四ツ、八時か、否、九時になりけり。",
              "citation": {
                "source": "軒もる月",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "いと恥かしうて、これ習ひ得ざらんほどはと、家に近き某の社に日参といふ事をなしける、思へばそれも昔しなりけり。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "イギリスの有名な詩人の詩に「童なりけり」というがあります。",
              "citation": {
                "source": "春の鳥",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "〔月のほのほをかたむけて〕月のほのほをかたむけて、　　　水杵はひとりありしかど、搗けるはまこと喰みも得ぬ、　　渋きこならの実なりけり。",
              "citation": {
                "source": "文語詩稿　五十篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "学校の、　　ガラス片ごとかゞやきて、　　あるはうつろのごとくなりけり。",
              "citation": {
                "source": "文語詩稿　一百篇",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "はやその谷川の音を聞くと我身で持余す蛭の吸殻を真逆に投込んで、水に浸したらさぞいい心地であろうと思うくらい、何の渡りかけて壊れたらそれなりけり。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "われはハヤゆうべ見し顔のあかき老夫の背に負われて、とある山路を行くなりけり。",
              "citation": {
                "source": "龍潭譚",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "時に、其の夜の事なりけり。",
              "citation": {
                "source": "甲冑堂",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゆえに渠は泰然と威厳を存して、他意なく、懸念なく、悠々としてただ前途のみを志すを得るなりけり。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語は皆まことにもあらぬを、おもへば我も彼男に劣らずおろかなる思ひを馳せたるかな、と後に自からあざ笑ひけるも、今またおもへば、それもことさらに我賢からんと願ひたるやうにていよ／＼おろかなることなりけり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "熊谷直好の和歌に、よもすから木葉かたよる音きけは　　　しのひに風のかよふなりけりというがあれど、自分は山家の生活を知っていながら、この歌の心をげにもと感じたのは、じつに武蔵野の冬の村居の時であった。",
              "citation": {
                "source": "武蔵野",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "身を切るような風吹きて霙降る夜の、まだ宵ながら餅屋ではいつもよりも早く閉めて、幸衛門は酒一口飲めぬ身の慰藉なく堅い男ゆえ炬燵へ潜って寝そべるほどの楽もせず火鉢を控えて厳然と座り、煙草を吹かしながらしきりに首をひねるは句を案ずるなりけり。",
              "citation": {
                "source": "置土産",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "草を吹く風の果てなり雲の峰　娘十八｜向日葵の宿死んで行く人の片頬に残る笑　秋の実りは豊かなりけりこんな連続をもってこの一巻の「歌仙式フィルム」は始まるのである。",
              "citation": {
                "source": "映画雑感（１）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "渠はその壮時において加賀の銭屋内閣が海軍の雄将として、北海の全権を掌握したりし磁石の又五郎なりけり。",
              "citation": {
                "source": "取舵",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼者迷惑して、「つひに獻立を仕りたる覺えござなく、其道は聊も心得候はねば、不調法に候、此儀は何卒餘人に御申下さるべし」と困じたる状なりけり。",
              "citation": {
                "source": "十萬石",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "どぶろくも早や傾いて、殘るは芋※の酢和なりけり。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "こは後より追々にし出ださんずる悪計の、人に知られんことを恐れしなりけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "聞覚えのある声はそれ、とお録内より戸を開けば、外よりずっと入るは下男を連れたる紳士なりけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "されば得三が引返し来て、被の上より突込みたるは、下枝にあらで人形なりけり。",
              "citation": {
                "source": "活人形",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
