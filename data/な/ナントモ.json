        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "僕は僕を何とも思はぬ！",
              "citation": {
                "source": "蝉",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――一体自分の評判は好いのか悪いのかと自問してみると何とも決りが着かなかつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　耕二は何とも言ひ出しさうではなかつた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "室生犀星氏がいつか或る随筆で書いてゐたが、仕事の終つた後で、きれいに机を片づけ、硯に墨をすりながら静かに句想を練る気持は、何とも言へない楽しみだと。",
              "citation": {
                "source": "小説家の俳句",
                "author": "俳人としての芥川龍之介と室生犀星",
                "note": "青空文庫"
              }
            },
            {
              "text": "裏町の溝を流れる湯の匂ひや、朧ろにかすむ紅色の軒灯や、枕に近い湯滝の音やが、何とも言へぬ春らしい感じを起させる。",
              "citation": {
                "source": "石段上りの街",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうした町を歩いている時に何とも知れぬ不思議な匂いがした。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "重兵衛さんの細君は喘息やみでいつも顔色の悪い、小さな弱々しいおばさんであったが、これはいつも傍で酌をしたり蚊を追ったりしながら、この人にはおそらく可笑しくも何ともない話を子供と一緒に聴きながら一緒に笑っているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "なお面白いのは日が高くなるにつれて椎茸が次第に縮んで、おしまいにはもう椎茸とも何とも分らぬものになって石ころ道の上を飛び飛び転がって行く。",
              "citation": {
                "source": "車",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の花の香もせぬ常闇の国に永劫生きて、ただ名ばかりに生きていなければならぬかと思うと、何とも知れぬ恐ろしさにからだがすくむ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "おまへの故郷の方には、小生の家の方から別に何とも言ふわけで無し、誰にも知れる氣づかひは無いのだから、安心して一度たづねてやつて下さい。",
              "citation": {
                "source": "このごろ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "馴れてくると、この薄暗いのが、何とも言へずやはらかく心を休めてくれる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "どうもあの爺さんの顏を見ると、おれは何とも言へず不愉快になる。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "狸はたちまち七轉八倒して、「ううむ、何ともない。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "このメデウサの姿をひとめ見た者は、何とも知れずいやな氣持になつて、さうして、心臟が凍り、からだ全體つめたい石になつたといふ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "一向におそろしくも何とも無い。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "實に何とも、つまらない女だ。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "その立体構成面の威嚇的偉大さを、駭くべき簡単なる曲線で、統整して、しかも委曲に至っては、富士で謂うところの八百八谷の線から、おのずと発生する凹凸面の、複雑なる入り乱れのために、眼もあやになることを如何ともしがたい。",
              "citation": {
                "source": "火と氷のシャスタ山",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "小作人どもは、ワイワイ云ってるだけで、何とも手の下しようがなかった。",
              "citation": {
                "source": "乳色の靄",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "（だが、何とも為方はないさ。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "二十銭では何ともならない。",
              "citation": {
                "source": "生爪を剥ぐ",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "其の人形の色彩から何からが何とも云へない陰慘なものである。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "池の對岸の石垣の上には竹藪があつて、其の中から一本の大榎が聳えて居るが、其の梢の紅や黄を帶びた色彩が何とも云はれない美しい。",
              "citation": {
                "source": "寫生紀行",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しばらくすると真赤な血のような色の何とも知れぬものが暗黒の中に現れる。",
              "citation": {
                "source": "赤",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の癖に」　山の祖神のこういうたしなめ方に対し福慈の女神はもう何ともいわなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何とも知れない鳥の声が、瀬戸物の破片を擦り合すような鋭い叫声を立てている。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その味が自分たちのような、情味に脆い性質の人間を痺らせるのだろうと思いますよ」　強いて同感を求めるような語気でもないから、私は何とも返事しようがない気持をただ微笑に現して頷いてだけいた。",
              "citation": {
                "source": "東海道五十三次",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "傍で見ていると、何とも云えず幸福そうに見える。",
              "citation": {
                "source": "異国食餌抄",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そういうあたりまえのことにひょいと気がつくと何とも知れない涙が眼の奥から浸潤み出るのだ。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "リゼットは怖くも何とも無かった。",
              "citation": {
                "source": "売春婦リゼット",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "その小さな列車の窓は一列小さく赤く見え、その中にはたくさんの旅人が、苹果を剥いたり、わらったり、いろいろな風にしてゐると考へますと、ジョバンニは、もう何とも云へずかなしくなって、また眼をそらに挙げました。",
              "citation": {
                "source": "銀河鉄道の夜",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            }
          ]
        }
