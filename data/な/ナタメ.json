[
  {
    "uuid": "a54f6327-a5c0-5a75-9525-062c7460ce0d",
    "entry": "鉈目",
    "reading": {
      "primary": "なため",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
