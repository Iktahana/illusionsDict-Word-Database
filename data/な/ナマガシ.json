    "definitions": [
      {
        "index": 1,
        "gloss": "fresh Japanese sweets (usu. containing red bean paste)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "」と云いながら達二は鳥を見ましたら、鳥はいつか、萌黄色の生菓子に変っていました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "生菓子をいろいろ、四角で扁平な漆塗りの箱に入れたのを肩にかけて、「カエチョウ、カエチョウ」と呼び歩くのは、多くは男の子で、そうして大概きまって尻の切れた冷飯草履をはいていたような気がする。",
              "citation": {
                "source": "物売りの声",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と云ひながら達二は鳥を見ましたら、鳥はいつか、萌黄色の生菓子に変ってゐました。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつでも上等の生菓子を出された。",
              "citation": {
                "source": "夏目漱石先生の追憶",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "お八ツ時分になると、甘党の松島は卓上電話で紅谷から生菓子を取り寄せ、玉露を煎れて呑んでいたが、晩餐には姐さんのためにてんやものの料理が決まって二三品食卓に並び、楽しい食事が始まるのだったが、彼自身は口がきわめて質素で、ひじきや煮豆で済ますのであった。",
              "citation": {
                "source": "縮図",
                "author": "徳田秋声",
                "note": "青空文庫"
              }
            },
            {
              "text": "饅頭、煎餅、豆平糖、おはぎ、生菓子、黒砂糖飴、白紙に包んだおすし、強飯なぞを中位の風呂敷一パイぐらい。",
              "citation": {
                "source": "梅津只圓翁伝",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ガラス製の立派な箱が十五、六、その広い鋪に並べてあって、その中には、外国人がクリスマスに食べるようなパイや、その他種々な生菓子が並べてあると、一方の棚の中には、栗饅頭や、金つばや、鹿の子などという東京風の蒸し菓子が陳列してあった。",
              "citation": {
                "source": "海に生くる人々",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "三人に鵜殿家から鮨と生菓子とを贈った。",
              "citation": {
                "source": "護持院原の敵討",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と佐佐は云って生菓子を一つ摘まんだ。",
              "citation": {
                "source": "旅愁",
                "author": "横光利一",
                "note": "青空文庫"
              }
            },
            {
              "text": "見事な味で、その他、鮪、豆腐、なめこ、黄菊、天麩羅、生菓子、いくら等。",
              "citation": {
                "source": "夜の靴",
                "author": "――木人夜穿靴去、石女暁冠帽帰（指月禅師）",
                "note": "青空文庫"
              }
            },
            {
              "text": "砂糖の塔、生菓子、麦藁のパイプを入れた曹達水のコップなどの向うに人かげが幾つも動いている。",
              "citation": {
                "source": "浅草公園",
                "author": "――或シナリオ――",
                "note": "青空文庫"
              }
            },
            {
              "text": "がこれでまだ、発つ朝に塩瀬へでも寄って生菓子を少し仕入れて行かなくちゃ……」　壁の衣紋竹には、紫紺がかった派手な色の新調の絽の羽織がかかっている。",
              "citation": {
                "source": "遁走",
                "author": "葛西善蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "芸者屋、料理屋、待合風の家、その間に、寿司や、蕎麦や、生菓子やなどが軒を並べ、その何れもが、支那風の建物に入口だけ格子や暖簾をくつつけてゐる異様な風景は、ちよつと他の租界では見られまい。",
              "citation": {
                "source": "北支物情",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "第三十八　米のソフレ　は膨んだ生菓子です。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四十二　パンのカビネットプデン　は頗る上等の生菓子です。",
              "citation": {
                "source": "食道楽",
                "author": "秋の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "昨日生菓子を持ってかえって来て一つくれたが、まず甘い方であって、幻滅のおそれはなきものだった。",
              "citation": {
                "source": "海野十三敗戦日記",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "その実の形はちょうど彼の生菓子のカノコに似て、その赤い実が秋から冬へかけその長梗で蔓から葉間に垂れ下がっている風情、なかなかもって趣きのある姿である。",
              "citation": {
                "source": "植物一日一題",
                "author": "牧野富太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "放二の部屋には、ルミ子や八重子や数人の女たちが、生菓子と果物をたべていた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の店ではその日に売る生菓子は常に午後三時のお八ツまでを限りに売り切るように製造致します。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "これより甚だしいのは半日か一日ぐらいしか保たない生菓子を注文しておきながら急に不用になったという場合。",
              "citation": {
                "source": "私の小売商道",
                "author": "相馬愛蔵",
                "note": "青空文庫"
              }
            },
            {
              "text": "その毒は、晝頃食べた生菓子の餡の中に入つて居たのではあるまいかと――言ひますが、確かなことは判りません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衞は茶が好きだつたのと、朝から晝までの食物で、一人で食べたのは、その生菓子の外にはなかつたといふところまで判つたのでした。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶の相手をしたのは女房のお峯ですが、それは金米糖か何かを一粒口に入れただけで、生菓子は食べなかつたと自分で言つて居ります。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、生菓子へ入れた毒も、その時お峯が入れたとは限らないわけで、一刻も二刻も前に入れて置いても、七兵衞が喰ふに決つた菓子だつたのです。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "生菓子へ入れた毒は、其邊の藪に澤山ある×××××だ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その毒は、昼頃食べた生菓子の餡の中に入っていたのではあるまいかと――言いますが確かなことは判りません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "七兵衛は茶が好きだったのと、朝から昼までの食物で、一人で食べたのは、その生菓子の外にはなかったというところまで判ったのでした。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "お茶の相手をしたのは女房のお峯ですが、それは金米糖か何かを一粒口に入れただけで、生菓子は食わなかったと自分で言っております。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もう一つ、生菓子へ入れた毒も、その時お峯が入れたとは限らないわけで、一刻も二刻も前に入れておいても、七兵衛が喰うに決った菓子だったのです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "謎の鍵穴",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
