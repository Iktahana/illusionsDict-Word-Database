    "definitions": [
      {
        "index": 1,
        "gloss": "any- (e.g. anything, anywhere, anyone)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
