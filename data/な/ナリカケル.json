        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "声もかすかに呼びつれ呼び交すうちに、ふとわたくしはあのお雛妓のかの子さんの若さになりかける。",
              "citation": {
                "source": "雛妓",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「はア……」新子は、危うく涙になりかけるほど、有頂天な嬉しさに浸っていた。",
              "citation": {
                "source": "貞操問答",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ暑くなりかける頃だつた。",
              "citation": {
                "source": "我等の一團と彼",
                "author": "石川啄木",
                "note": "青空文庫"
              }
            },
            {
              "text": "脂ぎつた顔が河馬のやうにだらしなくなりかけると、客足は現金なもので毎日のやうに寂れ出した。",
              "citation": {
                "source": "茶話",
                "author": "大正五（一九一六）年",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のことはない、遊興してよい気持になりかけると入りかわり立ちかわり借金取りが現われるようなものである。",
              "citation": {
                "source": "私の活動写真傍観史",
                "author": "伊丹万作",
                "note": "青空文庫"
              }
            },
            {
              "text": "短篇小説は、職場の意識の低い男が飛びやになりかける。",
              "citation": {
                "source": "「鎌と鎚」工場の文学研究会",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そろそろ熱くなりかける時分のことで、教会堂風な窓々から明く射しこんで来る五月の日の光のみが残った。",
              "citation": {
                "source": "新生",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "フーマン自身もそれを知り、何か状態が複雑になりかけると、自分の単純な激情に駆られる性質を恐れるように、冷静な、狡智に長けたバーマンを傍に持とうとする。",
              "citation": {
                "source": "古き小画",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "昼間は至つて穏かで、さらさら幽霊の気配などはありましねえのに、あたりが薄暗くなりかけるてえと、どうでがせう。",
              "citation": {
                "source": "ディカーニカ近郷夜話　前篇",
                "author": "VECHERA NA HUTORE BLIZ DIKANIKI",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに亭主が遺いて行った銭もなくなりかけるし、女房は弱りきっていた。",
              "citation": {
                "source": "世間師",
                "author": "小栗風葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小さい時から、冬になりかけるとよく歯が痛んだものだ。",
              "citation": {
                "source": "新版　放浪記",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私は小さい時から、冬になりかけると、よく歯が痛んだ。",
              "citation": {
                "source": "放浪記（初出）",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "私はややもするとクラクラとなりかける心を叱り付けながら、未亡人の枕元に光っている銀色の鋏を取り上げた。",
              "citation": {
                "source": "一足お先に",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕日がしづんで、うすぐらくなりかけるまで、エミリアンはひきつゞけました。",
              "citation": {
                "source": "エミリアンの旅",
                "author": "豊島与志雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を渡つたりしてそろそろのぼりになりかけると、細い雨が降つて来た。",
              "citation": {
                "source": "遍路",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "……　もう夜になって、少年がそろそろ睡くなりかける時分から、見知らないお客たちが四五人きては、みんな奥の間にはいって、しばらく父や母をまじえて、あかるい、らちのない笑い声を立てているが、そのうちきまって急にひっそりとしてしまう。",
              "citation": {
                "source": "幼年時代",
                "author": "堀辰雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "それをなお見つめていると今度は視覚が鈍くなって多少ぼんやりし始めるのだからいったん上の方へ向いた意識の方向がまた下を向いて暗くなりかける。",
              "citation": {
                "source": "現代日本の開化",
                "author": "――明治四十四年八月和歌山において述――",
                "note": "青空文庫"
              }
            },
            {
              "text": "夕方、薄暗くなりかける頃、見張っていますと、ほんとに蝙蝠がひらりひらりと、椎の木の蔭に飛んでることがありました。",
              "citation": {
                "source": "古木",
                "author": "――近代説話――",
                "note": "青空文庫"
              }
            },
            {
              "text": "川を渡ったりしてそろそろのぼりになりかけると、細い雨が降って来た。",
              "citation": {
                "source": "遍路",
                "author": "斎藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "思はず先生自らがマッカになりかけるのをゴマかすためにカストリをガブリとのみすぎて、むせてしまつた。",
              "citation": {
                "source": "破門",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのニヤニヤがなんとなく色好みらしく、その気がある様子に見えてカン違ひをする客もあり、おい泊りに行かうなどゝ札束をみせて意気込んでくる五十男があつたりすると、まつたくもう泊つてやらうか、金のためには何でもするといふやうな気持にもなりかけるほどだつた。",
              "citation": {
                "source": "金銭無情",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "「人に盗まれる筈のないものだと思うが、お前の記憶ちがいじゃないか」　こう云われて政子は気色ばみ、あわや兄妹の喧嘩になりかける形勢に、年功の周信、これはマズイと悟ったらしく、にわかに切りあげて、三人組は荷車と一しょに引き上げてしまったのである。",
              "citation": {
                "source": "明治開化　安吾捕物",
                "author": "その十九　乞食男爵",
                "note": "青空文庫"
              }
            },
            {
              "text": "思わず夢心地になりかけると、フッと溜息がでて、涙がにじんでしまうのである。",
              "citation": {
                "source": "現代忍術伝",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "バカの代表が身をもって証した事実を利用するのが、利巧者の生き方ですよ」　長平がこう結んで、幕をおろしたツモリになりかけると、無言をやぶって、礼子がきいた。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "日の出の五十分くらい前から東の地平線の空が、少し明かるくなりかける。",
              "citation": {
                "source": "黒い月の世界",
                "author": "中谷宇吉郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "気のまよいかなと、夫人がよこになりかけると、となりの部屋から、ぱたぱたと、はだしで歩く足音がはっきりときこえた。",
              "citation": {
                "source": "透明人間",
                "author": "ハーバート・ジョージ・ウエルズ",
                "note": "青空文庫"
              }
            },
            {
              "text": "まあ、それはそれとして、久しぶりで会つたんだから、一緒に飯でも食おうか」「…………」　強いて反対もしないので、上野のさる中華料理店でビールを飲み、すこし打ち融けた気分になりかけると、急に、弟の深志はむつつり口を噤んでしまう。",
              "citation": {
                "source": "光は影を",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
