    "definitions": [
      {
        "index": 1,
        "gloss": "southern mountains",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "下宿と其周囲道具屋、薬屋、南山堂、神田書店、夜の読書、詩作、篠田と其婆の一件。",
              "citation": {
                "source": "我が生活",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "――　紅葉先生、その時の態度は……采菊東籬下、悠然見南山。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏郷は白河をば関｜右兵衛尉、須賀川をば田丸｜中務少輔、阿子が嶋をば蒲生源左衛門、大槻を蒲生忠右衛門、猪苗代を蒲生四郎兵衛、南山を小倉孫作、伊南を蒲生左文、塩川を蒲生喜内、津川を北川平左衛門に与えて、武威も強く政治も届く様子だから、政宗も迂闊に手を掛ける訳にはゆかぬ。",
              "citation": {
                "source": "蒲生氏郷",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "三十七八年役に南山を攻撃した兵卒の中に、敵の砲弾を受けながら、高梁の畑で糞をしたものがある。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "南山の竹は揉めずして自ら直く、斬ってこれを用うれば犀革の厚きをも通すと聞いている。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "汝の云うその南山の竹に矢の羽をつけ鏃を付けてこれを礪いたならば、ただに犀革を通すのみではあるまいに、と孔子に言われた時、愛すべき単純な若者は返す言葉に窮した。",
              "citation": {
                "source": "弟子",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "正行の活動　延元四年の秋、後醍醐天皇は吉野の南山｜行宮に崩御せられた。",
              "citation": {
                "source": "四条畷の戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時政利が用いた刀に羅山銘を作りて南山と名づく、周処が白額虎を除いた故事に拠ると出づ、『菅氏世譜』に政利寛永六年五十九歳で歿したとあるから、文禄中虎を斬った時は三十四、五の時だ。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "問う、何を以てこれを知ると、曰く、さきに南山の虎嘯を聞きて知るのみと、俄に使至る〉。",
              "citation": {
                "source": "十二支考",
                "author": "虎に関する史話と伝説民俗",
                "note": "青空文庫"
              }
            },
            {
              "text": "支那にも似た事ありて『南山経』や『列子』に〈類自ら牝牡を為す、食う者妬まず〉、類は『本草綱目』に霊狸の事とす。",
              "citation": {
                "source": "十二支考",
                "author": "兎に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "約束の通りに少女をあたえると、犬は彼女を伴って南山にのぼった。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "捜神記（六朝）",
                "note": "青空文庫"
              }
            },
            {
              "text": "梨園の弟子のうちに笛師があって、これも都を落ちて終南山の奥に隠れていた。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "白猿伝・其他",
                "note": "青空文庫"
              }
            },
            {
              "text": "学問をしても何の益も無い、南山の竹の真直ぐで強いものは、そのまま斬って矢として使えば、厚く強い革さえ通す。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時、お叱りも無く、「其方は、そう思うかも知れないが、その素性の良い南山の竹に、矢筈というものを取りつけて、矢羽というものをつけ、刃味の良い鏃というものをつけて、これを研ぎ澄まし、そして射放てば、矢の入ることも一層深いであろう、どうじゃ。",
              "citation": {
                "source": "悦楽（現代訳）",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ただし『今昔物語』十一や『弘法大師｜行化記』に、大師初めて南山に向った時、二黒犬を随えた猟人から唐で擲げた三｜鈷の行き先を教えられたとあり、この黒犬が大師を嚮導したらしいから、本邦では黒犬を凶物とせなんだらしい。",
              "citation": {
                "source": "十二支考",
                "author": "犬に関する伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "この地方が初めて平定した時、四方を巡回して南山の深いところへ分け入ると、日もようやく暮れかかって来た。",
              "citation": {
                "source": "中国怪奇小説集",
                "author": "閲微草堂筆記（清）",
                "note": "青空文庫"
              }
            },
            {
              "text": "わが沒理想は南山の壽の如く、かげず崩れざるべく、不壞金剛の磐石の如く、芥子劫に亙りて依然たるべし。",
              "citation": {
                "source": "柵草紙の山房論文",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "全唐紙に「如南山寿、不騫不崩」の八字が二行に大書してある。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "（梅道士水亭）払衣去何処、高枕南山南。",
              "citation": {
                "source": "閑人詩話",
                "author": "河上肇",
                "note": "青空文庫"
              }
            },
            {
              "text": "東坡の其の決して南山を望むに非ざるを知る所以なり。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "「采菊東籬下、悠然見南山。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし望南山となせば便ち興味索然たるを覚ゆ」。",
              "citation": {
                "source": "放翁鑑賞",
                "author": "その七　――放翁詩話三十章――",
                "note": "青空文庫"
              }
            },
            {
              "text": "南山見｜来れば常に悠々。",
              "citation": {
                "source": "骨董羹",
                "author": "―寿陵余子の仮名のもとに筆を執れる戯文―",
                "note": "青空文庫"
              }
            },
            {
              "text": "最後に夏目漱石先生の南山松竹を見て、同じく又敬意を表した。",
              "citation": {
                "source": "俳画展覧会を観て",
                "author": "芥川龍之介",
                "note": "青空文庫"
              }
            },
            {
              "text": "下の級は、寿とか、福とか、むずかしくなると、三字、五字、七字――南山寿とか、百尺竿頭更一歩進とかいうのだった。",
              "citation": {
                "source": "旧聞日本橋",
                "author": "蕎麦屋の利久",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼自らは「琉球産物誌」「南山俗語考」「成形図説」を著し、洋学者を招聘し、鹿児島の文化に、新彩を放たしめたが、然し、それは悉く、多大に金のかかることであった。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "午後は西田君と南山の麓にある大連神社の祭礼を一拝した。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "金州以北の記（與謝野晶子）南山　十六日の朝、加藤郁哉さんと三人で満鉄本線の急行列車に乗り、大連を出立した。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "金州駅へ下りると、駅長の厚意で日本語の出来る支那人の青年駅夫を案内として馬車に載せ、先づ附近にある南山に、日清日露両役の戦跡を訪うた。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            },
            {
              "text": "南山は金州平野の一部にある低い丘陵地で、小松の中に白い御影石の記念碑が建つてゐる。",
              "citation": {
                "source": "満蒙遊記",
                "author": "附　満蒙の歌",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
