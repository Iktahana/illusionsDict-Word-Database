        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "孤高を以て任ずるなどといふのぢや尚更ない。",
              "citation": {
                "source": "夏と悲運",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "衣食住さへ足りればよい人達は、不景気なれば、尚更ボヤボヤしてはゐられないといふので、景気のよい時よりも当然意志的になるのであらう。",
              "citation": {
                "source": "作家と孤独",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "遅れて来て途中から聞いた者は尚更さうであつた。",
              "citation": {
                "source": "校長",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに朝鮮人の労働者が乗り合はしてゐて一向寐ようともしないでベチヤベチヤ喋舌るので尚更だつた。",
              "citation": {
                "source": "分らないもの",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "公園は尚更、黄褐色の大渦巻きだった。",
              "citation": {
                "source": "伯林の落葉",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "反省が入れば入る程尚更その窮屈がオークワードになります。",
              "citation": {
                "source": "橡の花",
                "author": "――或る私信――",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところがもっと近くによりますと、尚更わからなくなりました。",
              "citation": {
                "source": "蛙のゴム靴",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「両方別々なら尚更をかしいぢゃないかねえ。",
              "citation": {
                "source": "林の底",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ラクシャンの第一子は尚更怒って立派な金粉のどなりをまるで火のやうにあげた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」ラクシャンの第一子は尚更怒って立派な金粉のどなりをまるで火のようにあげた。",
              "citation": {
                "source": "楢ノ木大学士の野宿",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども私が死にましたならば、尚更深い、悲しみと、苦しみをアヤ子に与えることになります、ああ、どうしたらいいでしょう私は…………。",
              "citation": {
                "source": "瓶詰地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "苦い敵愾心が又胸につきあげて来た――嫉妬と云ふ言葉ででも現はすべき敵愾心が――「それでなくてもパヽは怖いものなんだよ、……それ……に」　パヽだけが折檻をやつては、尚更怖がらせるばかりで、仕舞にはどう始末をしていゝか判らなくなる。",
              "citation": {
                "source": "An Incident",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "片手で、尚ほつよく、しかと婦人の手を取つたまゝ、その上、腰で椅子を摺寄せて、正面をしやんと切つて、曰く此時、神色自若たりき、としてあるのは、英雄が事變に處して、然るよりも、尚更ら驚歎に價値する。",
              "citation": {
                "source": "みつ柏",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "』『しかし、それでは尚更、奥さんが小野氏を殺す理由が考えられんではないですか？",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "翌朝、美代子が死体を発見して、投げ出されているピストルを見て、黒いリボンでもあれば尚更のこと、葛飾に殺されたものと思い込む。",
              "citation": {
                "source": "遺書に就て",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "エミ子は、どんな男刈にした奥さんにだって負をとらない位、近代夫婦生活の新様式を理解しているつもりだったのですが、それだから尚更のこと堪え難い侮辱でした。",
              "citation": {
                "source": "四月馬鹿",
                "author": "渡辺温",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人死んだら尚更いい。",
              "citation": {
                "source": "女の決闘",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日本音楽などは尚更詰らぬものだと思う。",
              "citation": {
                "source": "文士の生活",
                "author": "夏目漱石氏−収入−衣食住−娯楽−趣味−愛憎−日常生活−執筆の前後",
                "note": "青空文庫"
              }
            },
            {
              "text": "でも、やっぱり出来ないで……時々ここへ来ては未練がましく出したり取り散らしたりして見るのですけれど……」　明るみに出て、陽の光を真正面に受けると、今まで薄暗いところで見た娘の貌のくぼみやゆがみはすっかり均らされ、いつもの爛漫とした大柄の娘の眼が涙を拭いたあとだけに、尚更、冴え冴えとしてしおらしい。",
              "citation": {
                "source": "河明り",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "今のこの時局に於ては尚更、大いに読まなければいけない。",
              "citation": {
                "source": "心の王者",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "知っているからこそ、尚更あの人は私を意地悪く軽蔑するのだ。",
              "citation": {
                "source": "駈込み訴え",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だが、もっと地味に、決定的に、質実に、その本質を指定することも出来ない組み合せになって相当、年月を経た男女――少なくとも取り立てて男女などと感じなくなった自分達だけは、子の前などでは尚更「夫婦」なんてぷんぷんなまの性欲の匂いのする形容詞を着せられるのは恥かしい。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にその上皮が美人であったなら尚更のことでしょう。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "僕は、それに堪え兼ねて尚更に魅惑的の月光を求める。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼女は痩せた体を尚更硬張らせて長方形の一段周辺より下った芝生を見入って居る。",
              "citation": {
                "source": "決闘場",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "何か最近、彼女に差し迫った変事でもありはしまいか――そんな予感が微かに起ると小田島は尚更じっとして居られなかった。",
              "citation": {
                "source": "ドーヴィル物語",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、なおさら、てれているんだよ。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "尤もこの頃人の話で大凡こんなものかくらいは解ったようだが元来西洋の音楽などは遠くの昔バイオリンを聞いたばかりでピアノなんか一度も聞いた事はないからなおさら駄目だ。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに調子が単純で弾ずる人に熱情がないからなおさらいかん。",
              "citation": {
                "source": "根岸庵を訪う記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "この場合は第二句の方が短いからなおさら都合がよいのである。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
