        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "年中太陽に晒されて、豚小屋みたいな処に寝ころんで……」「ウーン。",
              "citation": {
                "source": "いなか、の、じけん",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "背の低い顔の丸い中太りの快活で物の解った人といわれてる。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "就中太郎、二郎はあん寿、つし王をいたはり、三郎は二人を虐けるのである。",
              "citation": {
                "source": "歴史其儘と歴史離れ",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "異様なる蛇ども　前項にいった、わが邦中国のトウビョウ蛇神が、体短く中太いというについて、必ず聯想さるるは、野槌という蛇である。",
              "citation": {
                "source": "十二支考",
                "author": "蛇に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "死因のわからぬあぶらぎった中太りの女の死体が、ぶよんとしたなま白い色をたたえて、湯の中に沈んでいるのです。",
              "citation": {
                "source": "右門捕物帖",
                "author": "死人ぶろ",
                "note": "青空文庫"
              }
            },
            {
              "text": "張従正、字は子和、※州考城の人、金大定明昌の間医を以て聞え、興定中太医に補せられた。",
              "citation": {
                "source": "伊沢蘭軒",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "六所様には径六尺の上もある大太鼓が一個、中太鼓が幾個かある。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "後気が変になり、帰国の船中太平洋の水屑になられたと聞いて居る。",
              "citation": {
                "source": "みみずのたはこと",
                "author": "徳冨健次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "すくなくとも私が雪国で生れて一番閉口したのは秋なかばから一冬中太陽を見ることのできないせつなさであった。",
              "citation": {
                "source": "桐生通信",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだから二六時中太平の時はない。",
              "citation": {
                "source": "吾輩は猫である",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "供につれていた新参の家来に越後中太家光という者があり、これが、「敵はすでに河原まで攻め入っておりますのに、何で悠々と落ちつかれているのですか。",
              "citation": {
                "source": "現代語訳　平家物語",
                "author": "第九巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "石州者の田中太七というは、俗にいう稲荷下ろしにて、女房おきぬとともに神戸へ来たり。",
              "citation": {
                "source": "おばけの正体",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "石州者の田中太七というは、俗にいう稲荷下ろしにて、女房おきぬとともに、本年の四月ごろより神戸へ来たり。",
              "citation": {
                "source": "迷信と宗教",
                "author": "井上円了",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうしておいて丈助は老中太田｜備後守にカゴ訴をしたから事メンドウになった。",
              "citation": {
                "source": "安吾史譚",
                "author": "勝夢酔",
                "note": "青空文庫"
              }
            },
            {
              "text": "いろいろ書いて一杯になってしまったけれど、十三日には窪川、壺井夫妻、徳さんの細君、雅子、林町の連中太郎まで来て十三人。",
              "citation": {
                "source": "獄中への手紙",
                "author": "一九三七年（昭和十二年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "此音に付き、近い頃日本に来る途中太平洋上で死なれたキングスレー博士は、次ぎの様な面白い噺を書いて居る。",
              "citation": {
                "source": "日本その日その日",
                "author": "日本その日その日",
                "note": "青空文庫"
              }
            },
            {
              "text": "筋肉質ではなく、ぼてっと中太りの躯に、夏も冬も洗いざらした浴衣一枚で、冬にはほころびだらけの半纏をひっかける。",
              "citation": {
                "source": "季節のない街",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「御老中太田備中守様のお書付。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　と、老先生は、狂喜の手に、老中太田備中守の書付をつかんで、奉行所の門内へ走りこんだ。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "老先生は、きっと向き直って、老中太田備中守の執行猶予書を、羅門と東儀の眼のまえに向けて、開いて見せた。",
              "citation": {
                "source": "牢獄の花嫁",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「このほど、侍中太史令の王立という者が、天文を観るに、昨年から太白星が天の河をつらぬき、※星の運行もそれへ向って、両星が出合おうとしている。",
              "citation": {
                "source": "三国志",
                "author": "草莽の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "中太夫｜孔融は、前の日、彼に諫めた。",
              "citation": {
                "source": "三国志",
                "author": "赤壁の巻",
                "note": "青空文庫"
              }
            },
            {
              "text": "木の幹の高い所に、大きなみごとなかぶと虫がいかめしい角を立てて止まっているのを見つけた時はうれしかった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その後たびたび同じ常山木の下へも行ったが、あの時のようなみごとなかぶと虫はもう見つからなかった。",
              "citation": {
                "source": "花物語",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし甲板の上で、これをじっとみていたロロー殿下は、大きなかぶとの中で、にやりと笑った。",
              "citation": {
                "source": "海底大陸",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "千二は、妙なかぶとのようなものを、頭にかぶっているのだ。",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだけじゃありません、いろんなかぶと虫にもわたしは気をとられていました。",
              "citation": {
                "source": "百姓マレイ",
                "author": "フョードル・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
