  {
    "uuid": "95f7971b-61b6-5cbd-a949-eaaef0090e08",
    "entry": "無き",
    "reading": {
      "primary": "なき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "接尾辞",
        "連体詞"
      ],
      "ctype": null,
