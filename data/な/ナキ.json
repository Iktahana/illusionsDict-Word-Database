    },
    "definitions": [
      {
        "index": 1,
        "gloss": "-less",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "地下鐵道にてひとり來りて地下鐵道の青き歩廊をさまよひつ君待ちかねて悲しめど君が夢には無きものをなに幻影の後尾燈空洞に暗きトンネルの壁に映りて消え行けり。",
              "citation": {
                "source": "氷島",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこに距離の間隔はあれども無きが如く、翁の擬して撫で来る指の腹に地平の林は皮膚のうぶ毛のように触れられた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "御新造は驚きたるやうの惘れ顏して、夫れはまあ何の事やら、成ほどお前が伯父さんの病氣、つゞいて借金の話しも聞ましたが、今が今私しの宅から立換へようとは言はなかつた筈、それはお前が何ぞの聞違へ、私は毛頭も覺えの無き事と、これが此人の十八｜番とはてもさても情なし。",
              "citation": {
                "source": "大つごもり",
                "author": "一葉女史",
                "note": "青空文庫"
              }
            },
            {
              "text": "（その十二）直次は其夜の闇にまぎれて、松川屋敷を出ぬ、明けて驚きし佐助夫婦が、常は兎角に小言もいひけれど、いかに定めて斯かる仕義と流石に胸やすからねば評議とり／″＼に、おそよは朝な／＼手を合する神々にも、心得違ひの無きやうにと祈りぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "月の夜　村雲すこし有るもよし、無きもよし。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "虫の声　垣根の朝顔やう／＼小さく咲きて、昨日今日｜葉がくれに一花みゆるも、そのはじめの事おもはれて哀れなるに、松虫すゞ虫いつしか鳴よわりて、朝日まちとりて竈馬の果敢なげに声する、小溝の端、壁の中など有るか無きかの命のほど、老たる人、病める身などにて聞たらば、さこそ比らべられて物がなしからん。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "根の根の細かな繊毛のその岐れの殆ど有るか無きかの毛の尖のイルミネエション、それがセンチメンタリズムの極致とすれば、その毛の尖端にかじりついて泣く男、それは病気の朔太郎である。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "と又、Ｔ「引ッ込ま無きゃ　ひきずり下す！",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は聖像の前に嚴かに十字を切ると、金色の燭臺を降して、それを兩手に支へたまま、人無きが如くに私達の眼の前を去つて行つた。",
              "citation": {
                "source": "修道院の秋",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "此以後自分と志村は全く仲が善くなり、自分は心から志村の天才に服し、志村もまた元來が温順しい少年であるから、自分を又無き朋友として親しんで呉れた。",
              "citation": {
                "source": "畫の悲み",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "それだのにわれわれはこの句によって限り無き情緒の活動を喚起されるのは何ゆえであろうか。",
              "citation": {
                "source": "俳句の精神",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわちその物なりと心得たる者も無きにもあらず。",
              "citation": {
                "source": "人の言葉――自分の言葉",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "さいはひにして、大過無き出發となつてくれたらよいと、いまはそれを祈るばかりである。",
              "citation": {
                "source": "『パンドラの匣』あとがき",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "国賊逆徒、売国奴、殺せ、撲れと、衆口一斉｜熱罵恫喝を極めたる、思い思いの叫声は、雑音意味も無き響となりて、騒然としてかまびすしく、あわや身の上ぞと見る眼｜危き、ただ単身なる看護員は、冷々然として椅子に恁りつ。",
              "citation": {
                "source": "海城発電",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "ああはたして仁なりや、しかも一人の渠が残忍｜苛酷にして、恕すべき老車夫を懲罰し、憐むべき母と子を厳責したりし尽瘁を、讃歎するもの無きはいかん。",
              "citation": {
                "source": "夜行巡査",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "荼枳尼天の形相、真言等をここに記するも益無きことであるし、かつまた自分が飯綱二十法を心得ているわけでもないから、飯綱修法に関することは書かぬが、やはり他の天部夜叉部等の修法の如くに、相伝を得て、次第により如法に修するものであろう。",
              "citation": {
                "source": "魔法修行者",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紅梅　紅梅の香なきは艶なる女の歌ごゝろ無きが如し。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "甘く芳はしき香も悪しからず、花の黄金色なせるも地にこぼれて後も見ておもむき無きならず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "さすがに、ゆかしきかたも無きにはあらず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "名も無き小川のほとりなる農家の背戸の方に一本二本一重なるが咲ける、其蔭に洗はれたる鍋釜の、うつぶせにして日に干されたるなんど、長閑なる春のさま、この花のあたりより溢れ出づる心地す。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "刺も緑の茎に紅く見えたる、おもむき無きならず。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "紫藤　春の花いづれとなく皆開け出る色ごとに目おどろかぬは無きを、心短く打すてゝ散りぬるが恨めしうおぼゆるころほひ、此花の独たち後れて夏にさきかゝるなん、あやしく心にくゝ、あはれにおぼえ侍る。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "虻の声は天地の活気を語り、風の温く軟きが袂軽き衣を吹き皺めて、人々の魂魄を快き睡りの郷に誘はんとする時にだも、此花を見れば我が心は天にもつかず地にもつかぬ空に漂ひて、物を思ふにも無く思はぬにも無き境に遊ぶなり。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "鉄線蓮　てつせんは、詩にも歌にも遺れられて、物のもやうにのみ用ゐらるゝものなるが、詩歌に採らるべきおもむき無きものにはあらじ。",
              "citation": {
                "source": "花のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲の旗の如く見ゆることは多し、旗雲といふ語は今無きやうなり。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "冬は多く北風吹き、火のあやまちは冬多きものなれば、怪むべくもあらぬ事ながら、東京の大火を叙せんとて、心も無く、北へ行く雲に火の色うつりて天は紅霞のわたれるが如し、など別の故も無きに筆を舞はして記さば、如何に見苦しきものに老いたる人などの見なさん。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "ゑせ歌人は、かゝる言葉のはたらきあるはたらきよりは、猶ふるき言葉のあたひ無きあたひを尊むべきものと思へるなるべし。",
              "citation": {
                "source": "雲のいろ／＼",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "やつぱり形式に於ても経験世界を肯定しなきや万人の芸術品とは言へないのでせうか？",
              "citation": {
                "source": "（最も純粋に意地悪い奴）",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "「夕暮」なき競走、油と虫となる理想！",
              "citation": {
                "source": "地極の天使",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "はてしなき、そが心母にも、……もとより友にも明さざりき。",
              "citation": {
                "source": "夏と私",
                "author": "中原中也",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
