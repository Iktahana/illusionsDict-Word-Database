[
  {
    "uuid": "30277e34-b2b2-5f3d-a4a9-051f99ba4fc2",
    "entry": "憖っか",
    "reading": {
      "primary": "なまじっか",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
