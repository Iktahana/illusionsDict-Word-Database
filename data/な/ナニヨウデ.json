          "literary": [
            {
              "text": "この方は何用でいらっしゃいました。",
              "citation": {
                "source": "金時計",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "『何用で来なすった？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "で、お前らは一体何用でここへ来た？",
              "citation": {
                "source": "シルヴァブレイズ",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "それで僕は何用でも大抵葉書で濟ますのだが、若し一｜枚で足りなければ二｜枚續きにする。",
              "citation": {
                "source": "ハガキ運動",
                "author": "堺利彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「はいはい何用でござんすかえ？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "……さア何用で参れらたな？",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "白紙へ筋を引いたのが碁盤、碁石といっても同じく紙製、眼のないほどの囲碁好きで、どこへ何用で行こうとも、この二品だけは携えて行く。",
              "citation": {
                "source": "剣侠受難",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "な、何用ではいってきたのか」「いや、その御挨拶は恐れ入りました。",
              "citation": {
                "source": "浮かぶ飛行島",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "「何用で来なすったのかね？",
              "citation": {
                "source": "白銀の失踪",
                "author": "SILVER BLAZE",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると彼は、『ふん、何用ですって？",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "真暗、くらくらくろ装束で忍び込んだる恋の闇　と、手を延して、広縁の板へ触れたとき、背後から「何用でござる」　小藤次は、冷たいもので、身体中を逆撫でされたように感じた。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "足軽が「何用で」　と、咎めると「死体に、坊主は、つきものじゃで」　と、笑いながら、小走りに、死体の方へ走って行った。",
              "citation": {
                "source": "南国太平記",
                "author": "直木三十五",
                "note": "青空文庫"
              }
            },
            {
              "text": "何用です」婆さんは迂散臭そうにいった。",
              "citation": {
                "source": "日蔭の街",
                "author": "松本泰",
                "note": "青空文庫"
              }
            },
            {
              "text": "隣家の専斎で」「これはこれは専斎殿、その大声は何用でござるな？",
              "citation": {
                "source": "大鵬のゆくえ",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「かかる深夜に何用でござる」門の内から声がした。",
              "citation": {
                "source": "銅銭会事変",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "仏蘭西の学校へ何用でとお考へかも知れないが、近頃、碁の用はこの学校が間に合ふのである。",
              "citation": {
                "source": "生命拾ひをした話",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は……」　と言いかけて、「博士は少年に何用ですか」「うむ、千二が、一しょにつれになっていた丸木という怪漢について、話を聞きたいのだ」「丸木？",
              "citation": {
                "source": "火星兵団",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "（何用で来たのです？",
              "citation": {
                "source": "四年のあいだのこと",
                "author": "久坂葉子",
                "note": "青空文庫"
              }
            },
            {
              "text": "鼻介が何用でオトキの妾宅へ出入りしているかということが分ると、若者たちはオドロキを通りこして、居ても立ってもいられない恐怖にかられた。",
              "citation": {
                "source": "落語・教祖列伝",
                "author": "飛燕流開祖",
                "note": "青空文庫"
              }
            },
            {
              "text": "何用で礼子さんに会いたいのか、ぼくには分らないが、あの人自身が全然迷っている子羊で、あなたに貸す智恵は持ち合せッこないですよ。",
              "citation": {
                "source": "街はふるさと",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょっとした学生同志の挨拶が済むと、窪田はちらと机の上に目をやりながら、まだ何用でこの二人が来たのかを推測しかねている久野にいきなり言いかけた。",
              "citation": {
                "source": "競漕",
                "author": "久米正雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、ザミョートフは何用でやって来たんだろう？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "いったいあなた何用です？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　このなれなれしげな『あなた何用です？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "何用でご来駕をかたじけのうしたのか、それを聞かしてくださいませんか、……それに……それに……ぼく急ぐんだから。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "何用でやって来たんだ？",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            },
            {
              "text": "「止れ、何用で来た」　浪人は三尺に余る野太刀の柄に手をかけて叫んだ。",
              "citation": {
                "source": "松風の門",
                "author": "山本周五郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「して、その薬師が、この戦場へ何しに、また何用で、われらを呼びとめたか」　輿の従者たちが咎め返すと、蔵六は、家法の陣中薬を、東条の城へ献納のために来たと答え、洛内の商民である自分らとしては、せめてこういうことでもするしか、朝廷への御奉公の道はないので――などと云い足した。",
              "citation": {
                "source": "日本名婦伝",
                "author": "大楠公夫人",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの銭豹子か」　なんと、あいにく浮かない日ではあったが、さっそく通して、久闊をあたため、さて何用でと来意を訊くと、客の湯隆は、旅包みの中から、二タ竿の黄金、おもさ二十両を、そこへさし出して。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "小姓部屋へもどって、虎之助は着ものを着かえ、やがて秀吉のまえに行って、何用ですかと伺った。",
              "citation": {
                "source": "新書太閤記",
                "author": "第五分冊",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
