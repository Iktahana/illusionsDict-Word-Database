    "definitions": [
      {
        "index": 1,
        "gloss": "close friendship",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "お照さんとは一ばんの仲良し。",
              "citation": {
                "source": "お伽草紙",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それに、おれはあの青蛇団と留置場の中ですっかり仲良しになったんだよ。",
              "citation": {
                "source": "夜光虫",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それはね、――」兄嫁はちょっと口ごもって、「あたしの一番の仲良しをあの晩お呼び出来なかったからよ。",
              "citation": {
                "source": "眼鏡",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして到るところで、村の子供達と仲良しになつた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の母娘は評判の仲良しで近所の人達は彼女等が姉妹か親友のようだと言う程、何事をも共同でやっていた。",
              "citation": {
                "source": "母と娘",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そしてオレ達の社会は、あうんの仲良しクラブにとどまっているには小金をため過ぎたのだから。",
              "citation": {
                "source": "青空のリスタート",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "殊にわしとは日頃から仲良しじゃで、妹をくりょうと約束した。",
              "citation": {
                "source": "小坂部姫",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "死んだにいさんが広田先生とはたいへん仲良しだったそうです。",
              "citation": {
                "source": "三四郎",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "お君は仲良しの女工に呼ばれて、そこで腰を並べて、昼食をたべた。",
              "citation": {
                "source": "工場細胞",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうすなおに育てられた息子は、十八歳のときに、同じ村の百姓の娘のお萩という同じ年ごろの子と仲良しになりました。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "この母子二人暮らしのうちはひどく仲良しであったのに息子が大人になり、そこに嫁子がくると、昨日に変わって老婆はよけい者にされるようになった。",
              "citation": {
                "source": "東奥異聞",
                "author": "佐々木喜善",
                "note": "青空文庫"
              }
            },
            {
              "text": "一寸したきつかけで、かうした兵隊と、仲良しになつて、極くさゝやかな幸運をもたらせてくれないものかと、空想もしてみる。",
              "citation": {
                "source": "瀑布",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この四人はとても仲良しだけれども、四人とも氣が弱くて、何にでも感激する。",
              "citation": {
                "source": "おにおん倶樂部",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ううん、いわないけど……」「それ御覧、大丈夫だよ、それで勘三叔父さんは、啓ちゃんと仲良しだものねえ」　体操の組では綱引きが始まった。",
              "citation": {
                "source": "泣虫小僧",
                "author": "林芙美子",
                "note": "青空文庫"
              }
            },
            {
              "text": "仲良しになるもならないもありゃしませんワ。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "地面を掘ってみても、すぐわかるけれど、土というものは、案外かたいものだよ」　と、一郎の仲良しの松木亮二が、いったことである。",
              "citation": {
                "source": "未来の地下戦車長",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それというのも、ハイタが一番好きなのは決して素性を明かさぬハスターで、その次に大事にしていたのが仲良しの隣人たち、人見知りな森や小川の不死の精のことだったからです。",
              "citation": {
                "source": "羊飼いハイタ",
                "author": "Ａ. ビアス　A.Bierce",
                "note": "青空文庫"
              }
            },
            {
              "text": "お兄さんは女と無駄話をするのが巧いから、あたしのお友達が、あたしよりもお兄さんの仲良しになつてしまふんです。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "すつかり仲良しになつちやつておいて、順調に話をつけずに、暴力をふるつちやうのよ。",
              "citation": {
                "source": "蒼茫夢",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は仲良しだし、ほんとに仲がいいんだから。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "美※　あなたとは、仲良しじゃないの、誰がみたってそうみえると思うわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "だがまあ、考えてみてくれ、須貝は未納と一番仲良しにしていながら、一方では諏訪に言い寄っている。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "あの人は、やっぱり妾の仲良しだわ。",
              "citation": {
                "source": "華々しき一族",
                "author": "森本薫",
                "note": "青空文庫"
              }
            },
            {
              "text": "この十人の特攻隊には安川たち三人組、死なばモロトモといふ仲良しの妙信と京二郎も含まれてゐた。",
              "citation": {
                "source": "決闘",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほどの仲良しの竹見から、ナイフを、なげつけられようなどとはまったく想像もしなかったのである。",
              "citation": {
                "source": "火薬船",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "克巳は、いなかの松吉、杉作の家に十日ばかりいたのですが、最後のこの日ほど、三人がこころの中で、なかよしになったことはありませんでした。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "ひとつは、夏休みになかよしになったいとこの克巳に会えるということ、もうひとつは、あまりはっきりいいたくないのですが、おだちんをもらえることです。",
              "citation": {
                "source": "いぼ",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "氏も、それを感じて居るのか、いわゆるなかよしになり、しんみり語り合う機会が日増に多くなった。",
              "citation": {
                "source": "鶴は病みき",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥は、なかよしの去年の木のところへまたかえっていきました。",
              "citation": {
                "source": "去年の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "小鳥は工場の門の上にとまって、「門さん、わたしのなかよしの木は、どうなったか知りませんか。",
              "citation": {
                "source": "去年の木",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
