[
  {
    "uuid": "235e9cb6-7a3a-5eca-9c37-117a04ba17c1",
    "entry": "鉛",
    "reading": {
      "primary": "なまり",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
