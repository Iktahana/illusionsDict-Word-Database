        "collocations": [],
        "examples": {
          "standard": [
            {
              "text": "彼の家の家紋は、七つ星紋で、歴史ある家柄だという。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "七つ星の家紋は、武家や公家にも多く見られる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "「この着物の模様、七つ星のデザインが素敵だね」と、友人が褒めてくれた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": []
        }
