        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "どうも、同じクラスの者は大学を出てからも、仲の良いくせにつまらないところで張合って喧嘩をしたがる傾向がある。",
              "citation": {
                "source": "佳日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わしと仲の良い振りをしていて下さい。",
              "citation": {
                "source": "新ハムレット",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、さすがに嫂の手前気がとがめたのか、それとも、やはり一ぺん位夫婦仲の良い気持を味いたかったのか、高津の黒焼屋へ出掛けた。",
              "citation": {
                "source": "大阪発見",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "あくる日、二人で改めて自由軒へ行き、帰りに高津のおきんの所へ仲の良い夫婦の顔を出した。",
              "citation": {
                "source": "夫婦善哉",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "私たちは、仲の良い兄妹のように、旅に出た。",
              "citation": {
                "source": "東京八景",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "蛸氏もまた心得たもので、如何なる場合にも絶えず論敵の肩に手をかけることを忘れず、一匹の子分が脚を離れても、必ず他の一匹を捉へてをくといふ蛸氏の腹黒さは徹底したものであつたが、それを知つてゐてか知らないのか、とにかくこのグループは表面甚だ仲の良いものであつた。",
              "citation": {
                "source": "小熊秀雄全集−15−",
                "author": "小説",
                "note": "青空文庫"
              }
            },
            {
              "text": "（感動的に）皆さま方はお親しい、仲の良いことでございます。",
              "citation": {
                "source": "きのふは嵐けふは晴天",
                "author": "小熊秀雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "すると、彼は、「俺の友達にこんなのがある」と云った、「仲の良い二人の友達なんだが、一人は三・一五で三年やられたんだ。",
              "citation": {
                "source": "党生活者",
                "author": "小林多喜二",
                "note": "青空文庫"
              }
            },
            {
              "text": "二人は心から仲の良い様によっかかり合いながらとりとめもない事をぼそぼそと話した。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "太郎とお芳は、とても仲の良い友だちになった。",
              "citation": {
                "source": "赤い婚礼",
                "author": "RED BRIDAL",
                "note": "青空文庫"
              }
            },
            {
              "text": "だまったまんま、かおを見、だまったまんま考え、だまったまんまお互の心がわかって笑う時に一所に声をあげて笑ったらさぞマアうれしい事だろう」　帰りには仲の良いＫ子と一緒にかえった。",
              "citation": {
                "source": "千世子",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "死ぬとか生きるとかと云う事はまるで頭になく只私と仲の良い小さい娘に会いたいと云う心ばっかりに司配されてスタスタと走って行ったら汽車で行くよりかも近路をしたら早くはあるまいかとさえ早く行きたいと云う心が思わせた。",
              "citation": {
                "source": "悲しめる心",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "原口早苗にぴつたり寄添つて、さも仲の良い風をみせてゐる。",
              "citation": {
                "source": "荒天吉日",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "……壮六　実は私は試験所の方で稲作の方の勉強を主にやっとりまして、この金吾とは小さい時分から一番仲の良い友達でやすもんで、行く行くは二人で力を合わせて、この奥を開いて見べえと言う約束でがして、はあ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれから今日まで四年近く、こんだけ仲の良い俺でさえ、そうとハッキり気が附かなかったんだ。",
              "citation": {
                "source": "樹氷",
                "author": "三好十郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お松と仲の良い男は一體誰なんだ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな様子なんだ、ともかく、詳しく話してくれ」「旦那はこの間から、すっかり萎気切っておりました、仲の良い内儀さんに死なれて、何事も手につかない様子で、毎晩召し上がるお酒だけが次第に多くなるばかり」「で？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "和蘭の銀貨",
                "note": "青空文庫"
              }
            },
            {
              "text": "私共は町内でも評判の仲の良い父子でございましたよ」「少しばかりの寢酒を止させたり、三度のものも、粥を一膳に、味噌か鹽を嘗めさせて居たといふが――此邊に聞えた大身代の老木屋の隱居が、それで宜かつたのかな」　平次は思ひきつて突込みました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "凧糸の謎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「どんな樣子なんだ、兎も角、詳しく話してくれ」「旦那は此間から、すつかり萎氣切つて居りました、仲の良い内儀さんに死なれて、何事も手につかない樣子で、毎晩召し上がるお酒だけが次第に多くなるばかり」「で？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "和蘭の銀貨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「八、吉、二人手わけをして、このお玉さんに、仲の良い男がなかつたか、それを訊いてくれ、俺は、お内儀さんに用事がある」　平次は八五郎と湯島の吉を追ひやると、母親のお春と、たつた二人、氣まづく相對しました。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "鬼女",
                "note": "青空文庫"
              }
            },
            {
              "text": "――お松と仲の良い男はいったい誰なんだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "父の遺書",
                "note": "青空文庫"
              }
            },
            {
              "text": "競争者の地位に居るこの二人が、こんなに仲の良いことは、帝都劇場に取っても、どんなに幸せだったかわかりません。",
              "citation": {
                "source": "踊る美人像",
                "author": "野村胡堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "御主人と忍さんは、決して仲の良い親娘ぢやないけれど、お道坊が飛び込んで來たのも無理はありません。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "死の祕薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「お絹さんと、仲の良い男はなかつたのか。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "闇に飛ぶ箭",
                "note": "青空文庫"
              }
            },
            {
              "text": "剃刀で大の男の頸動脈を掻き切つて、聲も立てさせずに殺すのは、これは容易ならぬ手際でなければよく顏見知りの、――例へば仲の良い女などが、首つ玉に抱きつくやうにして、思ひきり深々とやつたものでせう。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "美少年國",
                "note": "青空文庫"
              }
            },
            {
              "text": "「非道な利息を取るから、怨んでゐる者は何十人あるか判りやしません」「金藏と仲の良いのは？",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金藏の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "「手堅い一方で、町内の評判者ですよ」「お茂とか言つたね――菱屋の娘には行方知れずになつた金藏の外に仲の良い男がないのかな」　平次の問ひは又一轉します。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "金藏の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「お六は仲の良い人間を拵えると、損が行くと思つて居ましたよ」「その中でも啀み合はないのがあるだらう」「若旦那――雪之助さんくらゐのものでせうよ。",
              "citation": {
                "source": "錢形平次捕物控",
                "author": "六軒長屋",
                "note": "青空文庫"
              }
            },
            {
              "text": "「非道な利息を取るから、怨んでいる者は何十人あるか判りゃしません」「金蔵と仲の良いのは？",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "金蔵の行方",
                "note": "青空文庫"
              }
            },
            {
              "text": "日頃なかのよい兄妹がこのありさまですから、婆やはますますあわててしまいました。",
              "citation": {
                "source": "ひばりの子",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
