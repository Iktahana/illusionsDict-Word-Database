        "examples": {
          "standard": [
            {
              "text": "子どもは母親に泣き落としをかけ、おもちゃを買ってもらった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "彼女の必死な泣き落としに、頑固な彼もついに折れた。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "私は泣き落としには弱いので、すぐに頼みを聞いてしまう。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "会社の未来にも、カラー版６５０２マシンの事業としての成功にも確信が持てなかったウォズニアックは、ジョブズの脅しやすかし、泣き落としにも、マークラーの説得にも、最後までＨＰをやめることをためらい続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたしを泣き落として、その二百五十両を払わせようと思っているなら、むだだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あの判事もやはり泣き落としにかけなくちゃならないかな』彼は青くなり、胸をどきどきさせながら、こう考えた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
