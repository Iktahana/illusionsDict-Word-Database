          "literary": [
            {
              "text": "会社の未来にも、カラー版６５０２マシンの事業としての成功にも確信が持てなかったウォズニアックは、ジョブズの脅しやすかし、泣き落としにも、マークラーの説得にも、最後までＨＰをやめることをためらい続けた。",
              "citation": {
                "source": "パソコン創世記",
                "author": "富田倫生",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかしわたしを泣き落として、その二百五十両を払わせようと思っているなら、むだだ。",
              "citation": {
                "source": "巷説享保図絵",
                "author": "林不忘",
                "note": "青空文庫"
              }
            },
            {
              "text": "『あの判事もやはり泣き落としにかけなくちゃならないかな』彼は青くなり、胸をどきどきさせながら、こう考えた。",
              "citation": {
                "source": "罪と罰",
                "author": "フョードル・ミハイロヴィッチ・ドストエフスキー",
                "note": "青空文庫"
              }
            }
          ]
        }
