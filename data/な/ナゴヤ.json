    "definitions": [
      {
        "index": 1,
        "gloss": "Nagoya (city)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
