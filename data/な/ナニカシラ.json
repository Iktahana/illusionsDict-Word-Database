    "definitions": [
      {
        "index": 1,
        "gloss": "somehow (or other)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "響くといふこともないけれども、何かしら本当に仕事してゐるものを却て一時的とはいへ吃驚させたりするのだ。",
              "citation": {
                "source": "文学に関係のない文学者",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら、これは大變な事件だと思つた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども同時に何かしら腑に落ちない妙な疑問が、別に新しく心の底にきざしてきた。",
              "citation": {
                "source": "芥川龍之介の死",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それを学ばないに拘らず、思念だけでは足りない、何かしら芸術は道具を要するものであるから、作品が読まれなければならぬ。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "何やかと少しく話は乱れたが、何かしら道具を以て作されるものが詩であつて、それは、その詩の伝統を習得することによつて習得されるものである。",
              "citation": {
                "source": "詩と其の伝統",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "こうした種類の人間は、絶えず何かしらしゃべってないと寂しいのだ。",
              "citation": {
                "source": "僕の孤独癖について",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこには何かしら、或る物なつかしい、昔々母の懐中でまどろむやうな、或はまた焚火の温暖を恋するやうな、人間情緒の本質に遺伝されてる、冬の物侘しい子守唄の情緒がある。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "或は荒寥とした枯木の中を、葱さげて家路に急ぐ人の姿は、さうした冬の季節の中で、ふしぎに物侘しく、孤独にふるへる生の果敢なさを感じさせ、何かしら或る暖かい、焚火の燃える家郷への、魂のノスタルヂアを追懐させる。",
              "citation": {
                "source": "冬の情緒",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "海と空の深い透明な色を見ていると、何かしら遠いゆかしいような想いがするのを喜んで買った。",
              "citation": {
                "source": "まじょりか皿",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "同じようにはかないうら悲しい心持ちに、今度は何かしら神秘的な気分が加わっているのであった。",
              "citation": {
                "source": "春寒",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "長崎を立って時津に向かう途中でロシア人専門の遊廓だというところを通ったら二階から女どもが見下ろして何かしら分らないことを云って呼びかけた。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "当時の露国海軍のブルータルな勢力の圧迫が若い頭に何かしら強い印銘を与えていたかもしれない。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "ホテルのポルチエーが自分を小蔭へ引っぱって行って何かしら談判を始める。",
              "citation": {
                "source": "二つの正月",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その一端に火をつけて「火渡し」と云って次の人に渡すと、次の人は「しりつぎ」と答えて次へ廻す、それからだんだんに東京でいわゆる「尻取り」をするのであるが、言葉に窮して考えている間に火が消えるとその人は何かしら罰として道化た隠し芸を提供実演しなければならないのである。",
              "citation": {
                "source": "追憶の冬夜",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "いつか熱が出て床に就いて、誰も居ない部屋にただ一人で寝ていたとき、何かしら独り言を云っていた。",
              "citation": {
                "source": "追憶の医師達",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして彼の理論の上に輝く何かしら神秘的の光環のようなものを想像している人もあるらしい。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが少しひどくなって来ると、自分が何かしらもっと積極的な悪事を犯していて、今にもその応報を受けるべき時節が到来しそうな心持ちになる。",
              "citation": {
                "source": "春六題",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の連中の書くものに比べて、虚子のものには、それが表面上は単なる写生的のものでも、その裏面に何かしら夢幻的の雰囲気が漂っているような気がした。",
              "citation": {
                "source": "高浜さんと私",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "父の長い留守の間に祖母と母と三人きりで割合に広い屋敷の中でのつつましい生活は子供心にもかなり淋しいものであったに相違ないので、この広くて淋しい家と、重兵衛さんの狭くて賑やかな家との対照が幼い頭に何かしら深い印象を刻んだのではないかと想像される。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その時刻にそこから十町も下流の河口を船で通りかかった人が、何かしら水面でぼちゃぼちゃ音がしていると思ってよく見ると、一匹の「えんこう」が、しきりにぐるぐる廻転運動をしているのであった。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "それにもかかわらずそれを見る人の心は遠い昔に起こったある何かしらかなり深刻な事件のかすかな反響のようなものを感ずる。",
              "citation": {
                "source": "田園雑感",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何かしら、不安らしかつた。",
              "citation": {
                "source": "當選の日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "而も私にとつて何かしら其の辺は思ひ出が濃い。",
              "citation": {
                "source": "夏",
                "author": "〔私が貧乏で〕",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何かしら、生きて行くのに大骨を折ると云ふことに、熱意を欠いたとでも云ふのであらうか。",
              "citation": {
                "source": "氷雨",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "随筆など書いて人に読んでもらおうというのはどの道何かしら「訴えたい」ところのある場合が多いであろうと思われる。",
              "citation": {
                "source": "随筆難",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "見ると池の真中に土手のやうなものが突出してゐて、その端の小屋のやうなものの中で何かしら機械が運転してゐるらしい。",
              "citation": {
                "source": "雨の上高地",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし個人的には、たとえそれは自覚されないにしても、何かしら自ずから一定の標準をもっていて、それに当嵌めて口調の善し悪しを区別している事だけは否定し難い事実である。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "もし出来るならば、多数の歌人が銘々に口調のいいと思う歌を百首くらいずつも選んで、それらの材料を一纏めにして統計的に前述の波数や波長の分配を調べてみたら何かしら多少ものになるような結果が得られはしないかと考えるのである。",
              "citation": {
                "source": "歌の口調",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "漢詩の五言、七言の連続も、何かしらある遠い関係を思わせる。",
              "citation": {
                "source": "短歌の詩形",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "併し、何か「しなかつたこと」をすると屹度、何かしら一つ「ものを覺える」から妙である。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            }
          ]
        }
      },
