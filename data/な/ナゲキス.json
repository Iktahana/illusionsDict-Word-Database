          "literary": [
            {
              "text": "一人の水夫は、規則正しい漕ぐ手を休めないままで投げキスを送るという芸当をやって見せた。",
              "citation": {
                "source": "火夫",
                "author": "DER HEIZER",
                "note": "青空文庫"
              }
            },
            {
              "text": "車室のなかで何やら歌を唄っていましたっけが、やがてあんたのことを思い出して、ちょいと投げキスをして、あんたに宜しくと言いましたぜ。",
              "citation": {
                "source": "永遠の夫",
                "author": "ドストエーフスキイ",
                "note": "青空文庫"
              }
            },
            {
              "text": "いい夢を」　伯爵夫人は宝石じゃらじゃらの指で投げキスをして、笑顔を見せて、さっと行ってしまった。",
              "citation": {
                "source": "くちなしの花",
                "author": "The Slave of Silence",
                "note": "青空文庫"
              }
            }
          ]
        }
