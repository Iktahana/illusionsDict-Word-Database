[
  {
    "uuid": "f823a180-c720-5312-a7d4-ad93fdfd8d89",
    "entry": "詰る",
    "reading": {
      "primary": "なじる",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "動詞-五段-ラ行",
