[
  {
    "uuid": "df9e051c-c5ef-5688-83be-77cfa4172ccf",
    "entry": "内規",
    "reading": {
      "primary": "ないき",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
