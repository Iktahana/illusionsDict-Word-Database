    "definitions": [
      {
        "index": 1,
        "gloss": "perilous pass (on a route or journey)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "直ぐ行くから」　看護婦は難所を抜け出るやうに走り去つた。",
              "citation": {
                "source": "医者と赤ン坊",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "御中道に昔は小舎がなくて、参詣の道者が難渋するため、そのうちの難所たる大沢に、お助け小舎を置いたそうだが、それは疾くにつぶれて、今のは粗末ながら、普通の旅人宿めいた小舎である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "雲ゆきが怪しいので、私は多少の気がかりで、大沢の小舎を立った、すぐ眼の前には、その大沢の難所なるものが控えている。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "暫らく停まつて呼吸を入れてゐた船は、こつちを目がけて、走つて来る、難所中の難所といふ、やぐらの瀑へかゝつて来たときは、波から三尺ばかり船体が乗り出したと思ふと、水煙が噴水の柱のやうに立つて、船頭の黒い立像が、水沫の中から二体浮び出た、火影に映る消防夫の姿のやうに。",
              "citation": {
                "source": "天竜川",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "だから、それはただ気休めである丈けではあったが、猶、坑夫たちはそこを避難所に当てねばならなかった。",
              "citation": {
                "source": "坑夫の子",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "此の有樣を見て居たら急に胃の工合が變になつて來て待合室の腰掛に一時の避難所を求めなければならなかつた。",
              "citation": {
                "source": "伊香保",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浅草の親戚を見舞うことは断念して松住町から御茶の水の方へ上がって行くと、女子高等師範の庭は杏雲堂病院の避難所になっていると立札が読まれる。",
              "citation": {
                "source": "震災日記より",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "「栗生峠はなかなか難所だが馬で越すことが出来るそうだ。",
              "citation": {
                "source": "本州横断　痛快徒歩旅行",
                "author": "井沢衣水",
                "note": "青空文庫"
              }
            },
            {
              "text": "人ごみの避難所へすぐ出向いて、荷物の持ち運びをがたり／＼やつたが、いゝ立て前になる。",
              "citation": {
                "source": "十六夜",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　俥が霞ヶ｜關へ掛つて、黒田の海鼠壁と云ふ昔からの難所を乘る時分には、馬が鬣を振るが如く幌が搖れた。",
              "citation": {
                "source": "大阪まで",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "お杉は通い馴れた路であるから不思議はないが、お葉が何うして此の難所を跳越え、渡り越えたかは疑問である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は人間も通わぬ難所である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "現八は柔術に達していたので、岩の多い難所を安々と飛び渡ったと書いてある。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "」と、彼は難所に逢う毎に自ら励ました。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "疲労と不眠と空腹とが重った上に、又もや此の難所を二時間余も彷徨ったのであるから、身体の疲れと気疲れとて、彼は少しく眼が眩んで来た。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "あれほどの難所を越えてようよう此処を尋ね当てた効も無く、暗い窟の奥には何の秘密も無かった。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "路は屡々記す通りの難所である、加之も細雨ふる暗夜である。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "不知案内の女が暗夜に此の難所を越えて、恙なく里へ出られるであろうか。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "東に迷い、南に迷い、彼女は実に幾時間を費したか知らぬが、人の一心は怖しいもので、何うやら斯うやら彼の難所を乗切ったらしい。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "燈台が高く明るい光を放っているのは、燈台みずからが誇っているのでは無くして、ここは難所ゆえ近づいてはいけませんという忠告の意味なのである。",
              "citation": {
                "source": "困惑の弁",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "昔から絵にかかれ歌によまれ俳句に吟ぜられた名所難所には、すべて例外なく、人間の表情が発見せられるものだが、この本州北端の海岸は、てんで、風景にも何も、なつてやしない。",
              "citation": {
                "source": "津軽",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "民子をのせて出た雪車は、路を辷つて、十三｜谷といふ難所を、大切な客ばかりを千尋の谷底へ振り落した、雪ゆゑ怪我はなかつたが、落込んだのは炭燒の小屋の中。",
              "citation": {
                "source": "雪の翼",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "自己の中に、アルプスの嶮にまさる難所があって、それを征服するのに懸命です。",
              "citation": {
                "source": "花燭",
                "author": "燭をともして昼を継がむ。",
                "note": "青空文庫"
              }
            },
            {
              "text": "線路の上に捨てられた電車は、そのまま付近の人びとの避難所になっていた。",
              "citation": {
                "source": "変災序記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "この道先きは行者たちが拓いたもので、名所旧蹟がそのまゝ難所になっているところが沢山あるそうです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのとき避難所としてこの山がなかったなら、恐らくこの平地の土民は全滅したであろうということです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "わかい葉柳の並木路、撒水した煉瓦道、そのなかの小さな人口花壇、（疲れた瞳の避難所）その方二｜尺のかなしい区劃に、夏がきて花が咲いた、小さい細い石竹と釣鐘艸。",
              "citation": {
                "source": "東京景物詩及其他",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "大洞可児合は蘇川中の一大難所である。",
              "citation": {
                "source": "木曾川",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "根尾から大字小鹿、松田、下大須、上大須を過ぎ、明神山から屏風山を越えて、はじめて越前へ出るのであるが、そのあいだに上り下りの難所の多いことは言うまでもない。",
              "citation": {
                "source": "くろん坊",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんしょ、ここは大けな建物やさかいな。",
              "citation": {
                "source": "青春の逆説",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
