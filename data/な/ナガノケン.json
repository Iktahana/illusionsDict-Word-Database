    "definitions": [
      {
        "index": 1,
        "gloss": "Nagano Prefecture (Chūbu area)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
