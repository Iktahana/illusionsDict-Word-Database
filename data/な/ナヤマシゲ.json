    "definitions": [
      {
        "index": 1,
        "gloss": "anxious (appearance)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
