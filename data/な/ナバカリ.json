    "definitions": [
      {
        "index": 1,
        "gloss": "in name only",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "なに、名ばかりの親戚で僕とは血のつながりなんか絶対にない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "今戸の渡と云う名ばかりは流石に床し。",
              "citation": {
                "source": "半日ある記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "河とは名ばかりの黄色き砂に水の気なくて、照りつく日のきらめく暑そうなり。",
              "citation": {
                "source": "東上記",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "浮世の花の香もせぬ常闇の国に永劫生きて、ただ名ばかりに生きていなければならぬかと思うと、何とも知れぬ恐ろしさにからだがすくむ。",
              "citation": {
                "source": "枯菊の影",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "（Ｆ・Ｏ）○＝（Ｆ・Ｉ）街　覆面の諸士二十名ばかり、　雲霧主膳を中心にひそひそ話。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "平伏して居る家臣一同（百名ばかり）。",
              "citation": {
                "source": "武蔵旅日記",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "殆ど假名ばかりで小兒が書いたやうな所もある。",
              "citation": {
                "source": "半七捕物帳",
                "author": "お文の魂",
                "note": "青空文庫"
              }
            },
            {
              "text": "食糧や、慰問品の受領に鉄道沿線まで一里半の道のりを出かけていた十名ばかりが、帰ってきたのだ。",
              "citation": {
                "source": "前哨",
                "author": "黒島傳治",
                "note": "青空文庫"
              }
            },
            {
              "text": "……が、そのうちにこの家が、私の最初からの予想通り、名ばかりの図書館であることをたしかめた。",
              "citation": {
                "source": "けむりを吐かぬ煙突",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "かくて仲善き甲乙の青年は、名ばかり公園の丘を下りて温泉宿へ帰る。",
              "citation": {
                "source": "恋を恋する人",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　見ればなるほど三畳敷の一間に名ばかりの板の間と、上がり口にようやく下駄を脱ぐだけの土間とがあるばかり、その三畳敷に寝床が二つ敷いてあって、豆ランプが板の間の箱の上に載せてある。",
              "citation": {
                "source": "窮死",
                "author": "国木田独歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "他の仏教国と言われる国は、多少大乗はあっても名ばかりで、実は小乗が行われているのであります。",
              "citation": {
                "source": "仏教人生読本",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "橋の詰には向い合って二軒、蔵屋、鍵屋と名ばかり厳しい、蛍狩、涼をあての出茶屋が二軒、十八になる同一年紀の評判娘が両方に居て、負けじと意気張って競争する、声も鶯、時鳥。",
              "citation": {
                "source": "黒百合",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "最近五、六年は舞台に出ているというも名ばかりで、あってもなくても好いような取扱いを受けていたが、彼は黙って勤めていた。",
              "citation": {
                "source": "源之助の一生",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "この大戦に参加したのは九州の諸大名ばかりでない。",
              "citation": {
                "source": "飛騨の怪談",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ふだんから梟娘の名ばかりを聞いてゐる町の人たちは一種の好奇心に駆られて、その正体を見とゞけようとして群つて来たのであつた。",
              "citation": {
                "source": "梟娘の話",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "花崗岩の敷石を飛び飛び赤土道を降りて、到着した判検事一行の七名ばかりを出迎えた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "本署からは剛腹で有名な巨漢の司法主任｜馬酔警部補と、貧相な戸山警察医のほかに、刑事が二名ばかり来ていた。",
              "citation": {
                "source": "巡査辞職",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "なに、名ばかりの親戚で僕とは血のつながりなんか絶對にない。",
              "citation": {
                "source": "ダス・ゲマイネ",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "将軍家といふ名ばかり立派だが、京の御所の御儀式の作法一つにもへどもどとまごつき、ずんぐりむつつりした田舎者、言葉は関東訛りと来てゐるし、それに叔父上は、あばたです、あばた将軍と、すぐに言はれる。",
              "citation": {
                "source": "右大臣実朝",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "だからその時の自分には、卒業とは名ばかりで、実際は、鉱山技師の資格など全く無かったのである。",
              "citation": {
                "source": "惜別",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）――読めますか、仮名ばかり。",
              "citation": {
                "source": "絵本の春",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "これといって行きたい場所も知りませんものですから、旅をするなら、名ばかりでも、聞いただけ懐しい、片原を、と存じまして、十月小春のいい時候に、もみじもさかり、と聞きました。",
              "citation": {
                "source": "神鷺之巻",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "それでいて門標を見れば、何処の誰だか分らない人の名ばかりじゃないの。",
              "citation": {
                "source": "かの女の朝",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "それが三方に分れて逃げたらしく、中之島公園へ逃げて来た連中はざっと三十名ばかり、差入れの着物や洋服などのいわゆる私服を持たぬ青い官服の囚人姿の者がその大半だったので、一眼見るなり拘置所からの脱走者だと判った。",
              "citation": {
                "source": "土曜夫人",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "名ばかりの亭主で、むなしく、日々が過ぎた。",
              "citation": {
                "source": "放浪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "物質諸般の性質を説明するには物質がすべて分子原子から成立していると考える事が必要なばかりでなく、また分子の実在はブラウン運動等からみてももはや疑い難い事である。",
              "citation": {
                "source": "物質とエネルギー",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "蝋燭にホヤをはめた燭台や手燭もあったが、これは明るさが不充分なばかりでなく、何となく一時の間に合せの燈火だというような気がする。",
              "citation": {
                "source": "石油ランプ",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "何だか細かい線で描いてある横物で、打見たところはモヤモヤと煙っているようなばかりだ。",
              "citation": {
                "source": "観画談",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "主人の批評に依れば、私の手紙やら日記やらの文章は、ただ真面目なばかりで、そうして感覚はひどく鈍いそうだ。",
              "citation": {
                "source": "十二月八日",
                "author": "太宰治",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
