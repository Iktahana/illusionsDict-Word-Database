          "literary": [
            {
              "text": "子供の菓子類では、菓子を賣るのか手藝品を賣るのか分らない物だらけである。",
              "citation": {
                "source": "折々の記",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "反省が足らない、努力が足らない、自重が足らない、すべて足らないものだらけだ！",
              "citation": {
                "source": "其中日記",
                "author": "種田山頭火",
                "note": "青空文庫"
              }
            },
            {
              "text": "「それに鏡も」「いや、鏡は要るまい」「何もかも、ないものだらけでござります。",
              "citation": {
                "source": "鳴門秘帖",
                "author": "船路の巻",
                "note": "青空文庫"
              }
            }
          ]
