        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "道がひろくなったところで、慶一は立ちどまり、右肩にひっかけていたナップザックをおろし、高志のソリッド・ステート11をひっぱりだして、スウィッチを入れ、またナップザックにもどした。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「クソ、近くで買物できれば、こんなにあわてなくてすんだのに」　腹立たしげにいって、高志が〈ライト・マイ・ファイア〉を流していたラジオのスウィッチをきり、ナップザックにしまった。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「でも……」「じゃ、おれのナップザックをもって」「そうしろ」　といいながら、高志が真新しいギンガムチェックの敷物をふりあげ、令子とじぶんにかぶせた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "「ああ、円海山までいってたら、いまごろ、ひでえことになってたな」　高志がナップザックからラジオを出し、ぬれていないことをたしかめ、スウィッチを入れると、グラス・ルーツの〈レッツ・リヴ・フォー・トゥデイ〉が飛びこんできた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "ハイガイっていうんですって」　高橋路子先生が補足をして、腰掛けにおいた赤いナップザックの口を開いた。",
              "citation": {
                "source": "45回転の夏",
                "author": "第２章　メリーゴーラウンド、１９６７年",
                "note": "青空文庫"
              }
            },
            {
              "text": "物体は衣服を纏っていなかったが、肩掛け鞄ないしナップザックを円錐状体幹部から下げていた。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "目指すものを取り出した後、下に降ろすのは困難だろうが、可動式の留め具を外套のカラーに引っ掛ければナップザックのように運べるだろう。",
              "citation": {
                "source": "時間からの影",
                "author": "H. P. ラヴクラフト　H.P.Lovecraft",
                "note": "青空文庫"
              }
            },
            {
              "text": "ＳＳＢトランシーバー、パソコン、テレビ、ビデオデッキの順に電源を切るとダンボール箱の中に手を突っ込み、皺くちゃになった青いナップザックを引っぱり出す。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "無線機から取りはずしたボードを中につめてナップザックを背負い、ＴＶ―３６０のスイッチを消してポケットに押し込む。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            },
            {
              "text": "隼人は机の上に置いてあるナップザックからボードを取り出し、押入から工作用具一式を準備するとビデオをつけっぱなしのまま作業に取りかかった。",
              "citation": {
                "source": "脳細胞日記",
                "author": "太田健一",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
