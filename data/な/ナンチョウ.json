[
  {
    "uuid": "1b24e2d8-a275-5018-9a06-847dcb6e0047",
    "entry": "南朝",
    "reading": {
      "primary": "なんちょう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
