[
  {
    "uuid": "3ad49f03-96e2-5bc4-a19e-4cc1c47f1dfd",
    "entry": "何事につけ",
    "reading": {
      "primary": "なにごとにつけ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
