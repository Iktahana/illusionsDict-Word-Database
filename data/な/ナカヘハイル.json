    "definitions": [
      {
        "index": 1,
        "gloss": "to go (come) inside",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "「御馳走さまで」と、案内者は水の礼を述べて、いよいよ裾野の中へ入る。",
              "citation": {
                "source": "雪中富士登山記",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "昭青年は苫を破り分けて早百合姫をその中へ入るよう促しました。",
              "citation": {
                "source": "鯉魚",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "雪枝耐らなく、サッと家の中へ入る。",
              "citation": {
                "source": "中村仲蔵",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "君江は侍に「少し待って下さい」と言って家の中へ入る。",
              "citation": {
                "source": "なりひら小僧",
                "author": "山中貞雄",
                "note": "青空文庫"
              }
            },
            {
              "text": "さて中へ入ると、戸が一ツ。",
              "citation": {
                "source": "畫の裡",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あ、あれはね（吼え按摩）と云つてね、矢來ぢや（鰯こ）とおんなじに不思議の中へ入るんだよ」「ふう」などと玄關で燒芋だつたものである。",
              "citation": {
                "source": "春着",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「この奥の知れない山の中へ入るのに、目標があの石ばかりじゃ分らんではないかね。",
              "citation": {
                "source": "薬草取",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "（御串戯で、中へ入ると、恐怖え、その亡くなった奥さんの骨があるんじゃありませんかい。",
              "citation": {
                "source": "唄立山心中一曲",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "町中に育ったわたくしはこういう賑わいの中へ入ると、自分の家にいるよりも自分の家に居ついた気持になり、寛いで燥ぎ度くて仕方がありません。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "池上の寮は、やゝその昔の俤をとゞめたものらしく、この人家櫛比の中に在ってはちっとも目立ちませんが、門の中へ入ると、もとは隅田川から鴎に混って小鴨がひょこり／＼と浮いて入って来たという、その水門口の跡の残っている池が中心で、石だけの中の島に、やゝ勾配のある柴の橋が架っております。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "中へ入ると広い前庭になっていて、一方には畑もあり、畑には葱の坊主と、大根の花がしどろもどろに咲き倒れています。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "この夜景の中に藍染橋と土橋の袂へ二口の片側町の口がつき、それが町中へ入るに従ってだん／＼家数の影は濃くなり、町家の群から抽んでて聳え立つ西隅の遊郭は煌々した灯を鏤めて怪物の棲む城のようです。",
              "citation": {
                "source": "生々流転",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "けれども、とうとう、ある日、アラジンは王さまの御殿の中へ入ることができました。",
              "citation": {
                "source": "アラビヤンナイト",
                "author": "一、アラジンとふしぎなランプ",
                "note": "青空文庫"
              }
            },
            {
              "text": "お幸ちやんが中へ入ると男は扉を仮に締めた。",
              "citation": {
                "source": "蛾",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "初枝「こゝですわ」庄平「どうも有難う（生徒Ａに）有難う（節子に）じゃ、失敬します」庄平、中へ入る。",
              "citation": {
                "source": "四つの都",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "室の中へ入ると防禦が出てきて立っていた。",
              "citation": {
                "source": "金鳳釵記",
                "author": "田中貢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "取っ手を回して、ホームズは中へ入る。",
              "citation": {
                "source": "まだらのひも",
                "author": "THE ADVENTURE OF THE SPECKLED BAND",
                "note": "青空文庫"
              }
            },
            {
              "text": "や、開けると、あの顔、――寝乱れた白い胸に、山蟻がぽっちり黒いぞ、と思うと、なぜか、この夜具へ寝るのは、少い主婦の懐中へ入るようで、心咎がしてならないので、しばらく考えていましたがね。",
              "citation": {
                "source": "星女郎",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ああ、そうです、」　金之助は話の糸の、乱れた苧環巻きかえし、「その、氷嚢をあけていた、厭な人影が中へ入る、ひとりでに扉が閉る。",
              "citation": {
                "source": "式部小路",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「否さ、景色がよくないから遊山に来ぬの、便利が悪いから旅の者が通行せぬのと、そんなつい通りのことぢやなくさ、私たちが聞いたのでは、此の野中へ入ることを、俗に身を投げると言ひ伝へて、無事にや帰られないんださうではないか。",
              "citation": {
                "source": "二世の契",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "この歪んだ階段を昇ると、倉庫の中へ入る。",
              "citation": {
                "source": "淫賣婦",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "お前は、俺達の仲間の間へ、そいつ等を※虫が腹ん中へ入るようにして棲わせておくんだ。",
              "citation": {
                "source": "牢獄の半日",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "『大清一統志』に、江南金竜池、深さ測られず、唐初その中から一馬出で、朝は郊坡を奔り騰り、夜は池中へ入る、尉遅敬徳これを捕えたと（巻八十）。",
              "citation": {
                "source": "十二支考",
                "author": "馬に関する民俗と伝説",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の挨拶もしないで、建物の中へ入ると、階段を勢よく馳け上ってしまった。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "飼主に追われて小舎の中へ入る豚のような恰好と心理とをもって、彼は自動車に乗せられた。",
              "citation": {
                "source": "犠牲者",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "」私は断崖の上に立つ所の亡びかけた森の中へ入ると、彼の女を詰問した。",
              "citation": {
                "source": "職工と微笑",
                "author": "松永延造",
                "note": "青空文庫"
              }
            },
            {
              "text": "わざわざ中へ入るにも及ばんじゃないか？",
              "citation": {
                "source": "五階の窓",
                "author": "合作の二",
                "note": "青空文庫"
              }
            },
            {
              "text": "又バスの中の湯は確に湯ではあるけれども、温度が低くて、中へ入るとひやりと冷い感じがした。",
              "citation": {
                "source": "南太平洋科學風土記",
                "author": "海野十三（佐野昌一）",
                "note": "青空文庫"
              }
            },
            {
              "text": "（甚兵衛、絶えず、にこにこしながら、矢来の中へ入る。",
              "citation": {
                "source": "義民甚兵衛",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            },
            {
              "text": "何の挨拶もしないで、建物の中へ入ると、階段を勢よく馳け上つてしまつた。",
              "citation": {
                "source": "真珠夫人",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
