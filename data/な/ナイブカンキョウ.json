        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "けれども、内部環境も亦物理化学的性質を有し、そこに起る生理現象は、物理化学現象に還元することができる。",
              "citation": {
                "source": "エミイル・ゾラの文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで、外部環境も、内部環境も換言すれば生物界の現象も無生物界の現象も、ひとしく因果関係によりて決定されてゐるといふことになる。",
              "citation": {
                "source": "エミイル・ゾラの文学方法論",
                "author": "平林初之輔",
                "note": "青空文庫"
              }
            },
            {
              "text": "ベルナールはこれに内部環境の概念を加えた。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            },
            {
              "text": "すべての生物は全体として外部環境を持っているがすべての細胞はその発達を決定する内部環境を持っている。",
              "citation": {
                "source": "文明と病気",
                "author": "Civilization And Disease (1943)",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
