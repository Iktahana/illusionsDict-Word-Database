        "examples": {
          "standard": [
            {
              "text": "かつて内供奉の僧侶は、宮中で仏事を行った。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "内供奉の職は、限られた高僧にのみ許された特別なものだった。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            },
            {
              "text": "歴史資料から、内供奉の僧たちの活動の一端がうかがえる。",
              "citation": {
                "source": "幻辭AI",
                "author": "Gemini",
                "note": "gemini-2.5-flash"
              }
            }
          ],
          "literary": [
            {
              "text": "長安醴泉寺僧内供奉翻経大徳として崇められたが、後、五台山に入って修道中、人のために殺されたというのであった。",
              "citation": {
                "source": "ドナウ源流行",
                "author": "齋藤茂吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "その死ぬる時に五台山停点普通院の壁上に左の手記あるを慈覚大師が発見せられた、「日本国内供奉翻経大徳霊仙元和十五年九月十五日到此蘭若」としてあった。",
              "citation": {
                "source": "東洋文化史における仏教の地位",
                "author": "高楠順次郎",
                "note": "青空文庫"
              }
            }
          ]
        }
