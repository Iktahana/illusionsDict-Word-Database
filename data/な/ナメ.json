[
  {
    "uuid": "f0a9995d-d9d5-57a7-a85d-9f1eb818377b",
    "entry": "縵面",
    "reading": {
      "primary": "なめ",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
        "名詞"
      ],
      "ctype": null,
      "inflections": null
    },
    "definitions": [
      {
        "index": 1,
        "gloss": "smooth unlettered back surface of an old \"zeni\" coin",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "みなつらなめて逃れゆく、黎明の林を出づる旅びとら、その足竝に音はなけれど、水ながれいでて靴のかかとをうるほせり。",
              "citation": {
                "source": "黎明と樹木",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "権威ある批評をしようと思ったら、まず、ご自分でも或る程度まで製作の苦労をなめてみる事ですね。",
              "citation": {
                "source": "炎天汗談",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "耕二のなめらかな頭の影が、真白な襖の面へ茫然浮き出てゐた。",
              "citation": {
                "source": "耕二のこと",
                "author": "中原中也",
                "note": "青空文庫"
              }
            },
            {
              "text": "遙か河下に星の如くまたたくは淺草の人家なめり。",
              "citation": {
                "source": "花あやめ",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "夏の暑い盛りだと下帯一つの丸裸で晩酌の膳の前にあぐらをかいて、渋団扇で蚊を追いながら実にうまそうに杯をなめては子供等を相手にして色々の話をするのが楽しみであったらしい。",
              "citation": {
                "source": "重兵衛さんの一家",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "腫物が、なほるばかりでなく、肌がなめらかになり色が白くなるかも知れない、と家の者に冗談を言ひ、靜かに横臥し、藥のききめを待つてゐました。",
              "citation": {
                "source": "知らない人",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんな井伏さんを見て、井伏さんを甘いなと、なめたら、悔いる事があるかも知れない。",
              "citation": {
                "source": "小照",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "落ちのびた私たちも、留守の両君も、現在の失業者のなめるのと、同じ悩みを味つたのはいふ迄も無い。",
              "citation": {
                "source": "遺言文学",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "浚渫船のデッキには、石油缶の七輪から石炭の煙が、いきなり風に吹き飛ばされて、下の方の穴からペロペロ、赤い焔が舌なめずりをして、飯の炊かれるのを待っていた。",
              "citation": {
                "source": "浚渫船",
                "author": "葉山嘉樹",
                "note": "青空文庫"
              }
            },
            {
              "text": "そうしてむしろかえってさんざん道楽をし尽くしたような中年以上のパトロンと辛酸をなめ尽くして来た芸妓との間の淡くして深い情交などにしばしば最も代表的なノルマールな形で実現されたもののようである。",
              "citation": {
                "source": "映画雑感（※）",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "その蛆がきれいに膿をなめつくしてきずが癒える。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "張ったばかりの天井にふんの砂子を散らしたり、馬の眼瞼をなめただらして盲目にする厄介ものとも見られていた。",
              "citation": {
                "source": "蛆の効用",
                "author": "寺田寅彦",
                "note": "青空文庫"
              }
            },
            {
              "text": "翁は興奮に駆られて自ら歓びをたしなめる下からまた盛り上る歓びにうたた反側しながら呟いた。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのようにこどもの山神たちにも秀でた性格の傍、叱りたしなめはするがそれによってまた憐れみがかかり懐き寄せられもする欠点なるものがあるのだったが。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "女の癖に」　山の祖神のこういうたしなめ方に対し福慈の女神はもう何ともいわなかった。",
              "citation": {
                "source": "富士",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "かの子　宜い理智から明快に生きる青年と時代のカスをなめてただ軽薄にその場その場の生活をするのと両方でしょうね。",
              "citation": {
                "source": "新時代女性問答",
                "author": "岡本かの子",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのなめらかな天井を、つぶつぶ暗い泡が流れて行きます。",
              "citation": {
                "source": "やまなし",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それは碧くなめらかに光ってゐた。",
              "citation": {
                "source": "あけがた",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "）実になめらかによるの気圏の底を猫が滑ってやって来る。",
              "citation": {
                "source": "猫",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "」その人は、あわてたのをごまかすように、わざとゆっくり、川をわたって、それから、アルプスの探険みたいな姿勢をとりながら、青い粘土と赤砂利の崖をななめにのぼって、せなかにしょった長いものをぴかぴかさせながら、上の豆畠へはいってしまった。",
              "citation": {
                "source": "さいかち淵",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "岩は何という円くなめらかに削られたもんだろう。",
              "citation": {
                "source": "台川",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "兵隊は一｜列になって、崖をななめに下り、中にはさきに黒い鉤のついた長い竿を持った人もありました。",
              "citation": {
                "source": "イギリス海岸",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "それも八月の末には、みんなめいめいの持主に戻ってしまうのです。",
              "citation": {
                "source": "種山ヶ原",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "「あたしどんなめにあってもいいから、おっかさんとこにいたいわ。",
              "citation": {
                "source": "いちょうの実",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "此坂を下りてあしこへ行きて暫時やすまん、つかれては話しも厭やなればと仰せあるに、さらば歸りたまふか、厭々、今しばし遊ばんとて、苔なめらかなる小道を下らるゝに、おあぶなしと言へば、氣のどくなれど其肩をかし給へとてつと寄りて此處を下りぬ。",
              "citation": {
                "source": "暗夜",
                "author": "一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "中禅寺の湖をながめて天雲のいはひもとほる湖の上に眞白片帆の舟歸る見ゆ歌袋歌滿ちあふるなめ革のかはり袋のありこせぬかも歌袋の歌は文して格堂にからかいやりしなり。",
              "citation": {
                "source": "滝見の旅",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "物語の中に「なめり」「あめり」と書いてありますが、これはこれまでの伝統的の読み方としては「ナンメリ」「アンメリ」と読んでいる。",
              "citation": {
                "source": "古代国語の音韻に就いて",
                "author": "橋本進吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "鈴虫はふり出てなく声のうつくしければ、物ねたみされて齢ひの短かきなめりと点頭かる。",
              "citation": {
                "source": "あきあはせ",
                "author": "樋口一葉",
                "note": "青空文庫"
              }
            },
            {
              "text": "およぐひとおよぐひとのからだはななめにのびる、二本の手はながくそろへてひきのばされる、およぐひとの心臓はくらげのやうにすきとほる、およぐひとの瞳はつりがねのひびきをききつつ、およぐひとのたましひは水のうへの月をみる。",
              "citation": {
                "source": "月に吠える",
                "author": "萩原朔太郎",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
