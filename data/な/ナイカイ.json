    "definitions": [
      {
        "index": 1,
        "gloss": "physician",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "三月に再度上京して、橋田内科医院に入院。",
              "citation": {
                "source": "長塚節句集",
                "author": "長塚節",
                "note": "青空文庫"
              }
            },
            {
              "text": "水船、酒船、料理船、青物船、小間物船、裁縫船、洗濯船、見世物船、蒸気風呂船、内科医船、外科医船、そのほか日常の事物坐ながらに用を弁ずべし。",
              "citation": {
                "source": "四百年後の東京",
                "author": "正岡子規",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのシャーロック・ホームズはドイルの師の何とかいう内科医をモデルにしたのであることは、その探偵小説「緋色の研究」（すなわち初めてシャーロック・ホームズの名を世に出したもの）の序に書いてある。",
              "citation": {
                "source": "科学的研究と探偵小説",
                "author": "小酒井不木",
                "note": "青空文庫"
              }
            },
            {
              "text": "医者で文化的に最も大きな存在は内科医入沢達吉博士だろう。",
              "citation": {
                "source": "日本の頭脳調べ",
                "author": "――特に自然科学者に就て――",
                "note": "青空文庫"
              }
            },
            {
              "text": "すなわち腹に宿っていた黒雷は腹一切の神（今日で云う内科医）であり、陰に宿っていた拆雷は云うまでもなく性殖神であり、左右の手足に宿っていた神は、とりもなおさず手足の神である。",
              "citation": {
                "source": "神州纐纈城",
                "author": "国枝史郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内科医が、獣医の家へ行ってお酒を飲んではいけませぬ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "しかし本職の内科医の斎藤さんが、どうしてソンナに過量の吐酒石酸を服用したのか。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "普通の内科医の処に在る吐酒石酸の瓶を見て見たまえ、高さ一寸かソコラの小さなものだ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちょうど内科医の処に在る酒石酸の瓶ぐらいあるんだ。",
              "citation": {
                "source": "無系統虎列剌",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "例えば患者が激しい腹痛を訴えた時、外科医は直ぐ盲腸炎だと考え、内科医は直ぐ胆石病だと考える、というような事がいわれている。",
              "citation": {
                "source": "血液型殺人事件",
                "author": "甲賀三郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "徳川時代には、お匕といえば、御殿医であることがわかり、医者が匕を投げたといえば病人が助からぬということであるし、匕を持つといえば内科医のことだった。",
              "citation": {
                "source": "田沢稲船",
                "author": "長谷川時雨",
                "note": "青空文庫"
              }
            },
            {
              "text": "「内科医としては」「いや、産科医としては」ということになつて、両方とも自説を固守しているので、そこで婦人の夫は、「ちよつと待つて下さい。",
              "citation": {
                "source": "笑について",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "八月十一日　月　Ａ、東洋内科医院のかえり、林町に来る。",
              "citation": {
                "source": "日記",
                "author": "一九二四年（大正十三年）",
                "note": "青空文庫"
              }
            },
            {
              "text": "内科医は、軽微な肋膜と診断した。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "内科医は、それはさうかも知れぬが、内科的に云へば、この容態では、なんとも致し方がない、と答へた。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "内科医は、それは貴下の御自由だが、自分には責任はもてぬ、といふ。",
              "citation": {
                "source": "空地利用",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この向うのサンタマリア病院の内科医ジョン・マクレオなんざ、ずいぶん奇怪な行動をしているじゃありませんか。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "あのジョン・マクレオという内科医が、そうなのか）と帆村は胸の中で自ら問い自ら答えた。",
              "citation": {
                "source": "人造人間事件",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "それから、長畑さん（柿沼内科医局長。",
              "citation": {
                "source": "わが精神の周囲",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "私の女房が長畑さん（東大柿沼内科医局長）をよんできた。",
              "citation": {
                "source": "小さな山羊の記録",
                "author": "坂口安吾",
                "note": "青空文庫"
              }
            },
            {
              "text": "そこで町内の本道（内科医）の玄庵さんに訊いてみますと、そのお医者の申すには、私もそれは不思議に思っているが、確かな証拠がないことを、差出がましく申出でて、世間を騒がせるわけには行かない。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "詭計の豆",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の本道（内科医）は病気は大した事はない、気の持ちようでは丈夫な身体になれると申しますが、本人は気が挫けて、寝たり起きたりでは、弱る一方でございます」　総右衛門の言葉には少しの暗い影もありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の本道（内科医）が、この娘の病気は大して重くはなかった。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "槍の折れ",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのうちに町内の本道（内科医）が来ました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "百四十四夜",
                "note": "青空文庫"
              }
            },
            {
              "text": "平次の熱は相変らず高く、町内の本道（内科医）は、この風邪は性質が悪いから、当分外へ出ては命に拘わるという脅かしようです。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "不死の霊薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "間もなく町内の本道（内科医）が、坊主頭に湯気を立てて飛んで来ましたが容体を一と眼見ると、「これは困ったことだ。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二服の薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "「そんな事はありませんよ、親分」「よしよし、物の譬えを言ったまでだ」　平次はそう言うと、四方に眼を配って、自分を取巻く家の中の空気への反応を調べている様子でしたが、大した事がなかったものか、その足ですぐ町内の本道（内科医）を訪ねました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二服の薬",
                "note": "青空文庫"
              }
            },
            {
              "text": "服部良庵という町内の本道（内科医）、頭を円めた五十年輩、黄八丈に縮緬の羽織といった、型のごとき風体です。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "二度死んだ男",
                "note": "青空文庫"
              }
            },
            {
              "text": "町内の本道（内科医）を呼んで見せると、岩見銀山の鼠捕りで死んだと判りましたが、食い物は店中同じですから、何か理由があって毒を飲んで自害したと見るの他はありません。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "路地の小判",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「ハイ、三人目の行方知らずになった本道（内科医）でございます」「それは大変」　これは平次の方が驚きました。",
              "citation": {
                "source": "銭形平次捕物控",
                "author": "兵糧丸秘聞",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
