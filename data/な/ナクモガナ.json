    "definitions": [
      {
        "index": 1,
        "gloss": "can be dispensed with",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
