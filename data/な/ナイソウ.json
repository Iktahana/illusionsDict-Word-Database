[
  {
    "uuid": "edfa561b-77d9-5282-a13e-6c7de016d0ca",
    "entry": "内奏",
    "reading": {
      "primary": "ないそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
