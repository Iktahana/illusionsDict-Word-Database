  {
    "uuid": "163acca0-f20a-5c9e-94fb-cd96db564a44",
    "entry": "内装",
    "reading": {
      "primary": "ないそう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
      "pos": [
