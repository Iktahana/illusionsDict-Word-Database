        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "そんなことまで何のかんの云うもんか。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "日日が延びると、世間では何のかんのと非難が聞え出す。",
              "citation": {
                "source": "探偵小説の魅力",
                "author": "南部修太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "そんなことまで何のかんの云ふもんか。",
              "citation": {
                "source": "二人の役人",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかんのといってて十年過ぐしてしまった。",
              "citation": {
                "source": "落穂",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "モウ担がれねえぞ」「ハアアア……アアア……何のかんのと言うてはみてもオ……抱いてみなけりゃあエエ……アハハ。",
              "citation": {
                "source": "少女地獄",
                "author": "夢野久作",
                "note": "青空文庫"
              }
            },
            {
              "text": "が、何のかんのと言ううちに、あすからはいよいよ放免の月だ。",
              "citation": {
                "source": "獄中消息",
                "author": "大杉栄",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「いんにゃ、お前さま、そんなことを言いなさっても、その手には乗りませんよ……何のかんのと言って……お前さまも妾を騙かそうと思っていなさるのでしょう。",
              "citation": {
                "source": "死せる魂",
                "author": "または　チチコフの遍歴　第一部　第二分冊",
                "note": "青空文庫"
              }
            },
            {
              "text": "そして何のかんのと世話をやくのが平三には却つて迷惑でならなかつた。",
              "citation": {
                "source": "厄年",
                "author": "加能作次郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかんのと差出がましいこと言うのを、俺の方の村では雌鶏めとき吹くって笑うんだ。",
              "citation": {
                "source": "米",
                "author": "犬田卯",
                "note": "青空文庫"
              }
            },
            {
              "text": "何のかんのと言って見たところで、弱い人達が生きている以上は、どうしてもそれを助けない訳にいかなかった。",
              "citation": {
                "source": "家（下巻）",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "まいにち、何千人だか何万人だか知らないけど、この絵の前に立ち止つてさ、やれ何のかんのつて、あたしの噂をするんだらう。",
              "citation": {
                "source": "喧嘩上手",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「品子かてよう何のかんの云うてたやないか。",
              "citation": {
                "source": "猫と庄造と二人のおんな",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "私立の女学校になると、事業家である校長先生は何のかんのと生徒に無心を仰せつける。",
              "citation": {
                "source": "思想と風俗",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "市町村議員は何のかんのと云って、之を匡救運動費（？",
              "citation": {
                "source": "現代日本の思想対立",
                "author": "戸坂潤",
                "note": "青空文庫"
              }
            },
            {
              "text": "―――折角連れて行って下さるって云うのに、何のかんのって文句を云うことはないじゃないか。",
              "citation": {
                "source": "蓼喰う虫",
                "author": "谷崎潤一郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "まして夜半の一時というのですから、無理もありませんがＭ医院ではいくら戸を叩いても、何のかんのと云って却々開けて呉れなかったらしいのです。",
              "citation": {
                "source": "赤い部屋",
                "author": "江戸川乱歩",
                "note": "青空文庫"
              }
            },
            {
              "text": "金蓮もまた今朝だけは何のかんのの文句もいわない。",
              "citation": {
                "source": "新・水滸伝",
                "author": "吉川英治",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしは、みんなにむかって、正直に、きみたちは、なんのかんのと言ったって、けっきょくは、人形にすぎないじゃないか、と、言ってやりました。",
              "citation": {
                "source": "人形つかい",
                "author": "ハンス・クリスチャン・アンデルセン　Hans Christian Andersen",
                "note": "青空文庫"
              }
            },
            {
              "text": "君は、なんのかんのと言いながらも、とにかく仕事をはじめる気になったじゃないか。",
              "citation": {
                "source": "風の便り",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "ところが、ある年の暮、いよいよ押し詰まって来たのにかかわらず、蔵元町人の平野屋ではなんのかんのと言って、一向に用達してくれない。",
              "citation": {
                "source": "勧善懲悪",
                "author": "織田作之助",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのかんの言ったって、わたしがいる気で少し気をつければ、わけはないですけど、なんだか知らんが、わたしの方で厭になっちまったんでさ。",
              "citation": {
                "source": "春の潮",
                "author": "伊藤左千夫",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのかんのと言うて、隊長急におじけづいたんですか！",
              "citation": {
                "source": "流行暗殺節",
                "author": "佐々木味津三",
                "note": "青空文庫"
              }
            },
            {
              "text": "ろくに二親の考えもしらないで居て近づけないのなんのかんのってったってまるで食べずぎらいみたいじゃあありませんかほんとうに。",
              "citation": {
                "source": "千世子（三）",
                "author": "宮本百合子",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのかんのと、しらばくれてはゐるけれど、大將がマッソンなことは一眼でちやんと睨んでゐらあ――だつて、その證據には、挨拶のために手を差し出す時、指を二本しか出さないぢやないか。",
              "citation": {
                "source": "狂人日記",
                "author": "ZAPISKI SUMASHEDSHAWO",
                "note": "青空文庫"
              }
            },
            {
              "text": "なんのかんのとはがてんがいかない。",
              "citation": {
                "source": "藪の鶯",
                "author": "三宅花圃",
                "note": "青空文庫"
              }
            },
            {
              "text": "」「僕はいままで探偵してきたことを続けてゆく方がいいと思うんだ」「なんのかんのというが、実はこわいのだろう。",
              "citation": {
                "source": "地中魔",
                "author": "海野十三",
                "note": "青空文庫"
              }
            },
            {
              "text": "旅先では、どうしたつて、やあ、なんのかんのと云つて……。",
              "citation": {
                "source": "百三十二番地の貸家",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            },
            {
              "text": "この上なんのかんのと選り好みをすることがあるもんですか、――あの人を貰ってください！",
              "citation": {
                "source": "真珠の首飾り",
                "author": "ZHEMCHUZHNOE OZHERELJE",
                "note": "青空文庫"
              }
            },
            {
              "text": "わたしをごらんなさい、みんなで寄ってたかっていろいろなことを言って、金華山沖のたいは、目の下一尺もあって、値がただみたようで、いいおさかなですことの、なんのかんのと、えらいお世話です。",
              "citation": {
                "source": "力餅",
                "author": "島崎藤村",
                "note": "青空文庫"
              }
            },
            {
              "text": "定臣　　（やがて）近頃はなんのかんのと、若いもんを煽てすぎる。",
              "citation": {
                "source": "富士はおまけ（ラヂオ・ドラマ）",
                "author": "岸田國士",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
