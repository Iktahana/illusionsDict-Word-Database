    "definitions": [
      {
        "index": 1,
        "gloss": "A Midsummer Night's Dream (comedy by William Shakespeare)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
