          "literary": [
            {
              "text": "当時私は金もないのに子供が生まれ、それが病身で泣き通す上に、絵はろくさま描けない、種々雑多のやけ糞から万事を母と細君にまかせて、この淋しい岩山の上へ逃げ出したのだった。",
              "citation": {
                "source": "めでたき風景",
                "author": "小出楢重",
                "note": "青空文庫"
              }
            },
            {
              "text": "小さい三つになる女の子などは、朝起きてからまず一時間は必ず泣き通す。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            },
            {
              "text": "慰めずに放っておけば三十分でも一時間でも泣き通す。",
              "citation": {
                "source": "ロザリオの鎖",
                "author": "永井隆",
                "note": "青空文庫"
              }
            }
          ]
        }
