      {
        "index": 1,
        "gloss": "part of the imperial palace where dancing girls were trained (Nara and Heian periods)",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
