    },
    "definitions": [
      {
        "index": 1,
        "gloss": "suffering",
        "register": "standard",
        "nuance": null,
        "scenarios": [],
        "sensory_tags": {
          "colors": [],
          "temperature": null,
          "sounds": [],
          "emotions": []
        },
        "collocations": [],
        "examples": {
          "standard": [],
          "literary": [
            {
              "text": "たいへん難渋の文章で、私は、おしまいまで読めなかった。",
              "citation": {
                "source": "音に就いて",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "御中道に昔は小舎がなくて、参詣の道者が難渋するため、そのうちの難所たる大沢に、お助け小舎を置いたそうだが、それは疾くにつぶれて、今のは粗末ながら、普通の旅人宿めいた小舎である。",
              "citation": {
                "source": "不尽の高根",
                "author": "小島烏水",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからがくがくして歩行くのが少し難渋になったけれども、ここで倒れては温気で蒸殺されるばかりじゃと、我身で我身を激まして首筋を取って引立てるようにして峠の方へ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "実を申すとここへ来る途中でもその事ばかり考える、蛇の橋も幸になし、蛭の林もなかったが、道が難渋なにつけても、汗が流れて心持が悪いにつけても、今更行脚もつまらない。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚に難渋な腫物があった、その療治を頼んだので。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "あゝ云ふ難渋な処にぶっつかっては全く損するより仕方ありません。",
              "citation": {
                "source": "化物丁場",
                "author": "宮沢賢治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼は首をすくめ、懐ろ手をしながら、落葉や朽葉とともにぬかるみになった粘土質の県道を、難渋し抜いて孵化場の方へと川沿いを溯っていった。",
              "citation": {
                "source": "星座",
                "author": "有島武郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "已むを得ずして悪い銀を造った、随って物価は騰貴した、市民は難渋した。",
              "citation": {
                "source": "一日一筆",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "○不景気のために難渋の者多ければとて、市川派の俳優が組織せる三升会は、七月七、八の二日間、新富座に慈善興行を催し、その純益金を東京府庁に寄附す。",
              "citation": {
                "source": "明治演劇年表",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "ちやうどその時分、都の近くの或橋が流され、人々が難渋してゐることを知つて、彼は橋をかける費用をあつめるため、人々の喜捨を請ひ歩いた。",
              "citation": {
                "source": "良寛物語　手毬と鉢の子",
                "author": "新美南吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "無上の不幸である」　冗漫と難渋とを恐れて、わざと大意｜丈を抄訳した此一節を読んで見ても、相手の軍国主義が何んな風に仏蘭西の思想界の一部に食ひ入りつゝあるかが解るだらう。",
              "citation": {
                "source": "点頭録",
                "author": "夏目漱石",
                "note": "青空文庫"
              }
            },
            {
              "text": "見た眼には、けわしそうでもあるが、こうして登ってみると、きちんきちんと足だまりができていて、さほど難渋でない。",
              "citation": {
                "source": "猿ヶ島",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "たいへん難渋の文章で、私は、おしまひまで読めなかつた。",
              "citation": {
                "source": "音について",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "彼の大臣は家に帰りて、もし我が父の知ることもやと例の密室に至りてこの由を述べけるに、そは難渋きことにあらず、軟※にして細きものを蛇に近づけてその躁ぐを雄と知り、静かなるを雌と知るべしと教へければ、大臣は急に王宮に行きてこの旨をいひ出で、試しみるに果してその言の如く、雄雌紛るるかたもあらず。",
              "citation": {
                "source": "印度の古話",
                "author": "幸田露伴",
                "note": "青空文庫"
              }
            },
            {
              "text": "もっとも迷惑をせば、いたせ、娘の親が人間同士の間でさえ、自分ばかりは、思い懸けない海の幸を、黄金の山ほど掴みましたに因って、他の人々の難渋ごときはいささか気にも留めませぬに、海のお世子であらせられます若様。",
              "citation": {
                "source": "海神別荘",
                "author": "泉鏡花",
                "note": "青空文庫"
              }
            },
            {
              "text": "そう呟いて、窓をぴたと閉め、それから難渋しながら、たわいない甘い物語を書き綴る。",
              "citation": {
                "source": "春の盗賊",
                "author": "太宰治",
                "note": "青空文庫"
              }
            },
            {
              "text": "乗円　大恩教王の御教は日月輪の如く明かれども、波羅密多の岸は遠く、鈍根痴愚の我等風情に求道の道は中々の難渋、それ故に互に諫め励まし、過あれば戒め懲らし、よしや歩は遅からうとも、いやさ精進懈怠はあるまいと、誓ひし言葉を覚えて居やるか。",
              "citation": {
                "source": "南蛮寺門前",
                "author": "木下杢太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "それからがく／″＼して歩行くのが少し難渋になつたけれども、此処で倒れては温気で蒸殺されるばかりぢやと、我身で我身を激まして首筋を取つて引立てるやうにして峠の方へ。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "実を申すと此処へ来る途中でも其の事ばかり考へる、蛇の橋も幸になし、蛭の林もなかつたが、道が難渋なにつけても汗が流れて心持が悪いにつけても、今更行脚も詰らない。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "脚に難渋な腫物があつた、其の療治を頼んだので。",
              "citation": {
                "source": "高野聖",
                "author": "泉鏡太郎",
                "note": "青空文庫"
              }
            },
            {
              "text": "作詩に就いては、眼疾最悪の時に当り、ほとほと難渋した。",
              "citation": {
                "source": "新頌",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "一つも難渋しなかつた。",
              "citation": {
                "source": "雀の卵",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "第四、第五の如きは、その推敲が十三年に亘つて、而も完成し得ぬ作の夥多があり、一首の中、僅かに一二音の為に難渋する若干もあつて、之等の整理は容易ではないのである。",
              "citation": {
                "source": "白南風",
                "author": "北原白秋",
                "note": "青空文庫"
              }
            },
            {
              "text": "そのお途中、倉橋山という険しい山をお越えになるときに、かよわい女鳥王はたいそうご難渋をなすって、夫の王のお手にすがりすがりして、やっと上までお上りになりました。",
              "citation": {
                "source": "古事記物語",
                "author": "鈴木三重吉",
                "note": "青空文庫"
              }
            },
            {
              "text": "今後は難渋な句の誤訳をも、もしどこかにあったら、発見して貰いたい。",
              "citation": {
                "source": "不苦心談",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "只蚊のうるさいのに難渋する。",
              "citation": {
                "source": "金貨",
                "author": "森鴎外",
                "note": "青空文庫"
              }
            },
            {
              "text": "」　とは言ったが、番頭は難渋らしい顔色をみせた。",
              "citation": {
                "source": "怪獣",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "万屋の伯父はお峰の詰問を受けてひどく難渋の顔色を見せたが、結局ため息まじりでこんな事を言い出した。",
              "citation": {
                "source": "経帷子の秘密",
                "author": "岡本綺堂",
                "note": "青空文庫"
              }
            },
            {
              "text": "負傷者も続出して行軍は難渋を極めている。",
              "citation": {
                "source": "李陵",
                "author": "中島敦",
                "note": "青空文庫"
              }
            },
            {
              "text": "若し総掛りに軍し給はゞ味方難渋仕り候はんか、今｜暫時敵の様を御覧ありて然るべきかと申しけるに、長政｜宣ふ様、横山の城の軍急なれば、其儘に見合せがたし。",
              "citation": {
                "source": "姉川合戦",
                "author": "菊池寛",
                "note": "青空文庫"
              }
            }
          ]
        }
      }
    ],
