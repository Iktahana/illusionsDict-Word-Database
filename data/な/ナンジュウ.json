[
  {
    "uuid": "1812682f-3dfb-543b-879d-9785af1d9e3f",
    "entry": "難渋",
    "reading": {
      "primary": "なんじゅう",
      "alternatives": [],
      "is_heteronym": false
    },
    "grammar": {
